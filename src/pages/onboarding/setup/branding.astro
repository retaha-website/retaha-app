---
import OnboardingLayout from '../../../layouts/OnboardingLayout.astro';
import { t } from '../../../i18n/helpers';
import { getUser, createSupabaseServerInstance } from '../../../lib/auth';
import type { AdminLocale } from '../../../i18n/types';

const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

// Slug-Helper
function slugify(input: string): string {
  return input
    .toLowerCase()
    .replace(/[äöü]/g, c => ({ ä: 'ae', ö: 'oe', ü: 'ue' }[c] ?? c))
    .replace(/ß/g, 'ss')
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 50);
}

let errorMessage: string | null = null;
let formData: Record<string, string> = {
  hotel_name: Astro.url.searchParams.get('hotel_name') ?? '',
  street: Astro.url.searchParams.get('street') ?? '',
  zip: Astro.url.searchParams.get('zip') ?? '',
  city: Astro.url.searchParams.get('city') ?? '',
  color: Astro.url.searchParams.get('color') ?? 'var(--theme-accent)',
};

// Wenn aus Schritt 1 frisch + Daten fehlen → zurück
if (Astro.request.method === 'GET' && (!formData.hotel_name || !formData.street || !formData.zip || !formData.city)) {
  return Astro.redirect('/onboarding/setup/hotel?error=missing_data');
}

// Error-Param aus Redirects
const errorParam = Astro.url.searchParams.get('error');
if (errorParam === 'db_failed') {
  errorMessage = t('onboarding.setup.error_db_failed', userLocale);
}

// POST: DB-INSERT + Redirect zu Done
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('_action')?.toString() ?? 'continue';

  formData = {
    hotel_name: (data.get('hotel_name')?.toString() ?? '').trim(),
    street: (data.get('street')?.toString() ?? '').trim(),
    zip: (data.get('zip')?.toString() ?? '').trim(),
    city: (data.get('city')?.toString() ?? '').trim(),
    color: action === 'skip' ? 'var(--theme-accent)' : (data.get('color')?.toString() ?? 'var(--theme-accent)').trim(),
  };

  if (!formData.hotel_name || !formData.street || !formData.zip || !formData.city) {
    return Astro.redirect('/onboarding/setup/hotel?error=missing_data');
  }

  const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

  // Slug-Collision-Check (RLS lässt fresh User nur eigene hotels sehen — bei
  // cross-user-Kollision fängt der UNIQUE-Constraint im RPC den Error)
  let slug = slugify(formData.hotel_name);
  if (!slug) slug = 'hotel';
  const { data: existing } = await client.from('hotels').select('slug').eq('slug', slug).maybeSingle();
  if (existing) {
    slug = `${slug}-${Date.now().toString(36)}`;
  }

  // Atomare Hotel-Anlage via SECURITY DEFINER RPC.
  // Umgeht das RLS-Chicken-and-Egg von INSERT...RETURNING (siehe Migration
  // 20260524_onboarding_phase8e_hotel_rpc.sql). Auth-Gate via auth.uid() in der Function.
  const { error: rpcError } = await client.rpc('create_hotel_with_owner', {
    p_slug: slug,
    p_name: formData.hotel_name,
    p_city: formData.city,
    p_default_language: userLocale,
    p_accent_color: formData.color,
  });

  if (rpcError) {
    console.error('[setup-wizard] create_hotel_with_owner failed:', {
      message: rpcError.message,
      code: rpcError.code,
      details: rpcError.details,
      hint: rpcError.hint,
    });
    const params = new URLSearchParams({ ...formData, error: 'db_failed' });
    return Astro.redirect(`/onboarding/setup/branding?${params.toString()}`);
  }

  return Astro.redirect('/onboarding/setup/done');
}
---

<OnboardingLayout title={t('onboarding.setup.step2_page_title', userLocale)} locale={userLocale}>
  <main class="onboarding-wizard-page">

    <section class="onboarding-wizard-strip">
      <div class="onboarding-wizard-strip-inner">
        <div class="onboarding-wizard-progress">
          <div class="onboarding-wizard-progress-markers" aria-hidden="true">
            <span class="onboarding-wizard-progress-marker onboarding-wizard-progress-marker--circle is-active"></span>
            <span class="onboarding-wizard-progress-line is-active"></span>
            <span class="onboarding-wizard-progress-marker onboarding-wizard-progress-marker--triangle is-active is-current"></span>
            <span class="onboarding-wizard-progress-line"></span>
            <span class="onboarding-wizard-progress-marker onboarding-wizard-progress-marker--square"></span>
          </div>
          <p class="onboarding-wizard-progress-label">— {t('onboarding.setup.step2_progress', userLocale)} —</p>
        </div>
        <p class="onboarding-wizard-brand">retaha</p>
      </div>
    </section>

    <section class="onboarding-wizard-form-wrapper">
      <form method="POST" class="onboarding-wizard-form">

        <p class="onboarding-wizard-eyebrow">— {t('onboarding.setup.step2_eyebrow', userLocale)} —</p>
        <h1 class="onboarding-wizard-headline">
          <span class="onboarding-wizard-headline-light">{t('onboarding.setup.step2_headline_light', userLocale)} </span>
          <span class="onboarding-wizard-headline-bold">{t('onboarding.setup.step2_headline_bold', userLocale)}<span class="onboarding-wizard-headline-punkt">.</span></span>
        </h1>

        {errorMessage && <p class="onboarding-wizard-field-error" style="margin-bottom: 18px;">{errorMessage}</p>}

        <!-- Hidden: Schritt-1-Daten weitergeben -->
        <input type="hidden" name="hotel_name" value={formData.hotel_name} />
        <input type="hidden" name="street" value={formData.street} />
        <input type="hidden" name="zip" value={formData.zip} />
        <input type="hidden" name="city" value={formData.city} />

        <!-- Logo (Platzhalter) -->
        <div class="onboarding-wizard-field">
          <p class="onboarding-wizard-field-eyebrow">— {t('onboarding.setup.field_logo', userLocale)} —</p>
          <div class="onboarding-wizard-logo-dropzone is-placeholder" aria-disabled="true">
            <p class="onboarding-wizard-logo-dropzone-text">{t('onboarding.setup.logo_placeholder_text', userLocale)}</p>
            <p class="onboarding-wizard-logo-dropzone-hint">{t('onboarding.setup.logo_placeholder_hint', userLocale)}</p>
          </div>
        </div>

        <!-- Akzentfarbe -->
        <div class="onboarding-wizard-field">
          <p class="onboarding-wizard-field-eyebrow">— {t('onboarding.setup.field_color', userLocale)} —</p>
          <div class="onboarding-wizard-color-input">
            <div class="onboarding-wizard-color-swatch" style={`background-color: ${formData.color}`}></div>
            <input
              type="text"
              name="color"
              value={formData.color}
              pattern="^#[0-9A-Fa-f]{6}$"
              class="bauhaus-input"
            />
          </div>
          <p class="onboarding-wizard-field-help">{t('onboarding.setup.color_hint', userLocale)}</p>
        </div>

        <div class="onboarding-wizard-actions onboarding-wizard-actions--triple">
          <a
            href={`/onboarding/setup/hotel?${new URLSearchParams({ hotel_name: formData.hotel_name, street: formData.street, zip: formData.zip, city: formData.city }).toString()}`}
            class="onboarding-wizard-back-link"
          >
            ← {t('onboarding.setup.cta_back', userLocale)}
          </a>

          <button type="submit" name="_action" value="skip" class="onboarding-wizard-skip-link">
            {t('onboarding.setup.cta_skip', userLocale)} →
          </button>

          <button type="submit" name="_action" value="continue" class="bauhaus-button bauhaus-button--primary">
            {t('onboarding.setup.cta_complete', userLocale)} →
          </button>
        </div>

      </form>
    </section>

  </main>
</OnboardingLayout>
