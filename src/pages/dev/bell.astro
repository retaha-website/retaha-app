---
import Bell from '../../components/Bell.astro';

const states = ['resting', 'ringing', 'waiting', 'sleeping', 'joyful', 'ready', 'discreet', 'alert'] as const;
const sizes = ['xs', 'sm', 'md', 'lg', 'xl'] as const;
const colors = ['burgund', 'bone', 'anthrazit'] as const;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bell — Dev-Test</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-bone: #FAF8F2;
        --color-stein: #E8E4DD;
        --color-burgund: #8C2128;
        --color-anthrazit: #1A1A1A;
      }
      body {
        margin: 0;
        background: var(--color-bone);
        color: var(--color-anthrazit);
        font-family: 'Inter', sans-serif;
        padding: 40px;
      }
      h1, h2 {
        font-weight: 300;
        letter-spacing: -0.02em;
        margin: 0 0 16px 0;
      }
      h1 { font-size: 32px; }
      h2 { font-size: 20px; margin-top: 48px; }
      .grid {
        display: grid;
        gap: 24px;
        grid-template-columns: repeat(4, 1fr);
      }
      .cell {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 20px;
        border: 1px solid rgba(26, 26, 26, 0.1);
      }
      .cell--bone { background: var(--color-bone); }
      .cell--stein { background: var(--color-stein); }
      .cell--burgund { background: var(--color-burgund); color: var(--color-bone); }
      .cell--anthrazit { background: var(--color-anthrazit); color: var(--color-bone); }
      .label { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.7; }
      .size-row { display: flex; align-items: end; gap: 24px; padding: 24px 0; flex-wrap: wrap; }
    </style>
  </head>
  <body>
    <h1>Bell — 8 States</h1>
    <p style="font-family: Georgia, serif; font-style: italic; opacity: 0.6;">
      Burgund auf Bone — der Standard-Fall.
    </p>
    <div class="grid">
      {states.map(state => (
        <div class="cell cell--bone">
          <Bell state={state} size="md" color="burgund" />
          <span class="label">{state}</span>
        </div>
      ))}
    </div>

    <h2>Bone auf Burgund — Trial-Banner-Kontext</h2>
    <div class="grid">
      {states.map(state => (
        <div class="cell cell--burgund">
          <Bell state={state} size="md" color="bone" />
          <span class="label">{state}</span>
        </div>
      ))}
    </div>

    <h2>Bone auf Anthrazit — Critical-Kontext</h2>
    <div class="grid">
      {states.map(state => (
        <div class="cell cell--anthrazit">
          <Bell state={state} size="md" color="bone" />
          <span class="label">{state}</span>
        </div>
      ))}
    </div>

    <h2>Größen-Skala — resting in Burgund</h2>
    <div class="size-row">
      {sizes.map(size => (
        <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
          <Bell state="resting" size={size} color="burgund" />
          <span class="label">{size}</span>
        </div>
      ))}
    </div>

    <h2>Farb-Matrix — resting in 3 Farben</h2>
    <div class="grid" style="grid-template-columns: repeat(3, 1fr);">
      {colors.map(color => (
        <div class={`cell ${color === 'bone' ? 'cell--anthrazit' : 'cell--bone'}`}>
          <Bell state="resting" size="md" color={color} />
          <span class="label">{color}</span>
        </div>
      ))}
    </div>

    <p style="margin-top: 60px; font-family: Georgia, serif; font-style: italic; opacity: 0.5; font-size: 13px;">
      Diese Seite ist ein Dev-Hilfsmittel — kann nach 8.F-Abnahme gelöscht werden.
    </p>
  </body>
</html>
