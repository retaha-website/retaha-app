---
// Sprint E3 Phase 1 — Service-Anfragen (Stub)
//
// Phase 4 baut den Bestätigen/Ablehnen-Flow inkl. Mews-Push falls vorhanden.

import AppLayout from '../../layouts/AppLayout.astro';
import { getUser, getUserHotels } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
---

<AppLayout title="Service-Anfragen" hotel={hotel} user={{ email: user.email ?? '' }}>
  <header class="app-page-header">
    <p class="app-page-eyebrow">— Operations —</p>
    <h1 class="app-page-title">Service-Anfragen.</h1>
  </header>

  <div class="app-stub">
    <p class="app-stub-eyebrow">— Phase 4 —</p>
    <p class="app-stub-text">Bestätigen/Ablehnen-Flow für pending Service-Bookings, mit Eve-Audit-Context bei Eve-gebuchten Anfragen.</p>
  </div>

  <style>
    .app-page-header { margin-bottom: 32px; }
    .app-page-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(26, 26, 26, 0.45); margin: 0 0 8px; }
    .app-page-title { font-size: 28px; font-weight: 300; letter-spacing: -0.01em; margin: 0; color: #1A1A1A; }
    .app-stub { padding: 32px 24px; background: #fff; border: 1px dashed #e0e0e0; text-align: center; }
    .app-stub-eyebrow { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #FF4A82; margin: 0 0 8px; }
    .app-stub-text { font-size: 14px; color: rgba(26, 26, 26, 0.55); margin: 0; }
  </style>
</AppLayout>
