---
// Sprint E3 Phase 6 — Print-Layout für QR-Bogen
//
// Pragma: Print-CSS statt PDF-Lib. Hotelier nutzt Browser-Print → "Als PDF
// speichern" oder direkt drucken. Funktioniert plattformübergreifend ohne
// extra Deps.
//
// Modes:
//   ?mode=rooms (default) → A4-Grid 3×4 = 12 QRs/Seite mit Zimmer-Nummer +
//                           room_code zum Ausschneiden
//   ?mode=tisch           → Hotel-weiter QR als Tischaufsteller (groß, mit
//                           Hotel-Name + Tagline für Rezeption/Lobby)
//
// Nicht in AppLayout — Print-Page soll Header/Sidebar nicht zeigen.

import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../lib/auth';
import { getGuestBaseUrl, buildGuestStayUrl, buildGuestRoomUrl } from '../../../lib/qr/base-url';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const url = new URL(Astro.request.url);
const mode = url.searchParams.get('mode') === 'tisch' ? 'tisch' : 'rooms';

// Hotel-weit (immer geladen — auch für rooms-Mode als Header-QR auf jedem Bogen)
const { data: firstStay } = await client
  .from('stays')
  .select('access_token')
  .eq('hotel_id', hotel.id)
  .in('state', ['Confirmed', 'Started'])
  .not('access_token', 'is', null)
  .order('check_in', { ascending: true })
  .limit(1)
  .maybeSingle();

const hotelTargetUrl = firstStay?.access_token ? buildGuestStayUrl(firstStay.access_token, Astro.request.url) : null;
const baseUrl = getGuestBaseUrl(Astro.request.url);

// Rooms (nur bei mode=rooms relevant)
const { data: rooms } = mode === 'rooms' ? await client
  .from('rooms')
  .select('id, room_code, room_number, room_name')
  .eq('hotel_id', hotel.id)
  .eq('is_active', true)
  .not('room_code', 'is', null)
  .order('room_number', { ascending: true })
: { data: [] };

const roomsList = rooms ?? [];
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{hotel.name} · QR-{mode === 'tisch' ? 'Tischaufsteller' : 'Bogen'} · Druckansicht</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Toolbar (nur Bildschirm) -->
  <div class="toolbar no-print">
    <div class="toolbar-inner">
      <div>
        <p class="toolbar-eyebrow">Druckansicht — {hotel.name}</p>
        <p class="toolbar-mode">{mode === 'tisch' ? 'Tischaufsteller (Hotel-weit)' : `Zimmer-Bogen — ${roomsList.length} QRs`}</p>
      </div>
      <div class="toolbar-actions">
        <a href={`/app/qr/print?mode=${mode === 'tisch' ? 'rooms' : 'tisch'}`} class="tb-btn tb-btn--secondary">
          Wechsel zu {mode === 'tisch' ? 'Zimmer-Bogen' : 'Tischaufsteller'}
        </a>
        <a href="/app/qr" class="tb-btn tb-btn--ghost">← zurück</a>
        <button type="button" onclick="window.print()" class="tb-btn tb-btn--primary">🖨 Drucken / Als PDF speichern</button>
      </div>
    </div>
    <p class="toolbar-hint">Tipp: Im Browser-Druck-Dialog „Hintergrundgrafiken drucken" aktivieren und „Ränder: Minimum" wählen. Als PDF speichern: Drucker → „In Datei speichern (PDF)".</p>
  </div>

  <!-- Print-Inhalt -->
  {mode === 'tisch' ? (
    <section class="tisch-sheet">
      {hotelTargetUrl ? (
        <div class="tisch-card">
          <p class="tisch-eyebrow">{hotel.name}</p>
          <h1 class="tisch-headline">Willkommen.</h1>
          <p class="tisch-sub">Scannen für WLAN, Frühstück, Empfehlungen & mehr.</p>
          <div class="tisch-qr-wrap">
            <img src={`/api/qr/hotel/${hotel.id}?format=svg`} alt="Hotel-QR" class="tisch-qr" />
          </div>
          <p class="tisch-foot">retaha · Ihr digitaler Gastgeber</p>
        </div>
      ) : (
        <div class="empty">Kein aktiver Stay mit access_token — kein Hotel-QR möglich.</div>
      )}
    </section>
  ) : (
    <section class="rooms-sheet">
      {roomsList.length === 0 ? (
        hotelTargetUrl ? (
          <div class="rooms-fallback">
            <p class="fallback-eyebrow">— Hinweis —</p>
            <p class="fallback-text">
              Aktuell keine Räume mit <code>room_code</code> verfügbar
              (Mews-Room-Bug — Backlog). Stattdessen wird der Hotel-weite QR gedruckt.
            </p>
            <div class="single-qr">
              <p class="single-name">{hotel.name}</p>
              <img src={`/api/qr/hotel/${hotel.id}?format=svg`} alt="Hotel-QR" class="single-qr-image" />
              <p class="single-url">{hotelTargetUrl}</p>
            </div>
          </div>
        ) : (
          <div class="empty">Weder Räume mit room_code noch aktiver Stay — nichts zu drucken.</div>
        )
      ) : (
        <div class="rooms-grid">
          {roomsList.map((r: any) => (
            <article class="room-cell">
              <div class="room-cell-head">
                <p class="room-cell-hotel">{hotel.name}</p>
                <p class="room-cell-room">Zimmer {r.room_number || '—'}</p>
                {r.room_name && <p class="room-cell-name">{r.room_name}</p>}
              </div>
              <img src={`/api/qr/room/${r.room_code}?format=svg`} alt={`QR ${r.room_number}`} class="room-cell-qr" />
              <p class="room-cell-scan">Scannen für WLAN, Frühstück & Service</p>
              <p class="room-cell-code">{r.room_code}</p>
            </article>
          ))}
        </div>
      )}
    </section>
  )}

  <style is:global>
    :root { color-scheme: light; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: #f5f5f5; font-family: 'Space Grotesk', system-ui, sans-serif; color: #1A1A1A; }

    /* Toolbar (Screen-only) */
    .toolbar { background: #fff; border-bottom: 1px solid #e0e0e0; padding: 16px 24px; position: sticky; top: 0; z-index: 10; }
    .toolbar-inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; max-width: 1200px; margin: 0 auto; }
    .toolbar-eyebrow { margin: 0; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(26,26,26,.5); }
    .toolbar-mode { margin: 4px 0 0; font-size: 16px; font-weight: 500; }
    .toolbar-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .toolbar-hint { margin: 12px auto 0; max-width: 1200px; font-size: 12px; color: rgba(26,26,26,.55); }
    .tb-btn { padding: 8px 14px; font-size: 13px; font-weight: 500; border: 1px solid; text-decoration: none; cursor: pointer; background: transparent; color: #1A1A1A; }
    .tb-btn--primary { background: #FF4A82; color: #fff; border-color: #FF4A82; }
    .tb-btn--primary:hover { background: #e63d72; }
    .tb-btn--secondary { border-color: #ddd; }
    .tb-btn--secondary:hover { background: #f5f5f5; }
    .tb-btn--ghost { border-color: transparent; color: rgba(26,26,26,.55); }
    .tb-btn--ghost:hover { color: #1A1A1A; }

    .empty { padding: 60px 24px; text-align: center; color: rgba(26,26,26,.55); font-style: italic; }

    /* ── Zimmer-Bogen ───────────────────────────────────────── */
    .rooms-sheet { max-width: 21cm; margin: 24px auto; background: #fff; padding: 1cm; box-shadow: 0 4px 24px rgba(0,0,0,.06); }
    .rooms-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8mm; }
    .room-cell { border: 1px dashed rgba(26,26,26,.25); padding: 10mm 6mm; display: flex; flex-direction: column; align-items: center; text-align: center; min-height: 0; break-inside: avoid; page-break-inside: avoid; }
    .room-cell-head { margin-bottom: 4mm; }
    .room-cell-hotel { margin: 0; font-size: 9pt; color: rgba(26,26,26,.55); letter-spacing: 0.05em; }
    .room-cell-room { margin: 2mm 0 0; font-size: 14pt; font-weight: 500; color: #1A1A1A; }
    .room-cell-name { margin: 1mm 0 0; font-size: 9pt; color: rgba(26,26,26,.65); }
    .room-cell-qr { display: block; width: 40mm; height: 40mm; margin: 2mm 0; }
    .room-cell-scan { margin: 3mm 0 0; font-size: 8pt; color: rgba(26,26,26,.65); }
    .room-cell-code { margin: 2mm 0 0; font-size: 7pt; font-family: 'JetBrains Mono', monospace; color: rgba(26,26,26,.45); }

    .rooms-fallback { padding: 30mm 20mm; text-align: center; }
    .fallback-eyebrow { font-size: 10pt; letter-spacing: 0.18em; text-transform: uppercase; color: #b45309; margin: 0 0 8mm; }
    .fallback-text { font-size: 11pt; color: rgba(26,26,26,.7); max-width: 14cm; margin: 0 auto 12mm; line-height: 1.5; }
    .fallback-text code { background: rgba(26,26,26,.06); padding: 1mm 2mm; font-family: 'JetBrains Mono', monospace; font-size: 9pt; }
    .single-qr { display: flex; flex-direction: column; align-items: center; gap: 4mm; }
    .single-name { margin: 0; font-size: 14pt; font-weight: 500; }
    .single-qr-image { width: 70mm; height: 70mm; }
    .single-url { margin: 0; font-size: 8pt; font-family: 'JetBrains Mono', monospace; color: rgba(26,26,26,.5); word-break: break-all; max-width: 14cm; }

    /* ── Tischaufsteller ───────────────────────────────────── */
    .tisch-sheet { max-width: 21cm; margin: 24px auto; background: #fff; padding: 0; box-shadow: 0 4px 24px rgba(0,0,0,.06); }
    .tisch-card { padding: 20mm 15mm; text-align: center; min-height: 28cm; display: flex; flex-direction: column; justify-content: center; }
    .tisch-eyebrow { margin: 0; font-size: 14pt; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,26,26,.55); }
    .tisch-headline { margin: 8mm 0 4mm; font-size: 48pt; font-weight: 300; letter-spacing: -0.02em; color: #1A1A1A; }
    .tisch-sub { margin: 0 0 12mm; font-size: 14pt; color: rgba(26,26,26,.7); max-width: 12cm; margin-left: auto; margin-right: auto; line-height: 1.4; }
    .tisch-qr-wrap { display: flex; justify-content: center; margin: 0 0 12mm; }
    .tisch-qr { width: 110mm; height: 110mm; }
    .tisch-foot { margin: 0; font-size: 10pt; color: rgba(26,26,26,.4); letter-spacing: 0.1em; }

    /* ── Print-Adjustments ─────────────────────────────────── */
    @page { size: A4 portrait; margin: 0; }
    @media print {
      .no-print { display: none !important; }
      html, body { background: #fff; }
      .rooms-sheet, .tisch-sheet { margin: 0; max-width: none; box-shadow: none; width: 21cm; }
      .rooms-sheet { padding: 1cm; }
      .rooms-grid { grid-template-columns: repeat(3, 1fr); gap: 6mm; }
      .room-cell { padding: 7mm 4mm; }
      .tisch-card { min-height: 29.7cm; }
      /* Browser-default: Hintergrundfarben aus — wir nutzen sowieso #fff. SVG-QR-dark
         ist als attribute gesetzt, druckt also auch ohne "Hintergrundgrafiken". */
    }
  </style>
</body>
</html>
