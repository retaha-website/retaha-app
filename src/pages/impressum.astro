---
import '../styles/global.css';
import '../styles/components/legal.css';
import { t } from '../i18n/helpers';
import type { AdminLocale } from '../i18n/types';

const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;
---

<!DOCTYPE html>
<html lang={userLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t('legal.impressum', userLocale)} · retaha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased text-anthrazit bg-white min-h-screen">

    <main class="legal-page">
      <a href="/admin/login" class="legal-page-back">← {t('legal.back_to_login', userLocale)}</a>

      <p class="legal-page-eyebrow">— {t('legal.impressum_eyebrow', userLocale)} —</p>
      <h1 class="legal-page-headline">
        {t('legal.impressum_headline_light', userLocale)}<br />
        <span class="legal-page-headline-bold">{t('legal.impressum_headline_bold', userLocale)}<span class="legal-page-headline-punkt">.</span></span>
      </h1>

      <div class="legal-page-content">
        <p>{t('legal.impressum_placeholder_intro', userLocale)}</p>
        <p>{t('legal.impressum_placeholder_link', userLocale)}</p>

        <h2>retaha GmbH</h2>
        <p>{t('legal.impressum_company_address', userLocale)}</p>

        <p><em>{t('legal.impressum_pending', userLocale)}</em></p>
      </div>
    </main>

  </body>
</html>
