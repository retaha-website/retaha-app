---
// Sprint E4 · Phase 5 — Eve-Persönlichkeits-Settings
//
// /admin/eve/settings — Master-Switch, Name, Tonalität, Online-bis, Tuning-Rules.
// Anrede (Du/Sie) wird aus hotel_settings.guest_address_form gelesen, read-only
// hier — Hotelier ändert das in /admin/settings (Allgemein).

import AdminLayout from '../../../components/AdminLayout.astro';
import EditorialPageHeader from '../../../components/admin/EditorialPageHeader.astro';
import EveSubNav from '../../../components/admin/EveSubNav.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../lib/auth';

interface TuningRule {
  trigger: string;
  instruction?: string;
  force_model?: 'haiku' | 'sonnet';
}

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

// ─── POST-Handlers ──────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'toggle_enabled') {
    const enabled = form.get('eve_enabled')?.toString() === 'true';
    const { error } = await client
      .from('hotel_settings')
      .update({ eve_enabled: enabled, updated_at: new Date().toISOString() })
      .eq('hotel_id', hotel.id);
    if (error) message = { type: 'error', text: `Toggle fehlgeschlagen: ${error.message}` };
    else message = { type: 'success', text: enabled ? 'Eve ist jetzt für deine Gäste aktiv.' : 'Eve ist deaktiviert.' };
  }

  else if (action === 'save_persona') {
    const name = form.get('eve_name')?.toString().trim();
    const tonality = form.get('eve_tonality')?.toString();
    const customPersona = form.get('eve_custom_persona')?.toString().trim() || null;
    const onlineUntil = form.get('eve_online_until')?.toString() || null;

    if (!name) {
      message = { type: 'error', text: 'Name darf nicht leer sein.' };
    } else if (!['warm_formal', 'casual', 'custom'].includes(tonality ?? '')) {
      message = { type: 'error', text: 'Ungültige Tonalität.' };
    } else if (tonality === 'custom' && !customPersona) {
      message = { type: 'error', text: 'Bei "Eigene Beschreibung" musst du den Persona-Text ausfüllen.' };
    } else {
      const { error } = await client
        .from('hotel_settings')
        .update({
          eve_name: name,
          eve_tonality: tonality,
          eve_custom_persona: tonality === 'custom' ? customPersona : null,
          eve_online_until: onlineUntil,
          updated_at: new Date().toISOString(),
        })
        .eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
      else message = { type: 'success', text: 'Persönlichkeit gespeichert.' };
    }
  }

  else if (action === 'tuning_rule_add' || action === 'tuning_rule_update' || action === 'tuning_rule_delete') {
    // Tuning-Rules sind JSONB-Array — wir lesen, mutieren, schreiben zurück.
    const { data: settings } = await client
      .from('hotel_settings')
      .select('eve_tuning_rules')
      .eq('hotel_id', hotel.id)
      .maybeSingle();
    const currentRules: TuningRule[] = (settings?.eve_tuning_rules as TuningRule[]) ?? [];

    let newRules: TuningRule[] = [...currentRules];

    if (action === 'tuning_rule_add') {
      const trigger = form.get('trigger')?.toString().trim();
      const instruction = form.get('instruction')?.toString().trim() || undefined;
      const forceModelRaw = form.get('force_model')?.toString();
      const force_model = (forceModelRaw === 'haiku' || forceModelRaw === 'sonnet') ? forceModelRaw : undefined;

      if (!trigger || !instruction) {
        message = { type: 'error', text: 'Trigger und Instruction sind Pflichtfelder.' };
      } else {
        newRules.push({ trigger, instruction, ...(force_model && { force_model }) });
      }
    }
    else if (action === 'tuning_rule_delete') {
      const indexStr = form.get('rule_index')?.toString();
      const idx = indexStr ? parseInt(indexStr, 10) : -1;
      if (idx < 0 || idx >= currentRules.length) {
        message = { type: 'error', text: 'Ungültiger Index.' };
      } else {
        newRules = currentRules.filter((_, i) => i !== idx);
      }
    }
    else if (action === 'tuning_rule_update') {
      const indexStr = form.get('rule_index')?.toString();
      const idx = indexStr ? parseInt(indexStr, 10) : -1;
      const trigger = form.get('trigger')?.toString().trim();
      const instruction = form.get('instruction')?.toString().trim() || undefined;
      const forceModelRaw = form.get('force_model')?.toString();
      const force_model = (forceModelRaw === 'haiku' || forceModelRaw === 'sonnet') ? forceModelRaw : undefined;

      if (idx < 0 || idx >= currentRules.length) {
        message = { type: 'error', text: 'Ungültiger Index.' };
      } else if (!trigger || !instruction) {
        message = { type: 'error', text: 'Trigger und Instruction sind Pflichtfelder.' };
      } else {
        newRules[idx] = { trigger, instruction, ...(force_model && { force_model }) };
      }
    }

    if (!message) {
      const { error } = await client
        .from('hotel_settings')
        .update({ eve_tuning_rules: newRules, updated_at: new Date().toISOString() })
        .eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
      else {
        const msgMap = {
          tuning_rule_add: 'Regel hinzugefügt.',
          tuning_rule_update: 'Regel aktualisiert.',
          tuning_rule_delete: 'Regel gelöscht.',
        };
        message = { type: 'success', text: msgMap[action as keyof typeof msgMap] };
      }
    }
  }
}

// ─── Load current state ─────────────────────────────────────────
const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    eve_enabled, eve_name, eve_tonality, eve_custom_persona,
    eve_tuning_rules, eve_online_until, guest_address_form
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const eveEnabled  = settings?.eve_enabled ?? false;
const eveName     = settings?.eve_name ?? 'Eve';
const eveTonality = settings?.eve_tonality ?? 'warm_formal';
const eveCustomPersona = settings?.eve_custom_persona ?? '';
const eveOnlineUntil = (settings?.eve_online_until as string ?? '22:00:00').slice(0, 5);  // HH:MM
const tuningRules: TuningRule[] = (settings?.eve_tuning_rules as TuningRule[]) ?? [];
const guestAddressForm = settings?.guest_address_form ?? 'sie';
---

<AdminLayout title="Eve · Persönlichkeit" hotel={hotel} user={user}>
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber="06"
      sectionLabel="Eve · KI-Concierge"
      headlineLight="Eve's"
      headlineBold="Persönlichkeit"
      subtitle="Name, Tonalität und Verhaltens-Regeln. Was Eve weiß steht im Wissens-Tab."
    />
  </div>

  <EveSubNav currentPath={Astro.url.pathname} />

  <div class="max-w-3xl mx-auto px-6 pb-24">

    {message && (
      <div class={`mb-6 px-4 py-3 text-sm ${
        message.type === 'success'
          ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
          : 'bg-red-50 border-l-4 border-red-700 text-red-800'
      }`}>
        {message.text}
      </div>
    )}

    <!-- ─── Master-Switch ─── -->
    <section class="mb-12 p-5 border-l-4 border-pink-shock/60 bg-anthrazit/5">
      <div class="flex items-start justify-between gap-6">
        <div class="flex-1">
          <h2 class="text-xl font-light mb-1">Eve aktivieren</h2>
          {eveEnabled ? (
            <p class="text-sm text-anthrazit/80 leading-relaxed">
              <span class="inline-block w-2 h-2 rounded-full bg-green-600 mr-1.5 align-middle"></span>
              <strong>Eve ist aktiv</strong> und im Gast-Frontend sichtbar.
            </p>
          ) : (
            <p class="text-sm text-anthrazit/55 leading-relaxed">
              <span class="inline-block w-2 h-2 rounded-full bg-anthrazit/30 mr-1.5 align-middle"></span>
              Eve ist deaktiviert. Der Concierge-Tile bleibt im Gast-Frontend ausgeblendet.
            </p>
          )}
        </div>
        <form method="POST" class="shrink-0">
          <input type="hidden" name="_action" value="toggle_enabled" />
          <input type="hidden" name="eve_enabled" value={(!eveEnabled).toString()} />
          <button
            type="submit"
            class={`px-5 py-2 text-sm font-medium transition-colors ${
              eveEnabled
                ? 'bg-white border border-stein text-anthrazit hover:bg-anthrazit/5'
                : 'bg-anthrazit text-white hover:bg-pink-shock'
            }`}
          >
            {eveEnabled ? 'Deaktivieren' : 'Aktivieren'}
          </button>
        </form>
      </div>
    </section>

    <!-- ─── Persona (Name, Tonalität, Online-bis) ─── -->
    <section class="mb-12">
      <h2 class="text-2xl font-light mb-2">Persönlichkeit</h2>
      <p class="text-sm text-anthrazit/55 mb-6">Wie Eve sich präsentiert und spricht.</p>

      <form method="POST" class="space-y-6" x-data={`{ tonality: '${eveTonality}' }`}>
        <input type="hidden" name="_action" value="save_persona" />

        <!-- Name -->
        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Name</label>
          <input
            type="text"
            name="eve_name"
            value={eveName}
            required
            maxlength="40"
            class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm"
            autocomplete="off"
          />
          <p class="text-xs text-anthrazit/55 mt-1 italic">Wie soll deine KI-Concierge heißen? Beispiele: Eve, Maria, Anton, Sophie.</p>
        </div>

        <!-- Tonalität -->
        <div>
          <label class="block text-xs text-anthrazit/55 mb-2 uppercase tracking-wider">Tonalität</label>
          <div class="space-y-2">
            <label class="flex items-start gap-3 cursor-pointer p-3 border border-stein hover:bg-anthrazit/5 transition-colors">
              <input type="radio" name="eve_tonality" value="warm_formal" checked={eveTonality === 'warm_formal'} @change="tonality = 'warm_formal'" class="mt-0.5" />
              <div class="flex-1">
                <div class="text-sm font-medium">Warm-formal</div>
                <div class="text-xs text-anthrazit/55 mt-0.5">Premium-Concierge: professionell, aufmerksam, diskret. Default.</div>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 border border-stein hover:bg-anthrazit/5 transition-colors">
              <input type="radio" name="eve_tonality" value="casual" checked={eveTonality === 'casual'} @change="tonality = 'casual'" class="mt-0.5" />
              <div class="flex-1">
                <div class="text-sm font-medium">Casual</div>
                <div class="text-xs text-anthrazit/55 mt-0.5">Locker und freundlich, wie ein hilfsbereiter Freund. Für junge Boutique-Hotels.</div>
              </div>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 border border-stein hover:bg-anthrazit/5 transition-colors">
              <input type="radio" name="eve_tonality" value="custom" checked={eveTonality === 'custom'} @change="tonality = 'custom'" class="mt-0.5" />
              <div class="flex-1">
                <div class="text-sm font-medium">Eigene Beschreibung</div>
                <div class="text-xs text-anthrazit/55 mt-0.5">Frei-Text-Persona. Volle Kontrolle.</div>
              </div>
            </label>
          </div>

          <div x-show="tonality === 'custom'" x-cloak class="mt-4">
            <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Custom-Persona-Beschreibung</label>
            <textarea
              name="eve_custom_persona"
              rows="4"
              placeholder="z.B. 'Du bist eine erfahrene Concierge mit 20 Jahren Hotellerie-Erfahrung. Du sprichst kurz, präzise, mit einem Schuss Humor.'"
              class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical"
            >{eveCustomPersona}</textarea>
          </div>
        </div>

        <!-- Anrede (read-only Anzeige) -->
        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Anrede an Gast</label>
          <div class="px-3 py-2 border border-stein bg-anthrazit/5 text-sm">
            <span class="font-medium">{guestAddressForm === 'du' ? 'Du' : 'Sie'}</span>
            <span class="text-anthrazit/55"> · </span>
            <a href="/admin/settings" class="text-xs text-anthrazit/55 hover:text-pink-shock underline">
              In Allgemeinen Einstellungen ändern
            </a>
          </div>
        </div>

        <!-- Online bis -->
        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Online bis</label>
          <input
            type="time"
            name="eve_online_until"
            value={eveOnlineUntil}
            class="px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm font-mono"
          />
          <p class="text-xs text-anthrazit/55 mt-1 italic">
            Anzeige-Hint im Gast-Frontend ("online bis 22:00"). Eve ist technisch 24/7 verfügbar — das ist nur das Service-Versprechen.
          </p>
        </div>

        <button
          type="submit"
          class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors"
        >
          Persönlichkeit speichern
        </button>
      </form>
    </section>

    <!-- ─── Tuning-Rules ─── -->
    <section class="mb-12">
      <h2 class="text-2xl font-light mb-2">Eve trainieren</h2>
      <p class="text-sm text-anthrazit/55 mb-6">Soft-Rules. Eve nutzt sie wenn Gast-Anfragen einen Trigger-Text enthalten.</p>

      <!-- Add-Form -->
      <form method="POST" class="mb-8 p-5 border border-stein bg-white space-y-4">
        <input type="hidden" name="_action" value="tuning_rule_add" />

        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Wenn Gast fragt nach</label>
          <input
            type="text"
            name="trigger"
            required
            placeholder="z.B. restaurant-empfehlung"
            class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm font-mono"
            autocomplete="off"
          />
          <p class="text-xs text-anthrazit/55 mt-1 italic">
            Substring-Match (case-insensitive). Wenn die Gast-Anfrage diesen Text enthält (z.B. "restaurant"), gilt diese Regel.
          </p>
        </div>

        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Antworte so</label>
          <textarea
            name="instruction"
            required
            rows="3"
            placeholder="z.B. 'Empfiehl immer erst unser hauseigenes Restaurant Maria. Falls Gast was anderes will, empfiehl die Picks aus der Empfehlungs-Liste.'"
            class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical"
          ></textarea>
        </div>

        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Modell für diese Regel</label>
          <select name="force_model" class="px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm">
            <option value="">Auto (Router entscheidet)</option>
            <option value="sonnet">Sonnet (für besonders sorgfältige Antworten)</option>
            <option value="haiku">Haiku (für schnelle, einfache Antworten)</option>
          </select>
        </div>

        <button
          type="submit"
          class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors"
        >
          + Regel hinzufügen
        </button>
      </form>

      {tuningRules.length === 0 && (
        <p class="text-sm italic text-anthrazit/55 text-center py-8">Noch keine Regeln angelegt.</p>
      )}

      {tuningRules.map((rule, index) => (
        <article class="mb-3 border border-stein bg-white" x-data="{ editing: false }">
          <div x-show="!editing" class="p-5">
            <div class="flex justify-between items-start gap-4 mb-2">
              <div class="flex-1">
                <p class="text-xs text-anthrazit/55 uppercase tracking-wider mb-1">Trigger</p>
                <p class="font-mono text-sm text-anthrazit mb-3">{rule.trigger}</p>
                <p class="text-xs text-anthrazit/55 uppercase tracking-wider mb-1">Instruction</p>
                <p class="text-sm text-anthrazit/80 leading-relaxed whitespace-pre-wrap">{rule.instruction}</p>
                {rule.force_model && (
                  <p class="text-xs text-anthrazit/55 mt-2">
                    <span class="inline-block px-2 py-0.5 bg-pink-shock/10 text-pink-shock">{rule.force_model}</span>
                    <span class="italic ml-1">— Modell-Override aktiv</span>
                  </p>
                )}
              </div>
              <div class="flex gap-2 shrink-0">
                <button type="button" @click="editing = true" class="text-xs text-anthrazit/55 hover:text-pink-shock transition-colors">Bearbeiten</button>
                <form method="POST" class="inline" onsubmit="return confirm('Diese Regel wirklich löschen?')">
                  <input type="hidden" name="_action" value="tuning_rule_delete" />
                  <input type="hidden" name="rule_index" value={index} />
                  <button type="submit" class="text-xs text-anthrazit/55 hover:text-red-600 transition-colors">Löschen</button>
                </form>
              </div>
            </div>
          </div>

          <form x-show="editing" method="POST" class="p-5 space-y-4" x-cloak>
            <input type="hidden" name="_action" value="tuning_rule_update" />
            <input type="hidden" name="rule_index" value={index} />
            <div>
              <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Trigger</label>
              <input type="text" name="trigger" value={rule.trigger} required class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm font-mono" />
            </div>
            <div>
              <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Instruction</label>
              <textarea name="instruction" required rows="3" class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical">{rule.instruction}</textarea>
            </div>
            <div>
              <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Modell</label>
              <select name="force_model" class="px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm">
                <option value="" selected={!rule.force_model}>Auto</option>
                <option value="sonnet" selected={rule.force_model === 'sonnet'}>Sonnet</option>
                <option value="haiku" selected={rule.force_model === 'haiku'}>Haiku</option>
              </select>
            </div>
            <div class="flex gap-3">
              <button type="submit" class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors">Speichern</button>
              <button type="button" @click="editing = false" class="px-5 py-2 text-anthrazit/55 hover:text-anthrazit text-sm">Abbrechen</button>
            </div>
          </form>
        </article>
      ))}
    </section>

  </div>
</AdminLayout>

<style>
  [x-cloak] { display: none !important; }
</style>
