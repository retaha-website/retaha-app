---
// Sprint E4 · Phase 4 — Eve Knowledge-Base UI
//
// Hotelier pflegt:
//   - FAQ (Q&A-Pairs, multi-row)
//   - Hausregeln (Frei-Text, 1 Row mit category='rules')
//   - Anfahrt (Frei-Text, 1 Row mit category='directions')
//
// Pattern: Page-level POST mit _action-Hidden-Field (konsistent zu pms.astro).
// Inline-Add (kein Modal). RLS schützt Hotelier-Scope automatisch.

import AdminLayout from '../../../components/AdminLayout.astro';
import EditorialPageHeader from '../../../components/admin/EditorialPageHeader.astro';
import EveSubNav from '../../../components/admin/EveSubNav.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;
let highlightId: string | null = null;

// ─── POST handlers ──────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'faq_create') {
    const question = form.get('question')?.toString().trim() ?? '';
    const answer   = form.get('answer')?.toString().trim() ?? '';
    if (!question || !answer) {
      message = { type: 'error', text: 'Frage und Antwort sind Pflichtfelder.' };
    } else {
      const { data, error } = await client
        .from('eve_knowledge')
        .insert({
          hotel_id: hotel.id,
          category: 'faq',
          question, answer,
          language_code: 'de',
        })
        .select('id')
        .single();
      if (error) {
        message = { type: 'error', text: `Anlegen fehlgeschlagen: ${error.message}` };
      } else {
        message = { type: 'success', text: 'FAQ-Eintrag hinzugefügt.' };
        highlightId = data?.id ?? null;
      }
    }
  }

  else if (action === 'faq_update') {
    const id       = form.get('id')?.toString();
    const question = form.get('question')?.toString().trim() ?? '';
    const answer   = form.get('answer')?.toString().trim() ?? '';
    if (!id || !question || !answer) {
      message = { type: 'error', text: 'Fehlende Felder beim Update.' };
    } else {
      const { error } = await client
        .from('eve_knowledge')
        .update({ question, answer, updated_at: new Date().toISOString() })
        .eq('id', id)
        .eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Update fehlgeschlagen: ${error.message}` };
      } else {
        message = { type: 'success', text: 'FAQ-Eintrag aktualisiert.' };
        highlightId = id;
      }
    }
  }

  else if (action === 'faq_delete') {
    const id = form.get('id')?.toString();
    if (!id) {
      message = { type: 'error', text: 'Keine ID übergeben.' };
    } else {
      const { error } = await client
        .from('eve_knowledge')
        .delete()
        .eq('id', id)
        .eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
      } else {
        message = { type: 'success', text: 'FAQ-Eintrag gelöscht.' };
      }
    }
  }

  else if (action === 'rules_save' || action === 'directions_save') {
    const category = action === 'rules_save' ? 'rules' : 'directions';
    const answer = form.get('answer')?.toString().trim() ?? '';

    if (!answer) {
      // Leerer Text → existing Row löschen (Hotelier will Section weg)
      const { error } = await client
        .from('eve_knowledge')
        .delete()
        .eq('hotel_id', hotel.id)
        .eq('category', category);
      if (error) {
        message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
      } else {
        message = { type: 'success', text: `${category === 'rules' ? 'Hausregeln' : 'Anfahrt'} gelöscht.` };
      }
    } else {
      // UPSERT: erst lookup, dann INSERT oder UPDATE
      const { data: existing } = await client
        .from('eve_knowledge')
        .select('id')
        .eq('hotel_id', hotel.id)
        .eq('category', category)
        .maybeSingle();

      if (existing?.id) {
        const { error } = await client
          .from('eve_knowledge')
          .update({ answer, updated_at: new Date().toISOString() })
          .eq('id', existing.id);
        if (error) message = { type: 'error', text: `Update fehlgeschlagen: ${error.message}` };
        else message = { type: 'success', text: `${category === 'rules' ? 'Hausregeln' : 'Anfahrt'} aktualisiert.` };
      } else {
        const { error } = await client
          .from('eve_knowledge')
          .insert({
            hotel_id: hotel.id,
            category, answer,
            language_code: 'de',
          });
        if (error) message = { type: 'error', text: `Anlegen fehlgeschlagen: ${error.message}` };
        else message = { type: 'success', text: `${category === 'rules' ? 'Hausregeln' : 'Anfahrt'} gespeichert.` };
      }
    }
  }
}

// ─── Load current state ─────────────────────────────────────────
const { data: knowledgeRows } = await client
  .from('eve_knowledge')
  .select('id, category, question, answer, sort_order, created_at, updated_at')
  .eq('hotel_id', hotel.id)
  .eq('language_code', 'de')
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

const faqs       = (knowledgeRows ?? []).filter(r => r.category === 'faq');
const rulesRow   = (knowledgeRows ?? []).find(r => r.category === 'rules');
const directionsRow = (knowledgeRows ?? []).find(r => r.category === 'directions');

const userLocale = Astro.locals.locale;
---

<AdminLayout title="Eve · Wissen" hotel={hotel} user={user}>
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber="06"
      sectionLabel="Eve · KI-Concierge"
      headlineLight="Eve's"
      headlineBold="Wissen"
      subtitle="Pflege Frage-Antwort-Paare, Hausregeln und Anfahrt. Eve nutzt das im Gast-Chat."
    />
  </div>

  <EveSubNav currentPath={Astro.url.pathname} />

  <div class="max-w-3xl mx-auto px-6 pb-24" x-data={`{ highlightId: ${JSON.stringify(highlightId)} }`} x-init="if (highlightId) { setTimeout(() => { const el = document.getElementById('faq-' + highlightId); if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'center' }); } }, 100); setTimeout(() => { highlightId = null }, 2500) }">

    {message && (
      <div class={`mb-6 px-4 py-3 text-sm ${
        message.type === 'success'
          ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
          : 'bg-red-50 border-l-4 border-red-700 text-red-800'
      }`}>
        {message.text}
      </div>
    )}

    <!-- Sprache-Hinweis -->
    <div class="mb-12 p-5 border-l-4 border-pink-shock/60 bg-anthrazit/5">
      <p class="text-sm text-anthrazit/80 leading-relaxed">
        <strong>Pflege dein Wissen auf Deutsch.</strong> Eve übersetzt automatisch für englische, französische und spanische Gäste — und cached die Übersetzung für spätere Anfragen.
      </p>
    </div>

    <!-- ─── FAQ ─── -->
    <section class="mb-16">
      <h2 class="text-2xl font-light mb-2">Häufige Fragen</h2>
      <p class="text-sm text-anthrazit/55 mb-6">Q&A-Paare die Eve direkt beantworten kann.</p>

      <!-- Inline-Add-Form -->
      <form method="POST" class="mb-8 p-5 border border-stein bg-white space-y-4">
        <input type="hidden" name="_action" value="faq_create" />
        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Frage</label>
          <input
            type="text"
            name="question"
            required
            placeholder="z.B. Wann ist Check-out?"
            class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm"
            autocomplete="off"
          />
        </div>
        <div>
          <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Antwort</label>
          <textarea
            name="answer"
            required
            rows="3"
            placeholder="z.B. 11:00 Uhr. Late-Check-out bis 13:00 für €15 möglich."
            class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical"
          ></textarea>
        </div>
        <button
          type="submit"
          class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors"
        >
          + FAQ hinzufügen
        </button>
      </form>

      {faqs.length === 0 && (
        <p class="text-sm italic text-anthrazit/55 text-center py-8">Noch keine FAQs angelegt.</p>
      )}

      {faqs.map(faq => (
        <article
          id={`faq-${faq.id}`}
          class="mb-3 border border-stein bg-white"
          x-data={`{ editing: false, highlight: highlightId === '${faq.id}' }`}
          x-init="if (highlight) { setTimeout(() => { highlight = false }, 2500) }"
          :class="highlight ? 'border-pink-shock shadow-lg' : ''"
        >
          <!-- Display Mode -->
          <div x-show="!editing" class="p-5">
            <div class="flex justify-between items-start gap-4 mb-2">
              <h3 class="font-medium text-anthrazit flex-1">{faq.question}</h3>
              <div class="flex gap-2 shrink-0">
                <button
                  type="button"
                  @click="editing = true"
                  class="text-xs text-anthrazit/55 hover:text-pink-shock transition-colors"
                >Bearbeiten</button>
                <form method="POST" class="inline" onsubmit="return confirm('Diesen Eintrag wirklich löschen?')">
                  <input type="hidden" name="_action" value="faq_delete" />
                  <input type="hidden" name="id" value={faq.id} />
                  <button
                    type="submit"
                    class="text-xs text-anthrazit/55 hover:text-red-600 transition-colors"
                  >Löschen</button>
                </form>
              </div>
            </div>
            <p class="text-sm text-anthrazit/80 leading-relaxed whitespace-pre-wrap">{faq.answer}</p>
          </div>

          <!-- Edit Mode -->
          <form x-show="editing" method="POST" class="p-5 space-y-4" x-cloak>
            <input type="hidden" name="_action" value="faq_update" />
            <input type="hidden" name="id" value={faq.id} />
            <div>
              <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Frage</label>
              <input
                type="text"
                name="question"
                value={faq.question}
                required
                class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm"
              />
            </div>
            <div>
              <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">Antwort</label>
              <textarea
                name="answer"
                required
                rows="3"
                class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical"
              >{faq.answer}</textarea>
            </div>
            <div class="flex gap-3">
              <button
                type="submit"
                class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors"
              >Speichern</button>
              <button
                type="button"
                @click="editing = false"
                class="px-5 py-2 text-anthrazit/55 hover:text-anthrazit text-sm"
              >Abbrechen</button>
            </div>
          </form>
        </article>
      ))}
    </section>

    <!-- ─── Hausregeln ─── -->
    <section class="mb-16">
      <h2 class="text-2xl font-light mb-2">Hausregeln</h2>
      <p class="text-sm text-anthrazit/55 mb-6">Frei-Text. Eve referenziert das wenn Gäste nach Regeln fragen (Rauchen, Haustiere, Ruhezeit, etc.).</p>

      <form method="POST" class="space-y-4">
        <input type="hidden" name="_action" value="rules_save" />
        <textarea
          name="answer"
          rows="6"
          placeholder="z.B. Rauchen ist im gesamten Hotel verboten. Haustiere sind willkommen (Anmeldung vor Anreise). Ruhezeit 22:00–07:00."
          class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical bg-white"
        >{rulesRow?.answer ?? ''}</textarea>
        <button
          type="submit"
          class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors"
        >
          Hausregeln speichern
        </button>
      </form>
    </section>

    <!-- ─── Anfahrt ─── -->
    <section class="mb-16">
      <h2 class="text-2xl font-light mb-2">Anfahrt</h2>
      <p class="text-sm text-anthrazit/55 mb-6">Wie kommt der Gast ans Hotel? ÖPNV-Tipps, Parkplatz-Info, Flughafen-Verbindung.</p>

      <form method="POST" class="space-y-4">
        <input type="hidden" name="_action" value="directions_save" />
        <textarea
          name="answer"
          rows="6"
          placeholder="z.B. Vom Flughafen BER: S-Bahn S9 bis Zoologischer Garten, dann U-Bahn U1 zur Uhlandstraße. Parkplätze im Innenhof (18€/Nacht)."
          class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical bg-white"
        >{directionsRow?.answer ?? ''}</textarea>
        <button
          type="submit"
          class="px-5 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors"
        >
          Anfahrt speichern
        </button>
      </form>
    </section>

  </div>
</AdminLayout>

<style>
  [x-cloak] { display: none !important; }
</style>
