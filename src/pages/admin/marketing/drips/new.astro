---
// Sprint Wallet · Phase 14 — Neuer Drip mit DripEditor

import AdminLayout from '../../../../components/AdminLayout.astro';
import DripEditor from '../../../../components/admin/DripEditor.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../../lib/auth';
import { getUserRole } from '../../../../lib/auth/require-permission';
import { hasPermission } from '../../../../lib/auth/permissions';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.write')) return new Response('Forbidden', { status: 403 });

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: templates } = await client
  .from('marketing_templates')
  .select('id, name')
  .eq('hotel_id', hotel.id)
  .eq('is_archived', false)
  .order('name');
---

<AdminLayout title="Marketing · Neue Drip-Sequenz" hotel={hotel} user={user}>
  <div class="dn-page">
    <header class="dn-header">
      <p class="dn-eyebrow">— Marketing · Neue Drip-Sequenz —</p>
      <h1 class="dn-title">Welche Sequenz möchtest du bauen<span class="dot">?</span></h1>
      <p class="dn-sub">Eine Drip-Sequenz besteht aus einem Trigger + einer Reihe von Steps (= Templates). Bei jedem Trigger-Event wird ein Pass in die Sequenz aufgenommen und durchläuft die Steps mit den angegebenen Tages-Verzögerungen.</p>
    </header>

    <DripEditor templates={templates ?? []} />
  </div>

  <style>
    .dn-page { max-width: 900px; margin: 0 auto; padding: 0 24px 60px; }
    .dn-header { margin: 20px 0 24px; }
    .dn-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin: 0 0 6px; }
    .dn-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; }
    .dot { color: var(--theme-accent); }
    .dn-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); max-width: 720px; line-height: 1.5; }
  </style>
</AdminLayout>
