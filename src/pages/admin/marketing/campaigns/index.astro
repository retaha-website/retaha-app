---
// Sprint Wallet · Phase 14 — Campaign-Liste

import AdminLayout from '../../../../components/AdminLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../../lib/auth';
import { getUserRole } from '../../../../lib/auth/require-permission';
import { hasPermission } from '../../../../lib/auth/permissions';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) return new Response('Forbidden', { status: 403 });
const canWrite = hasPermission(myRole, 'content.write');

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('status') || 'all';

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
let q = client
  .from('marketing_campaigns')
  .select('id, name, status, scheduled_at, sent_at, recipients_count, open_count, click_count, skipped_count, title_i18n')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false })
  .limit(100);
if (filter !== 'all') q = q.eq('status', filter);

const { data: rows } = await q;
const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '—';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '—';
}
function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('de-DE', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const STATUS_LABELS: Record<string, { label: string; class: string }> = {
  draft:     { label: 'Entwurf',    class: 'mc-status--draft' },
  scheduled: { label: 'Geplant',    class: 'mc-status--scheduled' },
  sending:   { label: 'Versandt …', class: 'mc-status--sending' },
  sent:      { label: 'Gesendet',   class: 'mc-status--sent' },
  cancelled: { label: 'Abgebrochen', class: 'mc-status--cancelled' },
  failed:    { label: 'Fehler',     class: 'mc-status--failed' },
};
---

<AdminLayout title="Marketing · Kampagnen" hotel={hotel} user={user}>
  <div class="mc-page">
    <header class="mc-header">
      <p class="mc-eyebrow">— Marketing · Kampagnen —</p>
      <h1 class="mc-title">Alle Versandaktionen<span class="dot">.</span></h1>
    </header>

    <div class="mc-bar">
      <div class="mc-tabs">
        <a href="?status=all"       class={`mc-tab${filter === 'all' ? ' is-active' : ''}`}>Alle</a>
        <a href="?status=draft"     class={`mc-tab${filter === 'draft' ? ' is-active' : ''}`}>Entwurf</a>
        <a href="?status=scheduled" class={`mc-tab${filter === 'scheduled' ? ' is-active' : ''}`}>Geplant</a>
        <a href="?status=sent"      class={`mc-tab${filter === 'sent' ? ' is-active' : ''}`}>Gesendet</a>
        <a href="?status=failed"    class={`mc-tab${filter === 'failed' ? ' is-active' : ''}`}>Fehler</a>
      </div>
      {canWrite && <a href="/admin/marketing/campaigns/new" class="mc-btn-primary">+ Neue Kampagne</a>}
    </div>

    {!rows || rows.length === 0 ? (
      <div class="mc-empty">
        <p>Keine Kampagnen in diesem Filter.</p>
        {canWrite && <a href="/admin/marketing/campaigns/new" class="mc-btn-primary">+ Erste Kampagne anlegen</a>}
      </div>
    ) : (
      <div class="mc-list">
        {rows.map((c: any) => {
          const s = STATUS_LABELS[c.status] ?? { label: c.status, class: '' };
          const openRate = c.recipients_count > 0 ? Math.round((c.open_count / c.recipients_count) * 100) : 0;
          const clickRate = c.recipients_count > 0 ? Math.round((c.click_count / c.recipients_count) * 100) : 0;
          return (
            <a href={`/admin/marketing/campaigns/${c.id}`} class="mc-row">
              <div class="mc-row-main">
                <div class="mc-row-head">
                  <span class={`mc-status ${s.class}`}>{s.label}</span>
                  <span class="mc-row-name">{c.name}</span>
                </div>
                <p class="mc-row-title">{pickI18n(c.title_i18n)}</p>
              </div>
              <div class="mc-row-meta">
                <div class="mc-meta-block">
                  <span class="mc-meta-label">{c.status === 'sent' ? 'Gesendet' : c.status === 'scheduled' ? 'Geplant für' : 'Erstellt'}</span>
                  <span class="mc-meta-val">{fmtDate(c.sent_at || c.scheduled_at)}</span>
                </div>
                {c.status === 'sent' && (
                  <>
                    <div class="mc-meta-block"><span class="mc-meta-label">Recipients</span><span class="mc-meta-val">{c.recipients_count}</span></div>
                    <div class="mc-meta-block"><span class="mc-meta-label">Open</span><span class="mc-meta-val">{openRate}%</span></div>
                    <div class="mc-meta-block"><span class="mc-meta-label">Click</span><span class="mc-meta-val">{clickRate}%</span></div>
                  </>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>

  <style>
    .mc-page { max-width: 1000px; margin: 0 auto; padding: 0 24px 60px; }
    .mc-header { margin: 20px 0 24px; }
    .mc-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin: 0 0 6px; }
    .mc-title { margin: 0; font-size: 26px; font-weight: 300; letter-spacing: -0.01em; }
    .dot { color: var(--theme-accent); }
    .mc-bar { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
    .mc-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--theme-border); }
    .mc-tab { padding: 10px 14px; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .mc-tab:hover { color: var(--theme-text-primary); }
    .mc-tab.is-active { color: var(--theme-text-primary); border-bottom-color: var(--theme-accent); font-weight: 500; }
    .mc-btn-primary { padding: 10px 18px; background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary); text-decoration: none; font-size: 13px; font-weight: 500; }
    .mc-btn-primary:hover { background: var(--theme-burgund); }
    .mc-empty { padding: 60px 24px; background: var(--theme-bg-primary); border: 1px dashed var(--theme-border); text-align: center; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }
    .mc-empty p { margin: 0 0 20px; font-style: italic; }
    .mc-list { display: flex; flex-direction: column; gap: 8px; }
    .mc-row { display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; padding: 16px; background: var(--theme-bg-primary); border: 1px solid var(--theme-border); text-decoration: none; color: inherit; transition: border-color .15s; }
    .mc-row:hover { border-color: var(--theme-text-primary); }
    .mc-row-main { min-width: 0; }
    .mc-row-head { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
    .mc-status { font-size: 10px; padding: 3px 8px; letter-spacing: 0.05em; text-transform: uppercase; }
    .mc-status--draft     { background: var(--theme-bg-tertiary); color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); }
    .mc-status--scheduled { background: #fff8e1; color: #6b4f00; border: 1px solid #f5d77a; }
    .mc-status--sending   { background: #e3f2fd; color: #0d47a1; border: 1px solid #90caf9; }
    .mc-status--sent      { background: #e8f5ec; color: #145c2a; border: 1px solid #a8d9b6; }
    .mc-status--cancelled { background: var(--theme-bg-tertiary); color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); text-decoration: line-through; }
    .mc-status--failed    { background: #fdeaea; color: #7a1515; border: 1px solid #f3b8b8; }
    .mc-row-name { font-size: 14px; font-weight: 500; color: var(--theme-text-primary); }
    .mc-row-title { margin: 0; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 600px; }
    .mc-row-meta { display: flex; gap: 16px; align-items: center; }
    @media (max-width: 720px) { .mc-row { grid-template-columns: 1fr; } .mc-row-meta { flex-wrap: wrap; } }
    .mc-meta-block { display: flex; flex-direction: column; align-items: flex-end; }
    .mc-meta-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); }
    .mc-meta-val { font-size: 13px; color: var(--theme-text-primary); font-variant-numeric: tabular-nums; }
  </style>
</AdminLayout>
