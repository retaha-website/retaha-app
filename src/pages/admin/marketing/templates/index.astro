---
// Sprint Wallet · Phase 9 — Marketing-Templates Liste
//
// Listet alle nicht-archivierten Templates des aktuellen Hotels.
// Permission: content.read (Anzeige), content.write (Edit/Archive-Buttons)

import AdminLayout from '../../../../components/AdminLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../../lib/auth';
import { getUserRole } from '../../../../lib/auth/require-permission';
import { hasPermission } from '../../../../lib/auth/permissions';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) {
  return new Response('Forbidden', { status: 403 });
}
const canWrite = hasPermission(myRole, 'content.write');

const url = new URL(Astro.request.url);
const showArchived = url.searchParams.get('archived') === '1';

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: templates } = await client
  .from('marketing_templates')
  .select('id, name, category, title_i18n, hero_image_url, is_archived, updated_at')
  .eq('hotel_id', hotel.id)
  .eq('is_archived', showArchived)
  .order('updated_at', { ascending: false });

const rows = (templates ?? []) as any[];
const hotelDefaultLang = (hotel as any).default_language || 'de';

function pickDefault(jsonb: any): string {
  if (!jsonb) return '—';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '—';
}

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString('de-DE', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const CAT_LABELS: Record<string, string> = {
  newsletter: 'Newsletter', event: 'Event', promotion: 'Promotion', seasonal: 'Seasonal',
};
---

<AdminLayout title="Marketing · Vorlagen" hotel={hotel} user={user}>
  <div class="mt-page">
    <header class="mt-header">
      <p class="mt-eyebrow">— Marketing · Vorlagen —</p>
      <h1 class="mt-title">Was möchtest du deinen Wallet-Gästen sagen<span class="dot">?</span></h1>
      <p class="mt-sub">
        Templates sind wiederverwendbare Nachrichten — schreibe sie einmal, sende sie immer wieder
        (oder in einer Drip-Sequenz). Marketing-Pushes respektieren Opt-Out automatisch.
      </p>
    </header>

    <div class="mt-actions-top">
      <div class="mt-tabs">
        <a href="/admin/marketing/templates"      class={`mt-tab${!showArchived ? ' is-active' : ''}`}>Aktiv</a>
        <a href="/admin/marketing/templates?archived=1" class={`mt-tab${showArchived ? ' is-active' : ''}`}>Archiv</a>
      </div>
      {canWrite && !showArchived && (
        <a href="/admin/marketing/templates/new" class="mt-btn-primary">+ Neue Vorlage</a>
      )}
    </div>

    {rows.length === 0 ? (
      <div class="mt-empty">
        <p>
          {showArchived
            ? 'Keine archivierten Vorlagen.'
            : 'Noch keine Vorlagen. Lege deine erste an — z.B. ein "Willkommen zurück"-Newsletter oder eine Aktion fürs Sommerfest.'}
        </p>
        {canWrite && !showArchived && (
          <a href="/admin/marketing/templates/new" class="mt-btn-primary">+ Erste Vorlage anlegen</a>
        )}
      </div>
    ) : (
      <div class="mt-grid">
        {rows.map((t: any) => (
          <article class="mt-card">
            {t.hero_image_url && <img class="mt-hero" src={t.hero_image_url} alt="" loading="lazy" />}
            <div class="mt-card-body">
              <div class="mt-card-meta">
                {t.category && <span class="mt-pill">{CAT_LABELS[t.category] ?? t.category}</span>}
                <span class="mt-date">{fmtDate(t.updated_at)}</span>
              </div>
              <h3 class="mt-card-name">{t.name}</h3>
              <p class="mt-card-title">{pickDefault(t.title_i18n)}</p>
              <div class="mt-card-actions">
                {canWrite ? (
                  <a href={`/admin/marketing/templates/${t.id}/edit`} class="mt-link">Bearbeiten</a>
                ) : (
                  <span class="mt-link mt-link--disabled">Bearbeiten</span>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>

  <style>
    .mt-page { max-width: 1000px; margin: 0 auto; padding: 0 24px 60px; }
    .mt-header { margin: 20px 0 24px; }
    .mt-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin: 0 0 6px; }
    .mt-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; letter-spacing: -0.01em; }
    .dot { color: var(--theme-accent); }
    .mt-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); max-width: 720px; line-height: 1.5; }

    .mt-actions-top { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; }
    .mt-tabs { display: flex; gap: 4px; border-bottom: 1px solid var(--theme-border); }
    .mt-tab { padding: 10px 14px; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .mt-tab:hover { color: var(--theme-text-primary); }
    .mt-tab.is-active { color: var(--theme-text-primary); border-bottom-color: var(--theme-accent); font-weight: 500; }
    .mt-btn-primary {
      display: inline-block; padding: 10px 18px;
      background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary);
      font-family: inherit; font-size: 13px; font-weight: 500;
      text-decoration: none;
      transition: background 0.15s ease;
    }
    .mt-btn-primary:hover { background: var(--theme-accent); }

    .mt-empty { padding: 60px 24px; background: var(--theme-bg-primary); border: 1px dashed var(--theme-border); text-align: center; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }
    .mt-empty p { margin: 0 0 20px; font-style: italic; }

    .mt-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    .mt-card {
      background: var(--theme-bg-primary); border: 1px solid var(--theme-border);
      display: flex; flex-direction: column;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .mt-card:hover { border-color: var(--theme-text-primary); }
    .mt-hero { width: 100%; aspect-ratio: 16/7; object-fit: cover; display: block; background: var(--theme-bg-tertiary); }
    .mt-card-body { padding: 16px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .mt-card-meta { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
    .mt-pill { font-size: 10px; padding: 2px 8px; background: var(--theme-bg-tertiary); color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); letter-spacing: 0.05em; text-transform: uppercase; }
    .mt-date { font-size: 11px; color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); }
    .mt-card-name { font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); margin: 0; font-weight: 500; }
    .mt-card-title { font-size: 15px; line-height: 1.4; color: var(--theme-text-primary); margin: 0; flex: 1; }
    .mt-card-actions { margin-top: 8px; }
    .mt-link { font-size: 13px; color: var(--theme-accent); text-decoration: underline; }
    .mt-link:hover { color: var(--theme-text-primary); }
    .mt-link--disabled { color: color-mix(in srgb, var(--theme-text-primary) .35, transparent); text-decoration: none; cursor: not-allowed; }
  </style>
</AdminLayout>
