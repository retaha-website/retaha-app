---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServerInstance,
  createSupabaseServiceRoleInstance,
} from '../../lib/auth';
import { encryptToken } from '../../lib/encryption';
import { MewsClient } from '../../lib/mews/client';
import { getEnv } from '../../lib/env';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const ssrClient = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

// POST: connect / disconnect. Sync läuft client-side via fetch → /api/admin/mews/sync
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'connect') {
    const accessToken = form.get('access_token')?.toString().trim() ?? '';
    const environment = form.get('environment')?.toString();

    if (!accessToken) {
      message = { type: 'error', text: 'Access-Token ist Pflichtfeld.' };
    } else if (environment !== 'demo' && environment !== 'production') {
      message = { type: 'error', text: 'Ungültiges Environment (nur demo/production erlaubt).' };
    } else {
      // 1) ENV für Environment auflösen (ClientToken gehört uns als Integration-Provider,
      //    nicht dem Hotel — kommt aus ENV, nicht aus dem Formular)
      const baseUrl = environment === 'demo'
        ? getEnv('MEWS_API_BASE_URL')
        : 'https://api.mews.com';
      const clientToken = environment === 'demo'
        ? getEnv('MEWS_DEMO_CLIENT_TOKEN')
        : getEnv('MEWS_PROD_CLIENT_TOKEN');

      if (!baseUrl || !clientToken) {
        message = {
          type: 'error',
          text: `${environment === 'demo' ? 'Demo' : 'Production'}-Environment nicht konfiguriert (ENV fehlt).`,
        };
      } else {
        try {
          // 2) Mews-API kontaktieren um Enterprise.Id aufzulösen (validiert gleichzeitig den Token)
          const testClient = new MewsClient({
            clientToken,
            accessToken,
            client: getEnv('MEWS_CLIENT_NAME') ?? 'retaha 1.0.0',
            baseUrl,
          });
          const config = await testClient.getConfiguration();
          const enterpriseId = config.Enterprise?.Id;
          const enterpriseName = config.Enterprise?.Name;

          if (!enterpriseId) {
            message = {
              type: 'error',
              text: 'Mews API antwortete ohne Enterprise.Id — Token möglicherweise ungültig oder Account ohne Enterprise.',
            };
          } else {
            // 3) Token verschlüsseln + Row upserten
            const encryptedToken = await encryptToken(accessToken);
            const { error } = await ssrClient
              .from('mews_integrations')
              .upsert(
                {
                  hotel_id: hotel.id,
                  enterprise_id: enterpriseId,
                  access_token_encrypted: encryptedToken,
                  environment,
                  sync_status: 'idle',
                  sync_error_message: null,
                  updated_at: new Date().toISOString(),
                },
                { onConflict: 'hotel_id' },
              );

            if (error) {
              message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
            } else {
              return Astro.redirect(
                `/admin/pms?saved=connected${enterpriseName ? `&hotel=${encodeURIComponent(enterpriseName)}` : ''}`,
              );
            }
          }
        } catch (err) {
          message = {
            type: 'error',
            text: `Mews-Verbindungstest fehlgeschlagen: ${(err as Error).message}`,
          };
        }
      }
    }
  } else if (action === 'disconnect') {
    const { error } = await ssrClient
      .from('mews_integrations')
      .delete()
      .eq('hotel_id', hotel.id);
    if (error) {
      message = { type: 'error', text: `Trennen fehlgeschlagen: ${error.message}` };
    } else {
      return Astro.redirect('/admin/pms?saved=disconnected');
    }
  }
}

// Flash-Messages aus URL-Param (Post-Redirect-Get)
const savedParam = Astro.url.searchParams.get('saved');
if (savedParam === 'connected' && !message) {
  const hotelName = Astro.url.searchParams.get('hotel');
  message = {
    type: 'success',
    text: hotelName
      ? `Verbunden mit „${hotelName}". Klicke „Jetzt synchronisieren" um Daten zu laden.`
      : 'Mews-Integration verbunden. Klicke „Jetzt synchronisieren" um Daten zu laden.',
  };
} else if (savedParam === 'disconnected' && !message) {
  message = { type: 'success', text: 'Mews-Integration getrennt. Bisher synchronisierte Daten bleiben erhalten.' };
} else if (savedParam === 'sync' && !message) {
  message = { type: 'success', text: 'Synchronisation erfolgreich abgeschlossen.' };
}

// Integration via SSR-Client (RLS) — access_token_encrypted bewusst NICHT selektiert,
// bleibt server-side, geht nie ans Frontend.
const { data: integration } = await ssrClient
  .from('mews_integrations')
  .select('enterprise_id, environment, last_sync_at, sync_status, sync_error_message, created_at, updated_at')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

// Counts via Service-Role (rooms/stays/guests-RLS uneinheitlich) — hotel.id-Filter
// kommt aus authentifizierter Session, also sicher.
let counts: { rooms: number; stays: number; guests: number } | null = null;
if (integration) {
  const adminClient = createSupabaseServiceRoleInstance();
  const [roomsRes, staysRes, guestsRes] = await Promise.all([
    adminClient.from('rooms').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
    adminClient.from('stays').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
    adminClient.from('guests').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
  ]);
  counts = {
    rooms: roomsRes.count ?? 0,
    stays: staysRes.count ?? 0,
    guests: guestsRes.count ?? 0,
  };
}

const lastSyncLabel = integration?.last_sync_at
  ? new Date(integration.last_sync_at).toLocaleString('de-DE', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;

const syncStatusBadge: Record<string, { label: string; classes: string }> = {
  idle: { label: 'Bereit', classes: 'bg-anthrazit/[0.06] text-anthrazit/70' },
  syncing: { label: 'Läuft…', classes: 'bg-pink-shock/10 text-pink-shock' },
  error: { label: 'Fehler', classes: 'bg-red-50 text-red-700' },
};
const statusKey = integration?.sync_status ?? 'idle';
const statusBadge = syncStatusBadge[statusKey] ?? syncStatusBadge.idle;
---

<AdminLayout title="PMS-Integration" hotel={hotel} user={{ email: user.email }}>

  <EditorialPageHeader
    sectionNumber="30"
    sectionLabel="Integrationen"
    headlineLight="PMS-"
    headlineBold="Integration"
    subtitle="Verbinde dein Mews-Hotel mit retaha. Reservationen, Zimmer und Gäste-Daten werden automatisch synchronisiert."
  />

  {message && (
    <div class={`mb-8 px-4 py-3 text-sm border-l-4 ${
      message.type === 'success'
        ? 'bg-green-50 border-green-700 text-green-800'
        : 'bg-red-50 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  {integration ? (
    <div class="space-y-10 max-w-3xl">

      <!-- Status-Block -->
      <section class="border-t border-b border-anthrazit/[0.12] py-8">
        <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
          <p class="eyebrow text-pink-shock m-0">— Mews verbunden —</p>
          <span class={`text-xs uppercase tracking-[0.12em] px-2.5 py-1 ${statusBadge.classes}`}>
            {statusBadge.label}
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6">
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Enterprise-ID</p>
            <p class="text-sm font-mono text-anthrazit break-all">{integration.enterprise_id}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Environment</p>
            <p class="text-base text-anthrazit capitalize">{integration.environment}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Access-Token</p>
            <p class="text-base font-mono text-anthrazit">••••••••••••</p>
            <p class="text-xs italic text-anthrazit/55 mt-1">verschlüsselt (AES-256-GCM)</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Letzter Sync</p>
            <p class="text-base text-anthrazit">{lastSyncLabel ?? 'noch nie'}</p>
          </div>
        </div>

        {integration.sync_status === 'error' && integration.sync_error_message && (
          <div class="mt-6 px-4 py-3 text-sm bg-red-50 border-l-4 border-red-700 text-red-800">
            <p class="font-semibold mb-1">Letzter Sync-Fehler:</p>
            <p class="font-mono text-xs break-all">{integration.sync_error_message}</p>
          </div>
        )}
      </section>

      <!-- Counts -->
      {counts && (
        <section>
          <p class="eyebrow text-anthrazit/55 mb-4">— Bisher synchronisiert —</p>
          <div class="grid grid-cols-3 gap-4">
            <div class="border border-stein p-6">
              <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Zimmer</p>
              <p class="text-3xl font-light text-anthrazit m-0">{counts.rooms}</p>
            </div>
            <div class="border border-stein p-6">
              <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Aufenthalte</p>
              <p class="text-3xl font-light text-anthrazit m-0">{counts.stays}</p>
            </div>
            <div class="border border-stein p-6">
              <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Gäste</p>
              <p class="text-3xl font-light text-anthrazit m-0">{counts.guests}</p>
            </div>
          </div>
        </section>
      )}

      <!-- Aktionen -->
      <section class="flex gap-6 flex-wrap items-center pt-2">
        <button
          id="sync-button"
          type="button"
          class="bauhaus-button bauhaus-button--primary"
        >
          Jetzt synchronisieren
        </button>
        <form
          method="POST"
          id="disconnect-form"
          class="m-0"
        >
          <input type="hidden" name="_action" value="disconnect" />
          <button
            type="submit"
            class="bauhaus-button bauhaus-button--ghost"
          >
            Verbindung trennen
          </button>
        </form>
      </section>

      <p class="text-xs italic text-anthrazit/55 max-w-xl leading-relaxed">
        Sync läuft über getMewsClientForHotel(hotel_id) — der Access-Token wird beim
        Sync server-seitig entschlüsselt und nie ans Frontend gesendet. Synchronisiert
        werden Reservationen der letzten 30 Tage (rolling window).
      </p>
    </div>

    <script is:inline>
      (function () {
        const syncBtn = document.getElementById('sync-button');
        const disconnectForm = document.getElementById('disconnect-form');

        if (syncBtn) {
          syncBtn.addEventListener('click', async () => {
            const originalText = syncBtn.textContent;
            syncBtn.disabled = true;
            syncBtn.textContent = 'Synchronisiere…';
            try {
              const resp = await fetch('/api/admin/mews/sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ windowDays: 30 }),
              });
              const data = await resp.json();
              if (data.ok) {
                window.location.href = '/admin/pms?saved=sync';
              } else {
                alert('Sync fehlgeschlagen: ' + (data.error || 'unbekannter Fehler'));
                syncBtn.disabled = false;
                syncBtn.textContent = originalText;
              }
            } catch (err) {
              alert('Netzwerk-Fehler: ' + (err && err.message ? err.message : err));
              syncBtn.disabled = false;
              syncBtn.textContent = originalText;
            }
          });
        }

        if (disconnectForm) {
          disconnectForm.addEventListener('submit', (e) => {
            if (!confirm('Mews-Verbindung wirklich trennen? Bisher synchronisierte Daten bleiben erhalten, der Sync stoppt aber sofort.')) {
              e.preventDefault();
            }
          });
        }
      })();
    </script>
  ) : (
    <div class="max-w-2xl">
      <p class="text-anthrazit/80 leading-relaxed text-base mb-10">
        Verbinde dein Mews-Property mit retaha. Du brauchst nur deinen
        <strong>Access-Token</strong> für die Connector-API — die Enterprise-ID lesen
        wir automatisch aus der Mews-API aus. Der Mews-Support hilft dir bei der
        Token-Generierung — sag ihnen, dass du eine Connector-API-Integration mit
        retaha aufbaust.
      </p>

      <form method="POST" class="space-y-8">
        <input type="hidden" name="_action" value="connect" />

        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-2">— Access-Token —</span>
          <input
            type="password"
            name="access_token"
            placeholder="••••••••••••"
            required
            autocomplete="off"
            spellcheck="false"
            class="bauhaus-input bauhaus-input--mono"
          />
          <span class="text-xs italic text-anthrazit/55 mt-2 block">
            Wird verschlüsselt gespeichert (AES-256-GCM) — niemals im Klartext in der Datenbank.
          </span>
        </label>

        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-2">— Environment —</span>
          <select
            name="environment"
            required
            class="bauhaus-input"
          >
            <option value="demo">Demo (api.mews-demo.com)</option>
            <option value="production">Production (api.mews.com)</option>
          </select>
          <span class="text-xs italic text-anthrazit/55 mt-2 block">
            Für erste Tests: Demo. Echte Reservationen: Production.
          </span>
        </label>

        <div class="pt-4">
          <button type="submit" class="bauhaus-button bauhaus-button--primary">
            Verbinden
          </button>
        </div>
      </form>
    </div>
  )}

</AdminLayout>
