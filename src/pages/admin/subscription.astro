---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels } from '../../lib/auth';
import { t } from '../../i18n/helpers';
import { calculateTrialStatus } from '../../lib/trial-status';
import type { AdminLocale } from '../../i18n/types';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;

const trial = calculateTrialStatus(hotel);
const trialEndFormatted = trial.endsAt?.toLocaleDateString(userLocale === 'en' ? 'en-US' : 'de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<AdminLayout title={t('subscription.page_title', userLocale)} hotel={hotel} user={user} activeTab="settings">
  <EditorialPageHeader
    sectionNumber={t('subscription.section_number', userLocale)}
    sectionLabel={t('subscription.section_label', userLocale)}
    headlineLight={t('subscription.headline_light', userLocale)}
    headlineBold={t('subscription.headline_bold', userLocale)}
    subtitle={t('subscription.subtitle', userLocale)}
  />

  <!-- Aktives Modul-Paket -->
  <section class="border-t border-b border-stone-200 py-8 mb-10">
    <p class="text-xs uppercase tracking-[0.18em] text-pink-shock mb-3">
      — {t('subscription.current_eyebrow', userLocale)} —
    </p>
    <div class="flex items-baseline justify-between gap-6 flex-wrap">
      <h2 class="text-2xl font-light text-anthrazit m-0">
        {t('subscription.current_module', userLocale)}
      </h2>
      <p class="text-2xl font-medium text-anthrazit m-0">
        {t('subscription.current_price', userLocale)}
      </p>
    </div>
    {trialEndFormatted && (
      <p class="text-sm italic text-anthrazit/60 mt-4 m-0">
        {t('onboarding.setup.done_trial_text', userLocale)} {trialEndFormatted}.
      </p>
    )}
  </section>

  <!-- Soon: Stripe -->
  <section class="py-8 mb-10">
    <p class="text-xs uppercase tracking-[0.18em] text-stone-500 mb-3">
      — {t('subscription.soon_eyebrow', userLocale)} —
    </p>
    <p class="text-sm text-anthrazit/70 max-w-2xl mb-6 leading-relaxed">
      {t('subscription.soon_note', userLocale)}
    </p>
    <button type="button" class="bauhaus-button" disabled aria-disabled="true">
      {t('subscription.cta_disabled', userLocale)}
    </button>
  </section>

  <a href="/admin/dashboard" class="inline-block text-sm text-anthrazit/60 hover:text-anthrazit">
    {t('subscription.cta_back', userLocale)}
  </a>
</AdminLayout>
