---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');
---

<AdminLayout title="Microsite Branding" hotel={hotel} user={user}>

  <EditorialPageHeader
    sectionNumber="16"
    sectionLabel="Inhalte"
    headlineLight="Microsite-"
    headlineBold="Branding"
    subtitle="Wie deine Gäste dein Haus digital erleben."
  />

  <div class="max-w-3xl">
    <p class="text-anthrazit/80 leading-relaxed text-base">
      Hier passt du das Erscheinungsbild deiner Microsite an — Logo, Hauptfarbe, Schriftart, Willkommens-Text, Hero-Bild. Alle Änderungen sind nach dem Speichern sofort sichtbar — sowohl für deine Gäste am NFC-Tag im Zimmer als auch in der öffentlichen Hotel-Microsite.
    </p>
  </div>

</AdminLayout>
