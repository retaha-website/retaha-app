---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../lib/auth';
import { t } from '../../i18n/helpers';

const userLocale = Astro.locals.locale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
// User authenticated aber kein Hotel → Onboarding-Flow (statt Login-Error-Rückwurf)
if (!hotel) return Astro.redirect('/onboarding/locale');

// Get settings + counts
const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: settings } = await client
  .from('hotel_settings')
  .select('features, recommendations')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const featuresActive = settings?.features
  ? Object.values(settings.features).filter(v => v === true).length
  : 0;
const featuresTotal = settings?.features ? Object.keys(settings.features).length : 0;
const recCount = settings?.recommendations?.length ?? 0;

const { count: stayCount } = await client
  .from('stays')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id)
  .eq('is_active', true);
---

<AdminLayout title="Übersicht" hotel={hotel} user={user} activeTab="overview">
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber={t('pages.dashboard.section_number', userLocale)}
      sectionLabel={t('pages.dashboard.section_label', userLocale)}
      headlineLight={t('pages.dashboard.headline_light', userLocale)}
      headlineBold={t('pages.dashboard.headline_bold', userLocale)}
      subtitle={t('pages.dashboard.subtitle', userLocale)}
    />
  </div>

  <div class="grid grid-cols-3 gap-4 mb-10">
    <a href="/admin/recommendations" class="bg-white border border-stone-200 p-6 hover:border-burgund transition group">
      <p class="text-xs italic text-stone-500 mb-3" style="font-family: Georgia, serif;">Empfehlungs-Karten</p>
      <p class="text-3xl font-light mb-1">{recCount}</p>
      <p class="text-xs text-stone-400 group-hover:text-burgund transition">bearbeiten →</p>
    </a>
    <a href="/admin/features" class="bg-white border border-stone-200 p-6 hover:border-burgund transition group">
      <p class="text-xs italic text-stone-500 mb-3" style="font-family: Georgia, serif;">Funktionen aktiv</p>
      <p class="text-3xl font-light mb-1">{featuresActive} <span class="text-base text-stone-400">/ {featuresTotal}</span></p>
      <p class="text-xs text-stone-400 group-hover:text-burgund transition">verwalten →</p>
    </a>
    <a href="/admin/bookings" class="bg-white border border-stone-200 p-6 hover:border-burgund transition group">
      <p class="text-xs italic text-stone-500 mb-3" style="font-family: Georgia, serif;">Aktive Gäste</p>
      <p class="text-3xl font-light mb-1">{stayCount ?? 0}</p>
      <p class="text-xs text-stone-400 group-hover:text-burgund transition">Buchungen →</p>
    </a>
  </div>

  <section class="bg-white border border-stone-200 p-8">
    <p class="text-xs italic text-burgund mb-3" style="font-family: Georgia, serif;">— Erster Schritt —</p>
    <h2 class="text-xl font-medium mb-2">Schau dir deine Gast-Ansicht an</h2>
    <p class="text-sm text-stone-600 mb-6 leading-relaxed max-w-xl">
      So sieht das, was deine Gäste sehen, wenn sie den NFC-Tag im Zimmer scannen.
      Änderungen, die du hier im Backoffice machst, werden dort sofort sichtbar.
    </p>

    <a
      href="/g/00d5924a16934db28f77a3f570194e24"
      target="_blank"
      class="bauhaus-button bauhaus-button--primary"
    >
      Gast-Ansicht öffnen (Hannah, Zimmer 12) →
    </a>
  </section>
</AdminLayout>
