---
import AdminLayout from '../../components/AdminLayout.astro';
import BauhausToggle from '../../components/admin/BauhausToggle.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../lib/auth';
import { t } from '../../i18n/helpers';

const userLocale = Astro.locals.locale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  // Read current settings to update features JSONB
  const { data: currentSettings } = await client
    .from('hotel_settings')
    .select('features')
    .eq('hotel_id', hotel.id)
    .maybeSingle();

  const currentFeatures = (currentSettings?.features as Record<string, any>) || {};

  const allReservationValues = form.getAll('breakfast_reservation');
  const reservationOn = allReservationValues.includes('on');
  const newFeatures = { ...currentFeatures, breakfast_reservation: reservationOn };

  const updates: Record<string, any> = {
    features: newFeatures,
    breakfast_start_time: form.get('breakfast_start_time')?.toString() || '07:30',
    breakfast_end_time: form.get('breakfast_end_time')?.toString() || '10:30',
    breakfast_slot_minutes: parseInt(form.get('breakfast_slot_minutes')?.toString() || '30') || 30,
    breakfast_location_de: form.get('breakfast_location_de')?.toString().trim() || null,
    breakfast_location_en: form.get('breakfast_location_en')?.toString().trim() || null,
    breakfast_location_fr: form.get('breakfast_location_fr')?.toString().trim() || null,
    breakfast_location_es: form.get('breakfast_location_es')?.toString().trim() || null,
    breakfast_included_de: form.get('breakfast_included_de')?.toString().trim() || null,
    breakfast_included_en: form.get('breakfast_included_en')?.toString().trim() || null,
    breakfast_included_fr: form.get('breakfast_included_fr')?.toString().trim() || null,
    breakfast_included_es: form.get('breakfast_included_es')?.toString().trim() || null,
    updated_at: new Date().toISOString(),
  };

  const { data: updatedRows, error } = await client
    .from('hotel_settings')
    .update(updates)
    .eq('hotel_id', hotel.id)
    .select('hotel_id');

  if (error) {
    message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
  } else if (!updatedRows || updatedRows.length === 0) {
    message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS) oder Eintrag nicht gefunden' };
  } else {
    message = { type: 'success', text: 'Frühstücks-Einstellungen gespeichert.' };
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    features,
    breakfast_start_time, breakfast_end_time, breakfast_slot_minutes,
    breakfast_location_de, breakfast_location_en, breakfast_location_fr, breakfast_location_es,
    breakfast_included_de, breakfast_included_en, breakfast_included_fr, breakfast_included_es
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || {};
const features = ((settings?.features as Record<string, any>) || {});
const reservationOn = features.breakfast_reservation !== false;

// Times as HH:MM
const startTime = ((s as any).breakfast_start_time || '07:30').substring(0, 5);
const endTime = ((s as any).breakfast_end_time || '10:30').substring(0, 5);
---

<AdminLayout title="Frühstück" hotel={hotel} user={user} activeTab="breakfast">
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber={t('pages.breakfast.section_number', userLocale)}
      sectionLabel={t('pages.breakfast.section_label', userLocale)}
      headlineLight={t('pages.breakfast.headline_light', userLocale)}
      headlineBold={t('pages.breakfast.headline_bold', userLocale)}
      subtitle={t('pages.breakfast.subtitle', userLocale)}
    />
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <form method="POST" class="space-y-8">

    <!-- Reservierungs-Schalter -->
    <section class="bg-white border border-stone-200 p-8">
      <div class="mb-6">
        <p class="text-xs italic text-pink-shock mb-1" style="font-family: var(--font-sans);">— Reservierung —</p>
        <h2 class="text-xl font-medium">Können Gäste einen Tisch reservieren?</h2>
        <p class="text-xs text-stone-500 mt-1 max-w-lg">
          Wenn aktiviert, sehen Gäste ein Formular zum Reservieren. Wenn deaktiviert, sehen sie nur
          die Frühstückszeiten + Ort als Info ("Komm einfach vorbei").
        </p>
      </div>

      <label
        for="reservation-toggle"
        class="flex items-center gap-5 py-[26px] cursor-pointer"
      >
        <span
          data-toggle-accent
          class="w-1.5 h-1.5 rounded-full bg-anthrazit/30 transition-colors duration-200 ease-in-out flex-shrink-0 pointer-events-none"
          aria-hidden="true"
        ></span>

        <div class="flex-1 min-w-0">
          <p class="text-[15px] font-medium text-anthrazit leading-tight tracking-tight mb-1.5">Tisch-Reservierung aktiv</p>
          <p class="text-[13px] italic text-anthrazit/55 leading-[1.55]" id="toggle-status-text">
            {reservationOn ? 'Gäste können Tische reservieren' : 'Gäste sehen nur Infos, kein Reservierungs-Formular'}
          </p>
        </div>

        <BauhausToggle id="reservation-toggle" name="breakfast_reservation" checked={reservationOn} label="Tisch-Reservierung aktiv" />
      </label>

      <script is:inline>
        // Update status text live when toggle changes
        const toggle = document.getElementById('reservation-toggle');
        const statusText = document.getElementById('toggle-status-text');
        if (toggle && statusText) {
          toggle.addEventListener('change', () => {
            statusText.textContent = toggle.checked
              ? 'Gäste können Tische reservieren'
              : 'Gäste sehen nur Infos, kein Reservierungs-Formular';
          });
        }
      </script>
    </section>

    <!-- Zeiten -->
    <section class="bg-white border border-stone-200 p-8">
      <div class="mb-6">
        <p class="text-xs italic text-pink-shock mb-1" style="font-family: var(--font-sans);">— Zeiten —</p>
        <h2 class="text-xl font-medium">Wann gibt es Frühstück?</h2>
      </div>

      <div class="grid grid-cols-3 gap-4">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Beginn</span>
          <input
            type="time"
            name="breakfast_start_time"
            value={startTime}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Ende</span>
          <input
            type="time"
            name="breakfast_end_time"
            value={endTime}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Slot-Länge (Min)</span>
          <input
            type="number"
            name="breakfast_slot_minutes"
            value={(s as any).breakfast_slot_minutes || 30}
            min="5"
            max="120"
            step="5"
            class="bauhaus-input"
          />
        </label>
      </div>

      <p class="text-[10px] text-stone-400 mt-3 italic">
        Slot-Länge bestimmt die Abstände der Reservierungs-Zeiten (z.B. 30 = 07:30, 08:00, 08:30, ...).
      </p>
    </section>

    <!-- Ort (4 Sprachen) -->
    <section class="bg-white border border-stone-200 p-8" data-translate-section="location">
      <div class="mb-6 flex justify-between items-start gap-4">
        <div>
          <p class="text-xs italic text-pink-shock mb-1" style="font-family: var(--font-sans);">— Ort —</p>
          <h2 class="text-xl font-medium">Wo wird gefrühstückt?</h2>
          <p class="text-xs text-stone-500 mt-1">Z.B. "im Wintergarten" — wird zusammen mit der Begrüßung gezeigt.</p>
        </div>
        <button type="button" data-translate="location"
          class="bauhaus-button bauhaus-button--primary bauhaus-button--small self-start">
          <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><path d="M8 1 a7 7 0 0 1 7 7 h-1 a6 6 0 0 0 -12 0 H1 a7 7 0 0 1 7 -7 z M14 8 a6 6 0 0 1 -12 0 a6 6 0 0 1 1 -1 l-2 -1 a7 7 0 0 0 13 2 z"/></svg>
          <span>Aus DE übersetzen</span>
        </button>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Deutsch</span>
          <input
            type="text"
            name="breakfast_location_de"
            data-field="location_de"
            value={(s as any).breakfast_location_de || ''}
            class="bauhaus-input"
          />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">English</span>
          <input
            type="text"
            name="breakfast_location_en"
            data-field="location_en"
            value={(s as any).breakfast_location_en || ''}
            class="bauhaus-input"
          />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Français</span>
          <input
            type="text"
            name="breakfast_location_fr"
            data-field="location_fr"
            value={(s as any).breakfast_location_fr || ''}
            class="bauhaus-input"
          />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Español</span>
          <input
            type="text"
            name="breakfast_location_es"
            data-field="location_es"
            value={(s as any).breakfast_location_es || ''}
            class="bauhaus-input"
          />
        </label>
      </div>
    </section>

    <!-- Was inkludiert (4 Sprachen) -->
    <section class="bg-white border border-stone-200 p-8" data-translate-section="included">
      <div class="mb-6 flex justify-between items-start gap-4">
        <div>
          <p class="text-xs italic text-pink-shock mb-1" style="font-family: var(--font-sans);">— Was inkludiert ist —</p>
          <h2 class="text-xl font-medium">Was bekommen deine Gäste?</h2>
          <p class="text-xs text-stone-500 mt-1 max-w-lg">
            Z.B. "Frische Backwaren, regionaler Honig, Bio-Eier, …" — wird im Info-Mode prominent gezeigt.
          </p>
        </div>
        <button type="button" data-translate="included"
          class="bauhaus-button bauhaus-button--primary bauhaus-button--small self-start">
          <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><path d="M8 1 a7 7 0 0 1 7 7 h-1 a6 6 0 0 0 -12 0 H1 a7 7 0 0 1 7 -7 z M14 8 a6 6 0 0 1 -12 0 a6 6 0 0 1 1 -1 l-2 -1 a7 7 0 0 0 13 2 z"/></svg>
          <span>Aus DE übersetzen</span>
        </button>
      </div>

      <div class="space-y-3">
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Deutsch</span>
          <textarea
            name="breakfast_included_de"
            data-field="included_de"
            rows="2"
            class="bauhaus-textarea"
          >{(s as any).breakfast_included_de || ''}</textarea>
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">English</span>
          <textarea
            name="breakfast_included_en"
            data-field="included_en"
            rows="2"
            class="bauhaus-textarea"
          >{(s as any).breakfast_included_en || ''}</textarea>
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Français</span>
          <textarea
            name="breakfast_included_fr"
            data-field="included_fr"
            rows="2"
            class="bauhaus-textarea"
          >{(s as any).breakfast_included_fr || ''}</textarea>
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Español</span>
          <textarea
            name="breakfast_included_es"
            data-field="included_es"
            rows="2"
            class="bauhaus-textarea"
          >{(s as any).breakfast_included_es || ''}</textarea>
        </label>
      </div>
    </section>

    <div class="flex justify-end pt-4">
      <button
        type="submit"
        class="bauhaus-button bauhaus-button--primary"
      >
        Änderungen speichern
      </button>
    </div>

  </form>

  <script>
    // DeepL-Translate-Buttons
    document.querySelectorAll('[data-translate]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const section = target.dataset.translate; // 'location' or 'included'
        const sectionEl = target.closest('[data-translate-section]') as HTMLElement;
        if (!sectionEl) return;

        const deInput = sectionEl.querySelector(`[data-field="${section}_de"]`) as HTMLInputElement | HTMLTextAreaElement;
        if (!deInput || !deInput.value.trim()) {
          alert('Bitte zuerst den deutschen Text eingeben.');
          return;
        }

        const originalText = target.innerHTML;
        target.disabled = true;
        target.innerHTML = '<span>Übersetze...</span>';

        try {
          const resp = await fetch('/api/translate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              source: 'de',
              targets: ['en', 'fr', 'es'],
              fields: {
                [`${section}_de`]: deInput.value,
              },
            }),
          });

          const data = await resp.json();

          if (!data.ok) {
            alert('Übersetzung fehlgeschlagen: ' + (data.error || 'unbekannt'));
            return;
          }

          ['en', 'fr', 'es'].forEach(target => {
            const trans = data.result[target];
            if (!trans) return;
            const value = trans[section]; // 'location' or 'included' key in response
            if (value !== undefined) {
              const input = sectionEl.querySelector(`[data-field="${section}_${target}"]`) as HTMLInputElement | HTMLTextAreaElement;
              if (input) input.value = value;
            }
          });

          const msg = document.createElement('div');
          msg.className = 'fixed top-4 right-4 bg-green-700 text-white px-4 py-3 text-sm shadow-lg z-50';
          msg.textContent = 'Übersetzt — vergiss nicht zu speichern.';
          document.body.appendChild(msg);
          setTimeout(() => msg.remove(), 4000);
        } catch (err: any) {
          alert('Fehler: ' + (err.message || 'unbekannt'));
        } finally {
          target.disabled = false;
          target.innerHTML = originalText;
        }
      });
    });
  </script>
</AdminLayout>
