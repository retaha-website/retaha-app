---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServiceRoleInstance,
} from '../../lib/auth';
import { resendGetDomain, type ResendDomainRecord } from '../../lib/email/resend';
import { getEnv } from '../../lib/env';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const sb = createSupabaseServiceRoleInstance();
const { data: settings } = await sb
  .from('hotel_settings')
  .select('custom_email_domain, custom_email_status, resend_domain_id')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const resendApiKeySet = !!getEnv('RESEND_API_KEY');

let message: { type: 'success' | 'error'; text: string } | null = null;

// Flash-Messages
const saved = Astro.url.searchParams.get('saved');
const err = Astro.url.searchParams.get('err');
const detail = Astro.url.searchParams.get('detail');
const status = Astro.url.searchParams.get('status');

if (saved === 'added') {
  message = { type: 'success', text: 'Domain bei Resend angelegt. Bitte die unten gezeigten DNS-Einträge bei deinem Domain-Provider hinterlegen, dann „Domain verifizieren" klicken.' };
} else if (saved === 'verified' && status === 'verified') {
  message = { type: 'success', text: '🎉 Domain verifiziert! Gast-Mails werden ab sofort von deiner Custom-Domain versendet.' };
} else if (saved === 'verified' && status === 'pending') {
  message = { type: 'error', text: 'Domain noch nicht verifiziert — DNS-Propagation kann bis 24h dauern. Bitte später nochmal versuchen.' };
} else if (saved === 'verified' && status === 'failed') {
  message = { type: 'error', text: 'Verifikation fehlgeschlagen — bitte DNS-Einträge prüfen.' };
} else if (saved === 'removed') {
  message = { type: 'success', text: 'Domain entfernt. Mails werden wieder von noreply@retaha.de versendet.' };
} else if (err) {
  const errTexts: Record<string, string> = {
    no_domain: 'Bitte eine Domain eingeben.',
    invalid_domain: 'Ungültiges Domain-Format (z.B. gategardenhotel.de — ohne https:// oder www.).',
    resend: `Resend-API-Fehler: ${detail ?? 'unbekannt'}`,
    db_save: 'Speichern in Datenbank fehlgeschlagen.',
    no_domain_id: 'Keine Domain konfiguriert.',
    invalid_form: 'Formular-Daten ungültig.',
    unknown_action: 'Unbekannte Aktion.',
  };
  message = { type: 'error', text: errTexts[err] ?? err };
}

// Wenn Domain konfiguriert: aktuellen Status + DNS-Records von Resend live nachladen.
// (kostet 1 API-Call pro Page-Load, OK weil sehr seltener Visit)
let domainDetail: { status: string; records: ResendDomainRecord[] } | null = null;
let domainDetailError: string | null = null;
if (settings?.resend_domain_id) {
  const resp = await resendGetDomain(settings.resend_domain_id);
  if (resp.ok) {
    domainDetail = {
      status: resp.data.status,
      records: resp.data.records ?? [],
    };
  } else {
    domainDetailError = resp.error;
  }
}
---

<AdminLayout title="Email-Domain" hotel={hotel} user={{ email: user.email ?? '' }}>
  <EditorialPageHeader
    sectionNumber="41"
    sectionLabel="Email"
    headlineLight="Eigene"
    headlineBold="Absender-Domain"
    subtitle="Customer-Facing-Mails (Pre-Arrival-Invite, später weitere Gast-Mails) versenden wir auf Wunsch von welcome@deine-domain.de statt von noreply@retaha.de. Premium-Vertrauen statt Service-Provider-Optik."
  />

  {!resendApiKeySet && (
    <div class="mb-6 px-4 py-3 text-sm bg-amber-50 border-l-4 border-amber-500 text-amber-800">
      <strong>RESEND_API_KEY nicht konfiguriert</strong> — kontaktiere Taha für API-Key-Setup.
      Bis dahin werden alle Customer-Facing-Mails über die Microsoft-Fallback-Adresse (noreply@retaha.de) versendet.
    </div>
  )}

  {message && (
    <div class={`mb-8 px-4 py-3 text-sm border-l-4 ${
      message.type === 'success'
        ? 'bg-green-50 border-green-700 text-green-800'
        : 'bg-red-50 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  {!settings?.custom_email_domain ? (
    <!-- Noch keine Domain konfiguriert -->
    <div class="max-w-2xl">
      <p class="text-anthrazit/80 leading-relaxed text-base mb-8">
        Trage deine Hotel-Domain ein (z.B. <span class="font-mono">gategardenhotel.de</span>).
        Wir legen sie bei Resend an und zeigen dir die DNS-Einträge, die du bei deinem Domain-Provider
        (Strato, IONOS, Cloudflare, GoDaddy, etc.) hinterlegen musst.
      </p>

      <form method="POST" action="/api/admin/email-domain" class="space-y-6">
        <input type="hidden" name="_action" value="add" />

        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-2">— Domain —</span>
          <input
            type="text"
            name="domain"
            placeholder="z.B. gategardenhotel.de"
            required
            autocomplete="off"
            spellcheck="false"
            class="bauhaus-input bauhaus-input--mono"
            disabled={!resendApiKeySet}
          />
          <span class="text-xs italic text-anthrazit/55 mt-2 block">
            Ohne https:// oder www. — nur die Apex-Domain.
          </span>
        </label>

        <button type="submit" class="bauhaus-button bauhaus-button--primary" disabled={!resendApiKeySet}>
          Bei Resend anlegen
        </button>
      </form>
    </div>
  ) : (
    <!-- Domain konfiguriert: Status + DNS-Records -->
    <div class="space-y-8 max-w-3xl">

      <section class="border-t border-b border-anthrazit/[0.12] py-8">
        <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
          <p class="eyebrow text-pink-shock m-0">— Konfigurierte Domain —</p>
          {(() => {
            const statusValue = settings.custom_email_status ?? 'pending';
            const badge = statusValue === 'verified'
              ? { label: '✓ Verifiziert', classes: 'bg-green-100 text-green-800' }
              : statusValue === 'failed'
                ? { label: '✗ Fehler',    classes: 'bg-red-100 text-red-800' }
                : { label: '⏳ Pending',   classes: 'bg-amber-100 text-amber-800' };
            return (
              <span class={`text-xs uppercase tracking-[0.12em] px-2.5 py-1 ${badge.classes}`}>
                {badge.label}
              </span>
            );
          })()}
        </div>

        <p class="text-2xl font-mono text-anthrazit m-0 mb-4">
          welcome@<strong class="font-bold">{settings.custom_email_domain}</strong>
        </p>

        {settings.custom_email_status === 'verified' ? (
          <p class="text-sm text-anthrazit/70 leading-relaxed">
            Customer-Facing-Mails (Pre-Arrival etc.) gehen ab sofort von deiner Domain raus.
            Hotelier-interne Mails (Booking-Notifications) bleiben über noreply@retaha.de.
          </p>
        ) : (
          <p class="text-sm text-anthrazit/70 leading-relaxed">
            DNS-Einträge unten beim Provider hinterlegen, dann „Domain verifizieren" klicken.
            DNS-Propagation kann bis zu 24 Stunden dauern.
          </p>
        )}
      </section>

      {/* DNS Records */}
      {domainDetailError && (
        <div class="px-4 py-3 text-sm bg-red-50 border-l-4 border-red-700 text-red-800">
          Domain-Details konnten nicht von Resend geladen werden: {domainDetailError}
        </div>
      )}

      {domainDetail && domainDetail.records.length > 0 && (
        <section>
          <p class="eyebrow text-anthrazit/55 mb-4">— DNS-Einträge —</p>
          <p class="text-xs italic text-anthrazit/55 mb-4 max-w-xl">
            Diese Einträge bei deinem Domain-Provider hinterlegen. Genauer Klick-Pfad siehe Provider-Doku
            (bei Strato unter „Domains → DNS-Verwaltung", bei IONOS unter „Domain → Domain-Tools").
          </p>
          <div class="overflow-x-auto border border-stein">
            <table class="w-full text-sm">
              <thead class="bg-anthrazit/[0.03]">
                <tr>
                  <th class="text-left p-3 font-medium border-b border-stein">Typ</th>
                  <th class="text-left p-3 font-medium border-b border-stein">Name / Host</th>
                  <th class="text-left p-3 font-medium border-b border-stein">Wert</th>
                  {domainDetail.records.some(r => r.priority !== undefined) && (
                    <th class="text-left p-3 font-medium border-b border-stein">Priorität</th>
                  )}
                </tr>
              </thead>
              <tbody>
                {domainDetail.records.map(r => (
                  <tr class="border-b border-stein last:border-b-0">
                    <td class="p-3 font-mono text-xs">{r.type ?? r.record}</td>
                    <td class="p-3 font-mono text-xs break-all">{r.name}</td>
                    <td class="p-3 font-mono text-xs break-all">{r.value}</td>
                    {domainDetail.records.some(x => x.priority !== undefined) && (
                      <td class="p-3 font-mono text-xs">{r.priority ?? '—'}</td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {/* Actions */}
      <section class="flex gap-4 flex-wrap items-center pt-2">
        {settings.custom_email_status !== 'verified' && (
          <form method="POST" action="/api/admin/email-domain" class="m-0">
            <input type="hidden" name="_action" value="verify" />
            <button type="submit" class="bauhaus-button bauhaus-button--primary">
              Domain verifizieren
            </button>
          </form>
        )}
        <form method="POST" action="/api/admin/email-domain" class="m-0"
              onsubmit="return confirm('Domain wirklich entfernen? Mails gehen dann wieder von noreply@retaha.de raus.')">
          <input type="hidden" name="_action" value="remove" />
          <button type="submit" class="bauhaus-button bauhaus-button--ghost">
            Domain entfernen
          </button>
        </form>
      </section>
    </div>
  )}
</AdminLayout>
