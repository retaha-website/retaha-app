---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');
---

<AdminLayout title="Whats App" hotel={hotel} user={user}>

  <EditorialPageHeader
    sectionNumber="27"
    sectionLabel="Integrationen"
    headlineLight="Whats-"
    headlineBold="App"
    subtitle="Wo deine Gäste ohnehin schreiben."
  />

  <div class="max-w-3xl">
    <p class="text-anthrazit/80 leading-relaxed text-base">
      Verbinde deinen WhatsApp-Business-Account mit retaha. Eingehende Nachrichten erscheinen in der Concierge-Inbox. Ausgehende Kampagnen — Pre-Stay-Info, Geburtstags-Wunsch, Empfehlungen — kannst du direkt über WhatsApp senden, wo deine Gäste sowieso schon sind.
    </p>
  </div>

</AdminLayout>
