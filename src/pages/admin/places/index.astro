---
// Sprint E2 · Phase 4 — Hotelier-UI: Place-Picks-Pflege
//
// Tab-Switcher (5 Kategorien) + Autocomplete (Alpine, debounced 300ms) +
// Pick-Cards (sort/edit/delete) + Auto-Suggestions aus nearby_cache
// (Phase 6 füllt das, vorher leer).
//
// POST-Actions im _action-Pattern (konsistent zu /admin/eve/knowledge):
//   pick_add        — placeId + category → addPickToHotel (Phase 5 Detail)
//   pick_update     — hotel_note (DE/EN/FR/ES) + sort_order
//   pick_delete     — Pick entfernen
//   pick_move       — sort_order ±1
//   promote_auto    — Auto-Suggestion zu Pick promoten

import AdminLayout from '../../../components/AdminLayout.astro';
import EditorialPageHeader from '../../../components/admin/EditorialPageHeader.astro';
import PlacesSubNav from '../../../components/admin/PlacesSubNav.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../lib/auth';
import { addPickToHotel } from '../../../lib/places/pick-actions';
import { buildPhotoUrl, type PickCategory } from '../../../lib/places/google-client';
import { mergeAndTranslate, asLanguageCode } from '../../../lib/i18n/save-hook.ts';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

// Sprint i18n Phase 5 — Hotel-Sprach-Settings für 1-Feld-UX laden
const { data: hotelLangRow } = await client
  .from('hotels')
  .select('default_language, enabled_languages')
  .eq('id', hotel.id)
  .maybeSingle();
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';
const hotelEnabledLangs: string[] = Array.isArray(hotelLangRow?.enabled_languages)
  ? hotelLangRow.enabled_languages : ['de','en','fr','es'];
const LANGUAGE_LABELS_LOCAL: Record<string, string> = {
  de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands',
  ru: 'Русский', ar: 'العربية', zh: '中文',
};
const otherEnabled = hotelEnabledLangs.filter(l => l !== hotelDefaultLang);
const otherEnabledLabel = otherEnabled.map(l => LANGUAGE_LABELS_LOCAL[l] || l).join(', ');

let message: { type: 'success' | 'error'; text: string } | null = null;

// ─── POST-Handlers ──────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'pick_add') {
    const placeId = form.get('place_id')?.toString().trim() ?? '';
    const cat = form.get('category')?.toString() ?? '';
    if (!placeId || !['restaurant', 'cafe', 'bar', 'activity', 'sight'].includes(cat)) {
      message = { type: 'error', text: 'Place-ID und Kategorie sind Pflicht.' };
    } else {
      const result = await addPickToHotel(client, hotel.id, placeId, cat as PickCategory);
      if (result.ok) {
        return Astro.redirect(`/admin/places?cat=${cat}&saved=pick_added`);
      }
      message = { type: 'error', text: result.error ?? 'Pick anlegen fehlgeschlagen.' };
    }
  }

  else if (action === 'pick_update') {
    // Sprint i18n Phase 5 — 1-Feld-UX: Hotelier pflegt nur Default-Sprache.
    // Save schreibt in hotel_note_i18n[default_lang] + spiegelt zur alten DE-
    // Spalte (Safety bis Phase 10). Phase 6 fügt async Translation-Hook hinzu.
    const id = form.get('id')?.toString();
    const note = form.get('hotel_note_default')?.toString().trim() || null;
    if (!id) {
      message = { type: 'error', text: 'Keine ID übergeben.' };
    } else {
      // Bestehende i18n laden — mergeAndTranslate respektiert override-Slots
      const { data: existing } = await client
        .from('hotel_place_picks')
        .select('hotel_note_i18n')
        .eq('id', id).eq('hotel_id', hotel.id).maybeSingle();

      // Sprint i18n Phase 6 — Save-Hook mit Auto-Translation
      const hookResult = await mergeAndTranslate(
        existing?.hotel_note_i18n as any,
        note ?? '',
        asLanguageCode(hotelDefaultLang),
        { logLabel: `place_picks.${id}.hotel_note` },
      );

      const updates: Record<string, any> = {
        hotel_note_i18n: Object.keys(hookResult.i18n).length > 0 ? hookResult.i18n : null,
        updated_at: new Date().toISOString(),
      };
      if (hotelDefaultLang === 'de') updates.hotel_note = note;

      const { error } = await client.from('hotel_place_picks').update(updates)
        .eq('id', id).eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Update fehlgeschlagen: ${error.message}` };
      } else {
        const langCount = Object.keys(hookResult.i18n).length;
        message = {
          type: 'success',
          text: `Hotel-Notiz gespeichert — ${langCount} Sprachen ($${hookResult.cost.estimatedUSD.toFixed(5)}, ${hookResult.durationMs}ms)` +
                (hookResult.failures.length ? ` · ${hookResult.failures.length} Übersetzungs-Fehler` : ''),
        };
      }
    }
  }

  else if (action === 'pick_delete') {
    const id = form.get('id')?.toString();
    if (!id) {
      message = { type: 'error', text: 'Keine ID übergeben.' };
    } else {
      const { error } = await client.from('hotel_place_picks').delete().eq('id', id).eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
      else message = { type: 'success', text: 'Pick entfernt.' };
    }
  }

  else if (action === 'pick_move') {
    const id = form.get('id')?.toString();
    const dir = form.get('direction')?.toString();  // 'up' | 'down'
    if (id && (dir === 'up' || dir === 'down')) {
      // Aktuellen sort_order laden
      const { data: current } = await client
        .from('hotel_place_picks')
        .select('sort_order')
        .eq('id', id).single();
      const newOrder = (current?.sort_order ?? 0) + (dir === 'up' ? -1 : 1);
      await client.from('hotel_place_picks').update({
        sort_order: newOrder,
        updated_at: new Date().toISOString(),
      }).eq('id', id).eq('hotel_id', hotel.id);
      message = { type: 'success', text: dir === 'up' ? 'Nach oben verschoben.' : 'Nach unten verschoben.' };
    }
  }
}

// ─── Load current state ────────────────────────────────────────
const activeCategory = (Astro.url.searchParams.get('cat') as PickCategory) || 'restaurant';

const { data: hotelRow } = await client
  .from('hotels')
  .select('latitude, longitude')
  .eq('id', hotel.id)
  .maybeSingle();
const hasAddress = typeof hotelRow?.latitude === 'number' && typeof hotelRow?.longitude === 'number';

const { data: allPicks } = await client
  .from('hotel_place_picks')
  .select('id, place_id, category, hotel_note, hotel_note_en, hotel_note_fr, hotel_note_es, hotel_note_i18n, cached_data, photo_references, sort_order, last_refresh')
  .eq('hotel_id', hotel.id)
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

const picksByCategory: Record<string, any[]> = {};
for (const p of allPicks ?? []) {
  if (!picksByCategory[p.category]) picksByCategory[p.category] = [];
  picksByCategory[p.category].push(p);
}
const activePicks = picksByCategory[activeCategory] ?? [];

const { data: nearbyCache } = await client
  .from('hotel_place_nearby_cache')
  .select('category, cached_places, last_refresh')
  .eq('hotel_id', hotel.id)
  .eq('category', activeCategory)
  .maybeSingle();

// Auto-Suggestions filtern: keine die schon als Pick gespeichert sind
const pickPlaceIds = new Set(activePicks.map(p => p.place_id));
const autoSuggestions = ((nearbyCache?.cached_places as any[]) ?? [])
  .filter(p => !pickPlaceIds.has(p.placeId ?? p.place_id))
  .slice(0, 10);

const TABS: Array<{ key: PickCategory; label: string }> = [
  { key: 'restaurant', label: 'Restaurants' },
  { key: 'cafe',       label: 'Cafés' },
  { key: 'bar',        label: 'Bars' },
  { key: 'activity',   label: 'Aktivitäten' },
  { key: 'sight',      label: 'Sehenswertes' },
];

// Saved-Flash
const savedParam = Astro.url.searchParams.get('saved');
if (savedParam === 'pick_added' && !message) {
  message = { type: 'success', text: 'Pick hinzugefügt — bitte Notiz pflegen.' };
}
---

<AdminLayout title="Empfehlungen" hotel={hotel} user={user}>
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber="07"
      sectionLabel="Empfehlungen · Google Places"
      headlineLight="Deine"
      headlineBold="Empfehlungen"
      subtitle="Picks für deine Lieblings-Restaurants, Cafés, Bars und Sehenswürdigkeiten. Eve zeigt sie deinen Gästen zuerst."
    />
  </div>

  <PlacesSubNav currentPath={Astro.url.pathname} />

  <div class="max-w-4xl mx-auto px-6 pb-24">

    {message && (
      <div class={`mb-6 px-4 py-3 text-sm ${
        message.type === 'success'
          ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
          : 'bg-red-50 border-l-4 border-red-700 text-red-800'
      }`}>
        {message.text}
      </div>
    )}

    {!hasAddress && (
      <div class="mb-8 p-5 border-l-4 border-amber-500 bg-amber-50 text-sm leading-relaxed">
        <strong class="text-amber-900">Hotel-Adresse fehlt.</strong>
        <span class="text-amber-800"> Bitte zuerst die Adresse in den </span>
        <a href="/admin/settings" class="text-amber-900 underline font-medium">Allgemeinen Einstellungen</a>
        <span class="text-amber-800"> pflegen — sonst können wir keine Empfehlungen in der Nähe finden.</span>
      </div>
    )}

    <!-- Category-Tabs -->
    <div class="flex gap-1 mb-8 border-b border-stein overflow-x-auto" role="tablist">
      {TABS.map(tab => (
        <a
          href={`/admin/places?cat=${tab.key}`}
          role="tab"
          aria-selected={activeCategory === tab.key}
          class={`px-4 py-3 text-sm whitespace-nowrap border-b-2 -mb-px transition-colors ${
            activeCategory === tab.key
              ? 'border-pink-shock text-anthrazit font-medium'
              : 'border-transparent text-anthrazit/55 hover:text-anthrazit'
          }`}
        >
          {tab.label}
          {(picksByCategory[tab.key]?.length ?? 0) > 0 && (
            <span class="ml-1 text-xs text-anthrazit/40">({picksByCategory[tab.key].length})</span>
          )}
        </a>
      ))}
    </div>

    <!-- Hinweis -->
    <div class="mb-8 p-5 border-l-4 border-pink-shock/60 bg-anthrazit/5">
      <p class="text-sm text-anthrazit/80 leading-relaxed">
        <strong>Pflege deine Lieblings-{TABS.find(t => t.key === activeCategory)?.label.toLowerCase() ?? 'Picks'}.</strong>
        {' '}Eve empfiehlt deine Picks zuerst, ergänzt mit Auto-Empfehlungen aus Google Places.
      </p>
    </div>

    <!-- Autocomplete-Form -->
    <section class="mb-12" x-data={`placesAutocomplete('${activeCategory}', ${hasAddress ? 'true' : 'false'})`}>
      <h2 class="text-lg font-light mb-3">{TABS.find(t => t.key === activeCategory)?.label} suchen</h2>
      <div class="relative">
        <input
          type="text"
          x-model="query"
          @input.debounce.300ms="search()"
          placeholder={hasAddress ? 'Name eingeben, z.B. „Restaurant Maria"…' : 'Erst Adresse in Einstellungen pflegen…'}
          :disabled="!hasAddress || pending"
          class="w-full px-4 py-3 border border-stein focus:border-pink-shock focus:outline-none text-sm bg-white disabled:bg-anthrazit/5"
          autocomplete="off"
        />
        <span x-show="pending" x-cloak class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-anthrazit/40">…</span>

        <div
          x-show="suggestions.length > 0"
          x-cloak
          class="absolute left-0 right-0 top-full mt-1 bg-white border border-stein shadow-lg z-10 max-h-80 overflow-y-auto"
        >
          <template x-for="s in suggestions" :key="s.placeId">
            <form method="POST" class="block">
              <input type="hidden" name="_action" value="pick_add" />
              <input type="hidden" name="category" :value="category" />
              <input type="hidden" name="place_id" :value="s.placeId" />
              <button
                type="submit"
                class="w-full text-left px-4 py-3 hover:bg-anthrazit/5 transition-colors border-b border-stein last:border-b-0"
              >
                <div class="font-medium text-sm text-anthrazit" x-text="s.mainText"></div>
                <div class="text-xs text-anthrazit/55 mt-0.5" x-text="s.secondaryText"></div>
              </button>
            </form>
          </template>
        </div>
      </div>
    </section>

    <!-- Picks-Liste -->
    <section class="mb-12">
      <h2 class="text-lg font-light mb-4">
        Deine Picks
        {activePicks.length > 0 && <span class="text-anthrazit/40 text-sm">({activePicks.length})</span>}
      </h2>

      {activePicks.length === 0 && (
        <p class="text-sm italic text-anthrazit/55 text-center py-8">
          Noch keine Picks in dieser Kategorie. Suche oben nach einem Ort.
        </p>
      )}

      {activePicks.map((pick, idx) => {
        const cd = (pick.cached_data ?? {}) as any;
        const photoUrl = pick.photo_references?.[0] ? buildPhotoUrl(pick.photo_references[0], 200) : null;
        return (
          <article
            class={`mb-4 border bg-white transition-all duration-700`}
            x-data={`pickCardRefresh('${pick.id}')`}
            :class="{ 'border-pink-shock shadow-lg': pulse, 'border-stein': !pulse }"
          >
            <div x-show="!editing" class="p-4 flex gap-4">
              {photoUrl && (
                <img src={photoUrl} alt={cd.name ?? ''} class="w-24 h-24 object-cover flex-shrink-0" loading="lazy" />
              )}
              <div class="flex-1 min-w-0">
                <div class="flex justify-between items-start gap-2 mb-1">
                  <h3 class="font-medium text-anthrazit truncate">{cd.name ?? '(Name fehlt)'}</h3>
                  <div class="flex gap-1 shrink-0">
                    {idx > 0 && (
                      <form method="POST" class="inline">
                        <input type="hidden" name="_action" value="pick_move" />
                        <input type="hidden" name="id" value={pick.id} />
                        <input type="hidden" name="direction" value="up" />
                        <button type="submit" class="text-xs text-anthrazit/55 hover:text-pink-shock px-1" aria-label="Nach oben">↑</button>
                      </form>
                    )}
                    {idx < activePicks.length - 1 && (
                      <form method="POST" class="inline">
                        <input type="hidden" name="_action" value="pick_move" />
                        <input type="hidden" name="id" value={pick.id} />
                        <input type="hidden" name="direction" value="down" />
                        <button type="submit" class="text-xs text-anthrazit/55 hover:text-pink-shock px-1" aria-label="Nach unten">↓</button>
                      </form>
                    )}
                    <button type="button" @click="editing = true" class="text-xs text-anthrazit/55 hover:text-pink-shock px-2">Notiz</button>
                    <button
                      type="button"
                      class="text-xs text-anthrazit/55 hover:text-pink-shock px-1 disabled:opacity-50 disabled:cursor-wait"
                      :disabled="refreshing"
                      @click="refresh()"
                      :title="refreshing ? '...' : 'Daten von Google aktualisieren'"
                      aria-label="Refresh"
                    >↻</button>
                    <form method="POST" class="inline" onsubmit="return confirm('Diesen Pick wirklich entfernen?')">
                      <input type="hidden" name="_action" value="pick_delete" />
                      <input type="hidden" name="id" value={pick.id} />
                      <button type="submit" class="text-xs text-anthrazit/55 hover:text-red-600 px-1">×</button>
                    </form>
                  </div>
                </div>
                <p class="text-xs text-anthrazit/55 mb-1">
                  {cd.rating && <span>⭐ {cd.rating} ({cd.user_ratings_total ?? 0})</span>}
                  {cd.price_level && <span> · {cd.price_level.replace('PRICE_LEVEL_', '').toLowerCase()}</span>}
                </p>
                <p class="text-xs text-anthrazit/55 truncate">{cd.formatted_address ?? ''}</p>
                {(pick.hotel_note_i18n?.[hotelDefaultLang]?.value ?? pick.hotel_note) && (
                  <p class="text-sm text-anthrazit/80 mt-2 italic">„{pick.hotel_note_i18n?.[hotelDefaultLang]?.value ?? pick.hotel_note}"</p>
                )}
              </div>
            </div>

            <form x-show="editing" method="POST" class="p-4 space-y-3" x-cloak>
              <input type="hidden" name="_action" value="pick_update" />
              <input type="hidden" name="id" value={pick.id} />
              <div>
                <label class="block text-xs text-anthrazit/55 mb-1 uppercase tracking-wider">
                  Hotel-Notiz ({LANGUAGE_LABELS_LOCAL[hotelDefaultLang]})
                </label>
                <textarea
                  name="hotel_note_default"
                  rows="2"
                  placeholder="z.B. „Unser Lieblings-Italiener für Geschäftsessen — bitte Risotto probieren!"
                  class="w-full px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none text-sm resize-vertical"
                >{pick.hotel_note_i18n?.[hotelDefaultLang]?.value ?? pick.hotel_note ?? ''}</textarea>
                <p class="text-xs text-anthrazit/55 mt-1 italic">
                  Optional. {otherEnabled.length > 0
                    ? `Wird automatisch in ${otherEnabledLabel} übersetzt (sobald Phase 6 aktiv).`
                    : 'Aktuell nur deine Standardsprache aktiviert.'}
                </p>
              </div>
              <div class="flex gap-3">
                <button type="submit" class="px-4 py-2 bg-anthrazit text-white text-sm font-medium hover:bg-pink-shock transition-colors">Speichern</button>
                <button type="button" @click="editing = false" class="px-4 py-2 text-anthrazit/55 hover:text-anthrazit text-sm">Abbrechen</button>
              </div>
            </form>
          </article>
        );
      })}
    </section>

    <!-- Auto-Suggestions aus nearby_cache -->
    <section x-data={`placesRefresh('${activeCategory}')`}>
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-light">
          Mehr in der Nähe
          {autoSuggestions.length > 0 && <span class="text-anthrazit/40 text-sm">({autoSuggestions.length})</span>}
        </h2>
        <button
          type="button"
          class="text-xs text-anthrazit/55 hover:text-pink-shock border border-stein hover:border-pink-shock px-3 py-1.5 transition-colors disabled:opacity-50 disabled:cursor-wait"
          :disabled="refreshing"
          @click="refreshNearby()"
        >
          <span x-show="!refreshing">↻ Auto-Empfehlungen aktualisieren</span>
          <span x-show="refreshing" x-cloak>… aktualisiere</span>
        </button>
      </div>
      <p x-show="refreshMessage" x-cloak class="mb-3 px-3 py-2 text-xs" :class="refreshOk ? 'bg-green-50 text-green-800 border-l-2 border-green-700' : 'bg-red-50 text-red-800 border-l-2 border-red-700'" x-text="refreshMessage"></p>
      {!nearbyCache && (
        <div class="p-4 bg-anthrazit/5 text-sm text-anthrazit/55 italic">
          Auto-Empfehlungen werden noch nicht angezeigt. Der monatliche Refresh-Cron (Phase 6)
          baut den Cache automatisch auf — danach erscheinen hier ~15 Vorschläge in der Nähe.
        </div>
      )}
      {nearbyCache && autoSuggestions.length === 0 && (
        <p class="text-sm italic text-anthrazit/55 py-4">Alle nahen Vorschläge sind bereits in deinen Picks.</p>
      )}
      {autoSuggestions.map(s => (
        <div class="flex items-center justify-between gap-3 py-3 border-b border-stein/50 last:border-b-0">
          <div class="flex-1 min-w-0">
            <p class="text-sm text-anthrazit truncate">
              {s.name ?? '(no name)'}
              {s.rating && <span class="text-anthrazit/55 text-xs ml-2">⭐ {s.rating} ({s.userRatingCount ?? 0})</span>}
            </p>
            <p class="text-xs text-anthrazit/55 truncate">{s.formattedAddress ?? s.address ?? ''}</p>
          </div>
          <form method="POST" class="shrink-0">
            <input type="hidden" name="_action" value="pick_add" />
            <input type="hidden" name="category" value={activeCategory} />
            <input type="hidden" name="place_id" value={s.placeId ?? s.place_id} />
            <button type="submit" class="text-xs text-pink-shock hover:bg-pink-shock hover:text-white border border-pink-shock px-3 py-1 transition-colors">
              Zu Picks +
            </button>
          </form>
        </div>
      ))}
    </section>

  </div>

  <script>
    document.addEventListener('alpine:init', () => {
      // @ts-expect-error - Alpine global
      Alpine.data('placesAutocomplete', (category: string, hasAddress: boolean) => ({
        category,
        hasAddress,
        query: '',
        suggestions: [] as Array<{ placeId: string; mainText: string; secondaryText: string }>,
        pending: false,

        async search() {
          const q = this.query.trim();
          if (q.length < 2) { this.suggestions = []; return; }
          this.pending = true;
          try {
            const res = await fetch(`/api/admin/places/autocomplete?q=${encodeURIComponent(q)}&category=${this.category}`);
            const body = await res.json();
            this.suggestions = body.ok ? (body.suggestions ?? []) : [];
          } catch (err) {
            console.warn('[places autocomplete]', err);
            this.suggestions = [];
          } finally {
            this.pending = false;
          }
        },
      }));

      // @ts-expect-error - Alpine global
      Alpine.data('placesRefresh', (category: string) => ({
        category,
        refreshing: false,
        refreshMessage: '' as string,
        refreshOk: true,

        async refreshNearby() {
          this.refreshing = true;
          this.refreshMessage = '';
          try {
            const res = await fetch('/api/admin/places/refresh-nearby', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ category: this.category }),
            });
            const body = await res.json();
            if (body.ok) {
              this.refreshOk = true;
              this.refreshMessage = `Aktualisiert — ${body.total_places_cached ?? 0} Places für ${this.category} gefunden. (Lade die Seite neu für den Anzeige-Update.)`;
            } else {
              this.refreshOk = false;
              this.refreshMessage = `Fehler: ${body.error ?? 'unbekannt'}`;
            }
          } catch (err) {
            this.refreshOk = false;
            this.refreshMessage = `Netzwerk-Fehler: ${(err as Error).message}`;
          } finally {
            this.refreshing = false;
          }
        },
      }));

      // @ts-expect-error - Alpine global
      Alpine.data('pickCardRefresh', (pickId: string) => ({
        pickId,
        editing: false,
        refreshing: false,
        pulse: false,

        async refresh() {
          this.refreshing = true;
          try {
            const res = await fetch('/api/admin/places/refresh-pick', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: this.pickId }),
            });
            const body = await res.json();
            if (body.ok) {
              this.pulse = true;
              setTimeout(() => { this.pulse = false; }, 2500);
            } else {
              console.warn('[pick refresh]', body.error);
            }
          } catch (err) {
            console.warn('[pick refresh] network', err);
          } finally {
            this.refreshing = false;
          }
        },
      }));
    });
  </script>
</AdminLayout>

<style>
  [x-cloak] { display: none !important; }
</style>
