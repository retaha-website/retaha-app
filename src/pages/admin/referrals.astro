---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');
---

<AdminLayout title="Empfehlungs Programm" hotel={hotel} user={user}>

  <EditorialPageHeader
    sectionNumber="21"
    sectionLabel="Marketing"
    headlineLight="Empfehlungs-"
    headlineBold="Programm"
    subtitle="Aus Gästen werden Botschafter."
  />

  <div class="max-w-3xl">
    <p class="text-anthrazit/80 leading-relaxed text-base">
      Jeder Gast bekommt einen persönlichen Empfehlungs-Code. Wer einen neuen Gast bringt, bekommt eine Belohnung — ein Upgrade, einen Drink an der Bar, einen Rabatt auf den nächsten Aufenthalt. Du entscheidest was, retaha verfolgt automatisch wer wen gebracht hat.
    </p>
  </div>

</AdminLayout>
