---
import AdminLayout from '../../components/AdminLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'save_times') {
    const updates = {
      service_start_time: form.get('service_start_time')?.toString() || '07:00',
      service_end_time: form.get('service_end_time')?.toString() || '22:00',
      updated_at: new Date().toISOString(),
    };

    const { data: updatedRows, error } = await client
      .from('hotel_settings')
      .update(updates)
      .eq('hotel_id', hotel.id)
      .select('hotel_id');

    if (error) {
      message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
    } else if (!updatedRows || updatedRows.length === 0) {
      message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS)' };
    } else {
      message = { type: 'success', text: 'Service-Zeiten gespeichert.' };
    }
  } else if (action === 'save_items') {
    const itemsJson = form.get('items_json')?.toString();
    if (itemsJson) {
      try {
        const items = JSON.parse(itemsJson);
        if (!Array.isArray(items)) throw new Error('Items müssen Array sein');

        const { data: updatedRows, error } = await client
          .from('hotel_settings')
          .update({ service_items: items, updated_at: new Date().toISOString() })
          .eq('hotel_id', hotel.id)
          .select('hotel_id');

        if (error) {
          message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
        } else if (!updatedRows || updatedRows.length === 0) {
          message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS)' };
        } else {
          message = { type: 'success', text: 'Service-Items gespeichert.' };
        }
      } catch (e: any) {
        message = { type: 'error', text: `Ungültige Daten: ${e.message || 'unbekannt'}` };
      }
    }
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select('service_items, service_start_time, service_end_time')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const items = ((settings?.service_items as any[]) || []);
const startTime = ((settings as any)?.service_start_time || '07:00').substring(0, 5);
const endTime = ((settings as any)?.service_end_time || '22:00').substring(0, 5);
---

<AdminLayout title="Service" hotel={hotel} user={user} activeTab="service">
  <div class="mb-8">
    <p class="text-xs italic text-red-700 mb-2" style="font-family: Georgia, serif;">— Service —</p>
    <h1 class="text-3xl font-light">Was deine Gäste<br /><span class="font-medium">anfragen können</span><span class="text-red-700">.</span></h1>
    <p class="text-sm text-stone-600 mt-3 max-w-xl">
      Service-Items wie Handtücher, Wasser, Bügeleisen — der Gast wählt aus, du bekommst die Anfrage.
      Zeitfenster gibt vor, wann Service möglich ist.
    </p>
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <!-- Section: Zeiten -->
  <section class="bg-white border border-stone-200 p-6 mb-6">
    <h2 class="text-xl font-medium mb-4">Service-Zeiten</h2>
    <p class="text-xs text-stone-500 mb-4">In diesem Zeitfenster können Gäste Service anfragen.</p>

    <form method="POST">
      <input type="hidden" name="_action" value="save_times" />
      <div class="grid grid-cols-2 gap-4 max-w-md">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Beginn</span>
          <input type="time" name="service_start_time" value={startTime}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900" />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Ende</span>
          <input type="time" name="service_end_time" value={endTime}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900" />
        </label>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" class="bg-stone-900 text-stone-50 px-6 py-3 text-sm hover:bg-red-900 transition font-medium">
          Zeiten speichern
        </button>
      </div>
    </form>
  </section>

  <!-- Section: Items -->
  <section class="bg-white border border-stone-200 p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-medium">Service-Items</h2>
      <button type="button" id="add-item-btn"
        class="text-sm border border-stone-300 px-4 py-2 hover:border-red-700 hover:text-red-700 transition">
        + Item hinzufügen
      </button>
    </div>

    <form method="POST" id="items-form">
      <input type="hidden" name="_action" value="save_items" />
      <input type="hidden" name="items_json" id="items-json-input" />

      <div id="items-container" class="space-y-4 mb-6"></div>

      <div class="flex justify-end pt-4 border-t border-stone-200">
        <button type="submit" class="bg-stone-900 text-stone-50 px-6 py-3 text-sm hover:bg-red-900 transition font-medium">
          Items speichern
        </button>
      </div>
    </form>
  </section>

  <script is:inline define:vars={{ initialItems: items }}>
    let items = JSON.parse(JSON.stringify(initialItems || []));

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      })[c]);
    }

    function render() {
      const container = document.getElementById('items-container');
      container.innerHTML = '';

      items.forEach((item, idx) => {
        const div = document.createElement('div');
        div.className = 'border border-stone-200 p-4';
        div.innerHTML = `
          <div class="flex justify-between items-start mb-3">
            <span class="bg-stone-100 text-stone-600 text-xs px-2 py-1 font-mono">Item ${idx + 1}</span>
            <div class="flex gap-2">
              <button type="button" data-action="translate" data-idx="${idx}"
                class="text-xs bg-stone-900 text-stone-50 px-3 py-1 hover:bg-red-900 transition">
                DE → andere Sprachen
              </button>
              <button type="button" data-action="delete" data-idx="${idx}"
                class="text-xs text-stone-400 hover:text-red-700">
                Entfernen
              </button>
            </div>
          </div>

          <div class="grid grid-cols-12 gap-3">
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Slug (id)</span>
              <input type="text" data-idx="${idx}" data-field="id" value="${escapeHtml(item.id || '')}" placeholder="z.B. towels"
                class="w-full px-2 py-1.5 border border-stone-300 text-xs focus:outline-none focus:border-stone-900 font-mono" />
            </label>
            <div class="col-span-6"></div>

            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Name (DE)</span>
              <input type="text" data-idx="${idx}" data-field="name_de" value="${escapeHtml(item.name_de || '')}"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900" />
            </label>
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Name (EN)</span>
              <input type="text" data-idx="${idx}" data-field="name_en" value="${escapeHtml(item.name_en || '')}"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900" />
            </label>
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Name (FR)</span>
              <input type="text" data-idx="${idx}" data-field="name_fr" value="${escapeHtml(item.name_fr || '')}"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900" />
            </label>
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Name (ES)</span>
              <input type="text" data-idx="${idx}" data-field="name_es" value="${escapeHtml(item.name_es || '')}"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900" />
            </label>

            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Beschreibung (DE)</span>
              <textarea data-idx="${idx}" data-field="description_de" rows="2"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900">${escapeHtml(item.description_de || '')}</textarea>
            </label>
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Beschreibung (EN)</span>
              <textarea data-idx="${idx}" data-field="description_en" rows="2"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900">${escapeHtml(item.description_en || '')}</textarea>
            </label>
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Beschreibung (FR)</span>
              <textarea data-idx="${idx}" data-field="description_fr" rows="2"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900">${escapeHtml(item.description_fr || '')}</textarea>
            </label>
            <label class="block col-span-6">
              <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Beschreibung (ES)</span>
              <textarea data-idx="${idx}" data-field="description_es" rows="2"
                class="w-full px-2 py-1.5 border border-stone-300 text-sm focus:outline-none focus:border-stone-900">${escapeHtml(item.description_es || '')}</textarea>
            </label>
          </div>
        `;
        container.appendChild(div);
      });

      container.querySelectorAll('input, textarea').forEach(el => {
        el.addEventListener('input', e => {
          const idx = parseInt(e.target.dataset.idx);
          const field = e.target.dataset.field;
          items[idx][field] = e.target.value;
        });
      });

      container.querySelectorAll('[data-action="delete"]').forEach(btn => {
        btn.addEventListener('click', e => {
          const idx = parseInt(e.currentTarget.dataset.idx);
          if (confirm('Item wirklich entfernen?')) {
            items.splice(idx, 1);
            render();
          }
        });
      });

      container.querySelectorAll('[data-action="translate"]').forEach(btn => {
        btn.addEventListener('click', async e => {
          const idx = parseInt(e.currentTarget.dataset.idx);
          const item = items[idx];
          if (!item.name_de) {
            alert('Bitte zuerst DE-Name eingeben.');
            return;
          }
          const btnEl = e.currentTarget;
          btnEl.disabled = true;
          btnEl.textContent = 'Übersetze...';

          try {
            const resp = await fetch('/api/translate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                source: 'de',
                targets: ['en', 'fr', 'es'],
                fields: {
                  name_de: item.name_de,
                  description_de: item.description_de || '',
                },
              }),
            });
            const data = await resp.json();
            if (data.ok) {
              ['en', 'fr', 'es'].forEach(t => {
                if (data.result[t]) {
                  items[idx][`name_${t}`] = data.result[t].name || items[idx][`name_${t}`] || '';
                  items[idx][`description_${t}`] = data.result[t].description || items[idx][`description_${t}`] || '';
                }
              });
              render();
            } else {
              alert('Übersetzung fehlgeschlagen: ' + (data.error || 'unbekannt'));
            }
          } catch (err) {
            alert('Fehler: ' + (err.message || 'unbekannt'));
          } finally {
            btnEl.disabled = false;
            btnEl.textContent = 'DE → andere Sprachen';
          }
        });
      });

      document.getElementById('items-json-input').value = JSON.stringify(items);
    }

    document.getElementById('add-item-btn').addEventListener('click', () => {
      items.push({
        id: 'item-' + Date.now(),
        name_de: 'Neues Item',
        name_en: '', name_fr: '', name_es: '',
        description_de: '', description_en: '', description_fr: '', description_es: '',
        icon: 'default',
      });
      render();
    });

    document.getElementById('items-form').addEventListener('submit', () => {
      document.getElementById('items-json-input').value = JSON.stringify(items);
    });

    render();
  </script>
</AdminLayout>
