---
// Sprint E7 Phase 3 — Action-Card-Editor (Backoffice)
//
// Ersetzt /admin/recommendations (alter JSONB-Editor). Hotelier verwaltet
// die Hero-Swipe-Cards mit:
//   - 5 Card-Typen (internal_action / external_link / info / phone / email)
//   - 4 Sprachen (title/subtitle/eyebrow/cta je DE/EN/FR/ES)
//   - Bild-Upload via Phase-2-Storage-Lib (client-side resize → API)
//   - Sortierung ↑↓ (Drag&Drop = Backlog)
//   - Live-Preview im retaha-Bauhaus-Stil
//
// CSS-Klassen aus src/styles/retaha.css: rec-anthrazit / rec-pink / rec-white
// (rec-burgundy aus Briefing existiert NICHT im CSS → nicht angeboten).
//
// Alpine.js für Editor-State + typ-abhängige Felder + Bild-Preview.

import AdminLayout from '../../components/AdminLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

// Sprint i18n Phase 5 — Hotel-Sprach-Settings für 1-Feld-UX
const { data: hotelLangRow, error: langError } = await client
  .from('hotels').select('default_language, enabled_languages')
  .eq('id', hotel.id).maybeSingle();
if (langError) console.error('[action-cards] hotels lang query error', { hotelId: hotel.id, error: langError });
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';
const hotelEnabledLangs: string[] = Array.isArray(hotelLangRow?.enabled_languages)
  ? hotelLangRow.enabled_languages : ['de','en','fr','es'];
const LANG_LABELS: Record<string, string> = {
  de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands',
  ru: 'Русский', ar: 'العربية', zh: '中文',
};
const otherEnabled = hotelEnabledLangs.filter(l => l !== hotelDefaultLang);
const otherEnabledLabel = otherEnabled.map(l => LANG_LABELS[l] || l).join(', ');

if (!hotel.id) console.error('[action-cards] hotel.id is undefined — cards query will return empty', { hotel });
const { data: cards, error: cardsError } = await client
  .from('hotel_action_cards')
  .select('*')
  .eq('hotel_id', hotel.id)
  .order('sort_order', { ascending: true });

if (cardsError) console.error('[action-cards] hotel_action_cards query error', { hotelId: hotel.id, error: cardsError });
const cardList = (cards ?? []) as any[];
const overFive = cardList.length > 5;
const hasDefaultCards = cardList.some((c: any) => c.is_default === true);

// pickI18n-Helper inline (Hotelier-Default für Listen/Preview)
function pickI18n(value: any, lang: string, fallbackLang: string = 'de'): string {
  if (!value || typeof value !== 'object') return '';
  return value[lang]?.value || value[fallbackLang]?.value || value['de']?.value || '';
}

const INTERNAL_ACTIONS = [
  { value: 'open_breakfast',  label: 'Frühstück' },
  { value: 'open_service',    label: 'Service-Anfrage' },
  { value: 'open_eve',        label: 'Eve KI-Concierge' },
  { value: 'open_places',     label: 'Empfehlungen' },
  { value: 'open_wifi',       label: 'WLAN' },
  { value: 'open_conference', label: 'Konferenz' },
  { value: 'open_wallet',     label: 'Wallet (bald verfügbar)' },
];

const CARD_CLASSES = [
  { value: 'rec-anthrazit', label: 'Anthrazit · dunkel' },
  { value: 'rec-pink',      label: 'Pink-Shock · Statement' },
  { value: 'rec-white',     label: 'Weiß · Brutalist' },
];

const CARD_TYPE_LABELS: Record<string, string> = {
  internal_action: 'Interne Action',
  external_link:   'Externer Link',
  info:            'Info-Card (kein Click)',
  phone:           'Telefon-Link',
  email:           'Email-Link',
};
---

<AdminLayout title="Action-Cards" hotel={hotel} user={user} activeTab="recommendations">
  <div
    x-data={`actionCardsEditor(${JSON.stringify({
      hotelId: hotel.id,
      defaultLang: hotelDefaultLang,
      cards: cardList,
      hasDefaultCards: hasDefaultCards,
      internalActions: INTERNAL_ACTIONS,
      cardClasses: CARD_CLASSES,
      typeLabels: CARD_TYPE_LABELS,
    })})`}
    class="ac-root"
  >
    <header class="ac-header">
      <p class="ac-eyebrow">— 08 · Hero-Karten —</p>
      <h1 class="ac-title">Die Karten oben im Gast-Bereich<span class="h-dot">.</span></h1>
      <p class="ac-sub">Swipebar, sortierbar, mehrsprachig. Empfehlung: 3–5 Karten — mehr macht das Swipen mühsam.</p>
    </header>

    {overFive && (
      <div class="ac-hint-banner">
        <strong>{cardList.length} Karten aktiv.</strong> Empfehlung sind 3–5 — Gäste swipen sonst zu lange. (Kein Limit, nur ein Hinweis.)
      </div>
    )}

    <div class="ac-actions-row">
      <div style="display:flex;gap:8px;align-items:center">
        <button type="button" @click="openNew()" class="ac-btn ac-btn--primary">+ Neue Karte</button>
        <button type="button" @click="loadExamples()" :disabled="isLoadingExamples" x-show="!hasDefaultCards" class="ac-btn ac-btn--ghost">
          <span x-show="!isLoadingExamples">Beispiele laden</span>
          <span x-show="isLoadingExamples" x-cloak>Lädt…</span>
        </button>
      </div>
      <span class="ac-counter">{cardList.length} {cardList.length === 1 ? 'Karte' : 'Karten'}</span>
    </div>

    <!-- ─── Liste ─────────────────────────────────────────────────── -->
    {cardList.length === 0 ? (
      <div class="ac-empty">
        <p class="ac-empty-text">Noch keine Karten. Lege deine erste an — z.B. „Frühstück reservieren" als interne Action.</p>
      </div>
    ) : (
      <div class="ac-list">
        {cardList.map((c, idx) => (
          <article class="ac-row" data-card-id={c.id}>
            <div class="ac-row-thumb">
              {c.image_url ? (
                <img src={c.image_url} alt="" loading="lazy" />
              ) : (
                <div class="ac-row-thumb-placeholder" data-class={c.card_class}>—</div>
              )}
            </div>
            <div class="ac-row-meta">
              <div class="ac-row-badges">
                <span class="ac-badge">{CARD_TYPE_LABELS[c.card_type] ?? c.card_type}</span>
                {!c.is_published && <span class="ac-badge ac-badge--draft">Entwurf</span>}
                {c.action_target && <span class="ac-badge ac-badge--target">{c.action_target}</span>}
              </div>
              <p class="ac-row-title">{pickI18n(c.title_i18n, hotelDefaultLang) || c.title_de}</p>
              {(pickI18n(c.subtitle_i18n, hotelDefaultLang) || c.subtitle_de) && (
                <p class="ac-row-sub">{pickI18n(c.subtitle_i18n, hotelDefaultLang) || c.subtitle_de}</p>
              )}
            </div>
            <div class="ac-row-actions">
              <button type="button" @click={`moveCard('${c.id}','up')`} disabled={idx === 0} class="ac-icon-btn" title="Nach oben">↑</button>
              <button type="button" @click={`moveCard('${c.id}','down')`} disabled={idx === cardList.length - 1} class="ac-icon-btn" title="Nach unten">↓</button>
              <button type="button" @click={`openEdit('${c.id}')`} class="ac-icon-btn" title="Bearbeiten">✎</button>
              <button type="button" @click={`deleteCard('${c.id}')`} class="ac-icon-btn ac-icon-btn--danger" title="Löschen">×</button>
            </div>
          </article>
        ))}
      </div>
    )}

    <!-- ─── Live-Preview ─────────────────────────────────────────── -->
    <section class="ac-preview-section">
      <h2 class="ac-section-title">Live-Vorschau im Gast-Bereich</h2>
      <p class="ac-section-sub">
        Vorschau in {LANG_LABELS[hotelDefaultLang]}. Gäste sehen automatische Übersetzungen in {otherEnabledLabel || 'ihrer Sprache'}.
      </p>

      {cardList.length === 0 ? (
        <p class="ac-preview-empty">Keine Karten zum Vorschauen.</p>
      ) : (
        <div class="ac-preview-stage">
          <div class="ac-preview-scroller">
            {cardList.map(c => {
              const t = pickI18n(c.title_i18n, hotelDefaultLang) || c.title_de;
              const s = pickI18n(c.subtitle_i18n, hotelDefaultLang) || c.subtitle_de;
              const e = pickI18n(c.eyebrow_i18n, hotelDefaultLang) || c.eyebrow_de;
              const cta = pickI18n(c.cta_i18n, hotelDefaultLang) || c.cta_de;
              return (
                <div class={`ac-preview-card rec-card ${c.card_class}`}>
                  {c.image_url && <img src={c.image_url} alt="" class="ac-preview-card-img" />}
                  {e && <div class="rec-card-eyebrow">{e}</div>}
                  <div class="rec-card-title">{t}</div>
                  {s && <div class="rec-card-sub">{s}</div>}
                  {cta && <button class="rec-card-cta" type="button" disabled>{cta}</button>}
                </div>
              );
            })}
          </div>
        </div>
      )}
    </section>

    <!-- ─── Editor-Modal ─────────────────────────────────────────── -->
    <div x-show="editorOpen" x-cloak class="ac-modal-backdrop" @click.self="closeEditor()">
      <div class="ac-modal" @click.stop>
        <header class="ac-modal-head">
          <h3 x-text="editorMode === 'new' ? 'Neue Karte' : 'Karte bearbeiten'"></h3>
          <button type="button" @click="closeEditor()" class="ac-modal-close">×</button>
        </header>

        <div class="ac-modal-body">
          <!-- Typ -->
          <label class="ac-field">
            <span class="ac-field-label">Karten-Typ</span>
            <select x-model="editor.card_type" @change="onTypeChange()" class="ac-input">
              <option value="internal_action">Interne Action</option>
              <option value="external_link">Externer Link</option>
              <option value="info">Info-Card (kein Click)</option>
              <option value="phone">Telefon-Link</option>
              <option value="email">Email-Link</option>
            </select>
          </label>

          <!-- Ziel (typ-abhängig) -->
          <div x-show="editor.card_type === 'internal_action'" class="ac-field">
            <span class="ac-field-label">Welches Sheet öffnen?</span>
            <select x-model="editor.action_target" class="ac-input">
              <option value="">— wählen —</option>
              {INTERNAL_ACTIONS.map(a => <option value={a.value}>{a.label}</option>)}
            </select>
          </div>

          <div x-show="editor.card_type === 'external_link'" class="ac-field">
            <span class="ac-field-label">URL (https://…)</span>
            <input type="url" x-model="editor.action_target" placeholder="https://booking.gate-garden.de" class="ac-input" />
          </div>

          <div x-show="editor.card_type === 'phone'" class="ac-field">
            <span class="ac-field-label">Telefonnummer</span>
            <input type="tel" x-model="editor.action_target" placeholder="+49 30 12345678" class="ac-input" />
          </div>

          <div x-show="editor.card_type === 'email'" class="ac-field">
            <span class="ac-field-label">Email-Adresse</span>
            <input type="email" x-model="editor.action_target" placeholder="rezeption@gate-garden.de" class="ac-input" />
          </div>

          <!-- Sprint i18n Phase 5 — 1-Feld-UX statt 4 Sprach-Tabs -->
          <div class="ac-i18n-hint">
            <strong>Eingabe in {LANG_LABELS[hotelDefaultLang]}</strong> · Wird {otherEnabled.length > 0
              ? `automatisch in ${otherEnabledLabel} übersetzt`
              : 'aktuell nicht übersetzt (keine weiteren Gast-Sprachen aktiviert)'
            } <span class="ac-optional">(Phase 6 verdrahtet den Translation-Hook)</span>
          </div>

          <label class="ac-field">
            <span class="ac-field-label">Titel <span class="ac-required">*</span></span>
            <input type="text" x-model="editor.title" required maxlength="60" class="ac-input" />
          </label>
          <label class="ac-field">
            <span class="ac-field-label">Eyebrow <span class="ac-optional">(z.B. „Morgen Mittag")</span></span>
            <input type="text" x-model="editor.eyebrow" maxlength="40" class="ac-input" />
          </label>
          <label class="ac-field">
            <span class="ac-field-label">Untertitel <span class="ac-optional">(2–3 Sätze)</span></span>
            <textarea x-model="editor.subtitle" rows="2" maxlength="200" class="ac-input"></textarea>
          </label>
          <label class="ac-field">
            <span class="ac-field-label">Button-Text (CTA)</span>
            <input type="text" x-model="editor.cta" maxlength="30" class="ac-input" placeholder="z.B. Tisch reservieren" />
          </label>

          <!-- Bild -->
          <div class="ac-field">
            <span class="ac-field-label">Bild <span class="ac-optional">(max 2 MB, JPEG/PNG/WebP, wird auf 1200px verkleinert)</span></span>
            <div class="ac-image-row">
              <div class="ac-image-preview">
                <template x-if="editor.imagePreview || editor.image_url">
                  <img :src="editor.imagePreview || editor.image_url" alt="" />
                </template>
                <template x-if="!editor.imagePreview && !editor.image_url">
                  <span class="ac-image-placeholder">kein Bild</span>
                </template>
              </div>
              <div class="ac-image-actions">
                <input type="file" accept="image/jpeg,image/png,image/webp" @change="onFileChange($event)" class="ac-input ac-input--file" />
                <button type="button" x-show="editor.imagePreview || editor.image_url" @click="clearImage()" class="ac-btn ac-btn--ghost">Bild entfernen</button>
              </div>
            </div>
          </div>

          <!-- Style + Published -->
          <div class="ac-field-row">
            <label class="ac-field">
              <span class="ac-field-label">Karten-Stil</span>
              <select x-model="editor.card_class" class="ac-input">
                {CARD_CLASSES.map(c => <option value={c.value}>{c.label}</option>)}
              </select>
            </label>
            <label class="ac-field ac-field--checkbox">
              <input type="checkbox" x-model="editor.is_published" />
              <span>Veröffentlicht (im Gast-Frontend sichtbar)</span>
            </label>
          </div>
        </div>

        <footer class="ac-modal-foot">
          <span x-show="saveError" x-text="saveError" class="ac-error"></span>
          <button type="button" @click="closeEditor()" class="ac-btn ac-btn--ghost">Abbrechen</button>
          <button type="button" @click="saveEditor()" :disabled="isSaving" class="ac-btn ac-btn--primary">
            <span x-show="!isSaving">Speichern</span>
            <span x-show="isSaving">Speichere…</span>
          </button>
        </footer>
      </div>
    </div>

    <!-- Toast -->
    <div x-show="toast" x-cloak class="ac-toast" :class="`ac-toast--${toast?.type}`" x-text="toast?.text"></div>
  </div>

  <script>
    import Alpine from 'alpinejs';
    import { resizeImage } from '../../lib/storage/client-resize';

    // Sprint i18n Phase 5 — Editor-State auf 1-Feld-UX (Default-Sprache)
    function emptyEditor() {
      return {
        id: null,
        card_type: 'internal_action',
        action_target: '',
        title: '', subtitle: '', eyebrow: '', cta: '',
        image_url: null,
        imageFile: null,
        imagePreview: null,
        card_class: 'rec-anthrazit',
        is_published: true,
      };
    }

    function pickI18nClient(value: any, lang: string): string {
      if (!value || typeof value !== 'object') return '';
      return value[lang]?.value || value['de']?.value || '';
    }

    Alpine.data('actionCardsEditor', (initial: any) => ({
      hotelId: initial.hotelId,
      defaultLang: initial.defaultLang as string,
      cards: initial.cards,
      hasDefaultCards: initial.hasDefaultCards as boolean,
      internalActions: initial.internalActions,
      cardClasses: initial.cardClasses,
      typeLabels: initial.typeLabels,

      editorOpen: false,
      editorMode: 'new' as 'new' | 'edit',
      editor: emptyEditor(),
      isSaving: false,
      saveError: '' as string,
      toast: null as null | { type: 'success' | 'error'; text: string },

      openNew() {
        this.editor = emptyEditor();
        this.editorMode = 'new';
        this.saveError = '';
        this.editorOpen = true;
      },

      openEdit(id: string) {
        const c = this.cards.find((x: any) => x.id === id);
        if (!c) return;
        const e = emptyEditor();
        // i18n-First mit Fallback auf alte _de-Spalten (Safety bis Phase 10)
        e.id = c.id;
        e.card_type = c.card_type;
        e.action_target = c.action_target ?? '';
        e.title    = pickI18nClient(c.title_i18n,    this.defaultLang) || c.title_de    || '';
        e.subtitle = pickI18nClient(c.subtitle_i18n, this.defaultLang) || c.subtitle_de || '';
        e.eyebrow  = pickI18nClient(c.eyebrow_i18n,  this.defaultLang) || c.eyebrow_de  || '';
        e.cta      = pickI18nClient(c.cta_i18n,      this.defaultLang) || c.cta_de      || '';
        e.image_url = c.image_url ?? null;
        e.card_class = c.card_class ?? 'rec-anthrazit';
        e.is_published = c.is_published !== false;
        this.editor = e;
        this.editorMode = 'edit';
        this.saveError = '';
        this.editorOpen = true;
      },

      closeEditor() {
        this.editorOpen = false;
      },

      onTypeChange() {
        // Bei Typ-Wechsel das action_target neutralisieren wenn unpassend
        if (this.editor.card_type === 'info') this.editor.action_target = '';
      },

      async onFileChange(ev: Event) {
        const input = ev.target as HTMLInputElement;
        const file = input.files?.[0];
        if (!file) return;
        if (file.size > 2 * 1024 * 1024) {
          this.showToast('Datei zu groß (max 2 MB)', 'error');
          input.value = '';
          return;
        }
        this.editor.imageFile = await resizeImage(file, 1200);
        this.editor.imagePreview = URL.createObjectURL(this.editor.imageFile);
      },

      clearImage() {
        this.editor.imageFile = null;
        this.editor.imagePreview = null;
        this.editor.image_url = null;
      },

      async saveEditor() {
        if (!this.editor.title?.trim()) {
          this.saveError = 'Titel ist Pflicht.';
          return;
        }
        this.isSaving = true;
        this.saveError = '';
        try {
          // 1-Feld-UX: schickt nur plain Werte. Endpoint mappt sie auf
          // {field}_i18n[default_lang] + spiegelt zur alten DE-Spalte.
          const payload: any = {
            id: this.editor.id || undefined,
            card_type: this.editor.card_type,
            action_target: this.editor.action_target,
            card_class: this.editor.card_class,
            is_published: this.editor.is_published,
            title:    this.editor.title,
            subtitle: this.editor.subtitle,
            eyebrow:  this.editor.eyebrow,
            cta:      this.editor.cta,
          };
          const res = await fetch('/api/admin/action-cards/upsert', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) { this.saveError = data.error || 'Speichern fehlgeschlagen.'; return; }

          // Bild-Upload falls neue Datei
          if (this.editor.imageFile) {
            const fd = new FormData();
            fd.append('card_id', data.id);
            fd.append('image', this.editor.imageFile);
            const upRes = await fetch('/api/admin/action-cards/upload-image', { method: 'POST', body: fd });
            const upData = await upRes.json();
            if (!upData.ok) { this.saveError = `Bild-Upload: ${upData.error}`; return; }
          }
          this.showToast('Gespeichert.', 'success');
          this.editorOpen = false;
          setTimeout(() => window.location.reload(), 600);
        } catch (err: any) {
          this.saveError = `Netzwerk-Fehler: ${err.message ?? err}`;
        } finally {
          this.isSaving = false;
        }
      },

      async moveCard(id: string, direction: 'up' | 'down') {
        const res = await fetch('/api/admin/action-cards/sort', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, direction }),
        });
        const data = await res.json();
        if (!data.ok) { this.showToast(data.error || 'Sortieren fehlgeschlagen', 'error'); return; }
        if (!data.noop) window.location.reload();
      },

      async deleteCard(id: string) {
        if (!confirm('Diese Karte wirklich löschen?')) return;
        const res = await fetch('/api/admin/action-cards/delete', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        const data = await res.json();
        if (!data.ok) { this.showToast(data.error || 'Löschen fehlgeschlagen', 'error'); return; }
        this.showToast('Gelöscht.', 'success');
        setTimeout(() => window.location.reload(), 400);
      },

      isLoadingExamples: false,

      async loadExamples() {
        if (!confirm('3 Beispielkarten hinzufügen? (Frühstück, Tipps, Wallet-Pass — editierbar und löschbar)')) return;
        this.isLoadingExamples = true;
        try {
          const res = await fetch('/api/admin/action-cards/seed-examples', { method: 'POST' });
          const data = await res.json();
          if (!data.ok) { this.showToast(data.error || 'Beispiele laden fehlgeschlagen', 'error'); return; }
          const n: number = data.inserted ?? 0;
          this.hasDefaultCards = true;
          if (n > 0) {
            this.showToast(`${n} Beispielkarten hinzugefügt.`, 'success');
            setTimeout(() => window.location.reload(), 600);
          } else {
            this.showToast('Beispiele bereits vorhanden.', 'success');
          }
        } catch (err: any) {
          this.showToast(`Netzwerk-Fehler: ${err.message ?? err}`, 'error');
        } finally {
          this.isLoadingExamples = false;
        }
      },

      showToast(text: string, type: 'success' | 'error') {
        this.toast = { type, text };
        setTimeout(() => { this.toast = null; }, 3000);
      },
    }));
  </script>

  <style>
    [x-cloak] { display: none !important; }
    .ac-root { padding: 0 24px 60px; max-width: 1200px; margin: 0 auto; }
    .ac-header { margin: 20px 0 24px; }
    .ac-eyebrow { margin: 0 0 6px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); }
    .ac-title { margin: 0 0 8px; font-size: 28px; font-weight: 300; letter-spacing: -0.01em; color: var(--theme-text-primary); }
    .ac-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); }

    .ac-hint-banner { margin-bottom: 16px; padding: 12px 16px; background: #fff8e1; border: 1px solid #f5d77a; color: #8a5800; font-size: 13px; }

    .ac-actions-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .ac-counter { font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); }

    .ac-empty { padding: 60px 24px; text-align: center; background: var(--theme-bg-primary); border: 1px dashed var(--theme-border); }
    .ac-empty-text { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); font-style: italic; }

    .ac-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 40px; }
    .ac-row { display: grid; grid-template-columns: 80px 1fr auto; gap: 16px; padding: 12px; background: var(--theme-bg-primary); border: 1px solid var(--theme-border); align-items: center; }
    .ac-row-thumb { width: 80px; height: 80px; background: var(--theme-bg-tertiary); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .ac-row-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .ac-row-thumb-placeholder { color: color-mix(in srgb, var(--theme-text-primary) .3, transparent); font-size: 24px; }
    .ac-row-meta { min-width: 0; }
    .ac-row-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 4px; }
    .ac-badge { font-size: 10px; padding: 2px 8px; background: color-mix(in srgb, var(--theme-text-primary) .06, transparent); color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); letter-spacing: 0.04em; }
    .ac-badge--draft { background: #fff8e1; color: #8a5800; }
    .ac-badge--target { background: rgba(var(--theme-accent-rgb), .08); color: var(--theme-accent); font-family: var(--theme-font-mono); }
    .ac-row-title { margin: 4px 0 2px; font-size: 15px; font-weight: 500; color: var(--theme-text-primary); }
    .ac-row-sub { margin: 0; font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 60ch; }
    .ac-row-actions { display: flex; gap: 4px; }

    .ac-section-title { margin: 0 0 6px; font-size: 16px; font-weight: 500; color: var(--theme-text-primary); }
    .ac-section-sub { margin: 0 0 16px; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }

    .ac-preview-section { margin-top: 32px; }
    .ac-preview-empty { font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); font-style: italic; }
    .ac-preview-stage { background: var(--theme-bg-secondary); padding: 20px; border: 1px solid var(--theme-border); overflow: hidden; }
    .ac-preview-scroller { display: flex; gap: 16px; overflow-x: auto; padding-bottom: 8px; }
    .ac-preview-card { flex: 0 0 280px; min-height: 220px; }
    .ac-preview-card-img { width: calc(100% + 52px); margin: -28px -26px 8px; height: 120px; object-fit: cover; }

    /* Buttons */
    .ac-btn { padding: 8px 16px; font-size: 13px; font-weight: 500; border: 1px solid; cursor: pointer; background: transparent; color: var(--theme-text-primary); }
    .ac-btn:disabled { opacity: 0.5; cursor: wait; }
    .ac-btn--primary { background: var(--theme-accent); color: var(--theme-bg-primary); border-color: var(--theme-accent); }
    .ac-btn--primary:hover:not(:disabled) { background: var(--theme-accent-hover); }
    .ac-btn--ghost { border-color: var(--theme-border); }
    .ac-btn--ghost:hover { background: var(--theme-bg-tertiary); }

    .ac-icon-btn { width: 32px; height: 32px; padding: 0; background: transparent; border: 1px solid var(--theme-border); cursor: pointer; font-size: 14px; line-height: 1; }
    .ac-icon-btn:hover:not(:disabled) { background: var(--theme-bg-tertiary); border-color: var(--theme-text-primary); }
    .ac-icon-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .ac-icon-btn--danger:hover { background: #fdeaea; border-color: #aa1f1f; color: #aa1f1f; }

    /* Modal */
    .ac-modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.45); display: flex; align-items: flex-start; justify-content: center; padding: 24px; z-index: 100; overflow-y: auto; }
    .ac-modal { background: var(--theme-bg-primary); width: 100%; max-width: 640px; max-height: calc(100vh - 48px); display: flex; flex-direction: column; box-shadow: 0 12px 48px rgba(0,0,0,.25); }
    .ac-modal-head { padding: 16px 20px; border-bottom: 1px solid var(--theme-border); display: flex; align-items: center; justify-content: space-between; }
    .ac-modal-head h3 { margin: 0; font-size: 18px; font-weight: 500; }
    .ac-modal-close { background: transparent; border: none; font-size: 24px; cursor: pointer; line-height: 1; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); }
    .ac-modal-close:hover { color: var(--theme-text-primary); }
    .ac-modal-body { padding: 20px; overflow-y: auto; flex: 1; }
    .ac-modal-foot { padding: 12px 20px; border-top: 1px solid var(--theme-border); display: flex; gap: 8px; justify-content: flex-end; align-items: center; }
    .ac-error { flex: 1; font-size: 12px; color: #aa1f1f; }

    /* Fields */
    .ac-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .ac-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .ac-field--checkbox { flex-direction: row; align-items: center; gap: 8px; }
    .ac-field-label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); }
    .ac-required { color: var(--theme-accent); }
    .ac-optional { font-size: 10px; color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); text-transform: none; letter-spacing: normal; }
    .ac-input { padding: 8px 10px; border: 1px solid var(--theme-border); font-size: 14px; font-family: inherit; color: var(--theme-text-primary); background: var(--theme-bg-primary); width: 100%; }
    .ac-input:focus { outline: none; border-color: var(--theme-accent); }
    .ac-input--file { padding: 4px; }
    textarea.ac-input { resize: vertical; }

    /* Lang-Tabs */
    .ac-i18n-hint { padding: 10px 12px; background: rgba(var(--theme-accent-rgb), .06); border-left: 3px solid var(--theme-accent); font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .75, transparent); margin-bottom: 16px; }
    .ac-i18n-hint strong { color: var(--theme-text-primary); font-weight: 500; }
    .ac-lang-tabs { display: flex; gap: 2px; border-bottom: 1px solid var(--theme-border); margin: 8px 0 16px; }
    .ac-lang-tab { padding: 8px 14px; background: transparent; border: none; border-bottom: 2px solid transparent; margin-bottom: -1px; font-size: 12px; font-weight: 500; cursor: pointer; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); display: flex; align-items: center; gap: 4px; }
    .ac-lang-tab.is-active { color: var(--theme-text-primary); border-bottom-color: var(--theme-accent); }
    .ac-lang-tab.has-content { color: var(--theme-text-primary); }
    .ac-lang-dot { color: #2a8a44; font-size: 16px; line-height: 0.5; }
    .ac-lang-fields { display: flex; flex-direction: column; }

    /* Bild */
    .ac-image-row { display: grid; grid-template-columns: 120px 1fr; gap: 12px; align-items: start; }
    .ac-image-preview { width: 120px; height: 120px; background: var(--theme-bg-tertiary); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .ac-image-preview img { width: 100%; height: 100%; object-fit: cover; }
    .ac-image-placeholder { font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .4, transparent); font-style: italic; }
    .ac-image-actions { display: flex; flex-direction: column; gap: 8px; }

    /* Toast */
    .ac-toast { position: fixed; top: 20px; right: 20px; padding: 12px 16px; color: var(--theme-bg-primary); font-size: 13px; z-index: 200; box-shadow: 0 4px 16px rgba(0,0,0,.18); }
    .ac-toast--success { background: #1f7a3a; }
    .ac-toast--error { background: #aa1f1f; }
  </style>
</AdminLayout>
