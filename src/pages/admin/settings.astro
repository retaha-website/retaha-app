---
import AdminLayout from '../../components/AdminLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const updates: Record<string, any> = {
    wifi_ssid: form.get('wifi_ssid')?.toString().trim() || null,
    wifi_password: form.get('wifi_password')?.toString().trim() || null,
    wifi_speed_mbits: parseInt(form.get('wifi_speed_mbits')?.toString() || '0') || null,
    concierge_name: form.get('concierge_name')?.toString().trim() || null,
    concierge_online_until: form.get('concierge_online_until')?.toString() || null,
    hotel_eyebrow_de: form.get('hotel_eyebrow_de')?.toString().trim() || null,
    hotel_eyebrow_en: form.get('hotel_eyebrow_en')?.toString().trim() || null,
    hotel_eyebrow_fr: form.get('hotel_eyebrow_fr')?.toString().trim() || null,
    hotel_eyebrow_es: form.get('hotel_eyebrow_es')?.toString().trim() || null,
    welcome_message_de: form.get('welcome_message_de')?.toString().trim() || null,
    welcome_message_en: form.get('welcome_message_en')?.toString().trim() || null,
    welcome_message_fr: form.get('welcome_message_fr')?.toString().trim() || null,
    welcome_message_es: form.get('welcome_message_es')?.toString().trim() || null,
    updated_at: new Date().toISOString(),
  };

  const { error } = await client
    .from('hotel_settings')
    .update(updates)
    .eq('hotel_id', hotel.id);

  if (error) {
    message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
  } else {
    message = { type: 'success', text: 'Einstellungen gespeichert.' };
  }
}

// Load current settings
const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    wifi_ssid, wifi_password, wifi_speed_mbits,
    concierge_name, concierge_online_until,
    hotel_eyebrow_de, hotel_eyebrow_en, hotel_eyebrow_fr, hotel_eyebrow_es,
    welcome_message_de, welcome_message_en, welcome_message_fr, welcome_message_es
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || {};

// Concierge time as HH:MM for input[type=time]
const conciergeTime = (s as any).concierge_online_until || '22:00';
const conciergeTimeShort = conciergeTime.substring(0, 5); // "22:00:00" → "22:00"
---

<AdminLayout title="Einstellungen" hotel={hotel} user={user} activeTab="settings">
  <div class="mb-8">
    <p class="text-xs italic text-red-700 mb-2" style="font-family: Georgia, serif;">— Einstellungen —</p>
    <h1 class="text-3xl font-light">Stammdaten<br /><span class="font-medium">deines Hotels</span><span class="text-red-700">.</span></h1>
    <p class="text-sm text-stone-600 mt-3 max-w-xl">
      Hier verwaltest du WLAN-Zugangsdaten, deine Concierge-Info und Begrüßungstexte.
      Änderungen sind beim Gast direkt nach dem Speichern sichtbar.
    </p>
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <form method="POST" class="space-y-8">

    <!-- WLAN -->
    <section class="bg-white border border-stone-200 p-8">
      <div class="mb-6">
        <p class="text-xs italic text-red-700 mb-1" style="font-family: Georgia, serif;">— WLAN —</p>
        <h2 class="text-xl font-medium">Internet-Zugang</h2>
        <p class="text-xs text-stone-500 mt-1">Der QR-Code im Gast-Frontend wird automatisch mit diesen Daten erzeugt.</p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Netzwerk-Name (SSID)</span>
          <input
            type="text"
            name="wifi_ssid"
            value={(s as any).wifi_ssid || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
            required
          />
        </label>

        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Geschwindigkeit (Mbit/s)</span>
          <input
            type="number"
            name="wifi_speed_mbits"
            value={(s as any).wifi_speed_mbits || 320}
            min="1"
            max="10000"
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>

        <label class="block col-span-2">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Passwort</span>
          <input
            type="text"
            name="wifi_password"
            value={(s as any).wifi_password || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm font-mono focus:outline-none focus:border-stone-900"
            required
          />
          <span class="text-[10px] text-stone-400 italic mt-1 block">
            Achtung: nur lesbar im Klartext für Gäste sichtbar. Spezialzeichen werden im QR-Code korrekt gehandhabt.
          </span>
        </label>
      </div>
    </section>

    <!-- Concierge -->
    <section class="bg-white border border-stone-200 p-8">
      <div class="mb-6">
        <p class="text-xs italic text-red-700 mb-1" style="font-family: Georgia, serif;">— Concierge —</p>
        <h2 class="text-xl font-medium">Wer empfängt die Gäste</h2>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Name</span>
          <input
            type="text"
            name="concierge_name"
            value={(s as any).concierge_name || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
            placeholder="Maria"
          />
        </label>

        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Online bis</span>
          <input
            type="time"
            name="concierge_online_until"
            value={conciergeTimeShort}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
      </div>
    </section>

    <!-- Hotel-Eyebrow (4 Sprachen) -->
    <section class="bg-white border border-stone-200 p-8">
      <div class="mb-6">
        <p class="text-xs italic text-red-700 mb-1" style="font-family: Georgia, serif;">— Marker-Text —</p>
        <h2 class="text-xl font-medium">Eyebrow oben im Hero</h2>
        <p class="text-xs text-stone-500 mt-1">Z.B. "Charlottenburg · Sommer 2026" — klein, italic, oben am Hero-Bild.</p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Deutsch</span>
          <input
            type="text"
            name="hotel_eyebrow_de"
            value={(s as any).hotel_eyebrow_de || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">English</span>
          <input
            type="text"
            name="hotel_eyebrow_en"
            value={(s as any).hotel_eyebrow_en || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Français</span>
          <input
            type="text"
            name="hotel_eyebrow_fr"
            value={(s as any).hotel_eyebrow_fr || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Español</span>
          <input
            type="text"
            name="hotel_eyebrow_es"
            value={(s as any).hotel_eyebrow_es || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
      </div>
    </section>

    <!-- Welcome (4 Sprachen) -->
    <section class="bg-white border border-stone-200 p-8">
      <div class="mb-6">
        <p class="text-xs italic text-red-700 mb-1" style="font-family: Georgia, serif;">— Willkommen —</p>
        <h2 class="text-xl font-medium">Begrüßungsnachricht unter dem Hero-Namen</h2>
        <p class="text-xs text-stone-500 mt-1">Z.B. "Schön, dich wieder bei uns zu haben." — italic.</p>
      </div>

      <div class="space-y-3">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Deutsch</span>
          <input
            type="text"
            name="welcome_message_de"
            value={(s as any).welcome_message_de || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">English</span>
          <input
            type="text"
            name="welcome_message_en"
            value={(s as any).welcome_message_en || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Français</span>
          <input
            type="text"
            name="welcome_message_fr"
            value={(s as any).welcome_message_fr || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Español</span>
          <input
            type="text"
            name="welcome_message_es"
            value={(s as any).welcome_message_es || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
      </div>
    </section>

    <div class="flex justify-end pt-4">
      <button
        type="submit"
        class="bg-stone-900 text-stone-50 px-6 py-3 text-sm hover:bg-red-900 transition font-medium"
      >
        Änderungen speichern
      </button>
    </div>

  </form>
</AdminLayout>
