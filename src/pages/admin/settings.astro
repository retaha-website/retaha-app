---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../lib/auth';
import { t } from '../../i18n/helpers';
import { SUPPORTED_ADMIN_LOCALES, LOCALE_LABELS, LOCALE_CODES, DEFAULT_ADDRESS_FORM } from '../../i18n/constants';
import type { AdminLocale, AddressForm } from '../../i18n/types';
import { mergeAndTranslate, asLanguageCode } from '../../lib/i18n/save-hook.ts';
import { getVapidPublicKey } from '../../lib/push/config';
const vapidPublicKey = getVapidPublicKey();
// Sprint H · Group 1 — Theme-Picker
import ThemePicker from '../../components/admin/ThemePicker.astro';
import { resolveTheme, type ThemeId } from '../../lib/theme';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
// Defensive fallbacks falls Middleware Astro.locals nicht gesetzt hat
const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;

// Sprint H · Group 1 — Preview-Token für Theme-Picker (irgendein aktiver Stay)
const { data: previewStayRow } = await client
  .from('stays').select('access_token').eq('hotel_id', hotel.id).eq('is_active', true).limit(1).maybeSingle();
const previewToken: string | null = previewStayRow?.access_token ?? null;

// Sprint i18n Phase 5.8 — Hotel-Sprach-Settings VOR POST-Handler laden
const { data: hotelPreLang } = await client
  .from('hotels').select('default_language')
  .eq('id', hotel.id).maybeSingle();
const hotelDefaultLang = (hotelPreLang?.default_language as string | undefined) ?? 'de';

const NOW_ISO = () => new Date().toISOString();
function mergeI18nField(existing: any, value: string): any | null {
  const merged: Record<string, any> = (existing && typeof existing === 'object') ? { ...existing } : {};
  if (value) merged[hotelDefaultLang] = { value, source: 'original', updated_at: NOW_ISO() };
  else delete merged[hotelDefaultLang];
  return Object.keys(merged).length > 0 ? merged : null;
}

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'update_locale') {
    const newLocale = form.get('locale')?.toString();

    if (newLocale && SUPPORTED_ADMIN_LOCALES.includes(newLocale as AdminLocale)) {
      const { error: updateError } = await client.auth.updateUser({ data: { locale: newLocale } });

      if (updateError) {
        message = { type: 'error', text: `Speichern fehlgeschlagen: ${updateError.message}` };
      } else {
        // JWT-Session refreshen damit neue Metadata im Session-Cookie landet
        // (sonst rendert die nächste Request-Page weiterhin in der alten Sprache)
        const { error: refreshError } = await client.auth.refreshSession();
        if (refreshError) {
          return Astro.redirect('/admin/login?locale-update=needs-relogin');
        }
        return Astro.redirect('/admin/settings?saved=locale');
      }
    } else {
      message = { type: 'error', text: 'Ungültige Sprache.' };
    }
  } else if (action === 'update_address') {
    // Sprint E2 Phase 3 — Adress-Felder speichern + auto-Geocoding via Nominatim.
    // Geocoding non-fatal: bei Fehler bleibt lat/lng wie sie sind, Warning an User.
    const street  = form.get('address_street')?.toString().trim() || null;
    const zip     = form.get('address_zip')?.toString().trim() || null;
    const city    = form.get('city')?.toString().trim() || null;
    const country = form.get('country')?.toString().trim() || null;

    const { geocodeAddress, buildAddressQuery } = await import('../../lib/places/geocoding');
    const addressQuery = buildAddressQuery({ street, zip, city, country });

    let lat: number | null = null;
    let lng: number | null = null;
    let geocodeWarning: string | null = null;

    if (addressQuery.length >= 5) {
      const result = await geocodeAddress(addressQuery);
      if (result) {
        lat = result.lat;
        lng = result.lng;
      } else {
        geocodeWarning = 'Adresse gespeichert, aber Geo-Koordinaten konnten nicht ermittelt werden. Bitte Adresse prüfen.';
      }
    }

    const updates: Record<string, any> = {
      address_street: street,
      address_zip: zip,
      city: city,
      country: country,
    };
    if (lat !== null && lng !== null) {
      updates.latitude = lat;
      updates.longitude = lng;
    }

    const { error } = await client.from('hotels').update(updates).eq('id', hotel.id);
    if (error) {
      message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
    } else if (geocodeWarning) {
      message = { type: 'error', text: geocodeWarning };
    } else if (lat !== null) {
      message = { type: 'success', text: `Adresse verifiziert ✓ — 📍 ${lat.toFixed(4)}, ${lng!.toFixed(4)} — Auto-Empfehlungen werden im Hintergrund aufgebaut.` };
      // Sprint E2 Phase 6 — Non-blocking Nearby-Cache-Build (fire-and-forget).
      // User sieht den Success-Message sofort, Cache läuft async (~5-10s).
      import('../../lib/places/nearby-actions').then(({ buildNearbyCache }) =>
        buildNearbyCache(hotel.id, lat!, lng!)
      ).catch(err => console.warn('[settings] nearby-cache build failed:', (err as Error).message));
    } else {
      message = { type: 'success', text: 'Adresse gespeichert.' };
    }
  } else if (action === 'update_languages') {
    // Sprint i18n Phase 4 — Hotelier-Sprach-Settings (hotels-Table)
    const VALID = ['de','en','fr','es','it','pt','nl','ru','ar','zh'];
    const newDefault = form.get('default_language')?.toString().trim() || '';
    const enabledRaw = form.getAll('enabled_languages').map(v => v.toString().trim()).filter(Boolean);

    // Server-side Validation (Constraints fangen das auch ab, aber bessere Fehler-Texte hier)
    if (!VALID.includes(newDefault)) {
      message = { type: 'error', text: 'Ungültige Standardsprache.' };
    } else if (enabledRaw.length === 0) {
      message = { type: 'error', text: 'Mindestens eine Sprache muss aktiviert sein.' };
    } else if (enabledRaw.length > 4) {
      message = { type: 'error', text: 'Maximal 4 Sprachen für den Gast-Selector (Mobile-UX).' };
    } else if (enabledRaw.some(l => !VALID.includes(l))) {
      message = { type: 'error', text: 'Eine der gewählten Sprachen ist ungültig.' };
    } else {
      // Default automatisch zu enabled hinzufügen falls nicht drin (Briefing-Hinweis 3)
      const enabled = enabledRaw.includes(newDefault) ? enabledRaw : [newDefault, ...enabledRaw].slice(0, 4);

      const { error } = await client
        .from('hotels')
        .update({ default_language: newDefault, enabled_languages: enabled })
        .eq('id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
      } else {
        return Astro.redirect('/admin/settings?saved=languages');
      }
    }
  } else if (action === 'update_address_form') {
    const newForm = form.get('address_form')?.toString();
    if (newForm === 'du' || newForm === 'sie') {
      const { data: updatedRows, error } = await client
        .from('hotel_settings')
        .update({ guest_address_form: newForm, updated_at: new Date().toISOString() })
        .eq('hotel_id', hotel.id)
        .select('hotel_id');
      if (error) {
        message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
      } else if (!updatedRows || updatedRows.length === 0) {
        message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS) oder Eintrag nicht gefunden' };
      } else {
        return Astro.redirect('/admin/settings?saved=address');
      }
    } else {
      message = { type: 'error', text: 'Ungültige Anrede.' };
    }
  } else {
    // Default: Bulk-Update — Sprint i18n Phase 5.8 auf 1-Feld-UX umgestellt
    const eyebrowDefault = form.get('hotel_eyebrow_default')?.toString().trim() || '';
    const welcomeDefault = form.get('welcome_message_default')?.toString().trim() || '';

    // Existing i18n laden damit override-Werte in anderen Sprachen erhalten bleiben
    const { data: existingI18n } = await client
      .from('hotel_settings')
      .select('hotel_eyebrow_i18n, welcome_message_i18n')
      .eq('hotel_id', hotel.id).maybeSingle();

    const updates: Record<string, any> = {
      notification_email: form.get('notification_email')?.toString().trim() || null,
      wifi_ssid: form.get('wifi_ssid')?.toString().trim() || null,
      wifi_password: form.get('wifi_password')?.toString().trim() || null,
      wifi_speed_mbits: parseInt(form.get('wifi_speed_mbits')?.toString() || '0') || null,
      eve_name: form.get('eve_name')?.toString().trim() || null,
      eve_online_until: form.get('eve_online_until')?.toString() || null,
      // Sprint i18n Phase 6 — Save-Hook mit Auto-Translation
      ...(await Promise.all([
        mergeAndTranslate(existingI18n?.hotel_eyebrow_i18n,   eyebrowDefault, asLanguageCode(hotelDefaultLang), { logLabel: 'hotel_settings.hotel_eyebrow' }),
        mergeAndTranslate(existingI18n?.welcome_message_i18n, welcomeDefault, asLanguageCode(hotelDefaultLang), { logLabel: 'hotel_settings.welcome_message' }),
      ]).then(([ebR, wmR]) => ({
        hotel_eyebrow_i18n:   Object.keys(ebR.i18n).length > 0 ? ebR.i18n : null,
        welcome_message_i18n: Object.keys(wmR.i18n).length > 0 ? wmR.i18n : null,
      }))),
      updated_at: new Date().toISOString(),
    };
    // Safety-Net: spiegle Default zur alten _de-Spalte (Phase 10 dropt)
    if (hotelDefaultLang === 'de') {
      updates.hotel_eyebrow_de   = eyebrowDefault || null;
      updates.welcome_message_de = welcomeDefault || null;
    }

    const { data: updatedRows, error } = await client
      .from('hotel_settings')
      .update(updates)
      .eq('hotel_id', hotel.id)
      .select('hotel_id');

    if (error) {
      message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
    } else if (!updatedRows || updatedRows.length === 0) {
      message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS) oder Eintrag nicht gefunden' };
    } else {
      message = { type: 'success', text: 'Einstellungen gespeichert.' };
    }
  }
}

// Sprint D Phase 6e — Logo-Upload-Flash + Error-Codes
const logoError = Astro.url.searchParams.get('logo_error');
if (logoError && !message) {
  const errorTexts: Record<string, string> = {
    no_file: 'Bitte eine Datei auswählen.',
    too_large: 'Datei zu groß — maximal 2 MB.',
    invalid_type: 'Ungültiger Dateityp — erlaubt: PNG, JPEG, SVG, WebP.',
    storage: 'Upload zum Storage fehlgeschlagen — bitte erneut versuchen.',
    db_save: 'Logo hochgeladen, aber Speichern fehlgeschlagen.',
    invalid_form: 'Formular-Daten ungültig.',
  };
  message = { type: 'error', text: errorTexts[logoError] ?? `Upload-Fehler: ${logoError}` };
}

// Saved-Flash aus URL-Param (nach Redirect)
const savedParam = Astro.url.searchParams.get('saved');
if (savedParam === 'logo' && !message) {
  message = { type: 'success', text: 'Logo aktualisiert.' };
} else if (savedParam === 'logo_removed' && !message) {
  message = { type: 'success', text: 'Logo entfernt.' };
} else if (savedParam === 'locale' && !message) {
  message = { type: 'success', text: t('settings.language.saved', userLocale) };
} else if (savedParam === 'address' && !message) {
  message = { type: 'success', text: t('settings.guest_address.saved', userLocale) };
} else if (savedParam === 'languages' && !message) {
  message = { type: 'success', text: 'Sprach-Einstellungen gespeichert.' };
}

// Load current settings (inkl. neuem guest_address_form)
const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    notification_email,
    wifi_ssid, wifi_password, wifi_speed_mbits,
    eve_name, eve_online_until,
    hotel_eyebrow_de, hotel_eyebrow_i18n,
    welcome_message_de, welcome_message_i18n,
    guest_address_form
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

// Sprint E2 Phase 3 — Hotel-Adresse + Geocoding-Status
const { data: hotelRow } = await client
  .from('hotels')
  .select('address_street, address_zip, city, country, latitude, longitude, default_language, enabled_languages')
  .eq('id', hotel.id)
  .maybeSingle();
const hr = (hotelRow ?? {}) as any;
const hasGeocode = typeof hr.latitude === 'number' && typeof hr.longitude === 'number';

const s = settings || {};

// Sprint i18n Phase 4 — Hotel-Sprach-Settings (default_language schon oben geladen)
const hotelEnabledLangs: string[] = Array.isArray(hr.enabled_languages) ? hr.enabled_languages : ['de','en','fr','es'];
const ALL_LANGUAGES = [
  { code: 'de', label: 'Deutsch'    }, { code: 'en', label: 'English'    },
  { code: 'fr', label: 'Français'   }, { code: 'es', label: 'Español'    },
  { code: 'it', label: 'Italiano'   }, { code: 'pt', label: 'Português'  },
  { code: 'nl', label: 'Nederlands' }, { code: 'ru', label: 'Русский'     },
  { code: 'ar', label: 'العربية'      }, { code: 'zh', label: '中文'        },
];

const conciergeTime = (s as any).eve_online_until || '22:00';
const conciergeTimeShort = conciergeTime.substring(0, 5);

// Bevorzugt user.user_metadata.locale (User-Preference), Fallback auf Middleware-resolved Locale, finally 'de'
const currentLocale: AdminLocale = (Astro.locals.user?.locale ?? userLocale ?? 'de') as AdminLocale;
const currentAddressForm: AddressForm = ((s as any).guest_address_form ?? DEFAULT_ADDRESS_FORM) as AddressForm;
---

<AdminLayout title="Einstellungen" hotel={hotel} user={{ email: user.email ?? '' }} activeTab="settings">
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber={t('pages.settings.section_number', userLocale)}
      sectionLabel={t('pages.settings.section_label', userLocale)}
      headlineLight={t('pages.settings.headline_light', userLocale)}
      headlineBold={t('pages.settings.headline_bold', userLocale)}
      subtitle={t('pages.settings.subtitle', userLocale)}
    />
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <!-- Sprache (pro User, separater Form mit Redirect) -->
  <section class="settings-section">
    <div class="settings-section-marker-bar">
      <span class="settings-section-marker settings-section-marker--circle"></span>
      <p class="settings-section-eyebrow">{t('settings.language.eyebrow', userLocale)}</p>
      <span class="settings-section-line"></span>
    </div>
    <h2 class="settings-section-headline">
      {t('settings.language.label_a', userLocale)} {t('settings.language.label_b', userLocale)}<span class="text-pink-shock">?</span>
    </h2>

    <form method="POST" class="flex items-end gap-4">
      <input type="hidden" name="_action" value="update_locale" />
      <input type="hidden" id="locale-hidden" name="locale" value={currentLocale ?? 'de'} />

      <div
        x-data={`{ open: false, current: '${currentLocale ?? 'de'}' }`}
        @click.outside="open = false"
        @keydown.escape="open = false"
        class="bauhaus-select-custom"
      >
        <button
          type="button"
          @click="open = !open"
          :aria-expanded="open.toString()"
          class="bauhaus-select-custom-trigger"
        >
          <span class="bauhaus-select-custom-code" x-text="current.toUpperCase()">{(currentLocale ?? 'de').toUpperCase()}</span>
          <span class="bauhaus-select-custom-arrow" :class="{ 'is-open': open }">⌄</span>
        </button>

        <ul x-show="open" x-cloak class="bauhaus-select-custom-list">
          {SUPPORTED_ADMIN_LOCALES.map(loc => (
            <li>
              <button
                type="button"
                @click={`current = '${loc}'; document.getElementById('locale-hidden').value = '${loc}'; open = false`}
                :class={`current === '${loc}' && 'is-active'`}
                class="bauhaus-select-custom-option"
              >
                <span class="bauhaus-select-custom-option-code">{LOCALE_CODES[loc]}</span>
                <span class="bauhaus-select-custom-option-name">{LOCALE_LABELS[loc]}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <button type="submit" class="bauhaus-button bauhaus-button--primary">
        {t('settings.language.submit', userLocale)}
      </button>
    </form>
  </section>

  <!-- Sprint i18n Phase 4 — Hotel-Sprachen (Hotelier-Default + Gast-enabled) -->
  <section
    class="settings-section"
    x-data={`{
      defaultLang: '${hotelDefaultLang}',
      enabled: ${JSON.stringify(hotelEnabledLangs)},
      toggle(code) {
        if (this.enabled.includes(code)) {
          if (code === this.defaultLang) return; // Default kann nicht entfernt werden
          this.enabled = this.enabled.filter(l => l !== code);
        } else {
          if (this.enabled.length >= 4) return; // Hard-Stop
          this.enabled = [...this.enabled, code];
        }
      },
      setDefault(code) {
        this.defaultLang = code;
        if (!this.enabled.includes(code)) {
          if (this.enabled.length >= 4) this.enabled = [code, ...this.enabled.slice(0, 3)];
          else this.enabled = [...this.enabled, code];
        }
      },
      get atLimit() { return this.enabled.length >= 4; },
      get defaultChanged() { return this.defaultLang !== '${hotelDefaultLang}'; }
    }`}
  >
    <div class="settings-section-marker-bar">
      <span class="settings-section-marker settings-section-marker--triangle"></span>
      <p class="settings-section-eyebrow themed-eyebrow-flank">sprachen</p>
      <span class="settings-section-line"></span>
    </div>
    <h2 class="settings-section-headline">
      In welchen Sprachen<span class="text-pink-shock">?</span>
    </h2>

    <form method="POST" class="settings-section-form space-y-6 max-w-2xl">
      <input type="hidden" name="_action" value="update_languages" />

      <div>
        <label class="block text-sm font-medium mb-2">Deine Standardsprache</label>
        <p class="text-xs text-anthrazit/55 mb-3">
          Du pflegst alle Inhalte (Karten, Tipps, FAQ) in dieser Sprache. Wir übersetzen
          automatisch in die anderen 9 Sprachen via KI.
        </p>
        <select
          name="default_language"
          x-model="defaultLang"
          @change="setDefault($event.target.value)"
          class="w-full max-w-xs px-3 py-2 border border-stein focus:border-pink-shock focus:outline-none bg-white text-sm"
        >
          {ALL_LANGUAGES.map(l => <option value={l.code}>{l.label}</option>)}
        </select>
        <p x-show="defaultChanged" x-cloak class="mt-2 text-xs text-amber-700">
          ⚠ Wechsel der Standardsprache: bestehende Inhalte werden bei nächstem Save re-übersetzt.
        </p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">
          Sprachen für deine Gäste <span class="text-anthrazit/45 font-normal">(max 4)</span>
        </label>
        <p class="text-xs text-anthrazit/55 mb-3">
          Diese Sprachen sieht der Gast im Sprach-Selector des Gast-Frontends.
          <strong>Auto-Übersetzungen funktionieren für alle 10</strong> — du kannst also
          jederzeit eine Sprache aktivieren, sobald Bedarf entsteht.
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2">
          {ALL_LANGUAGES.map(l => (
            <label
              class="flex items-center gap-2 px-3 py-2 border cursor-pointer text-sm"
              :class={`enabled.includes('${l.code}') ? 'border-pink-shock bg-pink-shock/5' : 'border-stein hover:border-anthrazit/40'`}
              :style={`!enabled.includes('${l.code}') && atLimit ? 'opacity: 0.4; cursor: not-allowed' : ''`}
            >
              <input
                type="checkbox"
                name="enabled_languages"
                value={l.code}
                :checked={`enabled.includes('${l.code}')`}
                @change={`toggle('${l.code}')`}
                :disabled={`!enabled.includes('${l.code}') && atLimit`}
                class="accent-pink-shock"
              />
              <span>{l.label}</span>
              <span x-show={`defaultLang === '${l.code}'`} x-cloak class="text-pink-shock text-xs ml-auto">★</span>
            </label>
          ))}
        </div>

        <p class="mt-2 text-xs text-anthrazit/55">
          ★ Standardsprache ist immer aktiviert · <span x-text="enabled.length"></span>/4 ausgewählt
        </p>
      </div>

      <button
        type="submit"
        class="px-6 py-2 bg-anthrazit text-white text-sm hover:bg-pink-shock transition"
      >
        Speichern
      </button>
    </form>
  </section>

  <!-- Gäste-Anrede (pro Hotel, separater Form mit Redirect) -->
  <section class="settings-section">
    <div class="settings-section-marker-bar">
      <span class="settings-section-marker settings-section-marker--square"></span>
      <p class="settings-section-eyebrow">{t('settings.guest_address.eyebrow', userLocale)}</p>
      <span class="settings-section-line"></span>
    </div>
    <h2 class="settings-section-headline">
      {t('settings.guest_address.label_a', userLocale)} {t('settings.guest_address.label_b', userLocale)}<span class="text-pink-shock">?</span>
    </h2>

    <form method="POST" class="settings-section-form">
      <input type="hidden" name="_action" value="update_address_form" />
      <div class="settings-section-pills">
        <label class="bauhaus-pill" data-active={currentAddressForm === 'du' ? 'true' : 'false'}>
          <input type="radio" name="address_form" value="du" checked={currentAddressForm === 'du'} class="sr-only" />
          <span class="bauhaus-pill-label">{t('settings.guest_address.du_option', userLocale)}</span>
          <span class="bauhaus-pill-sub">{t('settings.guest_address.du_example', userLocale)}</span>
        </label>
        <label class="bauhaus-pill" data-active={currentAddressForm === 'sie' ? 'true' : 'false'}>
          <input type="radio" name="address_form" value="sie" checked={currentAddressForm === 'sie'} class="sr-only" />
          <span class="bauhaus-pill-label">{t('settings.guest_address.sie_option', userLocale)}</span>
          <span class="bauhaus-pill-sub">{t('settings.guest_address.sie_example', userLocale)}</span>
        </label>
      </div>
      <button type="submit" class="bauhaus-button bauhaus-button--primary">
        {t('settings.guest_address.submit', userLocale)}
      </button>
    </form>
  </section>

  <!-- Sprint E2 Phase 3 — Adresse + Geocoding -->
  <section class="settings-section">
    <div class="settings-section-marker-bar">
      <span class="settings-section-marker settings-section-marker--circle"></span>
      <p class="settings-section-eyebrow themed-eyebrow-flank">standort</p>
      <span class="settings-section-line"></span>
    </div>
    <h2 class="settings-section-headline">Hotel-Adresse</h2>
    <p class="text-sm text-anthrazit/55 mb-4 max-w-xl leading-relaxed">
      Pflichtfeld für das Empfehlungs-Modul (Sprint E2). Aus Adresse und PLZ ermitteln
      wir per Geocoding die Geo-Koordinaten — Eve nutzt sie um Restaurants, Cafés und
      Sehenswürdigkeiten in der Nachbarschaft zu finden.
    </p>

    <form method="POST" class="settings-section-form space-y-4 max-w-2xl">
      <input type="hidden" name="_action" value="update_address" />

      <div>
