---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels } from '../../lib/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');
---

<AdminLayout title="Stamm gäste" hotel={hotel} user={user}>

  <EditorialPageHeader
    sectionNumber="12"
    sectionLabel="Gäste"
    headlineLight="Stamm-"
    headlineBold="gäste"
    subtitle="Wer war wann hier, was war ihm wichtig."
  />

  <div class="max-w-3xl">
    <p class="text-anthrazit/80 leading-relaxed text-base">
      Jeder Gast bekommt ein Profil mit Aufenthalts-Historie, Sprache und persönlichen Notizen — die Lieblings-Suite, die Allergie, die Vorliebe für ruhige Zimmer Richtung Garten. So begrüßt dein Team Wiederkehrende mit Namen und Geste, nicht mit Datenbank-Abfragen.
    </p>
  </div>

</AdminLayout>
