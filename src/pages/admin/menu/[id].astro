---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '../../../lib/auth';
import { loadBreakfastItem, EU_ALLERGENS } from '../../../lib/queries';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const { id } = Astro.params;
const isNew = id === 'new';

let item: any = null;
if (!isNew && id) {
  item = await loadBreakfastItem(id, hotel.id);
  if (!item) return Astro.redirect('/admin/menu?error=not_found');
}

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'delete' && !isNew) {
    const { error } = await client
      .from('breakfast_items')
      .delete()
      .eq('id', id);

    if (error) {
      message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
    } else {
      return Astro.redirect('/admin/menu?deleted=1');
    }
  } else {
    const allergenValues: Record<string, boolean> = {};
    EU_ALLERGENS.forEach(a => {
      allergenValues[`contains_${a.key}`] = form.get(`allergen_${a.key}`) === 'on';
    });

    const updates: Record<string, any> = {
      hotel_id: hotel.id,
      display_order: parseInt(form.get('display_order')?.toString() || '0') || 0,
      is_active: form.getAll('is_active').includes('on'),
      category: form.get('category')?.toString().trim() || null,

      name_de: form.get('name_de')?.toString().trim() || '',
      name_en: form.get('name_en')?.toString().trim() || null,
      name_fr: form.get('name_fr')?.toString().trim() || null,
      name_es: form.get('name_es')?.toString().trim() || null,

      description_de: form.get('description_de')?.toString().trim() || null,
      description_en: form.get('description_en')?.toString().trim() || null,
      description_fr: form.get('description_fr')?.toString().trim() || null,
      description_es: form.get('description_es')?.toString().trim() || null,

      ...allergenValues,

      is_vegetarian: form.getAll('is_vegetarian').includes('on'),
      is_vegan: form.getAll('is_vegan').includes('on'),
      is_organic: form.getAll('is_organic').includes('on'),

      updated_at: new Date().toISOString(),
    };

    if (!updates.name_de) {
      message = { type: 'error', text: 'Name (Deutsch) ist Pflichtfeld' };
    } else {
      if (isNew) {
        const { data, error } = await client
          .from('breakfast_items')
          .insert(updates)
          .select('id')
          .single();

        if (error) {
          message = { type: 'error', text: `Anlegen fehlgeschlagen: ${error.message}` };
        } else if (data) {
          return Astro.redirect(`/admin/menu/${data.id}?created=1`);
        }
      } else {
        console.log('=== UPDATE ATTEMPT ===');
        console.log('item id:', id);
        console.log('hotel id:', hotel.id);
        console.log('updates name_de:', updates.name_de);
        console.log('updates contains_sesame:', updates.contains_sesame);

        const { data: updatedRows, error } = await client
          .from('breakfast_items')
          .update(updates)
          .eq('id', id)
          .select('id');

        console.log('=== UPDATE RESULT ===');
        console.log('error:', error);
        console.log('error code:', error?.code);
        console.log('error message:', error?.message);
        console.log('error details:', error?.details);
        console.log('returned rows:', updatedRows?.length ?? 0);

        if (error) {
          message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
        } else if (!updatedRows || updatedRows.length === 0) {
          message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS) oder Eintrag nicht gefunden' };
        } else {
          message = { type: 'success', text: 'Speise gespeichert.' };
          item = { ...item, ...updates };
        }
      }
    }
  }
}

// Defaults for new item
const data = item || {
  display_order: 0,
  is_active: true,
  category: '',
  name_de: '', name_en: '', name_fr: '', name_es: '',
  description_de: '', description_en: '', description_fr: '', description_es: '',
  contains_gluten: false, contains_crustaceans: false, contains_eggs: false,
  contains_fish: false, contains_peanuts: false, contains_soy: false,
  contains_milk: false, contains_nuts: false, contains_celery: false,
  contains_mustard: false, contains_sesame: false, contains_sulfites: false,
  contains_lupins: false, contains_molluscs: false,
  is_vegetarian: false, is_vegan: false, is_organic: false,
};

// Check URL params for created-message
const url = new URL(Astro.request.url);
if (url.searchParams.get('created') === '1' && !message) {
  message = { type: 'success', text: 'Speise angelegt.' };
}
---

<AdminLayout title={isNew ? 'Neue Speise' : data.name_de} hotel={hotel} user={user} activeTab="menu">
  <div class="mb-6">
    <a href="/admin/menu" class="text-xs text-stone-500 hover:text-red-700 transition">
      ← Zurück zur Speisen-Liste
    </a>
  </div>

  <div class="mb-8">
    <p class="text-xs italic text-red-700 mb-2" style="font-family: Georgia, serif;">— Speise —</p>
    <h1 class="text-3xl font-light">
      {isNew
        ? <>Neue <span class="font-medium">Speise</span><span class="text-red-700">.</span></>
        : <><span class="font-medium">{data.name_de}</span><span class="text-red-700">.</span></>
      }
    </h1>
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <form method="POST" class="space-y-6">

    <!-- Allgemein -->
    <section class="bg-white border border-stone-200 p-6">
      <h2 class="text-lg font-medium mb-4">Allgemein</h2>

      <div class="grid grid-cols-12 gap-4">
        <label class="block col-span-6">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Kategorie</span>
          <input
            type="text"
            name="category"
            value={data.category || ''}
            placeholder="z.B. Brot, Körnig, Warm, Beilagen"
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>

        <label class="block col-span-3">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Reihenfolge</span>
          <input
            type="number"
            name="display_order"
            value={data.display_order || 0}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>

        <div class="col-span-3 flex items-end">
          <input type="hidden" name="is_active" value="off" />
          <label class="flex items-center gap-3 cursor-pointer p-2">
            {data.is_active !== false ? (
              <input
                type="checkbox"
                name="is_active"
                value="on"
                checked
                class="sr-only peer"
              />
            ) : (
              <input
                type="checkbox"
                name="is_active"
                value="on"
                class="sr-only peer"
              />
            )}
            <div class="relative w-12 h-6 bg-stone-300 peer-checked:bg-green-700 transition rounded-full">
              <div class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full transition peer-checked:translate-x-6"></div>
            </div>
            <span class="text-sm">Aktiv</span>
          </label>
        </div>
      </div>
    </section>

    <!-- Name (4 Sprachen) -->
    <section class="bg-white border border-stone-200 p-6" data-translate-section="name">
      <div class="flex justify-between items-start gap-4 mb-4">
        <div>
          <h2 class="text-lg font-medium">Name</h2>
          <p class="text-xs text-stone-500 mt-1">In allen 4 Sprachen. Pflichtfeld: Deutsch.</p>
        </div>
        <button type="button" data-translate="name"
          class="bg-stone-900 text-stone-50 px-4 py-2 text-xs hover:bg-red-900 transition font-medium flex items-center gap-2 self-start whitespace-nowrap">
          <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><path d="M8 1 a7 7 0 0 1 7 7 h-1 a6 6 0 0 0 -12 0 H1 a7 7 0 0 1 7 -7 z M14 8 a6 6 0 0 1 -12 0 a6 6 0 0 1 1 -1 l-2 -1 a7 7 0 0 0 13 2 z"/></svg>
          <span>Aus DE übersetzen</span>
        </button>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Deutsch *</span>
          <input
            type="text"
            name="name_de"
            data-field="name_de"
            value={data.name_de || ''}
            required
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">English</span>
          <input
            type="text"
            name="name_en"
            data-field="name_en"
            value={data.name_en || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Français</span>
          <input
            type="text"
            name="name_fr"
            data-field="name_fr"
            value={data.name_fr || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Español</span>
          <input
            type="text"
            name="name_es"
            data-field="name_es"
            value={data.name_es || ''}
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          />
        </label>
      </div>
    </section>

    <!-- Beschreibung (4 Sprachen) -->
    <section class="bg-white border border-stone-200 p-6" data-translate-section="description">
      <div class="flex justify-between items-start gap-4 mb-4">
        <div>
          <h2 class="text-lg font-medium">Beschreibung</h2>
          <p class="text-xs text-stone-500 mt-1">Optional. Z.B. "Hausgemacht mit Roggen-Sauerteig"</p>
        </div>
        <button type="button" data-translate="description"
          class="bg-stone-900 text-stone-50 px-4 py-2 text-xs hover:bg-red-900 transition font-medium flex items-center gap-2 self-start whitespace-nowrap">
          <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><path d="M8 1 a7 7 0 0 1 7 7 h-1 a6 6 0 0 0 -12 0 H1 a7 7 0 0 1 7 -7 z M14 8 a6 6 0 0 1 -12 0 a6 6 0 0 1 1 -1 l-2 -1 a7 7 0 0 0 13 2 z"/></svg>
          <span>Aus DE übersetzen</span>
        </button>
      </div>

      <div class="space-y-3">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Deutsch</span>
          <textarea
            name="description_de"
            data-field="description_de"
            rows="2"
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          >{data.description_de || ''}</textarea>
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">English</span>
          <textarea
            name="description_en"
            data-field="description_en"
            rows="2"
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          >{data.description_en || ''}</textarea>
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Français</span>
          <textarea
            name="description_fr"
            data-field="description_fr"
            rows="2"
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          >{data.description_fr || ''}</textarea>
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-stone-500 block mb-1">Español</span>
          <textarea
            name="description_es"
            data-field="description_es"
            rows="2"
            class="w-full px-3 py-2 border border-stone-300 text-sm focus:outline-none focus:border-stone-900"
          >{data.description_es || ''}</textarea>
        </label>
      </div>
    </section>

    <!-- Allergene -->
    <section class="bg-white border-2 border-amber-300 p-6">
      <div class="flex items-start gap-3 mb-4">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" class="text-amber-700 flex-shrink-0">
          <path d="M12 9v4m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.74-3l-6.93-12a2 2 0 0 0-3.48 0L3.34 16a2 2 0 0 0 1.73 3z"/>
        </svg>
        <div>
          <h2 class="text-lg font-medium text-amber-900">14 EU-Hauptallergene</h2>
          <p class="text-xs text-amber-800 mt-1 max-w-xl leading-relaxed">
            Kreuze an, was diese Speise enthält. Pflicht nach LMIV Art. 9.
            Du musst das bei Rezeptur-Änderungen aktualisieren — die Software erinnert dich nicht.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-3">
        <input type="hidden" name="_allergen_marker" value="set" />
        {EU_ALLERGENS.map(a => (
          <label class="flex items-center gap-2 p-2 hover:bg-amber-50 cursor-pointer transition">
            <input
              type="checkbox"
              name={`allergen_${a.key}`}
              checked={data[`contains_${a.key}`]}
              class="w-4 h-4 accent-amber-700"
            />
            <span class="text-sm">{a.label_de}</span>
          </label>
        ))}
      </div>
    </section>

    <!-- Diät-Flags -->
    <section class="bg-white border border-stone-200 p-6">
      <h2 class="text-lg font-medium mb-4">Diät-Flags</h2>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <input type="hidden" name="is_vegetarian" value="off" />
          <label class="flex items-center gap-3 p-3 cursor-pointer hover:bg-stone-50 transition border border-stone-200">
            {data.is_vegetarian ? (
              <input type="checkbox" name="is_vegetarian" value="on" checked class="sr-only peer" />
            ) : (
              <input type="checkbox" name="is_vegetarian" value="on" class="sr-only peer" />
            )}
            <div class="relative w-10 h-5 bg-stone-300 peer-checked:bg-green-700 transition rounded-full">
              <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition peer-checked:translate-x-5"></div>
            </div>
            <span class="text-sm">Vegetarisch</span>
          </label>
        </div>

        <div>
          <input type="hidden" name="is_vegan" value="off" />
          <label class="flex items-center gap-3 p-3 cursor-pointer hover:bg-stone-50 transition border border-stone-200">
            {data.is_vegan ? (
              <input type="checkbox" name="is_vegan" value="on" checked class="sr-only peer" />
            ) : (
              <input type="checkbox" name="is_vegan" value="on" class="sr-only peer" />
            )}
            <div class="relative w-10 h-5 bg-stone-300 peer-checked:bg-green-700 transition rounded-full">
              <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition peer-checked:translate-x-5"></div>
            </div>
            <span class="text-sm">Vegan</span>
          </label>
        </div>

        <div>
          <input type="hidden" name="is_organic" value="off" />
          <label class="flex items-center gap-3 p-3 cursor-pointer hover:bg-stone-50 transition border border-stone-200">
            {data.is_organic ? (
              <input type="checkbox" name="is_organic" value="on" checked class="sr-only peer" />
            ) : (
              <input type="checkbox" name="is_organic" value="on" class="sr-only peer" />
            )}
            <div class="relative w-10 h-5 bg-stone-300 peer-checked:bg-amber-700 transition rounded-full">
              <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition peer-checked:translate-x-5"></div>
            </div>
            <span class="text-sm">Bio</span>
          </label>
        </div>
      </div>
    </section>

    <!-- Actions -->
    <div class="flex justify-between items-center pt-4">
      {!isNew ? (
        <button
          type="submit"
          name="_action"
          value="delete"
          onclick="return confirm('Speise wirklich löschen?')"
          class="text-sm text-stone-400 hover:text-red-700 transition"
        >
          Löschen
        </button>
      ) : (
        <div></div>
      )}

      <div class="flex gap-3">
        <a href="/admin/menu" class="px-4 py-3 text-sm text-stone-500 hover:text-stone-900 transition">
          Abbrechen
        </a>
        <button
          type="submit"
          class="bg-stone-900 text-stone-50 px-6 py-3 text-sm hover:bg-red-900 transition font-medium"
        >
          {isNew ? 'Speise anlegen' : 'Änderungen speichern'}
        </button>
      </div>
    </div>

  </form>

  <script is:inline>
    document.querySelectorAll('[data-translate]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget;
        const section = target.dataset.translate;
        const sectionEl = target.closest('[data-translate-section]');
        if (!sectionEl) return;

        const deInput = sectionEl.querySelector(`[data-field="${section}_de"]`);
        if (!deInput || !deInput.value.trim()) {
          alert('Bitte zuerst den deutschen Text eingeben.');
          return;
        }

        const originalText = target.innerHTML;
        target.disabled = true;
        target.innerHTML = '<span>Übersetze...</span>';

        try {
          const resp = await fetch('/api/translate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              source: 'de',
              targets: ['en', 'fr', 'es'],
              fields: {
                [`${section}_de`]: deInput.value,
              },
            }),
          });

          const data = await resp.json();

          if (!data.ok) {
            alert('Übersetzung fehlgeschlagen: ' + (data.error || 'unbekannt'));
            return;
          }

          ['en', 'fr', 'es'].forEach(t => {
            const trans = data.result[t];
            if (!trans) return;
            const value = trans[section];
            if (value !== undefined) {
              const input = sectionEl.querySelector(`[data-field="${section}_${t}"]`);
              if (input) input.value = value;
            }
          });

          const msg = document.createElement('div');
          msg.className = 'fixed top-4 right-4 bg-green-700 text-white px-4 py-3 text-sm shadow-lg z-50';
          msg.textContent = 'Übersetzt — vergiss nicht zu speichern.';
          document.body.appendChild(msg);
          setTimeout(() => msg.remove(), 4000);
        } catch (err) {
          alert('Fehler: ' + (err.message || 'unbekannt'));
        } finally {
          target.disabled = false;
          target.innerHTML = originalText;
        }
      });
    });
  </script>
</AdminLayout>
