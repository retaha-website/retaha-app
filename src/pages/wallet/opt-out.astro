---
// Sprint Wallet · Phase 7 — Opt-Out-Confirmation-Page
//
// GET /wallet/opt-out?token=<signed_jwt>
//
// Zeigt eine Confirmation-Page: "Du wirst keine weiteren Marketing-Nachrichten
// von [Hotel] erhalten. Service-Updates während eines Aufenthalts bleiben
// unabhängig." Mit Bestätigen / Abbrechen.
//
// Auf Bestätigen → POST /api/wallet/opt-out → success-State.

import { createSupabaseServiceRoleInstance } from '../../lib/auth';
import { verifyOptOutToken } from '../../lib/wallet/opt-out-token';

const url = new URL(Astro.request.url);
const token = url.searchParams.get('token');

interface ViewState {
  status: 'invalid' | 'ready' | 'already_opted_out';
  hotelName?: string;
  token?: string;
}

let view: ViewState = { status: 'invalid' };

if (token) {
  const payload = await verifyOptOutToken(token);
  if (payload) {
    const sb = createSupabaseServiceRoleInstance();
    const { data: pass } = await sb
      .from('wallet_passes')
      .select('id, state, hotels:hotel_id(name)')
      .eq('id', payload.wallet_pass_id)
      .maybeSingle();
    if (pass) {
      const hotelName = ((pass as any).hotels?.name) || 'das Hotel';
      view = pass.state === 'opted_out'
        ? { status: 'already_opted_out', hotelName, token }
        : { status: 'ready', hotelName, token };
    }
  }
}
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Marketing-Abmeldung · retaha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="optout-page">
      <div class="optout-eyebrow">
        <span class="optout-eyebrow-shapes">
          <span class="circle"></span><span class="square"></span><span class="triangle"></span>
        </span>
        <span>retaha · Wallet</span>
      </div>

      {view.status === 'invalid' && (
        <>
          <h1 class="optout-title">Link ungültig oder abgelaufen<span class="dot">.</span></h1>
          <p class="optout-sub">
            Dieser Abmelde-Link kann nicht mehr verwendet werden. Wenn du weiterhin
            Marketing-Nachrichten erhältst, kontaktiere bitte das Hotel direkt.
          </p>
        </>
      )}

      {view.status === 'already_opted_out' && (
        <>
          <h1 class="optout-title">Bereits abgemeldet<span class="dot">.</span></h1>
          <p class="optout-sub">
            Du erhältst keine Marketing-Nachrichten von <strong>{view.hotelName}</strong> mehr.
            Service-Updates während eines Aufenthalts gehen davon unabhängig.
          </p>
        </>
      )}

      {view.status === 'ready' && (
        <div id="optout-form" data-token={view.token}>
          <h1 class="optout-title">Marketing-Nachrichten abbestellen<span class="dot">?</span></h1>
          <p class="optout-sub">
            Du wirst keine weiteren Marketing-Nachrichten von <strong>{view.hotelName}</strong>
            erhalten. Service-Updates während eines Aufenthalts (Frühstücks-Reminder,
            Service-Bestätigungen) bleiben davon unabhängig — dafür brauchst du nichts zu tun.
          </p>

          <div class="optout-actions">
            <button id="optout-cancel" type="button" class="btn btn-ghost">Abbrechen</button>
            <button id="optout-confirm" type="button" class="btn btn-primary">Bestätigen</button>
          </div>

          <div id="optout-result" class="optout-result" hidden></div>
        </div>
      )}
    </main>

    <style>
      body {
        margin: 0;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        background: #FFFFFF;
        color: #1A1A1A;
        min-height: 100vh;
        display: flex; align-items: center; justify-content: center;
        padding: 24px;
      }
      .optout-page { max-width: 540px; width: 100%; }
      .optout-eyebrow {
        display: flex; align-items: center; gap: 8px;
        font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
        color: #FF4A82; font-weight: 500;
        margin-bottom: 24px;
      }
      .optout-eyebrow-shapes { display: inline-flex; gap: 4px; align-items: center; }
      .optout-eyebrow-shapes .circle  { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
      .optout-eyebrow-shapes .square  { width: 6px; height: 6px; background: currentColor; }
      .optout-eyebrow-shapes .triangle{ width: 0; height: 0; border-left: 3px solid transparent; border-right: 3px solid transparent; border-bottom: 6px solid currentColor; }
      .optout-title {
        font-size: 28px; font-weight: 300; letter-spacing: -0.02em;
        line-height: 1.2; margin: 0 0 16px 0;
      }
      .dot { color: #FF4A82; }
      .optout-sub {
        font-size: 15px; line-height: 1.55; color: rgba(26,26,26,0.7);
        margin: 0 0 28px 0;
      }
      .optout-sub strong { color: #1A1A1A; font-weight: 500; }
      .optout-actions { display: flex; gap: 12px; align-items: stretch; }
      .btn {
        flex: 1; padding: 14px 16px;
        font-family: inherit; font-size: 14px; font-weight: 500;
        letter-spacing: 0.02em; cursor: pointer;
        border: none; min-height: 48px;
        transition: opacity .15s ease, background .15s ease;
      }
      .btn-ghost   { background: transparent; color: rgba(26,26,26,0.55); border: 1px solid #e8e8e8; }
      .btn-ghost:hover:not(:disabled)   { color: #1A1A1A; border-color: #1A1A1A; }
      .btn-primary { background: #1A1A1A; color: #FFFFFF; }
      .btn-primary:hover:not(:disabled) { background: #FF4A82; }
      .btn:disabled { opacity: .4; cursor: not-allowed; }
      .optout-result {
        margin-top: 20px; padding: 16px;
        background: #e8f5ec; color: #145c2a; border: 1px solid #a8d9b6;
        font-size: 14px; line-height: 1.5;
      }
      .optout-result.is-error { background: #fdeaea; color: #7a1515; border-color: #f3b8b8; }
    </style>

    <script is:inline>
      (function () {
        const form = document.getElementById('optout-form');
        if (!form) return;
        const token = form.getAttribute('data-token');
        const confirmBtn = document.getElementById('optout-confirm');
        const cancelBtn  = document.getElementById('optout-cancel');
        const result     = document.getElementById('optout-result');

        cancelBtn?.addEventListener('click', function () {
          window.history.length > 1 ? window.history.back() : window.close();
        });

        confirmBtn?.addEventListener('click', async function () {
          confirmBtn.setAttribute('disabled', 'true');
          cancelBtn?.setAttribute('disabled', 'true');
          result.hidden = true;
          result.classList.remove('is-error');
          try {
            const res = await fetch('/api/wallet/opt-out', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ token: token }),
            });
            const body = await res.json();
            if (body.ok) {
              result.textContent = 'Abmeldung bestätigt. Du erhältst keine Marketing-Nachrichten mehr von diesem Hotel.';
              result.hidden = false;
              confirmBtn.style.display = 'none';
              if (cancelBtn) cancelBtn.textContent = 'Schließen';
              cancelBtn?.removeAttribute('disabled');
            } else {
              result.classList.add('is-error');
              result.textContent = body.error === 'invalid_or_expired_token'
                ? 'Dieser Abmelde-Link ist nicht mehr gültig.'
                : 'Abmeldung fehlgeschlagen: ' + (body.error || 'unbekannt');
              result.hidden = false;
              confirmBtn.removeAttribute('disabled');
              cancelBtn?.removeAttribute('disabled');
            }
          } catch (err) {
            result.classList.add('is-error');
            result.textContent = 'Netzwerk-Fehler: ' + (err.message || 'unbekannt');
            result.hidden = false;
            confirmBtn.removeAttribute('disabled');
            cancelBtn?.removeAttribute('disabled');
          }
        });
      })();
    </script>
  </body>
</html>
