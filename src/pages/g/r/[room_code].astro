---
// Sprint D · Phase 3 — Holzkarten-Route
//
// Auflösungs-Logik:
// 1. room_code → rooms-Lookup (hotel_id, room_id, is_active)
// 2. Cookie auf diesem Browser prüfen (retaha_stay):
//    a) Cookie da + matched aktiven Stay → render Gast-View (Redirect zu
//       /g/[access_token] als pragmatic Phase-3-Compromise — vermeidet
//       1100-Zeilen Body-Refactor jetzt; Refactor kann später kommen wenn
//       URL-Stabilität gewünscht)
//    b) Cookie da + Stay nicht mehr aktiv (processed/checked-out) →
//       "Aufenthalt beendet"-Inline-HTML, Cookie löschen
// 3. Kein gültiger Cookie:
//    - Aktuellen Stay im Zimmer finden (state IN ('Confirmed','Started'))
//    - Wenn Stay existiert → "Aufenthalt-Starten?"-Skeleton (Phase 4 macht's hübsch)
//    - Kein Stay → "Bitte zur Rezeption"

import { createSupabaseServiceRoleInstance } from '../../../lib/auth';
import {
  getStaySession,
  clearStaySessionCookie,
} from '../../../lib/auth/stay-session';

const { room_code } = Astro.params;

function inlineMessage(eyebrow: string, headline: string, body: string) {
  return new Response(
    `<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>retaha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body style="margin:0;font-family:'Space Grotesk',system-ui,sans-serif;background:#FFFFFF;color:#1A1A1A;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px">
    <div style="text-align:center;max-width:420px">
      <p style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:#FF4A82;margin:0 0 20px 0">${eyebrow}</p>
      <h1 style="font-size:26px;font-weight:300;letter-spacing:-0.02em;line-height:1.2;margin:0 0 12px 0">${headline}</h1>
      <p style="opacity:0.55;font-size:14px;line-height:1.5;margin:0">${body}</p>
    </div>
  </body>
</html>`,
    { status: 200, headers: { 'Content-Type': 'text/html; charset=utf-8' } },
  );
}

if (!room_code || room_code.length < 6) {
  return inlineMessage('retaha', 'Unbekannte Zimmer-Karte', 'Bitte zur Rezeption.');
}

const supabase = createSupabaseServiceRoleInstance();

// 1) room_code → Zimmer
const { data: room } = await supabase
  .from('rooms')
  .select('id, hotel_id, room_number, room_name, is_active')
  .eq('room_code', room_code)
  .maybeSingle();

if (!room || room.is_active === false) {
  return inlineMessage('retaha', 'Karte nicht aktiv', 'Bitte zur Rezeption.');
}

// 2) Cookie prüfen
const session = await getStaySession(Astro.cookies);

if (session) {
  // Cookie-Hotel muss zum Zimmer-Hotel passen (sonst Karte aus anderem Hotel)
  if (session.hotel_id !== room.hotel_id) {
    clearStaySessionCookie(Astro.cookies);
    return inlineMessage('retaha', 'Karte aus anderem Hotel', 'Bitte zur Rezeption.');
  }

  // Aktuellen Stay zur Session laden
  const { data: stay } = await supabase
    .from('stays')
    .select('id, access_token, is_active, state, check_out')
    .eq('id', session.stay_id)
    .maybeSingle();

  if (stay?.is_active && stay.access_token && stay.state !== 'Processed' && stay.state !== 'Canceled') {
    // Pragmatic Phase-3-Compromise: Redirect zu /g/[token].
    // URL ändert sich für den Gast — wenn das langfristig stört, Phase 4
    // (oder später) extrahiert die Body-Logik aus [token].astro in eine
    // geteilte Komponente und rendert hier inline.
    return Astro.redirect(`/g/${stay.access_token}`);
  }

  // Cookie matched, aber Stay nicht mehr aktiv → Cookie löschen + Hinweis
  clearStaySessionCookie(Astro.cookies);
  return inlineMessage(
    'retaha',
    'Dein Aufenthalt ist beendet.',
    'Schön, dass du da warst. Falls du noch Hilfe brauchst — bitte zur Rezeption.',
  );
}

// 3) Kein Cookie → aktuellen Stay im Zimmer finden
const { data: activeStay } = await supabase
  .from('stays')
  .select(`
    id, check_in, check_out, state,
    guests(first_name, last_name)
  `)
  .eq('room_id', room.id)
  .eq('is_active', true)
  .in('state', ['Confirmed', 'Started'])
  .order('check_in', { ascending: true })
  .limit(1)
  .maybeSingle();

if (!activeStay) {
  return inlineMessage(
    'retaha',
    'Kein aktueller Aufenthalt in diesem Zimmer.',
    'Bitte zur Rezeption für einen neuen Link.',
  );
}

// Skeleton "Aufenthalt-Starten?"-Screen — Phase 4 macht das richtige Design + API-Call.
// Hier nur funktionaler Stub mit form-Submit zu /api/gast/start-stay (kommt Phase 4).
const guest = activeStay.guests as any;
const guestName = [guest?.first_name, guest?.last_name].filter(Boolean).join(' ').trim();

const checkIn = activeStay.check_in ? new Date(activeStay.check_in) : null;
const checkOut = activeStay.check_out ? new Date(activeStay.check_out) : null;
const fmt = (d: Date | null) => d ? d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '?';
const stayRange = `${fmt(checkIn)} – ${fmt(checkOut)}`;
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>retaha — Aufenthalt starten</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body style="margin:0;font-family:'Space Grotesk',system-ui,sans-serif;background:#FFFFFF;color:#1A1A1A;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px">
    <div style="text-align:center;max-width:420px;width:100%">
      <p style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:#FF4A82;margin:0 0 28px 0">retaha</p>
      <h1 style="font-size:30px;font-weight:300;letter-spacing:-0.02em;line-height:1.2;margin:0 0 8px 0">
        Schön, dass du da bist{guestName ? `,` : ``}
      </h1>
      {guestName && (
        <h2 style="font-size:30px;font-weight:700;letter-spacing:-0.02em;line-height:1.2;margin:0 0 32px 0">
          {guestName}.
        </h2>
      )}
      <p style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;opacity:0.55;margin:0 0 8px 0">Dein Aufenthalt</p>
      <p style="font-size:18px;font-weight:500;margin:0 0 40px 0">{stayRange}</p>

      <form method="POST" action="/api/gast/start-stay">
        <input type="hidden" name="room_code" value={room_code} />
        <button
          type="submit"
          style="display:inline-block;padding:14px 28px;background:#FF4A82;color:#fff;border:0;text-decoration:none;font-size:14px;font-weight:500;letter-spacing:0.04em;font-family:inherit;cursor:pointer"
        >
          Aufenthalt starten →
        </button>
      </form>

      <p style="margin:32px 0 0 0;font-size:11px;opacity:0.5;line-height:1.5">
        Mit Tap stimmst du zu dass dein Gerät den Aufenthalt erkennt — solange du im Hotel bist.
      </p>
    </div>
  </body>
</html>
