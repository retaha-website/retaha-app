---
// Editorial-Hero Footer-Sektion mit 4 Ebenen:
// Eyebrow → Headline (Light + Bold + Burgund-Punkt) → Antwort-Versprechen → 3 Support-Marker → Signatur.
// Bauhaus-Marker semantisch: Kreis=Primary, Quadrat=Secondary, Dreieck=Tertiary.
---

<footer class="bg-stein border-t border-anthrazit/5">
  <div class="max-w-screen-xl mx-auto px-5 py-12 md:px-6 md:py-16">

    <!-- Eyebrow nach STYLEGUIDE-Pattern: Statement + Verortung -->
    <p class="font-serif italic text-burgund text-sm">
      — Kontakt zur Manufaktur, Niedernhall —
    </p>

    <!-- Headline mit Bold-Burgund-Punkt -->
    <h2 class="mt-4 text-2xl md:text-3xl leading-tight">
      <span class="font-light">Wir sind hier,</span><br/>
      <span class="font-bold">um zu helfen<span class="text-burgund">.</span></span>
    </h2>

    <!-- Antwort-Versprechen -->
    <p class="mt-6 text-anthrazit/70 text-sm md:text-base max-w-md">
      Antwort gewöhnlich binnen 15 Minuten. Tagsüber, persönlich.
    </p>

    <!-- Drei Support-Marker -->
    <div class="mt-10 flex flex-col md:flex-row gap-4 md:gap-8">

      <a
        href="https://wa.me/4915735770222"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Support via WhatsApp"
        class="flex items-center gap-3 text-anthrazit hover:text-burgund transition-colors duration-200"
      >
        <span class="block w-2 h-2 rounded-full bg-burgund" aria-hidden="true"></span>
        <span class="text-base font-medium">WhatsApp</span>
      </a>

      <a
        href="mailto:hospitality-support@retaha.de"
        aria-label="Support via Email"
        class="flex items-center gap-3 text-anthrazit hover:text-burgund transition-colors duration-200"
      >
        <span class="block w-2 h-2 bg-burgund" aria-hidden="true"></span>
        <span class="text-base font-medium">Email</span>
      </a>

      <a
        href="tel:+4915735770222"
        aria-label="Direkter Telefon-Support"
        class="flex items-center gap-3 text-anthrazit hover:text-burgund transition-colors duration-200"
      >
        <svg width="9" height="9" viewBox="0 0 9 9" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M4.5 0L9 9H0L4.5 0Z" fill="currentColor" class="text-burgund"/>
        </svg>
        <span class="text-base font-medium">Telefon</span>
      </a>

    </div>

    <!-- Klartext-Kontaktdaten — kopierbar auf Desktop/iPad -->
    <p class="mt-6 text-sm text-anthrazit/60">
      <a
        href="tel:+4915735770222"
        class="hover:text-anthrazit transition-colors duration-200"
      >+49 157 35770222</a>
      <span class="mx-3 text-anthrazit/30 hidden sm:inline" aria-hidden="true">·</span>
      <br class="sm:hidden" />
      <a
        href="mailto:hospitality-support@retaha.de"
        class="hover:text-anthrazit transition-colors duration-200"
      >hospitality-support@retaha.de</a>
    </p>

    <!-- Bauhaus-Trennlinie als Layout-Grammatik -->
    <span class="block w-8 h-px bg-burgund mt-12" aria-hidden="true"></span>

    <!-- Signatur -->
    <a
      href="https://www.retaha.de"
      target="_blank"
      rel="noopener noreferrer"
      class="block mt-4 text-xs text-anthrazit/50 hover:text-anthrazit transition-colors duration-200"
    >
      engineered und developed by retaha
    </a>

  </div>
</footer>
