---
interface Props {
  type: 'sun' | 'partly' | 'cloud' | 'rain' | 'night';
  size?: number;
}
const { type, size = 56 } = Astro.props;
const styleAttr = `width:${size}px;height:${size}px;`;
const id = Math.random().toString(36).slice(2, 8);
---

{type === 'sun' && (
  <svg class="weather-icon-svg" viewBox="0 0 100 100" style={styleAttr} xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id={`halo-${id}`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFD54F" stop-opacity="0.85"/>
        <stop offset="60%" stop-color="#FFB300" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="#FF8F00" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id={`orb-${id}`} cx="38%" cy="35%" r="65%">
        <stop offset="0%" stop-color="#FFF59D"/>
        <stop offset="45%" stop-color="#FFB300"/>
        <stop offset="100%" stop-color="#EF6C00"/>
      </radialGradient>
    </defs>
    <circle class="sun-halo" cx="50" cy="50" r="38" fill={`url(#halo-${id})`}/>
    <circle class="sun-body" cx="50" cy="50" r="18" fill={`url(#orb-${id})`}/>
    <g>
      <line class="sun-ray sun-ray-1" x1="50" y1="6"  x2="50" y2="16"/>
      <line class="sun-ray sun-ray-2" x1="81" y1="19" x2="74" y2="26"/>
      <line class="sun-ray sun-ray-3" x1="94" y1="50" x2="84" y2="50"/>
      <line class="sun-ray sun-ray-4" x1="81" y1="81" x2="74" y2="74"/>
      <line class="sun-ray sun-ray-5" x1="50" y1="94" x2="50" y2="84"/>
      <line class="sun-ray sun-ray-6" x1="19" y1="81" x2="26" y2="74"/>
      <line class="sun-ray sun-ray-7" x1="6"  y1="50" x2="16" y2="50"/>
      <line class="sun-ray sun-ray-8" x1="19" y1="19" x2="26" y2="26"/>
    </g>
  </svg>
)}

{type === 'partly' && (
  <svg class="weather-icon-svg" viewBox="0 0 100 100" style={styleAttr} xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id={`halo-${id}`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFD54F" stop-opacity="0.85"/>
        <stop offset="60%" stop-color="#FFB300" stop-opacity="0.30"/>
        <stop offset="100%" stop-color="#FF8F00" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id={`orb-${id}`} cx="38%" cy="35%" r="65%">
        <stop offset="0%" stop-color="#FFF59D"/>
        <stop offset="45%" stop-color="#FFB300"/>
        <stop offset="100%" stop-color="#EF6C00"/>
      </radialGradient>
      <linearGradient id={`cloud-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#FFFFFF"/>
        <stop offset="100%" stop-color="#CFD8DC"/>
      </linearGradient>
    </defs>
    <circle class="sun-halo" cx="36" cy="36" r="26" fill={`url(#halo-${id})`}/>
    <circle class="sun-body" cx="36" cy="36" r="14" fill={`url(#orb-${id})`}/>
    <g>
      <line class="sun-ray sun-ray-1" x1="36" y1="6"  x2="36" y2="14"/>
      <line class="sun-ray sun-ray-3" x1="62" y1="36" x2="70" y2="36"/>
      <line class="sun-ray sun-ray-2" x1="16" y1="16" x2="22" y2="22"/>
      <line class="sun-ray sun-ray-8" x1="56" y1="16" x2="50" y2="22"/>
      <line class="sun-ray sun-ray-4" x1="10" y1="36" x2="18" y2="36"/>
      <line class="sun-ray sun-ray-6" x1="16" y1="56" x2="22" y2="50"/>
    </g>
    <ellipse class="cloud-shadow" cx="62" cy="84" rx="28" ry="3"/>
    <path class="cloud-body" fill={`url(#cloud-${id})`} d="M30 72 a14 14 0 0 1 26 -4 a10 10 0 0 1 22 6 a8 8 0 0 1 -8 14 H32 a10 10 0 0 1 -2 -16 z"/>
  </svg>
)}

{type === 'cloud' && (
  <svg class="weather-icon-svg" viewBox="0 0 100 100" style={styleAttr} xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id={`cloud-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#FFFFFF"/>
        <stop offset="100%" stop-color="#CFD8DC"/>
      </linearGradient>
      <linearGradient id={`cloud-dark-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#B0BEC5"/>
        <stop offset="100%" stop-color="#78909C"/>
      </linearGradient>
    </defs>
    <ellipse class="cloud-shadow" cx="50" cy="82" rx="32" ry="3"/>
    <path class="cloud-body-back" fill={`url(#cloud-dark-${id})`} d="M18 50 a10 10 0 0 1 18 -4 a8 8 0 0 1 16 4 a6 6 0 0 1 -6 12 H22 a8 8 0 0 1 -4 -12 z"/>
    <path class="cloud-body" fill={`url(#cloud-${id})`} d="M28 70 a14 14 0 0 1 26 -4 a10 10 0 0 1 20 6 a8 8 0 0 1 -8 14 H30 a10 10 0 0 1 -2 -16 z"/>
  </svg>
)}

{type === 'rain' && (
  <svg class="weather-icon-svg" viewBox="0 0 100 100" style={styleAttr} xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id={`cloud-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#90A4AE"/>
        <stop offset="100%" stop-color="#546E7A"/>
      </linearGradient>
      <linearGradient id={`drop-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#4FC3F7"/>
        <stop offset="100%" stop-color="#0288D1"/>
      </linearGradient>
    </defs>
    <path class="cloud-body" fill={`url(#cloud-${id})`} d="M22 45 a14 14 0 0 1 28 -4 a10 10 0 0 1 22 6 a8 8 0 0 1 -8 14 H24 a10 10 0 0 1 -2 -16 z"/>
    <line class="rain-drop rain-drop-1" stroke={`url(#drop-${id})`} x1="32" y1="68" x2="29" y2="80"/>
    <line class="rain-drop rain-drop-2" stroke={`url(#drop-${id})`} x1="42" y1="68" x2="39" y2="84"/>
    <line class="rain-drop rain-drop-3" stroke={`url(#drop-${id})`} x1="52" y1="68" x2="49" y2="80"/>
    <line class="rain-drop rain-drop-4" stroke={`url(#drop-${id})`} x1="62" y1="68" x2="59" y2="84"/>
    <line class="rain-drop rain-drop-5" stroke={`url(#drop-${id})`} x1="72" y1="68" x2="69" y2="80"/>
  </svg>
)}

{type === 'night' && (
  <svg class="weather-icon-svg" viewBox="0 0 100 100" style={styleAttr} xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id={`glow-${id}`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#E1F5FE" stop-opacity="0.8"/>
        <stop offset="100%" stop-color="#90CAF9" stop-opacity="0"/>
      </radialGradient>
      <linearGradient id={`moon-${id}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#ECEFF1"/>
        <stop offset="100%" stop-color="#B0BEC5"/>
      </linearGradient>
    </defs>
    <circle class="moon-glow" cx="55" cy="48" r="32" fill={`url(#glow-${id})`}/>
    <path class="moon-body" fill={`url(#moon-${id})`} d="M62 22 a26 26 0 1 0 14 38 a20 20 0 0 1 -14 -38 z"/>
    <circle class="star star-1" cx="20" cy="28" r="1.6"/>
    <circle class="star star-2" cx="30" cy="68" r="1.4"/>
    <circle class="star star-3" cx="82" cy="78" r="1.5"/>
    <circle class="star star-4" cx="14" cy="50" r="1.2"/>
  </svg>
)}
