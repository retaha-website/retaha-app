---
// Sprint E4 · Phase 4 — Sub-Navigation für /admin/eve/*
//
// Tabs für die Eve-Section. Hält UI-Konsistenz zwischen Knowledge (Phase 4),
// Personality-Settings (Phase 5) und später Audit-Log (Backlog).

interface Props {
  /** Pfad der aktuellen Seite (Astro.url.pathname) für active-state. */
  currentPath: string;
}

const { currentPath } = Astro.props;

const tabs = [
  { href: '/admin/eve/knowledge',   label: 'Wissen',        slug: 'knowledge' },
  { href: '/admin/eve/settings',    label: 'Persönlichkeit', slug: 'settings'  },
];
---

<nav class="eve-subnav" aria-label="Eve Sub-Navigation">
  <div class="eve-subnav-inner">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class={`eve-subnav-tab${currentPath === tab.href ? ' is-active' : ''}`}
        aria-current={currentPath === tab.href ? 'page' : undefined}
      >
        {tab.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .eve-subnav {
    border-bottom: 1px solid #e8e8e8;
    margin-bottom: 32px;
  }
  .eve-subnav-inner {
    display: flex;
    gap: 0;
    max-width: 72rem;
    margin: 0 auto;
  }
  .eve-subnav-tab {
    padding: 12px 20px;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: rgba(26, 26, 26, 0.55);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    margin-bottom: -1px;
  }
  .eve-subnav-tab:hover {
    color: #1A1A1A;
  }
  .eve-subnav-tab.is-active {
    color: #1A1A1A;
    border-bottom-color: #FF4A82;
    font-weight: 500;
  }
</style>
