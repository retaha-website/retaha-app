---
interface Props {
  sectionNumber: string;
  sectionLabel: string;
  headlineLight: string;
  headlineBold: string;
  subtitle?: string;
}

const {
  sectionNumber,
  sectionLabel,
  headlineLight,
  headlineBold,
  subtitle,
} = Astro.props;
---

<header class="relative py-12 md:py-16">
  <p class="text-sm italic text-pink-shock tracking-[0.06em] mb-5">
    — {sectionNumber} / {sectionLabel} —
  </p>

  <h1 class="text-[40px] md:text-[56px] leading-[0.95] tracking-[-0.025em] max-w-full md:max-w-[75%] mb-5">
    <span class="font-light text-anthrazit block">{headlineLight}</span>
    <span class="font-bold text-anthrazit">{headlineBold}<span class="text-pink-shock">.</span></span>
  </h1>

  {subtitle && (
    <p class="text-base italic text-anthrazit/60 leading-[1.5] max-w-full md:max-w-[65%]">
      {subtitle}
    </p>
  )}
</header>
