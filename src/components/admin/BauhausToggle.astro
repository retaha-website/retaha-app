---
interface Props {
  name: string;
  checked: boolean;
  id: string;
  label?: string;
}

const { name, checked, id, label } = Astro.props;
---

<div class="relative w-14 h-7 rounded-md bg-bone border border-anthrazit/20">
  <input type="hidden" name={name} value="off" />
  {checked ? (
    <input
      type="checkbox"
      id={id}
      name={name}
      value="on"
      checked
      class="peer sr-only"
      aria-label={label}
    />
  ) : (
    <input
      type="checkbox"
      id={id}
      name={name}
      value="on"
      class="peer sr-only"
      aria-label={label}
    />
  )}

  <div class="absolute left-[11px] top-1/2 -translate-y-1/2 w-[34px] h-[2px] bg-anthrazit/25 peer-checked:bg-waldgruen transition-colors duration-200 ease-in-out pointer-events-none"></div>

  <div class="absolute left-1 top-1/2 -translate-y-1/2 w-[14px] h-[14px] rounded-full bg-anthrazit peer-checked:translate-x-[34px] transition-transform duration-200 ease-in-out pointer-events-none"></div>

  <div class="absolute inset-0 rounded-md peer-focus-visible:ring-2 peer-focus-visible:ring-waldgruen/40 peer-focus-visible:ring-offset-1 pointer-events-none"></div>
</div>
