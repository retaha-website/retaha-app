---
// Sprint Wallet · Phase 9 — TipTap-basierter Marketing-Editor
//
// Wird im Template-Create + Template-Edit-Flow eingebunden. Schreibt aktuell
// nur in der Hotel-Default-Sprache. Auto-Translation in Phase 11 (Group 2).
//
// Props:
//   templateId      — UUID bei Edit-Mode, null bei Create
//   initialTitle    — Default-Sprach-Wert (oder leer bei Create)
//   initialBodyHtml — Default-Sprach-HTML (oder leer)
//   initialCtaLabel — Default-Sprach-Wert (oder leer)
//   initialCtaUrl   — String
//   initialHeroUrl  — String
//   initialName     — Hotelier-interne Bezeichnung
//   initialCategory — 'newsletter'|'event'|'promotion'|'seasonal' oder null
//   hotelDefaultLang — z.B. 'de' (für Label-Anzeige)
//
// Variables: HOTELIER_ALLOWED_VARIABLES aus src/lib/marketing/variables.ts

import { VARIABLE_UI_DEFS } from '../../lib/marketing/variables';

interface Props {
  templateId: string | null;
  initialTitle: string;
  initialBodyHtml: string;
  initialCtaLabel: string;
  initialCtaUrl: string;
  initialHeroUrl: string;
  initialName: string;
  initialCategory: string | null;
  hotelDefaultLang: string;
}
const p = Astro.props as Props;

const isEdit = !!p.templateId;
const apiUrl = isEdit
  ? `/api/admin/marketing/templates/${p.templateId}`
  : '/api/admin/marketing/templates/create';
const apiMethod = isEdit ? 'PUT' : 'POST';

const CATEGORIES = [
  { value: '',           label: '— keine —' },
  { value: 'newsletter', label: 'Newsletter' },
  { value: 'event',      label: 'Event' },
  { value: 'promotion',  label: 'Promotion' },
  { value: 'seasonal',   label: 'Seasonal' },
];
---

<div class="me-wrap" x-data="marketingEditor()" x-init="init()">
  <div class="me-header">
    <label class="me-field">
      <span class="me-label">Interner Name</span>
      <input
        type="text"
        x-model="form.name"
        placeholder="z.B. Sommerfest 2026"
        class="me-input"
      />
    </label>
    <label class="me-field">
      <span class="me-label">Kategorie</span>
      <select x-model="form.category" class="me-input">
        {CATEGORIES.map(c => <option value={c.value}>{c.label}</option>)}
      </select>
    </label>
  </div>

  <div class="me-section">
    <div class="me-label-row">
      <span class="me-label">Titel ({p.hotelDefaultLang.toUpperCase()})</span>
      <span class="me-hint">Hauptzeile der Push-Notification</span>
    </div>
    <input
      type="text"
      x-model="form.title"
      placeholder="z.B. Sommer im Garten — bei dir, ab Juni"
      class="me-input me-input-title"
    />
  </div>

  <div class="me-section">
    <div class="me-label-row">
      <span class="me-label">Inhalt ({p.hotelDefaultLang.toUpperCase()})</span>
      <div class="me-variable-menu">
        <button type="button" class="me-vmenu-trigger" @click="varMenuOpen = !varMenuOpen">+ Variable einfügen</button>
        <div class="me-vmenu" x-show="varMenuOpen" x-cloak @click.outside="varMenuOpen = false">
          {VARIABLE_UI_DEFS.map(v => (
            <button type="button" class="me-vmenu-item" data-var={v.key} @click={`insertVariable('${v.key}'); varMenuOpen=false`}>
              <span class="me-vmenu-label">{v.label}</span>
              <code class="me-vmenu-code">{`{{${v.key}}}`}</code>
              <span class="me-vmenu-example">→ {v.example}</span>
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="me-toolbar">
      <button type="button" @click="exec('toggleBold')"   :class="active.bold ? 'is-on' : ''"   title="Fett (Strg+B)">B</button>
      <button type="button" @click="exec('toggleItalic')" :class="active.italic ? 'is-on' : ''" title="Kursiv (Strg+I)" class="me-tb-i">I</button>
      <button type="button" @click="exec('toggleUnderline')" :class="active.underline ? 'is-on' : ''" title="Unterstrichen" class="me-tb-u">U</button>
      <span class="me-tb-sep"></span>
      <button type="button" @click="exec('toggleHeading', { level: 2 })" :class="active.h2 ? 'is-on' : ''" title="Überschrift">H2</button>
      <button type="button" @click="exec('toggleHeading', { level: 3 })" :class="active.h3 ? 'is-on' : ''" title="Zwischen-Überschrift">H3</button>
      <span class="me-tb-sep"></span>
      <button type="button" @click="exec('toggleBulletList')"  :class="active.bullet  ? 'is-on' : ''" title="Liste">•</button>
      <button type="button" @click="exec('toggleOrderedList')" :class="active.ordered ? 'is-on' : ''" title="Nummerierte Liste">1.</button>
      <span class="me-tb-sep"></span>
      <button type="button" @click="setLink()" :class="active.link ? 'is-on' : ''" title="Link">🔗</button>
      <button type="button" @click="setImage()" title="Bild einfügen">🖼</button>
    </div>

    <div id="me-tiptap-mount" class="me-editor"></div>
  </div>

  <div class="me-section">
    <div class="me-label-row">
      <span class="me-label">CTA-Button (optional)</span>
      <span class="me-hint">Wird unten in der Notification angezeigt</span>
    </div>
    <div class="me-cta-row">
      <input type="text" x-model="form.ctaLabel" placeholder="Label (z.B. Jetzt buchen)" class="me-input" />
      <input type="url"  x-model="form.ctaUrl"   placeholder="URL (https://…)"           class="me-input" />
    </div>
  </div>

  <div class="me-section">
    <span class="me-label">Hero-Bild-URL (optional)</span>
    <input type="url" x-model="form.heroUrl" placeholder="https://…" class="me-input" />
    <p class="me-hint">Wird im Wallet-Pass + Push-Vorschau angezeigt. Public HTTPS-URL.</p>
  </div>

  <template x-if="errorMsg">
    <div class="me-error" x-text="errorMsg"></div>
  </template>

  <div class="me-actions">
    <a href="/admin/marketing/templates" class="me-btn-ghost">Abbrechen</a>
    <button type="button" class="me-btn-primary" :disabled="submitting" @click="save()">
      <span x-text="submitting ? 'Speichern …' : (isEdit ? 'Änderungen speichern' : 'Vorlage anlegen')"></span>
    </button>
  </div>
</div>

<script
  is:inline
  define:vars={{
    API_URL: apiUrl,
    API_METHOD: apiMethod,
    IS_EDIT: isEdit,
    INITIAL: {
      title: p.initialTitle,
      body: p.initialBodyHtml,
      ctaLabel: p.initialCtaLabel,
      ctaUrl: p.initialCtaUrl,
      heroUrl: p.initialHeroUrl,
      name: p.initialName,
      category: p.initialCategory ?? '',
    },
  }}
>
  window.__RETAHA_ME__ = { API_URL, API_METHOD, IS_EDIT, INITIAL };
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Link from '@tiptap/extension-link';
  import Image from '@tiptap/extension-image';
  import Placeholder from '@tiptap/extension-placeholder';

  // TipTap StarterKit liefert Bold/Italic/Headings/Lists/etc. out-of-box.
  // Underline ist seit TipTap 3 in StarterKit enthalten.

  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('marketingEditor', () => ({
      cfg: (window as any).__RETAHA_ME__,
      get isEdit() { return this.cfg.IS_EDIT; },
      editor: null as any,
      varMenuOpen: false,
      submitting: false,
      errorMsg: '' as string,
      active: { bold: false, italic: false, underline: false, h2: false, h3: false, bullet: false, ordered: false, link: false },
      form: {
        name:     this.cfg.INITIAL.name     ?? '',
        category: this.cfg.INITIAL.category ?? '',
        title:    this.cfg.INITIAL.title    ?? '',
        ctaLabel: this.cfg.INITIAL.ctaLabel ?? '',
        ctaUrl:   this.cfg.INITIAL.ctaUrl   ?? '',
        heroUrl:  this.cfg.INITIAL.heroUrl  ?? '',
      },

      init() {
        const mount = document.getElementById('me-tiptap-mount');
        if (!mount) return;
        const initialBody = this.cfg.INITIAL.body || '<p></p>';

        this.editor = new Editor({
          element: mount,
          extensions: [
            StarterKit.configure({
              heading: { levels: [2, 3] },
              link: false,
              underline: {},
            }),
            Link.configure({ openOnClick: false, autolink: false, linkOnPaste: false }),
            Image.configure({}),
            Placeholder.configure({ placeholder: 'Schreibe hier deine Nachricht … Variablen wie {{first_name}} werden beim Versand ersetzt.' }),
          ],
          content: initialBody,
          onUpdate: () => this._refreshActive(),
          onSelectionUpdate: () => this._refreshActive(),
        });
      },

      _refreshActive() {
        if (!this.editor) return;
        const e = this.editor;
        this.active = {
          bold:      e.isActive('bold'),
          italic:    e.isActive('italic'),
          underline: e.isActive('underline'),
          h2:        e.isActive('heading', { level: 2 }),
          h3:        e.isActive('heading', { level: 3 }),
          bullet:    e.isActive('bulletList'),
          ordered:   e.isActive('orderedList'),
          link:      e.isActive('link'),
        };
      },

      exec(cmd: string, opts: any = {}) {
        if (!this.editor) return;
        const chain = this.editor.chain().focus();
        (chain as any)[cmd](opts).run();
        this._refreshActive();
      },

      setLink() {
        if (!this.editor) return;
        const previous = this.editor.getAttributes('link').href;
        const url = window.prompt('Link-URL:', previous || 'https://');
        if (url === null) return;
        if (url === '') {
          this.editor.chain().focus().extendMarkRange('link').unsetLink().run();
        } else {
          // Nur http(s)/mailto erlauben (Sanitize-Layer würde es sonst rauswerfen)
          if (!/^(https?:|mailto:)/i.test(url)) {
            alert('Bitte gib eine vollständige URL mit https:// oder mailto: an.');
            return;
          }
          this.editor.chain().focus().extendMarkRange('link').setLink({ href: url, target: '_blank' }).run();
        }
        this._refreshActive();
      },

      setImage() {
        if (!this.editor) return;
        const url = window.prompt('Bild-URL (HTTPS, z.B. Supabase Storage):', 'https://');
        if (!url) return;
        if (!/^https:\/\//i.test(url)) {
          alert('Bild-URLs müssen HTTPS sein.');
          return;
        }
        this.editor.chain().focus().setImage({ src: url, alt: '' }).run();
      },

      insertVariable(key: string) {
        if (!this.editor) return;
        this.editor.chain().focus().insertContent(`{{${key}}}`).run();
      },

      async save() {
        if (this.submitting) return;
        this.errorMsg = '';

        const bodyHtml = this.editor ? this.editor.getHTML() : '';
        const payload: any = {
          name: this.form.name?.trim(),
          category: this.form.category || null,
          title_default: this.form.title?.trim(),
          body_default_html: bodyHtml,
          cta_label_default: this.form.ctaLabel?.trim() || null,
          cta_url: this.form.ctaUrl?.trim() || null,
          hero_image_url: this.form.heroUrl?.trim() || null,
        };

        if (!payload.name)  { this.errorMsg = 'Bitte gib einen internen Namen an.'; return; }
        if (!payload.title_default) { this.errorMsg = 'Bitte gib einen Titel an.'; return; }
        if (!bodyHtml.trim() || bodyHtml === '<p></p>') { this.errorMsg = 'Bitte schreib einen Text.'; return; }

        this.submitting = true;
        try {
          const res = await fetch(this.cfg.API_URL, {
            method: this.cfg.API_METHOD,
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) {
            if (data.error === 'invalid_variables') {
              const parts: string[] = [];
              if (data.unknown?.length)   parts.push('Unbekannte Variablen: ' + data.unknown.map((v: string) => `{{${v}}}`).join(', '));
              if (data.forbidden?.length) parts.push('Verbotene Variablen (nur System): ' + data.forbidden.map((v: string) => `{{${v}}}`).join(', '));
              this.errorMsg = parts.join(' · ');
            } else {
              this.errorMsg = data.error || 'Speichern fehlgeschlagen.';
            }
            return;
          }
          window.location.href = '/admin/marketing/templates';
        } catch (err: any) {
          this.errorMsg = 'Netzwerk-Fehler: ' + (err.message || 'unbekannt');
        } finally {
          this.submitting = false;
        }
      },
    }));
  });
</script>

<style>
  .me-wrap { display: flex; flex-direction: column; gap: 24px; max-width: 900px; }
  .me-header { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; }
  @media (max-width: 640px) { .me-header { grid-template-columns: 1fr; } }
  .me-section { display: flex; flex-direction: column; gap: 8px; }
  .me-field { display: flex; flex-direction: column; gap: 6px; }
  .me-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(26,26,26,0.55); font-weight: 500; }
  .me-label-row { display: flex; justify-content: space-between; align-items: center; }
  .me-hint { font-size: 12px; color: rgba(26,26,26,0.5); font-style: italic; }
  .me-input {
    width: 100%; box-sizing: border-box;
    padding: 10px 12px;
    font-family: inherit; font-size: 14px; line-height: 1.5;
    border: 1px solid #e8e8e8; background: #FFFFFF;
    color: #1A1A1A;
  }
  .me-input:focus { outline: none; border-color: #1A1A1A; }
  .me-input-title { font-size: 20px; font-weight: 300; padding: 14px 16px; }
  .me-cta-row { display: grid; grid-template-columns: 1fr 2fr; gap: 12px; }
  @media (max-width: 640px) { .me-cta-row { grid-template-columns: 1fr; } }

  .me-variable-menu { position: relative; }
  .me-vmenu-trigger {
    background: transparent; border: 1px dashed #1A1A1A;
    color: #1A1A1A; padding: 6px 12px; font-size: 12px; font-family: inherit;
    cursor: pointer;
  }
  .me-vmenu-trigger:hover { background: #FF4A82; color: #FFFFFF; border-color: #FF4A82; }
  .me-vmenu {
    position: absolute; right: 0; top: calc(100% + 4px);
    background: #FFFFFF; border: 1px solid #e8e8e8;
    min-width: 320px; z-index: 50;
    box-shadow: 0 12px 28px rgba(0,0,0,0.12);
  }
  .me-vmenu-item {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 12px;
    width: 100%; padding: 10px 14px;
    text-align: left; font-family: inherit; font-size: 13px;
    background: transparent; border: none; border-bottom: 1px solid #f4f4f4;
    cursor: pointer;
  }
  .me-vmenu-item:last-child { border-bottom: none; }
  .me-vmenu-item:hover { background: rgba(255,74,130,0.06); }
  .me-vmenu-label { font-weight: 500; color: #1A1A1A; }
  .me-vmenu-code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; color: #FF4A82; background: #fff5f8; padding: 1px 6px; }
  .me-vmenu-example { font-size: 12px; color: rgba(26,26,26,0.5); font-style: italic; }

  .me-toolbar {
    display: flex; gap: 4px; align-items: center;
    padding: 8px;
    background: #FAFAFA;
    border: 1px solid #e8e8e8; border-bottom: none;
  }
  .me-toolbar button {
    width: 32px; height: 32px;
    background: transparent; border: none;
    font-family: inherit; font-size: 13px; font-weight: 600;
    color: rgba(26,26,26,0.65);
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .me-toolbar button:hover { background: #FFFFFF; color: #1A1A1A; }
  .me-toolbar button.is-on { background: #1A1A1A; color: #FFFFFF; }
  .me-toolbar .me-tb-i { font-style: italic; }
  .me-toolbar .me-tb-u { text-decoration: underline; }
  .me-tb-sep { width: 1px; height: 20px; background: #e8e8e8; margin: 0 4px; }

  .me-editor {
    min-height: 280px;
    padding: 16px;
    background: #FFFFFF;
    border: 1px solid #e8e8e8;
    font-family: inherit; font-size: 15px; line-height: 1.6;
  }
  .me-editor :global(.ProseMirror) { min-height: 250px; outline: none; }
  .me-editor :global(.ProseMirror p) { margin: 0 0 12px 0; }
  .me-editor :global(.ProseMirror h2) { font-size: 22px; font-weight: 500; margin: 16px 0 8px; }
  .me-editor :global(.ProseMirror h3) { font-size: 17px; font-weight: 500; margin: 14px 0 6px; }
  .me-editor :global(.ProseMirror ul),
  .me-editor :global(.ProseMirror ol) { padding-left: 24px; margin: 0 0 12px; }
  .me-editor :global(.ProseMirror a) { color: #FF4A82; text-decoration: underline; }
  .me-editor :global(.ProseMirror img) { max-width: 100%; height: auto; }
  .me-editor :global(.ProseMirror p.is-editor-empty:first-child::before) {
    content: attr(data-placeholder);
    color: rgba(26,26,26,0.35);
    float: left; pointer-events: none; height: 0;
  }

  .me-error {
    padding: 12px;
    background: rgba(220,53,69,0.08);
    color: #B00020;
    font-size: 13px;
    border-left: 3px solid #B00020;
  }

  .me-actions {
    display: flex; gap: 12px; justify-content: flex-end;
    padding-top: 8px; border-top: 1px solid #f0f0f0;
  }
  .me-btn-ghost {
    padding: 12px 20px;
    background: transparent; color: rgba(26,26,26,0.6);
    border: 1px solid #e8e8e8; text-decoration: none;
    font-family: inherit; font-size: 14px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .me-btn-ghost:hover { color: #1A1A1A; border-color: #1A1A1A; }
  .me-btn-primary {
    padding: 12px 24px;
    background: #1A1A1A; color: #FFFFFF;
    border: none; font-family: inherit; font-size: 14px; font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .me-btn-primary:hover:not(:disabled) { background: #FF4A82; }
  .me-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
