---
import '../styles/global.css';
import '../styles/components/buttons.css';
import '../styles/components/inputs.css';
import '../styles/components/pills.css';
import '../styles/components/menu.css';
import '../styles/components/settings.css';
import AdminFooter from './AdminFooter.astro';
import TrialBanner from './admin/TrialBanner.astro';
import { t } from '../i18n/helpers';

interface Props {
  title: string;
  hotel: {
    name: string;
    slug: string;
    trial_started_at?: string | null;
    subscription_status?: string;
  };
  user: { email: string };
  activeTab: 'overview' | 'recommendations' | 'breakfast' | 'menu' | 'conference' | 'service' | 'features' | 'bookings' | 'settings';
}

const { title, hotel, user, activeTab } = Astro.props;
const userLocale = Astro.locals.locale;

const tabs = [
  { id: 'overview', href: '/admin/dashboard' },
  { id: 'recommendations', href: '/admin/recommendations' },
  { id: 'breakfast', href: '/admin/breakfast' },
  { id: 'menu', href: '/admin/menu' },
  { id: 'conference', href: '/admin/conference' },
  { id: 'service', href: '/admin/service' },
  { id: 'features', href: '/admin/features' },
  { id: 'bookings', href: '/admin/bookings' },
  { id: 'settings', href: '/admin/settings' },
] as const;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · retaha backoffice</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body
    class="min-h-screen bg-stone-50 font-sans antialiased text-stone-900"
    x-data="{ menuOpen: false }"
    @keydown.escape.window="menuOpen = false"
    x-init="$watch('menuOpen', v => { document.body.style.overflow = v ? 'hidden' : '' })"
  >
    <!-- Sticky-Wrapper: Banner (wenn im Trial) + Header zusammen oben fixed -->
    <div class="sticky top-0 z-50">
      <TrialBanner hotel={hotel} locale={userLocale} />

      <!-- Top bar: Hotel-Name links, Marker-Trigger rechts -->
      <header class="border-b border-stone-200 bg-white">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center gap-3">
          <div class="flex items-baseline gap-3 min-w-0">
            <p class="font-light text-[15px] tracking-[-0.005em] text-anthrazit truncate m-0">{hotel.name}</p>
            <span class="text-xs text-stone-400 font-mono hidden sm:inline">/{hotel.slug}</span>
          </div>

          <button
            type="button"
            class="menu-trigger"
            :class="{ 'menu-trigger-active': menuOpen }"
            aria-label="Navigation"
            :aria-expanded="menuOpen.toString()"
            @click="menuOpen = !menuOpen"
          >
            <span class="menu-trigger-shapes">
              <span class="menu-trigger-circle"></span>
              <span class="menu-trigger-line"></span>
              <span class="menu-trigger-square"></span>
            </span>
            <span class="menu-trigger-label">menu</span>
          </button>
        </div>
      </header>
    </div>

    <!-- Editorial Menu (Sub-Header-Overlay, bone-Background, öffnet unter Header) -->
    <div
      class="editorial-menu"
      :class="{ 'is-open': menuOpen }"
      aria-label="Hauptmenü"
    >
      <!-- Top-Bar: User-Email + Logout (kein × — Burger im Header übernimmt) -->
      <div class="editorial-menu-topbar">
        <p class="editorial-menu-user-email">{user.email}</p>
        <form method="POST" action="/admin/auth/logout">
          <button type="submit" class="editorial-menu-logout">Abmelden</button>
        </form>
      </div>

      <!-- Items (Hero-Pattern: 24px anthrazit, 22px gap) -->
      <nav class="editorial-menu-items">
        {tabs.map(tab => (
          <a
            href={tab.href}
            class="editorial-menu-item"
            data-active={activeTab === tab.id ? 'true' : 'false'}
          >
            <span class="editorial-menu-item-label">{t(`nav.${tab.id}`, userLocale)}</span>
            <span class="editorial-menu-item-strich"></span>
          </a>
        ))}
      </nav>
    </div>

    <!-- Page content -->
    <main class="max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>

    <AdminFooter />

    <script>
      import Alpine from 'alpinejs';
      // @ts-expect-error - expose for debugging
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
