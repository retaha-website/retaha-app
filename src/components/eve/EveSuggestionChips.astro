---
// Sprint E4 · Phase 9 — Suggestion-Chips (Default-Set für Phase 9,
// tageszeit-dynamisch in Phase 10).
//
// Wird inline im EveChatSheet via Alpine gerendert — wenn messages.length === 0.
---

<style is:global>
  .eve-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 16px 0;
  }
  .eve-chips-label {
    width: 100%;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(26, 26, 26, 0.45);
    margin-bottom: 4px;
  }
  .eve-chip {
    padding: 8px 14px;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 18px;
    font-size: 13px;
    color: #1A1A1A;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .eve-chip:hover {
    border-color: #FF4A82;
    background: #fff5f8;
  }
</style>
