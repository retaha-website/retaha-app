---
// Sprint E4 · Phase 9 — Suggestion-Chips (Default-Set für Phase 9,
// tageszeit-dynamisch in Phase 10).
//
// Wird inline im EveChatSheet via Alpine gerendert — wenn messages.length === 0.
---

<style is:global>
  .eve-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 16px 0;
  }
  .eve-chips-label {
    width: 100%;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, var(--theme-text-primary) 0.45, transparent);
    margin-bottom: 4px;
  }
  .eve-chip {
    padding: 8px 14px;
    background: var(--theme-bg-primary);
    border: 1px solid var(--theme-border);
    border-radius: 18px;
    font-size: 13px;
    color: var(--theme-text-primary);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .eve-chip:hover {
    border-color: var(--theme-accent);
    background: rgba(var(--theme-accent-rgb), 0.06);
  }
</style>
