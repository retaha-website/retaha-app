---
// Sprint E4 · Phase 9 — Confirmation-Card für pending_action
//
// Wird inline im EveChatSheet via Alpine gerendert wenn evePendingAction != null.
// Hier nur die Styles + ein Template das via x-show in Sheet eingebunden wird.
---

<style is:global>
  .eve-confirm-card {
    margin: 12px 0 16px;
    padding: 16px;
    background: var(--theme-bg-primary);
    border: 2px solid var(--theme-accent);
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(var(--theme-accent-rgb), 0.12);
    animation: eve-confirm-in 0.3s ease-out;
  }
  @keyframes eve-confirm-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .eve-confirm-title {
    font-size: 16px;
    font-weight: 500;
    color: var(--theme-text-primary);
    margin: 0 0 12px;
  }
  .eve-confirm-list {
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
    font-size: 14px;
    color: color-mix(in srgb, var(--theme-text-primary) 0.85, transparent);
  }
  .eve-confirm-list li {
    padding: 4px 0;
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  .eve-confirm-list .item-name { flex: 1; }
  .eve-confirm-list .item-price { color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent); font-variant-numeric: tabular-nums; }
  .eve-confirm-when {
    font-size: 13px;
    color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    margin: 8px 0 0;
  }
  .eve-confirm-total {
    font-size: 14px;
    font-weight: 500;
    color: var(--theme-text-primary);
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--theme-border);
  }
  .eve-confirm-note {
    font-size: 12px;
    color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    font-style: italic;
    margin-top: 4px;
  }
  .eve-confirm-actions {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }
  .eve-confirm-btn {
    flex: 1;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }
  .eve-confirm-btn:disabled { opacity: 0.5; cursor: wait; }
  .eve-confirm-btn--primary {
    background: var(--theme-accent);
    color: var(--theme-bg-primary);
  }
  .eve-confirm-btn--primary:hover:not(:disabled) { background: var(--theme-accent-hover); }
  .eve-confirm-btn--secondary {
    background: transparent;
    color: color-mix(in srgb, var(--theme-text-primary) 0.7, transparent);
    border: 1px solid var(--theme-border);
  }
  .eve-confirm-btn--secondary:hover:not(:disabled) { background: var(--theme-bg-tertiary); }
</style>
