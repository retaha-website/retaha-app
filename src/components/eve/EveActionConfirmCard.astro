---
// Sprint E4 · Phase 9 — Confirmation-Card für pending_action
//
// Wird inline im EveChatSheet via Alpine gerendert wenn evePendingAction != null.
// Hier nur die Styles + ein Template das via x-show in Sheet eingebunden wird.
---

<style is:global>
  .eve-confirm-card {
    margin: 12px 0 16px;
    padding: 16px;
    background: #fff;
    border: 2px solid #FF4A82;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(255, 74, 130, 0.12);
    animation: eve-confirm-in 0.3s ease-out;
  }
  @keyframes eve-confirm-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .eve-confirm-title {
    font-size: 16px;
    font-weight: 500;
    color: #1A1A1A;
    margin: 0 0 12px;
  }
  .eve-confirm-list {
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
    font-size: 14px;
    color: rgba(26, 26, 26, 0.85);
  }
  .eve-confirm-list li {
    padding: 4px 0;
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  .eve-confirm-list .item-name { flex: 1; }
  .eve-confirm-list .item-price { color: rgba(26, 26, 26, 0.55); font-variant-numeric: tabular-nums; }
  .eve-confirm-when {
    font-size: 13px;
    color: rgba(26, 26, 26, 0.55);
    margin: 8px 0 0;
  }
  .eve-confirm-total {
    font-size: 14px;
    font-weight: 500;
    color: #1A1A1A;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid #eee;
  }
  .eve-confirm-note {
    font-size: 12px;
    color: rgba(26, 26, 26, 0.55);
    font-style: italic;
    margin-top: 4px;
  }
  .eve-confirm-actions {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }
  .eve-confirm-btn {
    flex: 1;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }
  .eve-confirm-btn:disabled { opacity: 0.5; cursor: wait; }
  .eve-confirm-btn--primary {
    background: #FF4A82;
    color: #fff;
  }
  .eve-confirm-btn--primary:hover:not(:disabled) { background: #e63d72; }
  .eve-confirm-btn--secondary {
    background: transparent;
    color: rgba(26, 26, 26, 0.7);
    border: 1px solid #ddd;
  }
  .eve-confirm-btn--secondary:hover:not(:disabled) { background: #f5f5f5; }
</style>
