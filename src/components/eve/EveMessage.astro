---
// Sprint E4 · Phase 9 — Einzelne Message-Bubble (User oder Assistant)
//
// Wird via Alpine x-for gerendert. Props kommen nicht als Astro-Props sondern
// als Alpine-Bindings (x-bind:class etc.) — diese Component ist ein Markup-
// Template das im EveChatSheet inline verwendet wird. Hier nur die Styles.
---

<style is:global>
  .eve-message {
    display: flex;
    margin-bottom: 12px;
    max-width: 100%;
  }
  .eve-message--user {
    justify-content: flex-end;
  }
  .eve-message--assistant {
    justify-content: flex-start;
  }
  .eve-message-bubble {
    max-width: 80%;
    padding: 12px 16px;
    font-size: 15px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .eve-message--user .eve-message-bubble {
    background: #FF4A82;
    color: #fff;
    border-radius: 18px 18px 4px 18px;
  }
  .eve-message--assistant .eve-message-bubble {
    background: #fff;
    color: #1A1A1A;
    border: 1px solid #e8e8e8;
    border-radius: 18px 18px 18px 4px;
  }
  /* Streaming-Cursor während Eve schreibt */
  .eve-message--streaming .eve-message-bubble::after {
    content: '▍';
    display: inline-block;
    margin-left: 2px;
    color: #FF4A82;
    animation: eve-cursor-blink 1s infinite;
    font-weight: 100;
  }
  @keyframes eve-cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Simple Markdown-Polish im Assistant-Bubble */
  .eve-message-bubble strong { font-weight: 600; }
  .eve-message-bubble em { font-style: italic; }

  /* Sprint Functional Modul C Phase 7 — Feedback-Daumen */
  .eve-message {
    flex-wrap: wrap;
    align-items: flex-end;
  }
  .eve-message-feedback {
    display: flex;
    gap: 4px;
    padding: 4px 0 0 8px;
    opacity: 0.3;
    transition: opacity 0.15s ease;
  }
  .eve-message:hover .eve-message-feedback { opacity: 0.7; }
  .eve-message-feedback:has(.is-active) { opacity: 1; }
  .eve-fb-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 14px;
    padding: 4px 6px;
    line-height: 1;
    border-radius: 4px;
    transition: background 0.12s, transform 0.12s;
    color: inherit;
  }
  .eve-fb-btn:hover { background: rgba(26,26,26,0.06); transform: scale(1.15); }
  .eve-fb-btn.is-active { background: rgba(255,74,130,0.12); }
</style>
