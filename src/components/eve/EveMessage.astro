---
// Sprint E4 · Phase 9 — Einzelne Message-Bubble (User oder Assistant)
//
// Wird via Alpine x-for gerendert. Props kommen nicht als Astro-Props sondern
// als Alpine-Bindings (x-bind:class etc.) — diese Component ist ein Markup-
// Template das im EveChatSheet inline verwendet wird. Hier nur die Styles.
---

<style is:global>
  .eve-message {
    display: flex;
    margin-bottom: 12px;
    max-width: 100%;
  }
  .eve-message--user {
    justify-content: flex-end;
  }
  .eve-message--assistant {
    justify-content: flex-start;
  }
  .eve-message-bubble {
    max-width: 80%;
    padding: 12px 16px;
    font-size: 15px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .eve-message--user .eve-message-bubble {
    background: #FF4A82;
    color: #fff;
    border-radius: 18px 18px 4px 18px;
  }
  .eve-message--assistant .eve-message-bubble {
    background: #fff;
    color: #1A1A1A;
    border: 1px solid #e8e8e8;
    border-radius: 18px 18px 18px 4px;
  }
  /* Streaming-Cursor während Eve schreibt */
  .eve-message--streaming .eve-message-bubble::after {
    content: '▍';
    display: inline-block;
    margin-left: 2px;
    color: #FF4A82;
    animation: eve-cursor-blink 1s infinite;
    font-weight: 100;
  }
  @keyframes eve-cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Simple Markdown-Polish im Assistant-Bubble */
  .eve-message-bubble strong { font-weight: 600; }
  .eve-message-bubble em { font-style: italic; }
</style>
