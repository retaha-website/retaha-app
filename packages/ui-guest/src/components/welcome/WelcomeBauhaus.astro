---
import '../../styles/guest-base.css';
import LanguageOverlay from './shared/LanguageOverlay.astro';
import StayLine from './shared/StayLine.astro';
import CraftFooter from './CraftFooter.astro';

interface Props {
  hotel: any;
  hotelLogoDark: string | null;
  guest: any;
  room: any;
  token: string;
  lang: string;
  hotelEnabledLangs: string[];
  checkInLabel: string;
  checkOutLabel: string;
  heroCards: any[];
  f: any;
  actions: any[];
  weather?: { temp: number; emoji: string } | null;
  persona?: 'pre_arrival' | 'in_house' | 'checking_out';
  greeting?: { hi: string; sub: string };
  preCheckinAvailable?: boolean;
}

const {
  hotel, hotelLogoDark, guest, room, token, lang,
  hotelEnabledLangs, checkInLabel, checkOutLabel,
  heroCards = [], f, actions, weather, persona = 'in_house',
  greeting = { hi: 'Willkommen,', sub: '' },
  preCheckinAvailable = false,
} = Astro.props;

const preCheckinAction = actions.find((a: any) => a.key === 'pre_checkin') ?? null;
const gridActions = actions.filter((a: any) => a.key !== 'pre_checkin');

const name = guest?.first_name ?? hotel.name;

// i18n text extraction for hero cards
function pickText(i18n: any, fallback: string): string {
  if (i18n && typeof i18n === 'object') {
    const v = (i18n[lang] ?? i18n['de'])?.value;
    if (v) return v;
  }
  return fallback || '';
}

// Hero card click handler string
function heroHandler(card: any): string {
  const t = (card.action_target || '').replace(/'/g, "\\'");
  switch (card.card_type) {
    case 'external_link': return `window.open('${t}','_blank')`;
    case 'phone':  return `window.location='tel:${t}'`;
    case 'email':  return `window.location='mailto:${t}'`;
    case 'internal_action':
      if (t === 'wifi')      return `(() => { const _p = new URLSearchParams(window.location.search).get('persona') || 'in_house'; window.location.href = '/g/${token}/wifi?persona='+_p; })()`;
      if (t === 'breakfast') return `(() => { const _p = new URLSearchParams(window.location.search).get('persona') || 'in_house'; window.location.href = '/g/${token}/breakfast?persona='+_p; })()`;
      if (t === 'places')    return `(() => { const _p = new URLSearchParams(window.location.search).get('persona') || 'in_house'; window.location.href = '/g/${token}/recommendations?persona='+_p; })()`;
      return `openSheet('${t}')`;
    default: return '';
  }
}

// Hero label per persona
const heroLabel: Record<string, string> = {
  pre_arrival:  'Vorab planen',
  in_house:     'Heute im Haus',
  checking_out: 'Bis zum nächsten Mal',
};

// Grid label per persona
const gridLabel: Record<string, string> = {
  pre_arrival:  'Ihre Anreise',
  in_house:     'Services',
  checking_out: 'Ihre Abreise',
};

// Weather condition mapping
type WxCondition = 'sunny' | 'partly_cloudy' | 'cloudy' | 'rain' | 'thunder' | 'snow' | 'fog';
function getWxCondition(emoji: string): WxCondition {
  const e = emoji.trim();
  if (e === '☀️') return 'sunny';
  if (e === '🌤️' || e === '⛅' || e === '🌥️') return 'partly_cloudy';
  if (e === '☁️') return 'cloudy';
  if (e === '🌧️' || e === '🌦️') return 'rain';
  if (e === '⛈️' || e === '🌩️') return 'thunder';
  if (e === '❄️' || e === '🌨️') return 'snow';
  if (e === '🌫️' || e === '🌁') return 'fog';
  return 'sunny';
}
const wxCondition: WxCondition | null = weather ? getWxCondition(weather.emoji) : null;
const weatherLabel = weather ? `${weather.temp}°C ${(hotel.city || '').toUpperCase()}` : (hotel.city || '').toUpperCase();

// 22px ambient window — map to 6 visual states
type WinCond = 'clear' | 'cloudy' | 'rain' | 'snow' | 'storm' | 'night';
const currentHour = new Date().getHours();
const isNight = !!weather && (currentHour >= 20 || currentHour < 6);
const winCondition: WinCond = !weather ? 'clear'
  : isNight ? 'night'
  : wxCondition === 'sunny' || wxCondition === 'partly_cloudy' ? 'clear'
  : wxCondition === 'thunder' ? 'storm'
  : wxCondition === 'fog' ? 'cloudy'
  : (wxCondition as WinCond);

// Particles — deterministic pseudo-random (pill 56×22 → n=7, fall=32px)
const WIN_N    = 7;
const WIN_FALL = 32;
function sv(i: number, salt: number): number { return ((i * 173 + salt * 97) % 100) / 100; }
const WIN_RAIN = Array.from({ length: WIN_N }, (_, i) => ({
  left: +(sv(i,1) * 80 + 10).toFixed(1),
  h:    +(sv(i,2) * 4.4 + 4.4).toFixed(1),
  o:    +(sv(i,3) * 0.4 + 0.45).toFixed(2),
  dl:   +(sv(i,4) * 0.8).toFixed(2),
  dr:   +(sv(i,5) * 0.3 + 0.45).toFixed(2),
}));
const WIN_SNOW = Array.from({ length: WIN_N }, (_, i) => ({
  left: +(sv(i,6) * 80 + 10).toFixed(1),
  sz:   +(sv(i,7) * 1.98 + 1.54).toFixed(1),
  o:    +(sv(i,8) * 0.5  + 0.5).toFixed(2),
  dl:   +(sv(i,9) * 3.5).toFixed(1),
  dr:   +(sv(i,10)* 2.0  + 3.0).toFixed(1),
}));
const WIN_STARS = Array.from({ length: WIN_N + 2 }, (_, i) => ({
  left: +(sv(i,11)* 84 + 8).toFixed(1),
  top:  +(sv(i,12)* 62 + 8).toFixed(1),
  sz:   +(sv(i,13)* 1.1 + 0.88).toFixed(1),
  o:    +(sv(i,14)* 0.6 + 0.4).toFixed(2),
  dl:   +(sv(i,15)* 3.0).toFixed(1),
}));
const WIN_SUN_RAYS = [0, 45, 90, 135, 180, 225, 270, 315];
const winHasCloud = winCondition === 'cloudy' || winCondition === 'rain' || winCondition === 'storm' || winCondition === 'snow';
const winHasRain  = winCondition === 'rain'   || winCondition === 'storm';

// Published hero cards only (already filtered by server, but guard here too)
const visibleCards = heroCards.filter((c: any) => c.is_published !== false);
---

<div class="bh-root">
  <!-- HEADER -->
  <header class="bh-head">
    <div class="bh-mark">
      {hotelLogoDark
        ? <img class="bh-mark__logo" src={hotelLogoDark} alt={hotel.name} />
        : <div class="bh-mark__sq">{hotel.name.charAt(0).toUpperCase()}</div>
      }
    </div>
    <LanguageOverlay lang={lang} hotelEnabledLangs={hotelEnabledLangs} token={token} />
  </header>

  <!-- READOUT: date · weather · city + ink line -->
  <div class="bh-readout">
    <span class="bh-readout__date">{checkInLabel ? '' : ''}{new Date().toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { weekday: 'short', day: '2-digit', month: '2-digit', year: 'numeric' }).toUpperCase()}</span>
    <span class="bh-readout__wx">
      {weather && (
        <>
          {/* 22px ambient weather window */}
          <span class={`bh-win bh-win--${winCondition}`} aria-hidden="true" style={`--bh-fall:${WIN_FALL}px`}>

            {/* Clear: pulsing glow + spinning sun with rays */}
            {winCondition === 'clear' && (
              <>
                <span class="bh-win__glow"></span>
                <svg class="bh-win__sun-rays" viewBox="0 0 100 100" aria-hidden="true">
                  <g stroke="#F2A100" stroke-width="6" stroke-linecap="round">
                    {WIN_SUN_RAYS.map(deg => (
                      <line x1="50" y1="6" x2="50" y2="18" transform={`rotate(${deg} 50 50)`} />
                    ))}
                  </g>
                  <circle cx="50" cy="50" r="22" fill="#F2A100" />
                </svg>
              </>
            )}

            {/* Night: glowing moon + twinkling stars */}
            {winCondition === 'night' && (
              <>
                <span class="bh-win__moon"></span>
                {WIN_STARS.map(s => (
                  <span class="bh-win__star" style={`left:${s.left}%;top:${s.top}%;width:${s.sz}px;height:${s.sz}px;opacity:${s.o};animation-delay:${s.dl}s`}></span>
                ))}
              </>
            )}

            {/* Cloud blobs (cloudy / rain / storm / snow) */}
            {winHasCloud && (
              <>
                <span class="bh-win__cloud bh-win__cloud--1"></span>
                <span class="bh-win__cloud bh-win__cloud--2"></span>
                <span class="bh-win__cloud bh-win__cloud--3"></span>
              </>
            )}

            {/* Rain drops (rain / storm) */}
            {winHasRain && (
              <span class="bh-win__rain-layer">
                {WIN_RAIN.map(d => (
                  <span class="bh-win__drop" style={`left:${d.left}%;height:${d.h}px;opacity:${d.o};animation-delay:${d.dl}s;animation-duration:${d.dr}s`}></span>
                ))}
              </span>
            )}

            {/* Snow flakes */}
            {winCondition === 'snow' && WIN_SNOW.map(f => (
              <span class="bh-win__flake" style={`left:${f.left}%;width:${f.sz}px;height:${f.sz}px;opacity:${f.o};animation-delay:${f.dl}s;animation-duration:${f.dr}s`}></span>
            ))}

            {/* Storm flash */}
            {winCondition === 'storm' && <span class="bh-win__flash"></span>}
          </span>

          <span class="bh-readout__temp">{weatherLabel}</span>
        </>
      )}
      {!weather && hotel.city && <span class="bh-readout__temp">{hotel.city.toUpperCase()}</span>}
    </span>
  </div>
  <div class="bh-readout-rule"></div>

  <!-- GREETING -->
  <section class="bh-greet">
    <h1 class="bh-greet__h1">
      {greeting.hi}<br />{name}<span class="bh-dot">.</span>
    </h1>
    <StayLine
      persona={persona}
      room={room}
      checkInLabel={checkInLabel}
      checkOutLabel={checkOutLabel}
      lang={lang}
    />
    {greeting.sub && <p class="bh-greet__sub">{greeting.sub}</p>}
  </section>

  <!-- HERO SLIDER -->
  {f.action_cards !== false && visibleCards.length > 0 && (
    <section class="bh-hero">
      <p class="bh-sec-label">{heroLabel[persona] ?? 'Angebote'}</p>
      <div class="bh-hero__track">
        {visibleCards.map((card: any) => {
          const title   = pickText(card.title_i18n,    card.title_de    || '');
          const sub     = pickText(card.subtitle_i18n, card.subtitle_de || '');
          const eyebrow = pickText(card.eyebrow_i18n,  card.eyebrow_de  || '');
          const handler = heroHandler(card);
          const hasImg  = !!card.image_url;
          return (
            <button
              type="button"
              class="bh-hcard"
              onclick={handler || undefined}
              style={!handler ? 'cursor:default' : undefined}
            >
              <div
                class="bh-hcard__img"
                style={hasImg
                  ? `background-image:linear-gradient(rgba(10,10,10,.08),rgba(10,10,10,.2)),url('${card.image_url}');background-color:#3A3A35`
                  : `background-color:#3A3A35`
                }
              >
                {eyebrow && <span class="bh-hcard__eyebrow">{eyebrow}</span>}
              </div>
              <div class="bh-hcard__body">
                <h3 class="bh-hcard__title">{title}</h3>
                {sub && <p class="bh-hcard__sub">{sub}</p>}
              </div>
            </button>
          );
        })}
      </div>
    </section>
  )}

  <!-- PRIMARY CTA (pre_checkin only) -->
  {preCheckinAction && (
    <a class="bh-primary-btn" href={preCheckinAction.href} data-astro-reload>
      <span class="bh-pb__dot" aria-hidden="true"></span>
      <span class="bh-pb__inner">
        <span class="bh-pb__ml">{preCheckinAction.label}</span>
        <span class="bh-pb__lb">{preCheckinAction.sub}</span>
      </span>
      <span class="bh-pb__chev" aria-hidden="true">→</span>
    </a>
  )}

  <!-- ACTION GRID -->
  {gridActions.length > 0 && (
    <>
      <p class="bh-sec-label" style="margin-top:26px">{gridLabel[persona] ?? 'Services'}</p>
      <div class="bh-grid">
        {gridActions.map((action: any) => action.href ? (
          <a class="bh-tile" href={action.href} data-astro-reload style="text-decoration:none;color:inherit">
            <span class="bh-tile__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={action.icon} />
            </span>
            <span class="bh-tile__label">{action.label}</span>
          </a>
        ) : (
          <button class="bh-tile" type="button" @click={action.handler}>
            <span class="bh-tile__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={action.icon} />
            </span>
            <span class="bh-tile__label">{action.label}</span>
          </button>
        ))}
      </div>
    </>
  )}

  <!-- CRAFT FOOTER -->
  <CraftFooter />
</div>

<style>
  /* ── Tokens ─────────────────────────────────────────────────────────── */
  .bh-root {
    --bh-bg: #F4EEE0;
    --bh-surface: #FFFEFB;
    --bh-ink: #0F0E0C;
    --bh-ink-muted: #6B6B66;
    --bh-ink-faint: #A8A8A2;
    --bh-border: #E7DECB;
    --bh-pink: #FF4A82;
    --bh-yellow: #FFE600;
    /* Brand overrides: palette-vars set on <html>, derived from brand_primary */
    --accent:       var(--user-brand-primary,  var(--bh-pink));
    --hover:        var(--user-brand-hover,    var(--bh-yellow));
    --accent-soft:  var(--user-brand-soft,     rgba(255,74,130,0.08));
    --on-accent:    var(--user-brand-on-accent, #FFFFFF);
    --bh-radius: 12px;
    --bh-mono: 'JetBrains Mono', monospace;
    --bh-display: 'Space Grotesk', sans-serif;
    font-family: var(--bh-display);
    color: var(--bh-ink);
    background: var(--bh-bg);
    padding: 0 22px 110px;
  }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .bh-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 26px 0 4px;
    position: relative;
    z-index: 1;
  }
  .bh-mark { display: flex; align-items: center; }
  .bh-mark__logo { height: 28px; width: auto; max-width: 100px; object-fit: contain; }
  .bh-mark__sq {
    width: 34px; height: 34px;
    border: 1.5px solid var(--bh-ink); border-radius: 9px;
    display: grid; place-items: center;
    font-weight: 700; font-size: 15px;
    font-family: var(--bh-display);
  }

  /* Globe-button (from LanguageOverlay) — override to match prototype */
  .bh-root :global(.globe-btn) {
    display: flex; align-items: center; gap: 6px;
    border: 1px solid var(--bh-border);
    background: var(--bh-surface);
    border-radius: var(--bh-radius);
    padding: 7px 11px;
    cursor: pointer;
    font-family: var(--bh-mono); font-size: 10px; letter-spacing: 0.08em;
    transition: all var(--dur-fast, 240ms) var(--ease-out, cubic-bezier(0.22,1,0.36,1));
  }
  .bh-root :global(.globe-btn:hover) { background: var(--hover); border-color: var(--hover); }
  .bh-root :global(.globe-btn svg) { width: 15px; height: 15px; }

  /* ── Context readout ─────────────────────────────────────────────────── */
  .bh-readout {
    margin-top: 22px;
    font-family: var(--bh-mono); font-size: 11px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--bh-ink-muted);
    display: flex; justify-content: space-between; align-items: center;
  }
  .bh-readout__wx { display: flex; align-items: center; gap: 7px; }

  .bh-readout-rule {
    height: 2px; background: var(--bh-ink);
    margin-top: 8px; position: relative;
  }
  .bh-readout-rule::after {
    content: ''; position: absolute;
    right: 0; top: -2px;
    width: 6px; height: 6px;
    background: var(--accent); border-radius: 50%;
  }

  /* ── Greeting ────────────────────────────────────────────────────────── */
  .bh-greet { margin-top: 26px; }
  .bh-greet__h1 {
    font-size: 34px; line-height: 1.08;
    font-weight: 700; letter-spacing: -0.02em; margin: 0;
    font-family: var(--bh-display);
  }
  .bh-dot { color: var(--accent); }
  .bh-greet__sub {
    margin: 8px 0 0;
    font-size: 13px; color: var(--bh-ink-muted);
    font-family: var(--bh-display);
  }

  /* StayLine override */
  .bh-root :global(.stay-line) {
    margin-top: 10px;
    padding: 0;
    font-family: var(--bh-mono); font-size: 11px;
    letter-spacing: 0.06em; color: var(--bh-ink-muted);
  }
  .bh-root :global(.stay-line b), .bh-root :global(.stay-line strong) {
    color: var(--bh-ink); font-weight: 500;
  }

  /* ── Section labels ──────────────────────────────────────────────────── */
  .bh-sec-label {
    font-family: var(--bh-mono); font-size: 9px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--bh-ink-faint);
    margin: 26px 0 10px;
  }

  /* ── Hero slider ─────────────────────────────────────────────────────── */
  .bh-hero { margin: 0; }
  .bh-hero > .bh-sec-label { padding-left: 4px; }
  .bh-hero__track {
    display: flex; gap: 10px;
    overflow-x: auto; scroll-snap-type: x mandatory;
    scrollbar-width: none;
    margin: 0 -22px; padding: 0;
    scroll-padding-left: 26px;
  }
  .bh-hero__track::before { content: ''; flex-shrink: 0; width: 26px; }
  .bh-hero__track::after  { content: ''; flex-shrink: 0; width: 22px; }
  .bh-hero__track::-webkit-scrollbar { display: none; }

  .bh-hcard {
    flex: 0 0 320px;
    scroll-snap-align: start;
    background: var(--bh-surface);
    border: 1px solid var(--bh-border);
    border-radius: var(--bh-radius);
    overflow: hidden;
    cursor: pointer;
    transition: transform var(--dur-fast, 240ms) var(--ease-spring, cubic-bezier(0.34,1.3,0.64,1)),
                border-color var(--dur-fast, 240ms) var(--ease-out, cubic-bezier(0.22,1,0.36,1));
    text-align: left;
    padding: 0;
  }
  .bh-hcard:hover { transform: translateY(-2px); border-color: var(--hover); }
  .bh-hcard:active { transform: scale(0.97) !important; transition-duration: 90ms !important; }

  .bh-hcard__img {
    aspect-ratio: 4/3;
    position: relative;
    background-size: cover; background-position: center;
  }
  .bh-hcard__eyebrow {
    position: absolute; top: 8px; left: 8px;
    background: var(--hover);
    font-family: var(--bh-mono); font-size: 8px;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 7px; border-radius: 3px; font-weight: 500;
    color: var(--bh-ink);
  }
  .bh-hcard__body { padding: 10px 12px 12px; }
  .bh-hcard__title {
    font-size: 14px; font-weight: 700;
    letter-spacing: -0.01em; margin: 0;
    color: var(--bh-ink); font-family: var(--bh-display);
  }
  .bh-hcard__sub {
    font-size: 11px; color: var(--bh-ink-muted); margin: 3px 0 0;
  }

  /* ── Primary CTA button (pre_checkin) ───────────────────────────────── */
  .bh-primary-btn {
    display: flex; align-items: center; gap: 12px;
    width: 100%; margin-top: 24px;
    background: var(--bh-ink); border-radius: 18px;
    padding: 16px 20px; text-decoration: none; border: 0; cursor: pointer;
    transition: opacity 160ms ease;
  }
  .bh-primary-btn:active { opacity: 0.85; }
  .bh-pb__dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0;
  }
  .bh-pb__inner { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .bh-pb__ml {
    font-family: var(--bh-mono); font-size: 9px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(244,238,224,0.55);
  }
  .bh-pb__lb {
    font-family: var(--bh-display); font-size: 17px;
    font-weight: 600; color: #F4EEE0;
  }
  .bh-pb__chev {
    font-size: 18px; color: rgba(244,238,224,0.55); flex-shrink: 0;
  }

  /* ── Action grid ─────────────────────────────────────────────────────── */
  .bh-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 9px;
  }
  .bh-tile {
    background: var(--bh-surface); border: 1px solid var(--bh-border);
    border-radius: var(--bh-radius); padding: 18px 10px 16px;
    cursor: pointer;
    transition: background var(--dur-fast, 240ms) var(--ease-out, cubic-bezier(0.22,1,0.36,1)),
                border-color var(--dur-fast, 240ms) var(--ease-out, cubic-bezier(0.22,1,0.36,1)),
                transform var(--dur-fast, 240ms) var(--ease-spring, cubic-bezier(0.34,1.3,0.64,1));
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    min-height: 118px; text-align: center;
  }
  .bh-tile:hover { background: var(--hover); border-color: var(--hover); }
  .bh-tile:active { transform: scale(0.97) !important; transition-duration: 90ms !important; }
  .bh-tile__icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
  .bh-tile__icon svg { width: 40px; height: 40px; stroke: var(--bh-ink); stroke-width: 1.5; }
  .bh-tile__label {
    font-family: var(--bh-mono); font-size: 9px;
    letter-spacing: 0.10em; text-transform: uppercase;
    font-weight: 500; line-height: 1.35;
    color: var(--bh-ink);
  }

  /* ── 56×22px ambient weather pill ───────────────────────────────────────── */
  .bh-win {
    position: relative;
    width: 56px; height: 22px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }

  /* Background gradient per condition */
  .bh-win--clear  { background: linear-gradient(160deg,#FFE9AE,#FFF6E2); }
  .bh-win--cloudy { background: linear-gradient(160deg,#C5CFD9,#9AA7B4); }
  .bh-win--rain   { background: linear-gradient(160deg,#8FA0B0,#B8C8D4); }
  .bh-win--snow   { background: linear-gradient(160deg,#DCE6EE,#F2F6FA); }
  .bh-win--storm  { background: linear-gradient(160deg,#6A757E,#9AA4AE); }
  .bh-win--night  { background: linear-gradient(160deg,#1A2030,#2A3450); }

  /* Sun: fixed px sizes anchored to right side of pill */
  .bh-win__glow {
    position: absolute;
    top: -3px; right: -3px;
