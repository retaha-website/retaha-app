---
import '../../styles/guest-base.css';
import LanguageOverlay from './shared/LanguageOverlay.astro';
import StayLine from './shared/StayLine.astro';
import CraftFooter from './CraftFooter.astro';

interface Props {
  hotel: any;
  hotelLogoDark: string | null;
  guest: any;
  room: any;
  token: string;
  lang: string;
  hotelEnabledLangs: string[];
  checkInLabel: string;
  checkOutLabel: string;
  heroCards: any[];
  f: any;
  actions: any[];
  weather?: { temp: number; emoji: string } | null;
  persona?: 'pre_arrival' | 'in_house' | 'checking_out';
  greeting?: { hi: string; sub: string };
}

const {
  hotel, hotelLogoDark, guest, room, token, lang,
  hotelEnabledLangs, checkInLabel, checkOutLabel,
  heroCards = [], f, actions, weather, persona = 'in_house',
  greeting = { hi: 'Willkommen,', sub: '' },
} = Astro.props;

const name = guest?.first_name ?? hotel.name;

// i18n text extraction for hero cards
function pickText(i18n: any, fallback: string): string {
  if (i18n && typeof i18n === 'object') {
    const v = (i18n[lang] ?? i18n['de'])?.value;
    if (v) return v;
  }
  return fallback || '';
}

// Hero card click handler string
function heroHandler(card: any): string {
  const t = (card.action_target || '').replace(/'/g, "\\'");
  switch (card.card_type) {
    case 'external_link': return `window.open('${t}','_blank')`;
    case 'phone':  return `window.location='tel:${t}'`;
    case 'email':  return `window.location='mailto:${t}'`;
    case 'internal_action': return `openSheet('${t}')`;
    default: return '';
  }
}

// Hero label per persona
const heroLabel: Record<string, string> = {
  pre_arrival:  'Vorab planen',
  in_house:     'Heute im Haus',
  checking_out: 'Bis zum nächsten Mal',
};

// Grid label per persona
const gridLabel: Record<string, string> = {
  pre_arrival:  'Ihre Anreise',
  in_house:     'Services',
  checking_out: 'Ihre Abreise',
};

// Weather condition mapping
type WxCondition = 'sunny' | 'partly_cloudy' | 'cloudy' | 'rain' | 'thunder' | 'snow' | 'fog';
function getWxCondition(emoji: string): WxCondition {
  const e = emoji.trim();
  if (e === '☀️') return 'sunny';
  if (e === '🌤️' || e === '⛅' || e === '🌥️') return 'partly_cloudy';
  if (e === '☁️') return 'cloudy';
  if (e === '🌧️' || e === '🌦️') return 'rain';
  if (e === '⛈️' || e === '🌩️') return 'thunder';
  if (e === '❄️' || e === '🌨️') return 'snow';
  if (e === '🌫️' || e === '🌁') return 'fog';
  return 'sunny';
}
const wxCondition: WxCondition | null = weather ? getWxCondition(weather.emoji) : null;
const weatherLabel = weather ? `${weather.temp}°C ${(hotel.city || '').toUpperCase()}` : (hotel.city || '').toUpperCase();

// Published hero cards only (already filtered by server, but guard here too)
const visibleCards = heroCards.filter((c: any) => c.is_published !== false);

// Days until check-in (for pre_arrival subtitle in stayline)
const SUN_RAYS = [0, 45, 90, 135, 180, 225, 270, 315];
---

<div class="bh-root">
  <!-- HEADER -->
  <header class="bh-head">
    <div class="bh-mark">
      {hotelLogoDark
        ? <img class="bh-mark__logo" src={hotelLogoDark} alt={hotel.name} />
        : <div class="bh-mark__sq">{hotel.name.charAt(0).toUpperCase()}</div>
      }
    </div>
    <LanguageOverlay lang={lang} hotelEnabledLangs={hotelEnabledLangs} token={token} />
  </header>

  <!-- READOUT: date · weather · city + ink line -->
  <div class="bh-readout">
    <span class="bh-readout__date">{checkInLabel ? '' : ''}{new Date().toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-GB', { weekday: 'short', day: '2-digit', month: '2-digit', year: 'numeric' }).toUpperCase()}</span>
    <span class="bh-readout__wx">
      {weather && (
        <>
          {wxCondition === 'sunny' && (
            <span class="bh-wx bh-sun" aria-hidden="true">
              <span class="bh-sun__rays">
                {SUN_RAYS.map(deg => <i style={`transform:rotate(${deg}deg)`}></i>)}
              </span>
              <span class="bh-sun__core"></span>
            </span>
          )}
          {wxCondition === 'partly_cloudy' && (
            <span class="bh-wx" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <circle cx="5.5" cy="6" r="2.5"/>
                <line x1="5.5" y1="2" x2="5.5" y2="2.8"/>
                <line x1="8" y1="3.6" x2="7.5" y2="4.1"/>
                <g class="bh-wxg-drift">
                  <rect x="2" y="10" width="14" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                  <rect x="5" y="7" width="8" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                  <rect x="2" y="10" width="14" height="5" rx="2.5"/>
                  <rect x="5" y="7" width="8" height="5" rx="2.5"/>
                </g>
              </svg>
            </span>
          )}
          {wxCondition === 'cloudy' && (
            <span class="bh-wx" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <g class="bh-wxg-drift2" opacity="0.55">
                  <rect x="4" y="4" width="12" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                  <rect x="7" y="2" width="6" height="4" rx="2" fill="var(--bh-bg,#FAFAF6)"/>
                  <rect x="4" y="4" width="12" height="5" rx="2.5"/>
                  <rect x="7" y="2" width="6" height="4" rx="2"/>
                </g>
                <g class="bh-wxg-drift1">
                  <rect x="1" y="10" width="14" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                  <rect x="3" y="7" width="9" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                  <rect x="1" y="10" width="14" height="5" rx="2.5"/>
                  <rect x="3" y="7" width="9" height="5" rx="2.5"/>
                </g>
              </svg>
            </span>
          )}
          {wxCondition === 'rain' && (
            <span class="bh-wx" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <rect x="2" y="4" width="14" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                <rect x="4" y="1" width="9" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                <rect x="2" y="4" width="14" height="5" rx="2.5"/>
                <rect x="4" y="1" width="9" height="5" rx="2.5"/>
                <line x1="5" y1="11" x2="4.2" y2="15.5" class="bh-wxg-drop bh-wxg-drop--1"/>
                <line x1="9" y1="11" x2="8.2" y2="15.5" class="bh-wxg-drop bh-wxg-drop--2"/>
                <line x1="13" y1="11" x2="12.2" y2="15.5" class="bh-wxg-drop bh-wxg-drop--3"/>
              </svg>
            </span>
          )}
          {wxCondition === 'thunder' && (
            <span class="bh-wx" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="14" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                <rect x="4" y="1" width="9" height="4" rx="2" fill="var(--bh-bg,#FAFAF6)"/>
                <rect x="2" y="3" width="14" height="5" rx="2.5"/>
                <rect x="4" y="1" width="9" height="4" rx="2"/>
                <polyline points="10,10 8,13.5 11,13.5 9,17" class="bh-wxg-bolt" stroke="var(--accent,#FF4A82)" stroke-width="1.5" fill="none"/>
              </svg>
            </span>
          )}
          {wxCondition === 'snow' && (
            <span class="bh-wx" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <rect x="2" y="4" width="14" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                <rect x="4" y="1" width="9" height="5" rx="2.5" fill="var(--bh-bg,#FAFAF6)"/>
                <rect x="2" y="4" width="14" height="5" rx="2.5"/>
                <rect x="4" y="1" width="9" height="5" rx="2.5"/>
                <circle cx="5" cy="13" r="1" class="bh-wxg-flake bh-wxg-flake--1" fill="currentColor" stroke="none"/>
                <circle cx="9" cy="13" r="1" class="bh-wxg-flake bh-wxg-flake--2" fill="currentColor" stroke="none"/>
                <circle cx="13" cy="13" r="1" class="bh-wxg-flake bh-wxg-flake--3" fill="currentColor" stroke="none"/>
              </svg>
            </span>
          )}
          {wxCondition === 'fog' && (
            <span class="bh-wx" aria-hidden="true">
              <svg viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <line x1="2" y1="5" x2="16" y2="5" class="bh-wxg-fog bh-wxg-fog--1"/>
                <line x1="3" y1="9" x2="15" y2="9" class="bh-wxg-fog bh-wxg-fog--2"/>
                <line x1="2" y1="13" x2="16" y2="13" class="bh-wxg-fog bh-wxg-fog--3"/>
              </svg>
            </span>
          )}
          <span class="bh-readout__temp">{weatherLabel}</span>
        </>
      )}
      {!weather && hotel.city && <span class="bh-readout__temp">{hotel.city.toUpperCase()}</span>}
    </span>
  </div>
  <div class="bh-readout-rule"></div>

  <!-- GREETING -->
  <section class="bh-greet">
    <h1 class="bh-greet__h1">
      {greeting.hi}<br />{name}<span class="bh-dot">.</span>
    </h1>
    <StayLine
      persona={persona}
      room={room}
      checkInLabel={checkInLabel}
      checkOutLabel={checkOutLabel}
      lang={lang}
    />
    {greeting.sub && <p class="bh-greet__sub">{greeting.sub}</p>}
  </section>

  <!-- HERO SLIDER -->
  {f.action_cards !== false && visibleCards.length > 0 && (
    <section class="bh-hero">
      <p class="bh-sec-label">{heroLabel[persona] ?? 'Angebote'}</p>
      <div class="bh-hero__track">
        {visibleCards.map((card: any) => {
          const title   = pickText(card.title_i18n,    card.title_de    || '');
          const sub     = pickText(card.subtitle_i18n, card.subtitle_de || '');
          const eyebrow = pickText(card.eyebrow_i18n,  card.eyebrow_de  || '');
          const handler = heroHandler(card);
          const hasImg  = !!card.image_url;
          return (
            <button
              type="button"
              class="bh-hcard"
              onclick={handler || undefined}
              style={!handler ? 'cursor:default' : undefined}
            >
              <div
                class="bh-hcard__img"
                style={hasImg
                  ? `background-image:linear-gradient(rgba(10,10,10,.08),rgba(10,10,10,.2)),url('${card.image_url}');background-color:#3A3A35`
                  : `background-color:#3A3A35`
                }
              >
                {eyebrow && <span class="bh-hcard__eyebrow">{eyebrow}</span>}
              </div>
              <div class="bh-hcard__body">
                <h3 class="bh-hcard__title">{title}</h3>
                {sub && <p class="bh-hcard__sub">{sub}</p>}
              </div>
            </button>
          );
        })}
      </div>
    </section>
  )}

  <!-- ACTION GRID -->
  <p class="bh-sec-label" style="margin-top:26px">{gridLabel[persona] ?? 'Services'}</p>
  <div class="bh-grid">
    {actions.map((action: any) => (
      <button class="bh-tile" type="button" @click={action.handler}>
        <span class="bh-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={action.icon} />
        </span>
        <span class="bh-tile__label">{action.label}</span>
      </button>
    ))}
  </div>

  <!-- CRAFT FOOTER -->
  <CraftFooter />
</div>

<style>
  /* ── Tokens (match prototype exactly) ─────────────────────────────────── */
  .bh-root {
    --bh-bg: #FAFAF6;
    --bh-surface: #FFFFFF;
    --bh-ink: #0A0A0A;
    --bh-ink-muted: #6B6B66;
    --bh-ink-faint: #A8A8A2;
    --bh-border: #E3E1DA;
    --bh-pink: #FF4A82;
    --bh-yellow: #FFE600;
    /* Brand overrides: palette-vars set on <html>, derived from brand_primary */
    --accent:       var(--user-brand-primary,  var(--bh-pink));
    --hover:        var(--user-brand-hover,    var(--bh-yellow));
    --accent-soft:  var(--user-brand-soft,     rgba(255,74,130,0.08));
    --on-accent:    var(--user-brand-on-accent, #FFFFFF);
    --bh-radius: 12px;
    --bh-mono: 'JetBrains Mono', monospace;
    --bh-display: 'Space Grotesk', sans-serif;
    font-family: var(--bh-display);
    color: var(--bh-ink);
    padding: 0 22px 110px;
  }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .bh-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 26px 0 4px;
  }
  .bh-mark { display: flex; align-items: center; }
  .bh-mark__logo { height: 28px; width: auto; max-width: 100px; object-fit: contain; }
  .bh-mark__sq {
    width: 34px; height: 34px;
    border: 1.5px solid var(--bh-ink); border-radius: 9px;
    display: grid; place-items: center;
    font-weight: 700; font-size: 15px;
    font-family: var(--bh-display);
  }

  /* Globe-button (from LanguageOverlay) — override to match prototype */
  .bh-root :global(.globe-btn) {
    display: flex; align-items: center; gap: 6px;
    border: 1px solid var(--bh-border);
    background: var(--bh-surface);
    border-radius: var(--bh-radius);
    padding: 7px 11px;
    cursor: pointer;
    font-family: var(--bh-mono); font-size: 10px; letter-spacing: 0.08em;
    transition: all 0.2s;
  }
  .bh-root :global(.globe-btn:hover) { background: var(--hover); border-color: var(--hover); }
  .bh-root :global(.globe-btn svg) { width: 15px; height: 15px; }

  /* ── Context readout ─────────────────────────────────────────────────── */
  .bh-readout {
    margin-top: 22px;
    font-family: var(--bh-mono); font-size: 11px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--bh-ink-muted);
    display: flex; justify-content: space-between; align-items: center;
  }
  .bh-readout__wx { display: flex; align-items: center; gap: 7px; }
  .bh-wx-emoji { font-size: 14px; }

  /* Animated sun */
  .bh-sun { width: 18px; height: 18px; position: relative; flex-shrink: 0; }
  .bh-sun__core {
    position: absolute; inset: 4px;
    background: var(--bh-yellow); border: 1.5px solid var(--bh-ink); border-radius: 50%;
  }
  .bh-sun__rays {
    position: absolute; inset: 0;
    animation: bh-spin 14s linear infinite;
  }
  .bh-sun__rays i {
    position: absolute; left: 50%; top: 0;
    width: 1.5px; height: 4px;
    background: var(--bh-ink);
    transform-origin: 50% 9px;
    border-radius: 1px;
  }
  @keyframes bh-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .bh-sun__rays { animation: none; } }

  .bh-readout-rule {
    height: 2px; background: var(--bh-ink);
    margin-top: 8px; position: relative;
  }
  .bh-readout-rule::after {
    content: ''; position: absolute;
    right: 0; top: -2px;
    width: 6px; height: 6px;
    background: var(--accent); border-radius: 50%;
  }

  /* ── Greeting ────────────────────────────────────────────────────────── */
  .bh-greet { margin-top: 26px; }
  .bh-greet__h1 {
    font-size: 34px; line-height: 1.08;
    font-weight: 700; letter-spacing: -0.02em; margin: 0;
    font-family: var(--bh-display);
  }
  .bh-dot { color: var(--accent); }
  .bh-greet__sub {
    margin: 8px 0 0;
    font-size: 13px; color: var(--bh-ink-muted);
    font-family: var(--bh-display);
  }

  /* StayLine override */
  .bh-root :global(.stay-line) {
    margin-top: 10px;
    padding: 0;
    font-family: var(--bh-mono); font-size: 11px;
    letter-spacing: 0.06em; color: var(--bh-ink-muted);
  }
  .bh-root :global(.stay-line b), .bh-root :global(.stay-line strong) {
    color: var(--bh-ink); font-weight: 500;
  }

  /* ── Section labels ──────────────────────────────────────────────────── */
  .bh-sec-label {
    font-family: var(--bh-mono); font-size: 9px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--bh-ink-faint);
    margin: 26px 0 10px;
  }

  /* ── Hero slider ─────────────────────────────────────────────────────── */
  .bh-hero { margin: 0; }
  .bh-hero__track {
    display: flex; gap: 10px;
    overflow-x: auto; scroll-snap-type: x mandatory;
    scrollbar-width: none;
    margin: 0 -22px; padding: 0 22px;
  }
  .bh-hero__track::-webkit-scrollbar { display: none; }

  .bh-hcard {
    flex: 0 0 calc(50% - 5px);
    scroll-snap-align: start;
    background: var(--bh-surface);
    border: 1px solid var(--bh-border);
    border-radius: var(--bh-radius);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s;
    text-align: left;
    padding: 0;
  }
  .bh-hcard:hover { transform: translateY(-2px); border-color: var(--hover); }

  .bh-hcard__img {
    aspect-ratio: 4/3;
    position: relative;
    background-size: cover; background-position: center;
  }
  .bh-hcard__eyebrow {
    position: absolute; top: 8px; left: 8px;
    background: var(--hover);
    font-family: var(--bh-mono); font-size: 8px;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 7px; border-radius: 3px; font-weight: 500;
    color: var(--bh-ink);
  }
  .bh-hcard__body { padding: 10px 12px 12px; }
  .bh-hcard__title {
    font-size: 14px; font-weight: 700;
    letter-spacing: -0.01em; margin: 0;
    color: var(--bh-ink); font-family: var(--bh-display);
  }
  .bh-hcard__sub {
    font-size: 11px; color: var(--bh-ink-muted); margin: 3px 0 0;
  }

  /* ── Action grid ─────────────────────────────────────────────────────── */
  .bh-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 9px;
  }
  .bh-tile {
    background: var(--bh-surface); border: 1px solid var(--bh-border);
    border-radius: var(--bh-radius); padding: 14px 10px 12px;
    cursor: pointer; transition: background 0.2s, border-color 0.2s;
    display: flex; flex-direction: column; gap: 8px; min-height: 84px;
    text-align: left;
  }
  .bh-tile:hover { background: var(--hover); border-color: var(--hover); }
  .bh-tile__icon { width: 19px; height: 19px; display: flex; align-items: center; }
  .bh-tile__icon svg { width: 19px; height: 19px; stroke: var(--bh-ink); }
  .bh-tile__label {
    font-family: var(--bh-mono); font-size: 9px;
    letter-spacing: 0.07em; text-transform: uppercase;
    font-weight: 500; line-height: 1.35;
    color: var(--bh-ink);
  }

  /* ── Weather icons base ──────────────────────────────────────────────── */
  .bh-wx {
    width: 18px; height: 18px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--bh-ink-muted);
    overflow: visible;
  }
  .bh-wx svg { width: 18px; height: 18px; overflow: visible; }

  /* Partly cloudy: cloud drifts */
  .bh-wxg-drift { animation: bh-wx-drift 7s ease-in-out infinite; }
  @keyframes bh-wx-drift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(3px); }
  }

  /* Cloudy: two layers drift offset */
  .bh-wxg-drift1 { animation: bh-wx-d1 9s ease-in-out infinite; }
  .bh-wxg-drift2 { animation: bh-wx-d2 12s ease-in-out infinite; }
  @keyframes bh-wx-d1 {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(2px); }
  }
  @keyframes bh-wx-d2 {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-2px); }
  }

  /* Rain: drops fall */
  .bh-wxg-drop { animation: bh-wx-fall 1.3s linear infinite; }
  .bh-wxg-drop--1 { animation-delay: 0s; }
  .bh-wxg-drop--2 { animation-delay: -0.45s; }
  .bh-wxg-drop--3 { animation-delay: -0.9s; }
  @keyframes bh-wx-fall {
    0%   { transform: translateY(-3px); opacity: 0; }
    25%  { opacity: 1; }
    100% { transform: translateY(4px);  opacity: 0; }
  }

  /* Thunder: bolt flashes every ~4s in accent color */
  .bh-wxg-bolt { opacity: 0; animation: bh-wx-flash 4s ease-in-out infinite; }
  @keyframes bh-wx-flash {
    0%, 85%, 100% { opacity: 0; }
    90%            { opacity: 1; }
    95%            { opacity: 0.3; }
    97%            { opacity: 1; }
  }

  /* Snow: flakes drift down */
  .bh-wxg-flake { animation: bh-wx-snow 2.8s ease-in-out infinite; }
  .bh-wxg-flake--1 { animation-delay: 0s; }
  .bh-wxg-flake--2 { animation-delay: -0.95s; }
  .bh-wxg-flake--3 { animation-delay: -1.9s; }
  @keyframes bh-wx-snow {
    0%   { transform: translateY(-2px) translateX(0);    opacity: 0; }
    20%  { opacity: 1; }
    55%  { transform: translateY(2px)  translateX(1.5px); opacity: 1; }
    100% { transform: translateY(5px)  translateX(0);    opacity: 0; }
  }

  /* Fog: lines pulse */
  .bh-wxg-fog { animation: bh-wx-fog 3.2s ease-in-out infinite; }
  .bh-wxg-fog--1 { animation-delay: 0s; }
