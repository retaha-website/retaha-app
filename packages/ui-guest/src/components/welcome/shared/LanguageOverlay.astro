---
interface Props {
  lang: string;
  hotelEnabledLangs: string[];
  token: string;
}

const { lang, hotelEnabledLangs, token } = Astro.props;

const switchUrl = (l: string) => `/g/${token}?lang=${l}`;
const LANG_NAMES: Record<string, string> = {
  de: 'Deutsch', en: 'English',  fr: 'Français', es: 'Español',
  it: 'Italiano', nl: 'Nederlands', pt: 'Português', pl: 'Polski',
  ru: 'Русский',  ar: 'العربية',   zh: '中文',
};
---

<div class="lp-wrap">
  <button
    class="lp-trigger"
    type="button"
    aria-label="Sprache wählen"
    aria-expanded="false"
    aria-haspopup="listbox"
  >
    <!-- Globe -->
    <svg class="lp-trigger__globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>
    </svg>
    <!-- Current language code -->
    <span class="lp-trigger__code">{lang.toUpperCase()}</span>
    <!-- Chevron — rotates 180° when open -->
    <svg class="lp-trigger__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </button>

  <div class="lp-panel" role="listbox" aria-label="Sprache auswählen" hidden>
    <div class="lp-panel__label">Sprache wählen</div>
    <div class="lp-grid">
      {hotelEnabledLangs.map(l => (
        <a
          href={switchUrl(l)}
          class={`lp-item ${lang === l ? 'is-active' : ''}`}
          role="option"
          aria-selected={lang === l ? 'true' : 'false'}
        >
          <span class="lp-item__code">{l.toUpperCase()}</span>
          <span class="lp-item__name">{LANG_NAMES[l] ?? l}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  const wrap    = document.querySelector<HTMLElement>('.lp-wrap');
  const trigger = wrap?.querySelector<HTMLButtonElement>('.lp-trigger');
  const panel   = wrap?.querySelector<HTMLElement>('.lp-panel');

  function open() {
    panel?.removeAttribute('hidden');
    trigger?.setAttribute('aria-expanded', 'true');
    trigger?.classList.add('is-open');
  }
  function close() {
    panel?.setAttribute('hidden', '');
    trigger?.setAttribute('aria-expanded', 'false');
    trigger?.classList.remove('is-open');
  }
  function toggle() {
    panel?.hasAttribute('hidden') ? open() : close();
  }

  trigger?.addEventListener('click', (e) => { e.stopPropagation(); toggle(); });
  document.addEventListener('click', () => { if (!panel?.hasAttribute('hidden')) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  panel?.addEventListener('click', close);
</script>

<style>
  /* Wrapper — provides anchor for absolute panel */
  .lp-wrap {
    position: relative;
    display: inline-flex;
  }

  /* Trigger */
  .lp-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 0 12px;
    border-radius: 12px;
    border: 1px solid var(--guest-border, #E4E1D9);
    background: var(--guest-bg-deep, #FAFAF8);
    cursor: pointer;
    color: var(--guest-ink, #0A0A0A);
    transition: border-color 140ms ease, background 140ms ease;
    outline: none;
  }
  .lp-trigger:hover,
  .lp-trigger.is-open {
    border-color: var(--guest-ink, #0A0A0A);
    background: #fff;
  }
  .lp-trigger:focus-visible {
    outline: 2px solid var(--accent, #FF4A82);
    outline-offset: 2px;
  }

  .lp-trigger__globe  { width: 16px; height: 16px; flex-shrink: 0; }
  .lp-trigger__code {
    font-family: var(--guest-font-mono, 'JetBrains Mono', monospace);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .lp-trigger__chevron {
    width: 14px; height: 14px; flex-shrink: 0;
    transition: transform 160ms ease;
  }
  .lp-trigger.is-open .lp-trigger__chevron {
    transform: rotate(180deg);
  }

  /* Dropdown panel */
  .lp-panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    z-index: 300;
    width: 320px;
    max-width: calc(100vw - 40px);
    max-height: min(60vh, 420px);
    overflow-y: auto;
    background: #fff;
    border: 1px solid var(--guest-border, #E4E1D9);
    border-radius: 12px;
    padding: 12px;
    box-shadow: 0 12px 32px rgba(10,10,10,0.12);
    transform-origin: top right;
    animation: lp-in 160ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
  .lp-panel[hidden] { display: none; }

  @keyframes lp-in {
    from { opacity: 0; transform: scale(0.96) translateY(-6px); }
    to   { opacity: 1; transform: scale(1)    translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lp-panel { animation: none; }
    .lp-trigger__chevron { transition: none; }
  }

  /* Panel label */
  .lp-panel__label {
    font-family: var(--guest-font-mono, 'JetBrains Mono', monospace);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--guest-ink-faint, #9A968C);
    padding: 2px 4px 10px;
  }

  /* Language grid */
  .lp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  /* Language tile */
  .lp-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid transparent;
    border-radius: 12px;
    text-decoration: none;
    background: var(--guest-bg-deep, #FAFAF8);
    transition: background 140ms ease, border-color 140ms ease;
    outline: none;
  }
  .lp-item:hover {
    background: rgba(255, 230, 0, 0.18);
    border-color: rgba(255, 230, 0, 0.4);
  }
  .lp-item.is-active {
    border-color: var(--accent, #FF4A82);
    background: rgba(255, 74, 130, 0.06);
  }
  .lp-item:focus-visible {
    outline: 2px solid var(--accent, #FF4A82);
    outline-offset: 2px;
  }

  /* Code: pink only when active, ink otherwise */
  .lp-item__code {
    font-family: var(--guest-font-mono, 'JetBrains Mono', monospace);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--guest-ink, #0A0A0A);
    min-width: 22px;
    flex-shrink: 0;
  }
  .lp-item.is-active .lp-item__code {
    color: var(--accent, #FF4A82);
  }

  /* Name: display font */
  .lp-item__name {
    font-family: var(--guest-font-display, 'Space Grotesk', sans-serif);
    font-size: 14px;
    font-weight: 500;
    color: var(--guest-ink, #0A0A0A);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
