---
interface Props {
  hotelLogoUrl?: string | null;
  hotelName?: string;
}
const { hotelLogoUrl, hotelName } = Astro.props;
---

<footer class="craft">
  <div class="craft-rule"></div>
  <div class="craft-row">
    <div class="craft-left">
      {hotelLogoUrl && (
        <img class="craft-hotel-logo" src={hotelLogoUrl} alt={hotelName ?? ''} />
      )}
      <span class="craft-text">Crafted with <b>♥</b> in Stuttgart</span>
    </div>
    <a class="craft-brand" href="https://retaha.de" target="_blank" rel="noopener">
      retaha<i>.</i>
    </a>
  </div>
</footer>

<style>
  .craft {
    margin-top: 44px;
    font-family: 'JetBrains Mono', monospace;
  }
  .craft-rule {
    height: 1px; background: #E3E1DA; margin-bottom: 13px;
  }
  .craft-row {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 12px;
  }
  .craft-left {
    display: flex; align-items: baseline; gap: 10px;
  }
  .craft-hotel-logo {
    height: 16px; width: auto; max-width: 60px;
    object-fit: contain; opacity: 0.55;
    /* align to baseline is approximate — use flex align-items: center on parent if needed */
    align-self: center;
  }
  .craft-text {
    font-size: 8px; letter-spacing: 0.16em;
    text-transform: uppercase; color: #A8A8A2;
  }
  .craft-text b { color: #FF4A82; font-weight: 400; }
  .craft-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 700; letter-spacing: 0.01em;
    color: #0A0A0A; text-decoration: none;
  }
  .craft-brand i { color: #FF4A82; font-style: normal; }
  .craft-brand:hover { opacity: 0.7; }
</style>
