<style>
  .craft {
    margin-top: 44px;
    font-family: 'JetBrains Mono', monospace;
  }
  .craft-rule {
    height: 1px; background: #E3E1DA; margin-bottom: 13px;
  }
  .craft-row {
    display: flex; justify-content: space-between; align-items: center;
    gap: 12px;
  }
  .craft-text {
    font-size: 8px; letter-spacing: 0.16em;
    text-transform: uppercase; color: #A8A8A2;
  }
  .craft-text b { color: #FF4A82; font-weight: 400; }
  .craft-brand {
    display: inline-flex; align-items: center; gap: 6px;
    text-decoration: none; color: #0A0A0A;
    transition: opacity 0.15s;
  }
  .craft-brand:hover { opacity: 0.55; }
  .craft-mark {
    height: 14px; width: auto; display: block; color: #0A0A0A; flex-shrink: 0;
  }
  .craft-wordmark {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 700; letter-spacing: 0.01em;
    color: #0A0A0A; line-height: 1;
  }
</style>
