---
import type { GuestTheme } from '../types/index.ts';

interface Props {
  theme: GuestTheme;
  guestFirstName?: string;
  checkoutTimeLabel?: string;
  previewMode?: boolean;
}

const {
  theme,
  guestFirstName = 'Anna',
  checkoutTimeLabel = 'heute bis 11:00 Uhr',
  previewMode = true,
} = Astro.props;
---

<div class="checkout">
  <div class="checkout__back">
    <span>← zurück</span>
  </div>

  <section class="checkout__hero">
    <div class="checkout__eyebrow">Abreise · {checkoutTimeLabel}</div>
    <h1 class="checkout__title">
      Vielen Dank, {guestFirstName}<span class="dot-accent">.</span>
    </h1>
    <p class="checkout__sub">Wir freuen uns, dich bald wieder begrüßen zu dürfen.</p>
  </section>

  <section class="checkout__steps">
    <div class="checkout__step checkout__step--done">
      <div class="checkout__step-num">1</div>
      <div class="checkout__step-body">
        <div class="checkout__step-title">Rechnung prüfen</div>
        <div class="checkout__step-sub">Alles automatisch erfasst. Fragen? Ruf kurz an.</div>
      </div>
      <svg class="checkout__step-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M5 12 L10 17 L19 7"/>
      </svg>
    </div>

    <div class="checkout__step">
      <div class="checkout__step-num">2</div>
      <div class="checkout__step-body">
        <div class="checkout__step-title">Schlüsselkarten abgeben</div>
        <div class="checkout__step-sub">Briefkasten am Empfang — du musst niemanden wecken.</div>
      </div>
    </div>

    <div class="checkout__step checkout__step--primary">
      <div class="checkout__step-num">3</div>
      <div class="checkout__step-body">
        <div class="checkout__step-title">Auschecken bestätigen</div>
        <div class="checkout__step-sub">Ein Klick — und du bist fertig.</div>
      </div>
    </div>
  </section>

  <div class="checkout__cta-area">
    <button class="checkout__btn-primary" type="button">
      Jetzt auschecken ✓
    </button>
    <p class="checkout__cta-hint">Du erhältst eine Bestätigungsnachricht.</p>
  </div>
</div>

<style>
  .checkout {
    display: flex; flex-direction: column; gap: 0;
    padding: 8px 0 24px;
    font-family: var(--guest-font-body);
    overflow-y: auto; height: 100%; box-sizing: border-box;
  }
  .checkout__back {
    padding: 4px 16px 0;
    font-family: var(--guest-font-mono);
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--guest-ink-muted); cursor: pointer;
  }
  .checkout__hero {
    padding: 16px 16px 20px;
  }
  .checkout__eyebrow {
    font-family: var(--guest-font-mono);
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--guest-ink);
    background: var(--guest-bg-deep);
    display: inline-block; padding: 3px 8px; border-radius: 2px;
    margin-bottom: 10px; border: 1px solid var(--guest-border);
  }
  .checkout__title {
    font-size: 22px; font-weight: 400; letter-spacing: -0.02em;
    line-height: 1.15; margin: 0 0 6px; color: var(--guest-ink);
  }
  .dot-accent { color: var(--guest-accent); }
  .checkout__sub {
    font-size: 12px; color: var(--guest-ink-muted); line-height: 1.4; margin: 0;
  }

  .checkout__steps {
    padding: 0 16px; display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px;
  }
  .checkout__step {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px 14px;
    background: var(--guest-bg-deep);
    border-radius: 8px; border: 1px solid transparent;
  }
  .checkout__step--done {
    opacity: 0.55;
  }
  .checkout__step--primary {
    border-color: var(--guest-accent);
    background: var(--guest-bg-card);
  }
  .checkout__step-num {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--guest-ink);
    color: var(--guest-bg-card);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600; flex-shrink: 0; margin-top: 1px;
  }
  .checkout__step--primary .checkout__step-num {
    background: var(--guest-accent);
  }
  .checkout__step-check {
    margin-left: auto; opacity: 0.5; flex-shrink: 0; margin-top: 3px;
  }
  .checkout__step-title {
    font-size: 12px; font-weight: 500; color: var(--guest-ink);
    line-height: 1.2; margin-bottom: 2px;
  }
  .checkout__step-sub {
    font-size: 10px; color: var(--guest-ink-muted);
  }

  .checkout__cta-area {
    padding: 0 16px; display: flex; flex-direction: column; gap: 8px; align-items: center;
  }
  .checkout__btn-primary {
    width: 100%; padding: 14px;
    background: var(--user-brand-primary, var(--guest-ink));
    color: var(--guest-bg-card);
    border: none; border-radius: 8px;
    font-size: 14px; font-weight: 500; cursor: pointer; font-family: inherit;
    transition: background 150ms;
  }
  .checkout__btn-primary:hover {
    background: var(--user-brand-secondary, var(--guest-accent));
  }
  .checkout__cta-hint {
    font-size: 10px; color: var(--guest-ink-muted);
    text-align: center; margin: 0;
  }

  /* ── BAUHAUS ─────────────────────────────────────────────────────────── */
  :global([data-theme="bauhaus"]) .checkout__title {
    font-family: var(--guest-font-display); font-weight: 500; letter-spacing: -0.025em;
  }
  :global([data-theme="bauhaus"]) .checkout__step,
  :global([data-theme="bauhaus"]) .checkout__step-num,
  :global([data-theme="bauhaus"]) .checkout__btn-primary { border-radius: 0; }
  :global([data-theme="bauhaus"]) .checkout__btn-primary {
    font-family: var(--guest-font-display);
  }

  /* ── EDITORIAL ───────────────────────────────────────────────────────── */
  :global([data-theme="editorial"]) .checkout__eyebrow {
    background: transparent; border: none; padding: 0; border-radius: 0;
    color: var(--guest-ink-muted);
  }
  :global([data-theme="editorial"]) .checkout__title {
    font-family: var(--guest-font-display); font-style: italic; font-weight: 400;
    letter-spacing: -0.01em; font-size: 24px;
  }
  :global([data-theme="editorial"]) .checkout__step {
    background: transparent; border-radius: 0;
    border-bottom: 1px solid var(--guest-border); padding: 12px 0;
  }
  :global([data-theme="editorial"]) .checkout__step--primary {
    border-color: var(--guest-accent); background: transparent;
    border-left: none; border-right: none; border-top: none;
  }
  :global([data-theme="editorial"]) .checkout__step-num {
    border-radius: 0; background: transparent; color: var(--guest-accent);
    font-family: var(--guest-font-display); font-style: italic; font-size: 18px;
    width: 22px; height: auto; font-weight: 300; border: none; margin-top: 0;
    align-self: flex-start;
  }
  :global([data-theme="editorial"]) .checkout__step-title {
    font-family: var(--guest-font-display); font-style: italic; font-size: 14px;
  }
  :global([data-theme="editorial"]) .checkout__btn-primary {
    background: transparent; color: var(--user-brand-primary, var(--guest-ink));
    border: 1px solid var(--user-brand-primary, var(--guest-ink)); border-radius: 0;
    font-family: var(--guest-font-display); font-style: italic;
  }
  :global([data-theme="editorial"]) .checkout__btn-primary:hover {
    background: var(--user-brand-primary, var(--guest-ink)); color: var(--guest-bg-card);
  }

  /* ── MAISON ──────────────────────────────────────────────────────────── */
  :global([data-theme="maison"]) .checkout__eyebrow {
    background: transparent; border: none; padding: 0; border-radius: 0;
    color: var(--guest-accent); letter-spacing: 0.20em; font-family: var(--guest-font-mono);
  }
  :global([data-theme="maison"]) .checkout__title {
    font-family: var(--guest-font-display); letter-spacing: 0.08em; font-weight: 400;
  }
  :global([data-theme="maison"]) .checkout__step {
    border-radius: 0; background: var(--guest-bg-card); border: 1px solid var(--guest-border);
  }
  :global([data-theme="maison"]) .checkout__step--primary {
    border-color: var(--guest-accent); background: var(--guest-accent-soft);
  }
  :global([data-theme="maison"]) .checkout__step-num {
    border-radius: 0; background: transparent; color: var(--guest-ink-muted);
    border: 1px solid var(--guest-border);
    font-family: var(--guest-font-display); font-size: 12px; font-weight: 400;
  }
  :global([data-theme="maison"]) .checkout__step--primary .checkout__step-num {
    background: var(--guest-accent); color: var(--guest-bg-deep); border-color: var(--guest-accent);
  }
  :global([data-theme="maison"]) .checkout__step-title {
    font-family: var(--guest-font-display); letter-spacing: 0.06em;
    text-transform: uppercase; font-size: 11px;
  }
  :global([data-theme="maison"]) .checkout__btn-primary {
    background: var(--user-brand-primary, var(--guest-accent)); color: var(--guest-bg-deep);
    border-radius: 0; border: none; font-family: var(--guest-font-display);
    letter-spacing: 0.18em; text-transform: uppercase; font-size: 11px;
  }
  :global([data-theme="maison"]) .checkout__btn-primary:hover {
    background: var(--user-brand-secondary, var(--guest-accent-bright)); color: var(--guest-bg-deep);
  }
</style>
