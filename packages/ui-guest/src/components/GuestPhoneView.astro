---
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/retaha.css';
import '../styles/guest-preview.css';
import '../themes/classic/tokens.css';
import '../themes/bauhaus/tokens.css';
import '../themes/editorial/tokens.css';

import GuestHomeScreen from './GuestHomeScreen.astro';
import GuestEveScreen from './GuestEveScreen.astro';
import GuestRecsScreen from './GuestRecsScreen.astro';
import GuestServiceScreen from './GuestServiceScreen.astro';
import type { GuestTheme } from '../types/index.ts';
import { mapThemeName, resolveDataTheme } from '../types/index.ts';

interface Props {
  theme: GuestTheme;
  welcomeText?: string;
  previewMode?: boolean;
  /** Skalierung für Mini-Preview (z.B. 0.45) */
  scale?: number;
}

const {
  theme,
  welcomeText,
  previewMode = true,
  scale,
} = Astro.props;

const guestTheme = theme.guestThemeName ?? mapThemeName(theme.themeName);
const accentColor = theme.primary ?? '#FF4A82';
const dataTheme = resolveDataTheme(theme.designIdentity, guestTheme);
---

<div
  class="guest-phone-view"
  data-theme={dataTheme}
  style={`--user-brand-primary:${accentColor};--theme-accent:${accentColor};--theme-accent-hover:${accentColor};${scale ? `--preview-scale:${scale}` : ''}`}
>
  <!-- Status Bar -->
  <div class="gp-statusbar">
    <span class="gp-time">9:41</span>
    <span class="gp-icons" aria-hidden="true">
      <svg viewBox="0 0 16 12" width="13" height="10"><rect x="0" y="6" width="2" height="6" fill="currentColor"/><rect x="4" y="4" width="2" height="8" fill="currentColor"/><rect x="8" y="2" width="2" height="10" fill="currentColor"/><rect x="12" y="0" width="2" height="12" fill="currentColor"/></svg>
      <svg viewBox="0 0 24 12" width="20" height="10"><rect x="1" y="2" width="20" height="8" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="4" width="14" height="4" rx="1" fill="currentColor"/><rect x="22" y="4" width="1.5" height="4" rx=".75" fill="currentColor"/></svg>
    </span>
  </div>

  <!-- Screen Content (tabbed) -->
  <div class="gp-screens">
    <div class="gp-screens-scaler">
      <div data-screen="home"         ><GuestHomeScreen    theme={theme} welcomeText={welcomeText} previewMode={previewMode} /></div>
      <div data-screen="eve"   hidden ><GuestEveScreen     theme={theme} previewMode={previewMode} /></div>
      <div data-screen="tipps" hidden ><GuestRecsScreen    theme={theme} previewMode={previewMode} /></div>
      <div data-screen="service" hidden><GuestServiceScreen theme={theme} previewMode={previewMode} /></div>
    </div>
  </div>

  <!-- Bottom Tabs -->
  <nav class="gp-tabs" aria-label="App-Navigation">
    {[
      { key: 'home',    label: 'Start',   svg: '<path d="M3 12L12 3l9 9"/><path d="M5 10v10h5v-6h4v6h5V10"/>' },
      { key: 'eve',     label: 'Eve',     svg: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>' },
      { key: 'tipps',   label: 'Tipps',   svg: '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>' },
      { key: 'service', label: 'Service', svg: '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>' },
    ].map((tab, i) => (
      <button
        class:list={['gp-tab', { 'gp-tab--active': i === 0 }]}
        data-tab={tab.key}
        type="button"
        aria-label={tab.label}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             width="20" height="20" set:html={tab.svg} aria-hidden="true" />
        <span>{tab.label}</span>
      </button>
    ))}
  </nav>
</div>

<style is:global>
  .guest-phone-view {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    background: var(--theme-bg-secondary, #FAFAF8);
    font-family: var(--theme-font-sans, 'Space Grotesk', sans-serif);
    color: var(--theme-text-primary, #1A1A1A);
    overflow: hidden;
  }

  /* Status Bar */
  .gp-statusbar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 18px 4px; flex-shrink: 0;
    font-size: 11px; font-weight: 600;
    color: var(--theme-text-primary, #1A1A1A);
  }
  .gp-icons { display: inline-flex; gap: 5px; align-items: center; }

  /* Screens */
  .gp-screens {
    flex: 1;
    overflow: hidden;
    position: relative;
  }
  /* Scaler: rendert Content in voller Mobilgröße, dann skaliert auf --preview-scale
     Kein Effekt wenn --preview-scale nicht gesetzt (default: 1) */
  .gp-screens-scaler {
    position: absolute;
    top: 0; left: 0;
    width: calc(100% / var(--preview-scale, 1));
    transform: scale(var(--preview-scale, 1));
    transform-origin: top left;
  }

  /* Tabs */
  .gp-tabs {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--theme-border, rgba(26,26,26,.08));
    padding: 6px 0 14px;
    background: var(--theme-bg-primary, #fff);
    flex-shrink: 0;
  }
  .gp-tab {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    background: transparent; border: none; padding: 4px;
    cursor: pointer; color: var(--theme-text-muted, rgba(26,26,26,.4));
    transition: color 150ms ease; font-family: inherit;
  }
  .gp-tab--active { color: var(--theme-text-primary, #1A1A1A); }
  .gp-tab span {
    font-size: 9px; letter-spacing: 0.06em; text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }
</style>

<script>
  // Tab switching — pure JS, kein Alpine
  document.querySelectorAll<HTMLElement>('.guest-phone-view').forEach(view => {
    const tabs    = view.querySelectorAll<HTMLButtonElement>('.gp-tab');
    const screens = view.querySelectorAll<HTMLElement>('[data-screen]');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const key = tab.dataset.tab;
        tabs.forEach(t => t.classList.remove('gp-tab--active'));
        tab.classList.add('gp-tab--active');
        screens.forEach(s => { s.hidden = s.dataset.screen !== key; });
      });
    });
  });
</script>
