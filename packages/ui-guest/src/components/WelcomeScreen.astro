---
import WelcomeBauhaus   from './welcome/WelcomeBauhaus.astro';
import WelcomeEditorial from './welcome/WelcomeEditorial.astro';
import WelcomeMaison    from './welcome/WelcomeMaison.astro';

interface Props {
  hotel: any;
  hotelLogoDark: string | null;
  guest: any;
  room: any;
  settings: any;
  token: string;
  lang: string;
  hotelEnabledLangs: string[];
  greetingName: string;
  checkInLabel: string;
  checkOutLabel: string;
  nightsCount: number;
  recs: any[];
  f: any;
  wifiConfigured?: boolean;
  heroCards?: any[];
  walletAvailable?: boolean;
  roomLabel?: string;
  weather?: { temp: number; emoji: string } | null;
  persona?: 'pre_arrival' | 'in_house' | 'checking_out';
  preCheckinAvailable?: boolean;
}

const {
  hotel, hotelLogoDark, guest, room, settings, token, lang,
  hotelEnabledLangs, checkInLabel, checkOutLabel,
  f, wifiConfigured = false,
  heroCards = [], weather, persona = 'in_house',
  preCheckinAvailable = false,
} = Astro.props;

type ModuleKey = 'wifi' | 'breakfast' | 'eve' | 'service' | 'places' | 'conference' | 'checkout' | 'wallet' | 'anfahrt' | 'pre_checkin';
type StayMode = 'pre_arrival' | 'in_house' | 'checking_out';

// Module-Reihenfolge und Sichtbarkeit pro Mode
const MODULE_ORDER: Record<StayMode, ModuleKey[]> = {
  pre_arrival:  ['pre_checkin', 'anfahrt', 'breakfast', 'wifi', 'eve', 'places', 'wallet'],
  in_house:     ['wifi', 'breakfast', 'eve', 'service', 'places', 'conference', 'checkout', 'wallet'],
  checking_out: ['checkout', 'eve', 'wallet', 'breakfast', 'places'],
};
const theme = (hotel as any).design_identity ?? 'bauhaus';
const eveName = settings.eve_name || 'Eve';
const cityLine = hotel.city || '';
const hasService    = f.service    !== false && (settings.service_items?.length ?? 0) > 0;
const hasConference = f.conference !== false && (settings.conference_rooms?.length ?? 0) > 0;
const welcomeSub = settings.welcome_message_de || '';

// i18n Begrüßung pro Mode
type Lang = 'de' | 'en' | 'fr' | 'es';
const l = (['de','en','fr','es'].includes(lang) ? lang : 'de') as Lang;
const MODE_GREETING: Record<StayMode, Record<Lang, { hi: string; sub: string }>> = {
  pre_arrival: {
    de: { hi: 'Willkommen,', sub: 'Wir freuen uns auf deinen Besuch.' },
    en: { hi: 'Welcome,',    sub: 'We look forward to your stay.' },
    fr: { hi: 'Bienvenue,',  sub: 'Nous avons hâte de vous accueillir.' },
    es: { hi: 'Bienvenido,', sub: 'Esperamos con entusiasmo su visita.' },
  },
  in_house: {
    de: { hi: 'Willkommen,', sub: welcomeSub },
    en: { hi: 'Welcome,',    sub: welcomeSub },
    fr: { hi: 'Bienvenue,',  sub: welcomeSub },
    es: { hi: 'Bienvenido,', sub: welcomeSub },
  },
  checking_out: {
    de: { hi: 'Schön, dass du da warst,', sub: 'Vielen Dank für deinen Aufenthalt.' },
    en: { hi: 'Goodbye,',                  sub: 'Thank you for staying with us.' },
    fr: { hi: 'Au revoir,',                sub: 'Merci pour votre séjour.' },
    es: { hi: 'Hasta pronto,',             sub: 'Gracias por su estancia.' },
  },
};
const greeting = MODE_GREETING[persona][l];

// Kategorie-Farben — fester retaha-Satz, über alle Hotels gleich
const MODULE_COLORS: Record<string, string> = {
  pre_checkin: '#0F0E0C',
  anfahrt:     '#5B7CB0',
  wifi:        '#5B7CB0',
  breakfast:   '#C28A3E',
  eve:         '#B5664A',
  service:     '#8A6A86',
  places:      '#6E8B5E',
  conference:  '#5E6B78',
  checkout:    '#5E6B78',
  wallet:      '#5E6B78',
};

// Actions-Pool — alle möglichen Module mit Key
type ActionItem = { key: ModuleKey; num: string; icon: string; label: string; sub: string; handler: string; href?: string; color?: string };
const ACTION_POOL: ActionItem[] = [
  {
    key: 'pre_checkin',
    num: '00',
    icon: '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>',
    label: 'Voranmeldung',
    sub: 'Check-in vorbereiten',
    handler: '',
    href: `/g/${token}/pre-checkin`,
    visible: preCheckinAvailable,
  } as any,
  {
    key: 'wifi',
    num: '01',
    icon: '<path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/>',
    label: 'WLAN',
    sub: 'Sofort verbinden',
    handler: '',
    href: `/g/${token}/wifi?persona=${persona}`,
    visible: wifiConfigured,
  } as any,
  {
    key: 'anfahrt',
    num: '01',
    icon: '<polygon points="3 11 22 2 13 21 11 13 3 11"/>',
    label: 'Anfahrt',
    sub: 'Route planen',
    handler: '',
    href: `/g/${token}/anfahrt`,
  } as any,
  {
    key: 'breakfast',
    num: '02',
    icon: '<path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>',
    label: 'Frühstück',
    sub: persona === 'pre_arrival' ? 'Zeiten & Infos' : 'Slot buchen',
    handler: '',
    href: persona === 'pre_arrival' ? `/g/${token}/fruehstueck` : `/g/${token}/breakfast?persona=${persona}`,
  } as any,
  {
    key: 'eve',
    num: '03',
    icon: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
    label: eveName,
    sub: '24/7 Concierge',
    handler: "eveOpen = true; eveSeenBefore = true; try { localStorage.setItem('retaha_eve_seen', '1') } catch(_) {}; eveMaybeWelcome()",
    visible: f.eve !== false,
  } as any,
  {
    key: 'service',
    num: '04',
    icon: '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/>',
    label: 'Service',
    sub: 'Anfrage senden',
    handler: "openSheet('service')",
    visible: hasService,
  } as any,
  {
    key: 'places',
    num: '05',
    icon: '<circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>',
    label: 'Tipps',
    sub: cityLine || 'Entdecken',
    handler: `(() => { const _p = new URLSearchParams(window.location.search).get('persona') || 'in_house'; window.location.href = '/g/${token}/recommendations?persona='+_p; })()`,
    visible: f.recommendations !== false,
  } as any,
  {
    key: 'conference',
    num: '06',
    icon: '<rect x="3" y="7" width="18" height="13"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>',
    label: 'Konferenz',
    sub: 'Raum buchen',
    handler: "openSheet('conference')",
    visible: hasConference,
  } as any,
  {
    key: 'checkout',
    num: '07',
    icon: '<path d="M5 12L10 17L19 7"/>',
    label: 'Checkout',
    sub: 'Abreise vorbereiten',
    handler: `window.location='/g/${token}/checkout'`,
    visible: f.self_checkout !== false,
  } as any,
];

// 1. Feature-Toggle-Filter (hotel_settings)
// 2. Mode-Filter (Reihenfolge aus MODULE_ORDER)
// 3. Umnummerieren + Kategorie-Farbe
const featureFiltered = ACTION_POOL.filter((a: any) => a.visible !== false);
const actions = MODULE_ORDER[persona]
  .map(key => featureFiltered.find(a => a.key === key))
  .filter(Boolean)
  .map((a, i) => ({ ...a!, num: String(i + 1).padStart(2, '0'), color: MODULE_COLORS[a!.key] ?? '#5B7CB0' }));

const sharedProps = {
  hotel, hotelLogoDark, guest, room, token, lang,
  hotelEnabledLangs, checkInLabel, checkOutLabel,
  heroCards, f, actions, weather, persona, greeting,
  preCheckinAvailable,
};
---

{theme === 'bauhaus'   && <WelcomeBauhaus   {...sharedProps} />}
{theme === 'editorial' && <WelcomeEditorial {...sharedProps} />}
{theme === 'maison'    && <WelcomeMaison    {...sharedProps} />}
{(theme !== 'bauhaus' && theme !== 'editorial' && theme !== 'maison') && (
  <WelcomeBauhaus {...sharedProps} />
)}
