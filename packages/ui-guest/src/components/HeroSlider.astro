---
interface Props {
  cards: any[];
  language: string;
}
const { cards, language } = Astro.props;

function t(field: any, fallback = ''): string {
  if (!field) return fallback;
  return field[language] ?? field.de ?? fallback;
}

function getHref(card: any): string {
  if (card.card_type === 'phone') return `tel:${card.action_target}`;
  if (card.card_type === 'email') return `mailto:${card.action_target}`;
  if (card.card_type === 'external_link') return card.action_target;
  if (card.card_type === 'internal_action') return `#${card.action_target}`;
  return '#';
}
---

{cards && cards.length > 0 && (
  <section class="hero-slider">
    <div class="hero-slider__track">
      {cards.map((card: any) => (
        <a
          class={`hero-slider__card ${card.card_class ?? ''}`}
          href={getHref(card)}
          data-card-type={card.card_type}
        >
          {card.image_url && (
            <div class="hero-slider__image">
              <img
                src={card.image_url}
                alt={t(card.title_i18n, card.title_de ?? '')}
                loading="lazy"
              />
            </div>
          )}
          <div class="hero-slider__body">
            {t(card.eyebrow_i18n, card.eyebrow_de ?? '') && (
              <span class="hero-slider__eyebrow">{t(card.eyebrow_i18n, card.eyebrow_de ?? '')}</span>
            )}
            <h3 class="hero-slider__title">{t(card.title_i18n, card.title_de ?? '')}</h3>
            {t(card.subtitle_i18n, card.subtitle_de ?? '') && (
              <p class="hero-slider__sub">{t(card.subtitle_i18n, card.subtitle_de ?? '')}</p>
            )}
            {t(card.cta_i18n, card.cta_de ?? '') && (
              <span class="hero-slider__cta">{t(card.cta_i18n, card.cta_de ?? '')} →</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .hero-slider {
    margin: 16px 0;
    overflow: hidden;
  }

  .hero-slider__track {
    display: flex;
    gap: 12px;
    padding: 4px 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .hero-slider__track::-webkit-scrollbar { display: none; }

  .hero-slider__card {
    flex: 0 0 78%;
    text-decoration: none;
    color: inherit;
    scroll-snap-align: start;
    background: var(--guest-bg-card);
    border: 1px solid var(--guest-border);
    border-radius: var(--guest-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 200ms ease;
  }
  .hero-slider__card:active { opacity: 0.8; }

  .hero-slider__image {
    aspect-ratio: 4/3;
    overflow: hidden;
    flex-shrink: 0;
  }
  .hero-slider__image img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-slider__body {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .hero-slider__eyebrow {
    font-family: var(--guest-font-mono);
    font-size: 9px;
    letter-spacing: var(--guest-label-tracking);
    text-transform: var(--guest-label-transform);
    color: var(--guest-ink-muted);
    display: inline-block;
    margin-bottom: 2px;
  }

  .hero-slider__title {
    font-family: var(--guest-font-display);
    font-weight: var(--guest-display-weight);
    font-style: var(--guest-display-style);
    letter-spacing: var(--guest-display-tracking);
    font-size: 18px;
    line-height: 1.2;
    margin: 0;
    color: var(--guest-ink);
  }

  .hero-slider__sub {
    font-size: 12px;
    color: var(--guest-ink-muted);
    line-height: 1.4;
    margin: 0;
  }

  .hero-slider__cta {
    font-family: var(--guest-font-mono);
    font-size: 10px;
    letter-spacing: var(--guest-label-tracking);
    text-transform: var(--guest-label-transform);
    color: var(--guest-accent);
    margin-top: auto;
    padding-top: 8px;
    display: block;
  }

  /* ── BAUHAUS — yellow eyebrow chip, translateY-lift on hover ── */
  :global([data-theme="bauhaus"]) .hero-slider__card:hover {
    transform: translateY(-2px);
    border-color: var(--guest-hover);
  }
  :global([data-theme="bauhaus"]) .hero-slider__eyebrow {
    background: var(--guest-hover);
    color: var(--guest-ink);
    padding: 3px 8px;
    border-radius: var(--guest-radius-sm);
  }

  /* ── EDITORIAL — magazine: borderless sides, translateX-shift hover ── */
  :global([data-theme="editorial"]) .hero-slider__card {
    background: transparent;
    border-left: none;
    border-right: none;
    border-top: none;
    border-radius: 0;
    border-bottom: 1px solid var(--guest-border);
  }
  :global([data-theme="editorial"]) .hero-slider__eyebrow {
    color: var(--guest-accent);
  }
  :global([data-theme="editorial"]) .hero-slider__card:hover {
    transform: translateX(4px);
  }

  /* ── MAISON — gold border, centered, uppercase title ── */
  :global([data-theme="maison"]) .hero-slider__card {
    border-color: var(--guest-accent);
    text-align: center;
  }
  :global([data-theme="maison"]) .hero-slider__eyebrow {
    color: var(--guest-accent);
    letter-spacing: 0.2em;
  }
  :global([data-theme="maison"]) .hero-slider__title {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  :global([data-theme="maison"]) .hero-slider__cta {
    color: var(--guest-accent);
  }
  :global([data-theme="maison"]) .hero-slider__cta::before {
    content: '◆ ';
    font-size: 8px;
  }
</style>
