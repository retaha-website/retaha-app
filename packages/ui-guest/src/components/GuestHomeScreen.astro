---
import type { GuestTheme } from '../types/index.ts';
import HeroSlider from './HeroSlider.astro';

interface Props {
  theme: GuestTheme;
  welcomeText?: string;
  previewMode?: boolean;
}

const { theme } = Astro.props;

const demoHeroCards = [
  {
    id: 'demo-1',
    card_type: 'info',
    action_target: '',
    title_i18n: { de: 'Spa & Wellness', en: 'Spa & Wellness' },
    subtitle_i18n: { de: 'Täglich 8–22 Uhr geöffnet', en: 'Open daily 8am–10pm' },
    eyebrow_i18n: { de: 'Entspannung', en: 'Relaxation' },
    cta_i18n: { de: 'Termin buchen', en: 'Book now' },
    image_url: null,
    card_class: '',
  },
  {
    id: 'demo-2',
    card_type: 'info',
    action_target: '',
    title_i18n: { de: 'Restaurant & Bar', en: 'Restaurant & Bar' },
    subtitle_i18n: { de: 'Kulinarische Highlights inklusive', en: 'Culinary highlights included' },
    eyebrow_i18n: { de: 'Genuss', en: 'Dining' },
    cta_i18n: { de: 'Mehr erfahren', en: 'Learn more' },
    image_url: null,
    card_class: '',
  },
];
// Wenn kein Hotel-Hintergrundbild: anthrazit-Fallback damit kein Broken-Image
const heroBgStyle = theme.heroBackground
  ? `background-image:url('${theme.heroBackground}')`
  : 'background-image:none; background-color:#1A1A1A';
---

<!-- Gleiche HTML-Struktur wie gate-hero in [token].astro -->
<div class="gate-guest-preview">

  <!-- HERO -->
  <section class="gate-hero">
    <div class="gate-hero-bg" style={heroBgStyle}></div>
    <div class="gate-hero-overlay"></div>
    <div class="gate-hero-content">

      <div class="gate-hero-top">
        <div class="gate-hero-tag">
          <span class="gate-hero-tag-shapes">
            <span class="circle"></span>
            <span class="square"></span>
            <span class="triangle"></span>
          </span>
          <span>Musterstadt</span>
        </div>
        <div class="lang-switcher">
          <span class="lang-btn active">DE</span>
        </div>
      </div>

      {theme.logoDarkUrl ? (
        <img class="gate-hero-logo" src={theme.logoDarkUrl} alt={theme.hotelName ?? ''} />
      ) : theme.logoUrl ? (
        <img class="gate-hero-logo gate-hero-logo--invert" src={theme.logoUrl} alt={theme.hotelName ?? ''} />
      ) : (
        <img class="gate-hero-logo" src="/specht-anthrazit.svg" alt={theme.hotelName ?? 'Hotel'} />
      )}

      <div class="gate-hero-welcome">
        <div class="gate-hero-kicker">Herzlich willkommen zurück</div>
        <h1 class="gate-hero-greeting">
          Hallo, Maximilian<span class="dot">.</span>
        </h1>
        <p class="gate-hero-sub">Schön, dass du da bist.</p>
      </div>

      <div class="gate-hero-stay">
        <div class="gate-hero-stay-block">
          <div class="label">Zimmer</div>
          <div class="value">204 · Suite</div>
        </div>
        <div class="gate-hero-stay-block">
          <div class="label">Aufenthalt</div>
          <div class="value">Heute – Morgen · 1 Nacht</div>
        </div>
      </div>

    </div>
  </section>

  <!-- CONCIERGE CARD -->
  <div class="gate-recommend-card">
    <div class="gate-recommend-card-left">
      <div class="gate-recommend-eyebrow">das Team empfiehlt heute</div>
      <p class="gate-recommend-text">Wir freuen uns, Sie begrüßen zu dürfen.</p>
    </div>
    <div class="gate-recommend-weather">
      <span class="weather-readout">
        <span class="weather-readout-temp">21°</span>
        <span class="weather-readout-label">Sonnig</span>
      </span>
    </div>
  </div>

  <!-- HERO SLIDER -->
  <HeroSlider cards={demoHeroCards} language="de" />

  <!-- ACTION TILES -->
  <section class="gate-actions">
    <div class="gate-actions-head">
      <div class="gate-actions-eyebrow">Was brauchen Sie?</div>
      <div class="gate-actions-time">Morgens · Heute</div>
    </div>
    <div class="gate-grid">

      <div class="gate-tile">
        <span class="gate-tile-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 8.5a16 16 0 0 1 20 0"/>
            <path d="M5 12a11 11 0 0 1 14 0"/>
            <path d="M8.5 15.5a6 6 0 0 1 7 0"/>
            <circle cx="12" cy="19" r="1" fill="currentColor"/>
          </svg>
        </span>
        <span class="gate-tile-label">WLAN</span>
        <span class="gate-tile-sub">Passwort anzeigen</span>
      </div>

      <div class="gate-tile">
        <span class="gate-tile-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <circle cx="9" cy="10" r="2"/>
            <circle cx="15" cy="10" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </span>
        <span class="gate-tile-label">{theme.eveName ?? 'Eve'}</span>
        <span class="gate-tile-sub">KI-Concierge</span>
      </div>

      <div class="gate-tile">
        <span class="gate-tile-badge green">inkl.</span>
        <span class="gate-tile-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <polygon points="12,5 19,18 5,18"/>
          </svg>
        </span>
        <span class="gate-tile-label">Frühstück</span>
        <span class="gate-tile-sub">Slot buchen</span>
      </div>

      <div class="gate-tile">
        <span class="gate-tile-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <circle cx="12" cy="12" r="9"/>
          </svg>
        </span>
        <span class="gate-tile-label">Service</span>
        <span class="gate-tile-sub">Anfrage senden</span>
      </div>

    </div>
  </section>

</div>

<style is:global>
  /* Preview-Wrapper: gleiche Body-Basis wie .gate-guest */
  .gate-guest-preview {
    background: var(--color-white, #FFFFFF);
    min-height: 100%;
    font-family: var(--font-inter, 'Inter Tight', system-ui, sans-serif);
    color: var(--color-anthrazit, #1A1A1A);
    overflow-x: hidden;
  }

  /* Lang-Switcher (Vorschau: nur statisch) */
  .gate-guest-preview .lang-switcher {
    display: flex; gap: 4px;
  }
  .gate-guest-preview .lang-btn {
    font-family: var(--font-georgia, Georgia, serif);
    font-style: italic; font-size: 12px;
    color: rgba(255,255,255,0.6);
    padding: 2px 6px;
    border-radius: 3px;
  }
  .gate-guest-preview .lang-btn.active {
    background: rgba(255,255,255,0.18);
    color: #fff;
  }

  /* Weather readout (kein WeatherIcon-Component in Vorschau) */
  .gate-guest-preview .weather-readout {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
  }
  .gate-guest-preview .weather-readout-temp {
    font-size: 22px; font-weight: 300; line-height: 1;
    color: var(--color-anthrazit, #1A1A1A);
  }
  .gate-guest-preview .weather-readout-label {
    font-family: var(--font-georgia, Georgia, serif);
    font-style: italic; font-size: 11px;
    color: var(--color-anthrazit-60, rgba(26,26,26,0.6));
  }
</style>
