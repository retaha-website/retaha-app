---
import type { GuestTheme } from '../types/index.ts';

interface Props {
  theme: GuestTheme;
  tier?: 'bronze' | 'silver' | 'gold' | 'platinum';
  points?: number;
  nextTierAt?: number;
  benefits?: string[];
  previewMode?: boolean;
}

const {
  theme,
  tier = 'silver',
  points = 340,
  nextTierAt = 500,
  benefits = ['Frühes Check-in (ab 12:00)', 'Spätes Check-out (bis 13:00)', 'Willkommensgetränk'],
  previewMode = true,
} = Astro.props;

const TIER_LABELS: Record<string, string> = {
  bronze: 'Bronze',
  silver: 'Silber',
  gold: 'Gold',
  platinum: 'Platin',
};

const progressPct = Math.min(100, Math.round((points / nextTierAt) * 100));
const nextTierLabel = tier === 'bronze' ? 'Silber' : tier === 'silver' ? 'Gold' : tier === 'gold' ? 'Platin' : '—';
---

<div class="loyalty">
  <section class="loyalty__hero">
    <div class="loyalty__eyebrow">Dein Status</div>
    <h1 class="loyalty__tier">{TIER_LABELS[tier] ?? tier}<span class="dot-accent">.</span></h1>
    <p class="loyalty__pts">{points} Punkte</p>
  </section>

  {tier !== 'platinum' && (
    <section class="loyalty__progress">
      <div class="loyalty__progress-bar-wrap">
        <div class="loyalty__progress-bar" style={`width:${progressPct}%`}></div>
      </div>
      <p class="loyalty__progress-label">
        Noch {nextTierAt - points} Punkte bis {nextTierLabel}
      </p>
    </section>
  )}

  <section class="loyalty__benefits">
    <div class="loyalty__section-label">Deine Vorteile</div>
    <ul class="loyalty__list">
      {benefits.map(b => (
        <li class="loyalty__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
            <path d="M5 12 L10 17 L19 7"/>
          </svg>
          {b}
        </li>
      ))}
    </ul>
  </section>

  <section class="loyalty__history">
    <div class="loyalty__section-label">Punkte-Verlauf</div>
    <div class="loyalty__history-item">
      <span>Aufenthalt gebucht</span>
      <span class="loyalty__history-pts">+50</span>
    </div>
    <div class="loyalty__history-item">
      <span>Frühstück reserviert</span>
      <span class="loyalty__history-pts">+10</span>
    </div>
    <div class="loyalty__history-item">
      <span>Bewertung hinterlassen</span>
      <span class="loyalty__history-pts">+20</span>
    </div>
  </section>
</div>

<style>
  .loyalty {
    display: flex; flex-direction: column; gap: 0;
    padding: 8px 0 24px;
    font-family: var(--guest-font-body);
    overflow-y: auto; height: 100%; box-sizing: border-box;
  }
  .loyalty__hero {
    padding: 20px 16px 16px;
    background: var(--guest-ink);
    color: var(--guest-bg-card);
    margin-bottom: 16px;
  }
  .loyalty__eyebrow {
    font-family: var(--guest-font-mono);
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    opacity: 0.55; margin-bottom: 8px;
  }
  .loyalty__tier {
    font-size: 32px; font-weight: 400; letter-spacing: -0.03em;
    margin: 0 0 4px; line-height: 1;
  }
  .dot-accent { color: var(--guest-accent); }
  .loyalty__pts {
    font-family: var(--guest-font-mono);
    font-size: 11px; letter-spacing: 0.08em; opacity: 0.7; margin: 0;
  }

  .loyalty__progress {
    padding: 0 16px 16px;
  }
  .loyalty__progress-bar-wrap {
    height: 6px; background: var(--guest-bg-deep);
    border-radius: 3px; overflow: hidden; margin-bottom: 6px;
  }
  .loyalty__progress-bar {
    height: 100%; background: var(--guest-accent);
    border-radius: 3px; transition: width 0.5s ease;
  }
  .loyalty__progress-label {
    font-size: 10px; color: var(--guest-ink-muted);
    font-family: var(--guest-font-mono);
    letter-spacing: 0.04em; margin: 0;
  }

  .loyalty__benefits, .loyalty__history {
    padding: 0 16px 16px;
  }
  .loyalty__section-label {
    font-family: var(--guest-font-mono);
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--guest-ink-muted);
    padding-bottom: 8px; margin-bottom: 8px;
    border-bottom: 1px solid var(--guest-border);
  }
  .loyalty__list {
    list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;
  }
  .loyalty__item {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: var(--guest-ink);
  }
  .loyalty__item svg { color: var(--guest-accent); flex-shrink: 0; }

  .loyalty__history-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--guest-border);
    font-size: 12px; color: var(--guest-ink);
  }
  .loyalty__history-pts {
    font-family: var(--guest-font-mono);
    font-size: 11px; color: var(--guest-accent); font-weight: 500;
  }

  /* ── BAUHAUS ─────────────────────────────────────────────────────────── */
  :global([data-theme="bauhaus"]) .loyalty__tier {
    font-family: var(--guest-font-display); font-weight: 500; letter-spacing: -0.04em;
  }

  /* ── EDITORIAL ───────────────────────────────────────────────────────── */
  :global([data-theme="editorial"]) .loyalty__hero {
    background: var(--guest-bg-deep); color: var(--guest-ink);
    border-bottom: 2px solid var(--guest-accent);
  }
  :global([data-theme="editorial"]) .loyalty__eyebrow {
    color: var(--guest-ink-muted); opacity: 1; font-family: var(--guest-font-mono); letter-spacing: 0.18em;
  }
  :global([data-theme="editorial"]) .loyalty__tier {
    font-family: var(--guest-font-display); font-style: italic; font-weight: 400;
    font-size: 36px; letter-spacing: -0.02em; color: var(--guest-ink);
  }
  :global([data-theme="editorial"]) .loyalty__pts {
    font-family: var(--guest-font-mono); color: var(--guest-accent); opacity: 1;
  }
  :global([data-theme="editorial"]) .loyalty__section-label {
    font-family: var(--guest-font-mono); letter-spacing: 0.18em;
  }
  :global([data-theme="editorial"]) .loyalty__item {
    font-family: var(--guest-font-body); font-style: italic;
  }
  :global([data-theme="editorial"]) .loyalty__history-item {
    font-family: var(--guest-font-body);
  }

  /* ── MAISON ──────────────────────────────────────────────────────────── */
  :global([data-theme="maison"]) .loyalty__hero {
    text-align: center; background: var(--guest-bg-deep);
    border-bottom: 1px solid var(--guest-accent);
  }
  :global([data-theme="maison"]) .loyalty__eyebrow {
    font-family: var(--guest-font-mono); letter-spacing: 0.22em; opacity: 1;
    color: var(--guest-accent);
  }
  :global([data-theme="maison"]) .loyalty__tier {
    font-family: var(--guest-font-display); letter-spacing: 0.12em;
    text-transform: uppercase; font-weight: 400; font-size: 28px;
  }
  :global([data-theme="maison"]) .loyalty__pts {
    font-family: var(--guest-font-display); font-style: italic;
    color: var(--guest-ink-muted); opacity: 1;
  }
  :global([data-theme="maison"]) .loyalty__progress-bar-wrap { border-radius: 0; }
  :global([data-theme="maison"]) .loyalty__progress-bar { border-radius: 0; }
  :global([data-theme="maison"]) .loyalty__section-label {
    font-family: var(--guest-font-mono); letter-spacing: 0.22em; color: var(--guest-accent);
  }
  :global([data-theme="maison"]) .loyalty__item { font-family: var(--guest-font-body); }
  :global([data-theme="maison"]) .loyalty__item svg { display: none; }
  :global([data-theme="maison"]) .loyalty__item::before {
    content: '◆'; color: var(--guest-accent); font-size: 8px; flex-shrink: 0;
  }
  :global([data-theme="maison"]) .loyalty__history-item { font-family: var(--guest-font-body); }
</style>
