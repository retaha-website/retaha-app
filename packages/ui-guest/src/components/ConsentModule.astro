---
// ConsentModule — DSGVO Consent, Bauhaus-Design (prototype 09.06.2026)
//
// Backwards-compat: same localStorage key pattern as CookieBanner
//   retaha_consent_v{POLICY_VERSION}
// Consent types: 'all' | 'necessary' | 'custom'
// After decision: shows shield DS-chip (bottom left)
//
// Alpine integration: requires consentOpen + consentGiven in parent x-data

interface Props {
  stayToken?: string;
  privacyHref?: string;
}
const { stayToken, privacyHref } = Astro.props;
const resolvedPrivacyHref = privacyHref ?? (stayToken ? `/g/${stayToken}/datenschutz` : '/g/datenschutz');
const POLICY_VERSION = '2026-06-01';
---

<!-- Consent Modal -->
<div
  class="cm-card"
  x-show="consentOpen"
  x-transition:enter="cm-enter"
  x-transition:enter-start="cm-enter-start"
  x-transition:enter-end="cm-enter-end"
  x-transition:leave="cm-leave"
  x-transition:leave-start="cm-leave-start"
  x-transition:leave-end="cm-leave-end"
  data-policy={POLICY_VERSION}
  data-token={stayToken ?? ''}
  data-privacy={resolvedPrivacyHref}
  style="display:none"
>
  <div class="cm-eyebrow">
    <span class="cm-pulse-dot" aria-hidden="true"></span>
    Consent-Modul · DSGVO
  </div>
  <h3 class="cm-title">Ihre Daten. Ihre Wahl<span class="cm-dot">.</span></h3>
  <p class="cm-body">
    Wir nutzen notwendige Funktionen für Ihren Aufenthalt.
    Statistik &amp; Komfort nur, wenn Sie zustimmen — jederzeit änderbar.
  </p>

  <!-- Expandable category toggles -->
  <div class="cm-cats" x-show="cmExpanded" x-cloak>
    <div class="cm-cat">
      <div class="cm-cat__info">
        <strong>Notwendig</strong>
        <span>Stay-Daten · Sprache · Sitzung</span>
      </div>
      <button class="cm-sw cm-sw--locked" disabled aria-label="Immer aktiv"></button>
    </div>
    <div class="cm-cat">
      <div class="cm-cat__info">
        <strong>Statistik</strong>
        <span>Anonyme Nutzungsanalyse</span>
      </div>
      <button
        class="cm-sw"
        :class="{ 'cm-sw--on': cmStats }"
        @click="cmStats = !cmStats"
        :aria-label="cmStats ? 'Statistik deaktivieren' : 'Statistik aktivieren'"
      ></button>
    </div>
    <div class="cm-cat">
      <div class="cm-cat__info">
        <strong>Komfort</strong>
        <span>Wetter · Karten · Empfehlungen</span>
      </div>
      <button
        class="cm-sw"
        :class="{ 'cm-sw--on': cmComfort }"
        @click="cmComfort = !cmComfort"
        :aria-label="cmComfort ? 'Komfort deaktivieren' : 'Komfort aktivieren'"
      ></button>
    </div>
  </div>

  <div class="cm-btns">
    <button type="button" class="cm-btn cm-btn--ghost" @click="cmDecide('necessary')">
      Nur notwendige
    </button>
    <button type="button" class="cm-btn cm-btn--prime" @click="cmDecide('all')">
      Alle akzeptieren
    </button>
  </div>
  <div class="cm-more">
    <button type="button" @click="cmExpanded = !cmExpanded">
      Auswahl anpassen
    </button>
  </div>
</div>

<!-- DS Shield Chip (bottom left, shows after consent) -->
<button
  class="cm-shield"
  x-show="consentGiven && !consentOpen && !eveOpen && !activeSheet"
  @click="consentOpen = true"
  aria-label="Datenschutz-Einstellungen"
  style="display:none"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
  </svg>
</button>

<style is:global>
  /* Consent card */
  .cm-card {
    position: fixed;
    left: 14px; right: 14px; bottom: 14px;
    background: #FFFFFF;
    border: 1.5px solid #0A0A0A;
    border-radius: 12px;
    padding: 16px 16px 14px;
    z-index: 200;
    box-shadow: 0 16px 40px rgba(0,0,0,.2);
    font-family: 'Space Grotesk', sans-serif;
    color: #0A0A0A;
    max-width: 460px;
    margin: 0 auto;
  }
  @media (min-width: 500px) {
    .cm-card { left: auto; right: 20px; width: 380px; }
  }

  /* Transitions */
  .cm-enter  { transition: transform 0.45s cubic-bezier(.32,.72,.32,1), opacity 0.3s; }
  .cm-enter-start { transform: translateY(135%); opacity: 0; }
  .cm-enter-end   { transform: none; opacity: 1; }
  .cm-leave  { transition: transform 0.3s ease-in, opacity 0.25s ease-in; }
  .cm-leave-start { transform: none; opacity: 1; }
  .cm-leave-end   { transform: translateY(135%); opacity: 0; }

  .cm-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5px; letter-spacing: 0.16em;
    text-transform: uppercase; color: #6B6B66;
    display: flex; align-items: center; gap: 7px;
  }
  .cm-pulse-dot {
    width: 6px; height: 6px;
    background: var(--accent, #FF4A82); border-radius: 50%;
    display: inline-block; flex-shrink: 0;
    animation: cm-pulse 2.4s infinite;
  }
  @keyframes cm-pulse {
    0%,100% { opacity: 1; } 50% { opacity: 0.35; }
  }
  .cm-title {
    font-size: 17px; font-weight: 700; margin: 8px 0 0;
    letter-spacing: -0.01em;
  }
  .cm-dot { color: var(--accent, #FF4A82); }
  .cm-body {
    font-size: 11.5px; line-height: 1.55;
    color: #6B6B66; margin: 6px 0 0;
  }

  /* Toggles */
  .cm-cats {
    margin-top: 12px; border-top: 1px solid #E3E1DA;
  }
  .cm-cat {
    display: flex; justify-content: space-between; align-items: center;
    padding: 11px 0; border-bottom: 1px solid #E3E1DA;
  }
  .cm-cat__info strong { font-size: 12.5px; font-weight: 500; display: block; }
  .cm-cat__info span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; letter-spacing: 0.08em;
    text-transform: uppercase; color: #A8A8A2;
    margin-top: 2px; display: block;
  }
  .cm-sw {
    width: 42px; height: 23px; border-radius: 12px;
    border: 1.5px solid #0A0A0A; background: #FFFFFF;
    position: relative; cursor: pointer;
    transition: background 0.2s; flex-shrink: 0; padding: 0;
  }
  .cm-sw::after {
    content: ''; position: absolute;
    top: 2.5px; left: 2.5px;
    width: 14px; height: 14px;
    border-radius: 50%; background: #0A0A0A;
    transition: transform 0.2s;
  }
  .cm-sw--on { background: var(--accent, #FFE600); }
  .cm-sw--on::after { transform: translateX(19px); }
  .cm-sw--locked {
    background: #5C9070; border-color: #5C9070; cursor: default;
  }
  .cm-sw--locked::after { background: #fff; transform: translateX(19px); }

  /* Buttons */
  .cm-btns { display: flex; gap: 8px; margin-top: 14px; }
  .cm-btn {
    flex: 1; border-radius: 12px; padding: 13px 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; letter-spacing: 0.07em; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .cm-btn--ghost {
    background: transparent; border: 1px solid #E3E1DA; color: #0A0A0A;
  }
  .cm-btn--ghost:hover { border-color: #0A0A0A; }
  .cm-btn--prime {
    flex: 1.35; background: #0A0A0A; color: #fff; border: none;
  }
  .cm-btn--prime:hover { background: var(--accent, #FF4A82); }

  .cm-more {
    margin-top: 11px; text-align: center;
  }
  .cm-more button {
    background: none; border: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5px; letter-spacing: 0.12em;
    text-transform: uppercase; color: #6B6B66;
    cursor: pointer; border-bottom: 1px solid #E3E1DA; padding-bottom: 2px;
  }
  .cm-more button:hover { color: #0A0A0A; border-color: #0A0A0A; }

  /* Shield DS chip */
  .cm-shield {
    position: fixed; bottom: 24px; left: 20px;
    width: 40px; height: 40px; border-radius: 14px;
    border: 1px solid #E3E1DA; background: #FFFFFF;
    display: grid; place-items: center;
    cursor: pointer; z-index: 80;
    transition: all 0.2s; padding: 0;
  }
  .cm-shield:hover { background: var(--hover, #FFE600); border-color: var(--hover, #FFE600); }
  .cm-shield svg { width: 17px; height: 17px; }
</style>
