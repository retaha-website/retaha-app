---
/**
 * LangSwitcher — Sprach-Selector mit Globe-Icon Trigger + Full-Screen 2x6 Grid-Overlay
 *
 * CSS-Quelle: lang_v4_grid.html (Sprint-I Prototyp, vom User gewaehlt aus 5 Varianten)
 *
 * Anforderungen erfuellt:
 *   - 11 Sprachen: DE, EN, TR, FR, ES, IT, PT, NL, RU, AR, ZH
 *   - Native Sprach-Namen (Deutsch, Türkçe, العربية, 中文)
 *   - 2-spaltiges Grid (mehr Atem als 3-spaltig auf Mobile)
 *   - Pink-Border + Pink-Code auf aktiver Sprache
 *   - Bei Klick: ruft globales Alpine setLang(code) auf
 *
 * Verwendung (in der Page):
 *   <LangSwitcher position="header-mobile" />
 *
 * Voraussetzung in Page:
 *   x-data auf Eltern-Element mit:
 *     - currentLang: 'de'|'en'|...
 *     - setLang(code: string)
 *     - langOverlayOpen: boolean
 *
 * Wiederverwendbar in: auth (login), dashboard (header), backoffice (header)
 */

interface Props {
  position?: 'header-mobile' | 'header-desktop' | 'inline';
  /** Optional: light/dark Trigger-Style (default: light fuer Anthrazit-Bg) */
  variant?: 'light' | 'dark';
}

const { position = 'header-mobile', variant = 'light' } = Astro.props;

const LANGUAGES = [
  { code: 'de', codeUpper: 'DE', name: 'Deutsch' },
  { code: 'en', codeUpper: 'EN', name: 'English' },
  { code: 'tr', codeUpper: 'TR', name: 'Türkçe' },
  { code: 'fr', codeUpper: 'FR', name: 'Français' },
  { code: 'es', codeUpper: 'ES', name: 'Español' },
  { code: 'it', codeUpper: 'IT', name: 'Italiano' },
  { code: 'pt', codeUpper: 'PT', name: 'Português' },
  { code: 'nl', codeUpper: 'NL', name: 'Nederlands' },
  { code: 'ru', codeUpper: 'RU', name: 'Русский' },
  { code: 'ar', codeUpper: 'AR', name: 'العربية' },
  { code: 'zh', codeUpper: 'ZH', name: '中文' },
];
---

<!-- TRIGGER: Globe-Icon + aktueller Sprach-Code -->
<button
  type="button"
  class={`lang-trigger lang-trigger--${variant} lang-trigger--${position}`}
  @click="langOverlayOpen = true"
  aria-label="Sprache waehlen"
>
  <svg class="lang-trigger__globe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <circle cx="12" cy="12" r="10"/>
    <line x1="2" y1="12" x2="22" y2="12"/>
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
  </svg>
  <span class="lang-trigger__code" x-text="(currentLang || 'de').toUpperCase()"></span>
</button>

<!-- OVERLAY: Full-Screen mit 2x6 Grid -->
<div
  class="lang-overlay"
  x-show="langOverlayOpen"
  x-cloak
  x-transition:enter="lang-overlay--transition"
  x-transition:enter-start="lang-overlay--enter-start"
  x-transition:enter-end="lang-overlay--enter-end"
  x-transition:leave="lang-overlay--transition"
  x-transition:leave-start="lang-overlay--enter-end"
  x-transition:leave-end="lang-overlay--enter-start"
  @keydown.escape.window="langOverlayOpen = false"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lang-overlay-title"
>
  <div class="lang-overlay__header">
    <h2 class="lang-overlay__title" id="lang-overlay-title">
      <span x-text="t('lang_select_title') || 'Sprache wählen'"></span><span class="lang-overlay__dot">.</span>
    </h2>
    <button
      type="button"
      class="lang-overlay__close"
      @click="langOverlayOpen = false"
      aria-label="Schliessen"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>
  </div>

  <p class="lang-overlay__eyebrow">— sprachen verfügbar —</p>

  <div class="lang-grid">
    {LANGUAGES.map((lang) => (
      <button
        type="button"
        class="lang-tile"
        data-lang={lang.code}
        x-bind:class={`{ 'is-active': currentLang === '${lang.code}' }`}
        x-on:click={`setLang('${lang.code}'); langOverlayOpen = false`}
      >
        <span class="lang-tile__code">{lang.codeUpper}</span>
        <span class="lang-tile__name">{lang.name}</span>
      </button>
    ))}
  </div>
</div>

<style>
  /* ────────────────────────────────────────────────────────────
     TRIGGER (Globe-Icon + Sprach-Code)
     1:1 aus lang_v4_grid.html, leichte Variante fuer light/dark
     ──────────────────────────────────────────────────────────── */
  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px 8px 10px;
    border-radius: 99px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 200ms ease;
    min-height: 36px;
  }
  .lang-trigger--light {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #FFFFFF;
  }
  .lang-trigger--light:active {
    transform: scale(0.96);
    background: rgba(255, 255, 255, 0.12);
  }
  .lang-trigger--dark {
    background: rgba(26, 26, 26, 0.04);
    border: 1px solid rgba(26, 26, 26, 0.12);
    color: #1A1A1A;
  }
  .lang-trigger--dark:active {
    transform: scale(0.96);
    background: rgba(26, 26, 26, 0.08);
  }
  .lang-trigger:focus-visible {
    outline: 2px solid #FF4A82;
    outline-offset: 2px;
  }
  .lang-trigger__globe {
    width: 16px;
    height: 16px;
    color: #FF4A82;
    flex-shrink: 0;
  }
  .lang-trigger__code {
    font-weight: 500;
  }

  /* ────────────────────────────────────────────────────────────
     OVERLAY (Full-Screen Anthrazit)
     ──────────────────────────────────────────────────────────── */
  .lang-overlay {
    position: fixed;
    inset: 0;
    background: #1A1A1A;
    z-index: 9999;
    overflow-y: auto;
    padding: 24px;
    -webkit-overflow-scrolling: touch;
  }
  .lang-overlay--transition {
    transition: opacity 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .lang-overlay--enter-start { opacity: 0; }
  .lang-overlay--enter-end { opacity: 1; }

  .lang-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-top: max(8px, env(safe-area-inset-top));
  }
  .lang-overlay__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: #FFFFFF;
    margin: 0;
  }
  .lang-overlay__dot {
    color: #FF4A82;
  }
  .lang-overlay__close {
    background: rgba(255, 255, 255, 0.06);
    border: none;
    color: #FFFFFF;
    cursor: pointer;
    padding: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 200ms ease;
    flex-shrink: 0;
  }
  .lang-overlay__close:active {
    background: rgba(255, 255, 255, 0.12);
    transform: scale(0.9);
  }
  .lang-overlay__close:focus-visible {
    outline: 2px solid #FF4A82;
    outline-offset: 2px;
  }

  .lang-overlay__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FF4A82;
    margin: 0 0 24px;
  }

  /* ────────────────────────────────────────────────────────────
     GRID (2 Spalten, animiert beim Open)
     ──────────────────────────────────────────────────────────── */
  .lang-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    animation: langGridFadeIn 600ms cubic-bezier(0.16, 1, 0.3, 1);
    padding-bottom: max(24px, env(safe-area-inset-bottom));
  }
  @keyframes langGridFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lang-grid { animation: none; }
  }

  .lang-tile {
    background: #242424;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    transition: all 200ms ease;
    min-height: 100px;
    color: rgba(255, 255, 255, 0.85);
    font-family: inherit;
  }
  .lang-tile:active {
    transform: scale(0.96);
    background: #2A2A2A;
  }
  .lang-tile:focus-visible {
    outline: 2px solid #FF4A82;
    outline-offset: 2px;
  }
  .lang-tile.is-active {
    background: rgba(255, 74, 130, 0.08);
    border-color: #FF4A82;
  }
  .lang-tile__code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: #FFFFFF;
    font-weight: 500;
  }
  .lang-tile.is-active .lang-tile__code {
    color: #FF4A82;
  }
  .lang-tile__name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    text-align: center;
    line-height: 1.3;
  }
  .lang-tile.is-active .lang-tile__name {
    color: rgba(255, 255, 255, 0.9);
  }

  /* ────────────────────────────────────────────────────────────
     POSITION-VARIANTEN (Trigger im Header-Layout)
     ──────────────────────────────────────────────────────────── */
  .lang-trigger--header-desktop {
    /* Wird im Form-Side oben rechts platziert via Page-CSS */
  }
  .lang-trigger--header-mobile {
    /* Wird in Hero-Top neben Logo platziert via Page-CSS */
  }
  .lang-trigger--inline {
    /* Generic Inline-Variante */
  }

  /* Mobile: groesseres Padding-Top im Overlay wegen Status-Bar */
  @media (max-width: 767px) {
    .lang-overlay { padding: 20px; }
    .lang-overlay__title { font-size: 22px; }
    .lang-tile { padding: 20px 14px; min-height: 90px; }
    .lang-tile__code { font-size: 20px; }
    .lang-tile__name { font-size: 12px; }
  }
</style>
