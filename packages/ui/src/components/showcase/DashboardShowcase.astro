---
/**
 * packages/ui/src/components/showcase/DashboardShowcase.astro
 *
 * 1:1 nach Prototyp v4g (login_v4g_insertion.html).
 * Cyclische 4-Card Animation, 4000ms interval, 700ms cross-fade.
 *
 * Cards (Inhalte exakt aus v4g):
 *   1. Cockpit  — 3 Stats (Belegung 87% / Frühstück 42 sage / Service 3 pink)
 *   2. Bookings — 4 Rows mit confirmed/pending-Markern
 *   3. Service  — 3 Rows mit Pink-Border-Left + ▲ Icons
 *   4. QR-Grid  — 12 Cells (Zimmer 204..306), Pink-Dot auf .is-printed
 */

interface Props {
  autoplaySeconds?: number;
}
const { autoplaySeconds = 4 } = Astro.props;
const intervalMs = autoplaySeconds * 1000;
---

<div
  class="dashboard-showcase"
  x-data={`{
    activeCard: 0,
    cards: 4,
    _interval: null,
    init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      this._interval = setInterval(() => {
        this.activeCard = (this.activeCard + 1) % this.cards;
      }, ${intervalMs});
    },
    destroy() { if (this._interval) clearInterval(this._interval); },
  }`}
  x-init="init()"
>
  <!-- Card 1: Cockpit -->
  <div class="showcase-card" :class="{ 'is-active': activeCard === 0 }">
    <div class="card-header">
      <span class="card-eyebrow">— cockpit · heute —</span>
      <span class="card-time">14:32</span>
    </div>
    <div class="stats-grid">
      <div class="stat-cell"><div class="stat-value">87%</div><div class="stat-label">Belegung</div></div>
      <div class="stat-cell"><div class="stat-value is-sage">42</div><div class="stat-label">Frühstück</div></div>
      <div class="stat-cell"><div class="stat-value is-accent">3</div><div class="stat-label">Service</div></div>
    </div>
  </div>

  <!-- Card 2: Bookings -->
  <div class="showcase-card" :class="{ 'is-active': activeCard === 1 }">
    <div class="card-header">
      <span class="card-eyebrow">— bookings · live —</span>
      <span class="card-time">heute</span>
    </div>
    <div class="bookings-list">
      <div class="booking-row"><span class="booking-marker is-confirmed"></span><span class="booking-name">M. Schäfer</span><span class="booking-room">204 · 3N</span></div>
      <div class="booking-row"><span class="booking-marker is-confirmed"></span><span class="booking-name">J. Riewe</span><span class="booking-room">301 · 2N</span></div>
      <div class="booking-row"><span class="booking-marker is-pending"></span><span class="booking-name">A. Müller</span><span class="booking-room">112 · 1N</span></div>
      <div class="booking-row"><span class="booking-marker is-confirmed"></span><span class="booking-name">T. Becker</span><span class="booking-room">405 · 4N</span></div>
    </div>
  </div>

  <!-- Card 3: Service -->
  <div class="showcase-card" :class="{ 'is-active': activeCard === 2 }">
    <div class="card-header">
      <span class="card-eyebrow">— service · offen —</span>
      <span class="card-time">3 anfragen</span>
    </div>
    <div class="service-grid">
      <div class="service-row"><span class="service-icon">▲</span><span class="service-text">Zimmer 204 — Extra-Handtücher</span><span class="service-time">14:02</span></div>
      <div class="service-row"><span class="service-icon">▲</span><span class="service-text">Zimmer 301 — Late Check-out</span><span class="service-time">13:48</span></div>
      <div class="service-row"><span class="service-icon">▲</span><span class="service-text">Zimmer 112 — Wifi-Hilfe</span><span class="service-time">13:21</span></div>
    </div>
  </div>

  <!-- Card 4: QR-Grid -->
  <div class="showcase-card" :class="{ 'is-active': activeCard === 3 }">
    <div class="card-header">
      <span class="card-eyebrow">— qr · zimmer-übersicht —</span>
      <span class="card-time">42/48</span>
    </div>
    <div class="qr-grid">
      <div class="qr-cell is-printed">204</div><div class="qr-cell is-printed">205</div>
      <div class="qr-cell is-printed">206</div><div class="qr-cell is-printed">207</div>
      <div class="qr-cell">208</div><div class="qr-cell">209</div>
      <div class="qr-cell is-printed">301</div><div class="qr-cell is-printed">302</div>
      <div class="qr-cell is-printed">303</div><div class="qr-cell is-printed">304</div>
      <div class="qr-cell is-printed">305</div><div class="qr-cell is-printed">306</div>
    </div>
  </div>

  <div class="showcase-indicators">
    <span class="indicator-dot" :class="{ 'is-active': activeCard === 0 }"></span>
    <span class="indicator-dot" :class="{ 'is-active': activeCard === 1 }"></span>
    <span class="indicator-dot" :class="{ 'is-active': activeCard === 2 }"></span>
    <span class="indicator-dot" :class="{ 'is-active': activeCard === 3 }"></span>
  </div>
</div>

<style>
  /* 1:1 aus v4g — Dashboard-Showcase */

  .dashboard-showcase {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin: 24px 0;
    position: relative;
    min-height: 240px;
  }
  @media (min-width: 1280px) { .dashboard-showcase { min-height: 280px; } }

  .showcase-card {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 20px;
    background: var(--color-anthrazit-card, #242424);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 700ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      transform 800ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
    pointer-events: none;
  }
  .showcase-card.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .card-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-pink-shock, #FF4A82);
  }

  .card-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* Card 1: Stats */
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .stat-cell {
    padding: 12px;
    background: var(--color-anthrazit-card-soft, #1E1E1E);
    border-radius: 3px;
  }
  .stat-value {
    font-size: 22px;
    font-weight: 500;
    line-height: 1;
    margin-bottom: 4px;
    color: #FFFFFF;
  }
  .stat-value.is-accent { color: var(--color-pink-shock, #FF4A82); }
  .stat-value.is-sage   { color: var(--theme-sage, #5C9070); }
  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Card 2: Bookings */
  .bookings-list { display: flex; flex-direction: column; gap: 8px; }
  .booking-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    background: var(--color-anthrazit-card-soft, #1E1E1E);
    border-radius: 3px;
    font-size: 11px;
  }
  .booking-marker { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .booking-marker.is-confirmed { background: var(--theme-sage, #5C9070); }
  .booking-marker.is-pending   { background: var(--color-pink-shock, #FF4A82); }
  .booking-name { flex: 1; color: rgba(255, 255, 255, 0.85); font-size: 12px; }
  .booking-room {
    font-family: 'JetBrains Mono', monospace;
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  /* Card 3: Service */
  .service-grid { display: flex; flex-direction: column; gap: 8px; }
  .service-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    background: var(--color-anthrazit-card-soft, #1E1E1E);
    border-radius: 3px;
    border-left: 2px solid var(--color-pink-shock, #FF4A82);
  }
  .service-icon {
    font-size: 12px;
    color: var(--color-pink-shock, #FF4A82);
    font-family: 'JetBrains Mono', monospace;
  }
  .service-text { flex: 1; font-size: 11px; color: rgba(255, 255, 255, 0.85); }
  .service-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Card 4: QR-Grid */
  .qr-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 6px;
    flex: 1;
    align-content: center;
  }
  .qr-cell {
    aspect-ratio: 1;
    background: var(--color-anthrazit-card-soft, #1E1E1E);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    color: rgba(255, 255, 255, 0.5);
    position: relative;
  }
  .qr-cell.is-printed::after {
    content: '';
    position: absolute;
    top: 2px;
    right: 2px;
    width: 4px;
    height: 4px;
    background: var(--color-pink-shock, #FF4A82);
    border-radius: 50%;
  }

  /* Indicators (position aus v4g: bottom: -28px absolut) */
  .showcase-indicators {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-top: 12px;
    position: absolute;
    bottom: -28px;
    left: 0;
    right: 0;
  }
  /* Active-Indicator als elongated Balken (User-Wunsch aus Round 3) */
  .indicator-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    transition:
      background 400ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      width 400ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)),
      border-radius 400ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .indicator-dot.is-active {
    background: var(--color-pink-shock, #FF4A82);
    width: 22px;
    border-radius: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-card, .indicator-dot { transition: none; }
  }
</style>
