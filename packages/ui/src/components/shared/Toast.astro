---
// Shared floating Toast — Single Source of Truth fuer Save-/Aktions-Bestaetigungen.
//
// Trigger (ueberall):  window.retahaToast(message, type?)
//   type: 'success' (default) | 'error'
//   success = v9-Gelb (--te-yellow) + Ink-Text/-Icon (Check)  → z.B. "Gespeichert"
//   error   = Pink (--pink) + weisser Text/-Icon (Alert)
// Auch via Event:  document.dispatchEvent(new CustomEvent('retaha:toast', { detail: { message, type } }))
//
// Position: fixed unten rechts, z-index ueber Content, Mobile-Safe-Areas.
// Verhalten: Auto-Dismiss nach 3.5s + X-Button (aria-label="Schliessen"). Stapelbar.
// A11y: Container role="status" aria-live="polite" (kein Fokus-Diebstahl).
---

<div id="retaha-toast-root" class="retaha-toast-root" role="status" aria-live="polite"></div>

<style is:global>
  .retaha-toast-root {
    position: fixed;
    right: max(16px, env(safe-area-inset-right));
    bottom: max(16px, env(safe-area-inset-bottom));
    z-index: 9999;
    display: flex; flex-direction: column; gap: 10px; align-items: flex-end;
    pointer-events: none;
  }
  .retaha-toast {
    pointer-events: auto;
    display: inline-flex; align-items: center; gap: 10px;
    padding: 11px 10px 11px 15px;
    border-radius: var(--r-sm, 12px);
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 14px; font-weight: 500; letter-spacing: -0.01em;
    box-shadow: 0 8px 24px rgba(0,0,0,0.16);
    max-width: min(360px, calc(100vw - 32px));
    opacity: 0; transform: translateY(10px);
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .retaha-toast.is-in { opacity: 1; transform: translateY(0); }
  .retaha-toast--success { background: var(--te-yellow, #FFE600); color: #0A0A0A; }
  .retaha-toast--error   { background: var(--pink, #FF4A82); color: #FFFFFF; }
  .retaha-toast__icon { flex-shrink: 0; display: inline-flex; }
  .retaha-toast__msg  { line-height: 1.35; }
  .retaha-toast__close {
    flex-shrink: 0; width: 22px; height: 22px; margin-left: 2px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent; border: none; cursor: pointer;
    color: currentColor; opacity: 0.65; border-radius: 6px;
    font-size: 17px; line-height: 1;
  }
  .retaha-toast__close:hover { opacity: 1; }
  .retaha-toast__close:focus-visible { outline: 2px solid currentColor; outline-offset: 1px; }
  @media (prefers-reduced-motion: reduce) {
    .retaha-toast { transition: opacity 140ms ease; transform: none; }
    .retaha-toast.is-in { transform: none; }
  }
</style>

<script is:inline>
  (function () {
    if (window.retahaToast) return;
    var CHECK = '<svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5l4 4 8-9"/></svg>';
    var ALERT = '<svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="8"/><path d="M10 6v5M10 14h.01"/></svg>';
    function ensureRoot() {
      var r = document.getElementById('retaha-toast-root');
      if (!r) {
        r = document.createElement('div');
        r.id = 'retaha-toast-root';
        r.className = 'retaha-toast-root';
        r.setAttribute('role', 'status');
        r.setAttribute('aria-live', 'polite');
        document.body.appendChild(r);
      }
      return r;
    }
    window.retahaToast = function (message, type) {
      try {
        if (!message) return;
        type = type === 'error' ? 'error' : 'success';
        var root = ensureRoot();
        var el = document.createElement('div');
        el.className = 'retaha-toast retaha-toast--' + type;
        var icon = document.createElement('span');
        icon.className = 'retaha-toast__icon';
        icon.setAttribute('aria-hidden', 'true');
        icon.innerHTML = type === 'error' ? ALERT : CHECK;
        var msg = document.createElement('span');
        msg.className = 'retaha-toast__msg';
        msg.textContent = String(message);
        var close = document.createElement('button');
        close.type = 'button';
        close.className = 'retaha-toast__close';
        close.setAttribute('aria-label', 'Schließen');
        close.innerHTML = '×';
        el.appendChild(icon); el.appendChild(msg); el.appendChild(close);
        root.appendChild(el);
        requestAnimationFrame(function () { el.classList.add('is-in'); });
        var timer;
        function dismiss() {
          if (timer) { clearTimeout(timer); timer = null; }
          el.classList.remove('is-in');
          setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 240);
        }
        close.addEventListener('click', dismiss);
        timer = setTimeout(dismiss, 3500);
      } catch (_) {}
    };
    document.addEventListener('retaha:toast', function (e) {
      var d = (e && e.detail) || {};
      window.retahaToast(d.message, d.type);
    });
  })();
</script>
