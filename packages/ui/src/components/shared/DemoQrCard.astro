---
interface Props {
  demoUrl: string | null;
  compact?: boolean;
}
const { demoUrl, compact = false } = Astro.props;

const qrUrl = demoUrl
  ? `https://api.qrserver.com/v1/create-qr-code/?size=180x180&color=0A0A0A&bgcolor=FAFAF8&qzone=1&format=svg&data=${encodeURIComponent(demoUrl)}`
  : null;
---

<div class={`demo-qr-card ${compact ? 'demo-qr-card--compact' : ''}`}>
  <div class="demo-qr-card__head">
    <span class="demo-qr-card__eyebrow">Demo-Link</span>
    <span class="demo-qr-card__badge">Nur Demo</span>
  </div>

  {demoUrl ? (
    <div class="demo-qr-card__body">
      <div class="demo-qr-card__qr">
        <img src={qrUrl} alt="QR-Code zur Gäste-App" width="140" height="140" loading="lazy" />
      </div>
      <div class="demo-qr-card__info">
        <p class="demo-qr-card__hint">
          Mit dem Handy scannen und die Gäste-App live erleben — genau so sehen es deine Gäste.
        </p>
        <a href={demoUrl} target="_blank" rel="noopener" class="demo-qr-card__link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Demo öffnen
        </a>
        <button class="demo-qr-card__copy" data-copy-url={demoUrl} type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span class="demo-qr-card__copy-label">Link kopieren</span>
        </button>
      </div>
    </div>
  ) : (
    <div class="demo-qr-card__empty">
      <p class="demo-qr-card__empty-text">Demo-Session konnte nicht erstellt werden.</p>
    </div>
  )}
</div>

<style>
  .demo-qr-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 20px;
  }
  .demo-qr-card--compact { padding: 16px; }

  .demo-qr-card__head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .demo-qr-card__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted); text-transform: uppercase;
  }
  .demo-qr-card__badge {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    background: var(--te-yellow); color: #0A0A0A;
    padding: 2px 8px; border-radius: 99px;
  }

  .demo-qr-card__body {
    display: flex; gap: 16px; align-items: flex-start;
  }
  .demo-qr-card__qr {
    flex-shrink: 0;
    background: var(--bg-deep); border-radius: var(--r-sm);
    padding: 8px; border: 1px solid var(--border);
  }
  .demo-qr-card__qr img { display: block; border-radius: 4px; }

  .demo-qr-card__info {
    display: flex; flex-direction: column; gap: 10px; flex: 1; min-width: 0;
  }
  .demo-qr-card__hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    line-height: 1.5; color: var(--ink-muted); letter-spacing: 0.03em;
  }

  .demo-qr-card__link,
  .demo-qr-card__copy {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: var(--r-sm);
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    transition: all 150ms ease; cursor: pointer; width: 100%;
    justify-content: center;
  }
  .demo-qr-card__link {
    background: var(--ink); color: var(--bg); text-decoration: none;
    border: none;
  }
  .demo-qr-card__link:hover { background: var(--te-yellow); color: #0A0A0A; }

  .demo-qr-card__copy {
    background: transparent; color: var(--ink-muted);
    border: 1px solid var(--border);
  }
  .demo-qr-card__copy:hover { background: var(--te-yellow-soft); color: var(--ink); border-color: var(--ink-faint); }
  .demo-qr-card__copy.copied { color: var(--sage-strong); border-color: var(--sage); background: var(--sage-soft); }

  .demo-qr-card__empty {
    padding: 16px; background: var(--bg-deep); border-radius: var(--r-sm); text-align: center;
  }
  .demo-qr-card__empty-text {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.demo-qr-card__copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.copyUrl;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const label = btn.querySelector('.demo-qr-card__copy-label');
        if (label) label.textContent = '✓ Kopiert';
        btn.classList.add('copied');
        setTimeout(() => {
          if (label) label.textContent = 'Link kopieren';
          btn.classList.remove('copied');
        }, 2000);
      } catch { /* clipboard not available */ }
    });
  });
</script>
