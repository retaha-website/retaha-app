<footer class="foot">
  <div class="foot__inner">

    <div class="foot__top">
      <div>
        <h3 class="foot__title">
          Wir sind hier,<br>
          <strong>um zu helfen<span class="dot-pink">.</span></strong>
        </h3>
        <p class="foot__meta">Antwort gewöhnlich binnen 15 Minuten. Tagsüber, persönlich.</p>
      </div>
      <div class="foot__channels">
        <a href="https://wa.me/4915224046716" class="foot__channel">
          <span class="foot__channel-label">WhatsApp</span>
          <span class="foot__channel-val">+49 152 240 46716</span>
        </a>
        <a href="mailto:support@retaha.de" class="foot__channel">
          <span class="foot__channel-label">E-Mail</span>
          <span class="foot__channel-val">support@retaha.de</span>
        </a>
        <a href="tel:+4971316161950" class="foot__channel">
          <span class="foot__channel-label">Telefon</span>
          <span class="foot__channel-val">+49 7131 616 1950</span>
        </a>
      </div>
    </div>

    <div class="foot__address">
      <div class="foot__addr">
        <p class="foot__addr-title">Manufaktur</p>
        <strong>retaha GmbH</strong><br>
        74676 Niedernhall<br>
        Deutschland
      </div>
      <div class="foot__addr">
        <p class="foot__addr-title">Studio</p>
        <strong>Stuttgart</strong><br>
        Baden-Württemberg<br>
        Deutschland
      </div>
      <div class="foot__addr">
        <p class="foot__addr-title">Build</p>
        v1.0.0 · 2026<br>
        Frankfurt<br>
        <span class="made-with-heart">crafted with <span class="heart">♥</span></span>
      </div>
    </div>

    <div class="foot__bottom">
      <span>© 2026 retaha GmbH</span>
      <div class="foot__legal">
        <a href="/datenschutz">Datenschutz</a>
        <a href="/agb">AGB</a>
        <a href="/impressum">Impressum</a>
      </div>
      <span>All rights reserved</span>
    </div>

  </div>
</footer>

<style>
  .foot {
    background: var(--ink);
    color: var(--bg);
    padding: 64px 32px 40px;
    border-top: 1px solid var(--ink);
  }
  [data-theme="dark"] .foot {
    background: var(--bg-deep);
    border-top-color: var(--border);
  }
  @media (max-width: 768px) { .foot { padding: 48px 20px 32px; } }

  .foot__inner { max-width: 1400px; margin: 0 auto; }

  .foot__top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(250,250,248,0.1);
  }
  [data-theme="dark"] .foot__top { border-bottom-color: var(--border); }
  @media (max-width: 768px) { .foot__top { grid-template-columns: 1fr; gap: 24px; } }

  .foot__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 32px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: var(--bg);
  }
  [data-theme="dark"] .foot__title { color: var(--ink); }
  .foot__title strong { font-weight: 500; }

  .foot__meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: rgba(250,250,248,0.6);
    letter-spacing: 0.04em;
  }
  [data-theme="dark"] .foot__meta { color: var(--ink-muted); }

  .foot__channels { display: flex; flex-direction: column; gap: 0; min-width: 320px; }

  .foot__channel {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    margin: 0 -16px;
    border-bottom: 1px solid rgba(250,250,248,0.08);
    transition: all 280ms cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    border-radius: var(--r-sm);
    text-decoration: none;
  }
  [data-theme="dark"] .foot__channel { border-bottom-color: var(--border); }
  .foot__channel:hover {
    background: rgba(79,179,198,0.10);
    padding-left: 24px;
  }
  .foot__channel:hover .foot__channel-val { color: white; }
  [data-theme="dark"] .foot__channel:hover .foot__channel-val { color: var(--ink); }
  .foot__channel:last-child { border-bottom: none; }

  .foot__channel-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--petrol-on-dark);
    text-transform: uppercase;
  }
  .foot__channel-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: rgba(250,250,248,0.85);
    letter-spacing: 0.04em;
    transition: color 200ms ease;
  }
  [data-theme="dark"] .foot__channel-val { color: var(--ink); }

  .foot__address {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    padding-bottom: 24px;
    margin-bottom: 24px;
    border-bottom: 1px dashed rgba(250,250,248,0.12);
  }
  [data-theme="dark"] .foot__address { border-bottom-color: var(--border); }
  @media (max-width: 700px) { .foot__address { grid-template-columns: 1fr; gap: 20px; } }

  .foot__addr {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(250,250,248,0.6);
    line-height: 1.7;
    letter-spacing: 0.04em;
  }
  [data-theme="dark"] .foot__addr { color: var(--ink-muted); }
  .foot__addr-title {
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--petrol-on-dark);
    margin-bottom: 8px;
    text-transform: uppercase;
  }
  .foot__addr strong {
    color: rgba(250,250,248,0.9);
    font-weight: 500;
  }
  [data-theme="dark"] .foot__addr strong { color: var(--ink); }

  .foot__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: rgba(250,250,248,0.4);
  }
  [data-theme="dark"] .foot__bottom { color: var(--ink-faint); }
  .foot__bottom a { color: rgba(250,250,248,0.7); }
  [data-theme="dark"] .foot__bottom a { color: var(--ink-soft); }
  .foot__bottom a:hover { color: var(--petrol-on-dark); }
  .foot__legal { display: flex; gap: 12px; flex-wrap: wrap; }

  /* Herz bleibt pink schock; alles andere (auch der Titel-Punkt) in Petrol. */
  .heart { color: #FF4A82; }
  .foot__title .dot-pink { color: var(--petrol-on-dark); }
</style>
