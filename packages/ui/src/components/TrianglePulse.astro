---
interface Props {
  variant?: 'pink' | 'sage' | 'anthrazit' | 'white';
  motion?: 'infinite' | 'once';
  label?: string;
  class?: string;
}

const {
  variant = 'pink',
  motion = 'infinite',
  label,
  class: className = '',
} = Astro.props;

const variantClass = `triangle-pulse--${variant}`;
const motionClass = motion === 'once' ? 'triangle-pulse--once' : '';
const ariaProps = label
  ? { 'aria-label': label, role: 'img' }
  : { 'aria-hidden': 'true' };
---

<span
  class={`triangle-pulse ${variantClass} ${motionClass} ${className}`.trim()}
  {...ariaProps}
></span>

<style is:global>
  .triangle-pulse {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 6px solid var(--petrol, #14616E);
    display: inline-block;
    animation: pulse-tri 2s ease-in-out infinite;
    transform-origin: center;
  }

  .triangle-pulse--sage      { border-bottom-color: var(--color-sage, #5C9070); }
  .triangle-pulse--anthrazit { border-bottom-color: var(--color-anthrazit, #1A1A1A); }
  .triangle-pulse--white     { border-bottom-color: var(--color-white, #FFFFFF); }

  .triangle-pulse--once {
    animation-iteration-count: 2.5;
  }

  @keyframes pulse-tri {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .triangle-pulse { animation: none !important; }
  }
</style>
