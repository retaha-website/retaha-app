---
// Sprint I · Phase 1 — Trial-Status-Notification mit Popover.
//
// Datenholung + i18n-Lookup passieren im aufrufenden Layout — diese
// Komponente ist "dumb" und rendert nur, was sie als Props erhält.
// Damit funktioniert sie aus jedem App-Kontext ohne packages/ui auf
// trial-status.ts oder app-spezifische i18n-Helper zu zwingen.
//
// Marken-Refresh vs. Vor-Sprint-I-Version:
//   - Tabler `ti-bell` / `ti-bell-filled` statt custom SVG
//   - idle-state: KEINE Dauer-Animation (Styleguide: nicht permanent animieren)
//   - Hover bringt Pink-Tint + Pink-Color (Marken-DNA-Regel)
//   - Border-radius 3px Button (Marken-Konstante)
//   - Popover-Eyebrow nutzt themed-eyebrow-flank-Klasse für Theme-Marker

export type TrialUrgency = 'idle' | 'normal' | 'warning' | 'critical' | 'expired';

export interface NotificationTexts {
  eyebrow: string;          // z.B. "bell" — lowercase laut Variante B
  headline: string;         // i18n notification_bell.headline_<urgency>
  body: string;             // i18n notification_bell.body_<urgency>
  cta: string;              // i18n notification_bell.cta_<urgency>
  ariaLabel: string;        // Button aria-label
  popoverAria: string;      // Popover-Container aria-label
  testphaseLabel: string;   // "TESTPHASE" o.ä. — Mono uppercase
  daysLabel: string;        // "tage" / "days"
}

interface Props {
  urgency: TrialUrgency;
  hasNotification: boolean;
  currentDay: number;
  totalDays: number;
  ctaHref: string;
  texts: NotificationTexts;
}

const { urgency, hasNotification, currentDay, totalDays, ctaHref, texts } = Astro.props;

const iconClass = hasNotification ? 'ti ti-bell-filled' : 'ti ti-bell';
const swingClass = urgency === 'idle' ? '' : `bell-swing-${urgency}`;
const isExpired = urgency === 'expired';
const isUrgent = urgency === 'critical' || urgency === 'expired';
const notificationKey = hasNotification ? urgency : '';
---

<div
  class="notification-bell-wrapper"
  x-data={`{
    open: false,
    notificationKey: '${notificationKey}',
    isExpired: ${isExpired},
    hasNotification: ${hasNotification},
    dotVisible: false,
    init() {
      if (!this.hasNotification) { this.dotVisible = false; return; }
      if (this.isExpired) { this.dotVisible = true; return; }
      const lastSeenKey = localStorage.getItem('bell_last_seen_state');
      this.dotVisible = lastSeenKey !== this.notificationKey;
    },
    togglePopover() {
      this.open = !this.open;
      if (this.open && this.hasNotification && !this.isExpired) {
        localStorage.setItem('bell_last_seen_state', this.notificationKey);
        this.dotVisible = false;
      }
    },
    closePopover() { this.open = false; }
  }`}
  @click.outside="closePopover()"
  @keydown.escape.window="closePopover()"
>
  <button
    type="button"
    class="bell-button"
    @click="togglePopover()"
    aria-label={texts.ariaLabel}
    :aria-expanded="open"
  >
    <span class="bell-icon-wrapper">
      <i class={`${iconClass} ${swingClass}`.trim()} aria-hidden="true"></i>
      <span class="bell-dot" x-show="dotVisible" x-cloak aria-hidden="true"></span>
    </span>
  </button>

  {hasNotification && (
    <div
      class="bell-popover"
      x-show="open"
      x-cloak
      x-transition:enter="popover-enter"
      x-transition:enter-start="popover-enter-start"
      x-transition:enter-end="popover-enter-end"
      role="dialog"
      aria-label={texts.popoverAria}
    >
      <div class="popover-header">
        <p class="popover-eyebrow themed-eyebrow-flank">{texts.eyebrow}</p>
        <p class="popover-headline">{texts.headline}</p>
      </div>
      <div class="popover-body">
        <p class="popover-label">{texts.testphaseLabel}</p>
        <div class="popover-counter">
          <span class="counter-current">{String(currentDay).padStart(2, '0')}</span>
          <span class="counter-total">/ {totalDays} {texts.daysLabel}</span>
        </div>
        <p class="popover-body-text">{texts.body}</p>
      </div>
      <div class="popover-footer">
        <a href={ctaHref} class={isUrgent ? 'popover-cta-urgent' : 'popover-cta-link'}>
          {texts.cta}
        </a>
      </div>
    </div>
  )}
</div>

<style>
  .notification-bell-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  /* Marken-Konstante: 3px Border-Radius + 44px Min-Tap-Target.
   * Wir nutzen 36px Button — bewusst kompakter im Header-Kontext, aber das
   * Icon selbst hat genug Tap-Toleranz dank padding. */
  .bell-button {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--theme-text-primary);
    width: 36px;
    height: 36px;
    border-radius: 3px;
    transition: color 150ms ease, background 150ms ease;
  }

  /* Marken-DNA: hover bringt immer pink ins spiel */
  .bell-button:hover {
    background: rgba(var(--theme-accent-rgb), 0.08);
    color: var(--theme-accent);
  }

  .bell-button:focus-visible {
    outline: 2px solid var(--theme-accent);
    outline-offset: 2px;
  }

  .bell-icon-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  /* Tabler-Icon size — 20px Default (Styleguide 2.3 für Tab-Bar/Toolbar). */
  .bell-icon-wrapper .ti {
    font-size: 20px;
    line-height: 1;
    transform-origin: center 10%;
  }

  /* Idle-state: KEINE Animation. Andere urgencies bekommen subtile swing —
   * funktional begründet als Trial-Awareness-Signal (laute Glocke = dringender). */
  .bell-swing-normal   { animation: bell-swing 15s ease-in-out infinite; }
  .bell-swing-warning  { animation: bell-swing 10s ease-in-out infinite; }
  .bell-swing-critical { animation: bell-swing 6s  ease-in-out infinite; }
  .bell-swing-expired  { animation: bell-swing 4s  ease-in-out infinite; }

  @keyframes bell-swing {
    0%, 85%, 100% { transform: rotate(0deg); }
    88%           { transform: rotate(-6deg); }
    92%           { transform: rotate(5deg); }
    96%           { transform: rotate(-2deg); }
  }

  .bell-dot {
    position: absolute;
    top: -1px;
    right: -2px;
    width: 7px;
    height: 7px;
    background: var(--theme-accent);
    border-radius: 50%;
    border: 1.5px solid var(--theme-bg-primary);
    pointer-events: none;
  }

  /* Popover — Marken-Konstante 3px (Modals 6px, aber das hier ist kein Modal). */
  .bell-popover {
    position: absolute;
    top: calc(100% + 14px);
    right: 0;
    width: 320px;
    background: var(--theme-bg-primary);
    border: 1px solid var(--theme-border);
    border-radius: 3px;
    z-index: 100;
    box-shadow: var(--theme-shadow-card);
  }

  .popover-enter {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .popover-enter-start { opacity: 0; transform: translateY(-4px); }
  .popover-enter-end   { opacity: 1; transform: translateY(0); }

  .popover-header {
    padding: 18px 22px;
    border-bottom: 1px solid var(--theme-border);
  }

  .popover-eyebrow {
    font-family: var(--theme-font-mono);
    font-size: 9px;
    color: var(--theme-accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1;
    font-weight: 500;
  }

  .popover-headline {
    font-family: var(--theme-font-sans);
    font-size: 18px;
    color: var(--theme-text-primary);
    margin: 6px 0 0;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .popover-body {
    padding: 18px 22px;
    border-bottom: 1px solid var(--theme-border);
  }
  .popover-label {
    font-family: var(--theme-font-mono);
    font-size: 9px;
    color: var(--theme-text-primary);
    opacity: 0.5;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .popover-counter {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 4px;
  }
  .counter-current {
    font-family: var(--theme-font-sans);
    font-size: 28px;
    font-weight: 500;
    color: var(--theme-text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .counter-total {
    font-family: var(--theme-font-mono);
    font-size: 12px;
    color: var(--theme-text-primary);
    opacity: 0.4;
  }
  .popover-body-text {
    font-family: var(--theme-font-sans);
    font-size: 13px;
    color: var(--theme-text-primary);
    opacity: 0.7;
    margin: 8px 0 0;
    line-height: 1.5;
  }

  .popover-footer {
    padding: 14px 22px;
  }

  .popover-cta-link {
    font-family: var(--theme-font-mono);
    font-size: 10px;
    color: var(--theme-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--theme-accent);
    padding-bottom: 1px;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s ease;
    display: inline-block;
  }
  .popover-cta-link:hover { opacity: 0.7; }

  .popover-cta-urgent {
    font-family: var(--theme-font-mono);
    font-size: 10px;
    color: var(--theme-bg-primary);
    background: var(--theme-accent);
    padding: 6px 14px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
    transition: opacity 0.2s ease;
    border-radius: 3px;
  }
  .popover-cta-urgent:hover { opacity: 0.85; }

  [x-cloak] { display: none !important; }

  @media (prefers-reduced-motion: reduce) {
    .bell-icon-wrapper .ti {
      animation: none !important;
    }
  }
</style>
