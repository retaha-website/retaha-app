---
/**
 * BauhausToggle — Styleguide 3.11
 *
 * Anatomie (alle dimensions aus Styleguide):
 *   - Track  : 56x28 weiss, border anthrazit/20, border-radius 6
 *   - Strich : 34x2 mittig — DAS ist der eigentliche Indikator
 *              inaktiv: anthrazit/25, aktiv: sage (#5C9070)
 *   - Knob   : 14px anthrazit, slidet 34px nach rechts
 *
 * Disabled: opacity 0.5 + cursor not-allowed (Styleguide 3.11).
 * Wird in 2FA "Magic-Link MFA"-Toggle gebraucht (disabled bis personal_mfa=true).
 */

interface Props {
  id: string;
  name: string;
  checked?: boolean;
  disabled?: boolean;
  label?: string;
}

const { id, name, checked = false, disabled = false, label } = Astro.props;
---

<div class:list={[
  'relative w-14 h-7 rounded-md bg-white border border-anthrazit/20',
  disabled && 'opacity-50 cursor-not-allowed'
]}>
  <input type="hidden" name={name} value="off" />
  {checked ? (
    <input
      type="checkbox"
      id={id}
      name={name}
      value="on"
      checked
      disabled={disabled}
      class="peer sr-only"
      aria-label={label}
    />
  ) : (
    <input
      type="checkbox"
      id={id}
      name={name}
      value="on"
      disabled={disabled}
      class="peer sr-only"
      aria-label={label}
    />
  )}

  <div class="absolute left-[11px] top-1/2 -translate-y-1/2 w-[34px] h-[2px] bg-anthrazit/25 peer-checked:bg-sage transition-colors duration-200 ease-in-out pointer-events-none"></div>

  <div class="absolute left-1 top-1/2 -translate-y-1/2 w-[14px] h-[14px] rounded-full bg-anthrazit peer-checked:translate-x-[34px] transition-transform duration-200 ease-in-out pointer-events-none"></div>

  <div class="absolute inset-0 rounded-md peer-focus-visible:ring-2 peer-focus-visible:ring-sage/40 peer-focus-visible:ring-offset-1 pointer-events-none"></div>
</div>
