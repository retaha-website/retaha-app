---
// Sprint H · Group 1 — Theme-Picker
//
// 3 Theme-Cards mit Mini-Mockup-Preview. Click → PUT /api/admin/settings/theme.
// "Vorschau Gast"-Link öffnet /g/[demo-token]?preview_theme=X in neuem Tab.

import { THEME_DESCRIPTORS, type ThemeId } from '../../theme';

interface Props {
  currentTheme: ThemeId;
  /** Beliebiger Stay-Access-Token des Hotels für Preview-Link (optional) */
  previewToken: string | null;
}
const { currentTheme, previewToken } = Astro.props;

const order: ThemeId[] = ['bauhaus_manufaktur', 'premium_anthrazit', 'warmes_burgund'];
---

<section class="settings-section" x-data={`themePicker(${JSON.stringify(currentTheme)})`}>
  <div class="settings-section-marker-bar">
    <span class="settings-section-marker settings-section-marker--circle"></span>
    <p class="settings-section-eyebrow">Hotel-Theme</p>
    <span class="settings-section-line"></span>
  </div>
  <h2 class="settings-section-headline">Wähle dein Erscheinungsbild</h2>
  <p class="settings-section-description">
    Drei Themes mit unterschiedlichem Charakter. Das Theme gilt für Gast-Frontend
    UND Backoffice. Änderung greift sofort.
  </p>

  <div class="tp-grid">
    {order.map((id) => {
      const t = THEME_DESCRIPTORS[id];
      return (
        <div class={`tp-card${id === currentTheme ? ' is-active' : ''}`} data-theme-id={id} :class={`{ 'is-busy': busyTheme === '${id}' }`}>
          <div class="tp-preview" data-preview-theme={id}>
            <div class="tp-preview-bar" style={`background: ${t.swatchBrand}`}></div>
            <div class="tp-preview-body" style={`background: ${t.swatchBg}`}>
              <div class="tp-preview-eyebrow" style={`color: ${t.swatchBrand}`}>retaha · {id === 'bauhaus_manufaktur' ? 'Hotel' : id === 'premium_anthrazit' ? 'Premium' : 'Klassik'}</div>
              <div class="tp-preview-title" style={`font-family: ${id === 'warmes_burgund' ? '"Cormorant Garamond", Georgia, serif' : id === 'premium_anthrazit' ? '"Inter Tight", system-ui, sans-serif' : '"Space Grotesk", system-ui, sans-serif'}`}>
                Willkommen.
              </div>
              <div class="tp-preview-meta">{t.fontFamilyLabel}</div>
            </div>
          </div>

          <div class="tp-info">
            <div class="tp-info-head">
              <h3 class="tp-label">{t.label}</h3>
              {id === currentTheme && <span class="tp-pill is-on">aktiv</span>}
            </div>
            <p class="tp-charakter">{t.charakter}</p>
            <div class="tp-actions">
              {id === currentTheme ? (
                <button type="button" class="tp-btn tp-btn--ghost" disabled>aktuell aktiv</button>
              ) : (
                <button type="button" class="tp-btn tp-btn--primary" :disabled="!!busyTheme" @click={`activate('${id}')`} x-text={`busyTheme === '${id}' ? 'wird aktiviert…' : 'Auswählen'`}></button>
              )}
              {previewToken && (
                <a href={`/g/${previewToken}?preview_theme=${id}`} target="_blank" rel="noopener" class="tp-btn tp-btn--link">Vorschau Gast →</a>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <template x-if="message">
    <div class="tp-toast" :class="messageType === 'error' ? 'is-error' : ''" x-text="message"></div>
  </template>
</section>

<script>
  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('themePicker', (initial: string) => ({
      current: initial,
      busyTheme: null as string | null,
      message: '' as string,
      messageType: 'ok' as 'ok' | 'error',

      async activate(theme: string) {
        if (this.busyTheme || theme === this.current) return;
        this.busyTheme = theme;
        this.message = '';
        try {
          const res = await fetch('/api/admin/settings/theme', {
            method: 'PUT', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ theme }),
          });
          const data = await res.json();
          if (!data.ok) {
            this.messageType = 'error';
            this.message = data.error || 'Speichern fehlgeschlagen.';
            return;
          }
          this.messageType = 'ok';
          this.message = 'Theme aktiviert. Seite wird neu geladen …';
          setTimeout(() => location.reload(), 600);
        } catch (err: any) {
          this.messageType = 'error';
          this.message = 'Netzwerk-Fehler: ' + (err.message || 'unbekannt');
        } finally {
          this.busyTheme = null;
        }
      },
    }));
  });
</script>

<style>
  .tp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 12px; }
  @media (max-width: 900px) { .tp-grid { grid-template-columns: 1fr; } }

  .tp-card { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); display: flex; flex-direction: column; transition: border-color .15s ease, transform .15s ease; }
  .tp-card.is-active { border-color: var(--theme-text-primary); border-width: 2px; }
  .tp-card.is-busy { opacity: 0.6; }

  /* Mini-Preview */
  .tp-preview { display: flex; flex-direction: column; height: 160px; overflow: hidden; }
  .tp-preview-bar { height: 8px; flex-shrink: 0; }
  .tp-preview-body { flex: 1; padding: 18px; display: flex; flex-direction: column; justify-content: center; gap: 8px; }
  .tp-preview-eyebrow { font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; }
  .tp-preview-title { font-size: 22px; font-weight: 300; line-height: 1.1; color: var(--theme-text-primary); }
  .tp-preview-meta { font-size: 10px; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); font-style: italic; margin-top: auto; }

  .tp-info { padding: 16px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .tp-info-head { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  .tp-label { font-size: 14px; font-weight: 500; margin: 0; color: var(--theme-text-primary); }
  .tp-pill { font-size: 10px; padding: 2px 8px; letter-spacing: 0.06em; text-transform: uppercase; background: #e8f5ec; color: #145c2a; border: 1px solid #a8d9b6; }
  .tp-pill.is-on { font-weight: 500; }
  .tp-charakter { font-size: 12px; line-height: 1.5; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); margin: 0; flex: 1; }

  .tp-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .tp-btn { padding: 8px 14px; font-family: inherit; font-size: 12px; cursor: pointer; border: 1px solid var(--theme-border); background: transparent; color: var(--theme-text-primary); text-decoration: none; }
  .tp-btn:hover:not(:disabled) { background: var(--theme-accent); border-color: var(--theme-accent); color: var(--theme-bg-primary); }
  .tp-btn--primary { background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary); border-color: var(--theme-text-primary); }
  .tp-btn--primary:hover:not(:disabled) { background: var(--theme-accent); border-color: var(--theme-accent); }
  .tp-btn--ghost { color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); cursor: default; }
  .tp-btn--ghost:hover:not(:disabled) { background: transparent; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); border-color: var(--theme-border); }
  .tp-btn--link { background: transparent; border: none; color: var(--theme-accent); padding: 8px 0; text-decoration: underline; font-size: 12px; }
  .tp-btn--link:hover { color: var(--theme-text-primary); background: transparent; }
  .tp-btn:disabled { opacity: .5; cursor: not-allowed; }

  .tp-toast { margin-top: 16px; padding: 10px 14px; background: rgba(92, 144, 112, 0.08); color: #145c2a; border-left: 3px solid var(--theme-sage); font-size: 13px; }
  .tp-toast.is-error { background: rgba(220,53,69,.08); color: #B00020; border-left-color: #B00020; }
</style>
