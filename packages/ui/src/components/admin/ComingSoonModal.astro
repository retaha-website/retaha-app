---
/*
 * Sprint H · Group 4c Tag 3 — Coming-Soon-Modal
 *
 * Theme-aware Modal-Pattern für 19 Stub-Pages der Sidebar.
 * Liegt als Overlay über AdminLayout, schließt per ESC / Close-Button /
 * Backdrop-Click → navigiert zurück zum Dashboard.
 *
 * Marken-Signaturen:
 *   - .themed-eyebrow mit Theme-spezifischem Marker
 *   - .h-dot Pink-Punkt am Ende h2
 *   - All-lowercase (auch Buttons)
 *   - Border-radius 6px (Modal-Ausnahme aus APP_STYLEGUIDE)
 *
 * A11y:
 *   - role="dialog" + aria-modal="true" + aria-labelledby
 *   - ESC-Close via Alpine @keydown.escape.window
 *   - Focus auf Close-Button beim Open (Alpine x-init)
 *   - Backdrop-Click schließt (@click.self)
 */

interface Props {
  /** Feature-Name als Headline (lowercase, ohne Punkt) */
  feature_name: string;
  /** Kurze Eyebrow über h2 (lowercase) */
  feature_eyebrow: string;
  /** Body-Text: was das Feature tun wird */
  feature_description: string;
  /** Optional: geplanter Release-Zeitraum, z.B. "Q4 2026" */
  planned_release?: string;
  /** Wohin Close-Button springt. Default: /admin/dashboard */
  back_to?: string;
}

const {
  feature_name,
  feature_eyebrow,
  feature_description,
  planned_release,
  back_to = '/admin/dashboard',
} = Astro.props;

const titleId = `coming-soon-${feature_name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<div
  class="coming-soon-backdrop"
  role="dialog"
  aria-modal="true"
  aria-labelledby={titleId}
  x-data={`{ open: true, close() { window.location.href = '${back_to}' } }`}
  x-show="open"
  @keydown.escape.window="close()"
  @click.self="close()"
  x-init="$nextTick(() => $refs.closeBtn?.focus())"
>
  <div class="coming-soon-card">

    <button
      type="button"
      class="coming-soon-close"
      x-ref="closeBtn"
      @click="close()"
      aria-label="schließen, zurück zur übersicht"
    >×</button>

    <div class="coming-soon-shapes" aria-hidden="true">
      <span class="circle"></span>
      <span class="square"></span>
      <span class="triangle"></span>
    </div>

    <p class="coming-soon-eyebrow themed-eyebrow">{feature_eyebrow}</p>

    <h2 id={titleId} class="coming-soon-title">
      {feature_name}<span class="h-dot">.</span>
    </h2>

    <p class="coming-soon-status-line">
      <span class="coming-soon-status-marker"></span>
      <span class="coming-soon-status-text">in arbeit</span>
    </p>

    <p class="coming-soon-description">{feature_description}</p>

    {planned_release && (
      <p class="coming-soon-meta">
        <span class="coming-soon-meta-label">geplant für</span>
        <span class="coming-soon-meta-value">{planned_release}</span>
      </p>
    )}

    <button
      type="button"
      class="coming-soon-back-btn"
      @click="close()"
    >
      → zurück zur übersicht
    </button>
  </div>
</div>

<style>
  .coming-soon-backdrop {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--theme-text-primary) 55%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    animation: cs-backdrop-fade 0.25s ease-out;
  }
  @keyframes cs-backdrop-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .coming-soon-card {
    background: var(--theme-bg-primary);
    border-radius: var(--theme-radius-modal);
    border: 1px solid var(--theme-border);
    box-shadow: var(--theme-shadow-modal);
    max-width: 480px;
    width: 100%;
    padding: 40px 36px 32px;
    position: relative;
    animation: cs-card-slide 0.32s cubic-bezier(0.22, 1, 0.36, 1);
    font-family: var(--theme-font-sans);
    color: var(--theme-text-primary);
  }
  @keyframes cs-card-slide {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .coming-soon-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    border-radius: var(--theme-radius-pill);
    background: color-mix(in srgb, var(--theme-text-primary) 6%, transparent);
    border: none;
    color: var(--theme-text-primary);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .coming-soon-close:hover,
  .coming-soon-close:focus-visible {
    background: var(--theme-accent);
    color: var(--theme-text-on-accent);
    outline: none;
  }

  .coming-soon-shapes {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 18px;
  }
  .coming-soon-shapes .circle,
  .coming-soon-shapes .square,
  .coming-soon-shapes .triangle {
    width: 8px;
    height: 8px;
    display: block;
  }
  .coming-soon-shapes .circle   {
    background: var(--theme-accent);
    border-radius: var(--theme-radius-pill);
  }
  .coming-soon-shapes .square   {
    background: var(--theme-text-primary);
  }
  .coming-soon-shapes .triangle {
    width: 0; height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 8px solid var(--theme-accent);
    background: transparent;
  }

  .coming-soon-eyebrow {
    margin: 0 0 12px;
  }

  .coming-soon-title {
    font-family: var(--theme-font-headline);
    font-size: 30px;
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 16px;
    text-transform: lowercase;
  }

  .coming-soon-status-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 18px;
    font-family: var(--theme-font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--theme-text-secondary);
  }
  .coming-soon-status-marker {
    width: 6px;
    height: 6px;
    border-radius: var(--theme-radius-pill);
    background: var(--theme-accent);
    display: inline-block;
    animation: cs-pulse 1.8s ease-in-out infinite;
  }
  @keyframes cs-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.85); }
    50%      { opacity: 1;   transform: scale(1.1); }
  }

  .coming-soon-description {
    font-size: 15px;
    line-height: 1.55;
    color: var(--theme-text-secondary);
    margin: 0 0 24px;
  }

  .coming-soon-meta {
    margin: 0 0 28px;
    padding: 14px 16px;
    background: var(--theme-bg-secondary);
    border-left: 3px solid var(--theme-accent);
    border-radius: var(--theme-radius);
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .coming-soon-meta-label {
    font-family: var(--theme-font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--theme-text-tertiary);
  }
  .coming-soon-meta-value {
    font-family: var(--theme-font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--theme-text-primary);
  }

  .coming-soon-back-btn {
    background: var(--theme-text-primary);
    color: var(--theme-bg-primary);
    border: none;
    padding: 14px 22px;
    font-family: var(--theme-font-sans);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border-radius: var(--theme-radius-button);
    text-transform: lowercase;
    transition: background 0.18s ease, color 0.18s ease;
    width: 100%;
  }
  .coming-soon-back-btn:hover,
  .coming-soon-back-btn:focus-visible {
    background: var(--theme-accent);
    color: var(--theme-text-on-accent);
    outline: none;
  }

  @media (max-width: 480px) {
    .coming-soon-card { padding: 32px 24px 24px; }
    .coming-soon-title { font-size: 26px; }
  }
</style>
