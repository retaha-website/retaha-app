---
// Page-Header-Konvention für Backoffice + Operations-Dashboard.
//
// Sprint I Phase 4a Marken-Refresh:
//   - Eyebrow nutzt jetzt .themed-eyebrow-flank → Theme-Marker statt
//     hartcodierte Em-Dashes (Theme 1: —, Theme 2: ─, Theme 3: ⁂)
//   - Color auf var(--theme-accent) statt hartcodiertem text-pink-shock
//     → Pink-Shock in Theme 1, Gold in Theme 2, Burgund in Theme 3
//   - h-dot via .h-dot Klasse (theme-aware) statt text-pink-shock
//   - Section-Nummern bleiben Pflicht-Prop (bestehende Konvention)
interface Props {
  sectionNumber: string;
  sectionLabel: string;
  headlineLight: string;
  headlineBold: string;
  subtitle?: string;
}

const {
  sectionNumber,
  sectionLabel,
  headlineLight,
  headlineBold,
  subtitle,
} = Astro.props;
---

<header class="relative py-12 md:py-16">
  <p class="eyebrow themed-eyebrow-flank mb-5" style="color: var(--theme-accent);">
    {sectionNumber} / {sectionLabel}
  </p>

  <h1 class="text-[40px] md:text-[56px] leading-[0.95] tracking-[-0.025em] max-w-full md:max-w-[75%] mb-5">
    <span class="font-light text-anthrazit block">{headlineLight}</span>
    <span class="font-bold text-anthrazit">{headlineBold}<span class="h-dot">.</span></span>
  </h1>

  {subtitle && (
    <p class="text-base italic text-anthrazit/60 leading-[1.5] max-w-full md:max-w-[65%]">
      {subtitle}
    </p>
  )}
</header>
