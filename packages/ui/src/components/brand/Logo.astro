---
/**
 * packages/ui/src/components/brand/Logo.astro
 *
 * Einheitliche retaha-Logo-Komponente:
 * - Bildmarke (Specht-Silhouette als Inline-SVG mit currentColor)
 * - Wortmarke "retaha" (Space Grotesk Medium)
 *
 * Source des SVG-Pfads: /public/specht-anthrazit.svg (Mai 2026, Repo-Standard).
 * Inline-Embedding statt <img> damit currentColor und Hover-Farb-Wechsel
 * funktionieren.
 *
 * Beispiele:
 *   <Logo variant="light" size="md" />          --> weisz auf dunklem BG
 *   <Logo variant="dark" size="sm" />           --> anthrazit auf hellem BG
 *   <Logo variant="dark" showWordmark={false}/> --> nur Bildmarke
 */

interface Props {
  /** "light" = fuer dunkle Backgrounds, "dark" = fuer helle. Default: dark */
  variant?: 'light' | 'dark';
  /** Hoehen-Preset. sm=28px, md=36px, lg=48px. Default: md */
  size?: 'sm' | 'md' | 'lg';
  /** Wortmarke "retaha" rechts neben Bildmarke anzeigen. Default: true */
  showWordmark?: boolean;
  /** Optionale CSS-Klasse fuer Wrapper */
  class?: string;
  /** Optional als <a> mit href rendern (z.B. zur Brand-Page) */
  href?: string;
  /** Aria-Label wenn als Link gerendert */
  ariaLabel?: string;
}

const {
  variant = 'dark',
  size = 'md',
  showWordmark = true,
  class: className = '',
  href,
  ariaLabel,
} = Astro.props;

const HEIGHTS = { sm: 28, md: 36, lg: 48 };
const markHeight = HEIGHTS[size];

const Tag = href ? 'a' : 'div';
---

<Tag
  class={`brand-logo brand-logo--${variant} brand-logo--${size} ${className}`.trim()}
  {...(href ? { href, 'aria-label': ariaLabel ?? 'retaha' } : {})}
>
  <svg
    class="brand-logo__mark"
    viewBox="326 177 121 176"
    style={`height: ${markHeight}px; width: auto;`}
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      transform="matrix(1,0,0,-1,437.2943,193.7768)"
      fill="currentColor"
      fill-rule="evenodd"
      d="M0 0C-9.489-.492-18.979-.934-28.419-1.377-28.419-1.377-46.021 8.949-60.722 4.819-75.423 .738-83.339 1.819-83.339 1.819-79.068-1.627-74.784-5.072-70.501-8.518-66.2-5.463-56.165-.825-35.647-1.967-35.647-1.967-58.593-4.806-66.425-11.798-63.144-14.438-59.865-17.077-56.592-19.717-56.592-19.717-15.193-54.677-68.687-83.884-68.687-83.884-30.533-47.646-59.985-30.141-70.162-53.939-80.291-77.688-90.469-101.487-88.01-100.798-85.503-100.061-83.044-99.372-88.748-116.434-94.5-133.496-100.204-150.558-100.204-150.558-74.489-146.92-68.245-97.848-68.245-97.848 2.213-66.527-34.86-20.307-41.055-12.883-23.846-5.36 0 0"
    />
  </svg>

  {showWordmark && <span class="brand-logo__wordmark">retaha</span>}
</Tag>

<style>
  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1;
  }

  .brand-logo__mark {
    display: block;
    flex-shrink: 0;
    color: inherit;
  }

  .brand-logo__wordmark {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1;
    color: inherit;
  }

  .brand-logo--sm .brand-logo__wordmark { font-size: 16px; }
  .brand-logo--md .brand-logo__wordmark { font-size: 20px; }
  .brand-logo--lg .brand-logo__wordmark { font-size: 26px; }

  .brand-logo--light { color: #FFFFFF; }
  .brand-logo--dark  { color: #1A1A1A; }

  /* Hover-Akzentuierung wenn als Link (nur dann color-change sinnvoll) */
  a.brand-logo:hover,
  a.brand-logo:focus-visible {
    color: var(--theme-accent, #FF4A82);
    outline: none;
  }
</style>
