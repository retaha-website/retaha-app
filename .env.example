# Supabase — Projekt-spezifisch
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DeepL — für /api/translate (Backoffice-Übersetzungs-Pipeline)
# Free-Tier reicht für Dev, Format: <uuid>:fx
DEEPL_API_KEY=

# Encryption — AES-256-GCM Key für Mews-Token-Storage (siehe src/lib/encryption.ts)
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WICHTIG: NIE in Git committen, NIE zwischen Environments teilen (dev/prod = unterschiedliche Keys)
ENCRYPTION_KEY=

# Mews Connector API — Demo Environment
# Demo-Credentials sind PUBLIC (docs.mews.com/connector-api/guidelines/environments).
# Für Production: pro Hotel eigene Tokens (encrypted in mews_integrations-Tabelle).
MEWS_API_BASE_URL=https://api.mews-demo.com
MEWS_DEMO_CLIENT_TOKEN=
MEWS_DEMO_ACCESS_TOKEN=
MEWS_CLIENT_NAME=retaha 1.0.0

# Microsoft 365 SMTP — Service-Account noreply@retaha.de, App-Passwort,
# MFA + Authenticated SMTP aktiv im M365 Admin Center.
# Display-Name wird pro Mail dynamisch gesetzt (z.B. Hotel-Name).
MICROSOFT_SMTP_HOST=smtp.office365.com
MICROSOFT_SMTP_PORT=587
MICROSOFT_SMTP_USER=noreply@retaha.de
MICROSOFT_SMTP_PASSWORD=

# Public-URL für Email-Links (Backoffice-Button in Notifications).
# Lokal: http://localhost:4321  ·  Production: https://retaha.de
PUBLIC_SITE_URL=http://localhost:4321

# Resend — Customer-Facing-Mails mit Hotel-Custom-Domain (Sprint D Phase 7).
# Microsoft 365 SMTP bleibt für interne Hotelier-Mails (Booking-Notifications).
# Resend kommt für Pre-Arrival + alle anderen Gast-Mails dazu, mit hotel-
# eigener Sender-Domain (welcome@gategardenhotel.de) statt noreply@retaha.de.
RESEND_API_KEY=

# Stay-Session-Cookie-Signing (HS256, 32+ bytes random) — Sprint D Phase 3
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Verschiedene Werte zwischen Environments (dev/prod) — bei Wechsel werden
# bestehende Cookies invalidiert (Gäste müssen neu pairen).
STAY_SESSION_SECRET=

# Cron-Secret für Vercel-Cron-Jobs (Sprint E1 Phase 5+6) — Vercel sendet
# automatisch "Authorization: Bearer ${CRON_SECRET}" wenn die ENV gesetzt ist.
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Endpoints:
#   · /api/cron/pre-arrival-invites  (täglich 08:00 UTC)
#   · /api/cron/mews-sync-all        (alle 2h zur vollen Stunde)
CRON_SECRET=
