---
// Basis-Setup-Formular — die Fragen, die nur der Hotelier kennt: WLAN, Check-in/-out,
// Frühstückszeiten. Speichert nach hotel_settings (service-role-managed, wie die
// übrigen Settings-Seiten). Frühstücks-Speisekarte & -Preise gehören ins
// Frühstück-Modul, nicht hierher. Kein Türcode (raus). Copy DE-only.
//
// Links: Formular. Rechts: Live-Vorschau der „Gut zu wissen"-Karte, die beim Tippen
// mitwächst (gleiche Sprache wie der Onboarding-Abschluss-Screen).
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

// Speichern (server-seitiges POST, wie die anderen Settings-Seiten).
let saved: { ok: boolean; msg: string } | null = null;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const str = (k: string) => {
    const v = (form.get(k) ?? '').toString().trim();
    return v.length ? v : null;
  };
  const updates = {
    wifi_ssid: str('wifi_ssid'),
    wifi_password: str('wifi_password'),
    checkin_time: str('checkin_time'),
    checkout_time: str('checkout_time'),
    breakfast_start_time: str('breakfast_start_time'),
    breakfast_end_time: str('breakfast_end_time'),
  };
  const { error } = await sb.from('hotel_settings').update(updates).eq('hotel_id', hotel.id);
  saved = error ? { ok: false, msg: error.message } : { ok: true, msg: 'Gespeichert.' };
}

// Aktuelle Werte laden (Pre-Fill).
const { data: s } = await sb
  .from('hotel_settings')
  .select('wifi_ssid, wifi_password, checkin_time, checkout_time, breakfast_start_time, breakfast_end_time')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const hhmm = (t: string | null | undefined) => (t ?? '').slice(0, 5);
const cur = {
  wifi_ssid: (s as any)?.wifi_ssid ?? '',
  wifi_password: (s as any)?.wifi_password ?? '',
  checkin_time: hhmm((s as any)?.checkin_time),
  checkout_time: hhmm((s as any)?.checkout_time),
  breakfast_start_time: hhmm((s as any)?.breakfast_start_time),
  breakfast_end_time: hhmm((s as any)?.breakfast_end_time),
};

const userInitial = (user.email ?? 'K').charAt(0).toUpperCase();
---

<Layout
  title="Basis-Setup"
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLocation={(hotel as any).city ?? undefined}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
  userInitial={userInitial}
>
  <section class="setup">
    {saved && (
      <div class:list={['setup-flash', { 'is-err': !saved.ok }]} role="status">{saved.msg}</div>
    )}

    <div class="setup-head">
      <h1 class="setup-h1">Mach's <span class="setup-nb">komplett<span class="setup-dot"></span></span></h1>
      <p class="setup-sub">Die letzten Angaben, die nur du kennst: WLAN, Check-in-/Check-out-Zeiten und wann es Frühstück gibt. Den Rest hat Eve schon aus eurer Website gezogen. Speisekarte & Preise pflegst du im Frühstück-Modul.</p>
    </div>

    <form method="POST" class="setup-grid">

      <!-- Links: Formular -->
      <div class="setup-form">
        <div class="setup-fields">
          <label class="setup-field"><span class="setup-field__lbl">WLAN-Name</span>
            <input type="text" name="wifi_ssid" data-prev="wifi" value={cur.wifi_ssid} placeholder="z. B. tahas-hotel-Gast" autocomplete="off" /></label>
          <label class="setup-field"><span class="setup-field__lbl">WLAN-Passwort</span>
            <input type="text" name="wifi_password" data-prev="pw" value={cur.wifi_password} placeholder="z. B. willkommen2026" autocomplete="off" /></label>

          <div class="setup-field-row">
            <label class="setup-field"><span class="setup-field__lbl">Check-in ab</span>
              <input type="time" name="checkin_time" data-prev="cin" value={cur.checkin_time} /></label>
            <label class="setup-field"><span class="setup-field__lbl">Check-out bis</span>
              <input type="time" name="checkout_time" data-prev="cout" value={cur.checkout_time} /></label>
          </div>

          <div class="setup-field-row">
            <label class="setup-field"><span class="setup-field__lbl">Frühstück von</span>
              <input type="time" name="breakfast_start_time" data-prev="bfrom" value={cur.breakfast_start_time} /></label>
            <label class="setup-field"><span class="setup-field__lbl">Frühstück bis</span>
              <input type="time" name="breakfast_end_time" data-prev="bto" value={cur.breakfast_end_time} /></label>
          </div>
        </div>

        <div class="setup-cta-row">
          <button type="submit" class="setup-save">Speichern</button>
          <a class="setup-later" href="/uebersicht">Später</a>
        </div>
      </div>

      <!-- Rechts: Live-Vorschau -->
      <div class="setup-preview">
        <span class="setup-preview__eyebrow">Live-Vorschau · so sehen es deine Gäste</span>
        <div class="setup-card">
          <h3 class="setup-card__title">Gut zu wissen<span class="setup-dot setup-dot--sm"></span></h3>
          <div class="setup-info"><span class="setup-info__k">WLAN</span><span class="setup-info__v" data-show="wifi">{cur.wifi_ssid || '—'}</span></div>
          <div class="setup-info"><span class="setup-info__k">Passwort</span><span class="setup-info__v" data-show="pw">{cur.wifi_password || '—'}</span></div>
          <div class="setup-info"><span class="setup-info__k">Check-in</span><span class="setup-info__v" data-show="cin">{cur.checkin_time ? 'ab ' + cur.checkin_time : 'ab —'}</span></div>
          <div class="setup-info"><span class="setup-info__k">Check-out</span><span class="setup-info__v" data-show="cout">{cur.checkout_time ? 'bis ' + cur.checkout_time : 'bis —'}</span></div>
          <div class="setup-info"><span class="setup-info__k">Frühstück</span><span class="setup-info__v" data-show="bf">{cur.breakfast_start_time || cur.breakfast_end_time ? (cur.breakfast_start_time || '—') + '–' + (cur.breakfast_end_time || '—') : '—'}</span></div>
        </div>
      </div>

    </form>
  </section>

  <script is:inline>
    (function () {
      var root = document.querySelector('.setup');
      if (!root) return;
      function set(key, val) {
        var t = root.querySelector('[data-show="' + key + '"]');
        if (t) t.textContent = val;
      }
      function sync() {
        var get = function (k) {
          var el = root.querySelector('[data-prev="' + k + '"]');
          return el ? (el.value || '').trim() : '';
        };
        set('wifi', get('wifi') || '—');
        set('pw', get('pw') || '—');
        set('cin', get('cin') ? 'ab ' + get('cin') : 'ab —');
        set('cout', get('cout') ? 'bis ' + get('cout') : 'bis —');
        var bf = get('bfrom') || get('bto')
          ? (get('bfrom') || '—') + '–' + (get('bto') || '—') : '—';
        set('bf', bf);
      }
      root.querySelectorAll('[data-prev]').forEach(function (inp) {
        inp.addEventListener('input', sync);
      });
    })();
  </script>

  <style>
    .setup {
      --petrol: #14616E;
      max-width: 1280px; width: calc(100% - 64px);
      margin: 32px auto 40px; box-sizing: border-box;
    }
    .setup-flash {
      max-width: 1154px; margin: 0 auto 20px; padding: 12px 16px;
      border-radius: var(--r); font-family: 'Inter Tight', sans-serif; font-size: 14px;
      background: var(--petrol-soft, rgba(20,97,110,0.10)); border: 1px solid var(--petrol); color: var(--ink);
    }
    .setup-flash.is-err { background: rgba(142,42,58,0.10); border-color: #8E2A3A; }

    .setup-head { max-width: 1154px; margin: 0 auto 28px; text-align: left; }
    .setup-h1 {
      font-family: 'Space Grotesk', sans-serif; font-weight: 400;
      font-size: clamp(36px, 4.5vw, 60px); line-height: 1.0;
      letter-spacing: -0.035em; color: var(--ink); margin: 0 0 14px;
    }
    .setup-nb { white-space: nowrap; }
    .setup-dot { display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: var(--petrol); margin-left: 4px; }
    .setup-dot--sm { width: 8px; height: 8px; }
    .setup-sub {
      font-family: 'Inter Tight', -apple-system, sans-serif; font-size: 16px; line-height: 1.6;
      color: var(--ink-soft, rgba(10,10,10,0.65)); margin: 0; max-width: 760px;
    }

    .setup-grid {
      display: grid; grid-template-columns: minmax(0, 600px) minmax(0, 498px); gap: 56px;
      align-items: start; justify-content: center; max-width: 1154px; margin: 0 auto;
    }
    @media (max-width: 1100px) {
      .setup-head { text-align: center; margin-left: auto; margin-right: auto; }
      .setup-sub { margin-left: auto; margin-right: auto; }
      .setup-grid { grid-template-columns: 1fr; gap: 28px; justify-items: center; max-width: 520px; }
      .setup-form, .setup-preview { width: 100%; }
      .setup-cta-row { justify-content: center; }
    }

    .setup-fields { display: flex; flex-direction: column; gap: 14px; }
    .setup-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @media (max-width: 480px) { .setup-field-row { grid-template-columns: 1fr; } }
    .setup-field { display: flex; flex-direction: column; gap: 5px; }
    .setup-field__lbl { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.5)); }
    .setup-field input {
      font-family: 'Inter Tight', sans-serif; font-size: 14px; color: var(--ink);
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-sm);
      padding: 11px 12px; outline: none; transition: border-color 0.15s ease;
      -webkit-appearance: none; appearance: none; width: 100%; box-sizing: border-box;
    }
    .setup-field input::placeholder { color: var(--ink-faint, rgba(10,10,10,0.4)); }
    .setup-field input:focus { border-color: var(--petrol); }

    .setup-preview { display: flex; flex-direction: column; gap: 10px; }
    .setup-preview__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.45)); }
    .setup-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--r);
      padding: 20px 20px 8px; box-shadow: 0 14px 40px -22px rgba(10,10,10,0.3);
    }
    .setup-card__title { font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 17px; color: var(--ink); margin: 0 0 14px; }
    .setup-info { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; padding: 11px 0; border-top: 1px solid var(--border); }
    .setup-info:first-of-type { border-top: none; padding-top: 0; }
    .setup-info__k { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.5)); flex-shrink: 0; }
    .setup-info__v { font-family: 'Inter Tight', sans-serif; font-size: 15px; font-weight: 500; color: var(--ink); text-align: right; word-break: break-word; }

    .setup-cta-row { display: flex; align-items: center; gap: 14px; margin-top: 22px; }
    .setup-save {
      appearance: none; -webkit-appearance: none; border: none;
      font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
      color: var(--surface); background: var(--ink); border-radius: var(--r, 12px); padding: 13px 28px;
      cursor: pointer; transition: background 0.15s ease;
    }
    .setup-save:hover { background: var(--petrol); }
    .setup-later {
      font-family: 'Inter Tight', -apple-system, sans-serif; font-size: 14px; font-weight: 500;
      color: var(--ink-muted, rgba(10,10,10,0.42)); text-decoration: none; transition: color 0.15s ease;
    }
    .setup-later:hover { color: var(--ink); }
  </style>
</Layout>
