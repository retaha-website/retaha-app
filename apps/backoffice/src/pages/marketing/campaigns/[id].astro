---
import Layout from '../../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const dateLocale = lang === 'de' ? 'de-DE' : lang;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const canWrite = true;

const campaignId = Astro.params.id;
if (!campaignId) return Astro.redirect('/marketing/campaigns');

const client = createSupabaseServiceRoleInstance();
const { data: campaign } = await client
  .from('marketing_campaigns')
  .select('*')
  .eq('id', campaignId)
  .maybeSingle();
if (!campaign || campaign.hotel_id !== hotel.id) return Astro.redirect('/marketing/campaigns');

const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '—';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '—';
}
function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString(dateLocale, { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
function pct(n: number, total: number): string {
  if (!total) return '—';
  return ((n / total) * 100).toFixed(1) + '%';
}

const recipients = campaign.recipients_count ?? 0;
const opens = campaign.open_count ?? 0;
const clicks = campaign.click_count ?? 0;
const skipped = campaign.skipped_count ?? 0;
const skipReasons = (campaign.skip_reasons || {}) as Record<string, number>;
const totalSkipped = Object.values(skipReasons).reduce((a, b) => a + (b as number), 0);

const CHANNEL_LABELS: Record<string, string> = {
  wallet_push: bt('cm.ch.wallet_push', lang),
  email: bt('cm.ch.email', lang),
};

const STATUS_LABELS: Record<string, string> = {
  draft: bt('cm.status.draft', lang), scheduled: bt('cm.status.scheduled', lang), sending: bt('cm.status.sending', lang), sent: bt('cm.status.sent', lang), cancelled: bt('cm.status.cancelled', lang), failed: bt('cm.status.failed', lang),
};
const SKIP_REASON_LABELS: Record<string, string> = {
  marketing_opted_out:               bt('cd.skipreason.marketing_opted_out', lang),
  marketing_consent_missing:         bt('cd.skipreason.marketing_consent_missing', lang),
  pass_expired:                      bt('cd.skipreason.pass_expired', lang),
  pass_not_synced_to_google:         bt('cd.skipreason.pass_not_synced_to_google', lang),
  filter_excluded:                   bt('cd.skipreason.filter_excluded', lang),
  service_push_contract_fulfillment: bt('cd.skipreason.service_push_contract_fulfillment', lang),
  marketing_consent_given:           bt('cd.skipreason.marketing_consent_given', lang),
};
---

<Layout title={`Kampagne · ${campaign.name}`} activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing/campaigns" class="breadcrumb__crumb">{bt('cm.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{campaign.name}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title">{campaign.name}<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">{pickI18n(campaign.title_i18n)}</p>
    </section>

    <div class="cd-head-meta">
      <span class={`cd-status cd-status--${campaign.status}`}>{STATUS_LABELS[campaign.status] ?? campaign.status}</span>
      <div class="cd-meta-row">
        <span class="cd-meta-label">{campaign.status === 'sent' ? bt('cm.status.sent', lang) + ':' : campaign.status === 'scheduled' ? bt('cm.status.scheduled', lang) + ':' : bt('cm.meta.created', lang) + ':'}</span>
        <span class="cd-meta-val">{fmtDate(campaign.sent_at || campaign.scheduled_at || campaign.created_at)}</span>
      </div>
      {Array.isArray(campaign.channels) && (
        <div class="cd-channels">
          {campaign.channels.map((ch: string) => (
            <span class="cd-channel-chip">{CHANNEL_LABELS[ch] ?? ch}</span>
          ))}
        </div>
      )}
    </div>

    {(canWrite && (campaign.status === 'draft' || campaign.status === 'scheduled')) && (
      <div class="cd-action-bar" x-data="{ submitting: false }">
        {campaign.status === 'draft' && (
          <button
            class="cd-btn-primary"
            type="button"
            :disabled="submitting"
            @click={`submitting = true; fetch('/api/marketing/campaigns/${campaign.id}/send-now', { method: 'POST', credentials: 'include' }).then(r => r.json()).then(d => { if (d.ok) location.reload(); else { alert(${JSON.stringify(bt('cd.err.prefix', lang) + ' ')} + (d.error || ${JSON.stringify(bt('cd.err.unknown', lang))})); submitting = false; } })`}
            x-text={`submitting ? ${JSON.stringify(bt('cd.btn.sending', lang))} : ${JSON.stringify(bt('cd.btn.sendnow', lang))}`}
          ></button>
        )}
        {campaign.status === 'scheduled' && (
          <button
            class="cd-btn-ghost"
            type="button"
            :disabled="submitting"
            @click={`if (!confirm(${JSON.stringify(bt('cd.confirm.cancel', lang))})) return; submitting = true; fetch('/api/marketing/campaigns/${campaign.id}/schedule', { method: 'DELETE', credentials: 'include' }).then(r => r.json()).then(d => { if (d.ok) location.reload(); else { alert(${JSON.stringify(bt('cd.err.prefix', lang) + ' ')} + (d.error || ${JSON.stringify(bt('cd.err.unknown', lang))})); submitting = false; } })`}
          >{bt('cd.btn.cancel', lang)}</button>
        )}
      </div>
    )}

    {campaign.send_error && (
      <div class="cd-error">
        <strong>{bt('cd.senderror', lang)}</strong> {campaign.send_error}
      </div>
    )}

    <!-- Stats Cards -->
    <section class="cd-stats">
      <div class="cd-stat">
        <div class="cd-stat-label">{bt('cd.stat.recipients', lang)}</div>
        <div class="cd-stat-value">{recipients}</div>
        <div class="cd-stat-sub">{bt('cd.stat.recipients.sub', lang)}</div>
      </div>
      <div class="cd-stat">
        <div class="cd-stat-label">{bt('cd.stat.opens', lang)}</div>
        <div class="cd-stat-value">{opens}</div>
        <div class="cd-stat-sub">{pct(opens, recipients)} {bt('cd.stat.rate', lang)}</div>
      </div>
      <div class="cd-stat">
        <div class="cd-stat-label">{bt('cd.stat.clicks', lang)}</div>
        <div class="cd-stat-value">{clicks}</div>
        <div class="cd-stat-sub">{pct(clicks, recipients)} {bt('cd.stat.rate', lang)}</div>
      </div>
      <div class="cd-stat">
        <div class="cd-stat-label">{bt('cd.stat.skipped', lang)}</div>
        <div class="cd-stat-value">{skipped}</div>
        <div class="cd-stat-sub">{bt('cd.stat.skipped.sub', lang)}</div>
      </div>
    </section>

    {totalSkipped > 0 && (
      <section class="cd-skip-breakdown">
        <p class="cd-section-eyebrow">{bt('cd.skip.eyebrow', lang)}</p>
        <h2 class="cd-section-title">{bt('cd.skip.title', lang)}</h2>
        <div class="cd-skip-bars">
          {Object.entries(skipReasons).map(([reason, count]) => {
            const w = Math.round(((count as number) / totalSkipped) * 100);
            return (
              <div class="cd-skip-row">
                <span class="cd-skip-label">{SKIP_REASON_LABELS[reason] ?? reason}</span>
                <span class="cd-skip-track"><span class="cd-skip-fill" style={`width: ${w}%`}></span></span>
                <span class="cd-skip-count">{count} · {w}%</span>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <section class="cd-content-preview">
      <p class="cd-section-eyebrow">{bt('cd.content.eyebrow', lang)}</p>
      <h2 class="cd-section-title">{bt('cd.content.title', lang)}</h2>
      <div class="cd-preview-block">
        <div class="cd-preview-title">{pickI18n(campaign.title_i18n)}</div>
        <div class="cd-preview-body" set:html={pickI18n(campaign.body_i18n)} />
        {campaign.cta_url && (
          <div class="cd-preview-cta">
            <strong>{pickI18n(campaign.cta_label_i18n) || bt('cd.cta.link', lang)}:</strong> {campaign.cta_url}
          </div>
        )}
      </div>
    </section>
  </div>

  <style>
    /* Wie /marketing: gerundete Karten, Petrol-Akzente, Space Grotesk — kein Gold/Burgund. */
    .breadcrumb { padding-top: 36px; }

    .cd-head-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .cd-status { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 4px 11px; letter-spacing: 0.08em; text-transform: uppercase; border-radius: 99px; font-weight: 500; }
    .cd-status--draft     { background: var(--bg-deep); color: var(--ink-muted); }
    .cd-status--scheduled { background: rgba(79,179,198,0.18); color: #0D434C; }
    .cd-status--sending   { background: rgba(20,97,110,0.14); color: #14616E; }
    .cd-status--sent      { background: #14616E; color: #fff; }
    .cd-status--cancelled { background: var(--bg-deep); color: var(--ink-muted); }
    .cd-status--failed    { background: #fdeaea; color: #7a1515; }
    .cd-meta-row { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); display: flex; gap: 6px; }
    .cd-meta-label { color: var(--ink-muted); }
    .cd-meta-val { color: var(--ink); }
    .cd-channels { display: flex; gap: 6px; }
    .cd-channel-chip { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 2px 8px; border: 1px solid var(--border); color: var(--ink-muted); background: var(--bg-deep); letter-spacing: 0.03em; border-radius: 99px; }

    .cd-action-bar { display: flex; gap: 12px; margin-bottom: 28px; }
    .cd-btn-primary { padding: 12px 24px; background: var(--petrol); color: #fff; border: none; border-radius: 8px; cursor: pointer; font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; transition: filter .15s ease; }
    .cd-btn-primary:hover:not(:disabled) { filter: brightness(1.08); }
    .cd-btn-primary:disabled { opacity: .5; cursor: not-allowed; }
    .cd-btn-ghost { padding: 12px 24px; background: transparent; color: var(--ink-muted); border: 1px solid var(--border); border-radius: 8px; cursor: pointer; font-size: 14px; }
    .cd-btn-ghost:hover { color: var(--ink); border-color: var(--ink); }

    .cd-error { padding: 12px 16px; background: rgba(220,53,69,.08); color: #7a1515; border-left: 3px solid #B00020; border-radius: 12px; margin-bottom: 24px; font-size: 13px; }

    .cd-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 40px; }
    @media (max-width: 720px) { .cd-stats { grid-template-columns: repeat(2, 1fr); } }
    .cd-stat { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 22px; }
    .cd-stat-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-muted); }
    .cd-stat-value { font-family: 'Space Grotesk', sans-serif; font-size: 32px; font-weight: 500; margin: 10px 0 4px; color: var(--ink); line-height: 1; }
    .cd-stat-sub { font-family: 'Inter Tight', sans-serif; font-size: 12px; color: var(--ink-soft, var(--ink-muted)); }

    .cd-section-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted); margin: 0 0 6px; }
    .cd-section-title { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 500; letter-spacing: -0.01em; margin: 0 0 16px; color: var(--ink); }

    .cd-skip-breakdown { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 40px; }
    .cd-skip-bars { display: flex; flex-direction: column; gap: 10px; }
    .cd-skip-row { display: grid; grid-template-columns: 200px 1fr 120px; gap: 12px; align-items: center; font-size: 13px; }
    @media (max-width: 600px) { .cd-skip-row { grid-template-columns: 1fr; gap: 4px; } }
    .cd-skip-label { color: var(--ink); }
    .cd-skip-track { height: 8px; background: var(--bg-deep); border-radius: 999px; position: relative; overflow: hidden; }
    .cd-skip-fill { position: absolute; inset: 0 auto 0 0; background: var(--petrol); border-radius: 999px; }
    .cd-skip-count { font-size: 12px; color: var(--ink-muted); text-align: right; font-variant-numeric: tabular-nums; }

    .cd-content-preview { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }
    .cd-preview-block { padding: 16px; background: var(--bg-deep); border-left: 3px solid var(--petrol); border-radius: 0 10px 10px 0; }
    .cd-preview-title { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 500; margin-bottom: 8px; color: var(--ink); }
    .cd-preview-body { font-family: 'Inter Tight', sans-serif; font-size: 14px; line-height: 1.6; color: var(--ink-soft, var(--ink-muted)); }
    .cd-preview-body :global(p) { margin: 0 0 8px; }
    .cd-preview-body :global(a) { color: var(--petrol); }
    .cd-preview-cta { margin-top: 12px; padding: 8px 12px; background: rgba(20,97,110,0.06); border-left: 2px solid var(--petrol); border-radius: 0 8px 8px 0; font-size: 13px; word-break: break-all; }
  </style>
</Layout>
