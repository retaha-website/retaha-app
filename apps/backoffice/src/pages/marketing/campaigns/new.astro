---
import Layout from '../../../layouts/Layout.astro';
import CampaignEditor from '../../../components/admin/CampaignEditor.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServiceRoleInstance();

const [
  { data: templates },
  { data: hotelBranding },
  { count: allWalletCount },
  { count: loyalCount },
  { count: lapsedCount },
  { count: emailCount },
] = await Promise.all([
  client
    .from('marketing_templates')
    .select('id, name, title_i18n, body_i18n, cta_label_i18n, cta_url, hero_image_url')
    .eq('hotel_id', hotel.id)
    .eq('is_archived', false)
    .order('updated_at', { ascending: false }),
  client
    .from('hotels')
    .select('brand_primary, logo_primary')
    .eq('id', hotel.id)
    .maybeSingle(),
  client
    .from('wallet_passes')
    .select('*', { count: 'exact', head: true })
    .eq('hotel_id', hotel.id)
    .eq('marketing_consent_given', true)
    .eq('state', 'active'),
  client
    .from('wallet_passes')
    .select('*', { count: 'exact', head: true })
    .eq('hotel_id', hotel.id)
    .eq('marketing_consent_given', true)
    .eq('state', 'active')
    .gte('visit_count', 3),
  client
    .from('wallet_passes')
    .select('*', { count: 'exact', head: true })
    .eq('hotel_id', hotel.id)
    .eq('marketing_consent_given', true)
    .eq('state', 'active')
    .lt('last_visit_at', new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString()),
  client
    .from('marketing_waitlist')
    .select('*', { count: 'exact', head: true })
    .eq('hotel_id', hotel.id)
    .not('confirmed_at', 'is', null)
    .is('unsubscribed_at', null),
]);

const enabledLangs: string[] = Array.isArray((hotel as any).enabled_languages)
  ? (hotel as any).enabled_languages
  : [(hotel as any).default_language || 'de'];

const segmentCounts = {
  allWallet: allWalletCount ?? 0,
  allEmail: emailCount ?? 0,
  loyal: loyalCount ?? 0,
  lapsed: lapsedCount ?? 0,
};
---

<Layout title="Marketing · Neue Kampagne" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing/campaigns" class="breadcrumb__crumb">{bt('cm.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('cm.new.crumb', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('cm.new.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('cm.new.sub', lang)}</p>
    </section>

    <CampaignEditor
      templates={templates ?? []}
      hotelName={hotel.name}
      hotelDefaultLang={(hotel as any).default_language || 'de'}
      enabledLangs={enabledLangs}
      brandPrimary={(hotelBranding as any)?.brand_primary ?? '#FF4A82'}
      logoUrl={(hotelBranding as any)?.logo_primary ?? null}
      segmentCounts={segmentCounts}
    />
  </div>

  <style>
    .breadcrumb { padding-top: 36px; }
  </style>
</Layout>
