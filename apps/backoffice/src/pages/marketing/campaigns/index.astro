---
import Layout from '../../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const dateLocale = lang === 'de' ? 'de-DE' : lang;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const canWrite = true;

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('status') || 'all';

const client = createSupabaseServiceRoleInstance();
let q = client
  .from('marketing_campaigns')
  .select('id, name, status, scheduled_at, sent_at, recipients_count, open_count, click_count, skipped_count, title_i18n, channels')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false })
  .limit(100);
if (filter !== 'all') q = q.eq('status', filter);

const { data: rows } = await q;
const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '—';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '—';
}
function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString(dateLocale, { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const CHANNEL_LABELS: Record<string, string> = {
  wallet_push: bt('cm.ch.wallet_push', lang),
  email: bt('cm.ch.email', lang),
};

const STATUS_LABELS: Record<string, { label: string; class: string }> = {
  draft:     { label: bt('cm.status.draft', lang),     class: 'mc-status--draft' },
  scheduled: { label: bt('cm.status.scheduled', lang), class: 'mc-status--scheduled' },
  sending:   { label: bt('cm.status.sending', lang),   class: 'mc-status--sending' },
  sent:      { label: bt('cm.status.sent', lang),      class: 'mc-status--sent' },
  cancelled: { label: bt('cm.status.cancelled', lang), class: 'mc-status--cancelled' },
  failed:    { label: bt('cm.status.failed', lang),    class: 'mc-status--failed' },
};
---

<Layout title="Marketing · Kampagnen" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('tab.backoffice', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('cm.crumb', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('cm.title.all', lang)}></h1>
    </section>

    <div class="mc-bar">
      <div class="mc-tabs">
        <a href="?status=all"       class={`mc-tab${filter === 'all' ? ' is-active' : ''}`}>{bt('cm.tab.all', lang)}</a>
        <a href="?status=draft"     class={`mc-tab${filter === 'draft' ? ' is-active' : ''}`}>{bt('cm.status.draft', lang)}</a>
        <a href="?status=scheduled" class={`mc-tab${filter === 'scheduled' ? ' is-active' : ''}`}>{bt('cm.status.scheduled', lang)}</a>
        <a href="?status=sent"      class={`mc-tab${filter === 'sent' ? ' is-active' : ''}`}>{bt('cm.status.sent', lang)}</a>
        <a href="?status=failed"    class={`mc-tab${filter === 'failed' ? ' is-active' : ''}`}>{bt('cm.status.failed', lang)}</a>
      </div>
      {canWrite && <a href="/marketing/campaigns/new" class="mc-btn-primary">+ {bt('cm.new.crumb', lang)}</a>}
    </div>

    {!rows || rows.length === 0 ? (
      <div class="mc-empty">
        <p>{bt('cm.empty', lang)}</p>
        {canWrite && <a href="/marketing/campaigns/new" class="mc-btn-primary">+ {bt('cm.btn.first', lang)}</a>}
      </div>
    ) : (
      <div class="mc-list">
        {rows.map((c: any) => {
          const s = STATUS_LABELS[c.status] ?? { label: c.status, class: '' };
          const openRate = c.recipients_count > 0 ? Math.round((c.open_count / c.recipients_count) * 100) : 0;
          const clickRate = c.recipients_count > 0 ? Math.round((c.click_count / c.recipients_count) * 100) : 0;
          return (
            <a href={`/marketing/campaigns/${c.id}`} class="mc-row">
              <div class="mc-row-main">
                <div class="mc-row-head">
                  <span class={`mc-status ${s.class}`}>{s.label}</span>
                  <span class="mc-row-name">{c.name}</span>
                  {Array.isArray(c.channels) && c.channels.map((ch: string) => (
                    <span class="mc-channel-chip">{CHANNEL_LABELS[ch] ?? ch}</span>
                  ))}
                </div>
                <p class="mc-row-title">{pickI18n(c.title_i18n)}</p>
              </div>
              <div class="mc-row-meta">
                <div class="mc-meta-block">
                  <span class="mc-meta-label">{c.status === 'sent' ? bt('cm.status.sent', lang) : c.status === 'scheduled' ? bt('cm.meta.scheduledfor', lang) : bt('cm.meta.created', lang)}</span>
                  <span class="mc-meta-val">{fmtDate(c.sent_at || c.scheduled_at)}</span>
                </div>
                {c.status === 'sent' && (
                  <>
                    <div class="mc-meta-block"><span class="mc-meta-label">{bt('cm.meta.recipients', lang)}</span><span class="mc-meta-val">{c.recipients_count}</span></div>
                    <div class="mc-meta-block"><span class="mc-meta-label">{bt('cm.meta.open', lang)}</span><span class="mc-meta-val">{openRate}%</span></div>
                    <div class="mc-meta-block"><span class="mc-meta-label">{bt('cm.meta.click', lang)}</span><span class="mc-meta-val">{clickRate}%</span></div>
                  </>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>

  <style>
    /* Wie /marketing: Petrol-Akzente, gerundete Zeilen mit Hover-Lift, kein Gold/Grün/Burgund. */
    .breadcrumb { padding-top: 36px; }
    .mc-bar { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
    .mc-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
    .mc-tab { padding: 10px 14px; font-size: 13px; color: var(--ink-muted); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .mc-tab:hover { color: var(--ink); }
    .mc-tab.is-active { color: var(--ink); border-bottom-color: var(--petrol); font-weight: 500; }
    .mc-btn-primary { padding: 10px 18px; background: var(--petrol); color: #fff; text-decoration: none; font-size: 13px; font-weight: 500; border-radius: 8px; transition: filter .15s ease; }
    .mc-btn-primary:hover { filter: brightness(1.08); }
    .mc-empty { padding: 60px 24px; background: var(--surface); border: 1px dashed var(--border); border-radius: 16px; text-align: center; color: var(--ink-muted); }
    .mc-empty p { margin: 0 0 20px; font-style: italic; }
    .mc-list { display: flex; flex-direction: column; gap: 10px; }
    .mc-row { display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; padding: 18px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; text-decoration: none; color: inherit; transition: box-shadow .16s ease, transform .16s ease; }
    .mc-row:hover { box-shadow: 0 10px 28px rgba(40,30,20,.09); transform: translateY(-2px); }
    .mc-row-main { min-width: 0; }
    .mc-row-head { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
    .mc-status { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 3px 9px; letter-spacing: 0.05em; text-transform: uppercase; border-radius: 99px; font-weight: 500; }
    .mc-status--draft     { background: var(--bg-deep); color: var(--ink-muted); }
    .mc-status--scheduled { background: rgba(79,179,198,0.18); color: #0D434C; }
    .mc-status--sending   { background: rgba(20,97,110,0.14); color: #14616E; }
    .mc-status--sent      { background: #14616E; color: #fff; }
    .mc-status--cancelled { background: var(--bg-deep); color: var(--ink-muted); text-decoration: line-through; }
    .mc-status--failed    { background: #fdeaea; color: #7a1515; }
    .mc-row-name { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; color: var(--ink); letter-spacing: -0.005em; }
    .mc-row-title { margin: 0; font-family: 'Inter Tight', sans-serif; font-size: 13px; color: var(--ink-soft, var(--ink-muted)); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 600px; }
    .mc-row-meta { display: flex; gap: 16px; align-items: center; }
    @media (max-width: 720px) { .mc-row { grid-template-columns: 1fr; } .mc-row-meta { flex-wrap: wrap; } }
    .mc-meta-block { display: flex; flex-direction: column; align-items: flex-end; }
    .mc-meta-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-muted); }
    .mc-meta-val { font-size: 13px; color: var(--ink); font-variant-numeric: tabular-nums; }
    .mc-channel-chip { font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 2px 8px; border: 1px solid var(--border); color: var(--ink-muted); background: var(--bg-deep); letter-spacing: 0.03em; border-radius: 99px; }
  </style>
</Layout>
