---
// Sprint Wallet · Phase 14 — Drip-Sequenz-Liste (Backoffice)

import Layout from '../../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

const { data: drips } = await sb
  .from('marketing_drips')
  .select(`
    id, name, trigger_type, trigger_config, is_active, created_at,
    steps:marketing_drip_steps(count),
    state:marketing_drip_state(count)
  `)
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false });

const TRIGGER_LABELS: Record<string, string> = {
  wallet_add: bt('dr.trigger.wallet_add', lang),
  first_visit: bt('dr.trigger.first_visit', lang),
  checkout: bt('dr.trigger.checkout', lang),
  anniversary: bt('dr.trigger.anniversary', lang),
  visit_count_milestone: bt('dr.trigger.visit_count_milestone', lang),
  seasonal: bt('dr.trigger.seasonal', lang),
};
---

<Layout title="Drip-Sequenzen" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('dr.crumb', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('dr.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('dr.sub', lang)}</p>
    </section>

    <div class="dl-bar">
      <a href="/marketing/drips/new" class="dl-btn-primary">+ {bt('dr.btn.new', lang)}</a>
    </div>

    {!drips || drips.length === 0 ? (
      <div class="dl-empty">
        <p>{bt('dr.empty', lang)}</p>
        <a href="/marketing/drips/new" class="dl-btn-primary">+ {bt('dr.btn.first', lang)}</a>
      </div>
    ) : (
      <div class="dl-grid">
        {drips.map((d: any) => {
          const stepsCount = Array.isArray(d.steps) ? (d.steps[0]?.count ?? 0) : 0;
          const stateCount = Array.isArray(d.state) ? (d.state[0]?.count ?? 0) : 0;
          return (
            <a href={`/marketing/drips/${d.id}`} class={`dl-card${d.is_active ? '' : ' dl-card--inactive'}`}>
              <div class="dl-card-head">
                <span class={`dl-active-pill${d.is_active ? ' is-on' : ''}`}>
                  {d.is_active ? bt('dr.pill.active', lang) : bt('dr.pill.inactive', lang)}
                </span>
                <span class="dl-trigger">{TRIGGER_LABELS[d.trigger_type] ?? d.trigger_type}</span>
              </div>
              <h3 class="dl-card-name">{d.name}</h3>
              <div class="dl-card-meta">
                <span><strong>{stepsCount}</strong> {stepsCount === 1 ? bt('dr.step.one', lang) : bt('dr.step.many', lang)}</span>
                <span>·</span>
                <span><strong>{stateCount}</strong> {bt('dr.enqueued', lang)}</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</Layout>

<style>
  /* Wie /marketing/campaigns: Petrol-Akzente, gerundete Karten mit Hover-Lift, kein Gold/Grün/Burgund. */
  .breadcrumb { padding-top: 36px; }
  .dl-bar {
    display: flex;
    justify-content: flex-end;
    margin: 0 0 16px;
  }
  .dl-btn-primary {
    display: inline-block;
    padding: 10px 18px;
    background: var(--petrol);
    color: #fff;
    text-decoration: none;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    border-radius: 8px;
    transition: filter 0.15s ease;
  }
  .dl-btn-primary:hover { filter: brightness(1.08); }

  .dl-empty {
    padding: 60px 24px;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 16px;
    text-align: center;
    color: var(--ink-muted);
  }
  .dl-empty p { margin: 0 0 20px; font-style: italic; }

  .dl-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .dl-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.16s ease, transform 0.16s ease;
  }
  .dl-card:hover { box-shadow: 0 10px 28px rgba(40,30,20,.09); transform: translateY(-2px); }
  .dl-card--inactive { opacity: 0.65; }

  .dl-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .dl-active-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    padding: 3px 9px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 99px;
    font-weight: 500;
    background: var(--bg-deep);
    color: var(--ink-muted);
  }
  .dl-active-pill.is-on {
    background: rgba(20,97,110,0.12);
    color: #14616E;
    border: 1px solid rgba(20,97,110,0.24);
  }
  .dl-trigger {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-muted);
  }
  .dl-card-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 10px;
    color: var(--ink);
  }
  .dl-card-meta {
    display: flex;
    gap: 6px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 12px;
    color: var(--ink-muted);
  }
  .dl-card-meta strong {
    color: var(--ink);
    font-weight: 500;
  }
</style>
