---
// Sprint Wallet · Phase 14 — Drip-Sequenz-Liste (Backoffice)

import Layout from '../../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const sb = createSupabaseServiceRoleInstance();

const { data: drips } = await sb
  .from('marketing_drips')
  .select(`
    id, name, trigger_type, trigger_config, is_active, created_at,
    steps:marketing_drip_steps(count),
    state:marketing_drip_state(count)
  `)
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false });

const TRIGGER_LABELS: Record<string, string> = {
  wallet_add: 'Wallet hinzugefügt',
  first_visit: 'Erster Besuch',
  checkout: 'Check-out',
  anniversary: 'Jahrestag',
  visit_count_milestone: 'Besuchs-Meilenstein',
  seasonal: 'Saisonal',
};
---

<Layout title="Drip-Sequenzen" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">Marketing</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Drip-Sequenzen</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">Marketing</span>
      <h1 class="settings-hero__title">Automatische Sequenzen<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">Sendet nach Trigger-Event — Wallet-Add, Check-out, Jahrestag u.m.</p>
    </section>

    <div class="dl-bar">
      <a href="/marketing/drips/new" class="dl-btn-primary">+ Neue Drip-Sequenz</a>
    </div>

    {!drips || drips.length === 0 ? (
      <div class="dl-empty">
        <p>Noch keine Drip-Sequenzen.</p>
        <a href="/marketing/drips/new" class="dl-btn-primary">+ Erste Sequenz anlegen</a>
      </div>
    ) : (
      <div class="dl-grid">
        {drips.map((d: any) => {
          const stepsCount = Array.isArray(d.steps) ? (d.steps[0]?.count ?? 0) : 0;
          const stateCount = Array.isArray(d.state) ? (d.state[0]?.count ?? 0) : 0;
          return (
            <a href={`/marketing/drips/${d.id}`} class={`dl-card${d.is_active ? '' : ' dl-card--inactive'}`}>
              <div class="dl-card-head">
                <span class={`dl-active-pill${d.is_active ? ' is-on' : ''}`}>
                  {d.is_active ? 'aktiv' : 'inaktiv'}
                </span>
                <span class="dl-trigger">{TRIGGER_LABELS[d.trigger_type] ?? d.trigger_type}</span>
              </div>
              <h3 class="dl-card-name">{d.name}</h3>
              <div class="dl-card-meta">
                <span><strong>{stepsCount}</strong> {stepsCount === 1 ? 'Step' : 'Steps'}</span>
                <span>·</span>
                <span><strong>{stateCount}</strong> Pässe enqueuet</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</Layout>

<style>
  .dl-bar {
    display: flex;
    justify-content: flex-end;
    margin: 0 0 16px;
  }
  .dl-btn-primary {
    display: inline-block;
    padding: 10px 18px;
    background: #1f1812;
    color: var(--surface);
    text-decoration: none;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.15s ease;
  }
  .dl-btn-primary:hover { background: #8c2128; }

  .dl-empty {
    padding: 60px 24px;
    background: var(--surface);
    border: 1px dashed var(--border);
    text-align: center;
    color: var(--ink-muted);
  }
  .dl-empty p { margin: 0 0 20px; font-style: italic; }

  .dl-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .dl-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 18px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .dl-card:hover { border-color: var(--ink); }
  .dl-card--inactive { opacity: 0.65; }

  .dl-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .dl-active-pill {
    font-size: 10px;
    padding: 3px 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--bg-deep);
    color: var(--ink-muted);
  }
  .dl-active-pill.is-on {
    background: #e8f5ec;
    color: #145c2a;
    border: 1px solid #a8d9b6;
  }
  .dl-trigger {
    font-size: 11px;
    color: var(--ink-muted);
  }
  .dl-card-name {
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 10px;
    color: var(--ink);
  }
  .dl-card-meta {
    display: flex;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-muted);
  }
  .dl-card-meta strong {
    color: var(--ink);
    font-weight: 500;
  }
</style>
