---
// Sprint Wallet · Phase 14 — Neue Drip-Sequenz (Backoffice)

import Layout from '../../../layouts/Layout.astro';
import DripEditor from '../../../components/admin/DripEditor.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();
const { data: templates } = await sb
  .from('marketing_templates')
  .select('id, name')
  .eq('hotel_id', hotel.id)
  .eq('is_archived', false)
  .order('name');
---

<Layout title="Neue Drip-Sequenz" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing/drips" class="breadcrumb__crumb">{bt('dr.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('mk.crumb.new', lang)}</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">{bt('mk.crumb', lang)}</span>
      <h1 class="settings-hero__title" set:html={bt('dr.new.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('dr.new.sub', lang)}</p>
    </section>

    <DripEditor
      drip={null}
      initialSteps={[]}
      templates={templates ?? []}
    />
  </div>
</Layout>
