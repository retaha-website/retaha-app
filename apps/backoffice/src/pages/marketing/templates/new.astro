---
// Sprint Wallet · Phase 9 — Marketing-Template Create-Page (Backoffice)

import Layout from '../../../layouts/Layout.astro';
import MarketingEditor from '../../../components/admin/MarketingEditor.astro';
import { getUser, getUserHotels } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const hotelDefaultLang = (hotel as any).default_language || 'de';
---

<Layout title="Neue Vorlage" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing/templates" class="breadcrumb__crumb">{bt('tm.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('mk.crumb.new', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('tm.new.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('tm.new.sub', lang)}</p>
    </section>

    <MarketingEditor
      templateId={null}
      initialTitle=""
      initialBodyHtml=""
      initialCtaLabel=""
      initialCtaUrl=""
      initialHeroUrl=""
      initialName=""
      initialCategory={null}
      hotelDefaultLang={hotelDefaultLang}
    />
  </div>

  <style>
    .breadcrumb { padding-top: 36px; }
  </style>
</Layout>
