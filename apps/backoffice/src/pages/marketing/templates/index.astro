---
// Sprint Wallet · Phase 9 — Marketing-Templates Liste (Backoffice)
//
// Listet alle Templates des aktuellen Hotels mit Active/Archiv-Tab-Filter.

import Layout from '../../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const dateLocale = lang === 'de' ? 'de-DE' : lang;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

const url = new URL(Astro.request.url);
const showArchived = url.searchParams.get('archived') === '1';

const { data: templates } = await sb
  .from('marketing_templates')
  .select('id, name, category, title_i18n, hero_image_url, is_archived, updated_at')
  .eq('hotel_id', hotel.id)
  .eq('is_archived', showArchived)
  .order('updated_at', { ascending: false });

const rows = (templates ?? []) as any[];
const hotelDefaultLang = (hotel as any).default_language || 'de';

function pickDefault(jsonb: any): string {
  if (!jsonb) return '—';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '—';
}

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString(dateLocale, {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const CAT_LABELS: Record<string, string> = {
  newsletter: bt('tm.cat.newsletter', lang),
  event: bt('tm.cat.event', lang),
  promotion: bt('tm.cat.promotion', lang),
  seasonal: bt('tm.cat.seasonal', lang),
};
---

<Layout title="Vorlagen" activeTab="backoffice" hotelName={hotel.name}>
  <div class="settings-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('tm.crumb', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('tm.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('tm.sub', lang)}</p>
    </section>

    <div class="mt-actions-top">
      <div class="mt-tabs">
        <a href="/marketing/templates" class={`mt-tab${!showArchived ? ' is-active' : ''}`}>{bt('tm.tab.active', lang)}</a>
        <a href="/marketing/templates?archived=1" class={`mt-tab${showArchived ? ' is-active' : ''}`}>{bt('tm.tab.archive', lang)}</a>
      </div>
      {!showArchived && (
        <a href="/marketing/templates/new" class="mt-btn-primary">+ {bt('tm.btn.new', lang)}</a>
      )}
    </div>

    {rows.length === 0 ? (
      <div class="mt-empty">
        <p>
          {showArchived
            ? bt('tm.empty.archived', lang)
            : bt('tm.empty.active', lang)}
        </p>
        {!showArchived && (
          <a href="/marketing/templates/new" class="mt-btn-primary">+ {bt('tm.btn.first', lang)}</a>
        )}
      </div>
    ) : (
      <div class="mt-grid">
        {rows.map((t: any) => (
          <article class="mt-card">
            {t.hero_image_url && (
              <img class="mt-hero" src={t.hero_image_url} alt="" loading="lazy" />
            )}
            <div class="mt-card-body">
              <div class="mt-card-meta">
                {t.category && (
                  <span class="mt-pill">{CAT_LABELS[t.category] ?? t.category}</span>
                )}
                <span class="mt-date">{fmtDate(t.updated_at)}</span>
              </div>
              <h3 class="mt-card-name">{t.name}</h3>
              <p class="mt-card-title">{pickDefault(t.title_i18n)}</p>
              <div class="mt-card-actions">
                <a href={`/marketing/templates/${t.id}/edit`} class="mt-link">{bt('tm.edit', lang)}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  /* Wie /marketing/campaigns: Petrol-Akzente, gerundete Karten mit Hover-Lift, kein Gold/Grün/Burgund. */
  .breadcrumb { padding-top: 36px; }
  .mt-actions-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .mt-tabs {
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--border);
  }
  .mt-tab {
    padding: 10px 14px;
    font-size: 13px;
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .mt-tab:hover { color: var(--ink); }
  .mt-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--petrol);
    font-weight: 500;
  }
  .mt-btn-primary {
    display: inline-block;
    padding: 10px 18px;
    background: var(--petrol);
    color: #fff;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 8px;
    transition: filter 0.15s ease;
  }
  .mt-btn-primary:hover { filter: brightness(1.08); }

  .mt-empty {
    padding: 60px 24px;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 16px;
    text-align: center;
    color: var(--ink-muted);
  }
  .mt-empty p { margin: 0 0 20px; font-style: italic; }

  .mt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .mt-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.16s ease, transform 0.16s ease;
  }
  .mt-card:hover { box-shadow: 0 10px 28px rgba(40,30,20,.09); transform: translateY(-2px); }
  .mt-hero {
    width: 100%;
    aspect-ratio: 16/7;
    object-fit: cover;
    display: block;
    background: var(--bg-deep);
  }
  .mt-card-body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mt-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  .mt-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    padding: 3px 9px;
    background: rgba(79,179,198,0.18);
    color: #0D434C;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 99px;
    font-weight: 500;
  }
  .mt-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
  }
  .mt-card-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
    font-weight: 500;
  }
  .mt-card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--ink);
    margin: 0;
    flex: 1;
  }
  .mt-card-actions { margin-top: 8px; }
  .mt-link {
    font-size: 13px;
    color: var(--petrol);
    text-decoration: underline;
  }
  .mt-link:hover { color: var(--ink); }
</style>
