---
import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const dateLocale = lang === 'de' ? 'de-DE' : lang;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

// Wallet-Push Opt-ins
const { count: walletOptInTotal } = await sb.from('wallet_passes')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id)
  .eq('marketing_consent_given', true);

const { count: walletActive } = await sb.from('wallet_passes')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id)
  .eq('marketing_consent_given', true)
  .eq('state', 'active');

// Email DOI Stats (global, aus marketing_waitlist — Zuordnung via wallet_passes.guest_email)
const { data: hotelEmails } = await sb.from('wallet_passes')
  .select('guest_email')
  .eq('hotel_id', hotel.id)
  .not('guest_email', 'is', null);

const emailSet = (hotelEmails ?? []).map(p => p.guest_email!.toLowerCase());

// Lade Waitlist-Entries für diese Emails
const { data: waitlistRows } = emailSet.length > 0
  ? await sb.from('marketing_waitlist')
      .select('id, email, confirmed_at, unsubscribed_at, pending_at, confirmation_sent_at')
      .in('email', emailSet)
  : { data: [] };

const wlTotal = waitlistRows?.length ?? 0;
const wlConfirmed = waitlistRows?.filter(w => w.confirmed_at && !w.unsubscribed_at).length ?? 0;
const wlPending = waitlistRows?.filter(w => !w.confirmed_at && !w.unsubscribed_at).length ?? 0;
const wlUnsubscribed = waitlistRows?.filter(w => w.unsubscribed_at).length ?? 0;

// Recent consents
const { data: recentConsents } = await sb.from('marketing_consents')
  .select('id, action, source, policy_version, created_at, wallet_pass_id, waitlist_id')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false })
  .limit(20);

function fmtDate(iso: string | null | undefined) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString(dateLocale, { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

// Roh-Quellwerte (doi_confirm_link …) → verständliche Labels (i18n), sonst Roh-Wert.
const SOURCE_KEYS = new Set(['doi_confirm_link', 'email_unsubscribe_link', 'opt_out_link', 'guest_checkout', 'self_checkout', 'wallet_add']);
function sourceLabel(s: string): string {
  return s && SOURCE_KEYS.has(s) ? bt(`mc.source.${s}`, lang) : (s || '—');
}
---

<Layout title="Consent-Dashboard" activeTab="backoffice" hotelName={hotel.name}>
<style>
/* Mehr Luft zwischen Header und Breadcrumb (war eingedrückt) — wie /marketing. */
.breadcrumb { padding-top: 36px; }

/* Freistehende Abschnitte wie /marketing: Titel + Inhalt direkt, keine nummerierte Box. */
.consent-sections { display: flex; flex-direction: column; gap: 44px; }
.consent-section-title { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); margin: 0 0 16px; }
.consent-note { font-family: 'Inter Tight', sans-serif; font-size: 13px; color: var(--ink-soft, var(--ink-muted)); margin: 16px 0 0; }
.consent-empty { padding: 24px; background: var(--surface); border: 1px dashed var(--border); border-radius: 16px; color: var(--ink-muted); font-size: 14px; }

/* KPI-Karten (freistehend) im /marketing-Stil; Akzente = Petrol-Töne des Charts. */
.consent-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
.consent-kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 22px; }
.consent-kpi__val { font-family: 'Space Grotesk', sans-serif; font-size: 34px; font-weight: 500; color: var(--ink); line-height: 1; }
.consent-kpi__label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-muted); margin-top: 8px; }
.consent-kpi--petrol .consent-kpi__val { color: #14616E; }
.consent-kpi--petrol-light .consent-kpi__val { color: #4FB3C6; }

/* Tabelle in eigener gerundeter Karte. */
.consent-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
.consent-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.consent-table th { text-align: left; padding: 12px 16px; color: var(--ink-muted); font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; border-bottom: 1px solid var(--border); }
.consent-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); color: var(--ink); }
.consent-table tr:last-child td { border-bottom: none; }
.consent-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; }
.consent-badge--granted { background: rgba(20,97,110,0.10); color: #14616E; }
.consent-badge--revoked { background: #fce8e8; color: #8c2128; }
</style>

<div class="settings-page">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <a href="/marketing" class="breadcrumb__crumb">{bt('mk.crumb', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('mc.crumb', lang)}</span>
  </nav>

  <section class="settings-hero">
    <h1 class="settings-hero__title" set:html={bt('mc.hero.title', lang)}></h1>
    <p class="settings-hero__sub">{bt('mc.hero.sub', lang)}</p>
  </section>

  <div class="consent-sections">
    <!-- Wallet-Push Opt-ins -->
    <section class="consent-section">
      <h2 class="consent-section-title">{bt('mc.wallet.title', lang)}</h2>
      <div class="consent-grid">
        <div class="consent-kpi consent-kpi--petrol">
          <div class="consent-kpi__val">{walletActive ?? 0}</div>
          <div class="consent-kpi__label">{bt('mc.wallet.active', lang)}</div>
        </div>
        <div class="consent-kpi">
          <div class="consent-kpi__val">{walletOptInTotal ?? 0}</div>
          <div class="consent-kpi__label">{bt('mc.wallet.total', lang)}</div>
        </div>
      </div>
      <p class="consent-note" set:html={bt('mc.wallet.note', lang)}></p>
    </section>

    <!-- Email DOI -->
    <section class="consent-section">
      <h2 class="consent-section-title">{bt('mc.email.title', lang)}</h2>
      <div class="consent-grid">
        <div class="consent-kpi consent-kpi--petrol">
          <div class="consent-kpi__val">{wlConfirmed}</div>
          <div class="consent-kpi__label">{bt('mc.email.confirmed', lang)}</div>
        </div>
        <div class="consent-kpi consent-kpi--petrol-light">
          <div class="consent-kpi__val">{wlPending}</div>
          <div class="consent-kpi__label">{bt('mc.email.pending', lang)}</div>
        </div>
        <div class="consent-kpi">
          <div class="consent-kpi__val">{wlUnsubscribed}</div>
          <div class="consent-kpi__label">{bt('mc.email.unsub', lang)}</div>
        </div>
        <div class="consent-kpi">
          <div class="consent-kpi__val">{wlTotal}</div>
          <div class="consent-kpi__label">{bt('mc.email.total', lang)}</div>
        </div>
      </div>
      <p class="consent-note">{bt('mc.email.note', lang)}</p>
    </section>

    <!-- Recent Consents -->
    <section class="consent-section">
      <h2 class="consent-section-title">{bt('mc.recent.title', lang)}</h2>
      {(recentConsents?.length ?? 0) === 0 ? (
        <p class="consent-empty">{bt('mc.recent.empty', lang)}</p>
      ) : (
        <div class="consent-card">
          <table class="consent-table">
            <thead>
              <tr>
                <th>{bt('mc.th.action', lang)}</th>
                <th>{bt('mc.th.source', lang)}</th>
                <th>{bt('mc.th.channel', lang)}</th>
                <th>{bt('mc.th.policy', lang)}</th>
                <th>{bt('mc.th.date', lang)}</th>
              </tr>
            </thead>
            <tbody>
              {recentConsents!.map(c => (
                <tr>
                  <td>
                    <span class={`consent-badge consent-badge--${c.action}`}>
                      {c.action === 'granted' ? bt('mc.badge.granted', lang) : bt('mc.badge.revoked', lang)}
                    </span>
                  </td>
                  <td>{sourceLabel(c.source)}</td>
                  <td style="color:var(--ink-muted)">{c.wallet_pass_id ? bt('mc.channel.wallet', lang) : bt('mc.channel.email', lang)}</td>
                  <td style="color:var(--ink-muted)">{c.policy_version}</td>
                  <td style="color:var(--ink-muted)">{fmtDate(c.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>
</div>
</Layout>
