---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { loadBreakfastItems, EU_ALLERGENS } from '@retaha/db';
import { getMewsClientForHotel } from '../lib/mews/factory';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const isLite = hotel?.plan === 'lite';

const supabase = createSupabaseServiceRoleInstance();

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString() || 'save_settings';

  // ── Mews import ──────────────────────────────────────────────────────────────
  if (action === 'mews_import') {
    const mews = await getMewsClientForHotel(hotel.id);
    if (!mews) {
      message = { type: 'error', text: bt('bf.msg.mewsnotconnected', lang) };
    } else {
      try {
        const resp = await mews.getProducts({ Limitation: { Count: 100 } });
        const products = resp.Products ?? [];
        if (products.length === 0) {
          message = { type: 'error', text: bt('bf.msg.mewsnoproducts', lang) };
        } else {
          let imported = 0;
          let skipped = 0;
          for (const p of products) {
            const mewsId = p.Id as string | undefined;
            if (!mewsId) continue;

            const names = (p.Names ?? p.ExternalNames ?? {}) as Record<string, string>;
            const descs = (p.Descriptions ?? {}) as Record<string, unknown>;
            const priceObj = (p.Price ?? p.DefaultPrice ?? {}) as Record<string, unknown>;
            const priceValue = (priceObj.Value ?? priceObj.GrossValue ?? priceObj.NetValue ?? 0) as number;

            const payload: Record<string, unknown> = {
              hotel_id: hotel.id,
              mews_product_id: mewsId,
              name_de: names['de-DE'] || names['en-US'] || names[Object.keys(names)[0]] || mewsId,
              name_en: names['en-US'] || names['en-GB'] || null,
              name_fr: names['fr-FR'] || null,
              name_es: names['es-ES'] || null,
              description_de: (descs['de-DE'] || descs['en-US'] || null) as string | null,
              description_en: (descs['en-US'] || descs['en-GB'] || null) as string | null,
              description_fr: (descs['fr-FR'] || null) as string | null,
              description_es: (descs['es-ES'] || null) as string | null,
              price_cents: Math.round(priceValue * 100),
              is_active: (p.IsActive as boolean | undefined) !== false,
              display_order: 0,
              updated_at: new Date().toISOString(),
            };

            const { error } = await supabase
              .from('breakfast_items')
              .upsert(payload, { onConflict: 'hotel_id,mews_product_id' });

            if (error) {
              skipped++;
            } else {
              imported++;
            }
          }
          const productsWord = imported === 1 ? bt('bf.msg.product.one', lang) : bt('bf.msg.product.many', lang);
          const skippedTxt = skipped > 0 ? bt('bf.msg.mewsskipped', lang).replace('{n}', String(skipped)) : '';
          message = { type: 'success', text: bt('bf.msg.mewsimport', lang).replace('{n}', String(imported)).replace('{products}', productsWord).replace('{skipped}', skippedTxt) };
        }
      } catch (err) {
        message = { type: 'error', text: `${bt('bf.msg.mewsfail', lang)}: ${(err as Error).message}` };
      }
    }
  }

  // Settings sections now save via AJAX (/api/admin/breakfast/section)
}

const { data: settings } = await supabase
  .from('hotel_settings')
  .select(`
    features,
    breakfast_start_time, breakfast_end_time, breakfast_slot_minutes,
    breakfast_hours,
    breakfast_location_i18n, breakfast_included_i18n,
    breakfast_price_cents,
    breakfast_room_service_enabled, breakfast_room_service_fee_cents
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || ({} as Record<string, any>);
const features        = ((s.features as Record<string, unknown>) ?? {});
const breakfastOn     = features.breakfast !== false;
const startTime       = ((s.breakfast_start_time as string | undefined) || '07:30').substring(0, 5);
const endTime         = ((s.breakfast_end_time   as string | undefined) || '10:30').substring(0, 5);
const slotMinutes     = (s.breakfast_slot_minutes as number | undefined) || 30;
const locationDe      = (s.breakfast_location_i18n as any)?.de?.value || '';
const includedDe      = (s.breakfast_included_i18n as any)?.de?.value || '';
const priceCents      = (s.breakfast_price_cents   as number | null | undefined) ?? null;
const roomServiceOn   = (s.breakfast_room_service_enabled as boolean | undefined) === true;
const roomServiceFee  = (s.breakfast_room_service_fee_cents as number | undefined) || 0;

// Build per-weekday hours initial state
const WEEK_DAYS = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'] as const;
const rawBreakfastHours = (s.breakfast_hours as Record<string, any> | null | undefined) ?? null;
const initialHours: Record<string, {start: string; end: string; closed: boolean}> = {};
for (const day of WEEK_DAYS) {
  const bh = rawBreakfastHours?.[day];
  initialHours[day] = {
    start: (bh?.start as string | undefined) || startTime,
    end: (bh?.end as string | undefined) || endTime,
    closed: bh?.closed === true,
  };
}

const items = await loadBreakfastItems(hotel.id);

const { data: hotelRow } = await supabase
  .from('hotels')
  .select('currency')
  .eq('id', hotel.id)
  .maybeSingle();
const hotelCurrency = (hotelRow?.currency as string | undefined) || 'EUR';
const currencySymbol = hotelCurrency === 'CHF' ? 'CHF' : '€';

// Check Mews integration for import button
const { data: mewsRow } = await supabase
  .from('mews_integrations')
  .select('mews_products_count')
  .eq('hotel_id', hotel.id)
  .maybeSingle();
const hasMews = !!mewsRow;

const url = new URL(Astro.request.url);
if (url.searchParams.get('deleted') === '1' && !message) {
  message = { type: 'success', text: bt('bf.js.itemdeleted', lang) };
}

const allergenInit = EU_ALLERGENS.map(a => ({ key: a.key, label_de: a.label_de }));
const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

// Client-Strings für die Alpine-Komponenten
const bfDayLabels = {
  mon: bt('si.day.mon', lang), tue: bt('si.day.tue', lang), wed: bt('si.day.wed', lang),
  thu: bt('si.day.thu', lang), fri: bt('si.day.fri', lang), sat: bt('si.day.sat', lang), sun: bt('si.day.sun', lang),
};
const bfHoursT = {
  error: bt('bf.js.error', lang),
  saved: bt('common.savedshort', lang),
  netErr: bt('bf.js.neterr', lang),
};
const bfPageT = {
  noCat: bt('bf.js.nocat', lang),
  nameRequired: bt('bf.js.namerequired', lang),
  saveFail: bt('bf.js.savefail', lang),
  itemCreated: bt('bf.js.itemcreated', lang),
  itemSaved: bt('bf.js.itemsaved', lang),
  itemDeleted: bt('bf.js.itemdeleted', lang),
  netErr: bt('bf.js.neterr', lang),
  deleteConfirm: bt('bf.js.deleteconfirm', lang),
  deleteFail: bt('bf.js.deletefail', lang),
  orderFail: bt('bf.js.orderfail', lang),
  sortErr: bt('bf.js.sorterr', lang),
};
---

<Layout title="Frühstück" activeTab="backoffice">

<script is:inline define:vars={{ _bfInit: { items, allergens: allergenInit, currency: hotelCurrency, t: bfPageT, lang }, _hoursInit: { hours: initialHours, slotMinutes: String(slotMinutes), dayLabels: bfDayLabels, t: bfHoursT } }}>
  window._bfInit = _bfInit;
  window._hoursInit = _hoursInit;
</script>

<style is:global>
[x-cloak] { display: none !important; }
textarea.s-input { resize: none; min-height: 72px; }
.breadcrumb { padding-top: 36px; }

/* ── V9-Karten ─────────────────────────────────────────────────────────── */
.bf-wrap { display: flex; flex-direction: column; gap: 12px; }
.bf-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 14px; padding: 16px 18px;
}
.bf-card-head {
  display: flex; align-items: center; justify-content: space-between;
  gap: 10px; margin-bottom: 12px;
}
.bf-card-title {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Space Grotesk', sans-serif; font-weight: 600;
  font-size: 13px; color: var(--ink);
}
.bf-card-title::before {
  content: ''; width: 6px; height: 6px;
  border-radius: 50%; background: var(--petrol, #14616E); flex-shrink: 0;
}
.bf-card-foot {
  display: flex; gap: 8px; justify-content: flex-end; align-items: center;
  margin-top: 0; padding-top: 12px; border-top: 1px solid var(--border);
}

/* ── Labels + Hints ────────────────────────────────────────────────────── */
.bf-label {
  display: block; font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 6px;
}
.bf-hint { display: block; font-size: 11px; color: var(--ink-muted); margin-top: 6px; line-height: 1.45; }
.bf-field { margin-bottom: 14px; }

/* iPad touch targets */
.settings-page .toggle-row { min-height: 44px; }

/* ── Buttons ────────────────────────────────────────────────────────────── */
.bf-cta {
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--petrol, #14616E); color: #fff;
  padding: 7px 16px; border: none; border-radius: 7px;
  font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase;
  cursor: pointer; transition: filter 200ms ease;
  -webkit-tap-highlight-color: transparent;
}
.bf-cta:hover:not(:disabled) { filter: brightness(1.1); }
.bf-cta:disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
.bf-cta--ghost {
  background: transparent; color: var(--ink-muted, rgba(10,10,10,0.55));
  border: 1px solid var(--border);
}
.bf-cta--ghost:hover:not(:disabled) { color: var(--ink); border-color: var(--ink); filter: none; }
.bf-cta--danger {
  background: transparent; color: #991B1B;
  border: 1px solid rgba(153,27,27,0.3);
}
.bf-cta--danger:hover:not(:disabled) { background: rgba(153,27,27,0.06); border-color: #991B1B; filter: none; }

/* ── Lite Locked Control ─────────────────────────────────────────────── */
.bf-locked-ctrl {
  position: relative;
  border: 1px dashed var(--petrol, #14616E);
  border-radius: 10px;
  padding: 14px 14px 12px;
  margin-top: 4px;
}
.bf-lock-chip {
  display: inline-flex; align-items: center; gap: 5px;
  position: absolute; top: -11px; right: 12px;
  background: var(--surface, #fff);
  padding: 2px 9px;
  border: 1px solid var(--petrol, #14616E);
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--petrol, #14616E);
}
.bf-locked-inner {
  opacity: 0.5;
  pointer-events: none;
  user-select: none;
}
.bf-lock-info {
  margin: 10px 0 0; padding: 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; line-height: 1.55;
  color: var(--ink-muted);
}
.bf-lock-info a { color: var(--petrol, #14616E); text-decoration: none; font-weight: 600; }
.bf-lock-info a:hover { text-decoration: underline; }

/* ── Room-Service Fee-Block ────────────────────────────────────────────── */
.bp-fee-section { padding-top: 14px; margin-top: 14px; border-top: 1px solid var(--border); }

/* ── Zeiten-Grid ───────────────────────────────────────────────────────── */
.bp-hours-grid {
  border: 1px solid var(--border); border-radius: 12px;
  overflow: hidden; margin-bottom: 16px;
}
.bp-hours-row {
  display: grid; grid-template-columns: 40px 1fr auto;
  gap: 10px; align-items: center; padding: 8px 12px;
  border-bottom: 1px solid var(--border); min-height: 44px;
}
.bp-hours-row:last-child { border-bottom: none; }
.bp-hours-row--closed { opacity: 0.6; }
.bp-hours-day {
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink);
}
.bp-hours-inputs { display: flex; align-items: center; gap: 6px; }
.bp-hours-sep { font-size: 13px; color: var(--ink-muted); flex-shrink: 0; }
.bp-hours-closed-txt { font-size: 12px; color: var(--ink-muted); font-style: italic; }
.s-input--time { width: 110px; min-width: 88px; }
@media (max-width: 480px) {
  .s-input--time { width: 88px; }
  .bp-hours-row { grid-template-columns: 36px 1fr auto; gap: 8px; padding: 8px 10px; }
}

/* ── Slot-Stepper ──────────────────────────────────────────────────────── */
.bp-slot-stepper { display: inline-flex; align-items: stretch; }
.bp-slot-stepper .s-input {
  text-align: center; width: 64px; border-radius: 0;
  border-left: none; border-right: none;
}
.bp-slot-stepper .s-input[type=number] { -moz-appearance: textfield; appearance: textfield; }
.bp-slot-stepper .s-input::-webkit-outer-spin-button,
.bp-slot-stepper .s-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.bp-slot-step-btn {
  display: flex; align-items: center; justify-content: center;
  width: 36px; min-height: 36px; border: 1px solid var(--border);
  background: var(--surface); cursor: pointer; font-size: 16px; line-height: 1;
  color: var(--ink); flex-shrink: 0; user-select: none; transition: background 120ms;
}
.bp-slot-step-btn:first-child { border-radius: 8px 0 0 8px; }
.bp-slot-step-btn:last-child  { border-radius: 0 8px 8px 0; }
.bp-slot-step-btn:hover { background: var(--bg-deep, #F5F4F2); }
.bp-slot-step-btn:active { background: color-mix(in srgb, var(--petrol, #14616E) 12%, transparent); }

/* ── Speisekarte ───────────────────────────────────────────────────────── */
.bp-item-group { margin-bottom: 4px; }
.bp-item-cat {
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted);
  padding: 14px 4px 5px;
}
.bp-item-list { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; touch-action: none; }
.bp-item-row { display: flex; align-items: center; border-bottom: 1px solid var(--border); transition: background 120ms; }
.bp-item-row:last-child { border-bottom: none; }
.bp-item-row.is-drag-over { background: color-mix(in srgb, var(--petrol, #14616E) 8%, transparent); box-shadow: inset 0 2px 0 var(--petrol, #14616E); }
.bp-item-row.is-dragging { opacity: 0.4; }
.bp-drag-handle {
  display: flex; align-items: center; justify-content: center;
  width: 36px; min-height: 44px; flex-shrink: 0;
  cursor: grab; color: var(--ink-faint); touch-action: none; user-select: none;
}
.bp-drag-handle:hover { color: var(--ink-muted); }
.bp-drag-handle:active { cursor: grabbing; }
.bp-drag-handle svg { pointer-events: none; }
.bp-item-content {
  flex: 1; display: flex; align-items: center; gap: 10px;
  padding: 10px 14px 10px 0; background: none; border: none;
  cursor: pointer; text-align: left; min-height: 44px; transition: background 120ms;
}
.bp-item-row:hover { background: var(--bg-deep, #F5F4F2); }
.bp-item-row:hover .bp-item-content { background: transparent; }
.bp-item-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border-medium); flex-shrink: 0; }
.bp-item-dot--on { background: #4CAF50; }
.bp-item-info { flex: 1; min-width: 0; }
.bp-item-name { display: block; font-size: 13px; font-weight: 500; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.bp-item-desc { display: block; font-size: 11px; color: var(--ink-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
.bp-item-meta { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.bp-badge { font-size: 10px; background: rgba(20,97,110,0.10); color: var(--petrol, #14616E); padding: 2px 8px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em; white-space: nowrap; }
.bp-item-price { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-muted); white-space: nowrap; }
.bp-item-edit { font-size: 11px; color: var(--ink-muted); white-space: nowrap; margin-left: 4px; flex-shrink: 0; }
.bp-item-row:hover .bp-item-edit { color: var(--ink); }
.bp-empty {
  text-align: center; padding: 36px 24px; color: var(--ink-muted); font-size: 13px;
  font-style: italic;
}

/* ── Modal ─────────────────────────────────────────────────────────────── */
.bp-modal-bd {
  position: fixed; inset: 0; z-index: 900; background: rgba(10,10,10,0.45);
  display: flex; align-items: center; justify-content: center;
  padding: 20px; box-sizing: border-box;
}
.bp-modal {
  background: var(--surface, #FAFAF8); border: 1px solid var(--border);
  border-radius: 16px; width: 100%; max-width: 640px; max-height: 88vh;
  display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,0.18);
}
.bp-modal-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 18px; border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.bp-modal-title {
  font-family: 'Space Grotesk', sans-serif; font-size: 13px;
  font-weight: 600; letter-spacing: -0.01em; color: var(--ink);
}
.bp-modal-x {
  background: none; border: none; font-size: 14px; cursor: pointer;
  color: var(--ink-muted); min-width: 30px; min-height: 30px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 6px; flex-shrink: 0;
}
.bp-modal-x:hover { background: var(--bg-deep); color: var(--ink); }
.bp-modal-body { flex: 1; overflow-y: auto; overscroll-behavior: contain; min-height: 0; }
.bp-modal-section { padding: 14px 18px; border-bottom: 1px solid var(--border); }
.bp-modal-section:last-child { border-bottom: none; }
.bp-modal-grid-3 { display: grid; grid-template-columns: 1fr 1fr auto; gap: 12px; }
.bp-modal-label {
  display: block; font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 6px;
}
.bp-modal-hint { display: block; font-size: 11px; color: var(--ink-muted); margin-top: 5px; }
.bp-allergen-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; }
.bp-allergen-row {
  display: flex; align-items: center; gap: 8px; min-height: 40px;
  padding: 4px 8px; cursor: pointer; border-radius: 6px;
}
.bp-allergen-row:hover { background: color-mix(in srgb, var(--petrol, #14616E) 6%, transparent); }
.bp-allergen-cb { width: 16px; height: 16px; accent-color: var(--petrol, #14616E); cursor: pointer; flex-shrink: 0; }
.bp-allergen-row span { font-size: 12px; color: var(--ink); }
.bp-diet-flags { display: flex; flex-direction: column; gap: 4px; }
.bp-modal-foot {
  display: flex; align-items: center; justify-content: space-between;
  padding: 11px 18px; border-top: 1px solid var(--border);
  flex-shrink: 0; background: var(--surface); border-radius: 0 0 14px 14px;
}
@media (max-width: 834px) { .bp-modal { max-height: 92vh; } .bp-modal-grid-3 { grid-template-columns: 1fr 1fr; } }
@media (min-width: 600px) { .bp-allergen-grid { grid-template-columns: repeat(3, 1fr); } }

/* ── Eve Aurora Button ──────────────────────────────────────────────────── */
@keyframes bf-aurora-flow { to { background-position: 280% 0 } }
@keyframes bf-aurora-twinkle { 0%,100%{transform:scale(1) rotate(0deg);opacity:1}50%{transform:scale(1.35) rotate(90deg);opacity:.7} }
.bf-eve-btn {
  border: 0; cursor: pointer; flex-shrink: 0;
  font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.05em; text-transform: uppercase;
  padding: 8px 13px; border-radius: 9px; display: inline-flex; align-items: center; gap: 7px; white-space: nowrap;
  color: #fff;
  background: linear-gradient(115deg, #14616E 0%, #1AA0B0 34%, #5B7CE0 68%, #14616E 100%);
  background-size: 280% 100%;
  animation: bf-aurora-flow 6s linear infinite;
  box-shadow: 0 4px 14px rgba(20,97,110,.32);
  transition: transform .15s, box-shadow .2s;
}
.bf-eve-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 22px rgba(45,91,208,.4); animation-duration: 2.2s; }
.bf-eve-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; animation-play-state: paused; }
.bf-eve-spk { animation: bf-aurora-twinkle 2.4s ease-in-out infinite; flex-shrink: 0; }

/* ── Eve Overlay / Modal ────────────────────────────────────────────────── */
.bf-eve-overlay { position: fixed; inset: 0; background: rgba(10,10,10,.45); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 20px; }
.bf-eve-modal { background: var(--surface, #fff); border-radius: 20px; padding: 28px; width: 100%; max-width: 480px; box-shadow: 0 20px 60px rgba(10,10,10,.18); }
.bf-eve-mhd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.bf-eve-mhd-title { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 15px; color: var(--petrol, #14616E); display: inline-flex; align-items: center; gap: 7px; }
.bf-eve-close { background: none; border: none; font-size: 16px; cursor: pointer; color: var(--ink-muted, #888); padding: 2px 6px; line-height: 1; }
.bf-eve-close:disabled { opacity: .4; cursor: default; }
.bf-eve-ta { width: 100%; box-sizing: border-box; resize: vertical; min-height: 80px; font-size: 13px; }
.bf-eve-result { font-size: 13px; color: var(--ink); white-space: pre-wrap; line-height: 1.6; background: var(--bg-deep, #F5F4F2); border-radius: 10px; padding: 14px 16px; margin-top: 14px; }
.bf-eve-err { font-size: 12px; color: #b91c1c; margin: 10px 0 0; }
.bf-eve-mft { display: flex; gap: 10px; justify-content: flex-end; margin-top: 16px; }
.bf-eve-cancel { background: none; border: 1px solid var(--border, #E5E4E0); border-radius: 8px; padding: 6px 14px; font-size: 13px; cursor: pointer; color: var(--ink-muted, #666); }
.bf-eve-cancel:hover:not(:disabled) { background: var(--bg-deep, #F5F4F2); }
.bf-eve-cancel:disabled { opacity: .5; cursor: default; }
</style>

<div class="settings-page" x-data="bfPage()" @bf-eve-open="openEve($event.detail.target)">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.breakfast', lang)}</span>
  </nav>

  <section class="settings-hero">
    <h1 class="settings-hero__title" set:html={bt('bf.hero.title', lang)}></h1>
    <p class="settings-hero__sub">{bt('bf.hero.sub', lang)}</p>
  </section>

  {message && (
    <script is:inline define:vars={{ m: message.text, t: message.type === 'success' ? 'success' : 'error' }}>
      window.addEventListener('DOMContentLoaded', function () { window.retahaToast && window.retahaToast(m, t); });
    </script>
  )}

  <div class="bf-wrap">

    <!-- 01 Modul-Status -->
    <div class="bf-card">
      <div class="bf-card-head">
        <span class="bf-card-title">{bt('bf.hero.eyebrow', lang)}</span>
      </div>
      <p class="bf-hint" style="margin-bottom:14px">{bt('si.mod.hint', lang)}</p>
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <ModStatusLed on={breakfastOn} />
        <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
      </div>
    </div>

    <!-- 02 Zeiten (Wochentage) -->
    <div class="bf-card" x-data="hoursSection()">
      <div class="bf-card-head">
        <span class="bf-card-title">{bt('bf.hours.title', lang)}</span>
      </div>
      <p class="bf-hint" style="margin-bottom:14px">{bt('bf.hours.hint', lang)}</p>

      <div class="bp-hours-grid">
        <template x-for="d in days" :key="d.key">
          <div class="bp-hours-row" :class="{'bp-hours-row--closed': hours[d.key].closed}">
            <span class="bp-hours-day" x-text="d.label"></span>
            <div class="bp-hours-inputs">
              <input type="time" class="s-input s-input--time"
                x-show="!hours[d.key].closed"
                :value="hours[d.key].start"
                @change="hours[d.key].start = $event.target.value" />
              <span class="bp-hours-sep" x-show="!hours[d.key].closed">–</span>
              <input type="time" class="s-input s-input--time"
                x-show="!hours[d.key].closed"
                :value="hours[d.key].end"
                @change="hours[d.key].end = $event.target.value" />
              <span x-show="hours[d.key].closed" class="bp-hours-closed-txt">{bt('si.hours.closed', lang)}</span>
            </div>
            <label class="toggle-row" style="margin:0;gap:6px">
              <input type="checkbox"
                :checked="hours[d.key].closed"
                @change="hours[d.key].closed = $event.target.checked"
                class="sr-only" />
              <span class="bt-visual" :class="{'is-checked': hours[d.key].closed}">
                <span class="bt-knob"></span>
              </span>
              <span class="toggle-label" style="font-size:11px;color:var(--ink-muted)">{bt('si.hours.closetoggle', lang)}</span>
            </label>
          </div>
        </template>
      </div>

      <div style="margin-bottom:16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        <button type="button" @click="copyMonToAll()" class="bf-cta bf-cta--ghost">{bt('si.hours.copyall', lang)}</button>
        <span class="bf-hint" style="margin-top:0">{bt('si.hours.copyallhint', lang)}</span>
      </div>

      <div class="bf-field">
        <span class="bf-label">{bt('conf.times.slot', lang)}</span>
        {isLite ? (
          <div class="bf-locked-ctrl" aria-disabled="true">
            <span class="bf-lock-chip">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              PRO
            </span>
            <div class="bf-locked-inner" aria-hidden="true">
              <div class="bp-slot-stepper">
                <button type="button" class="bp-slot-step-btn" disabled tabindex="-1">−</button>
                <input type="number" value={slotMinutes} disabled tabindex="-1" class="s-input" style="text-align:center;width:64px;border-radius:0;border-left:none;border-right:none;-moz-appearance:textfield" />
                <button type="button" class="bp-slot-step-btn" disabled tabindex="-1">+</button>
              </div>
            </div>
            <p class="bf-lock-info">
              Buchbare Frühstücks-Slots sind Teil der vollen Suite. In Lite zeigst du die Frühstückszeiten als Info.
              <a href="/subscription">Vertrieb kontaktieren →</a>
            </p>
          </div>
        ) : (
          <>
            <div class="bp-slot-stepper">
              <button type="button" class="bp-slot-step-btn"
                @click="slotMinutes = Math.max(5, slotMinutes - 5)"
                aria-label={bt('bf.slot.less', lang)}>−</button>
              <input type="number" id="bf-slot"
                x-model.number="slotMinutes" min="5" max="120" step="5"
                class="s-input" inputmode="numeric" />
              <button type="button" class="bp-slot-step-btn"
                @click="slotMinutes = Math.min(120, slotMinutes + 5)"
                aria-label={bt('bf.slot.more', lang)}>+</button>
            </div>
            <span class="bf-hint">{bt('bf.slot.hint', lang)}</span>
          </>
        )}
      </div>

      <div class="bf-card-foot">
        <button type="button" @click="save()" :disabled="saving" class="bf-cta">{bt('common.save', lang)}</button>
      </div>
    </div>

    <!-- 03 Ort -->
    <div class="bf-card" x-data={`sectionSave({ initial: ${JSON.stringify({ location_de: locationDe })}, section: 'location' })`}>
      <div class="bf-card-head">
        <span class="bf-card-title">{bt('bf.location.title', lang)}</span>
        <button type="button" class="bf-eve-btn" @click="$dispatch('bf-eve-open', { target: 'location' })">
          <svg class="bf-eve-spk" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
          Mit Eve hinzufügen
        </button>
      </div>
      <div class="bf-field">
        <input type="text" id="bf-location" name="location_de" x-model="data.location_de"
          placeholder="z.B. im Wintergarten" class="s-input" style="width:100%;box-sizing:border-box" />
        <span class="bf-hint">{bt('bf.location.hint', lang)}</span>
      </div>
      <div class="bf-card-foot">
        <button type="button" @click="save()" :disabled="saving" class="bf-cta">{bt('common.save', lang)}</button>
      </div>
    </div>

    <!-- 04 Inklusiv -->
    <div class="bf-card" x-data={`sectionSave({ initial: ${JSON.stringify({ included_de: includedDe })}, section: 'included' })`}>
      <div class="bf-card-head">
        <span class="bf-card-title">{bt('bf.included.title', lang)}</span>
        <button type="button" class="bf-eve-btn" @click="$dispatch('bf-eve-open', { target: 'included' })">
          <svg class="bf-eve-spk" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
          Mit Eve hinzufügen
        </button>
      </div>
      <div class="bf-field">
        <textarea id="bf-included" name="included_de" rows="3" x-model="data.included_de"
          placeholder="z.B. Frische Backwaren, regionaler Honig, Bio-Eier, …"
          class="s-input" style="width:100%;box-sizing:border-box"
          @input="$el.style.height='auto';$el.style.height=$el.scrollHeight+'px'"></textarea>
        <span class="bf-hint">{bt('bf.included.hint', lang)}</span>
      </div>
      <div class="bf-card-foot">
        <button type="button" @click="save()" :disabled="saving" class="bf-cta">{bt('common.save', lang)}</button>
      </div>
    </div>

    <!-- 05 Preis -->
    <div class="bf-card" x-data={`sectionSave({ initial: ${JSON.stringify({ breakfast_price_cents: priceCents !== null ? (priceCents / 100).toFixed(2).replace('.', ',') : '' })}, section: 'price' })`}>
      <div class="bf-card-head">
        <span class="bf-card-title">{bt('bf.price.title', lang)}</span>
      </div>
      <div class="bf-field">
        <span class="bf-label">{bt('bf.price.label', lang)}</span>
        <div style="display:flex;align-items:center;gap:8px">
          <input type="text" id="bf-price" name="breakfast_price_cents"
            x-model="data.breakfast_price_cents"
            inputmode="decimal" placeholder="leer = kein Preis"
            class="s-input" style="max-width:180px" />
          <span style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-muted)">{currencySymbol}</span>
        </div>
        <span class="bf-hint">{bt('bf.price.hint', lang)}</span>
      </div>
      <div class="bf-card-foot">
        <button type="button" @click="save()" :disabled="saving" class="bf-cta">{bt('common.save', lang)}</button>
      </div>
    </div>

    <!-- 06 Zimmerservice -->
    {isLite ? (
      <div class="bf-card">
        <div class="bf-card-head">
          <span class="bf-card-title">{bt('bf.rs.title', lang)}</span>
        </div>
        <div class="bf-locked-ctrl" aria-disabled="true">
          <span class="bf-lock-chip">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            PRO
          </span>
          <div class="bf-locked-inner" aria-hidden="true">
            <p class="bf-hint" style="margin-bottom:14px">{bt('bf.rs.hint', lang)}</p>
            <label class="toggle-row" style="pointer-events:none">
              <span class="bt-visual"><span class="bt-knob"></span></span>
              <span class="toggle-label">{bt('bf.rs.toggle', lang)}</span>
            </label>
          </div>
          <p class="bf-lock-info">
            Gäste aufs Zimmer bestellen zu lassen ist Teil der vollen Suite.
            <a href="/subscription">Vertrieb kontaktieren →</a>
          </p>
        </div>
      </div>
    ) : (
      <div class="bf-card" x-data={`sectionSave({ initial: ${JSON.stringify({ breakfast_room_service_enabled: roomServiceOn ? 'true' : 'false', breakfast_room_service_fee_cents: (roomServiceFee / 100).toFixed(2).replace('.', ',') })}, section: 'room_service' })`}>
        <div class="bf-card-head">
          <span class="bf-card-title">{bt('bf.rs.title', lang)}</span>
        </div>
        <p class="bf-hint" style="margin-bottom:14px">{bt('bf.rs.hint', lang)}</p>

        <label class="toggle-row">
          <input type="checkbox"
            :checked="data.breakfast_room_service_enabled === 'true'"
            @change="data.breakfast_room_service_enabled = $event.target.checked ? 'true' : 'false'"
            class="sr-only" />
          <span class="bt-visual" :class="{'is-checked': data.breakfast_room_service_enabled === 'true'}">
            <span class="bt-knob"></span>
          </span>
          <span class="toggle-label">{bt('bf.rs.toggle', lang)}</span>
        </label>

        <div x-show="data.breakfast_room_service_enabled === 'true'" class="bp-fee-section"
             style={roomServiceOn ? '' : 'display:none'}>
          <div class="bf-field">
            <span class="bf-label">{bt('bf.rs.fee', lang)}</span>
            <div style="display:flex;align-items:center;gap:8px">
              <input type="text" id="rs-fee" name="breakfast_room_service_fee_cents"
                x-model="data.breakfast_room_service_fee_cents"
                inputmode="decimal" class="s-input" style="max-width:180px"
                placeholder="0,00" />
              <span style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-muted)">{currencySymbol}</span>
            </div>
            <span class="bf-hint">{bt('bf.rs.feehint', lang)}</span>
          </div>
        </div>

        <div class="bf-card-foot">
          <button type="button" @click="save()" :disabled="saving" class="bf-cta">{bt('common.save', lang)}</button>
        </div>
      </div>
    )}

    <!-- 07 Speisekarte -->
    <div class="bf-card" id="speisekarte">
      <div class="bf-card-head">
        <span class="bf-card-title" set:html={bt('bf.menu.title', lang)}></span>
        <div style="display:flex;gap:8px;align-items:center;flex-shrink:0">
          {hasMews && (
            <form method="POST" style="display:inline">
              <input type="hidden" name="_action" value="mews_import" />
              <button type="submit"
                onclick={`return confirm(${JSON.stringify(bt('bf.menu.mewsconfirm', lang))})`}
                class="bf-cta bf-cta--ghost">{bt('bf.menu.frommews', lang)}</button>
            </form>
          )}
          <button type="button" class="bf-eve-btn" @click="openEve('allergen')">
            <svg class="bf-eve-spk" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
            Allergene vorschlagen
          </button>
          <button type="button" @click="openNew()" class="bf-cta">{bt('bf.menu.new', lang)}</button>
        </div>
      </div>

      <template x-if="groupedItems.length === 0">
        <div class="bp-empty">
          <p>{bt('bf.menu.empty', lang)}</p>
          <button type="button" @click="openNew()" class="bf-cta" style="margin-top:14px">{bt('bf.menu.first', lang)}</button>
        </div>
      </template>
      <template x-if="groupedItems.length > 0">
        <div>
          <template x-for="group in groupedItems" :key="group.cat">
            <div class="bp-item-group">
              <div class="bp-item-cat" x-text="group.cat"></div>
              <div class="bp-item-list">
                <template x-for="item in group.items" :key="item.id">
                  <div class="bp-item-row"
                    :class="{'is-drag-over': dragTarget && dragTarget.id === item.id, 'is-dragging': dragItem && dragItem.id === item.id}"
                    :data-item-id="item.id">
                    <span class="bp-drag-handle"
                      @click.stop
                      @pointerdown="dndPtrDown($event, item)"
                      aria-label={bt('bf.menu.draghandle', lang)}>
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
                        <circle cx="5" cy="4" r="1.5"/><circle cx="11" cy="4" r="1.5"/>
                        <circle cx="5" cy="8" r="1.5"/><circle cx="11" cy="8" r="1.5"/>
                        <circle cx="5" cy="12" r="1.5"/><circle cx="11" cy="12" r="1.5"/>
                      </svg>
                    </span>
                    <button type="button" class="bp-item-content" @click="openEdit(item)">
                      <span class="bp-item-dot" :class="item.is_active ? 'bp-item-dot--on' : ''"></span>
                      <div class="bp-item-info">
                        <span class="bp-item-name" x-text="item.name_de"></span>
                        <span class="bp-item-desc" x-show="item.description_de" x-text="item.description_de || ''"></span>
                      </div>
                      <div class="bp-item-meta">
                        <template x-if="item.is_vegan"><span class="bp-badge">vegan</span></template>
                        <template x-if="!item.is_vegan && item.is_vegetarian"><span class="bp-badge">veg</span></template>
                        <template x-if="item.is_organic"><span class="bp-badge">bio</span></template>
                        <span x-show="item.price_cents > 0" class="bp-item-price" x-text="formatEur(item.price_cents)"></span>
                      </div>
                      <span class="bp-item-edit">{bt('bf.menu.edititem', lang)}</span>
                    </button>
                  </div>
                </template>
              </div>
            </div>
          </template>
        </div>
      </template>

      <div class="s-warning-row" style="margin-top:16px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             width="16" height="16" aria-hidden="true" style="flex-shrink:0">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
        </svg>
        <span set:html={bt('bf.lmiv', lang)}></span>
      </div>
    </div>

  </div><!-- /.bf-wrap -->

  <!-- ── Modal Backdrop ──────────────────────────────────────────────────── -->
  <div x-show="modalOpen" x-cloak class="bp-modal-bd" @click.self="closeModal()">
    <div class="bp-modal" role="dialog" aria-modal="true" @click.stop>

      <div class="bp-modal-head">
        <h3 class="bp-modal-title" x-text={`modalIsNew ? ${JSON.stringify(bt('bf.menu.new2', lang))} : (modalItem.name_de || ${JSON.stringify(bt('bf.modal.edit', lang))})`}></h3>
        <button type="button" @click="closeModal()" class="bp-modal-x" aria-label={bt('common.close', lang)}>✕</button>
      </div>

      <div class="bp-modal-body">

        <div x-show="modalError" x-cloak style="padding:12px 22px 0">
          <div class="s-flash s-flash--err" style="margin-bottom:0" x-text="modalError"></div>
        </div>

        <!-- Allgemein -->
        <div class="bp-modal-section">
          <div class="bp-modal-grid-3">
            <div>
              <span class="bp-modal-label">{bt('bf.modal.category', lang)}</span>
              <input type="text" x-model="modalItem.category" placeholder="z.B. Brot, Warm" class="s-input" style="width:100%;box-sizing:border-box" />
            </div>
            <div>
              <span class="bp-modal-label">{bt('bf.modal.priceeur', lang)}</span>
              <input type="number" x-model="modalItem.price_eur" min="0" step="0.01" placeholder="0,00" class="s-input" inputmode="decimal" style="width:100%;box-sizing:border-box" />
              <span class="bp-modal-hint">{bt('bf.modal.pricehint', lang)}</span>
            </div>
            <div>
              <span class="bp-modal-label">{bt('bf.modal.active', lang)}</span>
              <label class="toggle-row" style="margin-top:2px">
                <input type="checkbox" x-model="modalItem.is_active" class="sr-only" />
                <span class="bt-visual" :class="{'is-checked': modalItem.is_active}">
                  <span class="bt-knob"></span>
                </span>
              </label>
            </div>
          </div>
        </div>

        <!-- Name -->
        <div class="bp-modal-section">
          <span class="bp-modal-label">{bt('bf.modal.namede', lang)}</span>
          <input type="text" x-model="modalItem.name_de" placeholder="z.B. Roggen-Sauerteigbrot" class="s-input" style="width:100%;box-sizing:border-box" />
          <span class="bp-modal-hint">{bt('bf.modal.namehint', lang)}</span>
        </div>

        <!-- Beschreibung -->
        <div class="bp-modal-section">
          <span class="bp-modal-label">{bt('bf.modal.desc', lang)}</span>
          <textarea x-model="modalItem.description_de" rows="2"
            placeholder="z.B. Hausgemacht aus regionalen Zutaten"
            class="s-input" style="width:100%;box-sizing:border-box"></textarea>
          <span class="bp-modal-hint">{bt('bf.modal.deschint', lang)}</span>
        </div>

        <!-- 14 Allergene -->
        <div class="bp-modal-section">
          <div class="bp-allergen-grid">
            <template x-for="a in allergens" :key="a.key">
              <label class="bp-allergen-row">
                <input type="checkbox" x-model="modalItem['contains_' + a.key]" class="bp-allergen-cb" />
                <span x-text="a.label_de"></span>
              </label>
            </template>
          </div>
        </div>

        <!-- Diät-Flags -->
        <div class="bp-modal-section">
          <span class="bp-modal-label" style="display:block;margin-bottom:10px">{bt('bf.modal.dietflags', lang)}</span>
          <div class="bp-diet-flags">
            <label class="toggle-row">
              <input type="checkbox" x-model="modalItem.is_vegetarian" class="sr-only" />
              <span class="bt-visual" :class="{'is-checked': modalItem.is_vegetarian}"><span class="bt-knob"></span></span>
              <span class="toggle-label">{bt('bf.diet.vegetarian', lang)}</span>
            </label>
            <label class="toggle-row">
              <input type="checkbox" x-model="modalItem.is_vegan" class="sr-only" />
              <span class="bt-visual" :class="{'is-checked': modalItem.is_vegan}"><span class="bt-knob"></span></span>
              <span class="toggle-label">{bt('bf.diet.vegan', lang)}</span>
            </label>
            <label class="toggle-row">
              <input type="checkbox" x-model="modalItem.is_organic" class="sr-only" />
              <span class="bt-visual" :class="{'is-checked': modalItem.is_organic}"><span class="bt-knob"></span></span>
              <span class="toggle-label">{bt('bf.diet.organic', lang)}</span>
            </label>
          </div>
        </div>

      </div><!-- .bp-modal-body -->

      <div class="bp-modal-foot">
        <div>
          <button type="button" x-show="!modalIsNew" x-cloak @click="deleteItem()"
            :disabled="modalSaving" class="bf-cta bf-cta--danger">{bt('nfc.delete', lang)}</button>
        </div>
        <div style="display:flex;gap:8px">
          <button type="button" @click="closeModal()" class="bf-cta bf-cta--ghost">{bt('common.cancel', lang)}</button>
          <button type="button" @click="saveItem()" :disabled="modalSaving" class="bf-cta">
            <span x-show="!modalSaving">{bt('common.save', lang)}</span>
            <span x-show="modalSaving" x-cloak>{bt('bf.modal.saving', lang)}</span>
          </button>
        </div>
      </div>

    </div><!-- .bp-modal -->
  </div><!-- .bp-modal-bd -->

  <!-- ── Eve-Overlay ────────────────────────────────────────────────────── -->
  <div class="bf-eve-overlay" x-show="eve.open" x-cloak
    @click.self="if(!eve.loading) eve.open = false"
    @keydown.escape.window="if(eve.open && !eve.loading) eve.open = false">
    <div class="bf-eve-modal">
      <div class="bf-eve-mhd">
        <span class="bf-eve-mhd-title">
          <svg class="bf-eve-spk" width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor" style="color:#14616E"/></svg>
          <span x-text="eve.target === 'location' ? 'Frühstücksort' : eve.target === 'included' ? 'Was ist inklusiv?' : 'Allergene vorschlagen'"></span>
        </span>
        <button type="button" class="bf-eve-close" @click="eve.open = false" :disabled="eve.loading">✕</button>
      </div>
      <template x-if="!eve.result">
        <div>
          <template x-if="eve.target !== 'allergen'">
            <textarea class="s-input bf-eve-ta" x-model="eve.prompt"
              :placeholder="eve.target === 'location' ? 'z.B. Heller Wintergarten, EG links' : 'z.B. Backwaren, regionale Produkte, Bio-Eier'"
              :disabled="eve.loading"
              @keydown.meta.enter.prevent="runEve()"
              @keydown.ctrl.enter.prevent="runEve()"></textarea>
          </template>
          <template x-if="eve.target === 'allergen'">
            <p style="font-size:13px;color:var(--ink-muted);line-height:1.55;margin:0 0 4px">
              Eve analysiert alle Speisen auf Basis ihrer Namen und Beschreibungen und trägt die EU-Hauptallergene automatisch ein.
            </p>
          </template>
          <div class="bf-eve-err" x-show="eve.error" x-cloak x-text="eve.error"></div>
          <div class="bf-eve-mft">
            <button type="button" class="bf-eve-cancel" @click="eve.open = false" :disabled="eve.loading">Abbrechen</button>
            <button type="button" class="bf-eve-btn" @click="runEve()"
              :disabled="eve.loading || (eve.target !== 'allergen' && !eve.prompt.trim())">
              <svg class="bf-eve-spk" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
              <span x-text="eve.loading ? 'Eve denkt …' : 'Mit Eve generieren'"></span>
            </button>
          </div>
        </div>
      </template>
      <template x-if="eve.result">
        <div>
          <pre class="bf-eve-result" x-text="eve.result"></pre>
          <div class="bf-eve-mft">
            <button type="button" class="bf-eve-cancel" @click="eve.result = ''; eve.open = false">Schließen</button>
          </div>
        </div>
      </template>
    </div>
  </div>

</div><!-- .settings-page -->

<script>
  document.addEventListener('alpine:init', () => {

    Alpine.data('hoursSection', () => {
      const init = window._hoursInit || {};
      const dl = init.dayLabels || {};
      const t = init.t || {};
      return {
        hours: init.hours || {},
        slotMinutes: parseInt(init.slotMinutes) || 30,
        saving: false,
        success: false,
        error: '',
        _origStr: '',
        _timer: null,
        _beforeUnload: null,

        days: [
          { key: 'mon', label: dl.mon || 'Mo' },
          { key: 'tue', label: dl.tue || 'Di' },
          { key: 'wed', label: dl.wed || 'Mi' },
          { key: 'thu', label: dl.thu || 'Do' },
          { key: 'fri', label: dl.fri || 'Fr' },
          { key: 'sat', label: dl.sat || 'Sa' },
          { key: 'sun', label: dl.sun || 'So' },
        ],

        init() {
          this._origStr = JSON.stringify({ hours: this.hours, slotMinutes: this.slotMinutes });
          this._beforeUnload = (e) => {
            if (this.isDirty) { e.preventDefault(); e.returnValue = ''; }
          };
          window.addEventListener('beforeunload', this._beforeUnload);
        },

        destroy() {
          if (this._beforeUnload) window.removeEventListener('beforeunload', this._beforeUnload);
        },

        get isDirty() {
          return JSON.stringify({ hours: this.hours, slotMinutes: this.slotMinutes }) !== this._origStr;
        },

        copyMonToAll() {
          const src = this.hours['mon'];
          if (!src || src.closed) return;
          this.days.forEach(d => {
            this.hours[d.key] = { ...this.hours[d.key], start: src.start, end: src.end };
          });
        },

        async save() {
          if (!this.isDirty || this.saving) return;
          this.saving = true;
          this.success = false;
          this.error = '';
          if (this._timer) clearTimeout(this._timer);
          try {
            const res = await fetch('/api/admin/breakfast/section', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                section: 'hours',
                breakfast_hours: this.hours,
                breakfast_slot_minutes: this.slotMinutes,
              }),
            });
            const d = await res.json();
            if (!d.ok) { this.error = d.error || t.error; window.retahaToast?.(this.error, 'error'); return; }
            this._origStr = JSON.stringify({ hours: this.hours, slotMinutes: this.slotMinutes });
            window.retahaToast?.(t.saved);
          } catch (err) {
            this.error = t.netErr;
          } finally {
            this.saving = false;
          }
        },
      };
    });

    Alpine.data('bfPage', () => ({
      items: (window._bfInit || {}).items || [],
      allergens: (window._bfInit || {}).allergens || [],
      t: (window._bfInit || {}).t || {},
      modalOpen: false,
      modalIsNew: false,
      modalItem: {},
      modalSaving: false,
      modalError: '',
      eve: { open: false, loading: false, prompt: '', target: '', error: '', result: '' },
      _toastTimer: null,

      // Drag & Drop state
      dragItem: null,
      dragTarget: null,
      _ptrItem: null,
      _ptrMoveHandler: null,
      _ptrUpHandler: null,

      get groupedItems() {
        const sorted = [...this.items].sort((a, b) => (a.display_order ?? 0) - (b.display_order ?? 0));
        const groups = {};
        for (const item of sorted) {
          const cat = item.category || this.t.noCat;
          if (!groups[cat]) groups[cat] = [];
          groups[cat].push(item);
        }
        return Object.keys(groups).map(cat => ({ cat, items: groups[cat] }));
      },

      formatEur(cents) {
        const cur = (window._bfInit || {}).currency || 'EUR';
        const loc = (window._bfInit || {}).lang || 'de';
        return (cents / 100).toLocaleString(loc, { style: 'currency', currency: cur });
      },

      openNew() {
        this.modalIsNew = true;
        const defaults = {};
        this.allergens.forEach(a => { defaults['contains_' + a.key] = false; });
        this.modalItem = Object.assign({
          id: null, name_de: '', description_de: '', category: '',
          price_eur: '0.00', display_order: this.items.length,
          is_active: true, is_vegetarian: false, is_vegan: false, is_organic: false,
        }, defaults);
        this.modalError = '';
        this.modalOpen = true;
      },

      openEdit(item) {
        this.modalIsNew = false;
        this.modalItem = Object.assign({}, item, {
          price_eur: ((item.price_cents != null ? item.price_cents : 0) / 100).toFixed(2),
        });
        this.modalError = '';
        this.modalOpen = true;
      },

      closeModal() {
        this.modalOpen = false;
      },

      openEve(target) {
        this.eve.target = target;
        this.eve.error = '';
        this.eve.result = '';
        if (target === 'allergen') {
          this.eve.prompt = this.items.map(i => i.name_de + (i.description_de ? ` (${i.description_de})` : '')).filter(Boolean).join('\n');
        } else {
          this.eve.prompt = '';
        }
        this.eve.open = true;
      },

      async runEve() {
        if (this.eve.loading) return;
        if (this.eve.target !== 'allergen' && !this.eve.prompt.trim()) return;
        this.eve.loading = true;
        this.eve.error = '';
        try {
          if (this.eve.target === 'allergen') {
            const res = await fetch('/api/admin/breakfast/eve-allergens', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
            });
            const rawText = await res.text();
            let d: any;
            try { d = JSON.parse(rawText); } catch { d = { ok: false, message: `Server-Fehler ${res.status}: ${rawText.slice(0, 120)}` }; }
            if (!d.ok) { this.eve.error = d.message || `Fehler (Status ${res.status})`; return; }
            this.items = d.items || this.items;
            this.eve.open = false;
            (window as any).retahaToast?.(`Eve hat ${d.updated} Speise${d.updated === 1 ? '' : 'n'} mit Allergenen versehen`);
          } else {
            const res = await fetch('/api/admin/eve/generate-field', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ field: this.eve.target, prompt: this.eve.prompt }),
            });
            const d = await res.json();
            if (!d.ok) { this.eve.error = d.message || 'Fehler bei der KI-Generierung.'; return; }
            const fieldId = this.eve.target === 'location' ? 'bf-location' : 'bf-included';
            const el = document.getElementById(fieldId);
            if (el) { el.value = d.text; el.dispatchEvent(new Event('input', { bubbles: true })); }
            this.eve.open = false;
          }
        } catch (err) {
          this.eve.error = 'Netzwerk-Fehler: ' + (err.message || 'Unbekannt');
        } finally {
          this.eve.loading = false;
        }
      },

      async saveItem() {
        const nameDe = this.modalItem.name_de ? this.modalItem.name_de.trim() : '';
        if (!nameDe) { this.modalError = this.t.nameRequired; return; }
        this.modalSaving = true;
        this.modalError = '';
        try {
          const priceVal = parseFloat(String(this.modalItem.price_eur).replace(',', '.') || '0');
          const priceCents = Math.max(0, isNaN(priceVal) ? 0 : Math.round(priceVal * 100));
          const allergens = {};
          this.allergens.forEach(a => { allergens['contains_' + a.key] = !!this.modalItem['contains_' + a.key]; });
          const payload = Object.assign({
            name_de: nameDe,
            description_de: (this.modalItem.description_de || '').trim() || null,
            category: (this.modalItem.category || '').trim() || null,
            price_cents: priceCents,
            display_order: Number(this.modalItem.display_order) || 0,
            is_active: !!this.modalItem.is_active,
            is_vegetarian: !!this.modalItem.is_vegetarian,
            is_vegan: !!this.modalItem.is_vegan,
            is_organic: !!this.modalItem.is_organic,
          }, allergens);
          if (!this.modalIsNew) payload.id = this.modalItem.id;
          const res = await fetch('/api/admin/breakfast/item', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) { this.modalError = data.error || this.t.saveFail; return; }
          if (this.modalIsNew) {
            this.items.push(data.item);
          } else {
            const idx = this.items.findIndex(i => i.id === data.item.id);
            if (idx >= 0) this.items.splice(idx, 1, data.item);
            else this.items.push(data.item);
          }
          this.closeModal();
          this.showToast(this.modalIsNew ? this.t.itemCreated : this.t.itemSaved, 'ok');
        } catch (err) {
          this.modalError = this.t.netErr + ': ' + (err && err.message ? err.message : String(err));
        } finally {
          this.modalSaving = false;
        }
      },

      async deleteItem() {
        if (!confirm(this.t.deleteConfirm)) return;
        this.modalSaving = true;
        this.modalError = '';
        try {
          const res = await fetch('/api/admin/breakfast/item', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: this.modalItem.id }),
          });
          const data = await res.json();
          if (!data.ok) { this.modalError = data.error || this.t.deleteFail; return; }
          this.items = this.items.filter(i => i.id !== this.modalItem.id);
          this.closeModal();
          this.showToast(this.t.itemDeleted, 'ok');
        } catch (err) {
          this.modalError = this.t.netErr + ': ' + (err && err.message ? err.message : String(err));
        } finally {
          this.modalSaving = false;
        }
      },

      // ── Drag & Drop (Pointer Events, window-listener — kein setPointerCapture)
      // iOS: setPointerCapture lässt elementFromPoint immer das Handle zurückgeben
      // statt der visuellen Row unter dem Finger → dragTarget wird nie gesetzt.
      // Fix: move+up auf window registrieren, kein capture nötig.
      dndPtrDown(e, item) {
        e.preventDefault();
        this._ptrItem = item;
        this.dragItem = item;
        const pid = e.pointerId;

        this._ptrMoveHandler = (ev) => {
          if (ev.pointerId !== pid) return;
          ev.preventDefault();
          const el = document.elementFromPoint(ev.clientX, ev.clientY);
          const row = el && el.closest('[data-item-id]');
          if (row) {
            const idStr = row.dataset.itemId;
            const target = this.items.find(i => String(i.id) === idStr);
            if (target && String(target.id) !== String(this._ptrItem?.id)) {
              this.dragTarget = target;
            }
          }
        };
        this._ptrUpHandler = (ev) => {
          if (ev.pointerId !== pid) return;
          window.removeEventListener('pointermove', this._ptrMoveHandler);
          window.removeEventListener('pointerup', this._ptrUpHandler);
          window.removeEventListener('pointercancel', this._ptrUpHandler);
          if (this._ptrItem && this.dragTarget) {
            this._dndPerform(this.dragTarget);
          } else {
            this.dragItem = null;
            this.dragTarget = null;
          }
          this._ptrItem = null;
          this._ptrMoveHandler = null;
          this._ptrUpHandler = null;
        };
        window.addEventListener('pointermove', this._ptrMoveHandler, { passive: false });
        window.addEventListener('pointerup', this._ptrUpHandler);
        window.addEventListener('pointercancel', this._ptrUpHandler);
      },
      _dndPerform(target: any) {
        const dragId = this.dragItem?.id;
        if (!dragId) { this.dragItem = null; this.dragTarget = null; return; }
        const fromIdx = this.items.findIndex((i: any) => i.id === dragId);
        const toIdx = this.items.findIndex((i: any) => i.id === target.id);
        if (fromIdx < 0 || toIdx < 0 || fromIdx === toIdx) {
          this.dragItem = null; this.dragTarget = null; return;
        }
        const newItems = [...this.items];
        const [moved] = newItems.splice(fromIdx, 1);
        newItems.splice(toIdx, 0, moved);
        newItems.forEach((item: any, idx: number) => { item.display_order = idx; });
        this.items = newItems;
        this.dragItem = null;
        this.dragTarget = null;
        this._saveOrder(newItems.map((i: any) => i.id));
      },
      async _saveOrder(ids: string[]) {
        try {
          const res = await fetch('/api/admin/breakfast/item', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids }),
          });
          const d = await res.json();
          if (!d.ok) this.showToast(this.t.orderFail + ': ' + (d.error || 'Unbekannt'), 'err');
        } catch {
          this.showToast(this.t.sortErr, 'err');
        }
      },

      showToast(msg: string, kind?: string) {
        (window as any).retahaToast?.(msg, kind === 'err' || kind === 'error' ? 'error' : 'success');
      },
    }));
  });
</script>

</Layout>
