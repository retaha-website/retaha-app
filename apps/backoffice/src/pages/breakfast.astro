                </span>
              </label>
            </div>
          </div>
        </div>

        <!-- Name -->
        <div class="bp-modal-section">
          <div class="field">
            <span class="field__label">{bt('bf.modal.namede', lang)}</span>
            <input type="text" x-model="modalItem.name_de" placeholder="z.B. Roggen-Sauerteigbrot" class="s-input" />
            <span class="field__hint">{bt('bf.modal.namehint', lang)}</span>
          </div>
        </div>

        <!-- Beschreibung -->
        <div class="bp-modal-section">
          <div class="field">
            <span class="field__label">{bt('bf.modal.desc', lang)}</span>
            <textarea x-model="modalItem.description_de" rows="2"
              placeholder="z.B. Hausgemacht aus regionalen Zutaten"
