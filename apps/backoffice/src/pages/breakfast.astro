---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { loadBreakfastItems, EU_ALLERGENS } from '@retaha/db';
import { getMewsClientForHotel } from '../lib/mews/factory';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const supabase = createSupabaseServiceRoleInstance();

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString() || 'save_settings';

  // ── Mews import ──────────────────────────────────────────────────────────────
  if (action === 'mews_import') {
    const mews = await getMewsClientForHotel(hotel.id);
    if (!mews) {
      message = { type: 'error', text: bt('bf.msg.mewsnotconnected', lang) };
    } else {
      try {
        const resp = await mews.getProducts({ Limitation: { Count: 100 } });
        const products = resp.Products ?? [];
        if (products.length === 0) {
          message = { type: 'error', text: bt('bf.msg.mewsnoproducts', lang) };
        } else {
          let imported = 0;
          let skipped = 0;
          for (const p of products) {
            const mewsId = p.Id as string | undefined;
            if (!mewsId) continue;

            const names = (p.Names ?? p.ExternalNames ?? {}) as Record<string, string>;
            const descs = (p.Descriptions ?? {}) as Record<string, unknown>;
            const priceObj = (p.Price ?? p.DefaultPrice ?? {}) as Record<string, unknown>;
            const priceValue = (priceObj.Value ?? priceObj.GrossValue ?? priceObj.NetValue ?? 0) as number;

            const payload: Record<string, unknown> = {
              hotel_id: hotel.id,
              mews_product_id: mewsId,
              name_de: names['de-DE'] || names['en-US'] || names[Object.keys(names)[0]] || mewsId,
              name_en: names['en-US'] || names['en-GB'] || null,
              name_fr: names['fr-FR'] || null,
              name_es: names['es-ES'] || null,
              description_de: (descs['de-DE'] || descs['en-US'] || null) as string | null,
              description_en: (descs['en-US'] || descs['en-GB'] || null) as string | null,
              description_fr: (descs['fr-FR'] || null) as string | null,
              description_es: (descs['es-ES'] || null) as string | null,
              price_cents: Math.round(priceValue * 100),
              is_active: (p.IsActive as boolean | undefined) !== false,
              display_order: 0,
              updated_at: new Date().toISOString(),
            };

            const { error } = await supabase
              .from('breakfast_items')
              .upsert(payload, { onConflict: 'hotel_id,mews_product_id' });

            if (error) {
              skipped++;
            } else {
              imported++;
            }
          }
          const productsWord = imported === 1 ? bt('bf.msg.product.one', lang) : bt('bf.msg.product.many', lang);
          const skippedTxt = skipped > 0 ? bt('bf.msg.mewsskipped', lang).replace('{n}', String(skipped)) : '';
          message = { type: 'success', text: bt('bf.msg.mewsimport', lang).replace('{n}', String(imported)).replace('{products}', productsWord).replace('{skipped}', skippedTxt) };
        }
      } catch (err) {
        message = { type: 'error', text: `${bt('bf.msg.mewsfail', lang)}: ${(err as Error).message}` };
      }
    }
  }

  // Settings sections now save via AJAX (/api/admin/breakfast/section)
}

const { data: settings } = await supabase
  .from('hotel_settings')
  .select(`
    features,
    breakfast_start_time, breakfast_end_time, breakfast_slot_minutes,
    breakfast_hours,
    breakfast_location_i18n, breakfast_included_i18n,
    breakfast_price_cents,
    breakfast_room_service_enabled, breakfast_room_service_fee_cents
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || ({} as Record<string, any>);
const features        = ((s.features as Record<string, unknown>) ?? {});
const breakfastOn     = features.breakfast !== false;
const startTime       = ((s.breakfast_start_time as string | undefined) || '07:30').substring(0, 5);
const endTime         = ((s.breakfast_end_time   as string | undefined) || '10:30').substring(0, 5);
const slotMinutes     = (s.breakfast_slot_minutes as number | undefined) || 30;
const locationDe      = (s.breakfast_location_i18n as any)?.de?.value || '';
const includedDe      = (s.breakfast_included_i18n as any)?.de?.value || '';
const priceCents      = (s.breakfast_price_cents   as number | null | undefined) ?? null;
const roomServiceOn   = (s.breakfast_room_service_enabled as boolean | undefined) === true;
const roomServiceFee  = (s.breakfast_room_service_fee_cents as number | undefined) || 0;

// Build per-weekday hours initial state
const WEEK_DAYS = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'] as const;
const rawBreakfastHours = (s.breakfast_hours as Record<string, any> | null | undefined) ?? null;
const initialHours: Record<string, {start: string; end: string; closed: boolean}> = {};
for (const day of WEEK_DAYS) {
  const bh = rawBreakfastHours?.[day];
  initialHours[day] = {
    start: (bh?.start as string | undefined) || startTime,
    end: (bh?.end as string | undefined) || endTime,
    closed: bh?.closed === true,
  };
}

const items = await loadBreakfastItems(hotel.id);

const { data: hotelRow } = await supabase
  .from('hotels')
  .select('currency')
  .eq('id', hotel.id)
  .maybeSingle();
const hotelCurrency = (hotelRow?.currency as string | undefined) || 'EUR';
const currencySymbol = hotelCurrency === 'CHF' ? 'CHF' : '€';

// Check Mews integration for import button
const { data: mewsRow } = await supabase
  .from('mews_integrations')
  .select('mews_products_count')
  .eq('hotel_id', hotel.id)
  .maybeSingle();
const hasMews = !!mewsRow;

const url = new URL(Astro.request.url);
if (url.searchParams.get('deleted') === '1' && !message) {
  message = { type: 'success', text: bt('bf.js.itemdeleted', lang) };
}

const allergenInit = EU_ALLERGENS.map(a => ({ key: a.key, label_de: a.label_de }));
const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

// Client-Strings für die Alpine-Komponenten
const bfDayLabels = {
  mon: bt('si.day.mon', lang), tue: bt('si.day.tue', lang), wed: bt('si.day.wed', lang),
  thu: bt('si.day.thu', lang), fri: bt('si.day.fri', lang), sat: bt('si.day.sat', lang), sun: bt('si.day.sun', lang),
};
const bfHoursT = {
  error: bt('bf.js.error', lang),
  saved: bt('common.savedshort', lang),
  netErr: bt('bf.js.neterr', lang),
};
const bfPageT = {
  noCat: bt('bf.js.nocat', lang),
  nameRequired: bt('bf.js.namerequired', lang),
  saveFail: bt('bf.js.savefail', lang),
  itemCreated: bt('bf.js.itemcreated', lang),
  itemSaved: bt('bf.js.itemsaved', lang),
  itemDeleted: bt('bf.js.itemdeleted', lang),
  netErr: bt('bf.js.neterr', lang),
  deleteConfirm: bt('bf.js.deleteconfirm', lang),
  deleteFail: bt('bf.js.deletefail', lang),
  orderFail: bt('bf.js.orderfail', lang),
  sortErr: bt('bf.js.sorterr', lang),
};
---

<Layout title="Frühstück" activeTab="backoffice">

<script is:inline define:vars={{ _bfInit: { items, allergens: allergenInit, currency: hotelCurrency, t: bfPageT, lang }, _hoursInit: { hours: initialHours, slotMinutes: String(slotMinutes), dayLabels: bfDayLabels, t: bfHoursT } }}>
  window._bfInit = _bfInit;
  window._hoursInit = _hoursInit;
</script>

<style is:global>
[x-cloak] { display: none !important; }


/* textarea resize + auto-grow */
textarea.s-input { resize: none; min-height: 72px; }

/* iPad touch targets (CC-ADDENDUM) */
.settings-page .toggle-row { min-height: 44px; }

/* v9-btn variants */
.v9-btn:active:not(:disabled) { background: var(--te-yellow, #FFE600) !important; color: #0A0A0A !important; }
.v9-btn--burg { background: #8C2128; color: white; border: none; }
.v9-btn--burg:hover:not(:disabled), .v9-btn--burg:active:not(:disabled) { background: #6E1920 !important; color: white !important; }

/* breakfast-specific */
.bp-time-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
@media (max-width: 600px) { .bp-time-grid { grid-template-columns: 1fr 1fr; } }
.bp-fee-section { padding-top: 16px; border-top: 1px solid var(--border); }

/* items list */
.bp-item-group { margin-bottom: 4px; }
.bp-item-cat { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted); padding: 14px 4px 4px; }
.bp-item-list { border: 1px solid var(--border); border-radius: var(--r-sm, 4px); overflow: hidden; touch-action: none; }
.bp-item-row { display: flex; align-items: center; border-bottom: 1px solid var(--border); transition: background 120ms; }
.bp-item-row:last-child { border-bottom: none; }
.bp-item-row.is-drag-over { background: var(--te-yellow-soft); box-shadow: inset 0 2px 0 var(--te-yellow); }
.bp-item-row.is-dragging { opacity: 0.4; }
.bp-drag-handle { display: flex; align-items: center; justify-content: center; width: 44px; min-height: 52px; flex-shrink: 0; cursor: grab; color: var(--ink-faint); touch-action: none; user-select: none; }
.bp-drag-handle:hover { color: var(--ink-muted); }
.bp-drag-handle:active { cursor: grabbing; }
.bp-drag-handle svg { pointer-events: none; }
.bp-item-content { flex: 1; display: flex; align-items: center; gap: 12px; padding: 12px 16px 12px 0; background: none; border: none; cursor: pointer; text-align: left; min-height: 52px; transition: background 120ms; }
.bp-item-row:hover { background: var(--bg-deep, #F5F4F2); }
.bp-item-row:hover .bp-item-content { background: transparent; }
.bp-item-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border-medium); flex-shrink: 0; }
.bp-item-dot--on { background: #4CAF50; }
.bp-item-info { flex: 1; min-width: 0; }
.bp-item-name { display: block; font-size: 14px; font-weight: 500; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.bp-item-desc { display: block; font-size: 12px; color: var(--ink-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
.bp-item-meta { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.bp-badge { font-size: 10px; background: #E8F5E9; color: #2E7D32; padding: 2px 8px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em; white-space: nowrap; }
.bp-item-price { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-muted); white-space: nowrap; }
.bp-item-edit { font-size: 11px; color: var(--ink-muted); white-space: nowrap; margin-left: 4px; flex-shrink: 0; }
.bp-item-row:hover .bp-item-edit { color: var(--ink); }
.bp-empty { text-align: center; padding: 48px 32px; color: var(--ink-muted); font-size: 14px; font-style: italic; }

/* Hours-Grid (Section 02 Wochentage) */
.bp-hours-grid { border: 1px solid var(--border); border-radius: var(--r-sm, 4px); overflow: hidden; margin-bottom: 16px; }
.bp-hours-row { display: grid; grid-template-columns: 44px 1fr auto; gap: 12px; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); min-height: 52px; }
.bp-hours-row:last-child { border-bottom: none; }
.bp-hours-row--closed { opacity: 0.6; }
.bp-hours-day { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink); }
.bp-hours-inputs { display: flex; align-items: center; gap: 6px; }
.bp-hours-sep { font-size: 13px; color: var(--ink-muted); flex-shrink: 0; }
.bp-hours-closed-txt { font-size: 12px; color: var(--ink-muted); font-style: italic; }
.s-input--time { width: 110px; min-width: 88px; }
@media (max-width: 480px) { .s-input--time { width: 88px; } .bp-hours-row { grid-template-columns: 36px 1fr auto; gap: 8px; padding: 8px 10px; } }

/* Slot-Länge stepper */
.bp-slot-stepper { display: flex; align-items: stretch; }
.bp-slot-stepper .s-input { text-align: center; width: 64px; border-radius: 0; border-left: none; border-right: none; }
.bp-slot-stepper .s-input[type=number] { -moz-appearance: textfield; appearance: textfield; }
.bp-slot-stepper .s-input::-webkit-outer-spin-button,
.bp-slot-stepper .s-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.bp-slot-step-btn { display: flex; align-items: center; justify-content: center; width: 44px; min-height: 44px; border: 1px solid var(--border); background: var(--bg); cursor: pointer; font-size: 18px; line-height: 1; color: var(--ink); flex-shrink: 0; user-select: none; transition: background 120ms; }
.bp-slot-step-btn:first-child { border-radius: var(--r-sm, 4px) 0 0 var(--r-sm, 4px); }
.bp-slot-step-btn:last-child { border-radius: 0 var(--r-sm, 4px) var(--r-sm, 4px) 0; }
.bp-slot-step-btn:active { background: var(--te-yellow, #FFE600) !important; color: #0A0A0A; }

/* LMIV notice — reuses shared s-warning-row style */

/* modal (CC-ADDENDUM: display:none close, no will-change, overscroll-behavior on scroller) */
.bp-modal-bd { position: fixed; inset: 0; z-index: 900; background: rgba(10,10,10,0.45); display: flex; align-items: center; justify-content: center; padding: 20px; box-sizing: border-box; }
.bp-modal { background: var(--surface, #FAFAF8); border: 1px solid var(--border); border-radius: var(--r, 8px); width: 100%; max-width: 640px; max-height: 88vh; display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,0.18); }
.bp-modal-head { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
.bp-modal-title { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); }
.bp-modal-x { background: none; border: none; font-size: 16px; cursor: pointer; color: var(--ink-muted); min-width: 36px; min-height: 36px; display: flex; align-items: center; justify-content: center; border-radius: var(--r-sm, 4px); flex-shrink: 0; }
.bp-modal-x:hover { background: var(--bg-deep); color: var(--ink); }
.bp-modal-body { flex: 1; overflow-y: auto; overscroll-behavior: contain; min-height: 0; }
.bp-modal-section { padding: 20px 24px; border-bottom: 1px solid var(--border); }
.bp-modal-section:last-child { border-bottom: none; }
.bp-modal-grid-3 { display: grid; grid-template-columns: 1fr 1fr auto; gap: 12px; }
.bp-allergen-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; }
.bp-allergen-row { display: flex; align-items: center; gap: 8px; min-height: 44px; padding: 4px 8px; cursor: pointer; border-radius: 4px; }
.bp-allergen-row:hover { background: rgba(140,106,32,0.08); }
.bp-allergen-row:active { background: rgba(140,106,32,0.15); }
.bp-allergen-cb { width: 18px; height: 18px; accent-color: #8C6A20; cursor: pointer; flex-shrink: 0; }
.bp-allergen-row span { font-size: 13px; color: #5A3E0A; }
.bp-diet-flags { display: flex; flex-direction: column; gap: 4px; }
.bp-modal-foot { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-top: 1px solid var(--border); flex-shrink: 0; background: var(--surface); border-radius: 0 0 var(--r, 8px) var(--r, 8px); }

/* toast */

@media (max-width: 834px) { .bp-modal { max-height: 92vh; } .bp-modal-grid-3 { grid-template-columns: 1fr 1fr; } }
@media (min-width: 600px) { .bp-allergen-grid { grid-template-columns: repeat(3, 1fr); } }
</style>

<div class="settings-page" x-data="bfPage()">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/uebersicht" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.breakfast', lang)}</span>
  </nav>

  <section class="settings-hero">
    <span class="settings-hero__eyebrow">{bt('bf.hero.eyebrow', lang)}</span>
    <h1 class="settings-hero__title" set:html={bt('bf.hero.title', lang)}></h1>
    <p class="settings-hero__sub">{bt('bf.hero.sub', lang)}</p>
  </section>

  {message && (
    <script is:inline define:vars={{ m: message.text, t: message.type === 'success' ? 'success' : 'error' }}>
      window.addEventListener('DOMContentLoaded', function () { window.retahaToast && window.retahaToast(m, t); });
    </script>
  )}

  <div class="settings-sections">

      <!-- 01 Modul -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('bf.hero.eyebrow', lang)}</h2>
          <span class="s-card__num">01</span>
        </div>
        <div class="s-card__body">
          <p class="field__hint">{bt('si.mod.hint', lang)}</p>
          <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <ModStatusLed on={breakfastOn} />
            <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
          </div>
        </div>
      </section>

      <!-- 02 Zeiten (Wochentage) -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('bf.hours.title', lang)}</h2>
          <span class="s-card__num">02</span>
        </div>
        <div x-data="hoursSection()">
          <div class="s-card__body">
            <p class="field__hint">{bt('bf.hours.hint', lang)}</p>
            <div class="bp-hours-grid">
              <template x-for="d in days" :key="d.key">
                <div class="bp-hours-row" :class="{'bp-hours-row--closed': hours[d.key].closed}">
                  <span class="bp-hours-day" x-text="d.label"></span>
                  <div class="bp-hours-inputs">
                    <input type="time" class="s-input s-input--time"
                      x-show="!hours[d.key].closed"
                      :value="hours[d.key].start"
                      @change="hours[d.key].start = $event.target.value" />
                    <span class="bp-hours-sep" x-show="!hours[d.key].closed">–</span>
                    <input type="time" class="s-input s-input--time"
                      x-show="!hours[d.key].closed"
                      :value="hours[d.key].end"
                      @change="hours[d.key].end = $event.target.value" />
                    <span x-show="hours[d.key].closed" class="bp-hours-closed-txt">{bt('si.hours.closed', lang)}</span>
                  </div>
                  <label class="toggle-row" style="margin:0;gap:6px">
                    <input type="checkbox"
                      :checked="hours[d.key].closed"
                      @change="hours[d.key].closed = $event.target.checked"
                      class="sr-only" />
                    <span class="bt-visual" :class="{'is-checked': hours[d.key].closed}">
                      <span class="bt-knob"></span>
                    </span>
                    <span class="toggle-label" style="font-size:11px;color:var(--ink-muted)">{bt('si.hours.closetoggle', lang)}</span>
                  </label>
                </div>
              </template>
            </div>
            <div style="margin-bottom:16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
              <button type="button" @click="copyMonToAll()" class="v9-btn v9-btn--ghost" style="font-size:10px;padding:6px 12px">
                {bt('si.hours.copyall', lang)}
              </button>
              <span style="font-size:12px;color:var(--ink-muted)">{bt('si.hours.copyallhint', lang)}</span>
            </div>
            <div class="field">
              <label class="field__label" for="bf-slot">{bt('conf.times.slot', lang)}</label>
              <div class="bp-slot-stepper">
                <button type="button" class="bp-slot-step-btn"
                  @click="slotMinutes = Math.max(5, slotMinutes - 5)"
                  aria-label={bt('bf.slot.less', lang)}>−</button>
                <input type="number" id="bf-slot"
                  x-model.number="slotMinutes" min="5" max="120" step="5"
                  class="s-input" inputmode="numeric" />
                <button type="button" class="bp-slot-step-btn"
                  @click="slotMinutes = Math.min(120, slotMinutes + 5)"
                  aria-label={bt('bf.slot.more', lang)}>+</button>
              </div>
            </div>
            <p class="field__hint" style="margin-top:8px">{bt('bf.slot.hint', lang)}</p>
          </div>
          <div class="s-card__footer">
            <button type="button" @click="save()" :disabled="saving" class="v9-btn">{bt('common.save', lang)}</button>
          </div>
        </div>
      </section>

      <!-- 03 Ort -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('bf.location.title', lang)}</h2>
          <span class="s-card__num">03</span>
        </div>
        <div x-data={`sectionSave({ initial: ${JSON.stringify({ location_de: locationDe })}, section: 'location' })`}>
          <div class="s-card__body">
            <div class="field">
              <input type="text" id="bf-location" name="location_de" x-model="data.location_de"
                placeholder="z.B. im Wintergarten" class="s-input" />
              <span class="field__hint">{bt('bf.location.hint', lang)}</span>
            </div>
          </div>
          <div class="s-card__footer">
            <button type="button" @click="save()" :disabled="saving" class="v9-btn">{bt('common.save', lang)}</button>
          </div>
        </div>
      </section>

      <!-- 04 Inklusiv -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('bf.included.title', lang)}</h2>
          <span class="s-card__num">04</span>
        </div>
        <div x-data={`sectionSave({ initial: ${JSON.stringify({ included_de: includedDe })}, section: 'included' })`}>
          <div class="s-card__body">
            <div class="field">
              <textarea id="bf-included" name="included_de" rows="3" x-model="data.included_de"
                placeholder="z.B. Frische Backwaren, regionaler Honig, Bio-Eier, …"
                class="s-input"
                @input="$el.style.height='auto';$el.style.height=$el.scrollHeight+'px'"></textarea>
              <span class="field__hint">{bt('bf.included.hint', lang)}</span>
            </div>
          </div>
          <div class="s-card__footer">
            <button type="button" @click="save()" :disabled="saving" class="v9-btn">{bt('common.save', lang)}</button>
          </div>
        </div>
      </section>

      <!-- 05 Preis -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('bf.price.title', lang)}</h2>
          <span class="s-card__num">05</span>
        </div>
        <div x-data={`sectionSave({ initial: ${JSON.stringify({ breakfast_price_cents: priceCents !== null ? (priceCents / 100).toFixed(2).replace('.', ',') : '' })}, section: 'price' })`}>
          <div class="s-card__body">
            <div class="field field--row">
              <label class="field__label" for="bf-price">{bt('bf.price.label', lang)}</label>
              <div class="field__input-wrap">
                <div style="display:flex;align-items:center;gap:8px">
                  <input type="text" id="bf-price" name="breakfast_price_cents"
                    x-model="data.breakfast_price_cents"
                    inputmode="decimal" placeholder="leer = kein Preis"
                    class="s-input" style="max-width:180px" />
                  <span style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-muted)">{currencySymbol}</span>
                </div>
                <span class="field__hint">{bt('bf.price.hint', lang)}</span>
              </div>
            </div>
          </div>
          <div class="s-card__footer">
            <button type="button" @click="save()" :disabled="saving" class="v9-btn">{bt('common.save', lang)}</button>
          </div>
        </div>
      </section>

      <!-- 06 Zimmerservice -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('bf.rs.title', lang)}</h2>
          <span class="s-card__num">06</span>
        </div>
        <div x-data={`sectionSave({ initial: ${JSON.stringify({ breakfast_room_service_enabled: roomServiceOn ? 'true' : 'false', breakfast_room_service_fee_cents: (roomServiceFee / 100).toFixed(2).replace('.', ',') })}, section: 'room_service' })`}>
          <div class="s-card__body">
            <p class="field__hint">{bt('bf.rs.hint', lang)}</p>
            <label class="toggle-row">
              <input type="checkbox"
                :checked="data.breakfast_room_service_enabled === 'true'"
                @change="data.breakfast_room_service_enabled = $event.target.checked ? 'true' : 'false'"
                class="sr-only" />
              <span class="bt-visual" :class="{'is-checked': data.breakfast_room_service_enabled === 'true'}">
                <span class="bt-knob"></span>
              </span>
              <span class="toggle-label">{bt('bf.rs.toggle', lang)}</span>
            </label>
            <div x-show="data.breakfast_room_service_enabled === 'true'" class="bp-fee-section"
                 style={roomServiceOn ? '' : 'display:none'}>
              <div class="field field--row">
                <label class="field__label" for="rs-fee">{bt('bf.rs.fee', lang)}</label>
                <div class="field__input-wrap">
                  <div style="display:flex;align-items:center;gap:8px">
                    <input type="text" id="rs-fee" name="breakfast_room_service_fee_cents"
                      x-model="data.breakfast_room_service_fee_cents"
                      inputmode="decimal" class="s-input" style="max-width:180px"
                      placeholder="0,00" />
                    <span style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-muted)">{currencySymbol}</span>
                  </div>
                  <span class="field__hint">{bt('bf.rs.feehint', lang)}</span>
                </div>
              </div>
            </div>
          </div>
          <div class="s-card__footer">
            <button type="button" @click="save()" :disabled="saving" class="v9-btn">{bt('common.save', lang)}</button>
          </div>
        </div>
      </section>

  </div>

  <!-- ── Speisekarte ──────────────────────────────────────────────────────── -->
  <section class="s-card" id="speisekarte" style="margin-top:20px">
    <div class="s-card__head" style="align-items:center">
      <div>
        <span class="s-card__num" style="display:block;margin-bottom:6px">{bt('bf.menu.num', lang)}</span>
        <h2 class="s-card__title" set:html={bt('bf.menu.title', lang)}></h2>
      </div>
      <div style="display:flex;gap:10px;align-items:center;flex-shrink:0">
        {hasMews && (
          <form method="POST" style="display:inline">
            <input type="hidden" name="_action" value="mews_import" />
            <button type="submit"
              onclick={`return confirm(${JSON.stringify(bt('bf.menu.mewsconfirm', lang))})`}
              class="v9-btn v9-btn--ghost" style="font-size:10px;padding:8px 16px">
              {bt('bf.menu.frommews', lang)}
            </button>
          </form>
        )}
        <button type="button" @click="openNew()" class="v9-btn">{bt('bf.menu.new', lang)}</button>
      </div>
    </div>

    <div class="s-card__body">
      <template x-if="groupedItems.length === 0">
        <div class="bp-empty">
          <p>{bt('bf.menu.empty', lang)}</p>
          <button type="button" @click="openNew()" class="v9-btn" style="margin-top:14px">{bt('bf.menu.first', lang)}</button>
        </div>
      </template>
      <template x-if="groupedItems.length > 0">
        <div>
          <template x-for="group in groupedItems" :key="group.cat">
            <div class="bp-item-group">
              <div class="bp-item-cat" x-text="group.cat"></div>
              <div class="bp-item-list">
                <template x-for="item in group.items" :key="item.id">
                  <div class="bp-item-row"
                    :class="{'is-drag-over': dragTarget && dragTarget.id === item.id, 'is-dragging': dragItem && dragItem.id === item.id}"
                    :data-item-id="item.id">
                    <span class="bp-drag-handle"
                      @click.stop
                      @pointerdown="dndPtrDown($event, item)"
                      aria-label={bt('bf.menu.draghandle', lang)}>
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
                        <circle cx="5" cy="4" r="1.5"/><circle cx="11" cy="4" r="1.5"/>
                        <circle cx="5" cy="8" r="1.5"/><circle cx="11" cy="8" r="1.5"/>
                        <circle cx="5" cy="12" r="1.5"/><circle cx="11" cy="12" r="1.5"/>
                      </svg>
                    </span>
                    <button type="button" class="bp-item-content" @click="openEdit(item)">
                      <span class="bp-item-dot" :class="item.is_active ? 'bp-item-dot--on' : ''"></span>
                      <div class="bp-item-info">
                        <span class="bp-item-name" x-text="item.name_de"></span>
                        <span class="bp-item-desc" x-show="item.description_de" x-text="item.description_de || ''"></span>
                      </div>
                      <div class="bp-item-meta">
                        <template x-if="item.is_vegan"><span class="bp-badge">vegan</span></template>
                        <template x-if="!item.is_vegan && item.is_vegetarian"><span class="bp-badge">veg</span></template>
                        <template x-if="item.is_organic"><span class="bp-badge">bio</span></template>
                        <span x-show="item.price_cents > 0" class="bp-item-price" x-text="formatEur(item.price_cents)"></span>
                      </div>
                      <span class="bp-item-edit">{bt('bf.menu.edititem', lang)}</span>
                    </button>
                  </div>
                </template>
              </div>
            </div>
          </template>
        </div>
      </template>
    </div>

    <div class="s-warning-row" style="margin:16px 0 0">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
           width="16" height="16" aria-hidden="true" style="flex-shrink:0">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
      </svg>
      <span set:html={bt('bf.lmiv', lang)}></span>
    </div>
  </section>

  <!-- ── Modal Backdrop ──────────────────────────────────────────────────── -->
  <div x-show="modalOpen" x-cloak class="bp-modal-bd" @click.self="closeModal()">
    <div class="bp-modal" role="dialog" aria-modal="true" @click.stop>

      <div class="bp-modal-head">
        <h3 class="bp-modal-title" x-text={`modalIsNew ? ${JSON.stringify(bt('bf.menu.new2', lang))} : (modalItem.name_de || ${JSON.stringify(bt('bf.modal.edit', lang))})`}></h3>
        <button type="button" @click="closeModal()" class="bp-modal-x" aria-label={bt('common.close', lang)}>✕</button>
      </div>

      <div class="bp-modal-body">

        <div x-show="modalError" x-cloak style="padding:12px 24px 0">
          <div class="s-flash s-flash--err" style="margin-bottom:0" x-text="modalError"></div>
        </div>

        <!-- Allgemein -->
        <div class="bp-modal-section">
          <div class="bp-modal-grid-3">
            <div class="field">
              <span class="field__label">{bt('bf.modal.category', lang)}</span>
              <input type="text" x-model="modalItem.category" placeholder="z.B. Brot, Warm" class="s-input" />
            </div>
            <div class="field">
              <span class="field__label">{bt('bf.modal.priceeur', lang)}</span>
              <input type="number" x-model="modalItem.price_eur" min="0" step="0.01" placeholder="0,00" class="s-input" inputmode="decimal" />
              <span class="field__hint">{bt('bf.modal.pricehint', lang)}</span>
