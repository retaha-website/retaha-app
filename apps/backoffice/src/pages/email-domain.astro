---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { resendGetDomain, resendAddDomain, resendVerifyDomain, resendDeleteDomain, type ResendDomainRecord } from '../lib/resend-domain';
import { getEnv } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const sb = createSupabaseServiceRoleInstance();
const { data: settings } = await sb
  .from('hotel_settings')
  .select('custom_email_domain, custom_email_status, resend_domain_id')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const resendApiKeySet = !!getEnv('RESEND_API_KEY');

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'add') {
    const domain = form.get('domain')?.toString().trim().toLowerCase();
    if (!domain || !/^[a-z0-9.-]+\.[a-z]{2,}$/.test(domain)) {
      message = { type: 'error', text: 'Ungültiges Domain-Format (z.B. gategardenhotel.de — ohne https:// oder www.).' };
    } else {
      const resp = await resendAddDomain(domain);
      if (!resp.ok) {
        message = { type: 'error', text: `Resend-API-Fehler: ${resp.error}` };
      } else {
        const { error: dbErr } = await sb.from('hotel_settings').upsert(
          { hotel_id: hotel.id, custom_email_domain: domain, custom_email_status: 'pending', resend_domain_id: resp.data.id, updated_at: new Date().toISOString() },
          { onConflict: 'hotel_id' },
        );
        if (dbErr) message = { type: 'error', text: `Speichern fehlgeschlagen: ${dbErr.message}` };
        else message = { type: 'success', text: 'Domain bei Resend angelegt. Bitte die unten gezeigten DNS-Einträge bei deinem Domain-Provider hinterlegen, dann „Domain verifizieren" klicken.' };
        return Astro.redirect('/email-domain?saved=added');
      }
    }
  } else if (action === 'verify') {
    if (!settings?.resend_domain_id) {
      message = { type: 'error', text: 'Keine Domain konfiguriert.' };
    } else {
      const resp = await resendVerifyDomain(settings.resend_domain_id);
      const newStatus = resp.ok ? resp.data.status : 'failed';
      await sb.from('hotel_settings').upsert(
        { hotel_id: hotel.id, custom_email_status: newStatus, updated_at: new Date().toISOString() },
        { onConflict: 'hotel_id' },
      );
      return Astro.redirect(`/email-domain?saved=verified&status=${newStatus}`);
    }
  } else if (action === 'remove') {
    if (settings?.resend_domain_id) {
      await resendDeleteDomain(settings.resend_domain_id);
    }
    await sb.from('hotel_settings').upsert(
      { hotel_id: hotel.id, custom_email_domain: null, custom_email_status: null, resend_domain_id: null, updated_at: new Date().toISOString() },
      { onConflict: 'hotel_id' },
    );
    return Astro.redirect('/email-domain?saved=removed');
  }
}

const saved = Astro.url.searchParams.get('saved');
const status = Astro.url.searchParams.get('status');

if (!message) {
  if (saved === 'added') message = { type: 'success', text: 'Domain bei Resend angelegt. Bitte die DNS-Einträge unten hinterlegen, dann „Domain verifizieren" klicken.' };
  else if (saved === 'verified' && status === 'verified') message = { type: 'success', text: 'Domain verifiziert! Gast-Mails werden ab sofort von deiner Custom-Domain versendet.' };
  else if (saved === 'verified' && status === 'pending') message = { type: 'error', text: 'Domain noch nicht verifiziert — DNS-Propagation kann bis 24h dauern.' };
  else if (saved === 'verified' && status === 'failed') message = { type: 'error', text: 'Verifikation fehlgeschlagen — bitte DNS-Einträge prüfen.' };
  else if (saved === 'removed') message = { type: 'success', text: 'Domain entfernt. Mails werden wieder von noreply@retaha.de versendet.' };
}

const { data: freshSettings } = await sb
  .from('hotel_settings')
  .select('custom_email_domain, custom_email_status, resend_domain_id')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

let domainDetail: { status: string; records: ResendDomainRecord[] } | null = null;
let domainDetailError: string | null = null;
if (freshSettings?.resend_domain_id) {
  const resp = await resendGetDomain(freshSettings.resend_domain_id);
  if (resp.ok) {
    domainDetail = { status: resp.data.status, records: resp.data.records ?? [] };
  } else {
    domainDetailError = resp.error;
  }
}
---

<Layout title="Email-Domain" activeTab="backoffice" hotelName={hotel.name}>

  <div class="page-header mb-8">
    <p class="eyebrow text-anthrazit/55 mb-2">— Email —</p>
    <h1 class="text-3xl font-light text-anthrazit">Eigene <strong class="font-bold">Absender-Domain</strong></h1>
    <p class="text-anthrazit/70 mt-3 max-w-2xl leading-relaxed">
      Customer-Facing-Mails (Pre-Arrival-Invite u.a.) versenden wir auf Wunsch von
      <span class="font-mono">welcome@deine-domain.de</span> statt von <span class="font-mono">noreply@retaha.de</span>.
      Premium-Vertrauen statt Service-Provider-Optik.
    </p>
  </div>

  {!resendApiKeySet && (
    <div class="mb-6 px-4 py-3 text-sm bg-amber-50 border-l-4 border-amber-500 text-amber-800">
      <strong>RESEND_API_KEY nicht konfiguriert</strong> — kontaktiere Taha für API-Key-Setup.
    </div>
  )}

  {message && (
    <div class={`mb-8 px-4 py-3 text-sm border-l-4 ${
      message.type === 'success'
        ? 'bg-green-50 border-green-700 text-green-800'
        : 'bg-red-50 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  {!freshSettings?.custom_email_domain ? (
    <div class="max-w-2xl">
      <p class="text-anthrazit/80 leading-relaxed text-base mb-8">
        Trage deine Hotel-Domain ein (z.B. <span class="font-mono">gategardenhotel.de</span>).
        Wir legen sie bei Resend an und zeigen dir die DNS-Einträge.
      </p>

      <form method="POST" class="space-y-6">
        <input type="hidden" name="_action" value="add" />

        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-2">— Domain —</span>
          <input
            type="text"
            name="domain"
            placeholder="z.B. gategardenhotel.de"
            required
            autocomplete="off"
            spellcheck="false"
            class="bauhaus-input bauhaus-input--mono"
            disabled={!resendApiKeySet}
          />
          <span class="text-xs italic text-anthrazit/55 mt-2 block">
            Ohne https:// oder www. — nur die Apex-Domain.
          </span>
        </label>

        <button type="submit" class="bauhaus-button bauhaus-button--primary" disabled={!resendApiKeySet}>
          Bei Resend anlegen
        </button>
      </form>
    </div>
  ) : (
    <div class="space-y-8 max-w-3xl">

      <section class="border-t border-b border-anthrazit/[0.12] py-8">
        <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
          <p class="eyebrow text-pink-shock m-0">— Konfigurierte Domain —</p>
          {(() => {
            const statusValue = freshSettings.custom_email_status ?? 'pending';
            const badge = statusValue === 'verified'
              ? { label: '✓ Verifiziert', classes: 'bg-green-100 text-green-800' }
              : statusValue === 'failed'
                ? { label: '✗ Fehler',    classes: 'bg-red-100 text-red-800' }
                : { label: '⏳ Pending',   classes: 'bg-amber-100 text-amber-800' };
            return (
              <span class={`text-xs uppercase tracking-[0.12em] px-2.5 py-1 ${badge.classes}`}>
                {badge.label}
              </span>
            );
          })()}
        </div>

        <p class="text-2xl font-mono text-anthrazit m-0 mb-4">
          welcome@<strong class="font-bold">{freshSettings.custom_email_domain}</strong>
        </p>

        {freshSettings.custom_email_status === 'verified' ? (
          <p class="text-sm text-anthrazit/70 leading-relaxed">
            Customer-Facing-Mails gehen ab sofort von deiner Domain raus.
            Hotelier-interne Mails (Booking-Notifications) bleiben über noreply@retaha.de.
          </p>
        ) : (
          <p class="text-sm text-anthrazit/70 leading-relaxed">
            DNS-Einträge unten beim Provider hinterlegen, dann „Domain verifizieren" klicken.
            DNS-Propagation kann bis zu 24 Stunden dauern.
          </p>
        )}
      </section>

      {domainDetailError && (
        <div class="px-4 py-3 text-sm bg-red-50 border-l-4 border-red-700 text-red-800">
          Domain-Details konnten nicht von Resend geladen werden: {domainDetailError}
        </div>
      )}

      {domainDetail && domainDetail.records.length > 0 && (
        <section>
          <p class="eyebrow text-anthrazit/55 mb-4">— DNS-Einträge —</p>
          <p class="text-xs italic text-anthrazit/55 mb-4 max-w-xl">
            Diese Einträge bei deinem Domain-Provider hinterlegen (Strato: „Domains → DNS-Verwaltung",
            IONOS: „Domain → Domain-Tools").
          </p>
          <div class="overflow-x-auto border border-stein">
            <table class="w-full text-sm">
              <thead class="bg-anthrazit/[0.03]">
                <tr>
                  <th class="text-left p-3 font-medium border-b border-stein">Typ</th>
                  <th class="text-left p-3 font-medium border-b border-stein">Name / Host</th>
                  <th class="text-left p-3 font-medium border-b border-stein">Wert</th>
                  {domainDetail.records.some(r => r.priority !== undefined) && (
                    <th class="text-left p-3 font-medium border-b border-stein">Priorität</th>
                  )}
                </tr>
              </thead>
              <tbody>
                {domainDetail.records.map(r => (
                  <tr class="border-b border-stein last:border-b-0">
                    <td class="p-3 font-mono text-xs">{r.type ?? r.record}</td>
                    <td class="p-3 font-mono text-xs break-all">{r.name}</td>
                    <td class="p-3 font-mono text-xs break-all">{r.value}</td>
                    {domainDetail.records.some(x => x.priority !== undefined) && (
                      <td class="p-3 font-mono text-xs">{r.priority ?? '—'}</td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <section class="flex gap-4 flex-wrap items-center pt-2">
        {freshSettings.custom_email_status !== 'verified' && (
          <form method="POST" class="m-0">
            <input type="hidden" name="_action" value="verify" />
            <button type="submit" class="bauhaus-button bauhaus-button--primary">
              Domain verifizieren
            </button>
          </form>
        )}
        <form method="POST" class="m-0"
              onsubmit="return confirm('Domain wirklich entfernen? Mails gehen dann wieder von noreply@retaha.de raus.')">
          <input type="hidden" name="_action" value="remove" />
          <button type="submit" class="bauhaus-button bauhaus-button--ghost">
            Domain entfernen
          </button>
        </form>
      </section>
    </div>
  )}
</Layout>
