---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

// ─── LADEN ─────────────────────────────────────────────────────────────────
const { data: hs } = await sb
  .from('hotel_settings')
  .select('features')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const features = ((hs?.features as Record<string, unknown>) ?? {});
const walletOn = features.wallet !== false;

// Hotel-Branding für Pass-Vorschau (gleiche Fallback-Kette wie wallet/create.ts)
const { data: h } = await sb
  .from('hotels')
  .select('name, brand_color, brand_primary, logo_primary, logo_dark, wallet_pass_bg, hero_image_url')
  .eq('id', (hotel as any).id)
  .maybeSingle();

const brandColor: string = (h as any)?.brand_color || (h as any)?.brand_primary || '#1A1A1A';
const logoUrl: string | null = (h as any)?.logo_primary ?? (h as any)?.logo_dark ?? null;
const heroUrl: string | null = (h as any)?.wallet_pass_bg ?? (h as any)?.hero_image_url ?? null;
const hotelName: string = (h as any)?.name ?? (hotel as any).name ?? 'Hotel';

// ─── STATS ─────────────────────────────────────────────────────────────────
const { count: totalCount } = await sb
  .from('wallet_passes')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', (hotel as any).id);

const { count: activeCount } = await sb
  .from('wallet_passes')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', (hotel as any).id)
  .eq('state', 'active');

const { count: consentCount } = await sb
  .from('wallet_passes')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', (hotel as any).id)
  .eq('marketing_consent_given', true);

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

// Helligkeits-Check für Titelfarbe über dem Wallet-Pass-Banner
function isColorDark(hex: string): boolean {
  const c = hex.replace('#', '');
  if (c.length < 6) return true;
  const r = parseInt(c.slice(0, 2), 16);
  const g = parseInt(c.slice(2, 4), 16);
  const b = parseInt(c.slice(4, 6), 16);
  return (r * 299 + g * 587 + b * 114) / 1000 < 128;
}
const passTextColor = isColorDark(brandColor) ? '#ffffff' : '#111111';
---

<Layout title="Wallet-Pass" activeTab="backoffice" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

  <div class="settings-page" style="padding-top:0">

    <nav class="breadcrumb" style="padding-top:36px" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.wallet', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('wk.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('wk.hero.sub', lang)}</p>
    </section>

    <div class="wk-wrap">

      <!-- ── 01 · Modul-Status ────────────────────────────────────────────── -->
      <div class="wk-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.mod.title', lang)}</span>
        </div>
        <p class="wk-hint">{bt('si.mod.hint', lang)}</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={walletOn} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
        </div>
      </div>

      <!-- ── 02 · Pass-Vorschau (Google Wallet Mock) ──────────────────────── -->
      <div class="wk-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.pass.title', lang)}</span>
        </div>
        <p class="wk-hint">{bt('wk.pass.sub', lang)}</p>

        <!-- Google Wallet Pass Mock -->
        <div class="wk-pass-wrap">
          <div class="wk-pass" style={`background:${brandColor};color:${passTextColor}`}>
            <!-- Pass-Header -->
            <div class="wk-pass-header">
              <div class="wk-pass-issuer">
                {logoUrl ? (
                  <img src={logoUrl} alt={hotelName} class="wk-pass-logo" />
                ) : (
                  <span class="wk-pass-logo-text" style={`color:${passTextColor}`}>{hotelName.slice(0, 2).toUpperCase()}</span>
                )}
              </div>
              <div class="wk-pass-type-badge">
                <span class="wk-pass-type-label" style={`color:${passTextColor};opacity:.7`}>{bt('wk.pass.member', lang)}</span>
              </div>
            </div>
            <!-- Pass-Hero -->
            {heroUrl && (
              <div class="wk-pass-hero" style={`background-image:url(${heroUrl})`}></div>
            )}
            <!-- Pass-Body -->
            <div class="wk-pass-body">
              <div class="wk-pass-hotel" style={`color:${passTextColor}`}>{hotelName}</div>
              <div class="wk-pass-meta" style={`color:${passTextColor};opacity:.65`}>
                <span>{bt('wk.pass.stays', lang)}: 1</span>
              </div>
            </div>
            <!-- Google Wallet Branding -->
            <div class="wk-pass-foot">
              <svg class="wk-pass-gw-icon" viewBox="0 0 24 24" fill="none" aria-label="Google Wallet">
                <rect width="24" height="24" rx="4" fill="rgba(255,255,255,.15)"/>
                <path d="M12 6c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6z" fill="rgba(255,255,255,.6)"/>
                <path d="M12 8.5c-1.93 0-3.5 1.57-3.5 3.5s1.57 3.5 3.5 3.5 3.5-1.57 3.5-3.5-1.57-3.5-3.5-3.5z" fill="rgba(255,255,255,.9)"/>
              </svg>
              <span class="wk-pass-gw-label" style={`color:${passTextColor};opacity:.6`}>Google Wallet</span>
            </div>
          </div>
          <p class="wk-pass-note">{hotelName} · {brandColor}</p>
        </div>
      </div>

      <!-- ── 03 · Nutzungsstatistiken ────────────────────────────────────── -->
      <div class="wk-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.stats.title', lang)}</span>
        </div>
        <div class="wk-stats-row">
          <div class="wk-stat">
            <span class="wk-stat-val">{totalCount ?? 0}</span>
            <span class="wk-stat-label">{bt('wk.stats.total', lang)}</span>
          </div>
          <div class="wk-stat">
            <span class="wk-stat-val">{activeCount ?? 0}</span>
            <span class="wk-stat-label">{bt('wk.stats.active', lang)}</span>
          </div>
          <div class="wk-stat">
            <span class="wk-stat-val">{consentCount ?? 0}</span>
            <span class="wk-stat-label">{bt('wk.stats.consent', lang)}</span>
          </div>
        </div>
        <p class="wk-hint" style="margin-top:14px;margin-bottom:0">
          {bt('wk.stats.note', lang)}{' '}
          <a href="/marketing-consents" class="wk-link">{bt('wk.stats.link', lang)}</a>
        </p>
      </div>

      <!-- ── 04 · Apple Wallet — Coming Soon ─────────────────────────────── -->
      <div class="wk-card wk-apple-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.apple.title', lang)}</span>
          <span class="wk-apple-badge">{bt('wk.apple.badge', lang)}</span>
        </div>
        <p class="wk-hint">{bt('wk.apple.sub', lang)}</p>
        <div class="wk-apple-icon-row" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" class="wk-apple-icon">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
        </div>
      </div>

    </div>
  </div>

  <style>
    /* ── V9-Karten ─────────────────────────────────────────────────────────── */
    .wk-wrap { display: flex; flex-direction: column; gap: 16px; }
    .wk-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 20px 22px; }
    .wk-card-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; }
    .wk-card-title {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 14px; color: var(--ink);
    }
    .wk-card-title::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--petrol, #14616E); flex-shrink: 0; }
    .wk-hint { display: block; font-size: 11px; color: var(--ink-muted); line-height: 1.45; margin-bottom: 16px; }
    .wk-link { color: var(--petrol, #14616E); text-decoration: none; font-weight: 500; }
    .wk-link:hover { text-decoration: underline; }

    /* ── Pass-Vorschau ──────────────────────────────────────────────────────── */
    .wk-pass-wrap { display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }
    .wk-pass {
      width: 100%; max-width: 340px; border-radius: 16px; overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,.18); position: relative;
    }
    .wk-pass-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 16px 0;
    }
    .wk-pass-issuer { display: flex; align-items: center; gap: 8px; }
    .wk-pass-logo { height: 28px; width: auto; object-fit: contain; border-radius: 4px; }
    .wk-pass-logo-text {
      width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,.2);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 11px;
    }
    .wk-pass-type-badge { }
    .wk-pass-type-label { font-family: 'JetBrains Mono', monospace; font-size: 8px; letter-spacing: 0.15em; text-transform: uppercase; }
    .wk-pass-hero {
      height: 80px; background-size: cover; background-position: center;
      margin: 12px 0 0; opacity: .85;
    }
    .wk-pass-body { padding: 12px 16px 0; }
    .wk-pass-hotel { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 15px; line-height: 1.3; }
    .wk-pass-meta { font-size: 11px; margin-top: 4px; }
    .wk-pass-foot {
      display: flex; align-items: center; gap: 6px;
      padding: 12px 16px; border-top: 1px solid rgba(255,255,255,.12); margin-top: 12px;
    }
    .wk-pass-gw-icon { width: 20px; height: 20px; flex-shrink: 0; }
    .wk-pass-gw-label { font-size: 10px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.08em; }
    .wk-pass-note { font-size: 10px; color: var(--ink-faint); font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; }

    /* ── Statistiken ────────────────────────────────────────────────────────── */
    .wk-stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    @media (max-width: 480px) { .wk-stats-row { grid-template-columns: 1fr 1fr; } }
    .wk-stat {
      background: var(--bg-deep, #F4F3F0); border-radius: 12px; padding: 14px 16px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .wk-stat-val { font-family: 'Space Grotesk', sans-serif; font-size: 24px; font-weight: 700; color: var(--ink); line-height: 1; }
    .wk-stat-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); }

    /* ── Apple Coming Soon ──────────────────────────────────────────────────── */
    .wk-apple-card { border-style: dashed; border-color: var(--border); opacity: .8; }
    .wk-apple-badge {
      font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase;
      padding: 4px 10px; border-radius: 20px; border: 1px solid var(--border);
      color: var(--ink-muted); background: var(--bg-deep, #F4F3F0);
    }
    .wk-apple-icon-row { display: flex; align-items: center; gap: 8px; }
    .wk-apple-icon { color: var(--ink-faint); }
  </style>

</Layout>
