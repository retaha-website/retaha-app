---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
import { computeTierProgress, DEFAULT_LOYALTY_CONFIG, type LoyaltyTier } from '@retaha/loyalty';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

// ─── LADEN ─────────────────────────────────────────────────────────────────
const { data: hs } = await sb
  .from('hotel_settings')
  .select('features')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const features = ((hs?.features as Record<string, unknown>) ?? {});
const walletOn = features.wallet !== false;

// Hotel-Branding für Pass-Vorschau (gleiche Fallback-Kette wie wallet/create.ts)
const { data: h } = await sb
  .from('hotels')
  .select('name, brand_color, brand_primary, logo_primary, logo_dark, wallet_pass_bg, hero_image_url')
  .eq('id', (hotel as any).id)
  .maybeSingle();

const brandColor: string = (h as any)?.brand_color || (h as any)?.brand_primary || '#1A1A1A';
const logoUrl: string | null = (h as any)?.logo_primary ?? (h as any)?.logo_dark ?? null;
const heroUrl: string | null = (h as any)?.wallet_pass_bg ?? (h as any)?.hero_image_url ?? null;
const hotelName: string = (h as any)?.name ?? (hotel as any).name ?? 'Hotel';

// ─── LOYALTY-TIER FÜR PASS-VORSCHAU ───────────────────────────────────────
const { data: lcRow } = await sb
  .from('loyalty_config')
  .select('tiers')
  .eq('hotel_id', (hotel as any).id)
  .maybeSingle();
const previewTiers = ((lcRow?.tiers ?? DEFAULT_LOYALTY_CONFIG.tiers) as LoyaltyTier[]);
// Beispiel: mittlere Stufe als Vorschau-Status (repräsentativer Stammgast)
const previewProgress = computeTierProgress(
  previewTiers.length > 1
    ? Math.round((previewTiers[Math.min(1, previewTiers.length - 1)].threshold_points ?? 0) * 1.1)
    : 0,
  previewTiers
);
const previewTierName = previewProgress.tier.name || undefined;

// ─── STATS ─────────────────────────────────────────────────────────────────
const { count: totalCount } = await sb
  .from('wallet_passes')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', (hotel as any).id);

const { count: activeCount } = await sb
  .from('wallet_passes')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', (hotel as any).id)
  .eq('state', 'active');

const { count: consentCount } = await sb
  .from('wallet_passes')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', (hotel as any).id)
  .eq('marketing_consent_given', true);

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

// Helligkeits-Check für Titelfarbe über dem Wallet-Pass-Banner
function isColorDark(hex: string): boolean {
  const c = hex.replace('#', '');
  if (c.length < 6) return true;
  const r = parseInt(c.slice(0, 2), 16);
  const g = parseInt(c.slice(2, 4), 16);
  const b = parseInt(c.slice(4, 6), 16);
  return (r * 299 + g * 587 + b * 114) / 1000 < 128;
}
const passTextColor = isColorDark(brandColor) ? '#ffffff' : '#111111';
---

<Layout title="Wallet-Pass" activeTab="backoffice" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

  <div class="settings-page" style="padding-top:0">

    <nav class="breadcrumb" style="padding-top:36px" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.wallet', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('wk.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('wk.hero.sub', lang)}</p>
    </section>

    <div class="wk-wrap">

      <!-- ── 01 · Modul-Status ────────────────────────────────────────────── -->
      <div class="wk-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.mod.title', lang)}</span>
        </div>
        <p class="wk-hint">{bt('si.mod.hint', lang)}</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={walletOn} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
        </div>
      </div>

      <!-- ── 02 · Pass-Vorschau (Google Wallet Mock) ──────────────────────── -->
      <div class="wk-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.pass.title', lang)}</span>
        </div>
        <p class="wk-hint">{bt('wk.pass.sub', lang)}</p>

        <!-- Google Wallet Loyalty Card — echtes Layout nachgebaut -->
        <div class="wk-pass-wrap">
          <div class="wk-pass" style={`--pass-bg:${brandColor};--pass-fg:${passTextColor}`}>

            <!-- 1 · Header: Logo + Programmname (= hotelName) -->
            <div class="wk-pass-hd">
              {logoUrl ? (
                <img src={logoUrl} alt={hotelName} class="wk-pass-logo" />
              ) : (
                <span class="wk-pass-logo-fallback">{hotelName.slice(0, 2).toUpperCase()}</span>
              )}
              <span class="wk-pass-program">{hotelName}</span>
            </div>

            <!-- 2 · Hero-Image (wallet_pass_bg / hero_image_url) -->
            {heroUrl && (
              <div class="wk-pass-hero" style={`background-image:url(${heroUrl})`} aria-hidden="true"></div>
            )}

            <!-- 3 · Gastname (accountName) -->
            <div class="wk-pass-name">Max Mustermann</div>

            <!-- 3b · Loyalty-Stufe (tier) — nur wenn konfiguriert -->
            {previewTierName && (
              <div class="wk-pass-fields" style="margin-top:6px">
                <div class="wk-pass-field">
                  <span class="wk-pass-field-label">Status</span>
                  <span class="wk-pass-field-val wk-pass-tier">{previewTierName}</span>
                </div>
              </div>
            )}

            <!-- 4 · Felder Reihe 1: MITGLIED SEIT | BESUCHE -->
            <div class="wk-pass-fields">
              <div class="wk-pass-field">
                <span class="wk-pass-field-label">Mitglied seit</span>
                <span class="wk-pass-field-val">2024-01-01</span>
              </div>
              <div class="wk-pass-field">
                <span class="wk-pass-field-label">Besuche</span>
                <span class="wk-pass-field-val">1</span>
              </div>
            </div>

            <!-- 5 · Felder Reihe 2: LETZTER BESUCH -->
            <div class="wk-pass-fields" style="margin-top:8px">
              <div class="wk-pass-field">
                <span class="wk-pass-field-label">Letzter Besuch</span>
                <span class="wk-pass-field-val">—</span>
              </div>
            </div>

            <!-- 6 · Footer: Google Wallet G-Logo + Schriftzug -->
            <div class="wk-pass-ft">
              <!-- Offizielles Google "G" Logo (vereinfacht) -->
              <svg class="wk-pass-g" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <span class="wk-pass-ft-text">Google Wallet</span>
            </div>

          </div>
          <!-- Hinweis: was wir einstellen können -->
          <div class="wk-pass-meta-row">
            <span class="wk-pass-meta-chip" style={`background:${brandColor};color:${passTextColor}`}>{brandColor}</span>
            {logoUrl && <span class="wk-pass-meta-chip wk-pass-meta-chip--muted">Logo ✓</span>}
            {heroUrl && <span class="wk-pass-meta-chip wk-pass-meta-chip--muted">Hero-Bild ✓</span>}
          </div>
        </div>
      </div>

      <!-- ── 03 · Nutzungsstatistiken ────────────────────────────────────── -->
      <div class="wk-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.stats.title', lang)}</span>
        </div>
        <div class="wk-stats-row">
          <div class="wk-stat">
            <span class="wk-stat-val">{totalCount ?? 0}</span>
            <span class="wk-stat-label">{bt('wk.stats.total', lang)}</span>
          </div>
          <div class="wk-stat">
            <span class="wk-stat-val">{activeCount ?? 0}</span>
            <span class="wk-stat-label">{bt('wk.stats.active', lang)}</span>
          </div>
          <div class="wk-stat">
            <span class="wk-stat-val">{consentCount ?? 0}</span>
            <span class="wk-stat-label">{bt('wk.stats.consent', lang)}</span>
          </div>
        </div>
        <p class="wk-hint" style="margin-top:14px;margin-bottom:0">
          {bt('wk.stats.note', lang)}{' '}
          <a href="/marketing" class="wk-link">{bt('wk.stats.link', lang)}</a>
        </p>
      </div>

      <!-- ── 04 · Apple Wallet — Coming Soon ─────────────────────────────── -->
      <div class="wk-card wk-apple-card">
        <div class="wk-card-head">
          <span class="wk-card-title">{bt('wk.apple.title', lang)}</span>
          <span class="wk-apple-badge">{bt('wk.apple.badge', lang)}</span>
        </div>
        <p class="wk-hint">{bt('wk.apple.sub', lang)}</p>
        <div class="wk-apple-icon-row" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" class="wk-apple-icon">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
        </div>
      </div>

    </div>
  </div>

  <style>
    /* ── V9-Karten ─────────────────────────────────────────────────────────── */
    .wk-wrap { display: flex; flex-direction: column; gap: 16px; }
    .wk-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 20px 22px; }
    .wk-card-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; }
    .wk-card-title {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 14px; color: var(--ink);
    }
    .wk-card-title::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--petrol, #14616E); flex-shrink: 0; }
    .wk-hint { display: block; font-size: 11px; color: var(--ink-muted); line-height: 1.45; margin-bottom: 16px; }
    .wk-link { color: var(--petrol, #14616E); text-decoration: none; font-weight: 500; }
    .wk-link:hover { text-decoration: underline; }

    /* ── Google Wallet Loyalty Card Mock ───────────────────────────────────── */
    .wk-pass-wrap { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }

    /* Karte selbst: brand-color Hintergrund, Portrait-Proportion wie im echten Wallet */
    .wk-pass {
      width: 100%; max-width: 300px;
      background: var(--pass-bg); color: var(--pass-fg);
      border-radius: 18px; overflow: hidden;
      box-shadow: 0 12px 40px rgba(0,0,0,.22);
      font-family: 'Google Sans', 'Roboto', sans-serif;
    }

    /* 1 · Header */
    .wk-pass-hd {
      display: flex; align-items: center; gap: 10px;
      padding: 16px 16px 14px;
    }
    .wk-pass-logo { height: 32px; width: auto; max-width: 80px; object-fit: contain; border-radius: 4px; }
    .wk-pass-logo-fallback {
      width: 32px; height: 32px; border-radius: 6px; flex-shrink: 0;
      background: rgba(255,255,255,.2);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 12px; color: inherit;
    }
    .wk-pass-program {
      font-size: 13px; font-weight: 500; opacity: .9;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* 2 · Hero-Image */
    .wk-pass-hero {
      width: 100%; height: 100px;
      background-size: cover; background-position: center;
    }

    /* 3 · Gastname */
    .wk-pass-name {
      padding: 14px 16px 0;
      font-size: 18px; font-weight: 600; line-height: 1.2;
      color: inherit;
    }

    /* 4/5 · Felder-Reihen */
    .wk-pass-fields {
      display: flex; gap: 24px;
      padding: 10px 16px 0;
    }
    .wk-pass-field { display: flex; flex-direction: column; gap: 2px; }
    .wk-pass-field-label {
      font-size: 9px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
      opacity: .6; color: inherit;
    }
    .wk-pass-field-val { font-size: 13px; font-weight: 500; color: inherit; }
    .wk-pass-tier { font-weight: 700; letter-spacing: 0.04em; }

    /* 6 · Footer: Google G + "Google Wallet" */
    .wk-pass-ft {
      display: flex; align-items: center; gap: 6px;
      padding: 14px 16px;
      margin-top: 10px;
      border-top: 1px solid rgba(255,255,255,.15);
    }
    .wk-pass-g { width: 18px; height: 18px; flex-shrink: 0; }
    .wk-pass-ft-text { font-size: 11px; font-weight: 500; opacity: .7; color: inherit; }

    /* Meta-Zeile unter der Karte */
    .wk-pass-meta-row { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .wk-pass-meta-chip {
      font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.08em;
      padding: 3px 8px; border-radius: 20px; font-weight: 500;
    }
    .wk-pass-meta-chip--muted { background: var(--bg-deep); color: var(--ink-muted); }

    /* ── Statistiken ────────────────────────────────────────────────────────── */
    .wk-stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    @media (max-width: 480px) { .wk-stats-row { grid-template-columns: 1fr 1fr; } }
    .wk-stat {
      background: var(--bg-deep, #F4F3F0); border-radius: 12px; padding: 14px 16px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .wk-stat-val { font-family: 'Space Grotesk', sans-serif; font-size: 24px; font-weight: 700; color: var(--ink); line-height: 1; }
    .wk-stat-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); }

    /* ── Apple Coming Soon ──────────────────────────────────────────────────── */
    .wk-apple-card { border-style: dashed; border-color: var(--border); opacity: .8; }
    .wk-apple-badge {
      font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase;
      padding: 4px 10px; border-radius: 20px; border: 1px solid var(--border);
      color: var(--ink-muted); background: var(--bg-deep, #F4F3F0);
    }
    .wk-apple-icon-row { display: flex; align-items: center; gap: 8px; }
    .wk-apple-icon { color: var(--ink-faint); }
  </style>

</Layout>
