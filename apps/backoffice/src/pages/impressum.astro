---
import Layout from '../layouts/Layout.astro';
import { getUserHotels } from '@retaha/auth';

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
---

<Layout title="Impressum · retaha" activeTab="backoffice" hotelName={hotel?.name} hotelLogoUrl={(hotel as any)?.logo_primary ?? (hotel as any)?.logo_dark}>

  <div class="settings-page" style="padding-top:0">
    <nav class="breadcrumb" style="padding-top:36px" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">Steuerung</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Impressum</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title">Impressum<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">Angaben gemäß § 5 TMG</p>
    </section>

    <div class="lg-body">

      <div class="lg-card">
        <h2 class="lg-h2">Anbieter</h2>
        <p><strong>retaha GmbH</strong><br />Weinsteige 31<br />74676 Niedernhall<br />Deutschland</p>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">Vertretungsberechtigter Geschäftsführer</h2>
        <p>Taha Mustafa Ünal</p>

        <h2 class="lg-h2">Kontakt</h2>
        <p>Tel: +49 7131 3824635<br />E-Mail: <a href="mailto:hallo@retaha.de">hallo@retaha.de</a></p>

        <h2 class="lg-h2">Registereintrag</h2>
        <p>Eintragung im Handelsregister<br />Registergericht: Amtsgericht Stuttgart<br />Registernummer: HRB 786739</p>

        <h2 class="lg-h2">Umsatzsteuer-ID</h2>
        <p>gemäß § 27a UStG: <strong>DE356391706</strong></p>

        <h2 class="lg-h2">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
        <p>Taha Mustafa Ünal<br />Anschrift wie oben</p>

        <h2 class="lg-h2">Online-Streitbeilegung (OS)</h2>
        <p>
          Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung bereit:
          <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener">ec.europa.eu/consumers/odr</a>
        </p>
        <p>Die retaha GmbH ist nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
      </div>

      <div class="lg-nav">
        <a href="/datenschutz">Datenschutz</a>
        <a href="/agb">AGB</a>
        <a href="/avv">AVV</a>
      </div>

    </div>
  </div>

</Layout>

<style>
  .lg-body { display: flex; flex-direction: column; gap: 12px; padding-bottom: 64px; }

  .lg-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 18px 20px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .lg-h2 {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--petrol, #14616E);
    margin-top: 16px; margin-bottom: 2px;
  }
  .lg-h2:first-child { margin-top: 0; }
  .lg-card p { font-size: 13px; color: var(--ink-muted); line-height: 1.65; margin: 0; }
  .lg-card p + p { margin-top: 4px; }
  .lg-card strong { color: var(--ink); font-weight: 600; }
  .lg-card a { color: var(--petrol, #14616E); text-decoration: underline; text-underline-offset: 3px; }
  .lg-card a:hover { opacity: 0.75; }

  .lg-nav {
    display: flex; gap: 16px; flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em;
    padding-top: 4px;
  }
  .lg-nav a { color: var(--ink-muted); text-decoration: none; transition: color 150ms; }
  .lg-nav a:hover { color: var(--petrol, #14616E); }
</style>
