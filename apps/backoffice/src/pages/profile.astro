---
// retaha Account — Hub /profil (Konto-Sektion). Sidebar/Header via AccountShell.
// E-Mail-Änderung (primär + sekundär) per Bestätigungscode an die Zieladresse:
// Code wird mit encryptSecret (MFA-Key) in user_metadata.pending_email abgelegt
// (NICHT user-entschlüsselbar → kein Bypass), Versand via interne SMTP.
// Passwort-Änderung mit Re-Auth (aktuelles Passwort). Kein DB-Change.
import Layout from '../layouts/Layout.astro';
import AccountShell from '../components/account/AccountShell.astro';
import { getUser, createSupabaseServerInstance, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
import { encryptSecret, decryptSecret } from '@retaha/auth/mfa';
import { createClient } from '@supabase/supabase-js';
import { getEnv } from '@retaha/db';
import { sendEmail as sendInternalEmail } from '../lib/email/microsoft-smtp';
import { randomInt } from 'node:crypto';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const ROLE_LABELS: Record<string, string> = { owner: bt('role.owner', lang), manager: bt('role.manager', lang), staff: bt('role.staff', lang) };
const CODE_TTL_MS = 10 * 60 * 1000;

interface Pending { email: string; purpose: 'primary' | 'secondary'; code_enc: string; exp: number; }

function codeEmailHtml(code: string, purpose: 'primary' | 'secondary'): string {
  const what = purpose === 'primary' ? bt('prof.mail.what.primary', lang) : bt('prof.mail.what.secondary', lang);
  return `<!doctype html><html><body style="font-family:Arial,sans-serif;color:#1A1A1A;background:#FBFAF7;padding:32px">
    <div style="max-width:440px;margin:0 auto;background:#fff;border:1px solid #E7E4DD;border-radius:8px;padding:32px">
      <p style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:#8C867F;margin:0 0 16px">${bt('prof.mail.eyebrow', lang)}</p>
      <p style="font-size:15px;margin:0 0 8px">${bt('prof.mail.body', lang).replace('{what}', what)}</p>
      <p style="font-family:monospace;font-size:34px;letter-spacing:0.3em;font-weight:600;margin:16px 0;color:#0A0A0A">${code}</p>
      <p style="font-size:13px;color:#8C867F;margin:8px 0 0">${bt('prof.mail.valid', lang)}</p>
    </div></body></html>`;
}

let message: { type: 'success' | 'error'; text: string } | null = null;
let attemptedAction: string | undefined;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();
  attemptedAction = action;
  const admin = createSupabaseServiceRoleInstance();
  const meta = (user.user_metadata ?? {}) as Record<string, unknown>;

  if (action === 'save_profile') {
    const first = (form.get('first_name')?.toString() ?? '').trim();
    const last  = (form.get('last_name')?.toString() ?? '').trim();
    if (!first || !last) {
      message = { type: 'error', text: bt('prof.msg.namerequired', lang) };
    } else {
      const { error } = await client.from('user_profiles').upsert(
        { user_id: user.id, first_name: first, last_name: last, updated_at: new Date().toISOString() },
        { onConflict: 'user_id' },
      );
      message = error
        ? { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` }
        : { type: 'success', text: bt('common.saved', lang) };
    }
  }

  // ── E-Mail (primär/sekundär): Code senden ──
  else if (action === 'send_email_code') {
    const purpose = form.get('purpose')?.toString() === 'secondary' ? 'secondary' : 'primary';
    const target = (form.get('email')?.toString() ?? '').trim().toLowerCase();
    if (!target || !target.includes('@')) {
      message = { type: 'error', text: bt('prof.msg.emailinvalid', lang) };
    } else if (target === (user.email ?? '').toLowerCase()) {
      message = { type: 'error', text: bt('prof.msg.emailcurrent', lang) };
    } else {
      const code = String(randomInt(0, 1_000_000)).padStart(6, '0');
      const pending: Pending = { email: target, purpose, code_enc: encryptSecret(code), exp: Date.now() + CODE_TTL_MS };
      const sent = await sendInternalEmail({
        to: target,
        subject: bt('prof.mail.subject', lang),
        html: codeEmailHtml(code, purpose),
        fromName: 'retaha',
      });
      if (!sent.ok) {
        message = { type: 'error', text: bt('prof.msg.codesendfail', lang) };
      } else {
        await admin.auth.admin.updateUserById(user.id, { user_metadata: { ...meta, pending_email: pending } });
        message = { type: 'success', text: bt('prof.email.codesent', lang).replace('{email}', target) };
      }
    }
  }

  // ── E-Mail: Code bestätigen → anwenden ──
  else if (action === 'verify_email_code') {
    const entered = (form.get('code')?.toString() ?? '').trim();
    const pending = meta.pending_email as Pending | undefined;
    if (!pending) {
      message = { type: 'error', text: bt('prof.msg.nocode', lang) };
    } else if (Date.now() > pending.exp) {
      await admin.auth.admin.updateUserById(user.id, { user_metadata: { ...meta, pending_email: null } });
      message = { type: 'error', text: bt('prof.msg.codeexpired', lang) };
    } else {
      let valid = false;
      try { valid = /^\d{6}$/.test(entered) && decryptSecret(pending.code_enc) === entered; } catch { valid = false; }
      if (!valid) {
        message = { type: 'error', text: bt('prof.msg.codewrong', lang) };
      } else if (pending.purpose === 'primary') {
        const { error } = await admin.auth.admin.updateUserById(user.id, {
          email: pending.email, email_confirm: true, user_metadata: { ...meta, pending_email: null },
        });
        message = error
          ? { type: 'error', text: `${bt('prof.msg.emailchangefail', lang)}: ${error.message}` }
          : { type: 'success', text: bt('prof.msg.emailchanged', lang) };
      } else {
        const { error } = await admin.auth.admin.updateUserById(user.id, {
          user_metadata: { ...meta, pending_email: null, secondary_email: pending.email },
        });
        message = error
          ? { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` }
          : { type: 'success', text: bt('prof.msg.secadded', lang) };
      }
    }
  }

  else if (action === 'cancel_email_code') {
    await admin.auth.admin.updateUserById(user.id, { user_metadata: { ...meta, pending_email: null } });
  }

  else if (action === 'remove_secondary_email') {
    await admin.auth.admin.updateUserById(user.id, { user_metadata: { ...meta, secondary_email: null } });
    message = { type: 'success', text: bt('prof.msg.secremoved', lang) };
  }

  // ── Passwort (mit Re-Auth) ──
  else if (action === 'change_password') {
    const current = form.get('current_password')?.toString() ?? '';
    const pw  = form.get('password')?.toString() ?? '';
    const pw2 = form.get('password_confirm')?.toString() ?? '';
    if (!current) {
      message = { type: 'error', text: bt('prof.msg.pwcurrent', lang) };
    } else if (pw.length < 8) {
      message = { type: 'error', text: bt('prof.msg.pwshort', lang) };
    } else if (pw !== pw2) {
      message = { type: 'error', text: bt('prof.msg.pwmismatch', lang) };
    } else {
      const url = getEnv('PUBLIC_SUPABASE_URL');
      const anon = getEnv('PUBLIC_SUPABASE_ANON_KEY');
      const check = (url && anon)
        ? await createClient(url, anon).auth.signInWithPassword({ email: user.email, password: current })
        : { error: { message: 'config' } } as { error: { message: string } };
      if (check.error) {
        message = { type: 'error', text: bt('prof.msg.pwwrong', lang) };
      } else {
        const { error } = await admin.auth.admin.updateUserById(user.id, { password: pw });
        message = error
          ? { type: 'error', text: `${bt('prof.msg.pwchangefail', lang)}: ${error.message}` }
          : { type: 'success', text: bt('prof.msg.pwchanged', lang) };
      }
    }
  }
}

// Frischen User nach POST lesen (Metadaten/Email können sich geändert haben).
let displayUser = user;
if (Astro.request.method === 'POST') {
  const u2 = await getUser(Astro.cookies, Astro.request);
  if (u2) displayUser = u2;
}

const { data: profile } = await client.from('user_profiles').select('first_name, last_name').eq('user_id', user.id).maybeSingle();
const { data: hotelUser } = await client.from('hotel_users').select('role').eq('user_id', user.id).maybeSingle();

const firstName    = profile?.first_name ?? '';
const lastName     = profile?.last_name ?? '';
const currentEmail = displayUser.email ?? '';
const role         = (hotelUser?.role ?? 'staff') as string;
const roleLabel    = ROLE_LABELS[role] ?? role;
const fullName     = [firstName, lastName].filter(Boolean).join(' ');
const initials     = (firstName.charAt(0) || currentEmail.charAt(0)).toUpperCase();
const dMeta        = (displayUser.user_metadata ?? {}) as Record<string, unknown>;
const avatarUrl    = (dMeta.avatar_url as string | undefined) ?? null;
const secondaryEmail = (dMeta.secondary_email as string | undefined) ?? null;
const pendingEmail = dMeta.pending_email as Pending | undefined;

// Bei Validierungsfehler öffnet der betroffene Editor nach dem Reload wieder.
const emailActions = ['send_email_code', 'verify_email_code', 'cancel_email_code', 'remove_secondary_email'];
const errorTile = (message?.type === 'error' || (pendingEmail && attemptedAction === 'send_email_code'))
  ? (attemptedAction === 'save_profile' ? 'name'
    : attemptedAction && emailActions.includes(attemptedAction) ? 'email'
    : attemptedAction === 'change_password' ? 'password'
    : null)
  : null;
// Offener Code → E-Mail-Editor offen halten (zum Code-Eingeben).
const openTile = pendingEmail ? 'email' : errorTile;
---

<Layout title="retaha Account" activeTab="backoffice">
  <AccountShell active="profile" initials={initials} displayName={fullName || currentEmail} roleLabel={roleLabel} avatarUrl={avatarUrl} lang={lang}>

    <section class="acct__section" id="konto">
      <div class="acct__section-head">
        <h2 class="acct__section-title">{bt('prof.section.title', lang)}</h2>
        <p class="acct__section-desc">{bt('prof.section.desc', lang)}</p>
      </div>

      <div class="settings-sections">

        <!-- 01 Name -->
        <section class="s-card" id="profile-name">
          <div class="s-card__head">
            <h2 class="s-card__title">{bt('prof.name.label', lang)}</h2>
          </div>
          <form method="POST" class="s-card__body">
            <input type="hidden" name="_action" value="save_profile" />
            <div class="field field--row">
              <label class="field__label field__label--req" for="first_name">{bt('prof.name.first', lang)}</label>
              <div class="field__input-wrap">
                <input type="text" id="first_name" name="first_name" value={firstName} required maxlength="60" autocomplete="given-name" class="s-input" />
              </div>
            </div>
            <div class="field field--row">
              <label class="field__label field__label--req" for="last_name">{bt('prof.name.last', lang)}</label>
              <div class="field__input-wrap">
                <input type="text" id="last_name" name="last_name" value={lastName} required maxlength="60" autocomplete="family-name" class="s-input" />
              </div>
            </div>
            <div class="s-card__footer">
              <button type="submit" class="v9-btn v9-btn--primary">{bt('common.save', lang)}</button>
            </div>
          </form>
        </section>

        <!-- 02 E-Mail -->
        <section class="s-card" id="profile-email">
          <div class="s-card__head">
            <h2 class="s-card__title">{bt('prof.email.label', lang)}</h2>
          </div>
          <div class="s-card__body">

            {pendingEmail && pendingEmail.purpose === 'primary' ? (
              <form method="POST">
                <input type="hidden" name="_action" value="verify_email_code" />
                <div class="field field--row">
                  <span class="field__label">{bt('prof.email.current', lang)}</span>
                  <div class="pr-readonly"><span>{currentEmail}</span></div>
                </div>
                <p class="acct-codehint" set:html={bt('prof.email.codesent', lang).replace('{email}', `<strong>${pendingEmail.email}</strong>`)}></p>
                <div class="field field--row">
                  <label class="field__label" for="email_code">{bt('prof.email.code', lang)}</label>
                  <div class="field__input-wrap">
                    <input type="text" id="email_code" name="code" inputmode="numeric" maxlength="6" placeholder="000000" autocomplete="one-time-code" class="s-input acct-code-input" />
                  </div>
                </div>
                <div class="s-card__footer">
                  <button type="submit" form="cancel-primary" class="v9-btn v9-btn--ghost">{bt('prof.email.otheraddr', lang)}</button>
                  <button type="submit" class="v9-btn v9-btn--primary">{bt('common.confirm', lang)}</button>
                </div>
              </form>
            ) : (
              <form method="POST">
                <input type="hidden" name="_action" value="send_email_code" />
                <input type="hidden" name="purpose" value="primary" />
                <div class="field field--row">
                  <span class="field__label">{bt('prof.email.current', lang)}</span>
                  <div class="pr-readonly"><span>{currentEmail}</span></div>
                </div>
                <div class="field field--row">
                  <label class="field__label" for="email">{bt('prof.email.new', lang)}</label>
                  <div class="field__input-wrap">
                    <input type="email" id="email" name="email" placeholder="neu@beispiel.de" autocomplete="email" class="s-input" />
                    <span class="field__hint">{bt('prof.email.newhint', lang)}</span>
                  </div>
                </div>
                <div class="s-card__footer">
                  <button type="submit" class="v9-btn v9-btn--primary">{bt('prof.email.sendcode', lang)}</button>
                </div>
              </form>
            )}

            <div class="ts-divider"></div>

            {secondaryEmail ? (
              <div class="field field--row">
                <span class="field__label">{bt('prof.email.sec', lang)}</span>
                <div class="acct-added-row">
                  <span class="acct-added">{secondaryEmail} · {bt('prof.email.sec.added', lang)}</span>
                  <form method="POST">
                    <input type="hidden" name="_action" value="remove_secondary_email" />
                    <button type="submit" class="v9-btn v9-btn--ghost">{bt('common.remove', lang)}</button>
                  </form>
                </div>
              </div>
            ) : pendingEmail && pendingEmail.purpose === 'secondary' ? (
              <form method="POST">
                <input type="hidden" name="_action" value="verify_email_code" />
                <p class="acct-codehint" set:html={bt('prof.email.codesent', lang).replace('{email}', `<strong>${pendingEmail.email}</strong>`)}></p>
                <div class="field field--row">
                  <label class="field__label" for="sec_code">{bt('prof.email.code', lang)}</label>
                  <div class="field__input-wrap">
                    <input type="text" id="sec_code" name="code" inputmode="numeric" maxlength="6" placeholder="000000" autocomplete="one-time-code" class="s-input acct-code-input" />
                  </div>
                </div>
                <div class="s-card__footer">
                  <button type="submit" form="cancel-secondary" class="v9-btn v9-btn--ghost">{bt('common.cancel', lang)}</button>
                  <button type="submit" class="v9-btn v9-btn--primary">{bt('common.confirm', lang)}</button>
                </div>
              </form>
            ) : (
              <form method="POST">
                <input type="hidden" name="_action" value="send_email_code" />
                <input type="hidden" name="purpose" value="secondary" />
                <div class="field field--row">
                  <label class="field__label" for="secondary_email">{bt('prof.email.sec', lang)}</label>
                  <div class="field__input-wrap">
                    <input type="email" id="secondary_email" name="email" placeholder="backup@beispiel.de" autocomplete="email" class="s-input" />
                    <span class="field__hint">{bt('prof.email.sec.hint', lang)}</span>
                  </div>
                </div>
                <div class="s-card__footer">
                  <button type="submit" class="v9-btn v9-btn--primary">{bt('prof.email.sec.add', lang)}</button>
                </div>
              </form>
            )}

          </div>
        </section>

        <!-- 03 Passwort -->
        <section class="s-card" id="profile-password" x-data="{ pwCurrent: '' }">
          <div class="s-card__head">
            <h2 class="s-card__title">{bt('prof.pw.label', lang)}</h2>
          </div>
          <form method="POST" class="s-card__body">
            <input type="hidden" name="_action" value="change_password" />
            <div class="field field--row">
              <label class="field__label field__label--req" for="current_password">{bt('prof.pw.current', lang)}</label>
              <div class="field__input-wrap">
                <input type="password" id="current_password" name="current_password" autocomplete="current-password" class="s-input" x-model="pwCurrent" />
                <span class="field__hint">{bt('prof.pw.currenthint', lang)}</span>
              </div>
            </div>
            <div class="field field--row">
              <label class="field__label" for="password">{bt('prof.pw.new', lang)}</label>
              <div class="field__input-wrap">
                <input type="password" id="password" name="password" minlength="8" autocomplete="new-password" class="s-input" x-bind:disabled="!pwCurrent" />
                <span class="field__hint">{bt('prof.pw.newhint', lang)}</span>
              </div>
            </div>
            <div class="field field--row">
              <label class="field__label" for="password_confirm">{bt('prof.pw.repeat', lang)}</label>
              <div class="field__input-wrap">
                <input type="password" id="password_confirm" name="password_confirm" minlength="8" autocomplete="new-password" class="s-input" x-bind:disabled="!pwCurrent" />
              </div>
            </div>
            <div class="s-card__footer">
              <button type="submit" class="v9-btn v9-btn--primary" x-bind:disabled="!pwCurrent">{bt('prof.pw.edit', lang)}</button>
            </div>
          </form>
        </section>

        <!-- 04 Rolle (read-only) -->
        <section class="s-card" id="profile-role">
          <div class="s-card__head">
            <h2 class="s-card__title">{bt('prof.role.label', lang)}</h2>
          </div>
          <div class="s-card__body">
            <div class="field field--row">
              <span class="field__label">{bt('prof.role.label', lang)}</span>
              <div x-data="{ open: false }" class="role-wrap">
                <div class="pr-readonly">
                  <span>{roleLabel}</span>
                  <button type="button" class="role-info-btn" @click="open = !open" :class="{ 'is-active': open }" aria-label="Info">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  </button>
                </div>
                <div class="role-info-box" x-show="open" x-transition x-cloak set:html={bt('prof.role.hint', lang).replace('{link}', `<a href="/team" class="field__hint-link">${bt('prof.role.teamlink', lang)}</a>`)}></div>
              </div>
            </div>
          </div>
        </section>

      </div>

      {pendingEmail && (
        <form method="POST" id={pendingEmail.purpose === 'primary' ? 'cancel-primary' : 'cancel-secondary'} hidden>
          <input type="hidden" name="_action" value="cancel_email_code" />
        </form>
      )}
    </section>

  </AccountShell>

  {message && (
    <script is:inline set:html={`(function(){var m=${JSON.stringify(message.text)},t=${JSON.stringify(message.type === 'success' ? 'success' : 'error')};function go(){window.retahaToast&&window.retahaToast(m,t)}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',go);else go();})();`}></script>
  )}
</Layout>

<style>
  /* ── E-Mail-Box: forms erben s-card__body Gap ─────────────────────────── */
  .s-card__body form { display: flex; flex-direction: column; gap: 18px; }

  /* ── bf-cta overrides ──────────────────────────────────────────────────── */
  .v9-btn { min-height: auto !important; }
  .v9-btn.v9-btn--primary {
    background: var(--petrol, #14616E) !important; color: #fff !important;
    border: none !important; border-radius: 7px !important; padding: 7px 16px !important;
    font-family: 'JetBrains Mono', monospace !important; font-size: 11px !important;
    font-weight: 600 !important; letter-spacing: 0.14em !important;
    text-transform: uppercase !important; position: static !important;
    display: inline-flex !important; align-items: center !important;
    transition: filter 150ms ease !important;
  }
  .v9-btn.v9-btn--primary::before,
  .v9-btn.v9-btn--primary::after { display: none !important; }
  .v9-btn.v9-btn--primary:hover:not(:disabled) { filter: brightness(1.1) !important; }
  .v9-btn.v9-btn--primary:disabled { opacity: 0.45 !important; cursor: not-allowed !important; }
  .v9-btn.v9-btn--ghost {
    background: transparent !important; color: var(--ink-muted) !important;
    border: 1px solid var(--border-medium, rgba(10,10,10,.16)) !important;
    border-radius: 7px !important; padding: 7px 16px !important;
    font-family: 'JetBrains Mono', monospace !important; font-size: 11px !important;
    font-weight: 600 !important; letter-spacing: 0.14em !important; text-transform: uppercase !important;
  }
  .v9-btn.v9-btn--ghost:hover:not(:disabled) { color: var(--ink) !important; border-color: var(--ink) !important; }

  /* ── Divider ─────────────────────────────────────────────────────────── */
  .ts-divider { height: 1px; background: var(--border); margin: 16px 0; }

  /* ── Readonly-Feld ────────────────────────────────────────────────────── */
  .pr-readonly {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); padding: 10px 14px;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; color: var(--ink);
    word-break: break-word;
  }

  /* ── Code-Input ───────────────────────────────────────────────────────── */
  .acct-codehint { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); margin: 0 0 12px; }
  .acct-codehint strong { color: var(--ink); }
  .acct-code-input { max-width: 160px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.3em; text-align: center; }

  /* ── Sekundär-E-Mail hinzugefügt ─────────────────────────────────────── */
  .acct-added-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .acct-added {
    display: inline-flex; align-items: center;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600;
    letter-spacing: 0.08em; color: var(--sage-strong, #4a7a5c);
    background: var(--sage-soft, rgba(92,144,112,0.10)); border: 1px solid var(--sage, #5C9070);
    padding: 7px 16px; border-radius: 7px; word-break: break-word;
  }

  /* ── Link-Hint ────────────────────────────────────────────────────────── */
  .field__hint-link { color: var(--petrol, #14616E); text-decoration: underline; text-underline-offset: 2px; }
  .field__hint-link:hover { opacity: 0.75; }

  /* ── Rollen-Info ─────────────────────────────────────────────────────── */
  .role-wrap { display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .role-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0;
    background: transparent; border: 1.5px solid var(--petrol, #14616E);
    color: var(--petrol, #14616E); cursor: pointer; padding: 0;
