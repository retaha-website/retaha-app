---
// retaha Account — Sicherheit /profil/sicherheit. Hub-Shell wie /profil.
// Persönliche 2FA (TwoFactorSection) + Team-Sicherheit (owner-only, aus
// Hotel-Daten hierher verschoben). Pflicht-Redirect-Ziel (?required=true).
import Layout from '../../layouts/Layout.astro';
import AccountShell from '../../components/account/AccountShell.astro';
import TwoFactorSection from '../../components/profil/TwoFactorSection.astro';
import { getUser, createSupabaseServerInstance, createSupabaseServiceRoleInstance, clampTimeoutHours } from '@retaha/auth';
import { getUserMfaStatus, getHotelMfaPolicy } from '@retaha/auth/mfa';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const ROLE_LABELS: Record<string, string> = { owner: bt('role.owner', lang), manager: bt('role.manager', lang), staff: bt('role.staff', lang) };

const { data: hotelUser } = await client.from('hotel_users').select('role, hotel_id').eq('user_id', user.id).maybeSingle();
const role     = (hotelUser?.role ?? 'staff') as string;
const hotelId  = hotelUser?.hotel_id as string | undefined;
const isOwner  = role === 'owner';

// ─── POST: Team-Sicherheit (Session-Timeout; nur Owner) ────────────────────
let saved: { ok: boolean; msg: string } | null = null;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (form.get('_action')?.toString() === 'team_security' && isOwner && hotelId) {
    const session_timeout_hours = clampTimeoutHours(form.get('session_timeout_hours')?.toString());
    const { error } = await client.from('hotels').update({ session_timeout_hours }).eq('id', hotelId);
    saved = error ? { ok: false, msg: error.message } : { ok: true, msg: bt('common.savedshort', lang) };
  }
}

const { data: profile } = await client.from('user_profiles').select('first_name, last_name').eq('user_id', user.id).maybeSingle();
const { data: hotelSec } = (isOwner && hotelId)
  ? await client.from('hotels').select('mfa_required_for_team, session_timeout_hours').eq('id', hotelId).maybeSingle()
  : { data: null };

const firstName    = profile?.first_name ?? '';
const lastName     = profile?.last_name ?? '';
const currentEmail = user.email ?? '';
const roleLabel    = ROLE_LABELS[role] ?? role;
const fullName     = [firstName, lastName].filter(Boolean).join(' ');
const initials     = (firstName.charAt(0) || currentEmail.charAt(0)).toUpperCase();
const avatarUrl    = ((user.user_metadata as Record<string, unknown> | undefined)?.avatar_url as string | undefined) ?? null;

const mfaRequiredForTeam = hotelSec?.mfa_required_for_team === true;
const sessionTimeout     = String((hotelSec?.session_timeout_hours as number | undefined) ?? 4);

// 2FA-Status (user_mfa ist Service-Role-verwaltet) + Hotel-Pflicht-Policy.
const service = createSupabaseServiceRoleInstance();
const mfaStatus = await getUserMfaStatus(service, user.id);
const hotelPolicy = hotelId ? await getHotelMfaPolicy(service, hotelId) : null;
const mfaEnabled        = mfaStatus?.enabled ?? false;
const mfaRequired       = hotelPolicy?.required ?? false;
const recoveryRemaining = mfaStatus?.recoveryCodesRemaining ?? 0;
const isRequired        = Astro.url.searchParams.get('required') === 'true';

// ─── Team-Übersicht (owner-only): Mitglieder + 2FA-Status (aus /team-security) ──
type MfaState = 'active' | 'pending' | 'inactive';
let team: { email: string; mfaState: MfaState }[] = [];
let pendingCount = 0;
if (isOwner && hotelId) {
  const { data: members } = await service.from('hotel_users').select('user_id').eq('hotel_id', hotelId);
  const memberIds = (members ?? []).map((m) => (m as { user_id: string }).user_id);
  const { data: mfaRows } = memberIds.length
    ? await service.from('user_mfa').select('user_id, enabled, verified_at').in('user_id', memberIds)
    : { data: [] as unknown[] };
  const mfaByUser = new Map(
    (mfaRows ?? []).map((m) => [(m as { user_id: string }).user_id, m as { enabled: boolean; verified_at: string | null }]),
  );
  const { data: authList } = await service.auth.admin.listUsers({ page: 1, perPage: 1000 });
  const emailMap = new Map((authList?.users ?? []).map((u) => [u.id, u.email ?? '']));
  team = (members ?? []).map((m) => {
    const uid = (m as { user_id: string }).user_id;
    const mf = mfaByUser.get(uid);
    const mfaState: MfaState = mf?.enabled && mf.verified_at ? 'active' : mf && !mf.enabled ? 'pending' : 'inactive';
    return { email: emailMap.get(uid) || '—', mfaState };
  });
  pendingCount = team.filter((m) => m.mfaState !== 'active').length;
}
const activeCount = team.length - pendingCount;
---

<Layout title="retaha Account · Sicherheit" activeTab="backoffice">
  <AccountShell active="security" initials={initials} displayName={fullName || currentEmail} roleLabel={roleLabel} avatarUrl={avatarUrl} lang={lang}>

    <section class="acct__section" id="security-section">
      <div class="acct__section-head">
        <h2 class="acct__section-title">{bt('hub.security', lang)}</h2>
        <p class="acct__section-desc">{bt('sec.section.desc', lang)}</p>
      </div>

      <div class="settings-sections">
        <TwoFactorSection
          mfaEnabled={mfaEnabled}
          mfaRequired={mfaRequired}
          recoveryRemaining={recoveryRemaining}
          isRequired={isRequired}
          magicLinkEnabled={(mfaStatus as Record<string, unknown> | null)?.requireOnMagicLink === true}
          lang={lang}
        />

        {isOwner && (
        <section class="s-card" id="team-security">
          <div class="s-card__head">
            <h2 class="s-card__title">{bt('sec.team.title', lang)}</h2>
          </div>

          <form method="POST" class="s-card__body">
            <input type="hidden" name="_action" value="team_security" />

            <div class="field field--row">
              <span class="field__label">{bt('sec.team.mfaall', lang)}</span>
              <div x-data={`persistToggle({ initial: ${mfaRequiredForTeam}, field: 'mfa_required_for_team' })`}>
                <label class="toggle-row bf-close-toggle">
                  <input type="checkbox" :checked="checked" class="sr-only" @change="toggle($event)" />
                  <span class="bt-visual" :class="{'is-checked': checked}">
                    <span class="bt-knob"></span>
                  </span>
                  <span class="toggle-label">{bt('sec.team.mfaall.hint', lang)}</span>
                </label>
                <p x-show="error" x-cloak class="field__hint" style="color:var(--burgund);margin-top:4px" x-text="error"></p>
              </div>
            </div>

            <div class="field field--row">
              <label class="field__label">{bt('sec.team.timeout', lang)}</label>
              <div class="field__input-wrap">
                <div x-data={`{open:false,val:'${sessionTimeout}',opts:${JSON.stringify({'1':bt('sec.timeout.1h',lang),'2':bt('sec.timeout.2h',lang),'4':bt('sec.timeout.4h',lang),'8':bt('sec.timeout.8h',lang),'24':bt('sec.timeout.24h',lang),'0':bt('sec.timeout.none',lang)})}}`} class="st-dd" @click.outside="open=false">
                  <input type="hidden" name="session_timeout_hours" x-bind:value="val" />
                  <button type="button" class="st-dd-btn" @click="open=!open">
                    <span x-text="opts[val]"></span>
                    <svg class="st-dd-chevron" :class="{'rotated':open}" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </button>
                  <div class="st-dd-menu" x-show="open" x-cloak>
                    {[['1', bt('sec.timeout.1h',lang)],['2', bt('sec.timeout.2h',lang)],['4', bt('sec.timeout.4h',lang)],['8', bt('sec.timeout.8h',lang)],['24', bt('sec.timeout.24h',lang)],['0', bt('sec.timeout.none',lang)]].map(([v, label]) => (
                      <button type="button" class="st-dd-opt" :class={`{'is-active': val==='${v}'}`} @click={`val='${v}'; open=false`}>
                        {label}
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" x-show={`val==='${v}'`} style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
                      </button>
                    ))}
                  </div>
                </div>
                <span class="field__hint">{bt('sec.team.timeout.hint', lang)}</span>
              </div>
            </div>

            <div class="s-card__footer">
              <button type="submit" class="v9-btn v9-btn--primary">{bt('common.save', lang)}</button>
            </div>
          </form>

          <div class="ts-divider"></div>

          <div class="ts-team">
            <div class="ts-team__head">
              <span class="ts-team__title">{bt('sec.overview.title', lang)}</span>
              <span class="ts-team__sub">{team.length} {team.length === 1 ? bt('sec.member.one', lang) : bt('sec.member.many', lang)} · {activeCount} {bt('sec.overview.activesuffix', lang)}</span>
            </div>
            <ul class="ts-team__list">
              {team.map((m) => (
                <li class="ts-team__row">
                  <span class="ts-team__email">{m.email}</span>
                  <span class={`ts-team__status ts-team__status--${m.mfaState}`}>
                    {m.mfaState === 'active' ? bt('sec.status.active', lang) : m.mfaState === 'pending' ? bt('sec.status.pending', lang) : bt('sec.status.inactive', lang)}
                  </span>
                </li>
              ))}
            </ul>
          </div>

          {mfaRequiredForTeam && pendingCount > 0 && (
            <div class="ts-enforce" x-data={`{ busy: false, sendReminder() { this.busy = true; fetch('/api/mfa/send-reminder', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ hotelId: ${JSON.stringify(hotelId)} }) }).then(function(r){return r.json()}).then(function(d){ window.retahaToast && window.retahaToast(d.ok ? ${JSON.stringify(bt('sec.reminder.sent', lang))} : (d.message || ${JSON.stringify(bt('sec.reminder.fail', lang))}), d.ok ? 'success' : 'error'); }).catch(function(){ window.retahaToast && window.retahaToast(${JSON.stringify(bt('sec.reminder.neterr', lang))}, 'error'); }).finally(function(){ this.busy = false; }.bind(this)); } }`}>
              <p class="ts-enforce__text" set:html={bt('sec.enforce', lang).replace('{count}', String(pendingCount)).replace('{total}', String(team.length)).replace('{members}', team.length === 1 ? bt('sec.member.one', lang) : bt('sec.member.many', lang))}></p>
              <button type="button" class="v9-btn v9-btn--ghost" x-on:click="sendReminder()" x-bind:disabled="busy">{bt('sec.enforce.send', lang)}</button>
            </div>
          )}
        </section>
        )}
      </div>
    </section>

  </AccountShell>

  {saved && (
    <script is:inline set:html={`(function(){var m=${JSON.stringify(saved.msg)},t=${JSON.stringify(saved.ok ? 'success' : 'error')};function go(){window.retahaToast&&window.retahaToast(m,t)}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',go);else go();})();`}></script>
  )}

  <!-- Flash nach client-seitigem Reload (z.B. 2FA deaktiviert). -->
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      var f = sessionStorage.getItem('pr_flash');
      if (f) { sessionStorage.removeItem('pr_flash'); window.retahaToast && window.retahaToast(f, 'success'); }
    });
  </script>

  <style>
    /* bf-cta overrides */
    .v9-btn { min-height: auto !important; }
    .v9-btn.v9-btn--primary {
      background: var(--petrol, #14616E) !important;
      color: #fff !important;
      border: none !important;
      border-radius: 7px !important;
      padding: 7px 16px !important;
      font-family: 'JetBrains Mono', monospace !important;
      font-size: 11px !important;
      font-weight: 600 !important;
      letter-spacing: 0.14em !important;
      text-transform: uppercase !important;
      position: static !important;
      display: inline-flex !important;
      align-items: center !important;
      transition: filter 150ms ease !important;
    }
    .v9-btn.v9-btn--primary::before,
    .v9-btn.v9-btn--primary::after { display: none !important; }
    .v9-btn.v9-btn--primary:hover:not(:disabled) { filter: brightness(1.1) !important; background: var(--petrol, #14616E) !important; color: #fff !important; }
    .v9-btn.v9-btn--ghost {
      background: transparent !important;
      color: var(--ink-muted) !important;
      border: 1px solid var(--border-medium, rgba(10,10,10,.16)) !important;
      border-radius: 7px !important;
      padding: 7px 16px !important;
      font-family: 'JetBrains Mono', monospace !important;
      font-size: 11px !important;
      font-weight: 600 !important;
      letter-spacing: 0.14em !important;
      text-transform: uppercase !important;
    }
    .v9-btn.v9-btn--ghost:hover:not(:disabled) { color: var(--ink) !important; border-color: var(--ink) !important; background: transparent !important; }

    .ts-divider { height: 1px; background: var(--border); margin: 22px 0 20px; }
    .ts-team__head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
    .ts-team__title { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; color: var(--ink); }
    .ts-team__sub { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); }
    .ts-team__list { list-style: none; margin: 0; padding: 0; border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; }
    .ts-team__row { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 11px 14px; border-bottom: 1px solid var(--border); }
    .ts-team__row:last-child { border-bottom: none; }
    .ts-team__email { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink); word-break: break-all; }
    .ts-team__status { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 10px; border-radius: 99px; white-space: nowrap; flex-shrink: 0; }
    .ts-team__status--active   { background: var(--sage-soft, rgba(92,144,112,0.10)); color: var(--sage, #5C9070); }
    .ts-team__status--pending  { background: rgba(255,74,130,0.08); color: var(--petrol, #14616E); }
    .ts-team__status--inactive { background: var(--bg-deep); color: var(--ink-muted); }
    .ts-enforce { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-top: 18px; padding: 14px 16px; background: var(--bg-deep); border-left: 3px solid var(--petrol, #14616E); border-radius: var(--r-sm); }
    .ts-enforce__text { font-size: 13px; color: var(--ink); margin: 0; line-height: 1.5; }
    .ts-enforce__text strong { font-weight: 600; }

  </style>
</Layout>
