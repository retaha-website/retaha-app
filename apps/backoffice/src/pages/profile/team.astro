---
// Team-Verwaltung — Untermenü des „retaha Account"-Hubs (AccountShell),
// gleiche Shell/Design wie /profile, /profile/security, /profile/hotel-data.
// URL: /profile/team (Verweise: Hauptnav, Übersicht, Account-Hub, /admin/team-Redirect).
//
// Liste aller hotel_users für das eingeloggte Hotel:
//   - aktive Mitglieder (accepted_at NOT NULL)
//   - offene Einladungen (accepted_at IS NULL)
// Owner sieht Rollen-Dropdown + Entfernen + Einladen. (team.* ist Owner-only.)

import Layout from '../../layouts/Layout.astro';
import AccountShell from '../../components/account/AccountShell.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import { getLang, bt } from '../../lib/i18n';

const lang = getLang(Astro.cookies, Astro.request);
const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole) return Astro.redirect('/admin/login?error=no_membership');

// Team-Verwaltung ist Owner-only (Matrix: manager/staff = „kein Team").
if (!hasPermission(myRole, 'team.read')) {
  return Astro.redirect('/overview?error=team_owner_only');
}

const admin = createSupabaseServiceRoleInstance();

// Team laden — alle hotel_users für dieses Hotel + matching user_profiles + auth-emails
const { data: members } = await admin
  .from('hotel_users')
  .select('id, user_id, role, invited_at, accepted_at, created_at, invited_by')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: true });

const memberRows = (members ?? []) as any[];
const userIds = Array.from(new Set(memberRows.map(m => m.user_id)));

// user_profiles parallel
const { data: profiles } = userIds.length > 0
  ? await admin.from('user_profiles').select('user_id, first_name, last_name').in('user_id', userIds)
  : { data: [] };
const profileMap = new Map((profiles ?? []).map((p: any) => [p.user_id, p]));

// auth.users via Admin-API für Emails
const { data: { users: authUsers } } = await admin.auth.admin.listUsers({ page: 1, perPage: 1000 });
const emailMap = new Map((authUsers ?? []).map(u => [u.id, u.email ?? '']));

function displayName(member: any): string {
  const p = profileMap.get(member.user_id);
  if (p?.first_name || p?.last_name) {
    return [p.first_name, p.last_name].filter(Boolean).join(' ');
  }
  return emailMap.get(member.user_id) || member.user_id.slice(0, 8) + '…';
}

const activeMembers = memberRows.filter(m => m.accepted_at);
const pendingInvites = memberRows.filter(m => !m.accepted_at);

const canInvite     = hasPermission(myRole, 'team.invite');
const canChangeRole = hasPermission(myRole, 'team.change_role');
const canRemove     = hasPermission(myRole, 'team.remove');

// ─── Hub-Shell-Daten (User-Mini in der Sidebar) ────────────────────────────
const HUB_ROLE: Record<string, string> = { owner: bt('role.owner', lang), manager: bt('role.manager', lang), staff: bt('role.staff', lang) };
const myProfile = profileMap.get(user.id) as { first_name?: string; last_name?: string } | undefined;
const hubFirst    = myProfile?.first_name ?? '';
const hubLast     = myProfile?.last_name ?? '';
const hubFullName = [hubFirst, hubLast].filter(Boolean).join(' ');
const hubEmail    = user.email ?? '';
const hubInitials = (hubFirst.charAt(0) || hubEmail.charAt(0)).toUpperCase();
const hubAvatar   = ((user.user_metadata as Record<string, unknown> | undefined)?.avatar_url as string | undefined) ?? null;
const hubRoleLabel = HUB_ROLE[myRole] ?? myRole;
---

<Layout title="retaha Account · Team" activeTab="backoffice">
  <AccountShell active="team" initials={hubInitials} displayName={hubFullName || hubEmail} roleLabel={hubRoleLabel} avatarUrl={hubAvatar} lang={lang}>

    <section class="acct__section" id="team">
      <div class="acct__section-head">
        <h2 class="acct__section-title">{bt('hub.team', lang)}</h2>
        <p class="acct__section-desc">{bt('team.section.desc', lang)}</p>
      </div>

      <div class="tm-root">

        <div class="settings-sections">

          <!-- Aktive Mitglieder -->
          <section class="s-card">
            <div class="s-card__head">
              <h2 class="s-card__title">{bt('team.active.title', lang)}</h2>
            </div>
            <div class="s-card__body">
              <div class="tm-list">
                {activeMembers.map(m => {
                  const isMe = m.user_id === user.id;
                  const isOwner = m.role === 'owner';
                  return (
                    <article class="tm-row" data-member-id={m.id}>
                      <div class="tm-row-info">
                        <p class="tm-row-name">
                          {displayName(m)}{isMe && <span class="tm-row-self"> {bt('team.self', lang)}</span>}
                        </p>
                        <p class="tm-row-meta">{emailMap.get(m.user_id) || '—'}</p>
                      </div>
                      <div class="tm-row-actions">
                        {(canChangeRole && !isOwner && !isMe) ? (
                          <select
                            class="s-select tm-role-select"
                            style="font-size:12px;padding:5px 10px"
                            data-member-id={m.id}
                            data-current-role={m.role}
                          >
                            <option value="manager" selected={m.role === 'manager'}>{bt('role.manager', lang)}</option>
                            <option value="staff" selected={m.role === 'staff'}>{bt('team.role.frontdesk', lang)}</option>
                          </select>
                        ) : (
                          <span class={`tm-badge${isOwner ? ' tm-badge--owner' : ''}`}>
                            {bt('role.' + m.role, lang)}{isOwner && ' ★'}
                          </span>
                        )}
                        {(canRemove && !isOwner && !isMe) && (
                          <button
                            type="button"
                            class="v9-btn v9-btn--danger tm-remove-btn"
                            style="font-size:11px;font-weight:300;padding:5px 12px"
                            data-member-id={m.id}
                            data-member-name={displayName(m)}
                          >
                            {bt('common.remove', lang)}
                          </button>
                        )}
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
            {canInvite && (
              <div class="s-card__footer">
                <button type="button" id="tm-invite-open" class="v9-btn v9-btn--primary">
                  {bt('team.invite.btn', lang)}
                </button>
              </div>
            )}
          </section>

          <!-- Offene Einladungen -->
          {pendingInvites.length > 0 && (
            <section class="s-card">
              <div class="s-card__head">
                <h2 class="s-card__title">{bt('team.pending.title', lang)}</h2>
              </div>
              <div class="s-card__body">
                <div class="tm-list">
                  {pendingInvites.map(m => (
                    <article class="tm-row tm-row--pending">
                      <div class="tm-row-info">
                        <p class="tm-row-name">{emailMap.get(m.user_id) || '—'}</p>
                        <p class="tm-row-meta">
                          {bt('team.invited.as', lang).replace('{role}', bt('role.' + m.role, lang))}{' '}
                          {m.invited_at
                            ? new Date(m.invited_at).toLocaleString(lang, { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' })
                            : '—'}
                        </p>
                      </div>
                      <div class="tm-row-actions">
                        <span class="tm-badge tm-badge--pending">{bt('team.pending.badge', lang)}</span>
                        {canRemove && (
                          <button
                            type="button"
                            class="v9-btn v9-btn--danger tm-remove-btn"
                            style="font-size:11px;font-weight:300;padding:5px 12px"
                            data-member-id={m.id}
                            data-member-name={emailMap.get(m.user_id) || ''}
                          >
                            {bt('team.revoke', lang)}
                          </button>
                        )}
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            </section>
          )}

        </div>{/* .settings-sections */}

        <!-- Invite-Modal — reines Vanilla-JS (Alpine-unabhängig, siehe Script unten) -->
        {canInvite && (
          <div id="tm-invite-modal" class="bp-modal-bd">
            <div class="bp-modal" role="dialog" aria-modal="true">
              <div class="bp-modal-head">
                <h3 class="bp-modal-title">{bt('team.modal.title', lang)}</h3>
                <button type="button" class="bp-modal-x tm-invite-close" aria-label={bt('common.close', lang)}>✕</button>
              </div>
              <div class="bp-modal-body">
                <div id="tm-invite-error" class="tm-invite-error" hidden style="margin-bottom:12px">
                  <p class="s-flash s-flash--err" style="margin:0"></p>
                </div>
                <label class="tm-field">
                  <span class="tm-field-label">{bt('prof.email.label', lang)}</span>
                  <input type="email" id="tm-invite-email" placeholder="kollege@hotel.de" class="s-input" />
                </label>
                <div class="tm-field">
                  <span class="tm-field-label">{bt('prof.role.label', lang)}</span>
                  <div class="tm-dd" id="tm-invite-role-dd">
                    <button type="button" class="tm-dd-btn" id="tm-invite-role-btn" aria-haspopup="listbox" aria-expanded="false">
                      <span class="tm-dd-val" id="tm-invite-role-val" data-value="manager">{bt('team.modal.role.manager', lang)}</span>
                      <svg class="tm-dd-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="tm-dd-menu" id="tm-invite-role-menu" role="listbox" hidden>
                      <button type="button" class="tm-dd-opt is-active" data-value="manager" role="option">
                        {bt('team.modal.role.manager', lang)}
                        <svg class="tm-dd-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      </button>
                      <button type="button" class="tm-dd-opt" data-value="staff" role="option">
                        {bt('team.modal.role.staff', lang)}
                        <svg class="tm-dd-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      </button>
                    </div>
                  </div>
                </div>
                <p class="tm-hint">{bt('team.modal.hint', lang)}</p>
              </div>
              <div class="bp-modal-foot">
                <button type="button" class="v9-btn v9-btn--ghost tm-invite-close">{bt('common.cancel', lang)}</button>
                <button type="button" id="tm-invite-send" class="v9-btn v9-btn--primary">{bt('team.modal.send', lang)}</button>
              </div>
            </div>
          </div>
        )}

      </div>{/* .tm-root */}

      <script type="application/json" id="tm-i18n" is:inline set:html={JSON.stringify({
        roleFailed: bt('team.js.rolefailed', lang),
        roleUpdated: bt('team.js.roleupdated', lang),
        netErr: bt('sec.reminder.neterr', lang),
        memberFallback: bt('team.js.memberfallback', lang),
        removeConfirm: bt('team.js.removeconfirm', lang),
        removeFailed: bt('team.js.removefailed', lang),
        removed: bt('team.js.removed', lang),
        emailInvalid: bt('team.js.emailinvalid', lang),
        sending: bt('team.js.sending', lang),
        inviteFailed: bt('team.js.invitefailed', lang),
        invited: bt('team.js.invited', lang),
      })}></script>
    </section>

  </AccountShell>
</Layout>

<style is:global>
[x-cloak] { display: none !important; }

/* ── Team member rows ─────────────────────────────────────────────────────── */
.tm-list { display: flex; flex-direction: column; gap: 6px; }
.tm-row {
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
  padding: 12px 16px;
  border: 1px solid var(--border); border-radius: var(--r, 8px);
  background: var(--surface);
}
.tm-row--pending {
  background: var(--bg-deep, #F0EDE6);
  border-color: color-mix(in srgb, var(--ink) 18%, transparent);
}
.tm-row-info { min-width: 0; flex: 1; }
.tm-row-name { margin: 0 0 2px; font-size: 14px; font-weight: 500; color: var(--ink); }
.tm-row-self { color: var(--ink-muted); font-weight: 400; font-size: 12px; }
.tm-row-meta { margin: 0; font-size: 12px; color: var(--ink-muted); }
.tm-row-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

.tm-badge {
  font-size: 11px; padding: 3px 9px; border-radius: 6px;
  background: color-mix(in srgb, var(--ink) 6%, transparent);
  color: var(--ink-muted); letter-spacing: 0.04em;
  border: 1px solid transparent;
}
.tm-badge--owner {
  background: rgba(140, 33, 40, 0.08); color: var(--burgund, #8C2128);
  border-color: rgba(140, 33, 40, 0.24);
}
.tm-badge--pending {
  background: var(--surface); color: var(--ink-muted);
  border: 1px solid var(--border);
}

/* ── Modal (bp-modal pattern) ─────────────────────────────────────────────── */
.bp-modal-bd {
  position: fixed; inset: 0; z-index: 900;
  background: rgba(10,10,10,0.45);
  display: none; align-items: center; justify-content: center;
  padding: 20px; box-sizing: border-box;
}
.bp-modal-bd.is-open { display: flex; }
.bp-modal {
  background: var(--surface, #FAFAF8); border: 1px solid var(--border);
  border-radius: var(--r, 8px); width: 100%; max-width: 480px;
  max-height: 88vh; display: flex; flex-direction: column;
  box-shadow: 0 20px 60px rgba(0,0,0,0.18);
}
.bp-modal-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 24px; border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.bp-modal-title { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); margin: 0; }
.bp-modal-x {
  background: none; border: none; font-size: 16px; cursor: pointer;
  color: var(--ink-muted); min-width: 36px; min-height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--r-sm, 4px); flex-shrink: 0;
}
.bp-modal-x:hover { background: var(--bg-deep); color: var(--ink); }
.bp-modal-body { flex: 1; overflow-y: auto; overscroll-behavior: contain; min-height: 0; padding: 20px 24px; }
.bp-modal-foot {
  display: flex; align-items: center; justify-content: flex-end; gap: 8px;
  padding: 16px 24px; border-top: 1px solid var(--border); flex-shrink: 0;
  background: var(--surface); border-radius: 0 0 var(--r, 8px) var(--r, 8px);
}

.tm-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
.tm-field:last-child { margin-bottom: 0; }
.tm-field-label { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: var(--ink-muted); text-transform: uppercase; }
.tm-hint { font-size: 12px; color: var(--ink-muted); margin: 10px 0 0; font-style: italic; }

/* Boxen rechteckiger wirken lassen — kleinerer Radius (an den Buttons orientiert),
   aber weiterhin gerundet. Innenliegende Member-Rows mit angleichen. */
.tm-root .s-card { border-radius: var(--r-sm); }
.tm-root .tm-row { border-radius: var(--r-sm); }

/* Primary-Buttons exakt wie /profile/hotel-data (Größe, Form, Mono-Caps, Petrol, 7px). */
.v9-btn { min-height: auto !important; }
.v9-btn.v9-btn--primary {
  background: var(--petrol, #14616E) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 7px !important;
  padding: 7px 16px !important;
  font-family: 'JetBrains Mono', monospace !important;
  font-size: 10px !important;
  font-weight: 300 !important;
  letter-spacing: 0.14em !important;
  text-transform: uppercase !important;
  position: static !important;
  display: inline-flex !important;
  align-items: center !important;
  transition: filter 150ms ease !important;
}
.v9-btn.v9-btn--primary::before,
.v9-btn.v9-btn--primary::after { display: none !important; }
.v9-btn.v9-btn--primary:hover:not(:disabled) { filter: brightness(1.1) !important; background: var(--petrol, #14616E) !important; color: #fff !important; }

/* Ghost-Button (Abbrechen) gleiche Geometrie wie der Primary daneben — Outline nicht größer. */
.v9-btn.v9-btn--ghost {
  background: transparent !important; color: var(--ink-muted) !important;
  border: 1px solid var(--border-medium, rgba(10,10,10,.16)) !important;
  border-radius: 7px !important; padding: 7px 16px !important;
  font-family: 'JetBrains Mono', monospace !important; font-size: 10px !important;
  font-weight: 300 !important; letter-spacing: 0.14em !important; text-transform: uppercase !important;
}
.v9-btn.v9-btn--ghost:hover:not(:disabled) { color: var(--ink) !important; border-color: var(--ink) !important; background: transparent !important; }

/* Rollen-Dropdown im Einladen-Popup — Vorbild: /action-cards „Welches Sheet öffnen?" (.ac-type-dd). */
.tm-dd { position: relative; }
.tm-dd-btn { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 9px 12px; border: 1px solid var(--border, rgba(10,10,10,0.12)); border-radius: 9px; background: var(--surface); font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--ink); cursor: pointer; transition: border-color 150ms, box-shadow 150ms; }
.tm-dd-btn:hover, .tm-dd-btn.is-open { outline: none; border-color: var(--petrol, #14616E); box-shadow: 0 0 0 3px rgba(20,97,110,0.10); }
.tm-dd-chevron { color: var(--ink-muted); flex-shrink: 0; transition: transform 150ms; }
.tm-dd-btn.is-open .tm-dd-chevron { transform: rotate(180deg); }
.tm-dd-menu { position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 200; background: var(--surface); border: 1px solid var(--border, rgba(10,10,10,0.12)); border-radius: 10px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,.10); }
.tm-dd-menu[hidden] { display: none; }
.tm-dd-opt { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 10px 14px; border: none; background: transparent; font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--ink); cursor: pointer; text-align: left; transition: background 100ms; }
.tm-dd-opt:hover { background: rgba(20,97,110,0.07); color: var(--petrol, #14616E); }
.tm-dd-opt.is-active { color: var(--petrol, #14616E); font-weight: 600; background: rgba(20,97,110,0.05); }
.tm-dd-check { color: var(--petrol, #14616E); flex-shrink: 0; opacity: 0; }
.tm-dd-opt.is-active .tm-dd-check { opacity: 1; }
</style>

<script>
  // Rollen-Wechsel + Entfernen: reines Vanilla-JS (Alpine-unabhängig). Registrierte
  // Alpine-Components (Alpine.data via alpine:init) feuern unter dem AccountShell-
  // Wrapper zu spät — siehe Invite-Fix. Daher hier kein Alpine.
  (() => {
    const T = JSON.parse(document.getElementById('tm-i18n')?.textContent || '{}');
    const toast = (msg: string, kind: 'ok' | 'err' = 'ok') =>
      (window as any).retahaToast?.(msg, kind === 'err' ? 'error' : 'success');

    document.querySelectorAll<HTMLSelectElement>('.tm-role-select').forEach((sel) => {
      sel.addEventListener('change', async () => {
        const prev = sel.dataset.currentRole || 'staff';
        try {
          const res = await fetch('/api/admin/team/role', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ member_id: sel.dataset.memberId, new_role: sel.value }),
          });
          const data = await res.json();
          if (!data.ok) { sel.value = prev; toast(data.message || data.error || T.roleFailed, 'err'); return; }
          sel.dataset.currentRole = sel.value;
          toast(T.roleUpdated);
        } catch {
          sel.value = prev;
          toast(T.netErr, 'err');
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.tm-remove-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const name = btn.dataset.memberName || T.memberFallback;
        if (!confirm(T.removeConfirm.replace('{name}', name))) return;
        btn.disabled = true;
        try {
          const res = await fetch('/api/admin/team/remove', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ member_id: btn.dataset.memberId }),
          });
          const data = await res.json();
          if (!data.ok) { toast(data.error || T.removeFailed, 'err'); btn.disabled = false; return; }
          toast(T.removed.replace('{name}', name));
          setTimeout(() => window.location.reload(), 400);
        } catch {
          toast(T.netErr, 'err');
          btn.disabled = false;
        }
      });
    });
  })();
</script>

<script>
  // Invite-Modal: reines Vanilla-JS — bewusst UNABHÄNGIG von Alpine (Open/Close +
  // Submit funktionieren auch, falls Alpine auf der Seite nicht initialisiert).
  // Endpoint /api/admin/team/invite bleibt unverändert.
  (() => {
    const T = JSON.parse(document.getElementById('tm-i18n')?.textContent || '{}');
    const openBtn = document.getElementById('tm-invite-open');
    const modal = document.getElementById('tm-invite-modal');
    if (!openBtn || !modal) return;
    const emailInput = document.getElementById('tm-invite-email') as HTMLInputElement | null;
    const roleDd = document.getElementById('tm-invite-role-dd');
    const roleBtn = document.getElementById('tm-invite-role-btn');
    const roleMenu = document.getElementById('tm-invite-role-menu');
    const roleVal = document.getElementById('tm-invite-role-val');
    const sendBtn = document.getElementById('tm-invite-send') as HTMLButtonElement | null;
    const errorBox = document.getElementById('tm-invite-error');
    const errorMsg = errorBox ? errorBox.querySelector('p') : null;

    // Rollen-Dropdown (Custom, Vorbild /action-cards) — reines Vanilla-JS.
    const roleOpts = roleMenu ? Array.from(roleMenu.querySelectorAll<HTMLButtonElement>('.tm-dd-opt')) : [];
    const setRoleOpen = (o: boolean) => {
      if (!roleMenu || !roleBtn) return;
      roleMenu.hidden = !o;
      roleBtn.classList.toggle('is-open', o);
      roleBtn.setAttribute('aria-expanded', String(o));
    };
    roleBtn?.addEventListener('click', (e) => { e.stopPropagation(); setRoleOpen(!!roleMenu?.hidden); });
    roleOpts.forEach((opt) => {
      opt.addEventListener('click', () => {
        if (roleVal) { roleVal.textContent = (opt.textContent || '').trim(); roleVal.dataset.value = opt.dataset.value || 'manager'; }
        roleOpts.forEach((o) => o.classList.toggle('is-active', o === opt));
        setRoleOpen(false);
      });
    });
    document.addEventListener('click', (e) => { if (roleDd && !roleDd.contains(e.target as Node)) setRoleOpen(false); });

    const showError = (msg: string) => {
      if (errorBox && errorMsg) { errorMsg.textContent = msg; errorBox.hidden = false; }
    };
    const open = () => { modal.classList.add('is-open'); setTimeout(() => emailInput?.focus(), 50); };
    const close = () => { modal.classList.remove('is-open'); if (errorBox) errorBox.hidden = true; };

    openBtn.addEventListener('click', open);
    modal.querySelectorAll('.tm-invite-close').forEach((b) => b.addEventListener('click', close));
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('is-open')) close(); });

    sendBtn?.addEventListener('click', async () => {
      const email = (emailInput?.value || '').trim();
      const role = roleVal?.dataset.value || 'manager';
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError(T.emailInvalid); return; }
      sendBtn.disabled = true;
      const orig = sendBtn.textContent;
      sendBtn.textContent = T.sending;
      try {
        const res = await fetch('/api/admin/team/invite', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, role }),
        });
        const data = await res.json();
        if (!data.ok) { showError(data.message || data.error || T.inviteFailed); sendBtn.disabled = false; sendBtn.textContent = orig; return; }
        (window as any).retahaToast?.(T.invited.replace('{email}', email));
        setTimeout(() => window.location.reload(), 600);
      } catch {
        showError(T.netErr);
        sendBtn.disabled = false; sendBtn.textContent = orig;
      }
    });
  })();
</script>
