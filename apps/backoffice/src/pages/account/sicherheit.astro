---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Sicherheit & 2FA" activeTab="backoffice">
  <section class="stub-page">
    <p class="stub-page__eyebrow">Account · Sicherheit</p>
    <h1 class="stub-page__title">Sicherheit & 2FA<span class="dot-pink">.</span></h1>
    <p class="stub-page__sub">
      Zwei-Faktor-Authentifizierung einrichten:
      <a href="/admin/sicherheit" class="stub-page__link">→ Zum Setup-Wizard</a>
    </p>
    <p class="stub-page__sub" style="margin-top: 8px;">
      Team-Sicherheitsrichtlinien (Owner):
      <a href="/admin/team-security" class="stub-page__link">→ Team-Sicherheit</a>
    </p>
  </section>
</Layout>

<style>
  .stub-page {
    max-width: 800px;
    margin: 64px auto;
    padding: 0 32px;
  }
  .stub-page__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .stub-page__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }
  .stub-page__sub {
    font-size: 16px;
    color: var(--ink-muted);
    line-height: 1.5;
  }
  .stub-page__link {
    color: var(--ink);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .stub-page__link:hover { color: var(--te-yellow); }
</style>
