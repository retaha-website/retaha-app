---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Mein Profil" activeTab="backoffice">
  <section class="stub-page">
    <p class="stub-page__eyebrow">Account · Profil</p>
    <h1 class="stub-page__title">Mein Profil<span class="dot-pink">.</span></h1>
    <p class="stub-page__sub">Name, Foto, Kontakt — kommt in Sprint J.</p>
  </section>
</Layout>

<style>
  .stub-page {
    max-width: 800px;
    margin: 64px auto;
    padding: 0 32px;
  }
  .stub-page__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .stub-page__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }
  .stub-page__sub {
    font-size: 16px;
    color: var(--ink-muted);
    line-height: 1.5;
  }
</style>
