---
import Layout from '../layouts/Layout.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServerInstance,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { encryptToken } from '@retaha/auth';
import { MewsClient } from '../lib/mews/client';
import { getMewsClientForHotel } from '../lib/mews/factory';
import { getEnv } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const ssrClient = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

// POST: connect / disconnect. Sync läuft client-side via fetch → /api/admin/mews/sync
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'connect') {
    const accessToken = form.get('access_token')?.toString().trim() ?? '';
    const environment = form.get('environment')?.toString();

    if (!accessToken) {
      message = { type: 'error', text: 'Access-Token ist Pflichtfeld.' };
    } else if (environment !== 'demo' && environment !== 'production') {
      message = { type: 'error', text: 'Ungültiges Environment (nur demo/production erlaubt).' };
    } else {
      // 1) ENV für Environment auflösen (ClientToken gehört uns als Integration-Provider,
      //    nicht dem Hotel — kommt aus ENV, nicht aus dem Formular)
      const baseUrl = environment === 'demo'
        ? getEnv('MEWS_API_BASE_URL')
        : 'https://api.mews.com';
      const clientToken = environment === 'demo'
        ? getEnv('MEWS_DEMO_CLIENT_TOKEN')
        : getEnv('MEWS_PROD_CLIENT_TOKEN');

      if (!baseUrl || !clientToken) {
        message = {
          type: 'error',
          text: `${environment === 'demo' ? 'Demo' : 'Production'}-Environment nicht konfiguriert (ENV fehlt).`,
        };
      } else {
        try {
          // 2) Mews-API kontaktieren um Enterprise.Id aufzulösen (validiert gleichzeitig den Token)
          const testClient = new MewsClient({
            clientToken,
            accessToken,
            client: getEnv('MEWS_CLIENT_NAME') ?? 'retaha 1.0.0',
            baseUrl,
          });
          const config = await testClient.getConfiguration();
          const enterpriseId = config.Enterprise?.Id;
          const enterpriseName = config.Enterprise?.Name;

          if (!enterpriseId) {
            message = {
              type: 'error',
              text: 'Mews API antwortete ohne Enterprise.Id — Token möglicherweise ungültig oder Account ohne Enterprise.',
            };
          } else {
            // 3) Default-Currency aus Enterprise.Currencies (IsDefault=true)
            const currencies = (config.Enterprise as any)?.Currencies as
              | Array<{ Currency?: string; IsDefault?: boolean }>
              | undefined;
            const defaultCurrency = currencies?.find(c => c.IsDefault)?.Currency ?? null;

            // 3b) Pricing-Mode aus Enterprise.Pricing — bestimmt ob orders/add
            //     GrossValue oder NetValue als Feldname braucht (Sprint C Phase 3).
            const enterprisePricing = (config.Enterprise as any)?.Pricing as string | undefined;
            const pricingMode = enterprisePricing === 'Gross' || enterprisePricing === 'Net'
              ? enterprisePricing
              : null;

            // 4) Products-Count (für Toggle-Disable in UI). Best-effort — wenn der Call
            //    fehlschlägt, bleibt Counter 0 = Pfad C+ disabled (sicherer Default).
            let productsCount = 0;
            try {
              const productsResp = await testClient.getProducts({ Limitation: { Count: 100 } });
              productsCount = (productsResp.Products ?? []).length;
            } catch {
              // ignored — Products sind optional, Pfad C+ ist eh out-of-scope für Sprint C
            }

            // 5) Token verschlüsseln + Row upserten
            const encryptedToken = await encryptToken(accessToken);
            const { error } = await ssrClient
              .from('mews_integrations')
              .upsert(
                {
                  hotel_id: hotel.id,
                  enterprise_id: enterpriseId,
                  access_token_encrypted: encryptedToken,
                  environment,
                  default_currency: defaultCurrency,
                  pricing_mode: pricingMode,
                  mews_products_count: productsCount,
                  sync_status: 'idle',
                  sync_error_message: null,
                  updated_at: new Date().toISOString(),
                },
                { onConflict: 'hotel_id' },
              );

            if (error) {
              message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
            } else {
              return Astro.redirect(
                `/pms?saved=connected${enterpriseName ? `&hotel=${encodeURIComponent(enterpriseName)}` : ''}`,
              );
            }
          }
        } catch (err) {
          message = {
            type: 'error',
            text: `Mews-Verbindungstest fehlgeschlagen: ${(err as Error).message}`,
          };
        }
      }
    }
  } else if (action === 'save_config') {
    // Service-Mapping + TaxCode + Pricing-Source speichern
    const serviceBreakfast = form.get('service_id_breakfast')?.toString().trim() || null;
    const serviceService = form.get('service_id_service')?.toString().trim() || null;
    const serviceConference = form.get('service_id_conference')?.toString().trim() || null;
    const taxCode = form.get('default_tax_code')?.toString().trim() || null;
    const pricingSource = form.get('pricing_source')?.toString();

    if (pricingSource !== 'retaha' && pricingSource !== 'mews') {
      message = { type: 'error', text: 'Ungültige Preis-Quelle.' };
    } else {
      // Bei Tax-Code-Set: Tax-Rate via taxations/getAll auflösen (Sprint D Phase 1).
      // Wir filtern manuell auf TaxationCode === TaxEnvironmentCode (Mews ignoriert
      // den TaxEnvironmentCodes-Param) und matchen den exakten Code.
      let resolvedTaxRate: number | null = null;
      let taxRateLookupError: string | null = null;
      if (taxCode) {
        try {
          const mews = await getMewsClientForHotel(hotel.id);
          if (mews) {
            const config = await mews.getConfiguration();
            const taxEnv = (config.Enterprise as any)?.TaxEnvironmentCode as string | undefined;
            const taxResp = await mews.getTaxations({
              ...(taxEnv ? { TaxEnvironmentCodes: [taxEnv] } : {}),
              Limitation: { Count: 100 },
            });
            const allRates = (taxResp.TaxRates ?? []) as Array<{
              Code: string;
              TaxationCode?: string;
              Value?: number;
              Strategy?: { Discriminator?: string; Value?: unknown };
            }>;
            const filtered = taxEnv ? allRates.filter(r => r.TaxationCode === taxEnv) : allRates;
            const match = filtered.find(r => r.Code === taxCode);
            if (match) {
              const flat = typeof match.Value === 'number' ? match.Value : null;
              const sv = match.Strategy?.Value as any;
              const nested = sv && typeof sv === 'object' && typeof sv.Value === 'number' ? sv.Value : null;
              const numericRate = flat ?? nested;
              if (typeof numericRate === 'number' && numericRate >= 0 && numericRate < 1) {
                resolvedTaxRate = numericRate;
              } else {
                taxRateLookupError = `Tax-Code "${taxCode}" gefunden, aber kein numerischer Rate-Wert (Strategy=${JSON.stringify(match.Strategy?.Discriminator)})`;
              }
            } else {
              taxRateLookupError = `Tax-Code "${taxCode}" nicht in taxations/getAll für TaxEnvironment "${taxEnv}" gefunden`;
            }
          }
        } catch (err) {
          taxRateLookupError = `taxations/getAll fehlgeschlagen: ${(err as Error).message}`;
        }
      }

      const { error } = await ssrClient
        .from('mews_integrations')
        .update({
          service_id_breakfast: serviceBreakfast,
          service_id_service: serviceService,
          service_id_conference: serviceConference,
          default_tax_code: taxCode,
          default_tax_rate: resolvedTaxRate,
          pricing_source: pricingSource,
          updated_at: new Date().toISOString(),
        })
        .eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
      } else if (taxRateLookupError && taxCode) {
        // Soft-Warning: gespeichert, aber Tax-Rate konnte nicht aufgelöst werden.
        // Bei Net-Hotels wirft pushBookingToMews dann PushSkipped(no_default_tax_rate).
        return Astro.redirect(`/pms?saved=config_warn&warn=${encodeURIComponent(taxRateLookupError)}`);
      } else {
        return Astro.redirect('/pms?saved=config');
      }
    }
  } else if (action === 'save_charge_config') {
    // UX-017 P3 — Charge-Required-Toggle pro Booking-Type.
    // HTML-Checkboxen senden nur Wert wenn checked → fehlende Felder = false.
    const CHARGE_TYPES = [
      'breakfast', 'conference', 'service',
      'restaurant', 'spa', 'late_checkout', 'housekeeping',
    ] as const;
    const update: Record<string, boolean | string> = {
      updated_at: new Date().toISOString(),
    };
    for (const t of CHARGE_TYPES) {
      update[`${t}_charge_enabled`] = form.get(`${t}_charge_enabled`) === 'on';
    }
    const { error } = await ssrClient
      .from('mews_integrations')
      .update(update)
      .eq('hotel_id', hotel.id);
    if (error) {
      message = { type: 'error', text: `Charge-Konfig speichern fehlgeschlagen: ${error.message}` };
    } else {
      return Astro.redirect('/pms?saved=charge_config');
    }
  } else if (action === 'disconnect') {
    // Sprint D Phase 6b — Reconnect-Symmetrie: Row NICHT löschen, nur Auth-Felder
    // nullen. Service-Mappings + Tax/Currency/Pricing-Defaults bleiben erhalten.
    // Bei Reconnect setzt der Connect-Handler einfach access_token_encrypted +
    // enterprise_id neu, die Mappings sind sofort wieder da.
    const { error } = await ssrClient
      .from('mews_integrations')
      .update({
        access_token_encrypted: null,
        enterprise_id: null,
        last_sync_at: null,
        sync_status: 'idle',
        sync_error_message: null,
        mews_products_count: 0,
        updated_at: new Date().toISOString(),
      })
      .eq('hotel_id', hotel.id);
    if (error) {
      message = { type: 'error', text: `Trennen fehlgeschlagen: ${error.message}` };
    } else {
      return Astro.redirect('/pms?saved=disconnected');
    }
  }
}

// Flash-Messages aus URL-Param (Post-Redirect-Get)
const savedParam = Astro.url.searchParams.get('saved');
if (savedParam === 'connected' && !message) {
  const hotelName = Astro.url.searchParams.get('hotel');
  message = {
    type: 'success',
    text: hotelName
      ? `Verbunden mit „${hotelName}". Klicke „Jetzt synchronisieren" um Daten zu laden.`
      : 'Mews-Integration verbunden. Klicke „Jetzt synchronisieren" um Daten zu laden.',
  };
} else if (savedParam === 'disconnected' && !message) {
  message = { type: 'success', text: 'Mews-Integration getrennt. Service-Mappings, Tax-Code und Sync-Daten bleiben für einen Reconnect erhalten.' };
} else if (savedParam === 'sync' && !message) {
  message = { type: 'success', text: 'Synchronisation erfolgreich abgeschlossen.' };
} else if (savedParam === 'config' && !message) {
  message = { type: 'success', text: 'Order-Konfiguration gespeichert.' };
} else if (savedParam === 'config_warn' && !message) {
  const warn = Astro.url.searchParams.get('warn') ?? 'Tax-Rate konnte nicht aufgelöst werden.';
  message = { type: 'error', text: `Konfiguration gespeichert mit Warnung — ${warn}. Bei Net-Hotels wird der Mews-Push fehlschlagen bis der Rate-Wert da ist.` };
}

// Integration via SSR-Client (RLS) — access_token_encrypted bewusst NICHT selektiert,
// bleibt server-side, geht nie ans Frontend.
const { data: integration } = await ssrClient
  .from('mews_integrations')
  .select(`
    enterprise_id, environment, last_sync_at, sync_status, sync_error_message, created_at, updated_at,
    pricing_source, default_currency, default_tax_code, default_tax_rate, pricing_mode,
    service_id_breakfast, service_id_service, service_id_conference,
    mews_products_count,
    breakfast_charge_enabled, conference_charge_enabled, service_charge_enabled,
    restaurant_charge_enabled, spa_charge_enabled,
    late_checkout_charge_enabled, housekeeping_charge_enabled
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

// Sprint D Phase 6b: integration.enterprise_id NULL = disconnected, Mappings
// bleiben erhalten in der Row. UI behandelt isConnected statt rohen integration-Existenz.
const isConnected = integration?.enterprise_id != null;

// Counts via Service-Role (rooms/stays/guests-RLS uneinheitlich) — hotel.id-Filter
// kommt aus authentifizierter Session, also sicher.
let counts: { rooms: number; stays: number; guests: number } | null = null;
if (isConnected) {
  const adminClient = createSupabaseServiceRoleInstance();
  const [roomsRes, staysRes, guestsRes] = await Promise.all([
    adminClient.from('rooms').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
    adminClient.from('stays').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
    adminClient.from('guests').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
  ]);
  counts = {
    rooms: roomsRes.count ?? 0,
    stays: staysRes.count ?? 0,
    guests: guestsRes.count ?? 0,
  };
}

// Services live aus Mews für die Mapping-Dropdowns. Best-effort —
// bei Fehler bleibt die Liste leer + Hinweis im UI.
let orderableServices: Array<{ Id: string; Name: string; IsActive: boolean }> = [];
let servicesError: string | null = null;
// Sprint E1 Phase 2 — Tax-Code-Dropdown statt freier Input.
let taxRateOptions: Array<{ code: string; rate: number; label: string }> = [];
let taxEnvironmentCode: string | null = null;
if (isConnected) {
  try {
    const mews = await getMewsClientForHotel(hotel.id);
    if (mews) {
      const resp = await mews.getServices({ Limitation: { Count: 100 } });
      // Sprint D Phase 6c: nur Orderable+Active zeigen. Inaktive Services im
      // Demo-Hotel sind häufig Test-Reste — Mews lehnt orders/add bei ihnen ab
      // mit "Invalid ServiceId" (siehe Sprint-C-Verifikation §3 Befund).
      orderableServices = (resp.Services ?? [])
        .filter(s => s.Type === 'Orderable' && s.IsActive !== false)
        .map(s => ({
          Id: s.Id,
          Name: (s.Name as string) || (s.Names && Object.values(s.Names)[0]) || s.Id,
          IsActive: true,
        }))
        .sort((a, b) => a.Name.localeCompare(b.Name));

      // Tax-Rates für das Enterprise — Filter auf TaxationCode === TaxEnvironment
      // (Mews ignoriert TaxEnvironmentCodes-Param im Request, manuell filtern).
      try {
        const config = await mews.getConfiguration();
        taxEnvironmentCode = (config.Enterprise as any)?.TaxEnvironmentCode ?? null;
        if (taxEnvironmentCode) {
          const taxResp = await mews.getTaxations({
            TaxEnvironmentCodes: [taxEnvironmentCode],
            Limitation: { Count: 100 },
          });
          const allRates = (taxResp.TaxRates ?? []) as Array<{
            Code: string;
            TaxationCode?: string;
            Value?: number;
            Strategy?: { Discriminator?: string; Value?: unknown };
          }>;
          taxRateOptions = allRates
            .filter(tr => tr.TaxationCode === taxEnvironmentCode)
            .map(tr => {
              const flat = typeof tr.Value === 'number' ? tr.Value : null;
              const sv = tr.Strategy?.Value as any;
              const nested = sv && typeof sv === 'object' && typeof sv.Value === 'number' ? sv.Value : null;
              const rate = flat ?? nested ?? 0;
              const pct = (rate * 100).toFixed(rate < 0.1 ? 1 : 0);
              return { code: tr.Code, rate, label: `${pct}% (${tr.Code})` };
            })
            .filter(opt => typeof opt.rate === 'number' && opt.rate >= 0 && opt.rate < 1)
            .sort((a, b) => b.rate - a.rate);  // höchster Rate zuerst (Standard meist 20%)
        }
      } catch {
        // Tax-Lookup-Fehler nicht-fatal — Dropdown bleibt leer, Fallback-Input greift
      }
    }
  } catch (err) {
    servicesError = (err as Error).message;
  }
}

const productsCount = integration?.mews_products_count ?? 0;
const productsAvailable = productsCount > 0;

type ServiceMappingField = { name: string; label: string; current: string | null };
// Sprint E1 Phase 3 — nur Frühstück-Mapping zeigen. Service + Konferenz
// werden nicht nach Mews gepushed (Sprint-C-Scope-Korrektur §14):
// Service ist meist kostenfrei, Konferenz B2B-Vertrieb. Code-Side bleibt
// (graceful skip wenn service_id_* NULL), UI ist nur klarer.
const serviceMappingFields: ServiceMappingField[] = integration
  ? [
      { name: 'service_id_breakfast', label: 'Frühstück-Buchungen', current: integration.service_id_breakfast ?? null },
    ]
  : [];

const lastSyncLabel = integration?.last_sync_at
  ? new Date(integration.last_sync_at).toLocaleString('de-DE', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;

const syncStatusLabels: Record<string, string> = {
  idle: 'Bereit',
  syncing: 'Läuft…',
  error: 'Fehler',
};
const statusKey = integration?.sync_status ?? 'idle';
const statusBadge = { label: syncStatusLabels[statusKey] ?? 'Bereit' };
---

<Layout title="PMS-Integration" activeTab="backoffice" hotelName={hotel.name}>

<style is:global>
[x-cloak] { display: none !important; }

.sp-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
.sp-field:last-child { margin-bottom: 0; }
.sp-label { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: var(--ink-muted); text-transform: uppercase; }
.sp-label-hint { font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 10px; opacity: 0.7; }

.pms-meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px 24px;
  margin-bottom: 0;
}
@media (max-width: 480px) { .pms-meta-grid { grid-template-columns: 1fr; } }

.pms-meta-item__label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 4px;
}
.pms-meta-item__value {
  font-size: 13px;
  color: var(--ink);
  word-break: break-all;
}
.pms-meta-item__value--mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
.pms-meta-item__hint { font-size: 11px; color: var(--ink-muted); font-style: italic; margin-top: 3px; }

.pms-counts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.pms-count-cell {
  border: 1px solid var(--border);
  border-radius: var(--r, 8px);
  padding: 16px 20px;
  background: var(--surface);
}
.pms-count-cell__label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 6px;
}
.pms-count-cell__num {
  font-size: 28px;
  font-weight: 300;
  color: var(--ink);
  line-height: 1;
}

.pms-status-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 4px;
}
.pms-status-badge--idle { background: rgba(10,10,10,0.06); color: rgba(10,10,10,0.7); }
.pms-status-badge--syncing { background: rgba(192,106,60,0.1); color: var(--accent, #C06A3C); }
.pms-status-badge--error { background: #FEF2F2; color: #B91C1C; }

.charge-toggle-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}
@media (min-width: 560px) { .charge-toggle-grid { grid-template-columns: 1fr 1fr; } }

.charge-toggle-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 16px;
  background: var(--bg-deep, #F0EDE6);
  border: 1px solid var(--border);
  border-radius: var(--r, 8px);
  cursor: pointer;
  transition: border-color 0.15s ease;
}
.charge-toggle-card:hover { border-color: var(--ink-muted); }
.charge-toggle-info { min-width: 0; }
.charge-toggle-label {
  margin: 0;
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
}
.charge-toggle-hint {
  margin: 2px 0 0;
  font-size: 11px;
  color: var(--ink-muted);
}

.pms-info-box {
  padding: 16px 20px;
  border-left: 3px solid var(--border);
  background: var(--bg-deep, #F0EDE6);
  border-radius: 0 var(--r-sm, 4px) var(--r-sm, 4px) 0;
  margin-bottom: 20px;
}
.pms-info-box__eyebrow {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 8px;
}
.pms-info-box ol {
  padding-left: 20px;
  margin: 8px 0;
}
.pms-info-box li { font-size: 13px; color: var(--ink); line-height: 1.6; margin-bottom: 2px; }
.pms-info-box__note { font-size: 11px; color: var(--ink-muted); font-style: italic; line-height: 1.5; margin-top: 8px; }

.pms-pricing-option {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 14px;
  border: 1px solid var(--border);
  border-radius: var(--r, 8px);
  cursor: pointer;
  transition: border-color 0.12s;
  margin-bottom: 8px;
}
.pms-pricing-option:last-child { margin-bottom: 0; }
.pms-pricing-option:hover { border-color: var(--ink-muted); }
.pms-pricing-option--disabled { opacity: 0.5; cursor: not-allowed; }
.pms-pricing-option input[type="radio"] { margin-top: 2px; flex-shrink: 0; }
.pms-pricing-option__title { font-size: 13px; font-weight: 500; color: var(--ink); }
.pms-pricing-option__sub { font-size: 11px; color: var(--ink-muted); margin-top: 2px; line-height: 1.5; }

.s-card__actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

.pms-footer-note {
  font-size: 11px;
  color: var(--ink-muted);
  font-style: italic;
  line-height: 1.6;
  max-width: 560px;
}
</style>

<div class="settings-page">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">PMS-Integration</span>
  </nav>

  <section class="settings-hero">
    <span class="settings-hero__eyebrow">Integrationen</span>
    <h1 class="settings-hero__title">PMS-Integration<span class="dot-pink">.</span></h1>
    <p class="settings-hero__sub">Verbinde dein Mews-Hotel mit retaha. Reservationen, Zimmer und Gäste-Daten werden automatisch synchronisiert.</p>
  </section>

  {message && (
    <div class={`s-flash ${message.type === 'success' ? 's-flash--ok' : 's-flash--err'}`} style="margin-bottom: 24px;">
      {message.text}
    </div>
  )}

  <div class="settings-sections">

  {isConnected && integration ? (

    <>
      <!-- 01 Verbindungs-Status -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Mews verbunden</h2>
          <span class="s-card__num">01</span>
        </div>
        <div class="s-card__body">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:20px;">
            <span class={`pms-status-badge pms-status-badge--${statusKey}`}>{statusBadge.label}</span>
          </div>

          <div class="pms-meta-grid">
            <div>
              <p class="pms-meta-item__label">Enterprise-ID</p>
              <p class="pms-meta-item__value pms-meta-item__value--mono">{integration.enterprise_id}</p>
            </div>
            <div>
              <p class="pms-meta-item__label">Environment</p>
              <p class="pms-meta-item__value" style="text-transform:capitalize;">{integration.environment}</p>
            </div>
            <div>
              <p class="pms-meta-item__label">Access-Token</p>
              <p class="pms-meta-item__value pms-meta-item__value--mono">••••••••••••</p>
              <p class="pms-meta-item__hint">verschlüsselt (AES-256-GCM)</p>
            </div>
            <div>
              <p class="pms-meta-item__label">Letzter Sync</p>
              <p class="pms-meta-item__value">{lastSyncLabel ?? 'noch nie'}</p>
            </div>
          </div>

          {integration.sync_status === 'error' && integration.sync_error_message && (
            <div class="s-flash s-flash--err" style="margin-top:16px;">
              <strong>Letzter Sync-Fehler:</strong><br />
              <span style="font-family:'JetBrains Mono',monospace;font-size:11px;word-break:break-all;">{integration.sync_error_message}</span>
            </div>
          )}
        </div>
      </section>

      <!-- 02 Synchronisierte Daten -->
      {counts && (
        <section class="s-card">
          <div class="s-card__head">
            <h2 class="s-card__title">Bisher synchronisiert</h2>
            <span class="s-card__num">02</span>
          </div>
          <div class="s-card__body">
            <div class="pms-counts-grid">
              <div class="pms-count-cell">
                <p class="pms-count-cell__label">Zimmer</p>
                <p class="pms-count-cell__num">{counts.rooms}</p>
              </div>
              <div class="pms-count-cell">
                <p class="pms-count-cell__label">Aufenthalte</p>
                <p class="pms-count-cell__num">{counts.stays}</p>
              </div>
              <div class="pms-count-cell">
                <p class="pms-count-cell__label">Gäste</p>
                <p class="pms-count-cell__num">{counts.guests}</p>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- 03 Order-Konfiguration (Sprint C — Charge-to-Room) -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Order-Konfiguration</h2>
          <span class="s-card__num">{counts ? '03' : '02'}</span>
        </div>
        <div class="s-card__body">
          <p class="field__hint" style="margin-bottom:16px;">
            Wenn der Hotelier eine Buchung bestätigt, schickt retaha sie als Order
            auf das Mews-Gast-Konto ("Charge to Room"). Damit das funktioniert,
            ordne pro Buchungstyp einen Mews-Service zu und setze deinen Tax-Code.
          </p>

          {servicesError && (
            <div class="s-flash s-flash--err" style="margin-bottom:16px;">
              <strong>Services konnten nicht geladen werden:</strong> {servicesError}
              <br />Trotzdem speicherbar — Dropdowns sind leer. Bei nächstem Page-Load nochmal probieren.
            </div>
          )}

          <form method="POST">
            <input type="hidden" name="_action" value="save_config" />

            <!-- Service-Mapping (Sprint E1 Phase 3 — nur Frühstück) -->
            <p class="pms-meta-item__hint" style="margin-bottom:16px;">
              Charge-to-Room ist aktuell <strong>nur für Frühstück</strong> aktiv.
              Service-Anfragen und Konferenz-Buchungen bleiben in retaha (Service ist meist
              kostenfrei, Konferenz läuft über B2B-Vertrieb).
            </p>

            {serviceMappingFields.map(field => (
              <div class="sp-field">
                <label class="sp-label">Mews-Service für {field.label}</label>
                <select name={field.name} class="s-select">
                  <option value="">— nicht zugeordnet —</option>
                  {orderableServices.map(s => (
                    <option value={s.Id} selected={field.current === s.Id}>
                      {s.Name}{!s.IsActive ? ' (inaktiv)' : ''}
                    </option>
                  ))}
                </select>
              </div>
            ))}

            <!-- Tax-Code (Sprint E1 Phase 2 — Dropdown wenn Liste da, sonst Input-Fallback) -->
            <div class="sp-field">
              <label class="sp-label">Tax-Code (Default)</label>
              {taxRateOptions.length > 0 ? (
                <select name="default_tax_code" class="s-select" style="font-family:'JetBrains Mono',monospace;">
                  <option value="">— bitte wählen —</option>
                  {taxRateOptions.map(opt => (
                    <option value={opt.code} selected={integration.default_tax_code === opt.code}>
                      {opt.label}
                    </option>
                  ))}
                </select>
              ) : (
                <input
                  type="text"
                  name="default_tax_code"
                  value={integration.default_tax_code ?? ''}
                  placeholder="z.B. UK-2022-20%, DE-2020-1-S, …"
                  autocomplete="off"
                  spellcheck="false"
                  class="s-input"
                  style="font-family:'JetBrains Mono',monospace;"
                />
              )}
              <span class="sp-label-hint" style="font-size:11px;color:var(--ink-muted);font-style:italic;margin-top:2px;">
                {taxRateOptions.length > 0
                  ? <>Auswahl gefiltert auf Tax-Environment <span style="font-family:'JetBrains Mono',monospace;">{taxEnvironmentCode}</span>. Löst auch den numerischen Rate-Wert auf (für Net-Pricing-Hotels).</>
                  : <>Tax-Codes aus Mews konnten nicht geladen werden — bitte manuell eintragen. Tax-Environment: <span style="font-family:'JetBrains Mono',monospace;">{taxEnvironmentCode ?? '?'}</span></>}
                {integration.default_tax_rate != null && (
                  <><br />Aktueller Rate: <span style="font-family:'JetBrains Mono',monospace;">{(Number(integration.default_tax_rate) * 100).toFixed(2)}%</span></>
                )}
              </span>
            </div>

            <!-- Currency + Pricing-Mode (read-only Anzeige) -->
            <div class="pms-meta-grid" style="margin-bottom:20px;">
              <div>
                <p class="pms-meta-item__label">Default-Currency</p>
                <p class="pms-meta-item__value pms-meta-item__value--mono">{integration.default_currency ?? '(nicht gesetzt)'}</p>
                <p class="pms-meta-item__hint">Aus configuration.Enterprise.Currencies (IsDefault=true).</p>
              </div>
              <div>
                <p class="pms-meta-item__label">Pricing-Mode</p>
                <p class="pms-meta-item__value pms-meta-item__value--mono">{integration.pricing_mode ?? '(nicht gesetzt)'}</p>
                <p class="pms-meta-item__hint">Gross = GrossValue; Net = NetValue bei orders/add.</p>
              </div>
            </div>

            <!-- Pricing-Source-Toggle -->
            <div class="sp-field" style="margin-bottom:20px;">
              <span class="sp-label">Preis-Quelle</span>
              <label class="pms-pricing-option">
                <input
                  type="radio"
                  name="pricing_source"
                  value="retaha"
                  checked={integration.pricing_source !== 'mews'}
                />
                <span>
                  <span class="pms-pricing-option__title">Preise in retaha pflegen</span>
                  <span class="pms-pricing-option__sub">Hotelier pflegt Preise direkt in den retaha-Modulen. Push als Custom-Items.</span>
                </span>
              </label>
              <label class={`pms-pricing-option${!productsAvailable ? ' pms-pricing-option--disabled' : ''}`}>
                <input
                  type="radio"
                  name="pricing_source"
                  value="mews"
                  checked={integration.pricing_source === 'mews'}
                  disabled={!productsAvailable}
                />
                <span>
                  <span class="pms-pricing-option__title">
                    Preise aus Mews-Products abrufen
                    <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ink-muted);margin-left:6px;">({productsCount} Products)</span>
                  </span>
                  <span class="pms-pricing-option__sub">
                    {productsAvailable
                      ? 'Verfügbar. Hinweis: Pfad C+ ist noch nicht implementiert (Backlog) — auswählbar, aber wird beim Push einen Fehler werfen.'
                      : 'Nicht verfügbar — dein Mews-Hotel hat keine Products angelegt. Lege Products in Mews an und verbinde neu.'}
                  </span>
                </span>
              </label>
            </div>

            <div class="s-card__footer">
              <button type="submit" class="v9-btn v9-btn--primary">
                Order-Konfiguration speichern
              </button>
            </div>
          </form>
        </div>
      </section>

      <!-- 04 Charge-Konfiguration (UX-017 P3) -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Charge-Konfiguration</h2>
          <span class="s-card__num">{counts ? '04' : '03'}</span>
        </div>
        <div class="s-card__body">
          <p class="field__hint" style="margin-bottom:16px;">
            Pro Buchungs-Typ: Soll bei Bestätigung automatisch eine
            Mews-Charge an das Gäste-Zimmer geschickt werden? Deaktiviere
            für Reservation-only-Typen (z.B. Spa, wo Zahlung vor Ort erfolgt).
          </p>

          <form method="POST">
            <input type="hidden" name="_action" value="save_charge_config" />

            <div class="charge-toggle-grid" style="margin-bottom:20px;">
              {[
                { type: 'breakfast',     label: 'Frühstück',     hint: 'Preis aus /admin/breakfast' },
                { type: 'conference',    label: 'Konferenz',     hint: 'Preis aus /admin/conference' },
                { type: 'service',       label: 'Service',       hint: 'Preis aus /admin/service' },
                { type: 'restaurant',    label: 'Restaurant',    hint: 'Reservation-only — Zahlung vor Ort' },
                { type: 'spa',           label: 'Spa',           hint: 'Reservation-only — Zahlung vor Ort' },
                { type: 'late_checkout', label: 'Late Checkout', hint: 'Kostet meist extra' },
                { type: 'housekeeping',  label: 'Housekeeping',  hint: 'Kostenfreier Service' },
              ].map(({ type, label, hint }) => {
                const colKey = `${type}_charge_enabled` as keyof typeof integration;
                // null → fallback true (Backward-Compat fuer Rows ohne Default)
                const checked = (integration as any)?.[colKey] !== false;
                return (
                  <label class="charge-toggle-card">
                    <div class="charge-toggle-info">
                      <p class="charge-toggle-label">{label}</p>
                      <p class="charge-toggle-hint">{hint}</p>
                    </div>
                    <span style="position:relative;display:inline-block;flex-shrink:0;">
                      <input
                        type="checkbox"
                        name={`${type}_charge_enabled`}
                        checked={checked}
                        class="sr-only"
                      />
                      <span class="bt-visual"><span class="bt-knob"></span></span>
                    </span>
                  </label>
                );
              })}
            </div>

            <div class="s-card__footer">
              <button type="submit" class="v9-btn v9-btn--primary">
                Charge-Konfiguration speichern
              </button>
            </div>
          </form>
        </div>
      </section>

      <!-- 05 Aktionen -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Aktionen</h2>
          <span class="s-card__num">{counts ? '05' : '04'}</span>
        </div>
        <div class="s-card__body">
          <div class="s-card__actions">
            <button
              id="sync-button"
              type="button"
              class="v9-btn v9-btn--primary"
            >
              Jetzt synchronisieren
            </button>
            <form method="POST" id="disconnect-form" style="margin:0;">
              <input type="hidden" name="_action" value="disconnect" />
              <button type="submit" class="v9-btn v9-btn--ghost">
                Verbindung trennen
              </button>
            </form>
          </div>
          <p class="pms-footer-note" style="margin-top:16px;">
            Sync läuft über getMewsClientForHotel(hotel_id) — der Access-Token wird beim
            Sync server-seitig entschlüsselt und nie ans Frontend gesendet. Synchronisiert
            werden Reservationen der letzten 30 Tage (rolling window).
          </p>
        </div>
      </section>
    </>

  ) : (

    <>
      <!-- 01 Token-Hilfe -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Token-Generierung</h2>
          <span class="s-card__num">01</span>
        </div>
        <div class="s-card__body">
          <p class="field__hint" style="margin-bottom:12px;">
            Verbinde dein Mews-Property mit retaha. Du brauchst nur deinen
            <strong>Access-Token</strong> für die Connector-API — die Enterprise-ID lesen
            wir automatisch aus der Mews-API aus.
          </p>
          <div class="pms-info-box">
            <p class="pms-info-box__eyebrow">So findest du deinen Access-Token in Mews Commander</p>
            <ol>
              <li>Mews Commander öffnen → <strong>Marketplace</strong></li>
              <li>Eintrag "retaha" suchen und <strong>Connect</strong> klicken</li>
              <li>Access-Token kopieren und hier einfügen</li>
            </ol>
            <p class="pms-info-box__note">
              Falls retaha noch nicht im Marketplace ist: Mews-Support kontaktieren
              ("Connector-API-Integration mit retaha") oder die offizielle
              <a href="https://mews-systems.gitbook.io/connector-api/" target="_blank" rel="noopener" style="text-decoration:underline;">
                Connector-API-Doku
              </a>
              öffnen.
            </p>
          </div>
        </div>
      </section>

      <!-- 02 Verbinden -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Mews verbinden</h2>
          <span class="s-card__num">02</span>
        </div>
        <div class="s-card__body">
          <form method="POST">
            <input type="hidden" name="_action" value="connect" />

            <div class="sp-field">
              <label class="sp-label">
                Access-Token
                <span class="sp-label-hint">(Pflichtfeld)</span>
              </label>
              <input
                type="password"
                name="access_token"
                placeholder="••••••••••••"
                required
                autocomplete="off"
                spellcheck="false"
                class="s-input"
                style="font-family:'JetBrains Mono',monospace;"
              />
              <span style="font-size:11px;color:var(--ink-muted);font-style:italic;">
                Wird verschlüsselt gespeichert (AES-256-GCM) — niemals im Klartext in der Datenbank.
              </span>
            </div>

            <div class="sp-field">
              <label class="sp-label">Environment</label>
              <select name="environment" required class="s-select">
                <option value="demo">Demo (api.mews-demo.com)</option>
                <option value="production">Production (api.mews.com)</option>
              </select>
              <span style="font-size:11px;color:var(--ink-muted);font-style:italic;">
                Für erste Tests: Demo. Echte Reservationen: Production.
              </span>
            </div>

            <div class="s-card__footer">
              <button type="submit" class="v9-btn v9-btn--primary">
                Verbinden
              </button>
            </div>
          </form>
        </div>
      </section>
    </>

  )}

  </div><!-- /.settings-sections -->

</div><!-- /.settings-page -->

<script is:inline>
  (function () {
    const syncBtn = document.getElementById('sync-button');
    const disconnectForm = document.getElementById('disconnect-form');

    if (syncBtn) {
      syncBtn.addEventListener('click', async () => {
        const originalText = syncBtn.textContent;
        syncBtn.disabled = true;
        syncBtn.textContent = 'Synchronisiere…';
        try {
          const resp = await fetch('/api/admin/mews/sync', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ windowDays: 30 }),
          });
          const data = await resp.json();
          if (data.ok) {
            window.location.href = '/pms?saved=sync';
          } else {
            alert('Sync fehlgeschlagen: ' + (data.error || 'unbekannter Fehler'));
            syncBtn.disabled = false;
            syncBtn.textContent = originalText;
          }
        } catch (err) {
          alert('Netzwerk-Fehler: ' + (err && err.message ? err.message : err));
          syncBtn.disabled = false;
          syncBtn.textContent = originalText;
        }
      });
    }

    if (disconnectForm) {
      disconnectForm.addEventListener('submit', (e) => {
        if (!confirm('Mews-Verbindung wirklich trennen? Bisher synchronisierte Daten bleiben erhalten, der Sync stoppt aber sofort.')) {
          e.preventDefault();
        }
      });
    }
  })();
</script>

</Layout>
