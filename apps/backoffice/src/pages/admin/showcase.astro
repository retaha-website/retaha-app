---
// Sprint H · Group 2 — Showcase-Sessions Admin
//
// Hotelier verwaltet Demo-Sessions für Walkthroughs ohne echte Buchungen.

import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import { getEnv } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'settings.read')) return new Response('Forbidden', { status: 403 });
const canWrite = hasPermission(myRole, 'settings.write');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: sessions } = await client
  .from('showcase_sessions')
  .select('id, token, demo_data, expires_at, is_active, reset_count, last_reset_at, created_at')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false });

const rows = (sessions ?? []) as any[];
const siteOrigin = (getEnv('PUBLIC_SITE_URL') || 'http://localhost:4321').replace(/\/$/, '');

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('de-DE', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function statusOf(s: any): { label: string; class: string } {
  if (!s.is_active) return { label: 'inaktiv', class: 'sc-pill--off' };
  if (Date.parse(s.expires_at) < Date.now()) return { label: 'abgelaufen', class: 'sc-pill--off' };
  return { label: 'aktiv', class: 'sc-pill--on' };
}
---

<Layout title="Showcase" activeTab="backoffice">
  <div class="sc-page">
    <header class="sc-header">
      <p class="sc-eyebrow themed-eyebrow-flank">Showcase · Demo-Mode</p>
      <h1 class="sc-title">Zeig retaha vor — ohne echte Buchungen<span class="h-dot">.</span></h1>
      <p class="sc-sub">
        Eine Showcase-Session verhält sich wie ein echter Stay (Eve, Frühstücks-Bestellung,
        Service-Anfragen), aber alles bleibt isoliert: <strong>nichts geht an Mews, keine
        Email-Notifications, keine Push-Nachrichten</strong>. Reset wischt alle Demo-Daten.
      </p>
    </header>

    {canWrite && (
      <div class="sc-actions-top" x-data="{ creating: false, error: '' }">
        <button
          class="sc-btn-primary"
          type="button"
          :disabled="creating"
          @click="creating = true; fetch('/api/admin/showcase/create', { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: '{}' }).then(r => r.json()).then(d => { if (d.ok) location.reload(); else { error = d.error || 'Fehler'; creating = false; } })"
          x-text="creating ? 'Wird angelegt …' : '+ Neue Demo-Session'"
        ></button>
        <template x-if="error">
          <p class="sc-error" x-text="error"></p>
        </template>
      </div>
    )}

    {rows.length === 0 ? (
      <div class="sc-empty">
        <p>Noch keine Demo-Sessions. Lege eine an um retaha als Showcase zu nutzen.</p>
      </div>
    ) : (
      <div class="sc-list">
        {rows.map((s: any) => {
          const status = statusOf(s);
          const demoUrl = `${siteOrigin}/g/${s.token}`;
          return (
            <article class={`sc-card${!s.is_active ? ' sc-card--off' : ''}`} x-data="{ busy: false }">
              <div class="sc-card-head">
                <span class={`sc-pill ${status.class}`}>{status.label}</span>
                <span class="sc-card-meta">erstellt {fmtDate(s.created_at)}</span>
              </div>
              <h3 class="sc-card-title">
                {s.demo_data?.guest_first_name ?? 'Anna'} {s.demo_data?.guest_last_name ?? 'Demo'}
                <span class="sc-card-sep"> · </span>
                Zimmer {s.demo_data?.room_number ?? '101'}
              </h3>
              <div class="sc-token-row">
                <code class="sc-token">{s.token}</code>
              </div>
              <div class="sc-meta-grid">
                <div><span class="sc-mlabel">Gültig bis</span><span class="sc-mval">{fmtDate(s.expires_at)}</span></div>
                <div><span class="sc-mlabel">Resets</span><span class="sc-mval">{s.reset_count}</span></div>
                <div><span class="sc-mlabel">Letzter Reset</span><span class="sc-mval">{s.last_reset_at ? fmtDate(s.last_reset_at) : '—'}</span></div>
              </div>
              {s.is_active && Date.parse(s.expires_at) >= Date.now() && (
                <div class="sc-card-actions">
                  <a href={demoUrl} target="_blank" rel="noopener" class="sc-btn-ghost">Demo öffnen →</a>
                  <button class="sc-btn-ghost" type="button" @click={`navigator.clipboard.writeText('${demoUrl}').then(() => alert('URL kopiert'))`}>URL kopieren</button>
                  {canWrite && (
                    <>
                      <button
                        class="sc-btn-ghost"
                        type="button"
                        :disabled="busy"
                        @click={`if (!confirm('Alle Demo-Daten dieser Session löschen?')) return; busy = true; fetch('/api/admin/showcase/${s.id}/reset', { method: 'POST', credentials: 'include' }).then(r => r.json()).then(d => { busy = false; if (d.ok) { alert('Reset: ' + d.deleted.bookings + ' Bookings + ' + d.deleted.chat + ' Chat-Messages gelöscht'); location.reload(); } else alert('Fehler: ' + (d.error || 'unbekannt')); })`}
                      >Reset</button>
                      <button
                        class="sc-btn-danger"
                        type="button"
                        :disabled="busy"
                        @click={`if (!confirm('Session dauerhaft deaktivieren?')) return; busy = true; fetch('/api/admin/showcase/${s.id}', { method: 'DELETE', credentials: 'include' }).then(r => r.json()).then(d => { busy = false; if (d.ok) location.reload(); else alert('Fehler: ' + (d.error || 'unbekannt')); })`}
                      >Deaktivieren</button>
                    </>
                  )}
                </div>
              )}
            </article>
          );
        })}
      </div>
    )}
  </div>

  <style>
    .sc-page { max-width: 900px; margin: 0 auto; padding: 0 24px 60px; }
    .sc-header { margin: 20px 0 24px; }
    .sc-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--theme-accent); margin: 0 0 6px; }
    .sc-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; }
    .sc-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .65, transparent); max-width: 720px; line-height: 1.5; }
    .sc-sub strong { color: var(--theme-text-primary); font-weight: 500; }

    .sc-actions-top { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .sc-btn-primary { padding: 10px 18px; background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary); border: none; cursor: pointer; font-family: inherit; font-size: 13px; font-weight: 500; }
    .sc-btn-primary:hover:not(:disabled) { background: var(--theme-brand, var(--theme-accent)); }
    .sc-btn-primary:disabled { opacity: .5; cursor: not-allowed; }
    /* Marken-DNA: error = pink */
    .sc-error { color: var(--theme-accent); font-size: 13px; margin: 0; }

    .sc-empty { padding: 48px 24px; background: var(--theme-bg-primary); border: 1px dashed var(--theme-border); text-align: center; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); font-style: italic; }
    .sc-empty p { margin: 0; }

    .sc-list { display: flex; flex-direction: column; gap: 12px; }
    .sc-card { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 18px; transition: border-color .15s; }
    .sc-card:hover { border-color: var(--theme-text-primary); }
    .sc-card--off { opacity: .55; }
    .sc-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 8px; flex-wrap: wrap; }
    .sc-pill { font-size: 10px; padding: 3px 8px; text-transform: uppercase; letter-spacing: 0.05em; }
    /* Marken-DNA: active = sage */
    .sc-pill--on {
      background: color-mix(in srgb, var(--theme-success) 10%, transparent);
      color: var(--theme-success);
      border: 1px solid color-mix(in srgb, var(--theme-success) 35%, transparent);
    }
    .sc-pill--off { background: var(--theme-bg-tertiary); color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); }
    .sc-card-meta { font-size: 11px; color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); }
    .sc-card-title { font-size: 18px; font-weight: 300; margin: 0 0 10px; color: var(--theme-text-primary); }
    .sc-card-sep { color: color-mix(in srgb, var(--theme-text-primary) .3, transparent); }

    /* Token-Row: Burgund-Akzent als sekundäres Marken-Signal (statt Gold) */
    .sc-token-row { margin-bottom: 12px; padding: 8px 10px; background: var(--theme-bg-secondary); border-left: 3px solid var(--theme-burgund); }
    .sc-token { font-family: var(--theme-font-mono); font-size: 12px; color: var(--theme-text-primary); word-break: break-all; }

    .sc-meta-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; padding: 12px 0; border-top: 1px solid var(--theme-bg-tertiary); border-bottom: 1px solid var(--theme-bg-tertiary); margin-bottom: 12px; }
    @media (max-width: 600px) { .sc-meta-grid { grid-template-columns: 1fr; } }
    .sc-meta-grid > div { display: flex; flex-direction: column; gap: 2px; }
    .sc-mlabel { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); }
    .sc-mval { font-size: 12px; color: var(--theme-text-primary); font-variant-numeric: tabular-nums; }

    .sc-card-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .sc-btn-ghost { padding: 7px 14px; background: transparent; color: color-mix(in srgb, var(--theme-text-primary) .65, transparent); border: 1px solid var(--theme-border); cursor: pointer; font-family: inherit; font-size: 12px; text-decoration: none; }
    .sc-btn-ghost:hover { color: var(--theme-text-primary); border-color: var(--theme-text-primary); }
    /* Marken-DNA: destructive = pink */
    .sc-btn-danger { padding: 7px 14px; background: transparent; color: var(--theme-accent); border: 1px solid var(--theme-accent); cursor: pointer; font-family: inherit; font-size: 12px; }
    .sc-btn-danger:hover:not(:disabled) { background: rgba(var(--theme-accent-rgb), 0.08); }
    .sc-btn-danger:disabled, .sc-btn-ghost:disabled { opacity: .5; cursor: not-allowed; }
  </style>
</Layout>
