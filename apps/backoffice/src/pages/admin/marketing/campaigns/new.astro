---
// Sprint Wallet · Phase 14 — Campaign-Editor Page (3-Spalten + Preview)

import Layout from '../../../../layouts/Layout.astro';
import CampaignEditor from '../../../../components/admin/CampaignEditor.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.write')) return new Response('Forbidden', { status: 403 });

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: templates } = await client
  .from('marketing_templates')
  .select('id, name, title_i18n, body_i18n, cta_label_i18n, cta_url, hero_image_url')
  .eq('hotel_id', hotel.id)
  .eq('is_archived', false)
  .order('updated_at', { ascending: false });

const enabledLangs: string[] = Array.isArray((hotel as any).enabled_languages)
  ? (hotel as any).enabled_languages
  : [(hotel as any).default_language || 'de'];
---

<Layout title="Marketing · Neue Kampagne" activeTab="backoffice">
  <div class="mn-page">
    <header class="mn-header">
      <p class="mn-eyebrow themed-eyebrow-flank">Marketing · Neue Kampagne</p>
      <h1 class="mn-title">Was möchtest du senden<span class="h-dot">?</span></h1>
      <p class="mn-sub">Wähle eine Vorlage oder schreib Ad-hoc. Inhalt wird beim Speichern in alle aktivierten Sprachen übersetzt.</p>
    </header>

    <CampaignEditor
      templates={templates ?? []}
      hotelName={hotel.name}
      hotelDefaultLang={(hotel as any).default_language || 'de'}
      enabledLangs={enabledLangs}
    />
  </div>

  <style>
    .mn-page { max-width: 1200px; margin: 0 auto; padding: 0 24px 60px; }
    .mn-header { margin: 20px 0 28px; }
    .mn-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--theme-accent); margin: 0 0 6px; }
    .mn-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; letter-spacing: -0.01em; }
    .mn-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); max-width: 720px; line-height: 1.5; }
  </style>
</Layout>
