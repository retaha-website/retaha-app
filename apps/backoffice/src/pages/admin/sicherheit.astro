---
/**
 * /admin/sicherheit — 2FA Setup-Wizard (4 Steps)
 *
 * 1:1 CSS aus Prototyp mfa_v2_setup_wizard.html (User-finalisiert).
 *
 * Steps:
 *   1. Vorbereiten (Checklist) — kein API-Call
 *   2. QR-Code (calls /api/mfa/setup-start, holt secret + qr_data_url)
 *   3. Verifizieren (calls /api/mfa/setup-verify, liefert recovery_codes)
 *   4. Recovery-Codes anzeigen + Confirm-Checkbox -> /admin/dashboard
 *
 * Notiz: User-Spec sagte 'apps/dashboard/src/pages/admin/team-security.astro'
 * fuer Enforcement. Aktuelle Architektur trennt aber:
 *   - apps/dashboard = /app/* Operations
 *   - apps/backoffice = /admin/* Configuration
 * Daher /admin/sicherheit + /admin/team-security in BACKOFFICE.
 *
 * Sprint-J-Backlog: PDF-Download (pdf-lib), Email an User nach Setup-Complete.
 */

import { getUser, getUserHotels } from '@retaha/auth';
import AdminLayout from '../../components/AdminLayout.astro';
import TrianglePulse from '@retaha/ui/components/TrianglePulse.astro';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

// ?required=true wenn von Team-Pflicht-Redirect kommend
const isRequired = Astro.url.searchParams.get('required') === 'true';
---

<AdminLayout title="Zwei-Faktor-Authentifizierung" user={user} hotel={hotel}>

  <main class="admin-shell" x-data={`{
    step: 1,
    code: ['', '', '', '', '', ''],
    secretRevealed: false,
    confirmedSaved: false,

    // Aus API setup-start
    qrDataUrl: null,
    secretForManualEntry: null,
    isStarting: false,

    // Aus API setup-verify
    recoveryCodes: [],
    isVerifying: false,

    errorMessage: '',

    isComplete() { return this.code.every(d => d !== ''); },

    onCodeInput(index, event) {
      const value = event.target.value.replace(/\\D/g, '').slice(-1);
      this.code[index] = value;
      this.errorMessage = '';
      if (value && index < 5) {
        this.$refs['input' + (index + 1)]?.focus();
      }
    },
    onCodeKeydown(index, event) {
      if (event.key === 'Backspace' && !this.code[index] && index > 0) {
        this.code[index - 1] = '';
        this.$refs['input' + (index - 1)]?.focus();
      }
    },

    async advance() {
      if (this.step === 1) {
        // Lade QR-Code wenn 1 -> 2
        await this.startSetup();
        if (!this.qrDataUrl) return; // Error already set
        this.step = 2;
      } else if (this.step === 2) {
        this.step = 3;
        setTimeout(() => this.$refs.input0?.focus(), 200);
      } else if (this.step === 3) {
        await this.verifySetup();
      }
    },

    back() {
      if (this.step > 1) {
        this.step--;
        this.errorMessage = '';
      }
    },

    async startSetup() {
      this.isStarting = true;
      this.errorMessage = '';
      try {
        const res = await fetch('/api/mfa/setup-start', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.ok) {
          this.qrDataUrl = data.qr_data_url;
          this.secretForManualEntry = data.secret_for_manual_entry;
        } else {
          this.errorMessage = data.message || 'Setup konnte nicht gestartet werden.';
        }
      } catch {
        this.errorMessage = 'Netzwerk-Fehler.';
      } finally {
        this.isStarting = false;
      }
    },

    async verifySetup() {
      if (!this.isComplete()) return;
      this.isVerifying = true;
      this.errorMessage = '';
      try {
        const res = await fetch('/api/mfa/setup-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code: this.code.join('') })
        });
        const data = await res.json();
        if (res.ok && data.ok) {
          this.recoveryCodes = data.recovery_codes;
          this.step = 4;
        } else {
          this.errorMessage = data.message || 'Code ungültig. Bitte erneut versuchen.';
          this.code = ['', '', '', '', '', ''];
          setTimeout(() => this.$refs.input0?.focus(), 100);
        }
      } catch {
        this.errorMessage = 'Netzwerk-Fehler.';
      } finally {
        this.isVerifying = false;
      }
    },

    async copyRecoveryCodes() {
      try {
        await navigator.clipboard.writeText(this.recoveryCodes.join('\\n'));
        alert('Codes in die Zwischenablage kopiert.');
      } catch {
        alert('Kopieren fehlgeschlagen — bitte manuell auswählen.');
      }
    },

    printRecoveryCodes() {
      window.print();
    }
  }`}>

    {isRequired && (
      <div class="enforcement-notice">
        <p><strong>Pflicht-Setup:</strong> Dein Hotel-Owner hat 2FA fuer das Team aktiviert. Du musst es jetzt einrichten.</p>
      </div>
    )}

    <p class="page-eyebrow">— sicherheit —</p>
    <h1 class="page-title">Zwei-Faktor-Authentifizierung<span class="h-dot">.</span></h1>
    <p class="page-sub">
      Schütze dein retaha-Konto mit einem zusätzlichen Sicherheits-Schlüssel.
      Du brauchst eine Authenticator-App auf deinem Smartphone — wir empfehlen
      Google Authenticator, 1Password oder den iCloud-Schlüsselbund.
    </p>

    <!-- STEP INDICATOR -->
    <nav class="step-indicator" aria-label="Setup-Fortschritt">
      {[
        { num: '01', title: 'Vorbereiten' },
        { num: '02', title: 'QR-Code scannen' },
        { num: '03', title: 'Code verifizieren' },
        { num: '04', title: 'Recovery-Codes' },
      ].map((cell, i) => (
        <div class="step-cell" x-bind:class={`{
          'is-active': step === ${i + 1},
          'is-complete': step > ${i + 1},
          'is-not-yet': step < ${i + 1}
        }`}>
          <p class="step-cell__label"><span class="step-cell__num">{cell.num}</span>SCHRITT</p>
          <p class="step-cell__title">{cell.title}</p>
        </div>
      ))}
    </nav>

    <!-- Error Banner (global) -->
    <div x-show="errorMessage" x-cloak class="setup-error" x-text="errorMessage"></div>

    <!-- STEP 1: VORBEREITEN -->
    <section class="step-panel" x-show="step === 1">
      <h2 class="step-panel__title">Was du brauchst<span class="h-dot">.</span></h2>
      <p class="step-panel__desc">
        Bevor wir starten — bereite eine <strong>Authenticator-App</strong> auf deinem
        Smartphone vor. Falls du noch keine hast, kein Problem:
      </p>

      <div class="checklist">
        <div class="checklist-item">
          <span class="checklist-item__num">01</span>
          <div class="checklist-item__content">
            <h4>Authenticator-App installieren</h4>
            <p>
              Empfohlen:
              <a href="https://apps.apple.com/de/app/google-authenticator/id388497605" target="_blank" rel="noopener">Google Authenticator</a>,
              <a href="https://1password.com" target="_blank" rel="noopener">1Password</a>
              oder der iCloud-Schlüsselbund (bereits auf deinem iPhone).
            </p>
          </div>
        </div>
        <div class="checklist-item">
          <span class="checklist-item__num">02</span>
          <div class="checklist-item__content">
            <h4>Smartphone bereithalten</h4>
            <p>Du brauchst es für den QR-Code-Scan im nächsten Schritt.</p>
          </div>
        </div>
        <div class="checklist-item">
          <span class="checklist-item__num">03</span>
          <div class="checklist-item__content">
            <h4>Recovery-Codes notieren</h4>
            <p>
              Am Ende bekommst du 8 Backup-Codes für den Notfall — falls du dein
              Phone verlierst. Halte einen Drucker oder Stift bereit.
            </p>
          </div>
        </div>
      </div>

      <div class="step-actions">
        <button class="btn-primary" x-on:click="advance()" x-bind:disabled="isStarting">
          <span x-show="!isStarting">Ich bin bereit</span>
          <span x-show="isStarting" x-cloak>Wird vorbereitet ...</span>
        </button>
      </div>
    </section>

    <!-- STEP 2: QR-CODE -->
    <section class="step-panel" x-show="step === 2" x-cloak>
      <h2 class="step-panel__title">QR-Code scannen<span class="h-dot">.</span></h2>
      <p class="step-panel__desc">
        Öffne deine Authenticator-App und tippe auf <strong>"+ Hinzufügen"</strong>.
        Scanne dann den QR-Code mit der Kamera.
      </p>

      <div class="qr-display">
        <div class="qr-code">
          <img x-bind:src="qrDataUrl" alt="QR-Code für Authenticator-App-Setup" x-show="qrDataUrl" />
        </div>

        <div class="qr-info">
          <h4>retaha · 2FA Setup</h4>
          <p>
            Falls dein Phone den QR-Code nicht scannen kann, kannst du den
            Setup-Schlüssel auch manuell eintippen:
          </p>
          <button class="qr-secret-toggle" type="button" x-on:click="secretRevealed = !secretRevealed">
            <span x-text="secretRevealed ? '← Schlüssel verbergen' : '→ Schlüssel anzeigen'"></span>
          </button>
          <div x-show="secretRevealed" x-cloak class="qr-secret-value" x-text="secretForManualEntry"></div>
        </div>
      </div>

      <div class="step-actions">
        <button class="step-back" type="button" x-on:click="back()">← Zurück</button>
        <button class="btn-primary" x-on:click="advance()">
          Weiter zur Verifizierung
        </button>
      </div>
    </section>

    <!-- STEP 3: VERIFIZIEREN -->
    <section class="step-panel" x-show="step === 3" x-cloak>
      <h2 class="step-panel__title">Code verifizieren<span class="h-dot">.</span></h2>
      <p class="step-panel__desc">
        Deine App zeigt jetzt einen <strong>6-stelligen Code</strong> der alle 30 Sekunden
        neu generiert wird. Gib den aktuellen Code hier ein:
      </p>

      <div class="code-input-group">
        {Array.from({ length: 6 }).map((_, index) => (
          <input
            type="text"
            inputmode="numeric"
            autocomplete="one-time-code"
            maxlength="1"
            class="code-input"
            x-bind:class={`{ 'is-filled': code[${index}] !== '' }`}
            x-ref={`input${index}`}
            x-bind:value={`code[${index}]`}
            x-on:input={`onCodeInput(${index}, $event)`}
            x-on:keydown={`onCodeKeydown(${index}, $event)`}
            x-bind:disabled="isVerifying"
            aria-label={`Ziffer ${index + 1} von 6`}
          />
        ))}
      </div>

      <div class="step-actions">
        <button class="step-back" type="button" x-on:click="back()">← Zurück</button>
        <button class="btn-primary"
                x-bind:disabled="!isComplete() || isVerifying"
                x-on:click="verifySetup()">
          <span x-show="!isVerifying">Code prüfen</span>
          <span x-show="isVerifying" x-cloak>Wird geprüft ...</span>
        </button>
      </div>
    </section>

    <!-- STEP 4: RECOVERY-CODES -->
    <section class="step-panel" x-show="step === 4" x-cloak>

      <div class="setup-complete">
        <div class="setup-complete__indicator">
          <TrianglePulse variant="sage" motion="once" label="Setup erfolgreich abgeschlossen" />
          <span class="setup-complete__label">Erfolgreich aktiviert</span>
        </div>
      </div>

      <h2 class="step-panel__title" style="text-align: center;">
        Bestens<span class="h-dot">.</span>
      </h2>
      <p class="step-panel__desc" style="text-align: center;">
        2FA ist jetzt aktiv. Hier sind deine <strong>8 Recovery-Codes</strong> — bewahre
        sie sicher auf. Jeder Code funktioniert nur einmal und ersetzt deine
        Authenticator-App im Notfall.
      </p>

      <div class="recovery-codes">
        <template x-for="rcode in recoveryCodes" x-bind:key="rcode">
          <span class="recovery-code" x-text="rcode"></span>
        </template>
      </div>

      <div class="recovery-actions">
        <button class="btn-secondary" type="button" x-on:click="copyRecoveryCodes()">
          Codes kopieren
        </button>
        <button class="btn-secondary" type="button" x-on:click="printRecoveryCodes()">
          Drucken
        </button>
      </div>

      <div class="recovery-warning">
        <strong>Wichtig:</strong> Diese Codes werden dir NICHT erneut angezeigt.
        Bewahre sie an einem sicheren Ort auf — z.B. im Passwort-Manager oder
        gedruckt im Safe.
      </div>

      <div class="recovery-checkbox">
        <input type="checkbox" id="confirm-saved" x-model="confirmedSaved" />
        <label for="confirm-saved">
          Ich habe meine Recovery-Codes sicher gespeichert.
        </label>
      </div>

      <div class="step-actions">
        <a class="btn-primary"
           x-bind:class="confirmedSaved ? '' : 'is-disabled'"
           x-bind:href="confirmedSaved ? '/admin/dashboard' : '#'"
           style="flex: 1; text-decoration: none;">
          fertig — zum dashboard
        </a>
      </div>
    </section>

  </main>

  <style>
    :root {
      --color-pink-shock: #FF4A82;
      --color-pink-glow: rgba(255, 74, 130, 0.18);
      --color-pink-soft: rgba(255, 74, 130, 0.08);
      --color-anthrazit: #1A1A1A;
      --color-anthrazit-soft: #2A2A2A;
      --color-sage: #5C9070;
      --color-white: #FFFFFF;
      --radius: 3px;
      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quint: cubic-bezier(0.22, 1, 0.36, 1);
    }
    [x-cloak] { display: none !important; }

    .admin-shell {
      max-width: 720px;
      margin: 0 auto;
      padding: 32px 24px 80px;
    }

    .enforcement-notice {
      padding: 16px;
      background: rgba(255, 74, 130, 0.06);
      border-left: 3px solid var(--color-pink-shock);
      border-radius: var(--radius);
      margin-bottom: 32px;
      font-size: 14px;
    }

    .page-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--color-pink-shock); margin-bottom: 16px;
    }
    .page-title {
      font-size: 36px; font-weight: 500; line-height: 1.15;
      letter-spacing: -0.02em; color: var(--color-anthrazit); margin-bottom: 12px;
    }
    .page-title .h-dot { color: var(--color-pink-shock); }
    .page-sub {
      font-size: 15px; color: rgba(26, 26, 26, 0.6);
      line-height: 1.55; max-width: 560px; margin-bottom: 48px;
    }

    .step-indicator {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-bottom: 48px;
    }
    .step-cell {
      padding-top: 12px;
      border-top: 2px solid rgba(26, 26, 26, 0.1);
      transition: border-color 400ms var(--ease-out-expo);
    }
    .step-cell.is-active { border-top-color: var(--color-pink-shock); }
    .step-cell.is-complete { border-top-color: var(--color-sage); }
    .step-cell__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(26, 26, 26, 0.4);
      margin-bottom: 4px;
    }
    .step-cell.is-active .step-cell__label,
    .step-cell.is-complete .step-cell__label { color: var(--color-anthrazit); }
    .step-cell__title {
      font-size: 13px; font-weight: 500; color: var(--color-anthrazit);
    }
    .step-cell.is-not-yet .step-cell__title { color: rgba(26, 26, 26, 0.3); }
    .step-cell__num {
      display: inline-block;
      color: var(--color-pink-shock);
      font-family: 'JetBrains Mono', monospace;
      margin-right: 8px;
    }
    .step-cell.is-complete .step-cell__num { color: var(--color-sage); }
    .step-cell.is-not-yet .step-cell__num { color: rgba(26, 26, 26, 0.3); }

    .setup-error {
      padding: 12px 16px;
      background: rgba(255, 74, 130, 0.08);
      border-left: 3px solid var(--color-pink-shock);
      border-radius: var(--radius);
      margin-bottom: 24px;
      font-size: 13px;
    }
    .setup-error::before {
      content: "▲ ";
      color: var(--color-pink-shock);
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
    }

    .step-panel {
      animation: panelEnter 500ms var(--ease-out-expo);
    }
    @keyframes panelEnter {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .step-panel { animation: none; }
    }
    .step-panel__title {
      font-size: 24px; font-weight: 500; letter-spacing: -0.015em;
      color: var(--color-anthrazit); margin-bottom: 12px;
    }
    .step-panel__title .h-dot { color: var(--color-pink-shock); }
    .step-panel__desc {
      font-size: 14px; color: rgba(26, 26, 26, 0.65);
      line-height: 1.6; margin-bottom: 32px;
    }
    .step-panel__desc strong { color: var(--color-anthrazit); font-weight: 500; }

    /* STEP 1 — Checklist */
    .checklist { display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }
    .checklist-item {
      padding: 16px;
      background: rgba(26, 26, 26, 0.02);
      border: 1px solid rgba(26, 26, 26, 0.06);
      border-radius: var(--radius);
      display: flex;
      align-items: flex-start;
      gap: 16px;
    }
    .checklist-item__num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--color-pink-shock);
      letter-spacing: 0.1em;
      flex-shrink: 0;
      padding-top: 2px;
    }
    .checklist-item__content h4 {
      font-size: 14px; font-weight: 500;
      color: var(--color-anthrazit); margin-bottom: 4px;
    }
    .checklist-item__content p {
      font-size: 13px; color: rgba(26, 26, 26, 0.6); line-height: 1.5;
    }
    .checklist-item__content a {
      color: var(--color-pink-shock);
      text-decoration: none;
      border-bottom: 1px solid rgba(255, 74, 130, 0.3);
    }

    /* STEP 2 — QR-Code */
    .qr-display { display: grid; grid-template-columns: 1fr; gap: 32px; margin-bottom: 32px; }
    @media (min-width: 640px) {
      .qr-display { grid-template-columns: auto 1fr; align-items: center; }
    }
    .qr-code {
      width: 200px; height: 200px;
      background: var(--color-white);
      border: 1px solid rgba(26, 26, 26, 0.1);
      border-radius: var(--radius);
      padding: 16px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .qr-code img { width: 100%; height: 100%; }
    .qr-info h4 { font-size: 14px; font-weight: 500; margin-bottom: 12px; }
    .qr-info p { font-size: 13px; color: rgba(26, 26, 26, 0.6); line-height: 1.55; margin-bottom: 16px; }
    .qr-secret-toggle {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; border: 1px solid rgba(26, 26, 26, 0.15);
      padding: 8px 12px;
      border-radius: var(--radius);
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(26, 26, 26, 0.65);
      cursor: pointer;
      transition: all 200ms ease;
    }
    .qr-secret-toggle:hover { border-color: var(--color-pink-shock); color: var(--color-pink-shock); }
    .qr-secret-value {
      margin-top: 12px; padding: 12px;
      background: rgba(26, 26, 26, 0.04);
      border-radius: var(--radius);
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px; color: var(--color-anthrazit);
      letter-spacing: 0.1em; word-break: break-all;
    }

    /* STEP 3 — Code-Input */
    .code-input-group {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 12px;
      margin-bottom: 24px;
      max-width: 380px;
    }
    .code-input {
      width: 100%; aspect-ratio: 1; max-height: 56px;
      border: 1.5px solid rgba(26, 26, 26, 0.15);
      border-radius: var(--radius);
      background: var(--color-white);
      font-family: 'JetBrains Mono', monospace;
      font-size: 22px; font-weight: 500;
      text-align: center;
      color: var(--color-anthrazit);
      transition: all 250ms var(--ease-out-expo);
    }
    .code-input:focus {
      outline: none;
      border-color: var(--color-pink-shock);
      box-shadow: 0 0 0 4px var(--color-pink-soft);
    }
    .code-input.is-filled { border-color: rgba(26, 26, 26, 0.4); }

    /* STEP 4 — Recovery */
    .setup-complete { text-align: center; padding: 32px 0; }
    .setup-complete__indicator {
      display: inline-flex; align-items: center; gap: 12px;
      margin-bottom: 24px;
    }
    .setup-complete__label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--color-sage);
    }

    .recovery-codes {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      padding: 24px;
      background: rgba(26, 26, 26, 0.02);
      border: 1px solid rgba(26, 26, 26, 0.06);
      border-radius: var(--radius);
      margin-bottom: 24px;
    }
    .recovery-code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px; letter-spacing: 0.08em;
      color: var(--color-anthrazit);
      padding: 8px 12px;
      background: var(--color-white);
      border: 1px solid rgba(26, 26, 26, 0.06);
      border-radius: 2px;
      text-align: center;
    }

    .recovery-actions {
      display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px;
    }
    .btn-secondary {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 8px; padding: 12px 16px;
      background: transparent;
      border: 1px solid rgba(26, 26, 26, 0.15);
      border-radius: var(--radius);
      font-family: inherit; font-size: 13px;
      color: var(--color-anthrazit);
      cursor: pointer;
      transition: all 200ms ease;
    }
    .btn-secondary:hover {
      border-color: var(--color-pink-shock); color: var(--color-pink-shock);
    }

    .recovery-warning {
      padding: 16px;
      background: rgba(255, 74, 130, 0.06);
      border-left: 3px solid var(--color-pink-shock);
      border-radius: var(--radius);
      margin-bottom: 32px;
      font-size: 13px;
    }
    .recovery-warning::before {
      content: "▲ ";
      color: var(--color-pink-shock);
      font-family: 'JetBrains Mono', monospace;
      font-weight: bold;
    }
    .recovery-warning strong { color: var(--color-anthrazit); font-weight: 500; }

