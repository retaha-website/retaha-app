---
import '@retaha/ui/styles/global.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/login.css';
import { getUser } from '@retaha/auth';
import { t } from '../../i18n/helpers';
import type { AdminLocale } from '../../i18n/types';

const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;

// Specht-Logo SVG (inline, da public/ nicht via Vite-Module-Graph importierbar).
// Eine d-Path-Definition, zwei Farb-Varianten via String-Template.
const SPECHT_SVG_OPEN = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="326 177 121 176" width="121" height="176">';
const SPECHT_PATH_D = "M0 0C-9.489-.492-18.979-.934-28.419-1.377-28.419-1.377-46.021 8.949-60.722 4.819-75.423 .738-83.339 1.819-83.339 1.819-79.068-1.627-74.784-5.072-70.501-8.518-66.2-5.463-56.165-.825-35.647-1.967-35.647-1.967-58.593-4.806-66.425-11.798-63.144-14.438-59.865-17.077-56.592-19.717-56.592-19.717-15.193-54.677-68.687-83.884-68.687-83.884-30.533-47.646-59.985-30.141-70.162-53.939-80.291-77.688-90.469-101.487-88.01-100.798-85.503-100.061-83.044-99.372-88.748-116.434-94.5-133.496-100.204-150.558-100.204-150.558-74.489-146.92-68.245-97.848-68.245-97.848 2.213-66.527-34.86-20.307-41.055-12.883-23.846-5.36 0 0";
const SPECHT_TRANSFORM = "matrix(1,0,0,-1,437.2943,193.7768)";
const spechtCurrentColor = `${SPECHT_SVG_OPEN}<path transform="${SPECHT_TRANSFORM}" d="${SPECHT_PATH_D}" fill="currentColor" fill-rule="evenodd"/></svg>`;

// If already logged in, redirect to dashboard
const user = await getUser(Astro.cookies, Astro.request);
if (user) {
  return Astro.redirect('/admin/dashboard');
}

// POST: Magic-Link Request
let successMessage: string | null = null;
let errorMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString().trim();

  if (!email) {
    errorMessage = t('auth.form_error_invalid_email', userLocale);
  } else {
    const { createSupabaseServerInstance } = await import('@retaha/auth');
    const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

    const { error } = await client.auth.signInWithOtp({
      email,
      options: {
        emailRedirectTo: `${new URL(Astro.request.url).origin}/admin/auth/callback`,
      },
    });

    if (error) {
      errorMessage = t('auth.form_error_generic', userLocale);
    } else {
      successMessage = t('auth.form_success', userLocale);
    }
  }
}
---

<!DOCTYPE html>
<html lang={userLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t('auth.page_title', userLocale)}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased text-anthrazit">

    <main class="login-page">

      <!-- LINKS: Burgund Hero-Block -->
      <section class="login-hero">
        <div>
          <!-- Bauhaus-Marker-Trio in Bone -->
          <div class="login-hero-markers" aria-hidden="true">
            <span class="login-hero-marker login-hero-marker--circle"></span>
            <span class="login-hero-marker login-hero-marker--line"></span>
            <span class="login-hero-marker login-hero-marker--square"></span>
          </div>

          <p class="login-hero-eyebrow">— {t('auth.hero_eyebrow', userLocale)} —</p>
          <h1 class="login-hero-headline">
            <span class="login-hero-headline-light">{t('auth.hero_headline_light', userLocale)}</span>
            <span class="login-hero-headline-bold">{t('auth.hero_headline_bold', userLocale)}<span class="login-hero-headline-punkt">.</span></span>
          </h1>
        </div>

        <div class="login-hero-bottom">
          <div class="login-hero-brand-block">
            <div class="login-hero-brand-anchor">
              <div class="login-hero-logo" aria-label="retaha Specht" set:html={spechtCurrentColor} />
              <p class="login-hero-brand">retaha</p>
            </div>
            <p class="login-hero-brand-sub">{t('auth.hero_brand_sub', userLocale)}</p>
          </div>
        </div>
      </section>

      <!-- RECHTS: Bone Form-Block -->
      <section class="login-form-wrapper">
        <form method="POST" class="login-form">
          <div class="login-form-field">
            <p class="login-form-field-eyebrow">— {t('auth.form_email_eyebrow', userLocale)} —</p>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              autofocus
              placeholder={t('auth.form_email_placeholder', userLocale)}
              class="bauhaus-input"
            />
          </div>

          <button type="submit" class="bauhaus-button bauhaus-button--primary">
            {t('auth.form_submit', userLocale)}
          </button>

          <p class="login-form-help">{t('auth.form_help', userLocale)}</p>

          {successMessage && (
            <div class="login-form-message login-form-message--success">{successMessage}</div>
          )}
          {errorMessage && (
            <div class="login-form-message login-form-message--error">{errorMessage}</div>
          )}
        </form>

        <!-- Desktop-Legal-Footer rechts unten (Mobile nutzt .login-mobile-footer-legal) -->
        <nav class="login-form-legal" aria-label="Rechtliches">
          <a href="/impressum" class="login-form-legal-link">{t('legal.impressum', userLocale)}</a>
          <a href="/datenschutz" class="login-form-legal-link">{t('legal.datenschutz', userLocale)}</a>
          <a href="/agb" class="login-form-legal-link">{t('legal.agb', userLocale)}</a>
        </nav>

        {import.meta.env.DEV && (
          <div class="login-dev-block">
            <p class="login-dev-block-eyebrow">— DEV ONLY —</p>
            <form method="POST" action="/admin/auth/dev-login" class="login-form">
              <div class="login-form-field">
                <input
                  name="email"
                  type="email"
                  placeholder="dev login: email eingeben"
                  class="bauhaus-input"
                />
              </div>
              <button type="submit" class="bauhaus-button bauhaus-button--secondary bauhaus-button--small">
                {t('auth.form_dev_submit', userLocale)}
              </button>
            </form>
          </div>
        )}

        <!-- Mobile retaha-Footer (nur unter 768px sichtbar) -->
        <div class="login-mobile-footer">
          <div class="login-mobile-footer-brand-block">
            <div class="login-mobile-footer-brand-anchor">
              <div class="login-mobile-footer-logo" aria-label="retaha Specht" set:html={spechtCurrentColor} />
              <p class="login-mobile-footer-brand">retaha</p>
            </div>
            <p class="login-mobile-footer-brand-sub">{t('auth.hero_brand_sub', userLocale)}</p>
          </div>

          <nav class="login-mobile-footer-legal" aria-label="Rechtliches">
            <a href="/impressum" class="login-mobile-footer-legal-link">{t('legal.impressum', userLocale)}</a>
            <a href="/datenschutz" class="login-mobile-footer-legal-link">{t('legal.datenschutz', userLocale)}</a>
            <a href="/agb" class="login-mobile-footer-legal-link">{t('legal.agb', userLocale)}</a>
          </nav>
        </div>
      </section>

    </main>

  </body>
</html>
