---
import Layout from '../../layouts/Layout.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { t } from '../../i18n/helpers';

const userLocale = Astro.locals.locale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'save_times') {
    const updates = {
      conference_start_time: form.get('conference_start_time')?.toString() || '08:00',
      conference_end_time: form.get('conference_end_time')?.toString() || '20:00',
      conference_slot_minutes: parseInt(form.get('conference_slot_minutes')?.toString() || '60') || 60,
      updated_at: new Date().toISOString(),
    };

    const { data: updatedRows, error } = await client
      .from('hotel_settings')
      .update(updates)
      .eq('hotel_id', hotel.id)
      .select('hotel_id');

    if (error) {
      message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
    } else if (!updatedRows || updatedRows.length === 0) {
      message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS)' };
    } else {
      message = { type: 'success', text: 'Konferenz-Zeiten gespeichert.' };
    }
  } else if (action === 'save_rooms') {
    const roomsJson = form.get('rooms_json')?.toString();
    if (roomsJson) {
      try {
        const rooms = JSON.parse(roomsJson);
        if (!Array.isArray(rooms)) throw new Error('Salons müssen Array sein');

        const { data: updatedRows, error } = await client
          .from('hotel_settings')
          .update({ conference_rooms: rooms, updated_at: new Date().toISOString() })
          .eq('hotel_id', hotel.id)
          .select('hotel_id');

        if (error) {
          message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
        } else if (!updatedRows || updatedRows.length === 0) {
          message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS)' };
        } else {
          message = { type: 'success', text: 'Salons gespeichert.' };
        }
      } catch (e: any) {
        message = { type: 'error', text: `Ungültige Daten: ${e.message || 'unbekannt'}` };
      }
    }
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select('conference_rooms, conference_start_time, conference_end_time, conference_slot_minutes')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const rooms = ((settings?.conference_rooms as any[]) || []);
const startTime = ((settings as any)?.conference_start_time || '08:00').substring(0, 5);
const endTime = ((settings as any)?.conference_end_time || '20:00').substring(0, 5);
const slotMin = (settings as any)?.conference_slot_minutes || 60;
---

<Layout title="Konferenz" activeTab="backoffice">
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber={t('pages.conference.section_number', userLocale)}
      sectionLabel={t('pages.conference.section_label', userLocale)}
      headlineLight={t('pages.conference.headline_light', userLocale)}
      headlineBold={t('pages.conference.headline_bold', userLocale)}
      subtitle={t('pages.conference.subtitle', userLocale)}
    />
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <!-- Section: Zeiten -->
  <section class="bg-white border border-anthrazit/[0.12] p-6 mb-6">
    <h2 class="text-xl font-medium mb-4">Buchungszeiten</h2>

    <form method="POST">
      <input type="hidden" name="_action" value="save_times" />
      <div class="grid grid-cols-3 gap-4">
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Beginn</span>
          <input type="time" name="conference_start_time" value={startTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit" />
        </label>
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Ende</span>
          <input type="time" name="conference_end_time" value={endTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit" />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Slot-Länge (Min)</span>
          <input type="number" name="conference_slot_minutes" value={slotMin} min="15" max="240" step="15"
            class="bauhaus-input" />
        </label>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" class="bauhaus-button bauhaus-button--primary">
          Zeiten speichern
        </button>
      </div>
    </form>
  </section>

  <!-- Section: Salons -->
  <section class="bg-white border border-anthrazit/[0.12] p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-medium">Salons</h2>
      <button type="button" id="add-room-btn" class="bauhaus-button bauhaus-button--secondary">
        + Salon hinzufügen
      </button>
    </div>

    <form method="POST" id="rooms-form">
      <input type="hidden" name="_action" value="save_rooms" />
      <input type="hidden" name="rooms_json" id="rooms-json-input" />

      <div id="rooms-container" class="space-y-4 mb-6"></div>

      <div class="flex justify-end pt-4 border-t border-anthrazit/[0.12]">
        <button type="submit" class="bauhaus-button bauhaus-button--primary">
          Salons speichern
        </button>
      </div>
    </form>
  </section>

  <script is:inline define:vars={{ initialRooms: rooms }}>
    let rooms = JSON.parse(JSON.stringify(initialRooms || []));

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      })[c]);
    }

    function render() {
      const container = document.getElementById('rooms-container');
      container.innerHTML = '';

      rooms.forEach((room, idx) => {
        const div = document.createElement('div');
        div.className = 'border border-anthrazit/[0.12] p-4';
        div.setAttribute('data-translate-section', 'room-' + idx);
        div.innerHTML = `
          <div class="flex justify-between items-start mb-3">
            <div class="flex items-center gap-3">
              <span class="bg-anthrazit/[0.04] text-anthrazit/70 text-xs px-2 py-1 font-mono-display">Salon ${idx + 1}</span>
            </div>
            <div class="flex gap-2 items-center">
              <button type="button" data-action="delete" data-idx="${idx}"
                class="bauhaus-button bauhaus-button--ghost">
                Entfernen
              </button>
            </div>
          </div>

          <div class="grid grid-cols-12 gap-3">
            <label class="bauhaus-field col-span-4">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Slug (id)</span>
              <input type="text" data-idx="${idx}" data-field="id" value="${escapeHtml(room.id || '')}" placeholder="z.B. salon-linde"
                class="bauhaus-input bauhaus-input--mono" />
            </label>
            <label class="bauhaus-field col-span-2">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Kapazität</span>
              <input type="number" data-idx="${idx}" data-field="capacity" value="${room.capacity || 8}" min="1" max="100"
                class="bauhaus-input" />
            </label>
            <div class="col-span-6"></div>

            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Name (DE)</span>
              <input type="text" data-idx="${idx}" data-field="name_de" value="${escapeHtml(room.name_de || '')}"
                class="bauhaus-input" />
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Name (EN)</span>
              <input type="text" data-idx="${idx}" data-field="name_en" value="${escapeHtml(room.name_en || '')}"
                class="bauhaus-input" />
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Name (FR)</span>
              <input type="text" data-idx="${idx}" data-field="name_fr" value="${escapeHtml(room.name_fr || '')}"
                class="bauhaus-input" />
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Name (ES)</span>
              <input type="text" data-idx="${idx}" data-field="name_es" value="${escapeHtml(room.name_es || '')}"
                class="bauhaus-input" />
            </label>

            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Beschreibung (DE)</span>
              <textarea data-idx="${idx}" data-field="description_de" rows="2"
                class="bauhaus-textarea">${escapeHtml(room.description_de || '')}</textarea>
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Beschreibung (EN)</span>
              <textarea data-idx="${idx}" data-field="description_en" rows="2"
                class="bauhaus-textarea">${escapeHtml(room.description_en || '')}</textarea>
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Beschreibung (FR)</span>
              <textarea data-idx="${idx}" data-field="description_fr" rows="2"
                class="bauhaus-textarea">${escapeHtml(room.description_fr || '')}</textarea>
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Beschreibung (ES)</span>
              <textarea data-idx="${idx}" data-field="description_es" rows="2"
                class="bauhaus-textarea">${escapeHtml(room.description_es || '')}</textarea>
            </label>
          </div>
        `;
        container.appendChild(div);
      });

      // Bind inputs
      container.querySelectorAll('input, textarea').forEach(el => {
        el.addEventListener('input', e => {
          const idx = parseInt(e.target.dataset.idx);
          const field = e.target.dataset.field;
          if (field === 'capacity') {
            rooms[idx][field] = parseInt(e.target.value) || 0;
          } else {
            rooms[idx][field] = e.target.value;
          }
        });
      });

      // Delete buttons
      container.querySelectorAll('[data-action="delete"]').forEach(btn => {
        btn.addEventListener('click', e => {
          const idx = parseInt(e.currentTarget.dataset.idx);
          if (confirm('Salon wirklich entfernen?')) {
            rooms.splice(idx, 1);
            render();
          }
        });
      });

      // Sprint i18n Phase 5: Translate-Button-Handler entfernt. Auto-
      // Translation kommt in Phase 6 via async Save-Hook (Haiku, im
      // Hintergrund nach Speichern).

      document.getElementById('rooms-json-input').value = JSON.stringify(rooms);
    }

    document.getElementById('add-room-btn').addEventListener('click', () => {
      rooms.push({
        id: 'salon-' + Date.now(),
        name_de: 'Neuer Salon',
        name_en: '',
        name_fr: '',
        name_es: '',
        capacity: 8,
        description_de: '',
        description_en: '',
        description_fr: '',
        description_es: '',
      });
      render();
    });

    document.getElementById('rooms-form').addEventListener('submit', () => {
      document.getElementById('rooms-json-input').value = JSON.stringify(rooms);
    });

    render();
  </script>
</Layout>
