---
// Sprint Functional Modul C Phase 7 — Eve-Feedback Admin-View
//
// Hotelier sieht alle Eve-Antworten mit Gast-Bewertung. Standard-Filter:
// nur 👎-Votes (das ist wo Eve schlecht antwortet → Knowledge präzisieren).
// Optional Filter auf 👍 für Positiv-Beispiele.

import Layout from '../../../layouts/Layout.astro';
import EveSubNav from '../../../components/admin/EveSubNav.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) {
  return new Response('Forbidden', { status: 403 });
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') === 'positive' ? 1 : -1;

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

// Counts für Header
const { count: positiveCount } = await client
  .from('eve_message_feedback')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id).eq('rating', 1);
const { count: negativeCount } = await client
  .from('eve_message_feedback')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id).eq('rating', -1);

// Feedback-Liste mit Message + vorheriger User-Message
const { data: feedbackRows } = await client
  .from('eve_message_feedback')
  .select(`
    id, rating, optional_comment, created_at,
    message:chat_messages!message_id (id, content, created_at, stay_id),
    stay:stays!stay_id (id, check_in, check_out, guest:guests(first_name, last_name))
  `)
  .eq('hotel_id', hotel.id)
  .eq('rating', filter)
  .order('created_at', { ascending: false })
  .limit(50);

const rows = (feedbackRows ?? []) as any[];

// Für jede Eve-Message: vorherige User-Message ermitteln (Conversation-Kontext)
const messageIds = rows.map(r => r.message?.id).filter(Boolean);
const stayIds = Array.from(new Set(rows.map(r => r.stay?.id).filter(Boolean)));
let priorByMessageId: Record<string, { content: string; created_at: string } | null> = {};
if (rows.length > 0 && stayIds.length > 0) {
  // Lade je Stay die letzten ~40 messages, finde pro feedback-msg die unmittelbar vorhergehende user-message
  const { data: allMsgs } = await client
    .from('chat_messages')
    .select('id, role, content, created_at, stay_id')
    .in('stay_id', stayIds)
    .order('created_at', { ascending: true });
  const byStay = new Map<string, any[]>();
  for (const m of allMsgs ?? []) {
    if (!byStay.has(m.stay_id)) byStay.set(m.stay_id, []);
    byStay.get(m.stay_id)!.push(m);
  }
  for (const r of rows) {
    const stayMsgs = byStay.get(r.stay?.id) ?? [];
    const idx = stayMsgs.findIndex(m => m.id === r.message?.id);
    if (idx > 0) {
      // letzte user-message davor
      for (let i = idx - 1; i >= 0; i--) {
        if (stayMsgs[i].role === 'user') {
          priorByMessageId[r.message.id] = { content: stayMsgs[i].content, created_at: stayMsgs[i].created_at };
          break;
        }
      }
    }
  }
}
---

<Layout title="Eve · Feedback" activeTab="backoffice">
  <EveSubNav currentPath={Astro.url.pathname} />

  <div class="ev-page">
    <header class="ev-header">
      <p class="ev-eyebrow themed-eyebrow-flank">Eve · Feedback</p>
      <h1 class="ev-title">Wie kommt Eve bei deinen Gästen an<span class="h-dot">?</span></h1>
      <p class="ev-sub">Gäste können einzelne Antworten mit Daumen hoch/runter bewerten. Filter unten zeigt was schief läuft.</p>
    </header>

    <div class="ev-tabs">
      <a href="?filter=negative" class={`ev-tab${filter === -1 ? ' is-active' : ''}`}>
        👎 Nicht hilfreich <span class="ev-tab-counter">({negativeCount ?? 0})</span>
      </a>
      <a href="?filter=positive" class={`ev-tab${filter === 1 ? ' is-active' : ''}`}>
        👍 Hilfreich <span class="ev-tab-counter">({positiveCount ?? 0})</span>
      </a>
    </div>

    {rows.length === 0 ? (
      <div class="ev-empty">
        <p>{filter === -1
          ? 'Keine negativen Bewertungen. Eve macht ihren Job ✓'
          : 'Noch keine positiven Bewertungen.'}
        </p>
      </div>
    ) : (
      <div class="ev-list">
        {rows.map(r => {
          const prior = priorByMessageId[r.message?.id];
          const guestName = r.stay?.guest ? [r.stay.guest.first_name, r.stay.guest.last_name].filter(Boolean).join(' ') : 'Gast';
          return (
            <article class="ev-card">
              <div class="ev-card-head">
                <span class={`ev-rating-badge ev-rating-badge--${r.rating === 1 ? 'pos' : 'neg'}`}>
                  {r.rating === 1 ? '👍 Hilfreich' : '👎 Nicht hilfreich'}
                </span>
                <span class="ev-card-meta">{guestName} · {new Date(r.created_at).toLocaleString('de-DE', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' })}</span>
              </div>
              {prior && (
                <div class="ev-prior">
                  <p class="ev-prior-label">Gast fragte:</p>
                  <p class="ev-prior-text">„{prior.content}"</p>
                </div>
              )}
              <div class="ev-message">
                <p class="ev-message-label">Eve antwortete:</p>
                <p class="ev-message-text">{r.message?.content ?? '(Message gelöscht)'}</p>
              </div>
              {r.optional_comment && (
                <div class="ev-comment">
                  <p class="ev-comment-label">Gast-Kommentar:</p>
                  <p class="ev-comment-text">„{r.optional_comment}"</p>
                </div>
              )}
            </article>
          );
        })}
      </div>
    )}
  </div>

  <style>
    .ev-page { max-width: 900px; margin: 0 auto; padding: 0 24px 60px; }
    .ev-header { margin: 20px 0 24px; }
    .ev-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--theme-accent); margin: 0 0 6px; }
    .ev-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; letter-spacing: -0.01em; }
    .ev-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); }

    .ev-tabs { display: flex; gap: 4px; margin-bottom: 16px; border-bottom: 1px solid var(--theme-border); }
    .ev-tab { padding: 10px 14px; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .ev-tab:hover { color: var(--theme-text-primary); }
    .ev-tab.is-active { color: var(--theme-text-primary); border-bottom-color: var(--theme-accent); font-weight: 500; }
    .ev-tab-counter { color: color-mix(in srgb, var(--theme-text-primary) .4, transparent); margin-left: 4px; font-size: 12px; }

    .ev-empty { padding: 60px 24px; background: var(--theme-bg-primary); border: 1px dashed var(--theme-border); text-align: center; font-style: italic; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }

    .ev-list { display: flex; flex-direction: column; gap: 12px; }
    .ev-card { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 16px; }
    .ev-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; gap: 8px; }
    .ev-rating-badge { font-size: 11px; padding: 4px 10px; letter-spacing: 0.04em; }
    /* Marken-DNA: pos = sage, neg = pink */
    .ev-rating-badge--pos {
      background: color-mix(in srgb, var(--theme-success) 10%, transparent);
      color: var(--theme-success);
      border: 1px solid color-mix(in srgb, var(--theme-success) 35%, transparent);
    }
    .ev-rating-badge--neg {
      background: rgba(var(--theme-accent-rgb), 0.08);
      color: var(--theme-accent);
      border: 1px solid rgba(var(--theme-accent-rgb), 0.35);
    }
    .ev-card-meta { font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }

    .ev-prior, .ev-message, .ev-comment { padding: 8px 12px; margin: 8px 0; font-size: 14px; }
    .ev-prior { background: color-mix(in srgb, var(--theme-text-primary) .04, transparent); border-left: 3px solid color-mix(in srgb, var(--theme-text-primary) .3, transparent); }
    .ev-message { background: rgba(var(--theme-accent-rgb), .04); border-left: 3px solid var(--theme-accent); }
    /* Comment-block: stein-Tint (statt yellow) */
    .ev-comment {
      background: color-mix(in srgb, var(--theme-text-primary) 5%, transparent);
      border-left: 3px solid color-mix(in srgb, var(--theme-text-primary) 25%, transparent);
    }
    .ev-prior-label, .ev-message-label, .ev-comment-label { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); margin: 0 0 4px; }
    .ev-prior-text, .ev-message-text, .ev-comment-text { margin: 0; line-height: 1.5; color: var(--theme-text-primary); }
    .ev-prior-text, .ev-comment-text { font-style: italic; }
  </style>
</Layout>
