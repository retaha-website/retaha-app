---
// Sprint Wallet · Modul D — Stay-Push-Templates Übersicht

import Layout from '../../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import {
  STAY_PUSH_TRIGGER_LABELS,
  STAY_PUSH_TRIGGER_DESCRIPTIONS,
  STAY_PUSH_TRIGGER_ORDER,
} from '@retaha/marketing';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) return new Response('Forbidden', { status: 403 });
const canWrite = hasPermission(myRole, 'content.write');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: templates } = await client
  .from('stay_push_templates')
  .select('trigger_type, title_i18n, is_active, updated_at')
  .eq('hotel_id', hotel.id);

const tplByTrigger = new Map((templates ?? []).map((t: any) => [t.trigger_type, t]));
const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '';
}
---

<Layout title="Stay-Pushes" activeTab="backoffice">
  <div class="sp-page">
    <header class="sp-header">
      <p class="sp-eyebrow themed-eyebrow-flank">Wallet · Stay-Pushes</p>
      <h1 class="sp-title">Push-Nachrichten während des Aufenthalts<span class="h-dot">.</span></h1>
      <p class="sp-sub">
        Service-Pushes (z.B. Bestätigung einer Service-Anfrage) sind <strong>Vertragserfüllung</strong>
        und gehen unabhängig vom Marketing-Opt-Out raus. Sie folgen automatisch auf Booking-Events
        oder einen Cron — du kannst pro Trigger den Text editieren oder den Push deaktivieren.
      </p>
    </header>

    <div class="sp-list">
      {STAY_PUSH_TRIGGER_ORDER.map((trigger) => {
        const t = tplByTrigger.get(trigger) as any;
        const preview = pickI18n(t?.title_i18n);
        const active = t?.is_active !== false;  // wenn kein Template: default aktiv (Edit legt es an)
        return (
          <a href={`/admin/stay-pushes/${trigger}`} class={`sp-card${active ? '' : ' sp-card--off'}`}>
            <div class="sp-card-head">
              <span class={`sp-pill${active ? ' is-on' : ''}`}>{active ? 'aktiv' : 'inaktiv'}</span>
              <span class="sp-card-trigger">{STAY_PUSH_TRIGGER_LABELS[trigger]}</span>
            </div>
            <p class="sp-card-preview">{preview || <em>(noch nicht konfiguriert)</em>}</p>
            <p class="sp-card-sub">{STAY_PUSH_TRIGGER_DESCRIPTIONS[trigger]}</p>
          </a>
        );
      })}
    </div>

    <div class="sp-footnote">
      <strong>DSGVO-Hinweis:</strong> Stay-Pushes gelten als Vertragserfüllung (DSGVO Art. 6 Abs. 1 lit. b).
      Sie ignorieren Marketing-Opt-Out, werden aber blockiert wenn der Pass <code>state='expired'</code> oder
      noch nicht in Google synchronisiert ist.
    </div>
  </div>

  <style>
    .sp-page { max-width: 1000px; margin: 0 auto; padding: 0 24px 60px; }
    .sp-header { margin: 20px 0 28px; }
    .sp-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--theme-accent); margin: 0 0 6px; }
    .sp-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; }
    .sp-sub { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); max-width: 720px; line-height: 1.5; }
    .sp-sub strong { color: var(--theme-text-primary); }

    .sp-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px; }
    .sp-card { display: block; background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 18px; text-decoration: none; color: inherit; transition: border-color .15s, transform .15s; }
    .sp-card:hover { border-color: var(--theme-text-primary); transform: translateY(-1px); }
    .sp-card--off { opacity: .55; }
    .sp-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .sp-pill { font-size: 10px; padding: 3px 8px; text-transform: uppercase; letter-spacing: 0.05em; background: var(--theme-bg-tertiary); color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); }
    /* Marken-DNA: active = sage */
    .sp-pill.is-on {
      background: color-mix(in srgb, var(--theme-success) 10%, transparent);
      color: var(--theme-success);
      border: 1px solid color-mix(in srgb, var(--theme-success) 35%, transparent);
    }
    .sp-card-trigger { font-size: 12px; font-weight: 500; color: var(--theme-text-primary); letter-spacing: 0.02em; }
    .sp-card-preview { font-size: 14px; color: var(--theme-text-primary); margin: 6px 0; line-height: 1.4; }
    .sp-card-preview em { color: color-mix(in srgb, var(--theme-text-primary) .4, transparent); font-style: italic; }
    .sp-card-sub { font-size: 11px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); margin: 0; line-height: 1.45; }

    .sp-footnote { margin-top: 32px; padding: 14px 18px; background: var(--theme-bg-secondary); border-left: 3px solid var(--theme-burgund); font-size: 13px; line-height: 1.5; color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); }
    .sp-footnote strong { color: var(--theme-burgund); }
    .sp-footnote code { background: var(--theme-bg-primary); padding: 1px 5px; font-family: var(--theme-font-mono); font-size: 12px; color: var(--theme-text-primary); }
  </style>
</Layout>
