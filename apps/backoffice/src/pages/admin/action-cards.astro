---
import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const { data: hotelLangRow, error: langError } = await client
  .from('hotels').select('default_language, enabled_languages')
  .eq('id', hotel.id).maybeSingle();
if (langError) console.error('[action-cards] hotels lang query error', { hotelId: hotel.id, error: langError });
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';

if (!hotel.id) console.error('[action-cards] hotel.id is undefined — cards query will return empty', { hotel });
const { data: cards, error: cardsError } = await client
  .from('hotel_action_cards')
  .select('*')
  .eq('hotel_id', hotel.id)
  .order('sort_order', { ascending: true });

if (cardsError) console.error('[action-cards] hotel_action_cards query error', { hotelId: hotel.id, error: cardsError });
const cardList = (cards ?? []) as any[];
const overFive = cardList.length > 5;

const currentPlan = ((hotel as any).plan as string | undefined) ?? 'lite';
const liteCardLimit = currentPlan === 'lite' ? 3 : 0;


const INTERNAL_ACTIONS = [
  { value: 'open_breakfast',  label: bt('ac.action.breakfast', lang) },
  { value: 'open_service',    label: bt('ac.action.service', lang) },
  { value: 'open_eve',        label: bt('ac.action.eve', lang) },
  { value: 'open_places',     label: bt('ac.action.places', lang) },
  { value: 'open_wifi',       label: bt('ac.action.wifi', lang) },
  { value: 'open_wallet',     label: bt('ac.action.wallet', lang) },
];

const CARD_CLASSES = [
  { value: 'rec-anthrazit', label: bt('ac.class.anthrazit', lang) },
  { value: 'rec-pink',      label: bt('ac.class.pink', lang) },
  { value: 'rec-white',     label: bt('ac.class.white', lang) },
];

const CARD_TYPE_LABELS: Record<string, string> = {
  internal_action: bt('ac.type.internal', lang),
  external_link:   bt('ac.type.external', lang),
  info:            bt('ac.type.info', lang),
  phone:           bt('ac.type.phone', lang),
  email:           bt('ac.type.email', lang),
};

const acT = {
  fileTooBig: bt('ac.js.filetoobig', lang),
  titleRequired: bt('ac.js.titlerequired', lang),
  saved: bt('common.saved', lang),
  netErr: bt('ac.js.neterr', lang),
  imageUpload: bt('ac.js.imageupload', lang),
  deleteConfirm: bt('ac.js.deleteconfirm', lang),
  deleted: bt('ac.js.deleted', lang),
  eveError: bt('ac.eve.error', lang),
  eveGeneratingSet: bt('ac.eve.generating.set', lang),
  eveGeneratingCard: bt('ac.eve.generating.card', lang),
  eveSingleResult: bt('ac.eve.single.result', lang),
};
---

<Layout title="Action-Cards" activeTab="backoffice" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

<div
  class="settings-page"
  style="padding-top:0"
  x-data={`actionCardsEditor(${JSON.stringify({
    hotelId: hotel.id,
    defaultLang: hotelDefaultLang,
    cards: cardList,
    internalActions: INTERNAL_ACTIONS,
    cardClasses: CARD_CLASSES,
    typeLabels: CARD_TYPE_LABELS,
    t: acT,
    liteCardLimit,
  })})`}
>

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">Action-Cards</span>
  </nav>

  <!-- Settings Hero -->
  <section class="settings-hero">
    <h1 class="settings-hero__title" set:html={bt('ac.marketing.title', lang)}></h1>
    <p class="settings-hero__sub">{bt('ac.marketing.sub', lang)}</p>
  </section>

  {overFive && (
    <div class="ly-banner" set:html={bt('ac.hintbanner', lang).replace('{n}', String(cardList.length))}></div>
  )}

  {liteCardLimit > 0 && (
    <div class="ac-lite-info">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span>In der <strong>Lite-Version</strong> kannst du bis zu <strong>{liteCardLimit} Action Cards</strong> hinzufügen. Für mehr Karten <a href="/subscription" class="ac-lite-info-link">jetzt auf Pro upgraden →</a></span>
    </div>
  )}

  <!-- ── Eve card ─────────────────────────────────────────────────────────── -->
  <div class="evecard">
    <div class="ec-head">
      <svg class="ec-spk" width="15" height="15" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
      <b>Lass <span class="ec-gradient">Eve</span> deine Karten gestalten</b>
    </div>
    <p class="ec-desc" x-show="!busySet">{bt('ac.eve.sub', lang)}</p>

    <div class="ec-row" x-show="!busySet">
      <input
        type="text"
        class="ec-brief"
        x-model="eveBrief"
        @keydown.enter="generateSet()"
        placeholder={bt('ac.eve.brief.placeholder', lang)}
        maxlength="300"
      />
      <button class="ly-btn ly-aurora" :disabled="!eveBrief.trim()" @click="generateSet()">
        <svg class="ec-spk-anim" width="13" height="13" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
        {bt('ac.eve.set.btn', lang)}
      </button>
    </div>

    <div class="ec-gen" x-show="busySet">
      <div class="ec-sk">
        <i></i>
        <i></i>
        <i></i>
      </div>
    </div>

    <!-- Set-Ergebnis -->
    <template x-if="eveSetCards.length > 0">
      <div class="ac-eve-result">
        <div class="ac-eve-result-head">
          <span class="ac-eve-result-label">{bt('ac.eve.set.result', lang)}</span>
          <button class="ac-eve-apply-all" @click="applyAllSetCards()">
            {bt('ac.eve.set.apply.all', lang).replace('{n}', '')} <span x-text="eveSetCards.length"></span> {bt('ac.card.many', lang)} {bt('common.save', lang).toLowerCase()}
          </button>
        </div>
        <div class="ac-eve-set-list">
          <template x-for="(ec, idx) in eveSetCards" :key="idx">
            <div class="ac-eve-set-item">
              <div class="ac-eve-set-item-meta">
                <span class="ac-eve-set-badge" x-text="typeLabels[ec.card_type] ?? ec.card_type"></span>
                <strong x-text="ec.title"></strong>
                <span x-text="ec.subtitle"></span>
              </div>
              <button class="ac-eve-set-take" @click="applySetCard(ec)">{bt('ac.eve.set.apply.one', lang)}</button>
            </div>
          </template>
        </div>
      </div>
    </template>
  </div>

  <!-- ── Karten-Liste ──────────────────────────────────────────────────────── -->
  <div class="ly-sec">
    <div class="ly-sec-head">
      <div class="ly-sec-l">
        <span class="ly-dot"></span>
        <b>Deine Action-Cards</b>
        <span class="ac-counter-badge" x-text="`${cards.length} ${cards.length === 1 ? ${JSON.stringify(bt('ac.card.one', lang))} : ${JSON.stringify(bt('ac.card.many', lang))}}`"></span>
      </div>
      <button
        type="button"
        @click="liteCardLimit > 0 && cards.length >= liteCardLimit ? null : openNew()"
        x-bind:disabled="liteCardLimit > 0 && cards.length >= liteCardLimit"
        x-bind:title="liteCardLimit > 0 && cards.length >= liteCardLimit ? 'Plan-Limit erreicht — mit Pro freischalten' : ''"
        class="ly-btn ly-btn-outline"
      >+ {bt('ac.new', lang).replace('+ ', '')}</button>
    </div>

    {liteCardLimit > 0 && (
      <div class="ac-limit-warning" x-show="liteCardLimit > 0 && cards.length >= liteCardLimit" x-cloak>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span>Limit erreicht (<span x-text="cards.length"></span>/{liteCardLimit} Karten). Lösche eine Karte oder <a href="/subscription" class="ac-limit-link">jetzt auf Pro upgraden →</a></span>
      </div>
    )}

    <template x-if="cards.length === 0">
      <div class="ac-empty">
        <p class="ac-empty-text">{bt('ac.empty', lang)}</p>
      </div>
    </template>

    <div class="ac-list">
      <template x-for="c in cards" :key="c.id">
        <div class="ac-row"
          :class="{'is-drag-over': dragTarget && dragTarget.id === c.id, 'is-dragging': dragItem && dragItem.id === c.id}"
          :data-card-id="c.id">
          <span class="ac-drag-handle"
            @click.stop
            @pointerdown="dndPtrDown($event, c)"
            aria-label="Reihenfolge ändern">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
              <circle cx="5" cy="4" r="1.5"/><circle cx="11" cy="4" r="1.5"/>
              <circle cx="5" cy="8" r="1.5"/><circle cx="11" cy="8" r="1.5"/>
              <circle cx="5" cy="12" r="1.5"/><circle cx="11" cy="12" r="1.5"/>
            </svg>
          </span>
          <div class="ac-row-thumb">
            <template x-if="c.image_url">
              <img :src="c.image_url" alt="" loading="lazy" />
            </template>
            <template x-if="!c.image_url">
              <div class="ac-row-thumb-placeholder">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 21V9"/></svg>
              </div>
            </template>
          </div>
          <div class="ac-row-meta">
            <div class="ac-row-badges">
              <span class="ac-badge" x-text="typeLabels[c.card_type] ?? c.card_type"></span>
              <span class="ac-badge ac-badge--draft" x-show="c.is_published === false">{bt('ac.badge.draft', lang)}</span>
              <span class="ac-badge ac-badge--target" x-show="c.action_target" x-text="c.action_target"></span>
            </div>
            <p class="ac-row-title" x-text="pickI18nClient(c.title_i18n, defaultLang) || c.title_de || '—'"></p>
            <p class="ac-row-sub" x-show="pickI18nClient(c.subtitle_i18n, defaultLang) || c.subtitle_de"
               x-text="pickI18nClient(c.subtitle_i18n, defaultLang) || c.subtitle_de"></p>
          </div>
          <div class="ac-row-actions">
            <button type="button" class="ac-row-pub-toggle" @click.stop="togglePublished(c)">
              <span class="ac-row-pub-label" :class="{'is-active': c.is_published !== false}"
                x-text="c.is_published !== false ? 'Aktiv' : 'Inaktiv'"></span>
              <span class="bt-visual" :class="{'is-checked': c.is_published !== false}">
                <span class="bt-knob"></span>
              </span>
            </button>
            <button type="button" @click="openEdit(c.id)" class="ac-icon-btn" title={bt('si.items.edit', lang)}>✎</button>
            <button type="button" @click="deleteCard(c.id)" class="ac-icon-btn ac-icon-btn--danger" title={bt('nfc.delete', lang)}>×</button>
          </div>
        </div>
      </template>
    </div>
  </div>

  <!-- ── Modal ─────────────────────────────────────────────────────────────── -->
  <div x-show="editorOpen" x-cloak class="ac-modal-backdrop" @click.self="closeEditor()">
    <div class="ac-modal" @click.stop>

      <header class="ac-modal-head">
        <div class="ac-modal-head-l">
          <span class="ac-modal-dot"></span>
          <span class="ac-modal-title" x-text={`editorMode === 'new' ? ${JSON.stringify(bt('ac.modal.new', lang))} : ${JSON.stringify(bt('ac.modal.edit', lang))}`}></span>
        </div>
        <button type="button" @click="closeEditor()" class="ac-modal-close" aria-label="Schließen">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </header>

      <div class="ac-modal-body">

        <!-- Kartentyp -->
        <div class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.type', lang)}</span>
          <div class="ac-type-dd" x-data={`{open:false,labels:${JSON.stringify(CARD_TYPE_LABELS)},ddId:'type'}`}
            @click.outside="open=false" @ac-dd-open.window="if($event.detail.id!==ddId) open=false">
            <button type="button" class="ac-type-dd-btn" @click="open=!open; if(open) $dispatch('ac-dd-open',{id:ddId})">
              <span x-text="labels[editor.card_type] || editor.card_type"></span>
              <svg class="ac-type-dd-chevron" :class="{'rotated':open}" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="ac-type-dd-menu" x-show="open" style="display:none">
              {Object.entries(CARD_TYPE_LABELS).map(([val, label]) => (
                <button type="button" class="ac-type-dd-opt"
                  :class={`{'is-active': editor.card_type === '${val}'}`}
                  @click={`editor.card_type = '${val}'; onTypeChange(); open = false`}>
                  {label}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" x-show={`editor.card_type === '${val}'`} style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
                </button>
              ))}
            </div>
          </div>
        </div>

        <!-- Ziel (je nach Typ) -->
        <div x-show="editor.card_type === 'internal_action'" class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.sheet', lang)}</span>
          <div class="ac-type-dd" x-data={`{open:false,labels:${JSON.stringify(Object.fromEntries(INTERNAL_ACTIONS.map(a => [a.value, a.label])))},ddId:'sheet'}`}
            @click.outside="open=false" @ac-dd-open.window="if($event.detail.id!==ddId) open=false">
            <button type="button" class="ac-type-dd-btn" @click="open=!open; if(open) $dispatch('ac-dd-open',{id:ddId})">
              <span x-text="labels[editor.action_target] || editor.action_target"></span>
              <svg class="ac-type-dd-chevron" :class="{'rotated':open}" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="ac-type-dd-menu" x-show="open" style="display:none">
              {INTERNAL_ACTIONS.map(a => (
                <button type="button" class="ac-type-dd-opt"
                  :class={`{'is-active': editor.action_target === '${a.value}'}`}
                  @click={`editor.action_target = '${a.value}'; open = false`}>
                  {a.label}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" x-show={`editor.action_target === '${a.value}'`} style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
                </button>
              ))}
            </div>
          </div>
        </div>

        <div x-show="editor.card_type === 'external_link'" class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.url', lang)}</span>
          <input type="url" x-model="editor.action_target" placeholder="https://deinhotel.de/angebote" class="ac-input" />
        </div>

        <div x-show="editor.card_type === 'phone'" class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.phone', lang)}</span>
          <input type="tel" x-model="editor.action_target" placeholder="+49 30 12345678" class="ac-input" />
        </div>

        <div x-show="editor.card_type === 'email'" class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.email', lang)}</span>
          <input type="email" x-model="editor.action_target" placeholder="rezeption@deinhotel.de" class="ac-input" />
        </div>

        <!-- Eve -->
        <div class="ac-eve-inline">
          <div class="ac-eve-inline-head">
            <svg width="12" height="12" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
            <span>Eve schlägt Texte vor</span>
          </div>
          <div class="ac-eve-inline-row">
            <input type="text" class="ac-input ac-eve-brief-input" x-model="eveBriefModal"
              placeholder={bt('ac.eve.brief.placeholder', lang)} maxlength="300" />
            <button type="button" class="ac-eve-inline-btn" :disabled="!eveBriefModal.trim() || busyCard" @click="generateCard()">
              <template x-if="!busyCard"><span>{bt('ac.eve.single.btn', lang)}</span></template>
              <template x-if="busyCard"><span x-text="t.eveGeneratingCard"></span></template>
            </button>
          </div>
          <template x-if="eveCardSuggestion">
            <div class="ac-eve-suggestion">
              <div class="ac-eve-suggestion-head" x-text="t.eveSingleResult"></div>
              <div class="ac-eve-suggestion-fields">
                <div class="ac-eve-sug-row" x-show="eveCardSuggestion.eyebrow">
                  <span class="ac-eve-sug-label">Eyebrow</span>
                  <span x-text="eveCardSuggestion.eyebrow"></span>
                </div>
                <div class="ac-eve-sug-row">
                  <span class="ac-eve-sug-label">Titel</span>
                  <span x-text="eveCardSuggestion.title"></span>
                </div>
                <div class="ac-eve-sug-row" x-show="eveCardSuggestion.subtitle">
                  <span class="ac-eve-sug-label">Untertitel</span>
                  <span x-text="eveCardSuggestion.subtitle"></span>
                </div>
                <div class="ac-eve-sug-row" x-show="eveCardSuggestion.cta">
                  <span class="ac-eve-sug-label">CTA</span>
                  <span x-text="eveCardSuggestion.cta"></span>
                </div>
              </div>
              <button type="button" class="ac-eve-sug-apply" @click="applyCardSuggestion()">{bt('ac.eve.single.apply', lang)}</button>
            </div>
          </template>
        </div>

        <div class="ac-modal-divider"></div>

        <!-- Texte -->
        <label class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.titlelabel', lang)}</span>
          <input type="text" x-model="editor.title" required maxlength="60" class="ac-input"
            placeholder="z.B. Frühstück reservieren" />
        </label>
        <label class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.eyebrow', lang)} <span class="ac-optional">{bt('ac.modal.eyebrowhint', lang)}</span></span>
          <input type="text" x-model="editor.eyebrow" maxlength="40" class="ac-input"
            placeholder="z.B. Täglich ab 7 Uhr" />
        </label>
        <label class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.subtitle', lang)} <span class="ac-optional">{bt('ac.modal.subtitlehint', lang)}</span></span>
          <textarea x-model="editor.subtitle" rows="2" maxlength="200" class="ac-input"
            placeholder="z.B. Frisch & regional — im Wintergarten"></textarea>
        </label>
        <label class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.cta', lang)} <span class="ac-optional">{bt('ac.modal.eyebrowhint', lang)}</span></span>
          <input type="text" x-model="editor.cta" maxlength="30" class="ac-input"
            placeholder="z.B. Jetzt reservieren" />
        </label>

        <div class="ac-modal-divider"></div>

        <!-- Bild -->
        <div class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.image', lang)} <span class="ac-optional">{bt('ac.modal.imagehint', lang)}</span></span>
          <label class="ac-dropzone" :class="{'has-image': editor.imagePreview || editor.image_url}">
            <input type="file" accept="image/jpeg,image/png,image/webp" @change="onFileChange($event)" style="display:none" />
            <template x-if="editor.imagePreview || editor.image_url">
              <img :src="editor.imagePreview || editor.image_url" alt="" class="ac-dropzone-img" />
            </template>
            <template x-if="!editor.imagePreview && !editor.image_url">
              <div class="ac-dropzone-empty">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 21V9"/></svg>
                <span>Bild hochladen</span>
                <span class="ac-dropzone-hint">JPG · PNG · WebP</span>
              </div>
            </template>
          </label>
          <button type="button" x-show="editor.imagePreview || editor.image_url" @click="clearImage()"
            class="ac-remove-img-btn">{bt('ac.modal.removeimage', lang)}</button>
        </div>

        <div class="ac-modal-divider"></div>

        <!-- Kartenstil -->
        <div class="ac-field">
          <span class="ac-field-label">{bt('ac.modal.style', lang)}</span>
          <div class="ac-style-swatches">
            <button type="button" class="ac-swatch" :class="{'is-active': editor.card_class === 'rec-anthrazit'}" @click="editor.card_class = 'rec-anthrazit'">
              <span class="ac-swatch-color" style="background:#1C1C1E"></span>
              <span>Anthrazit</span>
            </button>
            <button type="button" class="ac-swatch" :class="{'is-active': editor.card_class === 'rec-pink'}" @click="editor.card_class = 'rec-pink'">
              <span class="ac-swatch-color" style="background:#14616E"></span>
              <span>Petrol</span>
            </button>
            <button type="button" class="ac-swatch" :class="{'is-active': editor.card_class === 'rec-white'}" @click="editor.card_class = 'rec-white'">
              <span class="ac-swatch-color" style="background:#F5F4F2;border:1px solid #E0DED8"></span>
              <span>Hell</span>
            </button>
          </div>
        </div>


      </div>

      <footer class="ac-modal-foot">
        <span x-show="saveError" x-text="saveError" class="ac-error"></span>
        <button type="button" @click="closeEditor()" class="ly-btn ly-btn-ghost">{bt('common.cancel', lang)}</button>
        <button type="button" @click="saveEditor()" :disabled="isSaving" class="ly-btn ly-btn-petrol">
          <span x-show="!isSaving">{bt('common.save', lang)}</span>
          <span x-show="isSaving">{bt('ac.modal.saving', lang)}</span>
        </button>
      </footer>
    </div>
  </div>

</div>

<script>
  import { resizeImage } from '../../lib/storage/client-resize';

  const DEFAULT_ACTION_TARGET = 'open_breakfast';

  function emptyEditor() {
    return {
      id: null,
      card_type: 'internal_action',
      action_target: DEFAULT_ACTION_TARGET,
      title: '', subtitle: '', eyebrow: '', cta: '',
      image_url: null,
      imageFile: null,
      imagePreview: null,
      card_class: 'rec-anthrazit',
      is_published: true,
    };
  }

  function pickI18nClient(value: any, lang: string): string {
    if (!value || typeof value !== 'object') return '';
    return value[lang]?.value || value['de']?.value || '';
  }

  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('actionCardsEditor', (initial: any) => ({
      hotelId: initial.hotelId,
      defaultLang: initial.defaultLang as string,
      cards: initial.cards,
      internalActions: initial.internalActions,
      cardClasses: initial.cardClasses,
      typeLabels: initial.typeLabels,
      t: initial.t,
      liteCardLimit: initial.liteCardLimit ?? 0,

      editorOpen: false,
      editorMode: 'new' as 'new' | 'edit',
      editor: emptyEditor(),
      isSaving: false,
      saveError: '' as string,

      // DnD state (same pattern as breakfast.astro)
      dragItem: null as any,
      dragTarget: null as any,
      _ptrItem: null as any,
      _ptrMoveHandler: null as any,
      _ptrUpHandler: null as any,

      // Eve set
      eveBrief: '' as string,
      busySet: false,
      eveSetCards: [] as any[],

      // Eve single card (modal)
      eveBriefModal: '' as string,
      busyCard: false,
      eveCardSuggestion: null as any,

      pickI18nClient,

      openNew() {
        this.editor = emptyEditor();
        this.editorMode = 'new';
        this.saveError = '';
        this.eveCardSuggestion = null;
        this.editorOpen = true;
      },

      openEdit(id: string) {
        const c = this.cards.find((x: any) => x.id === id);
        if (!c) return;
        const e = emptyEditor();
        e.id = c.id;
        e.card_type = c.card_type;
        e.action_target = c.action_target ?? '';
        e.title    = pickI18nClient(c.title_i18n,    this.defaultLang) || c.title_de    || '';
        e.subtitle = pickI18nClient(c.subtitle_i18n, this.defaultLang) || c.subtitle_de || '';
        e.eyebrow  = pickI18nClient(c.eyebrow_i18n,  this.defaultLang) || c.eyebrow_de  || '';
        e.cta      = pickI18nClient(c.cta_i18n,      this.defaultLang) || c.cta_de      || '';
        e.image_url = c.image_url ?? null;
        e.card_class = c.card_class ?? 'rec-anthrazit';
        e.is_published = c.is_published !== false;
        this.editor = e;
        this.editorMode = 'edit';
        this.saveError = '';
        this.eveCardSuggestion = null;
        this.editorOpen = true;
      },

      closeEditor() {
        this.editorOpen = false;
        this.eveCardSuggestion = null;
      },

      onTypeChange() {
        if (this.editor.card_type === 'internal_action') {
          if (!this.editor.action_target) this.editor.action_target = DEFAULT_ACTION_TARGET;
        } else {
          this.editor.action_target = '';
        }
        this.eveCardSuggestion = null;
      },

      async generateSet() {
        const brief = this.eveBrief.trim();
        if (!brief) return;
        this.busySet = true;
        this.eveSetCards = [];
        try {
          const res = await fetch('/api/action-cards/generate', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mode: 'set', brief }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) { this.showToast(this.t.eveError, 'error'); return; }
          this.eveSetCards = data.cards ?? [];
        } catch {
          this.showToast(this.t.eveError, 'error');
        } finally {
          this.busySet = false;
        }
      },

      async applySetCard(ec: any) {
        const e = emptyEditor();
        e.card_type    = ec.card_type    ?? 'info';
        e.action_target = ec.action_target ?? '';
        e.card_class   = ec.card_class   ?? 'rec-anthrazit';
        e.eyebrow      = ec.eyebrow      ?? '';
        e.title        = ec.title        ?? '';
        e.subtitle     = ec.subtitle     ?? '';
        e.cta          = ec.cta          ?? '';
        this.editor = e;
        this.editorMode = 'new';
        this.saveError = '';
        this.eveCardSuggestion = null;
        this.editorOpen = true;
      },

      async applyAllSetCards() {
        let saved = 0;
        for (const ec of this.eveSetCards) {
          const payload = {
            card_type:    ec.card_type    ?? 'info',
            action_target: ec.action_target ?? '',
            card_class:   ec.card_class   ?? 'rec-anthrazit',
            is_published: true,
            eyebrow:      ec.eyebrow      ?? '',
            title:        ec.title        ?? '',
            subtitle:     ec.subtitle     ?? '',
            cta:          ec.cta          ?? '',
          };
          const res = await fetch('/api/action-cards/upsert', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (data.limitReached) {
            this.showToast(`Limit erreicht — ${saved} von ${this.eveSetCards.length} Karten gespeichert. Karte löschen oder auf Pro upgraden.`, 'error');
            this.eveSetCards = [];
            setTimeout(() => window.location.reload(), 1200);
            return;
          }
          if (data.ok) saved++;
        }
        this.eveSetCards = [];
        this.showToast(this.t.saved, 'success');
        setTimeout(() => window.location.reload(), 600);
      },

      async generateCard() {
        const brief = this.eveBriefModal.trim();
        if (!brief) return;
        this.busyCard = true;
        this.eveCardSuggestion = null;
        try {
          const res = await fetch('/api/action-cards/generate', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              mode: 'card',
              brief,
              card_type: this.editor.card_type,
              action_target: this.editor.action_target,
            }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) { this.showToast(this.t.eveError, 'error'); return; }
          this.eveCardSuggestion = data;
        } catch {
          this.showToast(this.t.eveError, 'error');
        } finally {
          this.busyCard = false;
        }
      },

      applyCardSuggestion() {
        if (!this.eveCardSuggestion) return;
        if (this.eveCardSuggestion.eyebrow)  this.editor.eyebrow  = this.eveCardSuggestion.eyebrow;
        if (this.eveCardSuggestion.title)    this.editor.title    = this.eveCardSuggestion.title;
        if (this.eveCardSuggestion.subtitle) this.editor.subtitle = this.eveCardSuggestion.subtitle;
        if (this.eveCardSuggestion.cta)      this.editor.cta      = this.eveCardSuggestion.cta;
        this.eveCardSuggestion = null;
      },

      async onFileChange(ev: Event) {
        const input = ev.target as HTMLInputElement;
        const file = input.files?.[0];
        if (!file) return;
        if (file.size > 2 * 1024 * 1024) {
          this.showToast(this.t.fileTooBig, 'error');
          input.value = '';
          return;
        }
        this.editor.imageFile = await resizeImage(file, 1200) as any;
        this.editor.imagePreview = URL.createObjectURL(this.editor.imageFile as any) as any;
      },

      clearImage() {
        this.editor.imageFile = null;
        this.editor.imagePreview = null;
        this.editor.image_url = null;
      },

      friendlyError(raw: string): string {
        if (raw.includes('title required') || raw.includes('titlerequired')) return 'Bitte gib einen Titel für die Karte ein.';
        if (raw.includes('action_target required')) return 'Bitte wähle eine Retaha-Funktion aus.';
        if (raw.includes('URL required') || raw.includes('Invalid URL') || raw.includes('http/https')) return 'Bitte gib eine gültige URL ein (z.B. https://deinhotel.de).';
        if (raw.includes('Invalid phone')) return 'Bitte gib eine gültige Telefonnummer ein.';
        if (raw.includes('Invalid email')) return 'Bitte gib eine gültige E-Mail-Adresse ein.';
        if (raw.includes('Limit erreicht')) return raw;
        if (raw.includes('API ') || raw.includes('API:')) return 'Speichern fehlgeschlagen — bitte nochmal versuchen.';
        if (raw.includes('Netzwerk') || raw.includes('network') || raw.includes('fetch')) return 'Keine Verbindung — bitte Internetverbindung prüfen.';
        return raw;
      },

      async saveEditor() {
        if (!this.editor.title?.trim()) {
          this.saveError = 'Bitte gib einen Titel für die Karte ein.';
          return;
        }
        this.isSaving = true;
        this.saveError = '';
        try {
          const payload: any = {
            id: this.editor.id || undefined,
            card_type: this.editor.card_type,
            action_target: this.editor.action_target,
            card_class: this.editor.card_class,
            is_published: this.editor.is_published,
            title:    this.editor.title,
            subtitle: this.editor.subtitle,
            eyebrow:  this.editor.eyebrow,
            cta:      this.editor.cta,
          };
          const res = await fetch('/api/action-cards/upsert', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) { this.saveError = this.friendlyError(data.error || `API ${res.status}`); return; }

          if (this.editor.imageFile) {
            const fd = new FormData();
            fd.append('card_id', data.id);
            fd.append('image', this.editor.imageFile);
            const upRes = await fetch('/api/action-cards/upload-image', { method: 'POST', body: fd });
            const upData = await upRes.json();
            if (!upRes.ok || !upData.ok) { this.saveError = `${this.t.imageUpload}: ${upData.error || upRes.statusText}`; return; }
          }
          this.showToast(this.t.saved, 'success');
          this.editorOpen = false;
          setTimeout(() => window.location.reload(), 600);
        } catch (err: any) {
          this.saveError = this.friendlyError(err.message ?? '');
        } finally {
          this.isSaving = false;
        }
      },

      dndPtrDown(e: PointerEvent, card: any) {
        e.preventDefault();
        this._ptrItem = card;
        this.dragItem = card;
        const pid = e.pointerId;
        this._ptrMoveHandler = (ev: PointerEvent) => {
          if (ev.pointerId !== pid) return;
          ev.preventDefault();
          const el = document.elementFromPoint(ev.clientX, ev.clientY);
          const row = el && (el as HTMLElement).closest('[data-card-id]');
          if (row) {
            const idStr = (row as HTMLElement).dataset.cardId;
            const target = this.cards.find((c: any) => c.id === idStr);
            if (target && target.id !== this._ptrItem?.id) this.dragTarget = target;
          }
        };
        this._ptrUpHandler = (ev: PointerEvent) => {
          if (ev.pointerId !== pid) return;
          window.removeEventListener('pointermove', this._ptrMoveHandler);
          window.removeEventListener('pointerup', this._ptrUpHandler);
          window.removeEventListener('pointercancel', this._ptrUpHandler);
          if (this._ptrItem && this.dragTarget) {
            this._dndPerform(this.dragTarget);
          } else {
            this.dragItem = null; this.dragTarget = null;
          }
          this._ptrItem = null; this._ptrMoveHandler = null; this._ptrUpHandler = null;
        };
        window.addEventListener('pointermove', this._ptrMoveHandler, { passive: false });
        window.addEventListener('pointerup', this._ptrUpHandler);
        window.addEventListener('pointercancel', this._ptrUpHandler);
      },

      _dndPerform(target: any) {
        const fromIdx = this.cards.findIndex((c: any) => c.id === this.dragItem.id);
        const toIdx   = this.cards.findIndex((c: any) => c.id === target.id);
        if (fromIdx < 0 || toIdx < 0 || fromIdx === toIdx) {
          this.dragItem = null; this.dragTarget = null; return;
        }
        const newCards = [...this.cards];
        const [moved] = newCards.splice(fromIdx, 1);
        newCards.splice(toIdx, 0, moved);
        this.cards = newCards;
        this.dragItem = null; this.dragTarget = null;
        this._saveOrder(newCards.map((c: any) => c.id));
      },

      async _saveOrder(ids: string[]) {
        try {
          const res = await fetch('/api/action-cards/reorder', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids }),
          });
          const d = await res.json();
          if (!d.ok) this.showToast(d.error || 'Reihenfolge konnte nicht gespeichert werden', 'error');
        } catch {
          this.showToast('Netzwerk-Fehler beim Speichern der Reihenfolge', 'error');
        }
      },

      async togglePublished(card: any) {
        const prev = card.is_published;
        card.is_published = prev === false ? true : false;
        try {
          const res = await fetch('/api/action-cards/set-published', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: card.id, is_published: card.is_published }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) card.is_published = prev;
        } catch { card.is_published = prev; }
      },

      async deleteCard(id: string) {
        if (!confirm(this.t.deleteConfirm)) return;
        const res = await fetch('/api/action-cards/delete', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) { this.showToast(data.error || `API ${res.status}: ${res.statusText}`, 'error'); return; }
        this.cards = this.cards.filter((c: any) => c.id !== id);
        this.showToast(this.t.deleted, 'success');
        setTimeout(() => window.location.reload(), 400);
      },

      showToast(text: string, type: 'success' | 'error') {
        (window as any).retahaToast?.(text, type);
      },
    }));
  });
</script>

<style>
  [x-cloak] { display: none !important; }
