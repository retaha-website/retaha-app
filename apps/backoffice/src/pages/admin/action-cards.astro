  .ac-eve-set-list { display: flex; flex-direction: column; gap: 6px; }
  .ac-eve-set-item {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 10px 12px; background: var(--surface); border: 1px solid var(--ly-line, var(--border-medium, #e0e0e0));
    border-radius: 8px;
  }
