  .ac-eve-set-item-meta strong { font-size: 13px; font-weight: 600; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ac-eve-set-item-meta span:last-child { font-size: 12px; color: var(--ink-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
  .ac-eve-set-badge { font-size: 10px; padding: 2px 7px; border-radius: 4px; background: rgba(20,97,110,.1); color: var(--petrol, #14616E); white-space: nowrap; flex-shrink: 0; }
  .ac-eve-set-take {
    flex-shrink: 0; padding: 5px 10px; font-size: 12px; font-weight: 500; border-radius: 6px; cursor: pointer;
