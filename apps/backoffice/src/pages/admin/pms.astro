---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '../../components/admin/EditorialPageHeader.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServerInstance,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { encryptToken } from '@retaha/auth';
import { MewsClient } from '../../lib/mews/client';
import { getMewsClientForHotel } from '../../lib/mews/factory';
import { getEnv } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const ssrClient = createSupabaseServerInstance(Astro.cookies, Astro.request);

let message: { type: 'success' | 'error'; text: string } | null = null;

// POST: connect / disconnect. Sync läuft client-side via fetch → /api/admin/mews/sync
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'connect') {
    const accessToken = form.get('access_token')?.toString().trim() ?? '';
    const environment = form.get('environment')?.toString();

    if (!accessToken) {
      message = { type: 'error', text: 'Access-Token ist Pflichtfeld.' };
    } else if (environment !== 'demo' && environment !== 'production') {
      message = { type: 'error', text: 'Ungültiges Environment (nur demo/production erlaubt).' };
    } else {
      // 1) ENV für Environment auflösen (ClientToken gehört uns als Integration-Provider,
      //    nicht dem Hotel — kommt aus ENV, nicht aus dem Formular)
      const baseUrl = environment === 'demo'
        ? getEnv('MEWS_API_BASE_URL')
        : 'https://api.mews.com';
      const clientToken = environment === 'demo'
        ? getEnv('MEWS_DEMO_CLIENT_TOKEN')
        : getEnv('MEWS_PROD_CLIENT_TOKEN');

      if (!baseUrl || !clientToken) {
        message = {
          type: 'error',
          text: `${environment === 'demo' ? 'Demo' : 'Production'}-Environment nicht konfiguriert (ENV fehlt).`,
        };
      } else {
        try {
          // 2) Mews-API kontaktieren um Enterprise.Id aufzulösen (validiert gleichzeitig den Token)
          const testClient = new MewsClient({
            clientToken,
            accessToken,
            client: getEnv('MEWS_CLIENT_NAME') ?? 'retaha 1.0.0',
            baseUrl,
          });
          const config = await testClient.getConfiguration();
          const enterpriseId = config.Enterprise?.Id;
          const enterpriseName = config.Enterprise?.Name;

          if (!enterpriseId) {
            message = {
              type: 'error',
              text: 'Mews API antwortete ohne Enterprise.Id — Token möglicherweise ungültig oder Account ohne Enterprise.',
            };
          } else {
            // 3) Default-Currency aus Enterprise.Currencies (IsDefault=true)
            const currencies = (config.Enterprise as any)?.Currencies as
              | Array<{ Currency?: string; IsDefault?: boolean }>
              | undefined;
            const defaultCurrency = currencies?.find(c => c.IsDefault)?.Currency ?? null;

            // 3b) Pricing-Mode aus Enterprise.Pricing — bestimmt ob orders/add
            //     GrossValue oder NetValue als Feldname braucht (Sprint C Phase 3).
            const enterprisePricing = (config.Enterprise as any)?.Pricing as string | undefined;
            const pricingMode = enterprisePricing === 'Gross' || enterprisePricing === 'Net'
              ? enterprisePricing
              : null;

            // 4) Products-Count (für Toggle-Disable in UI). Best-effort — wenn der Call
            //    fehlschlägt, bleibt Counter 0 = Pfad C+ disabled (sicherer Default).
            let productsCount = 0;
            try {
              const productsResp = await testClient.getProducts({ Limitation: { Count: 100 } });
              productsCount = (productsResp.Products ?? []).length;
            } catch {
              // ignored — Products sind optional, Pfad C+ ist eh out-of-scope für Sprint C
            }

            // 5) Token verschlüsseln + Row upserten
            const encryptedToken = await encryptToken(accessToken);
            const { error } = await ssrClient
              .from('mews_integrations')
              .upsert(
                {
                  hotel_id: hotel.id,
                  enterprise_id: enterpriseId,
                  access_token_encrypted: encryptedToken,
                  environment,
                  default_currency: defaultCurrency,
                  pricing_mode: pricingMode,
                  mews_products_count: productsCount,
                  sync_status: 'idle',
                  sync_error_message: null,
                  updated_at: new Date().toISOString(),
                },
                { onConflict: 'hotel_id' },
              );

            if (error) {
              message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
            } else {
              return Astro.redirect(
                `/admin/pms?saved=connected${enterpriseName ? `&hotel=${encodeURIComponent(enterpriseName)}` : ''}`,
              );
            }
          }
        } catch (err) {
          message = {
            type: 'error',
            text: `Mews-Verbindungstest fehlgeschlagen: ${(err as Error).message}`,
          };
        }
      }
    }
  } else if (action === 'save_config') {
    // Service-Mapping + TaxCode + Pricing-Source speichern
    const serviceBreakfast = form.get('service_id_breakfast')?.toString().trim() || null;
    const serviceService = form.get('service_id_service')?.toString().trim() || null;
    const serviceConference = form.get('service_id_conference')?.toString().trim() || null;
    const taxCode = form.get('default_tax_code')?.toString().trim() || null;
    const pricingSource = form.get('pricing_source')?.toString();

    if (pricingSource !== 'retaha' && pricingSource !== 'mews') {
      message = { type: 'error', text: 'Ungültige Preis-Quelle.' };
    } else {
      // Bei Tax-Code-Set: Tax-Rate via taxations/getAll auflösen (Sprint D Phase 1).
      // Wir filtern manuell auf TaxationCode === TaxEnvironmentCode (Mews ignoriert
      // den TaxEnvironmentCodes-Param) und matchen den exakten Code.
      let resolvedTaxRate: number | null = null;
      let taxRateLookupError: string | null = null;
      if (taxCode) {
        try {
          const mews = await getMewsClientForHotel(hotel.id);
          if (mews) {
            const config = await mews.getConfiguration();
            const taxEnv = (config.Enterprise as any)?.TaxEnvironmentCode as string | undefined;
            const taxResp = await mews.getTaxations({
              ...(taxEnv ? { TaxEnvironmentCodes: [taxEnv] } : {}),
              Limitation: { Count: 100 },
            });
            const allRates = (taxResp.TaxRates ?? []) as Array<{
              Code: string;
              TaxationCode?: string;
              Value?: number;
              Strategy?: { Discriminator?: string; Value?: unknown };
            }>;
            const filtered = taxEnv ? allRates.filter(r => r.TaxationCode === taxEnv) : allRates;
            const match = filtered.find(r => r.Code === taxCode);
            if (match) {
              const flat = typeof match.Value === 'number' ? match.Value : null;
              const sv = match.Strategy?.Value as any;
              const nested = sv && typeof sv === 'object' && typeof sv.Value === 'number' ? sv.Value : null;
              const numericRate = flat ?? nested;
              if (typeof numericRate === 'number' && numericRate >= 0 && numericRate < 1) {
                resolvedTaxRate = numericRate;
              } else {
                taxRateLookupError = `Tax-Code "${taxCode}" gefunden, aber kein numerischer Rate-Wert (Strategy=${JSON.stringify(match.Strategy?.Discriminator)})`;
              }
            } else {
              taxRateLookupError = `Tax-Code "${taxCode}" nicht in taxations/getAll für TaxEnvironment "${taxEnv}" gefunden`;
            }
          }
        } catch (err) {
          taxRateLookupError = `taxations/getAll fehlgeschlagen: ${(err as Error).message}`;
        }
      }

      const { error } = await ssrClient
        .from('mews_integrations')
        .update({
          service_id_breakfast: serviceBreakfast,
          service_id_service: serviceService,
          service_id_conference: serviceConference,
          default_tax_code: taxCode,
          default_tax_rate: resolvedTaxRate,
          pricing_source: pricingSource,
          updated_at: new Date().toISOString(),
        })
        .eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
      } else if (taxRateLookupError && taxCode) {
        // Soft-Warning: gespeichert, aber Tax-Rate konnte nicht aufgelöst werden.
        // Bei Net-Hotels wirft pushBookingToMews dann PushSkipped(no_default_tax_rate).
        return Astro.redirect(`/admin/pms?saved=config_warn&warn=${encodeURIComponent(taxRateLookupError)}`);
      } else {
        return Astro.redirect('/admin/pms?saved=config');
      }
    }
  } else if (action === 'disconnect') {
    // Sprint D Phase 6b — Reconnect-Symmetrie: Row NICHT löschen, nur Auth-Felder
    // nullen. Service-Mappings + Tax/Currency/Pricing-Defaults bleiben erhalten.
    // Bei Reconnect setzt der Connect-Handler einfach access_token_encrypted +
    // enterprise_id neu, die Mappings sind sofort wieder da.
    const { error } = await ssrClient
      .from('mews_integrations')
      .update({
        access_token_encrypted: null,
        enterprise_id: null,
        last_sync_at: null,
        sync_status: 'idle',
        sync_error_message: null,
        mews_products_count: 0,
        updated_at: new Date().toISOString(),
      })
      .eq('hotel_id', hotel.id);
    if (error) {
      message = { type: 'error', text: `Trennen fehlgeschlagen: ${error.message}` };
    } else {
      return Astro.redirect('/admin/pms?saved=disconnected');
    }
  }
}

// Flash-Messages aus URL-Param (Post-Redirect-Get)
const savedParam = Astro.url.searchParams.get('saved');
if (savedParam === 'connected' && !message) {
  const hotelName = Astro.url.searchParams.get('hotel');
  message = {
    type: 'success',
    text: hotelName
      ? `Verbunden mit „${hotelName}". Klicke „Jetzt synchronisieren" um Daten zu laden.`
      : 'Mews-Integration verbunden. Klicke „Jetzt synchronisieren" um Daten zu laden.',
  };
} else if (savedParam === 'disconnected' && !message) {
  message = { type: 'success', text: 'Mews-Integration getrennt. Service-Mappings, Tax-Code und Sync-Daten bleiben für einen Reconnect erhalten.' };
} else if (savedParam === 'sync' && !message) {
  message = { type: 'success', text: 'Synchronisation erfolgreich abgeschlossen.' };
} else if (savedParam === 'config' && !message) {
  message = { type: 'success', text: 'Order-Konfiguration gespeichert.' };
} else if (savedParam === 'config_warn' && !message) {
  const warn = Astro.url.searchParams.get('warn') ?? 'Tax-Rate konnte nicht aufgelöst werden.';
  message = { type: 'error', text: `Konfiguration gespeichert mit Warnung — ${warn}. Bei Net-Hotels wird der Mews-Push fehlschlagen bis der Rate-Wert da ist.` };
}

// Integration via SSR-Client (RLS) — access_token_encrypted bewusst NICHT selektiert,
// bleibt server-side, geht nie ans Frontend.
const { data: integration } = await ssrClient
  .from('mews_integrations')
  .select(`
    enterprise_id, environment, last_sync_at, sync_status, sync_error_message, created_at, updated_at,
    pricing_source, default_currency, default_tax_code, default_tax_rate, pricing_mode,
    service_id_breakfast, service_id_service, service_id_conference,
    mews_products_count
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

// Sprint D Phase 6b: integration.enterprise_id NULL = disconnected, Mappings
// bleiben erhalten in der Row. UI behandelt isConnected statt rohen integration-Existenz.
const isConnected = integration?.enterprise_id != null;

// Counts via Service-Role (rooms/stays/guests-RLS uneinheitlich) — hotel.id-Filter
// kommt aus authentifizierter Session, also sicher.
let counts: { rooms: number; stays: number; guests: number } | null = null;
if (isConnected) {
  const adminClient = createSupabaseServiceRoleInstance();
  const [roomsRes, staysRes, guestsRes] = await Promise.all([
    adminClient.from('rooms').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
    adminClient.from('stays').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
    adminClient.from('guests').select('*', { count: 'exact', head: true }).eq('hotel_id', hotel.id),
  ]);
  counts = {
    rooms: roomsRes.count ?? 0,
    stays: staysRes.count ?? 0,
    guests: guestsRes.count ?? 0,
  };
}

// Services live aus Mews für die Mapping-Dropdowns. Best-effort —
// bei Fehler bleibt die Liste leer + Hinweis im UI.
let orderableServices: Array<{ Id: string; Name: string; IsActive: boolean }> = [];
let servicesError: string | null = null;
// Sprint E1 Phase 2 — Tax-Code-Dropdown statt freier Input.
let taxRateOptions: Array<{ code: string; rate: number; label: string }> = [];
let taxEnvironmentCode: string | null = null;
if (isConnected) {
  try {
    const mews = await getMewsClientForHotel(hotel.id);
    if (mews) {
      const resp = await mews.getServices({ Limitation: { Count: 100 } });
      // Sprint D Phase 6c: nur Orderable+Active zeigen. Inaktive Services im
      // Demo-Hotel sind häufig Test-Reste — Mews lehnt orders/add bei ihnen ab
      // mit "Invalid ServiceId" (siehe Sprint-C-Verifikation §3 Befund).
      orderableServices = (resp.Services ?? [])
        .filter(s => s.Type === 'Orderable' && s.IsActive !== false)
        .map(s => ({
          Id: s.Id,
          Name: (s.Name as string) || (s.Names && Object.values(s.Names)[0]) || s.Id,
          IsActive: true,
        }))
        .sort((a, b) => a.Name.localeCompare(b.Name));

      // Tax-Rates für das Enterprise — Filter auf TaxationCode === TaxEnvironment
      // (Mews ignoriert TaxEnvironmentCodes-Param im Request, manuell filtern).
      try {
        const config = await mews.getConfiguration();
        taxEnvironmentCode = (config.Enterprise as any)?.TaxEnvironmentCode ?? null;
        if (taxEnvironmentCode) {
          const taxResp = await mews.getTaxations({
            TaxEnvironmentCodes: [taxEnvironmentCode],
            Limitation: { Count: 100 },
          });
          const allRates = (taxResp.TaxRates ?? []) as Array<{
            Code: string;
            TaxationCode?: string;
            Value?: number;
            Strategy?: { Discriminator?: string; Value?: unknown };
          }>;
          taxRateOptions = allRates
            .filter(tr => tr.TaxationCode === taxEnvironmentCode)
            .map(tr => {
              const flat = typeof tr.Value === 'number' ? tr.Value : null;
              const sv = tr.Strategy?.Value as any;
              const nested = sv && typeof sv === 'object' && typeof sv.Value === 'number' ? sv.Value : null;
              const rate = flat ?? nested ?? 0;
              const pct = (rate * 100).toFixed(rate < 0.1 ? 1 : 0);
              return { code: tr.Code, rate, label: `${pct}% (${tr.Code})` };
            })
            .filter(opt => typeof opt.rate === 'number' && opt.rate >= 0 && opt.rate < 1)
            .sort((a, b) => b.rate - a.rate);  // höchster Rate zuerst (Standard meist 20%)
        }
      } catch {
        // Tax-Lookup-Fehler nicht-fatal — Dropdown bleibt leer, Fallback-Input greift
      }
    }
  } catch (err) {
    servicesError = (err as Error).message;
  }
}

const productsCount = integration?.mews_products_count ?? 0;
const productsAvailable = productsCount > 0;
const pricingMewsLabelClass = productsAvailable
  ? 'flex items-start gap-3 cursor-pointer'
  : 'flex items-start gap-3 opacity-50 cursor-not-allowed';

type ServiceMappingField = { name: string; label: string; current: string | null };
// Sprint E1 Phase 3 — nur Frühstück-Mapping zeigen. Service + Konferenz
// werden nicht nach Mews gepushed (Sprint-C-Scope-Korrektur §14):
// Service ist meist kostenfrei, Konferenz B2B-Vertrieb. Code-Side bleibt
// (graceful skip wenn service_id_* NULL), UI ist nur klarer.
const serviceMappingFields: ServiceMappingField[] = integration
  ? [
      { name: 'service_id_breakfast', label: 'Frühstück-Buchungen', current: integration.service_id_breakfast ?? null },
    ]
  : [];

const lastSyncLabel = integration?.last_sync_at
  ? new Date(integration.last_sync_at).toLocaleString('de-DE', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;

const syncStatusBadge: Record<string, { label: string; classes: string }> = {
  idle: { label: 'Bereit', classes: 'bg-anthrazit/[0.06] text-anthrazit/70' },
  syncing: { label: 'Läuft…', classes: 'bg-pink-shock/10 text-pink-shock' },
  error: { label: 'Fehler', classes: 'bg-red-50 text-red-700' },
};
const statusKey = integration?.sync_status ?? 'idle';
const statusBadge = syncStatusBadge[statusKey] ?? syncStatusBadge.idle;
---

<AdminLayout title="PMS-Integration" hotel={hotel} user={{ email: user.email }}>

  <EditorialPageHeader
    sectionNumber="30"
    sectionLabel="Integrationen"
    headlineLight="PMS-"
    headlineBold="Integration"
    subtitle="Verbinde dein Mews-Hotel mit retaha. Reservationen, Zimmer und Gäste-Daten werden automatisch synchronisiert."
  />

  {message && (
    <div class={`mb-8 px-4 py-3 text-sm border-l-4 ${
      message.type === 'success'
        ? 'bg-green-50 border-green-700 text-green-800'
        : 'bg-red-50 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  {isConnected && integration ? (
    <div class="space-y-10 max-w-3xl">

      <!-- Status-Block -->
      <section class="border-t border-b border-anthrazit/[0.12] py-8">
        <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
          <p class="eyebrow text-pink-shock m-0">— Mews verbunden —</p>
          <span class={`text-xs uppercase tracking-[0.12em] px-2.5 py-1 ${statusBadge.classes}`}>
            {statusBadge.label}
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6">
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Enterprise-ID</p>
            <p class="text-sm font-mono text-anthrazit break-all">{integration.enterprise_id}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Environment</p>
            <p class="text-base text-anthrazit capitalize">{integration.environment}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Access-Token</p>
            <p class="text-base font-mono text-anthrazit">••••••••••••</p>
            <p class="text-xs italic text-anthrazit/55 mt-1">verschlüsselt (AES-256-GCM)</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Letzter Sync</p>
            <p class="text-base text-anthrazit">{lastSyncLabel ?? 'noch nie'}</p>
          </div>
        </div>

        {integration.sync_status === 'error' && integration.sync_error_message && (
          <div class="mt-6 px-4 py-3 text-sm bg-red-50 border-l-4 border-red-700 text-red-800">
            <p class="font-semibold mb-1">Letzter Sync-Fehler:</p>
            <p class="font-mono text-xs break-all">{integration.sync_error_message}</p>
          </div>
        )}
      </section>

      <!-- Counts -->
      {counts && (
        <section>
          <p class="eyebrow text-anthrazit/55 mb-4">— Bisher synchronisiert —</p>
          <div class="grid grid-cols-3 gap-4">
            <div class="border border-stein p-6">
              <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Zimmer</p>
              <p class="text-3xl font-light text-anthrazit m-0">{counts.rooms}</p>
            </div>
            <div class="border border-stein p-6">
              <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Aufenthalte</p>
              <p class="text-3xl font-light text-anthrazit m-0">{counts.stays}</p>
            </div>
            <div class="border border-stein p-6">
              <p class="text-xs uppercase tracking-[0.12em] text-anthrazit/55 mb-2">Gäste</p>
              <p class="text-3xl font-light text-anthrazit m-0">{counts.guests}</p>
            </div>
          </div>
        </section>
      )}

      <!-- Order-Konfiguration (Sprint C — Charge-to-Room) -->
      <section>
        <p class="eyebrow text-pink-shock mb-4">— Order-Konfiguration —</p>
        <p class="text-sm text-anthrazit/70 mb-6 max-w-2xl leading-relaxed">
          Wenn der Hotelier eine Buchung bestätigt, schickt retaha sie als Order
          auf das Mews-Gast-Konto („Charge to Room"). Damit das funktioniert,
          ordne pro Buchungstyp einen Mews-Service zu und setze deinen Tax-Code.
        </p>

        {servicesError && (
          <div class="mb-6 px-4 py-3 text-sm bg-amber-50 border-l-4 border-amber-500 text-amber-800">
            <strong>Services konnten nicht geladen werden:</strong> {servicesError}
            <br />
            Trotzdem speicherbar — Dropdowns sind leer. Bei nächstem Page-Load nochmal probieren.
          </div>
        )}

        <form method="POST" class="space-y-6 max-w-2xl">
          <input type="hidden" name="_action" value="save_config" />

          <!-- Service-Mapping (Sprint E1 Phase 3 — nur Frühstück) -->
          <p class="text-xs italic text-anthrazit/55 mb-4 max-w-xl leading-relaxed">
            Charge-to-Room ist aktuell <strong>nur für Frühstück</strong> aktiv.
            Service-Anfragen und Konferenz-Buchungen bleiben in retaha (Service ist meist
            kostenfrei, Konferenz läuft über B2B-Vertrieb).
          </p>
          <div class="space-y-5">
            {serviceMappingFields.map(field => (
              <label class="block">
                <span class="eyebrow text-anthrazit/55 block mb-2">— Mews-Service für {field.label} —</span>
                <select name={field.name} class="bauhaus-input">
                  <option value="">— nicht zugeordnet —</option>
                  {orderableServices.map(s => (
                    <option value={s.Id} selected={field.current === s.Id}>
                      {s.Name}{!s.IsActive ? ' (inaktiv)' : ''}
                    </option>
                  ))}
                </select>
              </label>
            ))}
          </div>

          <!-- Tax-Code (Sprint E1 Phase 2 — Dropdown wenn Liste da, sonst Input-Fallback) -->
          <label class="block">
            <span class="eyebrow text-anthrazit/55 block mb-2">— Tax-Code (Default) —</span>
            {taxRateOptions.length > 0 ? (
              <select
                name="default_tax_code"
                class="bauhaus-input bauhaus-input--mono"
              >
                <option value="">— bitte wählen —</option>
                {taxRateOptions.map(opt => (
                  <option value={opt.code} selected={integration.default_tax_code === opt.code}>
                    {opt.label}
                  </option>
                ))}
              </select>
            ) : (
              <input
                type="text"
                name="default_tax_code"
                value={integration.default_tax_code ?? ''}
                placeholder="z.B. UK-2022-20%, DE-2020-1-S, …"
                autocomplete="off"
                spellcheck="false"
                class="bauhaus-input bauhaus-input--mono"
              />
            )}
            <span class="text-xs italic text-anthrazit/55 mt-2 block">
              {taxRateOptions.length > 0
                ? <>Auswahl gefiltert auf Tax-Environment <span class="font-mono">{taxEnvironmentCode}</span>. Auswahl löst auch den numerischen Rate-Wert auf (für Net-Pricing-Hotels).</>
                : <>Tax-Codes aus Mews konnten nicht geladen werden — bitte manuell eintragen. Tax-Environment: <span class="font-mono">{taxEnvironmentCode ?? '?'}</span></>}
              {integration.default_tax_rate != null && (
                <>
                  <br />Aktueller Rate: <span class="font-mono">{(Number(integration.default_tax_rate) * 100).toFixed(2)}%</span>
                </>
              )}
            </span>
          </label>

          <!-- Currency + Pricing-Mode (read-only Anzeige) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <span class="eyebrow text-anthrazit/55 block mb-2">— Default-Currency —</span>
              <p class="text-base font-mono text-anthrazit m-0">
                {integration.default_currency ?? '(nicht gesetzt)'}
              </p>
              <span class="text-xs italic text-anthrazit/55 mt-1 block">Aus configuration.Enterprise.Currencies (IsDefault=true).</span>
            </div>
            <div>
              <span class="eyebrow text-anthrazit/55 block mb-2">— Pricing-Mode —</span>
              <p class="text-base font-mono text-anthrazit m-0">
                {integration.pricing_mode ?? '(nicht gesetzt)'}
              </p>
              <span class="text-xs italic text-anthrazit/55 mt-1 block">
                Aus Enterprise.Pricing. Gross = orders/add nutzt UnitAmount.GrossValue; Net = NetValue.
              </span>
            </div>
          </div>

          <!-- Pricing-Source-Toggle -->
          <fieldset class="border-t border-anthrazit/[0.12] pt-6">
            <legend class="eyebrow text-anthrazit/55 mb-3">— Preis-Quelle —</legend>
            <div class="space-y-3">
              <label class="flex items-start gap-3 cursor-pointer">
                <input
                  type="radio"
                  name="pricing_source"
                  value="retaha"
                  checked={integration.pricing_source !== 'mews'}
                  class="mt-1"
                />
                <span>
                  <span class="block text-sm font-medium text-anthrazit">Preise in retaha pflegen</span>
                  <span class="block text-xs text-anthrazit/55 mt-0.5">
                    Hotelier pflegt Preise direkt in den retaha-Modulen. Push als Custom-Items.
                  </span>
                </span>
              </label>

              <label class={pricingMewsLabelClass}>
                <input
                  type="radio"
                  name="pricing_source"
                  value="mews"
                  checked={integration.pricing_source === 'mews'}
                  disabled={!productsAvailable}
                  class="mt-1"
                />
                <span>
                  <span class="block text-sm font-medium text-anthrazit">
                    Preise aus Mews-Products abrufen
                    <span class="text-xs font-mono text-anthrazit/55 ml-2">({productsCount} Products in Mews)</span>
                  </span>
                  <span class="block text-xs text-anthrazit/55 mt-0.5">
                    {productsAvailable
                      ? 'Verfügbar. Hinweis: Pfad C+ ist noch nicht implementiert (Backlog) — auswählbar, aber wird beim Push einen Fehler werfen.'
                      : 'Nicht verfügbar — dein Mews-Hotel hat keine Products angelegt. Lege Products in Mews an und verbinde neu.'}
                  </span>
                </span>
              </label>
            </div>
          </fieldset>

          <div class="pt-2">
            <button type="submit" class="bauhaus-button bauhaus-button--primary">
              Order-Konfiguration speichern
            </button>
          </div>
        </form>
      </section>

      <!-- Aktionen -->
      <section class="flex gap-6 flex-wrap items-center pt-2">
        <button
          id="sync-button"
          type="button"
          class="bauhaus-button bauhaus-button--primary"
        >
          Jetzt synchronisieren
        </button>
        <form
          method="POST"
          id="disconnect-form"
          class="m-0"
        >
          <input type="hidden" name="_action" value="disconnect" />
          <button
            type="submit"
            class="bauhaus-button bauhaus-button--ghost"
          >
            Verbindung trennen
          </button>
        </form>
      </section>

      <p class="text-xs italic text-anthrazit/55 max-w-xl leading-relaxed">
        Sync läuft über getMewsClientForHotel(hotel_id) — der Access-Token wird beim
        Sync server-seitig entschlüsselt und nie ans Frontend gesendet. Synchronisiert
        werden Reservationen der letzten 30 Tage (rolling window).
      </p>
    </div>

    <script is:inline>
      (function () {
        const syncBtn = document.getElementById('sync-button');
        const disconnectForm = document.getElementById('disconnect-form');

        if (syncBtn) {
          syncBtn.addEventListener('click', async () => {
            const originalText = syncBtn.textContent;
            syncBtn.disabled = true;
            syncBtn.textContent = 'Synchronisiere…';
            try {
              const resp = await fetch('/api/admin/mews/sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ windowDays: 30 }),
              });
              const data = await resp.json();
              if (data.ok) {
                window.location.href = '/admin/pms?saved=sync';
              } else {
                alert('Sync fehlgeschlagen: ' + (data.error || 'unbekannter Fehler'));
                syncBtn.disabled = false;
                syncBtn.textContent = originalText;
              }
            } catch (err) {
              alert('Netzwerk-Fehler: ' + (err && err.message ? err.message : err));
              syncBtn.disabled = false;
              syncBtn.textContent = originalText;
            }
          });
        }

        if (disconnectForm) {
          disconnectForm.addEventListener('submit', (e) => {
            if (!confirm('Mews-Verbindung wirklich trennen? Bisher synchronisierte Daten bleiben erhalten, der Sync stoppt aber sofort.')) {
              e.preventDefault();
            }
          });
        }
      })();
    </script>
  ) : (
    <div class="max-w-2xl">
      <p class="text-anthrazit/80 leading-relaxed text-base mb-6">
        Verbinde dein Mews-Property mit retaha. Du brauchst nur deinen
        <strong>Access-Token</strong> für die Connector-API — die Enterprise-ID lesen
        wir automatisch aus der Mews-API aus.
      </p>

      <!-- Sprint E1 Phase 8 — Mews-Doku-Hilfe-Box -->
      <aside class="mb-10 p-5 border-l-4 border-pink-shock/60 bg-anthrazit/5">
        <p class="eyebrow text-anthrazit/55 mb-2">— Token-Generierung —</p>
        <p class="text-sm text-anthrazit/80 leading-relaxed mb-3">
          So findest du deinen Access-Token in Mews Commander:
        </p>
        <ol class="text-sm text-anthrazit/80 leading-relaxed list-decimal pl-5 space-y-1 mb-3">
          <li>Mews Commander öffnen → <strong>Marketplace</strong></li>
          <li>Eintrag „retaha" suchen und <strong>Connect</strong> klicken</li>
          <li>Access-Token kopieren und hier einfügen</li>
        </ol>
        <p class="text-xs text-anthrazit/55 italic leading-relaxed">
          Falls retaha noch nicht im Marketplace ist: Mews-Support kontaktieren
          („Connector-API-Integration mit retaha") oder die offizielle
          <a href="https://mews-systems.gitbook.io/connector-api/" target="_blank" rel="noopener" class="underline hover:text-pink-shock">
            Connector-API-Doku
          </a>
          öffnen.
        </p>
      </aside>

      <form method="POST" class="space-y-8">
        <input type="hidden" name="_action" value="connect" />

        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-2">— Access-Token —</span>
          <input
            type="password"
            name="access_token"
            placeholder="••••••••••••"
            required
            autocomplete="off"
            spellcheck="false"
            class="bauhaus-input bauhaus-input--mono"
          />
          <span class="text-xs italic text-anthrazit/55 mt-2 block">
            Wird verschlüsselt gespeichert (AES-256-GCM) — niemals im Klartext in der Datenbank.
          </span>
        </label>

        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-2">— Environment —</span>
          <select
            name="environment"
            required
            class="bauhaus-input"
          >
            <option value="demo">Demo (api.mews-demo.com)</option>
            <option value="production">Production (api.mews.com)</option>
          </select>
          <span class="text-xs italic text-anthrazit/55 mt-2 block">
            Für erste Tests: Demo. Echte Reservationen: Production.
          </span>
        </label>

        <div class="pt-4">
          <button type="submit" class="bauhaus-button bauhaus-button--primary">
            Verbinden
          </button>
        </div>
      </form>
    </div>
  )}

</AdminLayout>
