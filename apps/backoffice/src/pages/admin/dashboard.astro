---
import AdminLayout from '../../components/AdminLayout.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { t } from '../../i18n/helpers';

const userLocale = Astro.locals.locale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
// User authenticated aber kein Hotel → Onboarding-Flow (statt Login-Error-Rückwurf)
if (!hotel) return Astro.redirect('/onboarding/locale');

// Get settings + counts
const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: settings } = await client
  .from('hotel_settings')
  .select('features')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const featuresActive = settings?.features
  ? Object.values(settings.features).filter(v => v === true).length
  : 0;
const featuresTotal = settings?.features ? Object.keys(settings.features).length : 0;

// Sprint E7 Phase 5 — Action-Card-Count aus hotel_action_cards (war vorher
// hotel_settings.recommendations.length, JSONB ist deprecated).
const { count: recCount } = await client
  .from('hotel_action_cards')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id);

const { count: stayCount } = await client
  .from('stays')
  .select('*', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id)
  .eq('is_active', true);

// Sprint Wallet Modul E — Wiederkehrer diese Woche
const sevenDaysAgo = new Date(Date.now() - 7 * 86_400_000).toISOString();
const { data: returningRows } = await client
  .from('stays')
  .select('id, wallet_pass_id, wallet_passes:wallet_pass_id!inner(visit_count)')
  .eq('hotel_id', hotel.id)
  .gte('check_in', sevenDaysAgo)
  .not('wallet_pass_id', 'is', null);
const returningCount = (returningRows ?? []).filter((r: any) => {
  const wp = Array.isArray(r.wallet_passes) ? r.wallet_passes[0] : r.wallet_passes;
  return wp && wp.visit_count > 1;
}).length;
---

<AdminLayout title="Übersicht" hotel={hotel} user={user} activeTab="overview">
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber={t('pages.dashboard.section_number', userLocale)}
      sectionLabel={t('pages.dashboard.section_label', userLocale)}
      headlineLight={t('pages.dashboard.headline_light', userLocale)}
      headlineBold={t('pages.dashboard.headline_bold', userLocale)}
      subtitle={t('pages.dashboard.subtitle', userLocale)}
    />
  </div>

  <div class="grid grid-cols-4 gap-4 mb-10">
    <a href="/admin/action-cards" class="bg-white border border-stein p-6 hover:border-pink-shock transition group">
      <p class="eyebrow text-anthrazit/55 mb-3">Hero-Karten</p>
      <p class="text-3xl font-light mb-1">{recCount ?? 0}</p>
      <p class="text-xs text-anthrazit/40 group-hover:text-pink-shock transition">bearbeiten →</p>
    </a>
    <a href="/features" class="bg-white border border-stein p-6 hover:border-pink-shock transition group">
      <p class="eyebrow text-anthrazit/55 mb-3">Funktionen aktiv</p>
      <p class="text-3xl font-light mb-1">{featuresActive} <span class="text-base text-anthrazit/40">/ {featuresTotal}</span></p>
      <p class="text-xs text-anthrazit/40 group-hover:text-pink-shock transition">verwalten →</p>
    </a>
    <a href="/admin/bookings" class="bg-white border border-stein p-6 hover:border-pink-shock transition group">
      <p class="eyebrow text-anthrazit/55 mb-3">Aktive Gäste</p>
      <p class="text-3xl font-light mb-1">{stayCount ?? 0}</p>
      <p class="text-xs text-anthrazit/40 group-hover:text-pink-shock transition">Buchungen →</p>
    </a>
    <a href="/admin/checkins" class="bg-white border border-stein p-6 hover:border-pink-shock transition group" style="border-left: 3px solid var(--theme-burgund);">
      <p class="eyebrow text-anthrazit/55 mb-3">Wiederkehrer · 7 Tage</p>
      <p class="text-3xl font-light mb-1">{returningCount}</p>
      <p class="text-xs text-anthrazit/40 group-hover:text-pink-shock transition">★ Wallet-Match</p>
    </a>
  </div>

  <section class="bg-white border border-stein p-8">
    <p class="eyebrow text-pink-shock mb-3 themed-eyebrow-flank">Erster Schritt</p>
    <h2 class="text-xl font-medium mb-2">Schau dir deine Gast-Ansicht an</h2>
    <p class="text-sm text-anthrazit/70 mb-6 leading-relaxed max-w-xl">
      So sieht das, was deine Gäste sehen, wenn sie den NFC-Tag im Zimmer scannen.
      Änderungen, die du hier im Backoffice machst, werden dort sofort sichtbar.
    </p>

    <a
      href="/g/00d5924a16934db28f77a3f570194e24"
      target="_blank"
      class="bauhaus-button bauhaus-button--primary"
    >
      Gast-Ansicht öffnen (Hannah, Zimmer 12) →
    </a>
  </section>
</AdminLayout>
