---
import Layout from '../../layouts/Layout.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import BauhausToggle from '@retaha/ui/components/admin/BauhausToggle.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { loadBreakfastItems } from '@retaha/db';
import { mergeAndTranslate, asLanguageCode } from '@retaha/i18n';
import { getMewsClientForHotel } from '../../lib/mews/factory';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const supabase = createSupabaseServiceRoleInstance();

// Hotel default language for i18n save-hook
const { data: hotelLangRow } = await supabase
  .from('hotels')
  .select('default_language')
  .eq('id', hotel.id)
  .maybeSingle();
const hotelDefaultLang = asLanguageCode((hotelLangRow?.default_language as string | undefined) ?? 'de');

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString() || 'save_settings';

  // ── Mews import ──────────────────────────────────────────────────────────────
  if (action === 'mews_import') {
    const mews = await getMewsClientForHotel(hotel.id);
    if (!mews) {
      message = { type: 'error', text: 'Mews-Integration nicht verbunden. Zuerst unter PMS verbinden.' };
    } else {
      try {
        const resp = await mews.getProducts({ Limitation: { Count: 100 } });
        const products = resp.Products ?? [];
        if (products.length === 0) {
          message = { type: 'error', text: 'Mews hat keine Produkte zurückgegeben.' };
        } else {
          let imported = 0;
          let skipped = 0;
          for (const p of products) {
            const mewsId = p.Id as string | undefined;
            if (!mewsId) continue;

            const names = (p.Names ?? p.ExternalNames ?? {}) as Record<string, string>;
            const descs = (p.Descriptions ?? {}) as Record<string, string>;
            const priceObj = (p.Price ?? p.DefaultPrice ?? {}) as Record<string, unknown>;
            const priceValue = (priceObj.Value ?? priceObj.GrossValue ?? priceObj.NetValue ?? 0) as number;

            const payload: Record<string, unknown> = {
              hotel_id: hotel.id,
              mews_product_id: mewsId,
              name_de: names['de-DE'] || names['en-US'] || names[Object.keys(names)[0]] || mewsId,
              name_en: names['en-US'] || names['en-GB'] || null,
              name_fr: names['fr-FR'] || null,
              name_es: names['es-ES'] || null,
              description_de: descs['de-DE'] || descs['en-US'] || null,
              description_en: descs['en-US'] || descs['en-GB'] || null,
              description_fr: descs['fr-FR'] || null,
              description_es: descs['es-ES'] || null,
              price_cents: Math.round(priceValue * 100),
              is_active: (p.IsActive as boolean | undefined) !== false,
              display_order: 0,
              updated_at: new Date().toISOString(),
            };

            const { error } = await supabase
              .from('breakfast_items')
              .upsert(payload, { onConflict: 'hotel_id,mews_product_id' });

            if (error) {
              skipped++;
            } else {
              imported++;
            }
          }
          message = { type: 'success', text: `Mews-Import: ${imported} Produkt${imported === 1 ? '' : 'e'} importiert${skipped > 0 ? `, ${skipped} übersprungen` : ''}.` };
        }
      } catch (err) {
        message = { type: 'error', text: `Mews-Import fehlgeschlagen: ${(err as Error).message}` };
      }
    }
  }

  // ── Settings speichern ───────────────────────────────────────────────────────
  else {
    const startTime         = form.get('breakfast_start_time')?.toString() || '07:30';
    const endTime           = form.get('breakfast_end_time')?.toString()   || '10:30';
    const slotMinutes       = parseInt(form.get('breakfast_slot_minutes')?.toString() || '30') || 30;
    const locationDe        = form.get('location_de')?.toString().trim() || null;
    const includedDe        = form.get('included_de')?.toString().trim() || null;
    const priceRaw          = form.get('breakfast_price_cents')?.toString().trim();
    const priceCents        = priceRaw ? parseInt(priceRaw) : null;
    const roomServiceEnabled = form.getAll('breakfast_room_service_enabled').includes('on');
    const roomServiceFeeRaw  = form.get('breakfast_room_service_fee_cents')?.toString().trim();
    const roomServiceFeeCents = roomServiceFeeRaw ? (parseInt(roomServiceFeeRaw) || 0) : 0;
    const breakfastModuleOn  = form.getAll('features_breakfast').includes('on');

    // Read current i18n values + features so we can merge
    const { data: current } = await supabase
      .from('hotel_settings')
      .select('breakfast_location_i18n, breakfast_included_i18n, features')
      .eq('hotel_id', hotel.id)
      .maybeSingle();

    const currentFeatures = ((current?.features as Record<string, unknown>) ?? {});
    const newFeatures = { ...currentFeatures, breakfast: breakfastModuleOn };

    // Auto-translate location + included via @retaha/i18n (parallel)
    const [locResult, incResult] = await Promise.all([
      mergeAndTranslate(
        current?.breakfast_location_i18n as any,
        locationDe ?? '',
        hotelDefaultLang,
        { logLabel: 'hotel_settings.breakfast_location' },
      ),
      mergeAndTranslate(
        current?.breakfast_included_i18n as any,
        includedDe ?? '',
        hotelDefaultLang,
        { logLabel: 'hotel_settings.breakfast_included' },
      ),
    ]);

    const { error } = await supabase
      .from('hotel_settings')
      .upsert({
        hotel_id:                         hotel.id,
        features:                         newFeatures,
        breakfast_start_time:             startTime,
        breakfast_end_time:               endTime,
        breakfast_slot_minutes:           slotMinutes,
        breakfast_location_i18n:          Object.keys(locResult.i18n).length > 0 ? locResult.i18n : null,
        breakfast_included_i18n:          Object.keys(incResult.i18n).length > 0 ? incResult.i18n : null,
        breakfast_price_cents:            priceCents,
        breakfast_room_service_enabled:   roomServiceEnabled,
        breakfast_room_service_fee_cents: roomServiceFeeCents,
        updated_at:                       new Date().toISOString(),
      }, { onConflict: 'hotel_id' });

    if (error) {
      message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
    } else {
      message = { type: 'success', text: 'Frühstücks-Einstellungen gespeichert.' };
    }
  }
}

const { data: settings } = await supabase
  .from('hotel_settings')
  .select(`
    features,
    breakfast_start_time, breakfast_end_time, breakfast_slot_minutes,
    breakfast_location_i18n, breakfast_included_i18n,
    breakfast_price_cents,
    breakfast_room_service_enabled, breakfast_room_service_fee_cents
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || ({} as Record<string, any>);
const features        = ((s.features as Record<string, unknown>) ?? {});
const breakfastOn     = features.breakfast !== false;
const startTime       = ((s.breakfast_start_time as string | undefined) || '07:30').substring(0, 5);
const endTime         = ((s.breakfast_end_time   as string | undefined) || '10:30').substring(0, 5);
const slotMinutes     = (s.breakfast_slot_minutes as number | undefined) || 30;
const locationDe      = (s.breakfast_location_i18n as any)?.de?.value || '';
const includedDe      = (s.breakfast_included_i18n as any)?.de?.value || '';
const priceCents      = (s.breakfast_price_cents   as number | null | undefined) ?? null;
const roomServiceOn   = (s.breakfast_room_service_enabled as boolean | undefined) === true;
const roomServiceFee  = (s.breakfast_room_service_fee_cents as number | undefined) || 0;

const items = await loadBreakfastItems(hotel.id);

const itemsByCategory: Record<string, typeof items> = {};
items.forEach(item => {
  const cat = item.category || 'Ohne Kategorie';
  if (!itemsByCategory[cat]) itemsByCategory[cat] = [];
  itemsByCategory[cat].push(item);
});

// Check Mews integration for import button
const { data: mewsRow } = await supabase
  .from('mews_integrations')
  .select('mews_products_count')
  .eq('hotel_id', hotel.id)
  .maybeSingle();
const hasMews = !!mewsRow;

const url = new URL(Astro.request.url);
if (url.searchParams.get('deleted') === '1' && !message) {
  message = { type: 'success', text: 'Speise gelöscht.' };
}
---

<Layout title="Frühstück" activeTab="backoffice">
  <EditorialPageHeader
    sectionNumber="02"
    sectionLabel="Frühstücksmodul"
    headlineLight="Frühstücks-"
    headlineBold="Einstellungen."
    subtitle="Zeiten, Ort, Preis, Zimmerservice und Speisekarte — alles auf einer Seite."
  />

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <form method="POST" class="space-y-8">

    <!-- Modul Ein/Aus -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-4">
        <p class="eyebrow text-pink-shock mb-1">— Modul —</p>
        <h2 class="text-xl font-medium">Frühstücksmodul aktiv?</h2>
        <p class="text-xs text-anthrazit/55 mt-1">Schaltet das gesamte Frühstücks-Feature in der Gäste-App ein oder aus.</p>
      </div>
      <label for="breakfast-module-toggle" class="flex items-center gap-5 py-[26px] cursor-pointer">
        <span
          data-toggle-accent
          class="w-1.5 h-1.5 rounded-full bg-anthrazit/30 transition-colors duration-200 ease-in-out flex-shrink-0 pointer-events-none"
          aria-hidden="true"
        ></span>
        <div class="flex-1 min-w-0">
          <p class="text-[15px] font-medium text-anthrazit leading-tight tracking-tight mb-1.5">Frühstück in Gäste-App sichtbar</p>
          <p class="text-[13px] italic text-anthrazit/55 leading-[1.55]" id="module-status">
            {breakfastOn ? 'Frühstück ist aktiv — Gäste sehen das Modul' : 'Frühstück ist deaktiviert — Modul wird ausgeblendet'}
          </p>
        </div>
        <BauhausToggle id="breakfast-module-toggle" name="features_breakfast" checked={breakfastOn} label="Frühstück aktiv" />
      </label>
      <script is:inline>
        const modToggle = document.getElementById('breakfast-module-toggle');
        const modStatus = document.getElementById('module-status');
        if (modToggle && modStatus) {
          modToggle.addEventListener('change', () => {
            modStatus.textContent = modToggle.checked
              ? 'Frühstück ist aktiv — Gäste sehen das Modul'
              : 'Frühstück ist deaktiviert — Modul wird ausgeblendet';
          });
        }
      </script>
    </section>

    <!-- Zeiten -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Zeiten —</p>
        <h2 class="text-xl font-medium">Wann gibt es Frühstück?</h2>
        <p class="text-xs text-anthrazit/55 mt-1">Bestimmt die buchbaren Slots in der Gäste-App.</p>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Beginn</span>
          <input
            type="time"
            name="breakfast_start_time"
            value={startTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit"
          />
        </label>
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Ende</span>
          <input
            type="time"
            name="breakfast_end_time"
            value={endTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit"
          />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Slot-Länge (Min)</span>
          <input
            type="number"
            name="breakfast_slot_minutes"
            value={slotMinutes}
            min="5" max="120" step="5"
            class="bauhaus-input"
          />
        </label>
      </div>
      <p class="text-[10px] text-anthrazit/40 mt-3 italic">
        Slot-Länge bestimmt die Abstände der Buchungszeiten (z.B. 30 = 07:30, 08:00, 08:30, …).
      </p>
    </section>

    <!-- Ort -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Ort —</p>
        <h2 class="text-xl font-medium">Wo wird gefrühstückt?</h2>
        <p class="text-xs text-anthrazit/55 mt-1">Z.B. „im Wintergarten" — wird zusammen mit der Begrüßung gezeigt. Wird automatisch übersetzt.</p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Deutsch</span>
        <input
          type="text"
          name="location_de"
          value={locationDe}
          placeholder="z.B. im Wintergarten"
          class="bauhaus-input"
        />
      </label>
    </section>

    <!-- Inklusiv-Text -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Was inkludiert ist —</p>
        <h2 class="text-xl font-medium">Was bekommen deine Gäste?</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Z.B. „Frische Backwaren, regionaler Honig, …" — wird im Info-Modus prominent gezeigt. Wird automatisch übersetzt.
        </p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Deutsch</span>
        <textarea
          name="included_de"
          rows="3"
          placeholder="z.B. Frische Backwaren, regionaler Honig, Bio-Eier, …"
          class="bauhaus-textarea"
        >{includedDe}</textarea>
      </label>
    </section>

    <!-- Pauschalpreis -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Preis —</p>
        <h2 class="text-xl font-medium">Pauschalpreis pro Person</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Wird in der Gäste-App angezeigt und als Fallback für Mews-Buchungen verwendet.
          Leer lassen wenn kein fester Preis gewünscht.
        </p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Preis in Cent (z.B. 1500 = €15,00)</span>
        <input
          type="number"
          name="breakfast_price_cents"
          value={priceCents !== null ? priceCents : ''}
          min="0" step="50"
          placeholder="leer = kein Preis anzeigen"
          class="bauhaus-input"
        />
      </label>
    </section>

    <!-- Room-Service -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Zimmerservice —</p>
        <h2 class="text-xl font-medium">Frühstück aufs Zimmer anbieten?</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Wenn aktiv, können Gäste zwischen „Im Frühstücksraum" und „Aufs Zimmer" wählen.
        </p>
      </div>

      <label for="room-service-toggle" class="flex items-center gap-5 py-[26px] cursor-pointer">
        <span
          data-toggle-accent
          class="w-1.5 h-1.5 rounded-full bg-anthrazit/30 transition-colors duration-200 ease-in-out flex-shrink-0 pointer-events-none"
          aria-hidden="true"
        ></span>
        <div class="flex-1 min-w-0">
          <p class="text-[15px] font-medium text-anthrazit leading-tight tracking-tight mb-1.5">Room-Service aktiv</p>
          <p class="text-[13px] italic text-anthrazit/55 leading-[1.55]" id="room-service-status">
            {roomServiceOn ? 'Gäste können Lieferung aufs Zimmer wählen' : 'Gäste frühstücken nur im Frühstücksraum'}
          </p>
        </div>
        <BauhausToggle id="room-service-toggle" name="breakfast_room_service_enabled" checked={roomServiceOn} label="Room-Service aktiv" />
      </label>

      <script is:inline>
        const rsToggle = document.getElementById('room-service-toggle');
        const rsStatus = document.getElementById('room-service-status');
        const feeSection = document.getElementById('room-service-fee-section');
        if (rsToggle && rsStatus) {
          rsToggle.addEventListener('change', () => {
            rsStatus.textContent = rsToggle.checked
              ? 'Gäste können Lieferung aufs Zimmer wählen'
              : 'Gäste frühstücken nur im Frühstücksraum';
            if (feeSection) feeSection.style.display = rsToggle.checked ? '' : 'none';
          });
        }
      </script>

      <div id="room-service-fee-section" style={roomServiceOn ? '' : 'display:none'} class="mt-6 pt-6 border-t border-anthrazit/[0.10]">
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Zimmerservice-Aufschlag in Cent (z.B. 300 = €3,00 — 0 = kein Aufschlag)</span>
          <input
            type="number"
            name="breakfast_room_service_fee_cents"
            value={roomServiceFee}
            min="0" step="50"
            class="bauhaus-input"
          />
        </label>
      </div>
    </section>

    <div class="flex justify-end pt-2 pb-4">
      <button type="submit" class="bauhaus-button bauhaus-button--primary">
        Einstellungen speichern
      </button>
    </div>

  </form>

  <!-- Speisekarte ─────────────────────────────────────────────────────────── -->
  <div id="speisekarte" class="mt-8 space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="eyebrow text-pink-shock mb-1">— Speisekarte —</p>
        <h2 class="text-2xl font-light">Frühstücks-<span class="font-medium">Items</span><span class="h-dot">.</span></h2>
        <p class="text-xs text-anthrazit/55 mt-1">
          {items.length} Speise{items.length === 1 ? '' : 'n'} insgesamt
        </p>
      </div>
      <div class="flex gap-3">
        {hasMews && (
          <form method="POST">
            <input type="hidden" name="_action" value="mews_import" />
            <button
              type="submit"
              onclick="return confirm('Mews-Produkte importieren? Bestehende Items mit gleicher Mews-ID werden aktualisiert.')"
              class="bauhaus-button bauhaus-button--ghost"
            >
              Aus Mews übernehmen
            </button>
          </form>
        )}
        <a href="/admin/breakfast/items/new" class="bauhaus-button bauhaus-button--primary">
          + Neue Speise
        </a>
      </div>
    </div>

    {items.length === 0 ? (
      <div class="bg-white border border-anthrazit/[0.12] p-12 text-center">
        <p class="text-anthrazit/55 italic mb-4">Noch keine Speisen angelegt.</p>
        <div class="flex justify-center gap-3">
          {hasMews && (
            <form method="POST">
              <input type="hidden" name="_action" value="mews_import" />
              <button
                type="submit"
                onclick="return confirm('Mews-Produkte importieren?')"
                class="bauhaus-button bauhaus-button--ghost"
              >
                Aus Mews übernehmen
              </button>
            </form>
          )}
          <a href="/admin/breakfast/items/new" class="bauhaus-button bauhaus-button--primary">
            Erste Speise anlegen
          </a>
        </div>
      </div>
    ) : (
      <div class="space-y-6">
        {Object.entries(itemsByCategory).map(([cat, catItems]) => (
          <div>
            <h3 class="text-xs font-medium text-anthrazit/55 uppercase tracking-widest mb-2 px-1">{cat}</h3>
            <div class="bg-white border border-anthrazit/[0.12] divide-y divide-anthrazit/[0.08]">
              {catItems.map(item => (
                <a
                  href={`/admin/breakfast/items/${item.id}`}
                  class="flex items-center justify-between px-5 py-4 hover:bg-anthrazit/[0.02] transition group"
                >
                  <div class="flex items-center gap-4 min-w-0">
                    <span class={`w-2 h-2 rounded-full flex-shrink-0 ${item.is_active ? 'bg-green-500' : 'bg-anthrazit/25'}`}></span>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-anthrazit truncate">{item.name_de}</p>
                      {item.description_de && (
                        <p class="text-xs text-anthrazit/50 truncate mt-0.5">{item.description_de}</p>
                      )}
                    </div>
                  </div>
                  <div class="flex items-center gap-6 flex-shrink-0 ml-4">
                    {(item.is_vegetarian || item.is_vegan || item.is_organic) && (
                      <div class="flex gap-1">
                        {item.is_vegan && <span class="text-[10px] bg-green-100 text-green-800 px-1.5 py-0.5 rounded">vegan</span>}
                        {!item.is_vegan && item.is_vegetarian && <span class="text-[10px] bg-lime-100 text-lime-800 px-1.5 py-0.5 rounded">veg</span>}
                        {item.is_organic && <span class="text-[10px] bg-amber-100 text-amber-800 px-1.5 py-0.5 rounded">bio</span>}
                      </div>
                    )}
                    {item.price_cents > 0 && (
                      <span class="text-sm text-anthrazit/70 tabular-nums">
                        {(item.price_cents / 100).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })}
                      </span>
                    )}
                    <span class="text-xs text-anthrazit/40 group-hover:text-pink-shock transition">bearbeiten →</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}

    <div class="bg-amber-50 border-l-4 border-amber-400 p-4">
      <div class="flex gap-3">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" class="text-amber-700 flex-shrink-0 mt-0.5">
          <path d="M12 9v4m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.74-3l-6.93-12a2 2 0 0 0-3.48 0L3.34 16a2 2 0 0 0 1.73 3z"/>
        </svg>
        <p class="text-xs text-amber-800 leading-relaxed max-w-2xl">
          <strong class="font-medium">Hinweis Allergen-Angaben:</strong> Du als Hotelbetreiber bist gesetzlich (LMIV Art. 9) für die
          Richtigkeit der Allergen-Angaben verantwortlich. Bei Rezeptur-Änderungen bitte sofort aktualisieren.
        </p>
      </div>
    </div>
  </div>
</Layout>
