---
import Layout from '../../layouts/Layout.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import BauhausToggle from '@retaha/ui/components/admin/BauhausToggle.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { getEnv } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const supabase = createSupabaseServiceRoleInstance();

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const startTime     = form.get('breakfast_start_time')?.toString() || '07:30';
  const endTime       = form.get('breakfast_end_time')?.toString()   || '10:30';
  const slotMinutes   = parseInt(form.get('breakfast_slot_minutes')?.toString() || '30') || 30;
  const locationDe    = form.get('breakfast_location_de')?.toString().trim() || null;
  const includedDe    = form.get('breakfast_included_de')?.toString().trim() || null;

  // Preis: leerer String → null (kein Preis konfiguriert)
  const priceRaw      = form.get('breakfast_price_cents')?.toString().trim();
  const priceCents    = priceRaw ? (parseInt(priceRaw) || null) : null;

  // Room-Service: Checkbox liefert 'on' wenn gesetzt
  const roomServiceEnabled = form.getAll('breakfast_room_service_enabled').includes('on');

  const roomServiceFeeRaw  = form.get('breakfast_room_service_fee_cents')?.toString().trim();
  const roomServiceFeeCents = roomServiceFeeRaw ? (parseInt(roomServiceFeeRaw) || 0) : 0;

  const { error } = await supabase
    .from('hotel_settings')
    .upsert({
      hotel_id: hotel.id,
      breakfast_start_time:             startTime,
      breakfast_end_time:               endTime,
      breakfast_slot_minutes:           slotMinutes,
      breakfast_location_de:            locationDe,
      breakfast_included_de:            includedDe,
      breakfast_price_cents:            priceCents,
      breakfast_room_service_enabled:   roomServiceEnabled,
      breakfast_room_service_fee_cents: roomServiceFeeCents,
      updated_at: new Date().toISOString(),
    }, { onConflict: 'hotel_id' });

  if (error) {
    message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
  } else {
    message = { type: 'success', text: 'Frühstücks-Einstellungen gespeichert.' };
  }
}

const { data: settings } = await supabase
  .from('hotel_settings')
  .select(`
    breakfast_start_time, breakfast_end_time, breakfast_slot_minutes,
    breakfast_location_de, breakfast_included_de,
    breakfast_price_cents,
    breakfast_room_service_enabled, breakfast_room_service_fee_cents
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || ({} as Record<string, any>);
const startTime      = ((s.breakfast_start_time as string | undefined) || '07:30').substring(0, 5);
const endTime        = ((s.breakfast_end_time   as string | undefined) || '10:30').substring(0, 5);
const slotMinutes    = (s.breakfast_slot_minutes as number | undefined) || 30;
const locationDe     = (s.breakfast_location_de  as string | undefined) || '';
const includedDe     = (s.breakfast_included_de  as string | undefined) || '';
const priceCents     = (s.breakfast_price_cents   as number | null | undefined) ?? null;
const roomServiceOn  = (s.breakfast_room_service_enabled as boolean | undefined) === true;
const roomServiceFee = (s.breakfast_room_service_fee_cents as number | undefined) || 0;

const guestAppBase = getEnv('PUBLIC_SITE_URL') ?? 'https://app.retaha.de';
const menuUrl = `${guestAppBase.replace(/\/$/, '')}/menu/`;
---

<Layout title="Frühstück" activeTab="backoffice">
  <EditorialPageHeader
    sectionNumber="02"
    sectionLabel="Frühstücksmodul"
    headlineLight="Frühstücks-"
    headlineBold="Einstellungen."
    subtitle="Zeiten, Ort, Preis und Zimmerservice — alles was die Gäste-App für das Frühstücksmodul braucht."
  />

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <form method="POST" class="space-y-8">

    <!-- Zeiten -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Zeiten —</p>
        <h2 class="text-xl font-medium">Wann gibt es Frühstück?</h2>
        <p class="text-xs text-anthrazit/55 mt-1">Bestimmt die buchbaren Slots in der Gäste-App.</p>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Beginn</span>
          <input
            type="time"
            name="breakfast_start_time"
            value={startTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit"
          />
        </label>
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Ende</span>
          <input
            type="time"
            name="breakfast_end_time"
            value={endTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit"
          />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Slot-Länge (Min)</span>
          <input
            type="number"
            name="breakfast_slot_minutes"
            value={slotMinutes}
            min="5" max="120" step="5"
            class="bauhaus-input"
          />
        </label>
      </div>
      <p class="text-[10px] text-anthrazit/40 mt-3 italic">
        Slot-Länge bestimmt die Abstände der Buchungszeiten (z.B. 30 = 07:30, 08:00, 08:30, …).
      </p>
    </section>

    <!-- Ort -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Ort —</p>
        <h2 class="text-xl font-medium">Wo wird gefrühstückt?</h2>
        <p class="text-xs text-anthrazit/55 mt-1">Z.B. „im Wintergarten" — wird zusammen mit der Begrüßung gezeigt.</p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Deutsch</span>
        <input
          type="text"
          name="breakfast_location_de"
          value={locationDe}
          placeholder="z.B. im Wintergarten"
          class="bauhaus-input"
        />
      </label>
    </section>

    <!-- Inklusiv-Text -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Was inkludiert ist —</p>
        <h2 class="text-xl font-medium">Was bekommen deine Gäste?</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Z.B. „Frische Backwaren, regionaler Honig, …" — wird im Info-Modus prominent gezeigt.
        </p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Deutsch</span>
        <textarea
          name="breakfast_included_de"
          rows="3"
          placeholder="z.B. Frische Backwaren, regionaler Honig, Bio-Eier, …"
          class="bauhaus-textarea"
        >{includedDe}</textarea>
      </label>
    </section>

    <!-- Pauschalpreis -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Preis —</p>
        <h2 class="text-xl font-medium">Pauschalpreis pro Person</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Wird in der Gäste-App angezeigt und als Fallback für Mews-Buchungen verwendet (falls kein Item-Preis hinterlegt).
          Leer lassen wenn kein fester Preis gewünscht.
        </p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Preis in Cent (z.B. 1500 = €15,00)</span>
        <input
          type="number"
          name="breakfast_price_cents"
          value={priceCents !== null ? priceCents : ''}
          min="0" step="50"
          placeholder="leer = kein Preis anzeigen"
          class="bauhaus-input"
        />
      </label>
    </section>

    <!-- Room-Service -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Zimmerservice —</p>
        <h2 class="text-xl font-medium">Frühstück aufs Zimmer anbieten?</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Wenn aktiv, können Gäste zwischen „Im Frühstücksraum" und „Aufs Zimmer" wählen.
        </p>
      </div>

      <label for="room-service-toggle" class="flex items-center gap-5 py-[26px] cursor-pointer">
        <span
          data-toggle-accent
          class="w-1.5 h-1.5 rounded-full bg-anthrazit/30 transition-colors duration-200 ease-in-out flex-shrink-0 pointer-events-none"
          aria-hidden="true"
        ></span>
        <div class="flex-1 min-w-0">
          <p class="text-[15px] font-medium text-anthrazit leading-tight tracking-tight mb-1.5">Room-Service aktiv</p>
          <p class="text-[13px] italic text-anthrazit/55 leading-[1.55]" id="room-service-status">
            {roomServiceOn ? 'Gäste können Lieferung aufs Zimmer wählen' : 'Gäste frühstücken nur im Frühstücksraum'}
          </p>
        </div>
        <BauhausToggle id="room-service-toggle" name="breakfast_room_service_enabled" checked={roomServiceOn} label="Room-Service aktiv" />
      </label>

      <script is:inline>
        const rsToggle = document.getElementById('room-service-toggle');
        const rsStatus = document.getElementById('room-service-status');
        const feeSection = document.getElementById('room-service-fee-section');
        if (rsToggle && rsStatus) {
          rsToggle.addEventListener('change', () => {
            rsStatus.textContent = rsToggle.checked
              ? 'Gäste können Lieferung aufs Zimmer wählen'
              : 'Gäste frühstücken nur im Frühstücksraum';
            if (feeSection) feeSection.style.display = rsToggle.checked ? '' : 'none';
          });
        }
      </script>

      <div id="room-service-fee-section" style={roomServiceOn ? '' : 'display:none'} class="mt-6 pt-6 border-t border-anthrazit/[0.10]">
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Zimmerservice-Aufschlag in Cent (z.B. 300 = €3,00 — 0 = kein Aufschlag)</span>
          <input
            type="number"
            name="breakfast_room_service_fee_cents"
            value={roomServiceFee}
            min="0" step="50"
            class="bauhaus-input"
          />
        </label>
      </div>
    </section>

    <!-- Speisekarte -->
    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-4">
        <p class="eyebrow text-pink-shock mb-1">— Speisekarte —</p>
        <h2 class="text-xl font-medium">Frühstücks-Items verwalten</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Items, Preise, Allergene und Kategorien werden in der Gäste-App gepflegt.
        </p>
      </div>
      <a
        href={menuUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-3 border border-anthrazit/20 text-sm font-medium text-anthrazit hover:border-anthrazit transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Speisekarte öffnen (Gäste-App)
      </a>
      <p class="text-[10px] text-anthrazit/40 mt-3 italic">
        Öffnet die Speisekarte in der Gäste-App in einem neuen Tab.
      </p>
    </section>

    <div class="flex justify-end pt-4">
      <button type="submit" class="bauhaus-button bauhaus-button--primary">
        Änderungen speichern
      </button>
    </div>

  </form>
</Layout>
