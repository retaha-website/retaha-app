---
// Sprint Functional Modul B Phase 5 — Setup-Wizard /admin/setup
//
// 5 Schritte. Wizard-Logik: kein eigener wizard_state — wir lesen die
// echten Tabellen, setzen onboarding_state.step_* beim Save, springen
// beim Öffnen direkt zum ersten unfertigen Schritt.

import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getOnboardingChecklist } from '../../lib/onboarding/checklist';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const checklist = await getOnboardingChecklist(client, hotel.id);

// Wenn schon completed → Direkt zum Dashboard (User kommt aus Versehen hierher)
if (checklist.completed_at) return Astro.redirect('/admin');

// Aktuelle Hotel-Daten für Wizard-Pre-Fill
const { data: hotelData } = await client
  .from('hotels')
  .select('name, address_street, address_zip, city, country, default_language, enabled_languages, latitude, longitude')
  .eq('id', hotel.id).maybeSingle();

const h = (hotelData ?? {}) as any;

const ALL_LANGUAGES = [
  { code: 'de', label: 'Deutsch' }, { code: 'en', label: 'English' },
  { code: 'fr', label: 'Français' }, { code: 'es', label: 'Español' },
  { code: 'it', label: 'Italiano' }, { code: 'pt', label: 'Português' },
  { code: 'nl', label: 'Nederlands' }, { code: 'ru', label: 'Русский' },
  { code: 'ar', label: 'العربية' }, { code: 'zh', label: '中文' },
];

// Startschritt = erster unfertiger Required-Step (oder 1=Welcome wenn ganz neu)
function detectStartStep(): number {
  if (!h.name) return 2;
  if (!Array.isArray(h.enabled_languages) || h.enabled_languages.length === 0) return 2;
  if (!h.address_street || !h.city) return 3;
  return 4;
}
const startStep = h.name ? detectStartStep() : 1;

const initial = {
  step: startStep,
  hotelName: h.name ?? '',
  defaultLang: h.default_language ?? 'de',
  enabledLangs: Array.isArray(h.enabled_languages) ? h.enabled_languages : ['de','en','fr','es'],
  street: h.address_street ?? '',
  zip: h.address_zip ?? '',
  city: h.city ?? '',
  country: h.country ?? 'Deutschland',
};
---

<Layout title="Setup" activeTab="backoffice">
  <div x-data={`setupWizard(${JSON.stringify(initial)})`} class="wizard-page">

    <header class="wizard-header">
      <p class="wizard-eyebrow themed-eyebrow-flank">Setup-Wizard</p>
      <h1 class="wizard-title">Lass uns dein Hotel<br/>einrichten<span class="wizard-dot">.</span></h1>
      <div class="wizard-progress">
        <template x-for="n in [1,2,3,4,5]" :key="n">
          <span class="wizard-step-dot" :class="{ 'is-current': step === n, 'is-done': step > n }" x-text="n"></span>
        </template>
      </div>
      <p class="wizard-progress-label">Schritt <span x-text="step"></span> von 5</p>
    </header>

    <!-- Step 1: Willkommen -->
    <section x-show="step === 1" class="wizard-section" x-cloak>
      <h2 class="wizard-section-title">Willkommen bei retaha.</h2>
      <p class="wizard-section-body">
        Wir richten in 4 kurzen Schritten dein Hotel ein. Du kannst jederzeit pausieren
        und später weitermachen — deine Eingaben bleiben gespeichert.
      </p>
      <p class="wizard-section-body">
        Nach dem Setup hast du Zugriff auf die Concierge-App, Eve KI, Empfehlungen,
        Operations-Dashboard und mehr.
      </p>
      <div class="wizard-actions">
        <button type="button" @click="next()" class="wizard-btn wizard-btn--primary">Los geht's →</button>
      </div>
    </section>

    <!-- Step 2: Hotel-Basics + Sprachen -->
    <section x-show="step === 2" class="wizard-section" x-cloak>
      <h2 class="wizard-section-title">Dein Hotel</h2>

      <label class="wizard-field">
        <span class="wizard-field-label">Hotel-Name *</span>
        <input type="text" x-model="hotelName" class="wizard-input" placeholder="z.B. Gate Garden Hotel" />
      </label>

      <label class="wizard-field">
        <span class="wizard-field-label">Standardsprache *</span>
        <select x-model="defaultLang" @change="ensureDefaultEnabled()" class="wizard-input">
          {ALL_LANGUAGES.map(l => <option value={l.code}>{l.label}</option>)}
        </select>
        <p class="wizard-field-hint">In dieser Sprache pflegst du Inhalte. Wir übersetzen automatisch in andere.</p>
      </label>

      <label class="wizard-field">
        <span class="wizard-field-label">Sprachen für deine Gäste (max 6)</span>
        <div class="wizard-lang-grid">
          {ALL_LANGUAGES.map(l => (
            <label class="wizard-lang-chip" :class={`enabledLangs.includes('${l.code}') ? 'is-on' : ''`}>
              <input
                type="checkbox"
                :checked={`enabledLangs.includes('${l.code}')`}
                @change={`toggleLang('${l.code}')`}
                :disabled={`!enabledLangs.includes('${l.code}') && enabledLangs.length >= 6`}
              />
              <span>{l.label}</span>
            </label>
          ))}
        </div>
        <p class="wizard-field-hint">★ Standardsprache ist immer aktiv · <span x-text="enabledLangs.length"></span>/6 ausgewählt</p>
      </label>

      <p x-show="step2Error" x-text="step2Error" class="wizard-error" x-cloak></p>
      <div class="wizard-actions">
        <button type="button" @click="prev()" class="wizard-btn wizard-btn--ghost">← Zurück</button>
        <button type="button" @click="saveStep2()" :disabled="isSaving" class="wizard-btn wizard-btn--primary">
          <span x-show="!isSaving">Weiter →</span>
          <span x-show="isSaving" x-cloak>Speichere …</span>
        </button>
      </div>
    </section>

    <!-- Step 3: Adresse -->
    <section x-show="step === 3" class="wizard-section" x-cloak>
      <h2 class="wizard-section-title">Adresse</h2>
      <p class="wizard-section-body">
        Wir geocodieren die Adresse automatisch — wichtig für Empfehlungen in der Nähe.
      </p>

      <label class="wizard-field">
        <span class="wizard-field-label">Straße + Hausnummer</span>
        <input type="text" x-model="street" class="wizard-input" placeholder="Invalidenstraße 122" />
      </label>
      <div class="wizard-field-row">
        <label class="wizard-field" style="flex: 0 0 140px;">
          <span class="wizard-field-label">PLZ</span>
          <input type="text" x-model="zip" class="wizard-input" placeholder="10115" />
        </label>
        <label class="wizard-field" style="flex: 1;">
          <span class="wizard-field-label">Stadt</span>
          <input type="text" x-model="city" class="wizard-input" placeholder="Berlin" />
        </label>
      </div>
      <label class="wizard-field">
        <span class="wizard-field-label">Land</span>
        <input type="text" x-model="country" class="wizard-input" />
      </label>

      <p x-show="step3Status" :class="step3Ok ? 'wizard-status ok' : 'wizard-status err'" x-text="step3Status" x-cloak></p>

      <div class="wizard-actions">
        <button type="button" @click="prev()" class="wizard-btn wizard-btn--ghost">← Zurück</button>
        <button type="button" @click="saveStep3()" :disabled="isSaving" class="wizard-btn wizard-btn--primary">
          <span x-show="!isSaving">Weiter →</span>
          <span x-show="isSaving" x-cloak>Speichere + Geocoding …</span>
        </button>
      </div>
    </section>

    <!-- Step 4: Mews -->
    <section x-show="step === 4" class="wizard-section" x-cloak>
      <h2 class="wizard-section-title">Mews-Anbindung</h2>
      <p class="wizard-section-body">
        Verknüpfe dein <strong>Mews-PMS</strong>, damit Stays und Gäste automatisch synchronisiert werden.
        Du kannst diesen Schritt überspringen und später in den Einstellungen einrichten.
      </p>

      <div class="wizard-mews-card">
        <p class="wizard-mews-icon">⚙</p>
        <p class="wizard-mews-text">
          Die Mews-Anbindung läuft über deinen Mews-Account. Auf <a href="/admin/pms">/admin/pms</a> kannst
          du den Connector aktivieren — wir empfehlen das gemeinsam mit einem Setup-Call mit retaha.
        </p>
      </div>

      <div class="wizard-actions">
        <button type="button" @click="prev()" class="wizard-btn wizard-btn--ghost">← Zurück</button>
        <button type="button" @click="skipMews()" :disabled="isSaving" class="wizard-btn wizard-btn--secondary">Später einrichten</button>
        <a href="/admin/pms" class="wizard-btn wizard-btn--primary">Zur Mews-Anbindung →</a>
      </div>
    </section>

    <!-- Step 5: Done -->
    <section x-show="step === 5" class="wizard-section" x-cloak>
      <h2 class="wizard-section-title">Startklar.</h2>
      <p class="wizard-section-body">
        Dein Hotel ist eingerichtet. Im <strong>Dashboard</strong> findest du eine Checkliste mit den
        nächsten Schritten (Eve-Wissen, Hero-Karten, Empfehlungen, Team).
      </p>
      <ul class="wizard-next-steps">
        <li>→ <a href="/admin/eve/knowledge">Eve-Wissen pflegen</a> (3+ FAQs)</li>
        <li>→ <a href="/admin/action-cards">Hero-Karten anlegen</a></li>
        <li>→ <a href="/admin/places">Empfehlungs-Picks</a></li>
        <li>→ <a href="/admin/team">Mitarbeiter einladen</a></li>
      </ul>
      <div class="wizard-actions">
        <button type="button" @click="finish()" :disabled="isSaving" class="wizard-btn wizard-btn--primary">
          <span x-show="!isSaving">Zum Dashboard →</span>
          <span x-show="isSaving" x-cloak>Abschluss …</span>
        </button>
      </div>
    </section>

    <div x-show="toast" x-cloak :class="`wizard-toast wizard-toast--${toastKind}`" x-text="toast"></div>
  </div>

  <script>
    import Alpine from 'alpinejs';

    Alpine.data('setupWizard', (init: any) => ({
      step: init.step,
      hotelName: init.hotelName, defaultLang: init.defaultLang, enabledLangs: init.enabledLangs,
      street: init.street, zip: init.zip, city: init.city, country: init.country,
      isSaving: false,
      step2Error: '', step3Status: '', step3Ok: false,
      toast: '', toastKind: 'success' as 'success' | 'error',

      next() { if (this.step < 5) this.step++; },
      prev() { if (this.step > 1) this.step--; },

      ensureDefaultEnabled() {
        if (!this.enabledLangs.includes(this.defaultLang)) {
          this.enabledLangs = [this.defaultLang, ...this.enabledLangs].slice(0, 6);
        }
      },
      toggleLang(code: string) {
        if (this.enabledLangs.includes(code)) {
          if (code === this.defaultLang) return;
          this.enabledLangs = this.enabledLangs.filter((l: string) => l !== code);
        } else {
          if (this.enabledLangs.length >= 6) return;
          this.enabledLangs = [...this.enabledLangs, code];
        }
      },

      showToast(msg: string, kind: 'success' | 'error' = 'success') {
        this.toast = msg; this.toastKind = kind;
        setTimeout(() => { this.toast = ''; }, 3000);
      },

      async saveStep2() {
        this.step2Error = '';
        if (!this.hotelName.trim()) { this.step2Error = 'Hotel-Name ist Pflicht.'; return; }
        if (this.enabledLangs.length === 0) { this.step2Error = 'Mindestens eine Sprache aktivieren.'; return; }
        this.isSaving = true;
        try {
          // 2 Calls parallel: hotel_basics + languages
          const r1 = await fetch('/api/admin/setup/save-step', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ step: 'hotel_basics', data: { name: this.hotelName } }),
          });
          const r2 = await fetch('/api/admin/setup/save-step', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ step: 'languages', data: { default_language: this.defaultLang, enabled_languages: this.enabledLangs } }),
          });
          const d1 = await r1.json(); const d2 = await r2.json();
          if (!d1.ok || !d2.ok) {
            this.step2Error = d2.error || d1.error || 'Speichern fehlgeschlagen.';
            return;
          }
          this.step = 3;
        } catch (err: any) {
          this.step2Error = 'Netzwerk: ' + (err.message ?? err);
        } finally { this.isSaving = false; }
      },

      async saveStep3() {
        this.step3Status = ''; this.step3Ok = false;
        this.isSaving = true;
        try {
          const res = await fetch('/api/admin/setup/save-step', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ step: 'address', data: { street: this.street, zip: this.zip, city: this.city, country: this.country } }),
          });
          const data = await res.json();
          if (!data.ok) { this.step3Status = data.error || 'Fehler.'; return; }
          this.step3Ok = true;
          this.step3Status = data.geocoded ? 'Adresse + Geocoding gespeichert.' : 'Adresse gespeichert (Geocoding ausstehend).';
          setTimeout(() => { this.step = 4; this.step3Status = ''; }, 800);
        } catch (err: any) {
          this.step3Status = 'Netzwerk: ' + (err.message ?? err);
        } finally { this.isSaving = false; }
      },

      async skipMews() {
        this.isSaving = true;
        try {
          await fetch('/api/admin/setup/save-step', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ step: 'mews_skip' }),
          });
          this.step = 5;
        } finally { this.isSaving = false; }
      },

      async finish() {
        this.isSaving = true;
        try {
          await fetch('/api/admin/setup/save-step', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ step: 'complete' }),
          });
          window.location.href = '/admin';
        } catch (err: any) {
          this.showToast('Fehler beim Abschluss: ' + (err.message ?? err), 'error');
          this.isSaving = false;
        }
      },
    }));
  </script>

  <style>
    [x-cloak] { display: none !important; }
    .wizard-page { max-width: 680px; margin: 0 auto; padding: 24px 24px 60px; }

    .wizard-header { margin-bottom: 32px; text-align: center; }
    .wizard-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--theme-accent); margin: 0 0 12px; }
    .wizard-title { font-size: 32px; font-weight: 300; letter-spacing: -0.015em; color: var(--theme-text-primary); margin: 0 0 24px; line-height: 1.1; }
    .wizard-dot { color: var(--theme-accent); }

    .wizard-progress { display: flex; justify-content: center; gap: 12px; margin-bottom: 8px; }
    .wizard-step-dot {
      width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--theme-border); font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent);
    }
    .wizard-step-dot.is-current { border-color: var(--theme-accent); color: var(--theme-accent); font-weight: 600; }
    .wizard-step-dot.is-done { background: var(--theme-bg-anthrazit); border-color: var(--theme-text-primary); color: var(--theme-bg-primary); }
    .wizard-progress-label { text-align: center; font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin: 0; }

    .wizard-section { background: var(--theme-bg-primary); padding: 28px 24px; border: 1px solid var(--theme-border); }
    .wizard-section-title { margin: 0 0 16px; font-size: 22px; font-weight: 500; color: var(--theme-text-primary); }
    .wizard-section-body { font-size: 14px; line-height: 1.6; color: color-mix(in srgb, var(--theme-text-primary) .75, transparent); margin: 0 0 14px; }

    .wizard-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .wizard-field-row { display: flex; gap: 12px; margin-bottom: 16px; }
    .wizard-field-row > .wizard-field { margin-bottom: 0; }
    .wizard-field-label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); }
    .wizard-field-hint { font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); margin: 4px 0 0; font-style: italic; }
    .wizard-input { padding: 10px 12px; border: 1px solid var(--theme-border); font-size: 14px; font-family: inherit; background: var(--theme-bg-primary); transition: border-color 0.15s ease, box-shadow 0.15s ease; }
    .wizard-input:focus { outline: none; border-color: var(--theme-accent); box-shadow: 0 0 0 3px rgba(var(--theme-accent-rgb), 0.1); }

    .wizard-lang-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; margin-top: 8px; }
    @media (min-width: 640px) { .wizard-lang-grid { grid-template-columns: repeat(3, 1fr); } }
    .wizard-lang-chip {
      display: flex; align-items: center; gap: 8px; padding: 8px 12px;
      border: 1px solid var(--theme-border); font-size: 13px; cursor: pointer;
    }
    .wizard-lang-chip.is-on { border-color: var(--theme-accent); background: rgba(var(--theme-accent-rgb), .05); }
    .wizard-lang-chip input { accent-color: var(--theme-accent); }

    .wizard-mews-card {
      background: rgba(var(--theme-accent-rgb), .04); border: 1px solid rgba(var(--theme-accent-rgb), .2);
      padding: 20px; margin: 16px 0; display: flex; gap: 14px; align-items: flex-start;
    }
    .wizard-mews-icon { font-size: 28px; margin: 0; color: var(--theme-accent); }
    .wizard-mews-text { margin: 0; font-size: 14px; line-height: 1.5; color: var(--theme-text-primary); }
    .wizard-mews-text a { color: var(--theme-accent); text-decoration: underline; }

    .wizard-next-steps { list-style: none; padding: 0; margin: 16px 0; display: flex; flex-direction: column; gap: 8px; }
    .wizard-next-steps li { font-size: 14px; padding: 8px 0; border-bottom: 1px solid var(--theme-border); }
    .wizard-next-steps a { color: var(--theme-accent); text-decoration: none; }
    .wizard-next-steps a:hover { text-decoration: underline; }

    .wizard-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 24px; }
    .wizard-btn { padding: 10px 18px; font-size: 14px; font-weight: 500; border: 1px solid; cursor: pointer; background: var(--theme-bg-primary); color: var(--theme-text-primary); font-family: inherit; text-decoration: none; display: inline-flex; align-items: center; }
    .wizard-btn:disabled { opacity: 0.5; cursor: wait; }
    .wizard-btn--primary { background: var(--theme-accent); color: var(--theme-bg-primary); border-color: var(--theme-accent); }
    .wizard-btn--primary:hover:not(:disabled) { background: var(--theme-accent-hover); }
    .wizard-btn--secondary { border-color: var(--theme-text-primary); }
    .wizard-btn--secondary:hover:not(:disabled) { background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary); }
    .wizard-btn--ghost { border-color: var(--theme-border); color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); }
    .wizard-btn--ghost:hover:not(:disabled) { color: var(--theme-text-primary); }

    .wizard-error, .wizard-status { padding: 10px 14px; margin: 12px 0; font-size: 13px; }
    /* Marken-DNA: error = pink (NICHT rot), success = sage */
    .wizard-error, .wizard-status.err {
      background: rgba(var(--theme-accent-rgb), 0.08);
      color: var(--theme-accent);
      border-left: 3px solid var(--theme-accent);
    }
    .wizard-status.ok {
      background: color-mix(in srgb, var(--theme-success) 10%, transparent);
      color: var(--theme-text-primary);
      border-left: 3px solid var(--theme-success);
    }

    .wizard-toast { position: fixed; top: 16px; right: 16px; padding: 10px 16px; color: var(--theme-bg-primary); font-size: 13px; z-index: 200; box-shadow: 0 4px 16px rgba(0,0,0,.18); }
    .wizard-toast--success { background: var(--theme-success); }
    .wizard-toast--error { background: var(--theme-accent); }
  </style>
</Layout>
