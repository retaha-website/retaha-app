---
import Layout from '../layouts/Layout.astro';
import { getUserHotels } from '@retaha/auth';
import { POLICY_VERSION } from '../lib/legal/consent';

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
---

<Layout title="Datenschutz · retaha" activeTab="backoffice" hotelName={hotel?.name} hotelLogoUrl={(hotel as any)?.logo_primary ?? (hotel as any)?.logo_dark}>

  <div class="settings-page" style="padding-top:0">
    <nav class="breadcrumb" style="padding-top:36px" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">Steuerung</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Datenschutz</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title">Datenschutz<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">Was wir über dich als Hotelier speichern</p>
    </section>

    <div class="lg-body">

      <span class="lg-version">Stand: {POLICY_VERSION} · gültig für das retaha-Hospitality-Backoffice</span>

      <div class="lg-card">
        <h2 class="lg-h2">1. Verantwortlich</h2>
        <p>
          <strong>retaha GmbH</strong>, Weinsteige 31, 74676 Niedernhall, Geschäftsführer Taha Mustafa Ünal.<br />
          Kontakt: <a href="mailto:hallo@retaha.de">hallo@retaha.de</a> · Tel +49 7131 3824635
        </p>
        <p>
          <strong>Wichtiger Unterschied zur Gast-App:</strong> Für die Daten deiner Hotelgäste bist du (das Hotel) der Verantwortliche — retaha agiert dort nur als Auftragsverarbeiter (AVV). Diese Datenschutzerklärung betrifft nur deine eigenen Backoffice-Account-Daten.
        </p>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">2. Welche Daten wir verarbeiten</h2>
        <ul>
          <li><strong>Account-Daten</strong>: E-Mail, Vor- und Nachname, gehashtes Passwort (via Supabase Auth)</li>
          <li><strong>Hotel-Profil</strong>: Name, Adresse, Stadt, Land, Default-Sprache</li>
          <li><strong>Einstellungen</strong>: Eve-Persönlichkeit, WLAN, Frühstück, Service-Konfiguration</li>
          <li><strong>Inhaltsdaten</strong>: Hero-Karten, Empfehlungs-Picks, Eve-Wissens-Einträge</li>
          <li><strong>Abrechnungsdaten</strong>: Stripe-Customer-ID, Subscription-Status (keine Kartendaten)</li>
          <li><strong>Technische Logs</strong>: Login-Zeitpunkte, IP (gehasht), Browser, Aktionen</li>
        </ul>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">3. Rechtsgrundlagen</h2>
        <ul>
          <li><strong>Vertragserfüllung</strong> (Art. 6 Abs. 1 lit. b): Bereitstellung der SaaS-Plattform, Authentifizierung, Abrechnung</li>
          <li><strong>Berechtigtes Interesse</strong> (Art. 6 Abs. 1 lit. f): Sicherheits-Logs, Missbrauchsvermeidung</li>
          <li><strong>Gesetzliche Pflicht</strong> (Art. 6 Abs. 1 lit. c): Buchhaltungsaufbewahrung (10 Jahre)</li>
          <li><strong>Einwilligung</strong> (Art. 6 Abs. 1 lit. a): freiwillige Newsletter (separat opt-in)</li>
        </ul>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">4. Auftragsverarbeiter</h2>
        <ul>
          <li><strong>Supabase</strong> (EU/Frankfurt) — Auth, Datenbank</li>
          <li><strong>Vercel</strong> (USA, mit EU-Standardvertragsklauseln) — Hosting</li>
          <li><strong>Stripe</strong> (Irland/USA, mit EU-Standardvertragsklauseln) — Abrechnung</li>
          <li><strong>Resend</strong> (USA, mit EU-Standardvertragsklauseln) — transaktionale E-Mails</li>
          <li><strong>Anthropic</strong> (USA, mit EU-Standardvertragsklauseln) — nur bei Eve-Nutzung</li>
          <li><strong>Google Ireland</strong> (Dublin, EU) — Places-Daten für Empfehlungen</li>
          <li><strong>Mews Systems</strong> (Tschechien/EU) — PMS-Integration</li>
        </ul>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">5. Speicherdauer</h2>
        <ul>
          <li><strong>Account aktiv</strong>: solange dein Vertrag läuft</li>
          <li><strong>Nach Kündigung</strong>: Account-Daten 30 Tage; Buchhaltungsrelevantes 10 Jahre (§ 147 AO)</li>
          <li><strong>Sicherheits-Logs</strong>: bis zu 90 Tage</li>
          <li><strong>Backups</strong>: 30 Tage Retention bei Supabase</li>
        </ul>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">6. Deine Rechte</h2>
        <p>Du hast jederzeit das Recht auf Auskunft (Art. 15), Berichtigung (Art. 16), Löschung (Art. 17), Einschränkung (Art. 18), Datenübertragbarkeit (Art. 20) und Widerspruch (Art. 21).</p>
        <p>Schreib uns: <a href="mailto:hallo@retaha.de">hallo@retaha.de</a> — wir antworten innerhalb von 30 Tagen.</p>

        <h2 class="lg-h2">7. Beschwerderecht</h2>
        <p>
          <strong>Landesbeauftragter für den Datenschutz Baden-Württemberg</strong><br />
          Königstraße 10a, 70173 Stuttgart ·
          <a href="https://www.baden-wuerttemberg.datenschutz.de" target="_blank" rel="noopener">baden-wuerttemberg.datenschutz.de</a>
        </p>
      </div>

      <div class="lg-card">
        <h2 class="lg-h2">8. Cookies</h2>
        <ul>
          <li><strong>Auth-Session-Cookie</strong> (technisch notwendig)</li>
          <li><strong>Spracheinstellung</strong> (Komfort, anonym)</li>
        </ul>
        <p><strong>Kein externes Tracking</strong> (kein Google Analytics, Hotjar, Pixel etc.) im Backoffice.</p>
      </div>

    </div>
  </div>

</Layout>

<style>
  .lg-body { display: flex; flex-direction: column; gap: 12px; padding-bottom: 64px; }

  .lg-version {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em;
    color: var(--ink-faint); border: 1px solid var(--border); border-radius: 5px;
    padding: 4px 10px; display: inline-block; width: fit-content;
  }

  .lg-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 18px 20px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .lg-h2 {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--petrol, #14616E);
    margin-top: 16px; margin-bottom: 2px;
  }
  .lg-h2:first-child { margin-top: 0; }
  .lg-card p { font-size: 13px; color: var(--ink-muted); line-height: 1.65; margin: 0; }
  .lg-card p + p { margin-top: 4px; }
  .lg-card ul { font-size: 13px; color: var(--ink-muted); line-height: 1.65; margin: 0; padding-left: 18px; }
  .lg-card li { margin-bottom: 4px; }
  .lg-card strong { color: var(--ink); font-weight: 600; }
  .lg-card a { color: var(--petrol, #14616E); text-decoration: underline; text-underline-offset: 3px; }
  .lg-card a:hover { opacity: 0.75; }

</style>
