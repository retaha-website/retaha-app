---
import Layout from '../layouts/Layout.astro';
import OnboardingHero from '../components/uebersicht/OnboardingHero.astro';
import OnboardingStep2 from '../components/uebersicht/OnboardingStep2.astro';
import OnboardingStep3 from '../components/uebersicht/OnboardingStep3.astro';
import OnboardingStep5 from '../components/uebersicht/OnboardingStep5.astro';
import DashLite from '../components/uebersicht/DashLite.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getLang } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const supabase = createSupabaseServerInstance(Astro.cookies, Astro.request);

// setup_progress laden + automatisch anpassen basierend auf konfigurierten Feldern
let rawProgress: number | null = null;
let onboardingDone = false;
let setupSkipped = false;
let hotelPlan = 'lite';
try {
  const { data } = await supabase
    .from('hotels')
    .select('setup_progress, name, logo_primary, brand_primary, brand_theme, onboarding_done, setup_skipped, plan')
    .eq('id', hotel.id)
    .maybeSingle();
  rawProgress = (data as any)?.setup_progress ?? null;
  onboardingDone = (data as any)?.onboarding_done === true;
  setupSkipped = (data as any)?.setup_skipped === true;
  hotelPlan = (data as any)?.plan ?? 'lite';

  const hotelName    = (data as any)?.name;
  const logoSet      = !!((data as any)?.logo_primary);
  const colorCustom  = (data as any)?.brand_primary && (data as any).brand_primary !== '#FF4A82';
  const themeCustom  = (data as any)?.brand_theme && (data as any).brand_theme !== 'coffee';
  const brandingDone = logoSet || colorCustom || themeCustom;

  const current = rawProgress ?? 0;
  let target = current;

  // Stufe 15: Hotel-Name (Pflichtfeld) gesetzt
  if (hotelName && current < 15) target = 15;
  // Stufe 30: Branding konfiguriert (Logo ODER eigene Farbe/Theme)
  if (hotelName && brandingDone && current < 30) target = 30;

  if (target > current) {
    await supabase.from('hotels').update({ setup_progress: target }).eq('id', hotel.id);
    rawProgress = target;
  }
} catch { /* Spalte existiert noch nicht — DB-Migration ausstehend */ }

// „Setup unvollständig"-Benachrichtigung angeklickt (?resume=setup) → Skip-Marker
// account-weit löschen und auf die SAUBERE URL umleiten. Ohne Redirect bliebe
// ?resume=setup in der URL kleben → ein erneutes Überspringen + Refresh würde den
// Marker bei jedem Laden wieder löschen (Flow käme zurück, Benachrichtigung weg).
if (Astro.url.searchParams.get('resume') === 'setup') {
  if (setupSkipped) {
    try { await supabase.from('hotels').update({ setup_skipped: false }).eq('id', hotel.id); } catch { /* noop */ }
  }
  return Astro.redirect('/overview');
}
// Flow ausblenden, wenn abgeschlossen ODER übersprungen. Übersprungen kommt nur
// über die Benachrichtigung (?resume=setup) zurück — sonst bleibt er account-weit weg.
const flowHidden = onboardingDone || setupSkipped;

// User-Initial für Avatar (erster Buchstabe der Email)
const userInitial = (user.email ?? 'K').charAt(0).toUpperCase();

// ── Lite-Übersicht: echte Kennzahlen + Aktivität (eingeloggtes Haus) ──────────
const DASHBOARD = import.meta.env.DASHBOARD_URL ?? 'https://dashboard.retaha.de';
const _now = Date.now();
const WEEK = 7 * 86_400_000;
const weekStartIso = new Date(_now - WEEK).toISOString();
const prevStartIso = new Date(_now - 2 * WEEK).toISOString();
const dayStartIso  = new Date(_now - 86_400_000).toISOString();

type TrendObj = { dir: 'up' | 'down' | 'flat' | 'new' | 'none'; pct: number };
function calcTrend(thisN: number, prevN: number): TrendObj {
  if (thisN === 0 && prevN === 0) return { dir: 'none', pct: 0 };
  if (prevN === 0) return { dir: 'new', pct: 0 };
  const pct = Math.round(((thisN - prevN) / prevN) * 100);
  if (pct > 0) return { dir: 'up', pct };
  if (pct < 0) return { dir: 'down', pct: Math.abs(pct) };
  return { dir: 'flat', pct: 0 };
}
const trunc = (s: string, n = 120) => (s && s.length > n ? s.slice(0, n - 1) + '…' : (s ?? ''));

// Defaults — bleiben bei Query-Fehler (z. B. Tabelle fehlt) leer, ohne die Seite zu brechen.
let dl = {
  summaryCount: 0,
  opens:    { n: 0, trend: { dir: 'none', pct: 0 } as TrendObj },
  eve:      { n: 0, trend: { dir: 'none', pct: 0 } as TrendObj },
  requests: { n: 0, open: 0, trend: { dir: 'none', pct: 0 } as TrendObj },
  rating:   { avg: 0, count: 0 },
  activity: [] as any[],
  quick:    null as any,
  links: {
    eve: '/eve/knowledge',
    requests: `${DASHBOARD}/service`,
    feedback: `${DASHBOARD}/feedback`,
    packages: '/subscription',
    actionCards: '/admin/action-cards',
  },
};

try {
  const [chatRes, reqRes, fbRes, fbAllRes, quickRes] = await Promise.all([
    supabase.from('chat_messages').select('stay_id, role, content, created_at').eq('hotel_id', hotel.id).gte('created_at', prevStartIso).order('created_at', { ascending: false }),
    supabase.from('stay_requests').select('id, stay_id, status, note, chips, occasion, created_at').eq('hotel_id', hotel.id).gte('created_at', prevStartIso).order('created_at', { ascending: false }),
    supabase.from('stay_feedback').select('stay_id, rating, comment, created_at').eq('hotel_id', hotel.id).gte('created_at', prevStartIso).order('created_at', { ascending: false }),
    supabase.from('stay_feedback').select('rating').eq('hotel_id', hotel.id),
    supabase.from('hotel_action_cards').select('title_de, title_i18n, eyebrow_de, eyebrow_i18n, card_class, sort_order').eq('hotel_id', hotel.id).eq('is_published', true).order('sort_order', { ascending: true }).limit(1),
  ]);

  const chat = (chatRes.data ?? []) as any[];
  const reqs = (reqRes.data ?? []) as any[];
  const fbs  = (fbRes.data ?? []) as any[];

  const thisChat = chat.filter(r => r.created_at >= weekStartIso);
  const prevChat = chat.filter(r => r.created_at <  weekStartIso);
  const thisReq  = reqs.filter(r => r.created_at >= weekStartIso);
  const prevReq  = reqs.filter(r => r.created_at <  weekStartIso);
  const thisFb   = fbs.filter(r => r.created_at >= weekStartIso);
  const prevFb   = fbs.filter(r => r.created_at <  weekStartIso);

  // Gästemappe „geöffnet" = distinkte Gäste (stay_id) mit irgendeiner Mappen-Aktivität
  // (Chat/Wunsch/Feedback) — echte Untergrenze ohne zusätzliche Tracking-Tabelle.
  const distinct = (...sets: any[][]) => {
    const s = new Set<string>();
    sets.flat().forEach(r => { if (r.stay_id) s.add(r.stay_id); });
    return s.size;
  };
  const opensThis = distinct(thisChat, thisReq, thisFb);
  const opensPrev = distinct(prevChat, prevReq, prevFb);

  const eveThis = new Set(thisChat.map(r => r.stay_id)).size;
  const evePrev = new Set(prevChat.map(r => r.stay_id)).size;

  const reqOpen = thisReq.filter(r => r.status === 'open').length;

  const allRatings = ((fbAllRes.data ?? []) as any[]).map(r => r.rating).filter((n: any) => typeof n === 'number');
  const ratingAvg = allRatings.length ? allRatings.reduce((a: number, b: number) => a + b, 0) / allRatings.length : 0;

  // Aktivitäts-Feed (gemischt, chronologisch, neueste zuerst).
  const reqText = (r: any) => r.note || (Array.isArray(r.chips) && r.chips.length ? r.chips.join(', ') : (r.occasion || 'Gästewunsch'));
  const feed = [
    ...reqs.map(r => ({ kind: 'request', text: trunc(reqText(r)), ts: r.created_at, status: (r.status === 'done' ? 'done' : r.status === 'seen' ? 'seen' : 'open'), href: `${DASHBOARD}/service` })),
    ...chat.filter(r => r.role === 'user').map(r => ({ kind: 'eve', text: trunc(r.content), ts: r.created_at, status: 'answered', href: '/eve/knowledge' })),
    ...fbs.map(r => ({ kind: 'feedback', text: trunc(r.comment || ''), ts: r.created_at, status: 'done', stars: r.rating, href: `${DASHBOARD}/feedback` })),
  ].sort((a, b) => (a.ts < b.ts ? 1 : -1)).slice(0, 7);

  const qc = ((quickRes.data ?? []) as any[])[0];
  const quick = qc ? {
    title: (qc.title_i18n && qc.title_i18n[lang]) || qc.title_de || (qc.title_i18n && qc.title_i18n.de) || 'Kachel',
    eyebrow: (qc.eyebrow_i18n && qc.eyebrow_i18n[lang]) || qc.eyebrow_de || undefined,
    cardClass: qc.card_class || 'rec-anthrazit',
  } : null;

  dl = {
    ...dl,
    summaryCount: reqs.filter(r => r.created_at >= dayStartIso).length,
    opens:    { n: opensThis, trend: calcTrend(opensThis, opensPrev) },
    eve:      { n: eveThis,   trend: calcTrend(eveThis, evePrev) },
    requests: { n: thisReq.length, open: reqOpen, trend: calcTrend(thisReq.length, prevReq.length) },
    rating:   { avg: ratingAvg, count: allRatings.length },
    activity: feed,
    quick,
  };
} catch { /* Tabelle fehlt o. ä. — Defaults (Leerzustände) greifen */ }
---

<Layout
  title="Übersicht"
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLocation={hotel.city ?? undefined}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
  userInitial={userInitial}
>
  <div data-onboarding-flow data-done={flowHidden ? '1' : undefined} style={flowHidden ? 'display:none' : undefined}>
    <OnboardingHero hotelName={hotel.name} />
    <OnboardingStep2 hotelId={hotel.id} hotelName={hotel.name} userId={user.id} />
    <OnboardingStep3 />
    <OnboardingStep5 hotelId={hotel.id} userId={user.id} />
  </div>

  <div data-dashboard>
    <DashLite
      lang={lang}
      hotelName={hotel.name}
      plan={hotelPlan}
      summaryCount={dl.summaryCount}
      opens={dl.opens}
      eve={dl.eve}
      requests={dl.requests}
      rating={dl.rating}
      activity={dl.activity}
      quick={dl.quick}
      links={dl.links}
    />
  </div>

  {!onboardingDone && (
    <script is:inline>
      // Eve einmalig aus der Hotel-Website lernen lassen (Hintergrund, idempotent via
      // hotels.eve_seeded). Fire-and-forget — blockiert nichts, kein UI-Effekt.
      (function () {
        try {
          fetch('/api/admin/eve/auto-seed', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
        } catch (e) { /* noop */ }
      })();
    </script>
  )}

  <script is:inline>
    (function () {
      var flow  = document.querySelector('[data-onboarding-flow]');
      if (!flow) return;
      // Setup bereits abgeschlossen? Pro Account in der DB (data-done) ODER lokal
      // (localStorage) → Flow nicht mehr zeigen, direkt das Dashboard. (Ohne
      // Abschluss erscheint das Setup bei jedem Besuch.)
      if (flow.getAttribute('data-done') === '1') { flow.style.display = 'none'; return; }
      // DB ist maßgeblich: sagt sie „nicht abgeschlossen" (data-done != '1'), zeigen
      // wir den Flow — und löschen einen etwaigen alten localStorage-„done"-Marker,
      // damit er den Flow nach einem Account-Reset auf Tag 1 nicht fälschlich versteckt.
      try { localStorage.removeItem('retaha-onboarding-done'); } catch (e) {}
      var steps = Array.prototype.slice.call(flow.querySelectorAll('[data-onb-step]'));

      // Setup-Step füllt die volle Bildschirmhöhe — Step-Balken sitzt unten.
      function fit(el) {
        if (!el || el.style.display === 'none') return;
        el.style.minHeight = '';
        var top = el.getBoundingClientRect().top + (window.scrollY || window.pageYOffset || 0);
        el.style.minHeight = Math.max(520, window.innerHeight - top - 32) + 'px';
      }
      function visibleStep() {
        for (var i = 0; i < steps.length; i++) {
          if (steps[i].style.display !== 'none') return steps[i];
        }
        return null;
      }
      function fitVisible() { fit(visibleStep()); }

      fitVisible();
      window.addEventListener('resize', fitVisible);

      // Gleiche „Bend-in"-Geste wie beim Laden (sanftes Fade-up).
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function enter(el) {
        if (!el || reduce) return;
        el.style.transition = 'none';
        el.style.opacity = '0';
        el.style.transform = 'translateY(12px)';
        void el.offsetWidth; // Reflow erzwingen
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        el.style.opacity = '1';
        el.style.transform = 'none';
        setTimeout(function () {
          el.style.transition = ''; el.style.transform = ''; el.style.opacity = '';
        }, 680);
      }

      // Step per Nummer zeigen (1–3 gebaut; weitere folgen). Rahmen bleibt identisch.
      function showStep(n) {
        var target = flow.querySelector('[data-onb-step="' + n + '"]');
        if (!target) return; // Step noch nicht gebaut
        steps.forEach(function (s) {
          s.style.display = (s === target ? 'flex' : 'none');
        });
        window.scrollTo({ top: 0 });
        requestAnimationFrame(function () { fit(target); enter(target); });
      }
      window.__onbGoto = showStep;
      window.__onbComplete = complete;
      // „Setup überspringen" → Flow slidet schrumpfend nach oben rechts zum
      // Account-Icon (wie in den Papierkorb), danach erscheinen Punkte am Avatar
      // und am Benachrichtigungen-Eintrag.
      var dash = document.querySelector('[data-dashboard]');
      // Punkte (Avatar/Dropdown) + den passenden Drawer-Eintrag sofort aufdecken,
      // damit die Benachrichtigung OHNE Refresh erscheint (serverseitiges Rendern
      // greift beim nächsten Laden). which = 'setup' (übersprungen) | 'qr' (abgeschlossen).
      function revealNotif(which) {
        document.querySelectorAll('[data-onb-dot]').forEach(function (d) { d.classList.add('is-on'); });
        var drawer = document.getElementById('notifDrawer');
        if (!drawer) return;
        var item = drawer.querySelector('[data-notif="' + which + '"]');
        if (item) item.hidden = false;
        var empty = drawer.querySelector('[data-notif-empty]');
        if (empty) empty.hidden = true;
      }
      function finishSkip(which) {
        flow.style.display = 'none';
        flow.style.transform = ''; flow.style.opacity = '';
        flow.style.transition = ''; flow.style.willChange = '';
        document.body.style.overflowX = '';
        window.scrollTo({ top: 0 });
        revealNotif(which);
        enter(dash);
      }
      function flyToAvatar(onDone) {
        var target = document.getElementById('userAvatar');
        if (reduce || !target) { onDone(); return; }
        var fr = flow.getBoundingClientRect();
        var tr = target.getBoundingClientRect();
        var dx = (tr.left + tr.width / 2) - (fr.left + fr.width / 2);
        var dy = (tr.top + tr.height / 2) - (fr.top + fr.height / 2);
        document.body.style.overflowX = 'hidden';
        flow.style.transformOrigin = 'center center';
        flow.style.willChange = 'transform, opacity';
        flow.style.transition = 'transform 0.62s cubic-bezier(0.5, 0, 0.2, 1), opacity 0.62s ease';
        requestAnimationFrame(function () {
          flow.style.transform = 'translate(' + dx + 'px, ' + dy + 'px) scale(0.04)';
          flow.style.opacity = '0';
        });
        setTimeout(onDone, 640);
      }
      function skip() {
        // Übersprungen, aber nicht abgeschlossen → pro Account merken (DB), damit die
        // „Setup unvollständig"-Benachrichtigung erscheint. Best effort.
        try { fetch('/api/admin/onboarding/skip', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}', keepalive: true }); } catch (e) {}
        flyToAvatar(function () { finishSkip('setup'); });
      }

      // „Setup überspringen".
      document.querySelectorAll('[data-onb-action="skip"]').forEach(function (b) {
        b.addEventListener('click', function (e) { e.preventDefault(); skip(); });
      });
      // „Mach's komplett" (Abschluss) → fliegt wie Skip zum Account-Icon, parkt die
      // QR-Bestell-Benachrichtigung und merkt sich den Abschluss (Setup kommt nicht
      // wieder). Die Einstellungen erledigt der Hotelier danach im Dashboard.
      function complete() {
        try {
          localStorage.setItem('retaha-onboarding-done', '1');
          localStorage.setItem('retaha-qr-notif', '1');
        } catch (e) {}
        // Pro Account in der DB merken (cross-device) — best effort.
        try { fetch('/api/admin/onboarding/complete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}', keepalive: true }); } catch (e) {}
        flyToAvatar(function () { finishSkip('qr'); });
      }
      document.querySelectorAll('[data-onb-action="finish"]').forEach(function (b) {
        b.addEventListener('click', function (e) { e.preventDefault(); complete(); });
      });
      // „Weiter"-Buttons + Step-Balken-Segmente: zum Ziel-Step springen.
      // Nur gebaute Steps sind klickbar; auf noch nicht gebaute → disabled.
      document.querySelectorAll('[data-onb-goto]').forEach(function (el) {
        var n = parseInt(el.getAttribute('data-onb-goto') || '0', 10);
        if (!flow.querySelector('[data-onb-step="' + n + '"]')) {
          el.setAttribute('disabled', '');
          return;
        }
        el.addEventListener('click', function (e) { e.preventDefault(); showStep(n); });
      });
    })();
  </script>
</Layout>
