---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/locale');

const supabase = createSupabaseServiceRoleInstance();

const { data: settings } = await supabase
  .from('hotel_settings')
  .select('features, service_items, service_hours, service_start_time, service_end_time')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || ({} as Record<string, any>);
const features   = ((s.features as Record<string, unknown>) ?? {});
const serviceOn  = features.service !== false;
const startTime  = ((s.service_start_time as string | undefined) || '08:00').substring(0, 5);
const endTime    = ((s.service_end_time   as string | undefined) || '22:00').substring(0, 5);

const WEEK_DAYS = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'] as const;
const rawServiceHours = (s.service_hours as Record<string, any> | null | undefined) ?? null;
const initialHours: Record<string, { start: string; end: string; closed: boolean }> = {};
for (const day of WEEK_DAYS) {
  const bh = rawServiceHours?.[day];
  initialHours[day] = {
    start:  (bh?.start  as string  | undefined) || startTime,
    end:    (bh?.end    as string  | undefined) || endTime,
    closed: bh?.closed === true,
  };
}

const items = ((s.service_items as any[]) ?? []);

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';
---

<Layout title="Service-Items" activeTab="backoffice" hotelName={hotel.name}>

<script is:inline define:vars={{ _siInit: { hours: initialHours, items, serviceOn } }}>
  window._siInit = _siInit;
</script>

<style is:global>
[x-cloak] { display: none !important; }
textarea.s-input { resize: none; min-height: 72px; }
.settings-page .toggle-row { min-height: 44px; }

/* suppress browser autofill yellow */
input:-webkit-autofill,
input:-webkit-autofill:focus {
  -webkit-box-shadow: 0 0 0 1000px var(--bg, #FAFAF8) inset !important;
  -webkit-text-fill-color: var(--ink, #0A0A0A) !important;
  transition: background-color 9999s ease;
}

/* hours grid — same as .bp-hours-* from breakfast */
.sp-hours-grid { border: 1px solid var(--border); border-radius: var(--r-sm, 4px); overflow: hidden; margin-bottom: 16px; }
.sp-hours-row { display: grid; grid-template-columns: 44px 1fr auto; gap: 12px; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); min-height: 52px; }
.sp-hours-row:last-child { border-bottom: none; }
.sp-hours-row--closed { opacity: 0.6; }
.sp-hours-day { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink); }
.sp-hours-inputs { display: flex; align-items: center; gap: 6px; }
.sp-hours-sep { font-size: 13px; color: var(--ink-muted); flex-shrink: 0; }
.sp-hours-closed-txt { font-size: 12px; color: var(--ink-muted); font-style: italic; }
.s-input--time { width: 110px; min-width: 88px; }
@media (max-width: 480px) {
  .s-input--time { width: 88px; }
  .sp-hours-row { grid-template-columns: 36px 1fr auto; gap: 8px; padding: 8px 10px; }
}

/* items list */
.sp-row { border: 1px solid var(--border); padding: 20px; margin-bottom: 12px; }
.sp-row:last-child { margin-bottom: 0; }
.sp-row__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.sp-row__num {
  font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500;
  letter-spacing: 0.12em; color: var(--ink-muted); background: var(--bg-deep); padding: 3px 8px;
}
.sp-grid { display: grid; gap: 12px; margin-bottom: 12px; }
.sp-grid--2 { grid-template-columns: 1fr 1fr; }
@media (max-width: 600px) { .sp-grid--2 { grid-template-columns: 1fr; } }
.sp-field { display: flex; flex-direction: column; gap: 5px; }
.sp-label { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: var(--ink-muted); text-transform: uppercase; }
.sp-label--mono { font-family: 'JetBrains Mono', monospace; }
.sp-mono { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
.sp-textarea { min-height: 62px; resize: vertical; }
.sp-empty { font-size: 13px; color: var(--ink-muted); padding: 48px 32px; text-align: center; font-style: italic; }
.sp-footer { display: flex; gap: 12px; justify-content: flex-end; padding-top: 16px; }

/* toast — same as breakfast bp-toast */
.bp-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 1000; padding: 12px 24px; border-radius: var(--r, 8px); font-size: 13px; font-weight: 500; box-shadow: 0 8px 24px rgba(0,0,0,0.14); white-space: nowrap; pointer-events: none; }
.bp-toast--ok  { background: #0A0A0A; color: white; }
.bp-toast--err { background: #8C2128; color: white; }
</style>

<div class="settings-page">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">Service-Items</span>
  </nav>

  <section class="settings-hero">
    <span class="settings-hero__eyebrow">Service-Modul</span>
    <h1 class="settings-hero__title">Service-Anfragen<span class="dot-pink">.</span></h1>
    <p class="settings-hero__sub">Zeiten und Items, die Gäste im Check-in anfordern können.</p>
  </section>

  <div class="settings-sections">

    <!-- 01 Modul-Status -->
    <section class="s-card">
      <div class="s-card__head">
        <h2 class="s-card__title">Service-Modul</h2>
        <span class="s-card__num">01</span>
      </div>
      <div class="s-card__body">
        <p class="field__hint">Ein/Aus wird in der Gäste-App-Vorschau gesteuert.</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={serviceOn} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">
            In der Gäste-App-Vorschau steuern →
          </a>
        </div>
      </div>
    </section>

    <!-- 02 Service-Zeiten (pro Wochentag) -->
    <section class="s-card">
      <div class="s-card__head">
        <h2 class="s-card__title">Service-Zeiten</h2>
        <span class="s-card__num">02</span>
      </div>
      <div x-data="siHours()">
        <div class="s-card__body">
          <p class="field__hint">Buchbare Zeitfenster pro Wochentag — geschlossene Tage zeigen keine Service-Option.</p>
          <div class="sp-hours-grid">
            <template x-for="d in days" :key="d.key">
              <div class="sp-hours-row" :class="{'sp-hours-row--closed': hours[d.key].closed}">
                <span class="sp-hours-day" x-text="d.label"></span>
                <div class="sp-hours-inputs">
                  <input type="time" class="s-input s-input--time"
                    x-show="!hours[d.key].closed"
                    :value="hours[d.key].start"
                    @change="hours[d.key].start = $event.target.value" />
                  <span class="sp-hours-sep" x-show="!hours[d.key].closed">–</span>
                  <input type="time" class="s-input s-input--time"
                    x-show="!hours[d.key].closed"
                    :value="hours[d.key].end"
                    @change="hours[d.key].end = $event.target.value" />
                  <span x-show="hours[d.key].closed" class="sp-hours-closed-txt">Geschlossen</span>
                </div>
                <label class="toggle-row" style="margin:0;gap:6px">
                  <input type="checkbox"
                    :checked="hours[d.key].closed"
                    @change="hours[d.key].closed = $event.target.checked"
                    class="sr-only" />
                  <span class="bt-visual" :class="{'is-checked': hours[d.key].closed}">
                    <span class="bt-knob"></span>
                  </span>
                  <span class="toggle-label" style="font-size:11px;color:var(--ink-muted)">Zu</span>
                </label>
              </div>
            </template>
          </div>
          <div style="margin-bottom:8px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <button type="button" @click="copyMonToAll()" class="v9-btn v9-btn--ghost" style="font-size:10px;padding:6px 12px">
              Auf alle Tage übernehmen
            </button>
            <span style="font-size:12px;color:var(--ink-muted)">Montag-Zeiten auf alle Tage</span>
          </div>
        </div>
        <div class="s-card__footer">
          <span x-show="error" x-cloak class="s-flash s-flash--err" style="margin:0;padding:8px 12px" x-text="error"></span>
          <span x-show="success" x-cloak class="s-flash s-flash--ok" style="margin:0;padding:8px 12px">✓ Gespeichert</span>
          <button type="button" @click="save()" :disabled="saving" class="v9-btn">Speichern</button>
        </div>
      </div>
    </section>

  </div><!-- /.settings-sections -->

  <!-- 03 Service-Items -->
  <section class="s-card" style="margin-top:20px" x-data="siItems()">
    <div class="s-card__head" style="align-items:center">
      <div>
        <span class="s-card__num" style="display:block;margin-bottom:6px">Service-Items</span>
        <h2 class="s-card__title">Was Gäste anfragen können<span class="dot-pink">.</span></h2>
      </div>
      <button type="button" @click="addItem()" class="v9-btn" style="flex-shrink:0">+ Item hinzufügen</button>
    </div>

    <div class="s-card__body">
      <p class="field__hint" style="margin-bottom:16px">Jedes Item erscheint als Kachel in der Service-Anfrage der Gäste-App (nur für In-House-Gäste sichtbar).</p>

      <template x-if="items.length === 0">
        <div class="sp-empty">
          <p>Noch keine Service-Items. Klicke auf „+ Item hinzufügen".</p>
          <button type="button" @click="addItem()" class="v9-btn" style="margin-top:14px">Erstes Item anlegen</button>
        </div>
      </template>

      <template x-if="items.length > 0">
        <div>
          <template x-for="(item, idx) in items" :key="item._key">
            <div class="sp-row">
              <div class="sp-row__head">
                <span class="sp-row__num" x-text="String(idx + 1).padStart(2, '0')"></span>
                <button type="button" @click="removeItem(idx)"
                  class="v9-btn v9-btn--ghost" style="font-size:11px">Entfernen</button>
              </div>
              <div class="sp-grid sp-grid--2">
                <label class="sp-field">
                  <span class="sp-label sp-label--mono">Slug (id)</span>
                  <input type="text" x-model.lazy="item.id"
                    placeholder="z.B. extra-towels" autocomplete="off"
                    class="s-input sp-mono" />
                </label>
                <label class="sp-field">
                  <span class="sp-label sp-label--mono">Icon-Key</span>
                  <input type="text" x-model.lazy="item.icon"
                    placeholder="towels" autocomplete="off"
                    class="s-input sp-mono" />
                </label>
              </div>
              <div class="sp-grid sp-grid--2">
                <label class="sp-field">
                  <span class="sp-label">Name (DE)</span>
                  <input type="text" x-model.lazy="item.name_de"
                    autocomplete="off" class="s-input" />
                </label>
                <label class="sp-field">
                  <span class="sp-label">Name (EN)</span>
                  <input type="text" x-model.lazy="item.name_en"
                    autocomplete="off" class="s-input" />
                </label>
              </div>
              <div class="sp-grid sp-grid--2">
                <label class="sp-field">
                  <span class="sp-label">Beschreibung (DE)</span>
                  <textarea x-model.lazy="item.description_de"
                    rows="2" autocomplete="off"
                    class="s-input sp-textarea"></textarea>
                </label>
                <label class="sp-field">
                  <span class="sp-label">Beschreibung (EN)</span>
                  <textarea x-model.lazy="item.description_en"
                    rows="2" autocomplete="off"
                    class="s-input sp-textarea"></textarea>
                </label>
              </div>
            </div>
          </template>
        </div>
      </template>
    </div>

    <div class="s-card__footer" style="gap:12px">
      <button type="button" @click="addItem()" class="v9-btn v9-btn--ghost">+ Item hinzufügen</button>
      <button type="button" @click="saveItems()" :disabled="saving" class="v9-btn">
        <span x-show="!saving">Items speichern</span>
        <span x-show="saving" x-cloak>Speichert …</span>
      </button>
    </div>

    <div x-show="toast" x-cloak :class="'bp-toast bp-toast--' + toastKind" x-text="toast"></div>
  </section>

</div><!-- /.settings-page -->

<script>
  document.addEventListener('alpine:init', () => {

    Alpine.data('siHours', () => {
      const init = (window as any)._siInit || {};
      return {
        hours: init.hours || {},
        saving: false,
        success: false,
        error: '',
        _origStr: '',
        _timer: null as ReturnType<typeof setTimeout> | null,
        _beforeUnload: null as ((e: BeforeUnloadEvent) => void) | null,

        days: [
          { key: 'mon', label: 'Mo' },
          { key: 'tue', label: 'Di' },
          { key: 'wed', label: 'Mi' },
          { key: 'thu', label: 'Do' },
          { key: 'fri', label: 'Fr' },
          { key: 'sat', label: 'Sa' },
          { key: 'sun', label: 'So' },
        ],

        init() {
          this._origStr = JSON.stringify(this.hours);
          this._beforeUnload = (e: BeforeUnloadEvent) => {
            if (this.isDirty) { e.preventDefault(); e.returnValue = ''; }
          };
          window.addEventListener('beforeunload', this._beforeUnload);
        },

        destroy() {
          if (this._beforeUnload) window.removeEventListener('beforeunload', this._beforeUnload);
        },

        get isDirty(): boolean {
          return JSON.stringify(this.hours) !== this._origStr;
        },

        copyMonToAll() {
          const src = this.hours['mon'];
          if (!src || src.closed) return;
          this.days.forEach((d: { key: string }) => {
            this.hours[d.key] = { ...this.hours[d.key], start: src.start, end: src.end };
          });
        },

        async save() {
          if (!this.isDirty || this.saving) return;
          this.saving = true;
          this.success = false;
          this.error = '';
          if (this._timer) clearTimeout(this._timer);
          try {
            const res = await fetch('/api/admin/service/section', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ section: 'hours', service_hours: this.hours }),
            });
            const d = await res.json();
            if (!d.ok) { this.error = d.error || 'Fehler'; return; }
            this.success = true;
            this._origStr = JSON.stringify(this.hours);
            this._timer = setTimeout(() => { this.success = false; }, 3000);
          } catch {
            this.error = 'Netzwerk-Fehler';
          } finally {
            this.saving = false;
          }
        },
      };
    });

    Alpine.data('siItems', () => {
      const init = (window as any)._siInit || {};
      const raw = (init.items || []) as Record<string, unknown>[];
      return {
        items: raw.map((item, idx) => ({ _key: idx, ...item })) as Record<string, unknown>[],
        _nextKey: raw.length as number,
        saving: false,
        toast: '',
        toastKind: 'ok',
        _toastTimer: null as ReturnType<typeof setTimeout> | null,

        addItem() {
          (this.items as Record<string, unknown>[]).push({
            _key: (this._nextKey as number)++,
            id: '', name_de: '', name_en: '',
            description_de: '', description_en: '', icon: 'default',
          });
        },

        removeItem(idx: number) {
          if (confirm('Item wirklich entfernen?')) {
            (this.items as unknown[]).splice(idx, 1);
          }
        },

        async saveItems() {
          if (this.saving) return;
          this.saving = true;
          try {
            const payload = (this.items as Record<string, unknown>[]).map(
              ({ _key, ...rest }) => rest,
            );
            const res = await fetch('/api/admin/service/section', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ section: 'items', service_items: payload }),
            });
            const d = await res.json();
            if (d.ok) {
              this.showToast(`✓ ${payload.length} Item${payload.length !== 1 ? 's' : ''} gespeichert`, 'ok');
            } else {
              this.showToast(d.error || 'Fehler beim Speichern', 'err');
            }
          } catch {
            this.showToast('Netzwerk-Fehler', 'err');
          } finally {
            this.saving = false;
          }
        },

        showToast(msg: string, kind: string) {
          this.toast = msg;
          this.toastKind = kind;
          if (this._toastTimer) clearTimeout(this._toastTimer);
          this._toastTimer = setTimeout(() => { this.toast = ''; }, 3000);
        },
      };
    });

  });
</script>

</Layout>
