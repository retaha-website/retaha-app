---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const supabase = createSupabaseServiceRoleInstance();

// Split into two queries so a missing service_hours column never silences service_items.
const [{ data: settings }, { data: hoursRow }, { data: hotelRow }] = await Promise.all([
  supabase
    .from('hotel_settings')
    .select('features, service_items, service_start_time, service_end_time')
    .eq('hotel_id', hotel.id)
    .maybeSingle(),
  supabase
    .from('hotel_settings')
    .select('service_hours')
    .eq('hotel_id', hotel.id)
    .maybeSingle(),
  supabase
    .from('hotels')
    .select('default_language')
    .eq('id', hotel.id)
    .maybeSingle(),
]);

const s = settings || ({} as Record<string, any>);
const features  = ((s.features as Record<string, unknown>) ?? {});
const serviceOn = features.service !== false;
const startTime = ((s.service_start_time as string | undefined) || '08:00').substring(0, 5);
const endTime   = ((s.service_end_time   as string | undefined) || '22:00').substring(0, 5);

const WEEK_DAYS = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'] as const;
const rawServiceHours = ((hoursRow?.service_hours) as Record<string, any> | null | undefined) ?? null;
const initialHours: Record<string, { start: string; end: string; closed: boolean }> = {};
for (const day of WEEK_DAYS) {
  const bh = rawServiceHours?.[day];
  initialHours[day] = {
    start:  (bh?.start  as string  | undefined) || startTime,
    end:    (bh?.end    as string  | undefined) || endTime,
    closed: bh?.closed === true,
  };
}

const defaultLang = (hotelRow?.default_language as string | undefined) || 'de';
const LANG_LABELS: Record<string, string> = { de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español' };
const langLabel = LANG_LABELS[defaultLang] ?? 'Deutsch';

const rawItems = ((s.service_items as any[]) ?? []);
const itemsDisplay = rawItems.map((item: any) => ({
  _orig_id:    item.id || '',
  name:        item[`name_${defaultLang}`] || item.name_de || '',
  description: item[`description_${defaultLang}`] || item.description_de || '',
  icon:        item.icon || 'bell',
}));

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

// Client-Strings für die Alpine-Komponenten (via window._siInit.t)
const siT = {
  error: bt('si.js.error', lang),
  saved: bt('common.savedshort', lang),
  netErr: bt('si.js.neterr', lang),
  removeConfirm: bt('si.js.removeconfirm', lang),
  remove: bt('common.remove', lang),
  nameEmpty: bt('si.js.nameempty', lang),
  itemsSaved1: bt('si.js.itemsaved.one', lang),
  itemsSavedN: bt('si.js.itemsaved.many', lang),
  saveError: bt('si.js.saveerror', lang),
};
const siIconLabels: Record<string, string> = {
  bell:      bt('si.icon.bell', lang),
  coffee:    bt('si.icon.coffee', lang),
  clock:     bt('si.icon.clock', lang),
  key:       bt('si.icon.key', lang),
  briefcase: bt('si.icon.briefcase', lang),
  car:       bt('si.icon.car', lang),
  droplet:   bt('si.icon.droplet', lang),
  moon:      bt('si.icon.moon', lang),
  sun:       bt('si.icon.sun', lang),
  layers:    bt('si.icon.layers', lang),
};
const siDayLabels = {
  mon: bt('si.day.mon', lang), tue: bt('si.day.tue', lang), wed: bt('si.day.wed', lang),
  thu: bt('si.day.thu', lang), fri: bt('si.day.fri', lang), sat: bt('si.day.sat', lang), sun: bt('si.day.sun', lang),
};
---

<Layout title="Service-Items" activeTab="backoffice" hotelName={hotel.name}>

<script is:inline define:vars={{ _siInit: { hours: initialHours, items: itemsDisplay, serviceOn, defaultLang, langLabel, t: siT, iconLabels: siIconLabels, dayLabels: siDayLabels } }}>
  window._siInit = _siInit;
</script>

<style is:global>
[x-cloak] { display: none !important; }
.settings-page .toggle-row { min-height: 44px; }

input:-webkit-autofill,
input:-webkit-autofill:focus {
  -webkit-box-shadow: 0 0 0 1000px var(--bg, #FAFAF8) inset !important;
  -webkit-text-fill-color: var(--ink, #0A0A0A) !important;
  transition: background-color 9999s ease;
}

.sp-hours-grid { border: 1px solid var(--border); border-radius: var(--r-sm, 4px); overflow: hidden; margin-bottom: 16px; }
.sp-hours-row { display: grid; grid-template-columns: 44px 1fr auto; gap: 12px; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); min-height: 52px; }
.sp-hours-row:last-child { border-bottom: none; }
.sp-hours-row--closed { opacity: 0.6; }
.sp-hours-day { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink); }
.sp-hours-inputs { display: flex; align-items: center; gap: 6px; }
.sp-hours-sep { font-size: 13px; color: var(--ink-muted); flex-shrink: 0; }
.sp-hours-closed-txt { font-size: 12px; color: var(--ink-muted); font-style: italic; }
.s-input--time { width: 110px; min-width: 88px; }
@media (max-width: 480px) {
  .s-input--time { width: 88px; }
  .sp-hours-row { grid-template-columns: 36px 1fr auto; gap: 8px; padding: 8px 10px; }
}

.sp-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
.sp-field:last-child { margin-bottom: 0; }
.sp-label { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: var(--ink-muted); text-transform: uppercase; }
.sp-label-hint { font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 10px; opacity: 0.7; }
.sp-textarea { min-height: 62px; resize: vertical; }
.sp-empty { font-size: 13px; color: var(--ink-muted); padding: 48px 32px; text-align: center; font-style: italic; }

.sp-icon-grid { display: flex; flex-wrap: wrap; gap: 6px; }
.sp-icon-btn {
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  padding: 8px 6px; min-width: 52px;
  border: 1px solid var(--border); border-radius: var(--r-sm, 4px);
  background: transparent; cursor: pointer;
  transition: border-color 0.12s, background 0.12s;
}
.sp-icon-btn:hover { border-color: var(--ink-muted); }
.sp-icon-btn.is-active { border-color: var(--accent, #C06A3C); background: rgba(192, 106, 60, 0.08); }
.sp-icon-btn svg { color: var(--ink-muted); }
.sp-icon-btn.is-active svg { color: var(--accent, #C06A3C); }
.sp-icon-name { font-size: 9px; color: var(--ink-muted); text-align: center; line-height: 1.2; white-space: nowrap; }
.sp-icon-btn.is-active .sp-icon-name { color: var(--accent, #C06A3C); }

/* ── Items card grid ───────────────────────────────────────────────────────── */
.si-cards-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
}
@media (max-width: 640px) { .si-cards-grid { grid-template-columns: 1fr; } }

.si-card {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px;
  border: 1px solid var(--border); border-radius: var(--r, 8px);
  background: var(--surface);
  transition: border-color .12s, box-shadow .12s;
}
.si-card:hover { border-color: #D8D3C8; box-shadow: 0 2px 8px rgba(10,10,10,.05); }
.si-card--editing {
  border-color: var(--accent, #C06A3C);
  background: rgba(192, 106, 60, 0.04);
}

.si-card__icon {
  width: 40px; height: 40px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-deep, #F0EDE6); border-radius: 10px;
  color: var(--ink-muted);
}
.si-card__body { flex: 1; min-width: 0; }
.si-card__name { font-size: 13px; font-weight: 500; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.si-card__desc { font-size: 11px; color: var(--ink-muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.si-card__actions { display: flex; gap: 4px; flex-shrink: 0; }
.si-card__btn {
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border); border-radius: 7px;
  background: none; cursor: pointer; color: var(--ink-muted);
  transition: background .1s, border-color .1s, color .1s;
}
.si-card__btn:hover { background: var(--bg-deep); border-color: var(--border-medium); color: var(--ink); }
.si-card__btn--danger:hover { background: #8C2128; border-color: #8C2128; color: #fff; }
.si-card__btn svg { width: 14px; height: 14px; pointer-events: none; }

/* ── Edit / Add form panel ─────────────────────────────────────────────────── */
.si-edit-form {
  margin-top: 16px;
  border: 1px solid var(--border); border-radius: var(--r, 8px);
  padding: 16px; background: var(--bg-deep, #F0EDE6);
}
.si-edit-form__head { margin-bottom: 14px; }
.si-edit-form__title { font-size: 13px; font-weight: 600; color: var(--ink); font-family: 'Space Grotesk', sans-serif; }
.si-edit-form__actions { display: flex; gap: 8px; margin-top: 16px; justify-content: flex-end; }
/* ── /Items ────────────────────────────────────────────────────────────────── */
</style>

<div class="settings-page">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/uebersicht" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('si.breadcrumb', lang)}</span>
  </nav>

  <section class="settings-hero">
    <span class="settings-hero__eyebrow">{bt('si.hero.eyebrow', lang)}</span>
    <h1 class="settings-hero__title" set:html={bt('si.hero.title', lang)}></h1>
    <p class="settings-hero__sub">{bt('si.hero.sub', lang)}</p>
  </section>

  <div class="settings-sections">

    <!-- 01 Modul-Status -->
    <section class="s-card">
      <div class="s-card__head">
        <h2 class="s-card__title">{bt('si.mod.title', lang)}</h2>
        <span class="s-card__num">01</span>
      </div>
      <div class="s-card__body">
        <p class="field__hint">{bt('si.mod.hint', lang)}</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={serviceOn} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">
            {bt('si.mod.link', lang)}
          </a>
        </div>
      </div>
    </section>

    <!-- 02 Service-Zeiten (pro Wochentag) -->
    <section class="s-card">
      <div class="s-card__head">
        <h2 class="s-card__title">{bt('si.hours.title', lang)}</h2>
        <span class="s-card__num">02</span>
      </div>
      <div x-data="siHours()">
        <div class="s-card__body">
          <p class="field__hint">{bt('si.hours.hint', lang)}</p>
          <div class="sp-hours-grid">
            <template x-for="d in days" :key="d.key">
              <div class="sp-hours-row" :class="{'sp-hours-row--closed': hours[d.key].closed}">
                <span class="sp-hours-day" x-text="d.label"></span>
                <div class="sp-hours-inputs">
                  <input type="time" class="s-input s-input--time"
                    x-show="!hours[d.key].closed"
                    :value="hours[d.key].start"
                    @change="hours[d.key].start = $event.target.value" />
                  <span class="sp-hours-sep" x-show="!hours[d.key].closed">–</span>
                  <input type="time" class="s-input s-input--time"
                    x-show="!hours[d.key].closed"
                    :value="hours[d.key].end"
                    @change="hours[d.key].end = $event.target.value" />
                  <span x-show="hours[d.key].closed" class="sp-hours-closed-txt">{bt('si.hours.closed', lang)}</span>
                </div>
                <label class="toggle-row" style="margin:0;gap:6px">
                  <input type="checkbox"
                    :checked="hours[d.key].closed"
                    @change="hours[d.key].closed = $event.target.checked"
                    class="sr-only" />
                  <span class="bt-visual" :class="{'is-checked': hours[d.key].closed}">
                    <span class="bt-knob"></span>
                  </span>
                  <span class="toggle-label" style="font-size:11px;color:var(--ink-muted)">{bt('si.hours.closetoggle', lang)}</span>
                </label>
              </div>
            </template>
          </div>
          <div style="margin-bottom:16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
            <button type="button" @click="copyMonToAll()" class="v9-btn v9-btn--ghost" style="font-size:10px;padding:6px 12px">
              {bt('si.hours.copyall', lang)}
            </button>
            <span style="font-size:12px;color:var(--ink-muted)">{bt('si.hours.copyallhint', lang)}</span>
          </div>
        </div>
        <div class="s-card__footer">
          <button type="button" @click="save()" :disabled="saving" class="v9-btn">{bt('common.save', lang)}</button>
        </div>
      </div>
    </section>

  </div><!-- /.settings-sections -->

  <!-- 03 Service-Items -->
  <section class="s-card" id="service-items" style="margin-top:20px" x-data="siItems()">
    <div class="s-card__head" style="align-items:center">
      <div>
        <span class="s-card__num" style="display:block;margin-bottom:6px">{bt('si.breadcrumb', lang)}</span>
        <h2 class="s-card__title" set:html={bt('si.items.title', lang)}></h2>
      </div>
      <button type="button" @click="openAdd()" x-show="editingItem === null" class="v9-btn" style="flex-shrink:0">
        {bt('si.items.add', lang)}
      </button>
    </div>

    <div class="s-card__body">
      <p class="field__hint">
        {bt('si.items.langhint.pre', lang)} <strong x-text="langLabel"></strong> {bt('si.items.langhint.post', lang)}
      </p>

      <!-- Empty state: no items and no form open -->
      <template x-if="items.length === 0 && editingItem === null">
        <div class="sp-empty">
          <p>{bt('si.items.empty', lang)}</p>
          <button type="button" @click="openAdd()" class="v9-btn" style="margin-top:14px">{bt('si.items.first', lang)}</button>
        </div>
      </template>

      <!-- Cards overview -->
      <template x-if="items.length > 0">
        <div class="si-cards-grid">
          <template x-for="item in items" :key="item._key">
            <div class="si-card" :class="{ 'si-card--editing': editingKey === item._key }">
              <div class="si-card__icon">
                <span x-html="iconHtml(String(item.icon))"></span>
              </div>
              <div class="si-card__body">
                <div class="si-card__name" x-text={`item.name || ${JSON.stringify(bt('si.items.noname', lang))}`}></div>
                <div class="si-card__desc" x-show="item.description" x-text="String(item.description)"></div>
              </div>
              <div class="si-card__actions">
                <button type="button" class="si-card__btn" @click="openEdit(item)"
                  title={bt('si.items.edit', lang)} :aria-label={`${JSON.stringify(bt('si.items.edit', lang))} + ': ' + item.name`}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
                </button>
                <button type="button" class="si-card__btn si-card__btn--danger" @click="removeItem(item._key)"
                  title={bt('common.remove', lang)} :aria-label={`${JSON.stringify(bt('common.remove', lang))} + ': ' + item.name`}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/></svg>
                </button>
              </div>
            </div>
          </template>
        </div>
      </template>

      <!-- Add / Edit form — only when editingItem !== null -->
      <template x-if="editingItem !== null">
        <div class="si-edit-form">
          <div class="si-edit-form__head">
            <span class="si-edit-form__title" x-text={`editingKey === null ? ${JSON.stringify(bt('si.items.new', lang))} : ${JSON.stringify(bt('si.items.editform', lang))}`}></span>
          </div>

          <label class="sp-field">
            <span class="sp-label">
              {bt('si.items.name', lang)}
              <span class="sp-label-hint" x-text="'(' + langLabel + ')'"></span>
            </span>
            <input type="text" x-model.lazy="editingItem.name"
              autocomplete="off" class="s-input" />
          </label>

          <label class="sp-field">
            <span class="sp-label">
              {bt('si.items.desc', lang)}
              <span class="sp-label-hint">{bt('si.items.optional', lang)}</span>
            </span>
            <textarea x-model.lazy="editingItem.description"
              rows="2" autocomplete="off"
              class="s-input sp-textarea"></textarea>
          </label>

          <div class="sp-field">
            <span class="sp-label">{bt('si.items.iconlabel', lang)}</span>
            <div class="sp-icon-grid">
              <template x-for="ico in serviceIcons" :key="ico.key">
                <button type="button"
                  class="sp-icon-btn"
                  :class="{ 'is-active': editingItem.icon === ico.key }"
                  @click.stop="editingItem.icon = ico.key"
                  :title="ico.label"
                  :aria-pressed="String(editingItem.icon === ico.key)">
                  <span x-html="ico.svgHtml"></span>
                  <span class="sp-icon-name" x-text="ico.label"></span>
                </button>
              </template>
            </div>
          </div>

          <div class="si-edit-form__actions">
            <button type="button" @click="cancelEdit()" class="v9-btn v9-btn--ghost">{bt('common.cancel', lang)}</button>
            <button type="button" @click="saveEdit()" :disabled="saving" class="v9-btn">
              <span x-show="!saving">{bt('common.save', lang)}</span>
              <span x-show="saving" x-cloak>{bt('si.items.saving', lang)}</span>
            </button>
          </div>
        </div>
      </template>
    </div>

    <!-- Footer add button — only visible when no form is open -->
    <div class="s-card__footer" x-show="editingItem === null" style="gap:12px">
      <button type="button" @click="openAdd()" class="v9-btn v9-btn--ghost">{bt('si.items.add', lang)}</button>
    </div>
  </section>

</div><!-- /.settings-page -->

<script>
  function mkSvg(paths) {
    return '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">' + paths + '</svg>';
  }

  const SERVICE_ICONS = [
    { key: 'bell',      label: 'Glocke',     svgHtml: mkSvg('<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>') },
    { key: 'coffee',    label: 'Kaffee',     svgHtml: mkSvg('<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>') },
    { key: 'clock',     label: 'Weckruf',    svgHtml: mkSvg('<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>') },
    { key: 'key',       label: 'Check-out',  svgHtml: mkSvg('<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>') },
    { key: 'briefcase', label: 'Gepäck',     svgHtml: mkSvg('<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>') },
    { key: 'car',       label: 'Taxi',       svgHtml: mkSvg('<rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>') },
    { key: 'droplet',   label: 'Handtücher', svgHtml: mkSvg('<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>') },
    { key: 'moon',      label: 'Kissen',     svgHtml: mkSvg('<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>') },
    { key: 'sun',       label: 'Reinigung',  svgHtml: mkSvg('<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>') },
    { key: 'layers',    label: 'Sonstiges',  svgHtml: mkSvg('<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>') },
  ];

  document.addEventListener('alpine:init', function () {
    var A = window.Alpine;
    if (!A) return;

    A.data('siHours', function () {
      var init = window._siInit || {};
      var dl = init.dayLabels || {};
      var t = init.t || {};
      return {
        hours: init.hours || {},
        saving: false,
        success: false,
        error: '',
        _origStr: '',
        _timer: null,
        _beforeUnload: null,

        days: [
          { key: 'mon', label: dl.mon || 'Mo' },
          { key: 'tue', label: dl.tue || 'Di' },
          { key: 'wed', label: dl.wed || 'Mi' },
          { key: 'thu', label: dl.thu || 'Do' },
          { key: 'fri', label: dl.fri || 'Fr' },
          { key: 'sat', label: dl.sat || 'Sa' },
          { key: 'sun', label: dl.sun || 'So' },
        ],

        init: function () {
          var self = this;
          this._origStr = JSON.stringify(this.hours);
          this._beforeUnload = function (e) {
            if (self.isDirty) { e.preventDefault(); e.returnValue = ''; }
          };
          window.addEventListener('beforeunload', this._beforeUnload);
        },

        destroy: function () {
          if (this._beforeUnload) window.removeEventListener('beforeunload', this._beforeUnload);
        },

        get isDirty() {
          return JSON.stringify(this.hours) !== this._origStr;
        },

        copyMonToAll: function () {
          var src = this.hours['mon'];
          if (!src || src.closed) return;
          this.days.forEach(function (d) {
            this.hours[d.key] = Object.assign({}, this.hours[d.key], { start: src.start, end: src.end });
          }, this);
        },

        save: async function () {
          if (!this.isDirty || this.saving) return;
          this.saving = true;
          this.success = false;
          this.error = '';
          if (this._timer) clearTimeout(this._timer);
          try {
            var res = await fetch('/api/admin/service/section', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ section: 'hours', service_hours: this.hours }),
            });
            var d = await res.json();
            if (!d.ok) {
              this.error = d.error || t.error;
              (window as any).retahaToast?.(this.error, 'error');
              return;
            }
            this.success = false;
            this._origStr = JSON.stringify(this.hours);
            (window as any).retahaToast?.(t.saved);
          } catch (err) {
            this.error = t.netErr;
            (window as any).retahaToast?.(this.error, 'error');
          } finally {
            this.saving = false;
          }
        },
      };
    });

    A.data('siItems', function () {
      var init = window._siInit || {};
      var raw = init.items || [];
      var t = init.t || {};
      return {
        items: raw.map(function (item, idx) { return Object.assign({ _key: idx }, item); }),
        _nextKey: raw.length,
        defaultLang: init.defaultLang || 'de',
        langLabel:   init.langLabel   || 'Deutsch',

        editingItem: null,
        editingKey: null,

        saving: false,
        serviceIcons: SERVICE_ICONS.map(function (i) { return Object.assign({}, i, { label: (init.iconLabels && init.iconLabels[i.key]) || i.label }); }),

        iconHtml: function (key) {
          var ico = SERVICE_ICONS.find(function (i) { return i.key === key; });
          return ico ? ico.svgHtml : SERVICE_ICONS[0].svgHtml;
        },

        openAdd: function () {
          this.editingItem = { _key: this._nextKey++, _orig_id: '', name: '', description: '', icon: 'bell' };
          this.editingKey = null;
        },

        openEdit: function (item) {
          this.editingItem = Object.assign({}, item);
          this.editingKey = item._key;
        },

        cancelEdit: function () {
          this.editingItem = null;
          this.editingKey = null;
        },

        removeItem: function (key) {
          var self = this;
          this.$store.confirm.ask(
            t.removeConfirm,
            async function () {
              self.items = self.items.filter(function (it) { return it._key !== key; });
              await self._persistItems();
            },
            t.remove,
          );
        },

        saveEdit: async function () {
          if (this.saving || !this.editingItem) return;
          if (!String(this.editingItem.name || '').trim()) {
            this.showToast(t.nameEmpty, 'err');
            return;
          }

          if (this.editingKey === null) {
            this.items.push(Object.assign({}, this.editingItem));
          } else {
            var idx = this.items.findIndex(function (it) { return it._key === this.editingKey; }, this);
            if (idx !== -1) this.items[idx] = Object.assign({}, this.editingItem);
          }

          this.editingItem = null;
          this.editingKey = null;
          await this._persistItems();
        },

        _persistItems: async function () {
          this.saving = true;
          try {
            var payload = this.items
              .filter(function (it) { return String(it.name || '').trim(); })
              .map(function (it) { var r = Object.assign({}, it); delete r._key; return r; });
            var res = await fetch('/api/admin/service/section', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ section: 'items', service_items: payload }),
            });
            var d = await res.json();
            if (d.ok) {
              this.showToast(payload.length + ' ' + (payload.length !== 1 ? t.itemsSavedN : t.itemsSaved1), 'ok');
            } else {
              this.showToast(d.error || t.saveError, 'err');
            }
          } catch (err) {
            this.showToast(t.netErr, 'err');
          } finally {
            this.saving = false;
          }
        },

        showToast: function (msg, kind) {
          (window as any).retahaToast?.(msg, kind === 'err' || kind === 'error' ? 'error' : 'success');
        },
      };
    });

  });
</script>

</Layout>
