---
import Layout from '../../layouts/Layout.astro';
import EveSubNav from '../../components/admin/EveSubNav.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance, getUserRole, hasPermission } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) {
  return new Response('Forbidden', { status: 403 });
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') === 'positive' ? 1 : -1;

const client = createSupabaseServiceRoleInstance();

const { count: positiveCount } = await client
  .from('eve_message_feedback')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id).eq('rating', 1);
const { count: negativeCount } = await client
  .from('eve_message_feedback')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id).eq('rating', -1);

const { data: feedbackRows } = await client
  .from('eve_message_feedback')
  .select(`
    id, rating, optional_comment, created_at,
    message:chat_messages!message_id (id, content, created_at, stay_id),
    stay:stays!stay_id (id, check_in, check_out, guest:guests(first_name, last_name))
  `)
  .eq('hotel_id', hotel.id)
  .eq('rating', filter)
  .order('created_at', { ascending: false })
  .limit(50);

const rows = (feedbackRows ?? []) as any[];

const stayIds = Array.from(new Set(rows.map((r: any) => r.stay?.id).filter(Boolean)));
let priorByMessageId: Record<string, { content: string; created_at: string } | null> = {};
if (rows.length > 0 && stayIds.length > 0) {
  const { data: allMsgs } = await client
    .from('chat_messages')
    .select('id, role, content, created_at, stay_id')
    .in('stay_id', stayIds)
    .order('created_at', { ascending: true });
  const byStay = new Map<string, any[]>();
  for (const m of allMsgs ?? []) {
    if (!byStay.has(m.stay_id)) byStay.set(m.stay_id, []);
    byStay.get(m.stay_id)!.push(m);
  }
  for (const r of rows) {
    const stayMsgs = byStay.get(r.stay?.id) ?? [];
    const idx = stayMsgs.findIndex((m: any) => m.id === r.message?.id);
    if (idx > 0) {
      for (let i = idx - 1; i >= 0; i--) {
        if (stayMsgs[i].role === 'user') {
          priorByMessageId[r.message.id] = { content: stayMsgs[i].content, created_at: stayMsgs[i].created_at };
          break;
        }
      }
    }
  }
}
---

<Layout title="Eve · Feedback" activeTab="backoffice">
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/eve/knowledge" class="breadcrumb__crumb">Eve Concierge</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Feedback</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">— EVE · KI-CONCIERGE —</span>
      <h1 class="settings-hero__title">Eve's Feedback<span class="dot-pink">?</span></h1>
      <p class="settings-hero__sub">Gäste können einzelne Antworten mit Daumen hoch/runter bewerten. Filter zeigt was schief läuft.</p>
    </section>

    <EveSubNav currentPath={Astro.url.pathname} />

    <!-- Filter-Tabs -->
    <div class="evf-tabs">
      <a href="?filter=negative" class={`evf-tab${filter === -1 ? ' is-active' : ''}`}>
        <span class="evf-tab-icon">👎</span>
        Nicht hilfreich
        <span class="evf-tab-count">{negativeCount ?? 0}</span>
      </a>
      <a href="?filter=positive" class={`evf-tab${filter === 1 ? ' is-active' : ''}`}>
        <span class="evf-tab-icon">👍</span>
        Hilfreich
        <span class="evf-tab-count">{positiveCount ?? 0}</span>
      </a>
    </div>

    {rows.length === 0 ? (
      <div class="evf-empty">
        <p>{filter === -1
          ? 'Keine negativen Bewertungen — Eve macht ihren Job ✓'
          : 'Noch keine positiven Bewertungen.'}
        </p>
      </div>
    ) : (
      <div class="settings-sections">
        {rows.map((r: any) => {
          const prior = priorByMessageId[r.message?.id];
          const guestName = r.stay?.guest
            ? [r.stay.guest.first_name, r.stay.guest.last_name].filter(Boolean).join(' ')
            : 'Gast';
          const dateStr = new Date(r.created_at).toLocaleString('de-DE', {
            day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit',
          });
          return (
            <article class="s-card evf-card">
              <div class="s-card__head">
                <span class={`evf-badge evf-badge--${r.rating === 1 ? 'pos' : 'neg'}`}>
                  {r.rating === 1 ? '👍 Hilfreich' : '👎 Nicht hilfreich'}
                </span>
                <span class="s-card__num">{guestName} · {dateStr}</span>
              </div>

              <div class="s-card__body">
                {prior && (
                  <div class="evf-msg evf-msg--user">
                    <p class="evf-msg-label">Gast fragte:</p>
                    <p class="evf-msg-text">„{prior.content}"</p>
                  </div>
                )}
                <div class="evf-msg evf-msg--eve">
                  <p class="evf-msg-label">Eve antwortete:</p>
                  <p class="evf-msg-text">{r.message?.content ?? '(Message gelöscht)'}</p>
                </div>
                {r.optional_comment && (
                  <div class="evf-msg evf-msg--comment">
                    <p class="evf-msg-label">Gast-Kommentar:</p>
                    <p class="evf-msg-text">„{r.optional_comment}"</p>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}

  </div>
</Layout>

<style>
  /* Filter-Tabs */
  .evf-tabs {
    display: flex; gap: 0; margin-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .evf-tab {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 20px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; font-weight: 400;
    color: var(--ink-muted); text-decoration: none;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    transition: color 150ms, border-color 150ms;
    min-height: 44px;
  }
  .evf-tab:hover { color: var(--ink); }
  .evf-tab.is-active {
    color: var(--ink); border-bottom-color: var(--ink);
    font-weight: 500;
  }
  .evf-tab-icon { font-size: 15px; }
  .evf-tab-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; padding: 1px 7px;
    border-radius: var(--r-pill);
    background: var(--bg-deep); color: var(--ink-muted);
  }
  .evf-tab.is-active .evf-tab-count {
    background: var(--ink); color: var(--bg);
  }

  /* Empty state */
  .evf-empty {
    padding: 60px 24px;
    background: var(--surface); border: 1px dashed var(--border);
    border-radius: var(--r); text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted);
    letter-spacing: 0.04em;
  }

  /* Feedback card */
  .evf-card .s-card__head { align-items: center; }

  .evf-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.04em;
    padding: 4px 10px; border-radius: var(--r-sm);
  }
  .evf-badge--pos {
    background: var(--sage-soft); color: var(--sage-strong);
    border: 1px solid color-mix(in srgb, var(--sage) 40%, transparent);
  }
  .evf-badge--neg {
    background: var(--burgund-soft); color: var(--burgund);
    border: 1px solid color-mix(in srgb, var(--burgund) 30%, transparent);
  }

  /* Message blocks */
  .evf-msg {
    padding: 10px 14px; border-radius: var(--r-sm);
  }
  .evf-msg--user {
    background: var(--bg-deep);
    border-left: 3px solid var(--border-medium);
  }
  .evf-msg--eve {
    background: var(--te-yellow-soft);
    border-left: 3px solid var(--te-yellow);
  }
  .evf-msg--comment {
    background: var(--sage-soft);
    border-left: 3px solid color-mix(in srgb, var(--sage) 50%, transparent);
  }
  .evf-msg-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink-muted); margin: 0 0 5px;
  }
  .evf-msg-text {
    margin: 0; font-size: 14px; line-height: 1.55;
    color: var(--ink);
  }
  .evf-msg--user .evf-msg-text,
  .evf-msg--comment .evf-msg-text { font-style: italic; }
</style>
