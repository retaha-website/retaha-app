---
import Layout from '../../layouts/Layout.astro';
import EveSubNav from '../../components/admin/EveSubNav.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance, getUserRole, hasPermission } from '@retaha/auth';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) {
  return new Response('Forbidden', { status: 403 });
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') === 'positive' ? 1 : -1;

const client = createSupabaseServiceRoleInstance();

const { count: positiveCount } = await client
  .from('eve_message_feedback')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id).eq('rating', 1);
const { count: negativeCount } = await client
  .from('eve_message_feedback')
  .select('id', { count: 'exact', head: true })
  .eq('hotel_id', hotel.id).eq('rating', -1);

const { data: feedbackRows } = await client
  .from('eve_message_feedback')
  .select(`
    id, rating, optional_comment, created_at,
    message:chat_messages!message_id (id, content, created_at, stay_id),
    stay:stays!stay_id (id, check_in, check_out, guest:guests(first_name, last_name))
  `)
  .eq('hotel_id', hotel.id)
  .eq('rating', filter)
  .order('created_at', { ascending: false })
  .limit(50);

const rows = (feedbackRows ?? []) as any[];

const stayIds = Array.from(new Set(rows.map((r: any) => r.stay?.id).filter(Boolean)));
let priorByMessageId: Record<string, { content: string; created_at: string } | null> = {};
if (rows.length > 0 && stayIds.length > 0) {
  const { data: allMsgs } = await client
    .from('chat_messages')
    .select('id, role, content, created_at, stay_id')
    .in('stay_id', stayIds)
    .order('created_at', { ascending: true });
  const byStay = new Map<string, any[]>();
  for (const m of allMsgs ?? []) {
    if (!byStay.has(m.stay_id)) byStay.set(m.stay_id, []);
    byStay.get(m.stay_id)!.push(m);
  }
  for (const r of rows) {
    const stayMsgs = byStay.get(r.stay?.id) ?? [];
    const idx = stayMsgs.findIndex((m: any) => m.id === r.message?.id);
    if (idx > 0) {
      for (let i = idx - 1; i >= 0; i--) {
        if (stayMsgs[i].role === 'user') {
          priorByMessageId[r.message.id] = { content: stayMsgs[i].content, created_at: stayMsgs[i].created_at };
          break;
        }
      }
    }
  }
}
---

<Layout title="Eve · Feedback" activeTab="backoffice">
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current"><span class="eve-gradient">Eve</span> {bt('nav.eve', lang).slice(4)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('evf.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('evf.hero.sub', lang)}</p>
    </section>

    <EveSubNav currentPath={Astro.url.pathname} lang={lang} />

    <!-- Filter-Tabs -->
    <div class="evf-tabs">
      <a href="?filter=negative" class={`evf-tab${filter === -1 ? ' is-active' : ''}`}>
        <span class="evf-tab-icon">👎</span>
        {bt('evf.tab.neg', lang)}
        <span class="evf-tab-count">{negativeCount ?? 0}</span>
      </a>
      <a href="?filter=positive" class={`evf-tab${filter === 1 ? ' is-active' : ''}`}>
        <span class="evf-tab-icon">👍</span>
        {bt('evf.tab.pos', lang)}
        <span class="evf-tab-count">{positiveCount ?? 0}</span>
      </a>
    </div>

    {rows.length === 0 ? (
      <div class="evf-empty">
        <p>{filter === -1 ? bt('evf.empty.neg', lang) : bt('evf.empty.pos', lang)}</p>
      </div>
    ) : (
      <div class="ev-wrap">
        {rows.map((r: any) => {
          const prior = priorByMessageId[r.message?.id];
          const guestName = r.stay?.guest
            ? [r.stay.guest.first_name, r.stay.guest.last_name].filter(Boolean).join(' ')
            : bt('evf.guest', lang);
          const dateStr = new Date(r.created_at).toLocaleString(lang, {
            day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit',
          });
          return (
            <article class="ev-card">
              <div class="ev-card-head">
                <span class={`evf-badge evf-badge--${r.rating === 1 ? 'pos' : 'neg'}`}>
                  {r.rating === 1 ? bt('evf.badge.pos', lang) : bt('evf.badge.neg', lang)}
                </span>
                <span class="evf-meta">{guestName} · {dateStr}</span>
              </div>

              <div class="evf-msgs">
                {prior && (
                  <div class="evf-msg evf-msg--user">
                    <p class="evf-msg-label">{bt('evf.msg.asked', lang)}</p>
                    <p class="evf-msg-text">„{prior.content}"</p>
                  </div>
                )}
                <div class="evf-msg evf-msg--eve">
                  <p class="evf-msg-label">{bt('evf.msg.answered', lang)}</p>
                  <p class="evf-msg-text">{r.message?.content ?? bt('evf.msg.deleted', lang)}</p>
                </div>
                {r.optional_comment && (
                  <div class="evf-msg evf-msg--comment">
                    <p class="evf-msg-label">{bt('evf.msg.comment', lang)}</p>
                    <p class="evf-msg-text">„{r.optional_comment}"</p>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}

  </div>
</Layout>

<style>
  .breadcrumb { padding-top: 36px; }

  /* ── V9-Karten ──────────────────────────────────────────────────── */
  .ev-wrap { display: flex; flex-direction: column; gap: 16px; }
  .ev-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 20px 22px;
  }
  .ev-card-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; margin-bottom: 16px; flex-wrap: wrap;
  }

  /* ── Filter-Tabs ────────────────────────────────────────────────── */
  .evf-tabs {
    display: flex; gap: 0; margin-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .evf-tab {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 20px;
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 400;
    color: var(--ink-muted); text-decoration: none;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    transition: color 150ms, border-color 150ms; min-height: 44px;
  }
  .evf-tab:hover { color: var(--ink); }
  .evf-tab.is-active { color: var(--petrol, #14616E); border-bottom-color: var(--petrol, #14616E); font-weight: 500; }
  .evf-tab-icon { font-size: 15px; }
  .evf-tab-count {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    padding: 1px 7px; border-radius: 99px;
    background: var(--bg-deep); color: var(--ink-muted);
  }
  .evf-tab.is-active .evf-tab-count {
    background: var(--petrol, #14616E); color: #fff;
  }

  /* ── Empty state ────────────────────────────────────────────────── */
  .evf-empty {
    padding: 60px 24px;
    background: var(--surface); border: 1px dashed var(--border);
    border-radius: 16px; text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.04em;
  }

  /* ── Karten-Kopf ────────────────────────────────────────────────── */
  .evf-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 6px;
  }
  .evf-badge--pos {
    background: color-mix(in srgb, var(--sage, #5C9070) 12%, transparent);
    color: var(--sage-strong, #2D6347);
    border: 1px solid color-mix(in srgb, var(--sage, #5C9070) 30%, transparent);
  }
  .evf-badge--neg {
    background: rgba(153,27,27,0.08); color: #991B1B;
    border: 1px solid rgba(153,27,27,0.2);
  }
  .evf-meta {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.06em; color: var(--ink-muted);
  }

  /* ── Nachrichten-Blöcke ─────────────────────────────────────────── */
  .evf-msgs { display: flex; flex-direction: column; gap: 10px; }
  .evf-msg { padding: 11px 14px; border-radius: 10px; }
  .evf-msg--user {
    background: var(--bg-deep); border-left: 3px solid var(--border);
  }
  .evf-msg--eve {
    background: color-mix(in srgb, var(--petrol, #14616E) 6%, transparent);
    border-left: 3px solid var(--petrol, #14616E);
  }
  .evf-msg--comment {
    background: color-mix(in srgb, var(--sage, #5C9070) 8%, transparent);
    border-left: 3px solid color-mix(in srgb, var(--sage, #5C9070) 50%, transparent);
  }
  .evf-msg-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-muted); margin: 0 0 6px;
  }
  .evf-msg-text { margin: 0; font-size: 13.5px; line-height: 1.55; color: var(--ink); }
  .evf-msg--user .evf-msg-text,
  .evf-msg--comment .evf-msg-text { font-style: italic; color: var(--ink-muted); }
</style>
