---
import Layout from '../../layouts/Layout.astro';
import EveSubNav from '../../components/admin/EveSubNav.astro';
import ModStatusLed from '../../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

interface TuningRule {
  trigger: string;
  instruction?: string;
  force_model?: 'haiku' | 'sonnet';
}

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServiceRoleInstance();

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'toggle_enabled') {
    const enabled = form.get('eve_enabled')?.toString() === 'true';
    const { error } = await client
      .from('hotel_settings')
      .update({ eve_enabled: enabled, updated_at: new Date().toISOString() })
      .eq('hotel_id', hotel.id);
    if (error) message = { type: 'error', text: `${bt('evs.msg.togglefail', lang)}: ${error.message}` };
    else message = { type: 'success', text: enabled ? bt('evs.msg.enabled', lang) : bt('evs.msg.disabled', lang) };
  }

  else if (action === 'save_persona') {
    const name = form.get('eve_name')?.toString().trim();
    const tonality = form.get('eve_tonality')?.toString();
    const customPersona = form.get('eve_custom_persona')?.toString().trim() || null;
    const onlineUntil = form.get('eve_online_until')?.toString() || null;

    if (!name) {
      message = { type: 'error', text: bt('evs.msg.nameempty', lang) };
    } else if (!['warm_formal', 'casual', 'custom'].includes(tonality ?? '')) {
      message = { type: 'error', text: bt('evs.msg.invalidtonality', lang) };
    } else if (tonality === 'custom' && !customPersona) {
      message = { type: 'error', text: bt('evs.msg.custompersona', lang) };
    } else {
      const { error } = await client
        .from('hotel_settings')
        .update({
          eve_name: name,
          eve_tonality: tonality,
          eve_custom_persona: tonality === 'custom' ? customPersona : null,
          eve_online_until: onlineUntil,
          updated_at: new Date().toISOString(),
        })
        .eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` };
      else message = { type: 'success', text: bt('evs.msg.personasaved', lang) };
    }
  }

  else if (action === 'tuning_rule_add' || action === 'tuning_rule_update' || action === 'tuning_rule_delete') {
    const { data: settings } = await client
      .from('hotel_settings')
      .select('eve_tuning_rules')
      .eq('hotel_id', hotel.id)
      .maybeSingle();
    const currentRules: TuningRule[] = (settings?.eve_tuning_rules as TuningRule[]) ?? [];
    let newRules: TuningRule[] = [...currentRules];

    if (action === 'tuning_rule_add') {
      const trigger = form.get('trigger')?.toString().trim();
      const instruction = form.get('instruction')?.toString().trim() || undefined;
      const forceModelRaw = form.get('force_model')?.toString();
      const force_model = (forceModelRaw === 'haiku' || forceModelRaw === 'sonnet') ? forceModelRaw : undefined;
      if (!trigger || !instruction) {
        message = { type: 'error', text: bt('evs.msg.rulerequired', lang) };
      } else {
        newRules.push({ trigger, instruction, ...(force_model && { force_model }) });
      }
    }
    else if (action === 'tuning_rule_delete') {
      const indexStr = form.get('rule_index')?.toString();
      const idx = indexStr ? parseInt(indexStr, 10) : -1;
      if (idx < 0 || idx >= currentRules.length) {
        message = { type: 'error', text: bt('evs.msg.invalidindex', lang) };
      } else {
        newRules = currentRules.filter((_, i) => i !== idx);
      }
    }
    else if (action === 'tuning_rule_update') {
      const indexStr = form.get('rule_index')?.toString();
      const idx = indexStr ? parseInt(indexStr, 10) : -1;
      const trigger = form.get('trigger')?.toString().trim();
      const instruction = form.get('instruction')?.toString().trim() || undefined;
      const forceModelRaw = form.get('force_model')?.toString();
      const force_model = (forceModelRaw === 'haiku' || forceModelRaw === 'sonnet') ? forceModelRaw : undefined;
      if (idx < 0 || idx >= currentRules.length) {
        message = { type: 'error', text: bt('evs.msg.invalidindex', lang) };
      } else if (!trigger || !instruction) {
        message = { type: 'error', text: bt('evs.msg.rulerequired', lang) };
      } else {
        newRules[idx] = { trigger, instruction, ...(force_model && { force_model }) };
      }
    }

    if (!message) {
      const { error } = await client
        .from('hotel_settings')
        .update({ eve_tuning_rules: newRules, updated_at: new Date().toISOString() })
        .eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` };
      else {
        const msgMap = {
          tuning_rule_add: bt('evs.msg.ruleadded', lang),
          tuning_rule_update: bt('evs.msg.ruleupdated', lang),
          tuning_rule_delete: bt('evs.msg.ruledeleted', lang),
        };
        message = { type: 'success', text: msgMap[action as keyof typeof msgMap] };
      }
    }
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    eve_enabled, eve_name, eve_tonality, eve_custom_persona,
    eve_tuning_rules, eve_online_until, guest_address_form
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const eveEnabled       = settings?.eve_enabled ?? false;
const eveName          = settings?.eve_name ?? 'Eve';
const eveTonality      = settings?.eve_tonality ?? 'warm_formal';
const eveCustomPersona = settings?.eve_custom_persona ?? '';
const eveOnlineUntil   = (settings?.eve_online_until as string ?? '22:00:00').slice(0, 5);
const tuningRules: TuningRule[] = (settings?.eve_tuning_rules as TuningRule[]) ?? [];
const guestAddressForm = settings?.guest_address_form ?? 'sie';
---

<Layout title="Eve · Persönlichkeit" activeTab="backoffice">
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.eve', lang)}</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">{bt('evf.hero.eyebrow', lang)}</span>
      <h1 class="settings-hero__title" set:html={bt('evs.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('evs.hero.sub', lang)}</p>
    </section>

    {message && (
      <script is:inline define:vars={{ m: message.text, t: message.type === 'success' ? 'success' : 'error' }}>
        window.addEventListener('DOMContentLoaded', function () { window.retahaToast && window.retahaToast(m, t); });
      </script>
    )}

    <div class="settings-sections">

      <!-- 01 Modul-Status -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('nav.eve', lang)}</h2>
          <span class="s-card__num">01</span>
        </div>

        <div class="s-card__body">
          <p class="field__hint">{eveEnabled ? bt('evs.mod.on', lang) : bt('evs.mod.off', lang)}</p>
          <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <ModStatusLed on={eveEnabled} />
            <form method="POST" style="margin:0">
              <input type="hidden" name="_action" value="toggle_enabled" />
              <input type="hidden" name="eve_enabled" value={(!eveEnabled).toString()} />
              <button type="submit" class={`v9-btn${eveEnabled ? ' v9-btn--ghost' : ''}`}>
                {eveEnabled ? bt('evs.deactivate', lang) : bt('evs.activate', lang)}
              </button>
            </form>
          </div>
        </div>
      </section>

      <EveSubNav currentPath={Astro.url.pathname} lang={lang} />

      <!-- ── Persona ── -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('evs.persona.title', lang)}</h2>
          <span class="s-card__num">02</span>
        </div>
        <p class="s-card__sub" style="margin: -16px 0 20px;">{bt('evs.persona.sub', lang)}</p>

        <form method="POST" x-data={`{ tonality: '${eveTonality}' }`}>
          <input type="hidden" name="_action" value="save_persona" />
          <div class="s-card__body">

            <div class="field field--row">
              <label class="field__label field__label--req" for="eve-name">{bt('si.items.name', lang)}</label>
              <div class="field__input-wrap">
                <input
                  type="text" id="eve-name" name="eve_name"
                  value={eveName} required maxlength="40"
                  class="s-input" autocomplete="off"
                />
                <span class="field__hint">{bt('evs.persona.namehint', lang)}</span>
              </div>
            </div>

            <div class="field field--row">
              <span class="field__label">{bt('evs.persona.tonality', lang)}</span>
              <div class="radio-cards" role="radiogroup">
                {[
                  ['warm_formal', bt('evs.ton.warm.label', lang), bt('evs.ton.warm.hint', lang)],
                  ['casual', bt('evs.ton.casual.label', lang), bt('evs.ton.casual.hint', lang)],
                  ['custom', bt('evs.ton.custom.label', lang), bt('evs.ton.custom.hint', lang)],
                ].map(([val, label, hint]) => (
                  <label class={`radio-card ${eveTonality === val ? 'is-active' : ''}`} title={hint}>
                    <input
                      type="radio" name="eve_tonality" value={val}
                      checked={eveTonality === val}
                      @change={`tonality = '${val}'`}
                      class="sr-only"
                    />
                    {label}
                  </label>
                ))}
              </div>
            </div>

            <div x-show="tonality === 'custom'" x-cloak>
              <div class="field field--row">
                <label class="field__label" for="eve-custom-persona">{bt('evs.persona.text', lang)}</label>
                <div class="field__input-wrap">
                  <textarea
                    id="eve-custom-persona" name="eve_custom_persona" rows="4"
                    placeholder="z.B. locker und herzlich, duzt immer, erwähnt gern lokale Geheimtipps. Oder: professionell und knapp, nie aufdringlich."
                    class="s-input s-textarea"
                  >{eveCustomPersona}</textarea>
                </div>
              </div>
            </div>

            <div class="field field--row">
              <span class="field__label">{bt('evs.persona.address', lang)}</span>
              <div>
                <div class="ev-readonly-field">
                  <span>{guestAddressForm === 'du' ? bt('evs.address.du', lang) : bt('evs.address.sie', lang)}</span>
                  <a href="/admin/settings" class="s-btn-link">{bt('evs.persona.addresslink', lang)}</a>
                </div>
              </div>
            </div>

            <div class="field field--row">
              <label class="field__label" for="eve-online-until">{bt('evs.persona.onlineuntil', lang)}</label>
              <div class="field__input-wrap">
                <input
                  type="time" id="eve-online-until" name="eve_online_until"
                  value={eveOnlineUntil} class="s-input ev-time-input"
                />
                <span class="field__hint">{bt('evs.persona.onlinehint', lang)}</span>
              </div>
            </div>

          </div>
          <div class="s-card__footer">
            <button type="submit" class="v9-btn">{bt('evs.persona.save', lang)}</button>
          </div>
        </form>
      </section>

      <!-- ── Tuning-Rules ── -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('evs.tune.title', lang)}</h2>
          <span class="s-card__num">03</span>
        </div>
        <p class="s-card__sub" style="margin: -16px 0 20px;" set:html={bt('evs.tune.sub', lang).replace('{link}', `<a href="/eve/knowledge" class="s-btn-link">${bt('evs.tune.sublink', lang)}</a>`)}></p>

        <form method="POST">
          <input type="hidden" name="_action" value="tuning_rule_add" />
          <div class="s-card__body">
            <div class="field field--row">
              <label class="field__label field__label--req" for="rule-trigger">{bt('evs.tune.trigger', lang)}</label>
              <div class="field__input-wrap">
                <input
                  type="text" id="rule-trigger" name="trigger" required
                  placeholder="z.B. restaurant-empfehlung"
                  class="s-input ev-mono-input" autocomplete="off"
                />
                <span class="field__hint">{bt('evs.tune.triggerhint', lang)}</span>
              </div>
            </div>
            <div class="field field--row">
              <label class="field__label field__label--req" for="rule-instruction">{bt('evs.tune.instruction', lang)}</label>
              <textarea
                id="rule-instruction" name="instruction" required rows="3"
                placeholder="z.B. 'Empfiehl immer erst unser hauseigenes Restaurant Maria.'"
                class="s-input s-textarea"
              ></textarea>
            </div>
            <div class="field field--row">
              <label class="field__label" for="rule-force-model">{bt('evs.tune.model', lang)}</label>
              <div class="field__input-wrap">
                <select id="rule-force-model" name="force_model" class="s-input">
                  <option value="">{bt('evs.model.auto', lang)}</option>
                  <option value="sonnet">{bt('evs.model.sonnet', lang)}</option>
                  <option value="haiku">{bt('evs.model.haiku', lang)}</option>
                </select>
                <span class="field__hint">{bt('evs.tune.modelhint', lang)}</span>
              </div>
            </div>
          </div>
          <div class="s-card__footer">
            <button type="submit" class="v9-btn">{bt('evs.tune.add', lang)}</button>
          </div>
        </form>

        {tuningRules.length === 0 && (
          <p class="ev-empty-hint">{bt('evs.tune.empty', lang)}</p>
        )}

        {tuningRules.length > 0 && (
          <div class="ev-list">
            {tuningRules.map((rule, index) => (
              <article class="ev-item" x-data="{ editing: false }">
                <div x-show="!editing" class="ev-item__view">
                  <div class="ev-item__content">
                    <p class="ev-rule-trigger">{rule.trigger}</p>
                    <p class="ev-item__a">{rule.instruction}</p>
                    {rule.force_model && (
                      <p class="ev-rule-model"><span class="ev-model-badge">{rule.force_model}</span>{bt('evs.tune.override', lang)}</p>
                    )}
                  </div>
                  <div class="ev-item__actions">
                    <button
                      type="button" @click="editing = true"
                      class="v9-btn v9-btn--ghost ev-action-btn"
                    >{bt('si.items.edit', lang)}</button>
                    <form method="POST" class="inline" onsubmit={`return confirm(${JSON.stringify(bt('evs.confirm.delete', lang))})`}>
                      <input type="hidden" name="_action" value="tuning_rule_delete" />
                      <input type="hidden" name="rule_index" value={index} />
                      <button type="submit" class="v9-btn v9-btn--ghost ev-action-btn ev-action-btn--delete">{bt('nfc.delete', lang)}</button>
                    </form>
                  </div>
                </div>

                <form x-show="editing" method="POST" x-cloak>
                  <input type="hidden" name="_action" value="tuning_rule_update" />
                  <input type="hidden" name="rule_index" value={index} />
                  <div class="ev-item__edit-body">
                    <div class="field field--row">
                      <label class="field__label">{bt('evs.edit.trigger', lang)}</label>
                      <input type="text" name="trigger" value={rule.trigger} required class="s-input ev-mono-input" />
                    </div>
                    <div class="field field--row">
                      <label class="field__label">{bt('evs.edit.instruction', lang)}</label>
                      <textarea name="instruction" required rows="3" class="s-input s-textarea">{rule.instruction}</textarea>
                    </div>
                    <div class="field field--row">
                      <label class="field__label">{bt('evs.edit.model', lang)}</label>
                      <div class="field__input-wrap">
                        <select name="force_model" class="s-input">
                          <option value="" selected={!rule.force_model}>{bt('evs.model.autoshort', lang)}</option>
                          <option value="sonnet" selected={rule.force_model === 'sonnet'}>Sonnet</option>
                          <option value="haiku" selected={rule.force_model === 'haiku'}>Haiku</option>
                        </select>
                      </div>
                    </div>
                  </div>
                  <div class="ev-item__edit-footer">
                    <button type="submit" class="v9-btn">{bt('common.save', lang)}</button>
                    <button type="button" @click="editing = false" class="v9-btn v9-btn--ghost">{bt('common.cancel', lang)}</button>
                  </div>
                </form>
              </article>
            ))}
          </div>
        )}
      </section>

    </div>
  </div>
</Layout>

<style>
  [x-cloak] { display: none !important; }

  /* Touch-target & active state (iPad) */
  .v9-btn { min-height: 44px; }
  .v9-btn:active:not(:disabled) { background: var(--te-yellow); color: #0A0A0A; }
  .v9-btn.v9-btn--ghost:active:not(:disabled) { background: var(--bg-deep); color: var(--ink); }

  /* Textarea / time input */
  .s-textarea { resize: vertical; min-height: 80px; }
  .ev-time-input { max-width: 120px; font-family: 'JetBrains Mono', monospace; }
  .ev-mono-input { font-family: 'JetBrains Mono', monospace; }

  /* Read-only field row */
  .ev-readonly-field {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); padding: 10px 14px;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    color: var(--ink);
  }

  /* Rule item */
  .ev-rule-trigger {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; font-weight: 500;
    color: var(--ink); background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    padding: 2px 8px; display: inline-block; margin-bottom: 6px;
  }
  .ev-rule-model {
    font-size: 11px; color: var(--ink-muted);
    margin: 8px 0 0; display: flex; align-items: center; gap: 6px;
  }
  .ev-model-badge {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--te-pink, #FF4A82);
    background: color-mix(in srgb, var(--te-pink, #FF4A82) 12%, transparent);
    padding: 1px 7px; border-radius: var(--r-sm);
  }
  /* Shared list + item styles */
  .ev-list {
    border-top: 1px solid var(--border);
    margin-top: 24px; padding-top: 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .ev-item {
    border: 1px solid var(--border); border-radius: var(--r-sm);
    background: var(--bg);
  }
  .ev-item__view {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 16px;
    padding: 14px 16px;
  }
  .ev-item__content { flex: 1; min-width: 0; }
  .ev-item__a {
    font-size: 13px; color: var(--ink-soft);
    line-height: 1.55; margin: 0; white-space: pre-wrap;
  }
  .ev-item__actions { display: flex; gap: 6px; flex-shrink: 0; align-items: center; }
  .ev-action-btn {
    padding: 6px 12px !important; min-height: 36px !important; font-size: 10px !important;
  }
  .ev-action-btn--delete {
    color: var(--burgund) !important;
    border-color: color-mix(in srgb, var(--burgund) 30%, transparent) !important;
  }
  .ev-action-btn--delete:hover { background: var(--burgund-soft) !important; }

  .ev-item__edit-body {
    display: flex; flex-direction: column; gap: 16px; padding: 14px 16px 0;
  }
  .ev-item__edit-footer {
    display: flex; gap: 8px; padding: 12px 16px;
    border-top: 1px solid var(--border); margin-top: 14px;
  }
  .ev-empty-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--ink-muted);
    text-align: center; padding: 24px; margin: 16px 0 0;
    border-top: 1px solid var(--border);
  }
</style>

<script>
  /* Radio-card active state (same pattern as /settings) */
  document.querySelectorAll('[role="radiogroup"]').forEach(group => {
    group.querySelectorAll<HTMLLabelElement>('.radio-card').forEach(card => {
      const input = card.querySelector('input[type="radio"]') as HTMLInputElement;
      card.addEventListener('click', () => {
        group.querySelectorAll('.radio-card').forEach(c => c.classList.remove('is-active'));
        card.classList.add('is-active');
        if (input) {
          input.checked = true;
          input.dispatchEvent(new Event('change'));
        }
      });
    });
  });
</script>
