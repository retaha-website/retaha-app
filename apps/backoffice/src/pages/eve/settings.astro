---
import Layout from '../../layouts/Layout.astro';
import EveSubNav from '../../components/admin/EveSubNav.astro';
import ModStatusLed from '../../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

interface TuningRule {
  trigger: string;
  instruction?: string;
  force_model?: 'haiku' | 'sonnet';
}

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServiceRoleInstance();

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'toggle_enabled') {
    const enabled = form.get('eve_enabled')?.toString() === 'true';
    const { error } = await client
      .from('hotel_settings')
      .update({ eve_enabled: enabled, updated_at: new Date().toISOString() })
      .eq('hotel_id', hotel.id);
    if (error) message = { type: 'error', text: `${bt('evs.msg.togglefail', lang)}: ${error.message}` };
    else message = { type: 'success', text: enabled ? bt('evs.msg.enabled', lang) : bt('evs.msg.disabled', lang) };
  }

  else if (action === 'save_persona') {
    const name = form.get('eve_name')?.toString().trim();
    const tonality = form.get('eve_tonality')?.toString();
    const customPersona = form.get('eve_custom_persona')?.toString().trim() || null;
    const onlineUntil = form.get('eve_online_until')?.toString() || null;

    if (!name) {
      message = { type: 'error', text: bt('evs.msg.nameempty', lang) };
    } else if (!['warm_formal', 'casual', 'custom'].includes(tonality ?? '')) {
      message = { type: 'error', text: bt('evs.msg.invalidtonality', lang) };
    } else if (tonality === 'custom' && !customPersona) {
      message = { type: 'error', text: bt('evs.msg.custompersona', lang) };
    } else {
      const { error } = await client
        .from('hotel_settings')
        .update({
          eve_name: name,
          eve_tonality: tonality,
          eve_custom_persona: tonality === 'custom' ? customPersona : null,
          eve_online_until: onlineUntil,
          updated_at: new Date().toISOString(),
        })
        .eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` };
      else message = { type: 'success', text: bt('evs.msg.personasaved', lang) };
    }
  }

  else if (action === 'tuning_rule_add' || action === 'tuning_rule_update' || action === 'tuning_rule_delete') {
    const { data: settings } = await client
      .from('hotel_settings')
      .select('eve_tuning_rules')
      .eq('hotel_id', hotel.id)
      .maybeSingle();
    const currentRules: TuningRule[] = (settings?.eve_tuning_rules as TuningRule[]) ?? [];
    let newRules: TuningRule[] = [...currentRules];

    if (action === 'tuning_rule_add') {
      const trigger = form.get('trigger')?.toString().trim();
      const instruction = form.get('instruction')?.toString().trim() || undefined;
      const forceModelRaw = form.get('force_model')?.toString();
      const force_model = (forceModelRaw === 'haiku' || forceModelRaw === 'sonnet') ? forceModelRaw : undefined;
      if (!trigger || !instruction) {
        message = { type: 'error', text: bt('evs.msg.rulerequired', lang) };
      } else {
        newRules.push({ trigger, instruction, ...(force_model && { force_model }) });
      }
    }
    else if (action === 'tuning_rule_delete') {
      const indexStr = form.get('rule_index')?.toString();
      const idx = indexStr ? parseInt(indexStr, 10) : -1;
      if (idx < 0 || idx >= currentRules.length) {
        message = { type: 'error', text: bt('evs.msg.invalidindex', lang) };
      } else {
        newRules = currentRules.filter((_, i) => i !== idx);
      }
    }
    else if (action === 'tuning_rule_update') {
      const indexStr = form.get('rule_index')?.toString();
      const idx = indexStr ? parseInt(indexStr, 10) : -1;
      const trigger = form.get('trigger')?.toString().trim();
      const instruction = form.get('instruction')?.toString().trim() || undefined;
      const forceModelRaw = form.get('force_model')?.toString();
      const force_model = (forceModelRaw === 'haiku' || forceModelRaw === 'sonnet') ? forceModelRaw : undefined;
      if (idx < 0 || idx >= currentRules.length) {
        message = { type: 'error', text: bt('evs.msg.invalidindex', lang) };
      } else if (!trigger || !instruction) {
        message = { type: 'error', text: bt('evs.msg.rulerequired', lang) };
      } else {
        newRules[idx] = { trigger, instruction, ...(force_model && { force_model }) };
      }
    }

    if (!message) {
      const { error } = await client
        .from('hotel_settings')
        .update({ eve_tuning_rules: newRules, updated_at: new Date().toISOString() })
        .eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` };
      else {
        const msgMap = {
          tuning_rule_add: bt('evs.msg.ruleadded', lang),
          tuning_rule_update: bt('evs.msg.ruleupdated', lang),
          tuning_rule_delete: bt('evs.msg.ruledeleted', lang),
        };
        message = { type: 'success', text: msgMap[action as keyof typeof msgMap] };
      }
    }
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    eve_enabled, eve_name, eve_tonality, eve_custom_persona,
    eve_tuning_rules, eve_online_until, guest_address_form
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const eveEnabled       = settings?.eve_enabled ?? false;
const eveName          = settings?.eve_name ?? 'Eve';
const eveTonality      = settings?.eve_tonality ?? 'warm_formal';
const eveCustomPersona = settings?.eve_custom_persona ?? '';
const eveOnlineUntil   = (settings?.eve_online_until as string ?? '22:00:00').slice(0, 5);
const tuningRules: TuningRule[] = (settings?.eve_tuning_rules as TuningRule[]) ?? [];
const guestAddressForm = settings?.guest_address_form ?? 'sie';
---

<Layout title="Eve · Persönlichkeit" activeTab="backoffice">
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current"><span class="eve-gradient">Eve</span> {bt('nav.eve', lang).slice(4)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('evs.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('evs.hero.sub', lang)}</p>
    </section>

    {message && (
      <script is:inline define:vars={{ m: message.text, t: message.type === 'success' ? 'success' : 'error' }}>
        window.addEventListener('DOMContentLoaded', function () { window.retahaToast && window.retahaToast(m, t); });
      </script>
    )}

    <div class="ev-wrap">

      <!-- Modul-Status -->
      <div class="ev-card">
        <div class="ev-card-head">
          <span class="ev-card-title"><span class="eve-gradient">Eve</span> {bt('nav.eve', lang).slice(4)}</span>
        </div>
        <p class="ev-hint" style="margin-bottom:14px">{bt('si.mod.hint', lang)}</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={eveEnabled} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
        </div>
      </div>

      <EveSubNav currentPath={Astro.url.pathname} lang={lang} />

      <!-- ── Persona ── -->
      <div class="ev-card">
        <div class="ev-card-head">
          <span class="ev-card-title">{bt('evs.persona.title', lang)}</span>
        </div>
        <p class="ev-hint" style="margin-bottom:16px">{bt('evs.persona.sub', lang)}</p>

        <form method="POST" x-data={`{ tonality: '${eveTonality}' }`}>
          <input type="hidden" name="_action" value="save_persona" />

          <div class="ev-field">
            <label class="ev-label ev-label--req" for="eve-name">{bt('si.items.name', lang)}</label>
            <input type="text" id="eve-name" name="eve_name"
              value={eveName} required maxlength="40"
              class="s-input" style="width:100%;box-sizing:border-box" autocomplete="off" />
            <span class="ev-hint" style="margin-top:5px">{bt('evs.persona.namehint', lang)}</span>
          </div>

          <div class="ev-field">
            <span class="ev-label">{bt('evs.persona.tonality', lang)}</span>
            <div class="evs-radio-cards" role="radiogroup">
              {[
                ['warm_formal', bt('evs.ton.warm.label', lang), bt('evs.ton.warm.hint', lang)],
                ['casual', bt('evs.ton.casual.label', lang), bt('evs.ton.casual.hint', lang)],
                ['custom', bt('evs.ton.custom.label', lang), bt('evs.ton.custom.hint', lang)],
              ].map(([val, label, hint]) => (
                <label class={`evs-radio-card${eveTonality === val ? ' is-on' : ''}`} title={hint}>
                  <input type="radio" name="eve_tonality" value={val}
                    checked={eveTonality === val}
                    @change={`tonality = '${val}'`}
                    class="sr-only" />
                  {label}
                </label>
              ))}
            </div>
          </div>

          <div x-show="tonality === 'custom'" x-cloak>
            <div class="ev-field">
              <label class="ev-label" for="eve-custom-persona">{bt('evs.persona.text', lang)}</label>
              <textarea id="eve-custom-persona" name="eve_custom_persona" rows="4"
                placeholder="z.B. locker und herzlich, duzt immer, erwähnt gern lokale Geheimtipps. Oder: professionell und knapp, nie aufdringlich."
                class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:88px"
              >{eveCustomPersona}</textarea>
            </div>
          </div>

          <div class="ev-field">
            <span class="ev-label">{bt('evs.persona.address', lang)}</span>
            <div class="evs-readonly">
              <span>{guestAddressForm === 'du' ? bt('evs.address.du', lang) : bt('evs.address.sie', lang)}</span>
              <a href="/admin/settings" class="s-btn-link">{bt('evs.persona.addresslink', lang)}</a>
            </div>
          </div>

          <div class="ev-field" style="margin-bottom:0">
            <label class="ev-label" for="eve-online-until">{bt('evs.persona.onlineuntil', lang)}</label>
            <input type="time" id="eve-online-until" name="eve_online_until"
              value={eveOnlineUntil} class="s-input evs-time-input" />
            <span class="ev-hint" style="margin-top:5px">{bt('evs.persona.onlinehint', lang)}</span>
          </div>

          <div class="ev-card-foot">
            <button type="submit" class="v9-btn ev-btn-primary">{bt('evs.persona.save', lang)}</button>
          </div>
        </form>
      </div>

      <!-- ── Tuning-Rules ── -->
      <div class="ev-card">
        <div class="ev-card-head">
          <span class="ev-card-title">{bt('evs.tune.title', lang)}</span>
        </div>
        <p class="ev-hint" style="margin-bottom:16px" set:html={bt('evs.tune.sub', lang).replace('{link}', `<a href="/eve/knowledge" class="s-btn-link">${bt('evs.tune.sublink', lang)}</a>`)}></p>

        <form method="POST">
          <input type="hidden" name="_action" value="tuning_rule_add" />

          <div class="ev-field">
            <label class="ev-label ev-label--req" for="rule-trigger">{bt('evs.tune.trigger', lang)}</label>
            <input type="text" id="rule-trigger" name="trigger" required
              placeholder="z.B. restaurant-empfehlung"
              class="s-input evs-mono" style="width:100%;box-sizing:border-box" autocomplete="off" />
            <span class="ev-hint" style="margin-top:5px">{bt('evs.tune.triggerhint', lang)}</span>
          </div>

          <div class="ev-field" style="margin-bottom:0">
            <label class="ev-label ev-label--req" for="rule-instruction">{bt('evs.tune.instruction', lang)}</label>
            <textarea id="rule-instruction" name="instruction" required rows="3"
              placeholder="z.B. 'Empfiehl immer erst unser hauseigenes Restaurant Maria.'"
              class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:72px"
            ></textarea>
          </div>

          <div class="ev-card-foot">
            <button type="submit" class="v9-btn ev-btn-primary">{bt('evs.tune.add', lang)}</button>
          </div>
        </form>

        {tuningRules.length === 0 && (
          <p class="ev-empty-hint">{bt('evs.tune.empty', lang)}</p>
        )}

        {tuningRules.length > 0 && (
          <div class="ev-list">
            {tuningRules.map((rule, index) => (
              <article class="ev-item" x-data="{ editing: false }">
                <div x-show="!editing" class="ev-item__view">
                  <div class="ev-item__content">
                    <p class="evs-rule-trigger">{rule.trigger}</p>
                    <p class="ev-item__a">{rule.instruction}</p>
                  </div>
                  <div class="ev-item__actions">
                    <button type="button" @click="editing = true" class="v9-btn ev-btn-ghost ev-action-btn">
                      {bt('si.items.edit', lang)}
                    </button>
                    <form method="POST" class="inline" onsubmit={`return confirm(${JSON.stringify(bt('evs.confirm.delete', lang))})`}>
                      <input type="hidden" name="_action" value="tuning_rule_delete" />
                      <input type="hidden" name="rule_index" value={index} />
                      <button type="submit" class="v9-btn ev-action-btn ev-action-btn--delete">{bt('nfc.delete', lang)}</button>
                    </form>
                  </div>
                </div>

                <form x-show="editing" method="POST" x-cloak>
                  <input type="hidden" name="_action" value="tuning_rule_update" />
                  <input type="hidden" name="rule_index" value={index} />
                  <div class="ev-item__edit-body">
                    <div class="ev-field" style="margin-bottom:0">
                      <label class="ev-label">{bt('evs.edit.trigger', lang)}</label>
                      <input type="text" name="trigger" value={rule.trigger} required
                        class="s-input evs-mono" style="width:100%;box-sizing:border-box" />
                    </div>
                    <div class="ev-field" style="margin-bottom:0">
                      <label class="ev-label">{bt('evs.edit.instruction', lang)}</label>
                      <textarea name="instruction" required rows="3"
                        class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:72px"
                      >{rule.instruction}</textarea>
                    </div>
                  </div>
                  <div class="ev-item__edit-footer">
                    <button type="submit" class="v9-btn ev-btn-primary">{bt('common.save', lang)}</button>
                    <button type="button" @click="editing = false" class="v9-btn ev-btn-ghost">{bt('common.cancel', lang)}</button>
                  </div>
                </form>
              </article>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>
</Layout>

<style>
  [x-cloak] { display: none !important; }

  .breadcrumb { padding-top: 36px; }

  /* ── V9-Karten ──────────────────────────────────────────────────── */
  .ev-wrap { display: flex; flex-direction: column; gap: 16px; }
  .ev-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 20px 22px;
  }
  .ev-card-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 10px; margin-bottom: 16px;
  }
  .ev-card-title {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: 'Space Grotesk', sans-serif; font-weight: 600;
    font-size: 14px; color: var(--ink);
  }
  .ev-card-title::before {
    content: ''; width: 7px; height: 7px;
    border-radius: 50%; background: var(--petrol, #14616E); flex-shrink: 0;
  }
  .ev-card-foot {
    display: flex; gap: 10px; justify-content: flex-end; align-items: center;
    margin-top: 0; padding-top: 14px; border-top: 1px solid var(--border);
  }

  /* ── Labels + Hints ─────────────────────────────────────────────── */
  .ev-label {
    display: block; font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 6px;
  }
  .ev-label--req::after { content: ' *'; color: var(--petrol, #14616E); }
  .ev-hint { display: block; font-size: 11px; color: var(--ink-muted); line-height: 1.45; }
  .ev-field { margin-bottom: 14px; }

  /* ── Buttons ────────────────────────────────────────────────────── */
  .ev-btn-primary {
    background: var(--petrol, #14616E) !important; color: #fff !important;
    border: none !important; border-radius: 8px;
  }
  .ev-btn-primary:hover:not(:disabled) { filter: brightness(1.1); }
  .ev-btn-ghost {
    background: transparent !important; color: var(--ink-muted) !important;
    border: 1px solid var(--border) !important; border-radius: 8px;
  }
  .ev-btn-ghost:hover { color: var(--ink) !important; border-color: var(--ink) !important; }

  /* ── Tonalitäts-Radio-Cards ─────────────────────────────────────── */
  .evs-radio-cards { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 2px; }
  .evs-radio-card {
    cursor: pointer; user-select: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 500;
    padding: 7px 14px; border-radius: 8px;
    border: 1px solid var(--border); background: var(--surface); color: var(--ink-muted);
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .evs-radio-card:hover { color: var(--ink); border-color: var(--petrol, #14616E); }
  .evs-radio-card.is-on {
    background: var(--petrol, #14616E); color: #fff; border-color: var(--petrol, #14616E);
  }

  /* ── Readonly-Feld ──────────────────────────────────────────────── */
  .evs-readonly {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: 10px; padding: 9px 14px;
    font-family: 'Space Grotesk', sans-serif; font-size: 13.5px; color: var(--ink);
  }

  /* ── Spezial-Inputs ─────────────────────────────────────────────── */
  .evs-time-input { max-width: 120px; font-family: 'JetBrains Mono', monospace; }
  .evs-mono { font-family: 'JetBrains Mono', monospace; }

  /* ── Tuning-Rule-Items ──────────────────────────────────────────── */
  .evs-rule-trigger {
    font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 500;
    color: var(--petrol, #14616E);
    background: color-mix(in srgb, var(--petrol, #14616E) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--petrol, #14616E) 20%, transparent);
    border-radius: 6px; padding: 2px 9px; display: inline-block; margin-bottom: 6px;
  }
  .evs-rule-model {
    font-size: 11px; color: var(--ink-muted); margin: 8px 0 0;
    display: flex; align-items: center; gap: 6px;
  }
  .evs-model-badge {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--petrol, #14616E);
    background: color-mix(in srgb, var(--petrol, #14616E) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--petrol, #14616E) 20%, transparent);
    padding: 1px 7px; border-radius: 5px;
  }

  /* ── Gemeinsame Listen-Styles ───────────────────────────────────── */
  .ev-list {
    border-top: 1px solid var(--border); margin-top: 20px; padding-top: 14px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .ev-item {
    border: 1px solid var(--border); border-radius: 12px;
    background: var(--surface);
  }
  .ev-item__view {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 16px; padding: 14px 16px;
  }
  .ev-item__content { flex: 1; min-width: 0; }
  .ev-item__a {
    font-size: 13px; color: var(--ink-muted); line-height: 1.55; margin: 0; white-space: pre-wrap;
  }
  .ev-item__actions { display: flex; gap: 6px; flex-shrink: 0; align-items: center; }
  .ev-action-btn {
    padding: 5px 11px !important; min-height: 32px !important;
    font-size: 10px !important; border-radius: 7px !important;
  }
  .ev-action-btn--delete {
    background: transparent !important; color: #991B1B !important;
    border: 1px solid rgba(153,27,27,0.3) !important;
  }
  .ev-action-btn--delete:hover { background: rgba(153,27,27,0.06) !important; border-color: #991B1B !important; }
  .ev-item__edit-body {
    display: flex; flex-direction: column; gap: 14px; padding: 14px 16px 0;
  }
  .ev-item__edit-footer {
    display: flex; gap: 8px; padding: 12px 16px;
    border-top: 1px solid var(--border); margin-top: 14px;
  }
  .ev-empty-hint {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted);
    text-align: center; padding: 24px; margin: 14px 0 0;
    border-top: 1px solid var(--border);
  }
</style>

<script>
  /* Tonalitäts-Radio-Cards: is-on statt is-active, lokal statt global */
  document.querySelectorAll('.evs-radio-cards').forEach(group => {
    group.querySelectorAll<HTMLLabelElement>('.evs-radio-card').forEach(card => {
      const input = card.querySelector('input[type="radio"]') as HTMLInputElement;
      card.addEventListener('click', () => {
        group.querySelectorAll('.evs-radio-card').forEach(c => c.classList.remove('is-on'));
        card.classList.add('is-on');
        if (input) { input.checked = true; input.dispatchEvent(new Event('change')); }
      });
    });
  });
</script>
