---
import Layout from '../../layouts/Layout.astro';
import EveSubNav from '../../components/admin/EveSubNav.astro';
import ModStatusLed from '../../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { invalidateTranslationsForKnowledge } from '@retaha/eve';
import { mergeAndTranslate, asLanguageCode } from '@retaha/i18n';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServiceRoleInstance();

const { data: hotelLangRow } = await client
  .from('hotels').select('default_language, enabled_languages')
  .eq('id', hotel.id).maybeSingle();
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';
const LANG_LABELS: Record<string, string> = {
  de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands',
  ru: 'Русский', ar: 'العربية', zh: '中文',
};

const NOW = () => new Date().toISOString();
const makeI18nEntry = (value: string) => ({ value, source: 'original', updated_at: NOW() });

async function translateField(label: string, existing: any, value: string) {
  const result = await mergeAndTranslate(existing, value, asLanguageCode(hotelDefaultLang), { logLabel: label });
  return Object.keys(result.i18n).length > 0 ? result.i18n : null;
}

let message: { type: 'success' | 'error'; text: string } | null = null;
let highlightId: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'faq_create') {
    const question = form.get('question')?.toString().trim() ?? '';
    const answer   = form.get('answer')?.toString().trim() ?? '';
    if (!question || !answer) {
      message = { type: 'error', text: bt('evk.msg.faqrequired', lang) };
    } else {
      // INSERT first with base-language i18n — row is committed before translation
      const baseQI18n = { [hotelDefaultLang]: makeI18nEntry(question) };
      const baseAI18n = { [hotelDefaultLang]: makeI18nEntry(answer) };
      const { data, error } = await client
        .from('eve_knowledge')
        .insert({
          hotel_id: hotel.id,
          category: 'faq',
          question, answer,
          question_i18n: baseQI18n,
          answer_i18n: baseAI18n,
          language_code: hotelDefaultLang,
        })
        .select('id')
        .single();
      if (error) {
        message = { type: 'error', text: `${bt('evk.msg.createfail', lang)}: ${error.message}` };
      } else {
        highlightId = data?.id ?? null;
        message = { type: 'success', text: bt('evk.msg.faqadded', lang) };
        // Translate and update i18n — entry already saved, this is best-effort
        try {
          const [qI18n, aI18n] = await Promise.all([
            translateField('eve_knowledge.faq_create.question', baseQI18n, question),
            translateField('eve_knowledge.faq_create.answer',   baseAI18n, answer),
          ]);
          await client.from('eve_knowledge')
            .update({ question_i18n: qI18n, answer_i18n: aI18n })
            .eq('id', data!.id);
        } catch (_) { /* translation failed — entry saved with base language */ }
      }
    }
  }

  else if (action === 'faq_update') {
    const id       = form.get('id')?.toString();
    const question = form.get('question')?.toString().trim() ?? '';
    const answer   = form.get('answer')?.toString().trim() ?? '';
    if (!id || !question || !answer) {
      message = { type: 'error', text: bt('evk.msg.updatemissing', lang) };
    } else {
      // UPDATE core text first — saved regardless of translation outcome
      const { error: coreErr } = await client
        .from('eve_knowledge')
        .update({ question, answer, updated_at: NOW() })
        .eq('id', id)
        .eq('hotel_id', hotel.id);
      if (coreErr) {
        message = { type: 'error', text: `${bt('evk.msg.updatefail', lang)}: ${coreErr.message}` };
      } else {
        message = { type: 'success', text: bt('evk.msg.faqupdated', lang) };
        highlightId = id;
        // Translate and update i18n — best-effort after core save
        try {
          const { data: existingFaq } = await client
            .from('eve_knowledge')
            .select('question_i18n, answer_i18n')
            .eq('id', id).eq('hotel_id', hotel.id).maybeSingle();
          const [qI18n, aI18n] = await Promise.all([
            translateField(`eve_knowledge.${id}.question`, existingFaq?.question_i18n, question),
            translateField(`eve_knowledge.${id}.answer`,   existingFaq?.answer_i18n,   answer),
          ]);
          await client.from('eve_knowledge')
            .update({ question_i18n: qI18n, answer_i18n: aI18n })
            .eq('id', id).eq('hotel_id', hotel.id);
          await invalidateTranslationsForKnowledge(id);
        } catch (_) { /* translation failed — core text saved */ }
      }
    }
  }

  else if (action === 'faq_delete') {
    const id = form.get('id')?.toString();
    if (!id) {
      message = { type: 'error', text: bt('evk.msg.noid', lang) };
    } else {
      await invalidateTranslationsForKnowledge(id);
      const { error } = await client
        .from('eve_knowledge')
        .delete()
        .eq('id', id)
        .eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `${bt('evk.msg.deletefail', lang)}: ${error.message}` };
      } else {
        message = { type: 'success', text: bt('evk.msg.faqdeleted', lang) };
      }
    }
  }

  else if (action === 'rules_save' || action === 'directions_save') {
    const category = action === 'rules_save' ? 'rules' : 'directions';
    const answer = form.get('answer')?.toString().trim() ?? '';
    const catLabel = category === 'rules' ? bt('evk.cat.rules', lang) : bt('evk.cat.directions', lang);

    if (!answer) {
      const { error } = await client
        .from('eve_knowledge')
        .delete()
        .eq('hotel_id', hotel.id)
        .eq('category', category);
      if (error) {
        message = { type: 'error', text: `${bt('evk.msg.deletefail', lang)}: ${error.message}` };
      } else {
        message = { type: 'success', text: bt('evk.msg.catdeleted', lang).replace('{cat}', catLabel) };
      }
    } else {
      const { data: existing } = await client
        .from('eve_knowledge')
        .select('id')
        .eq('hotel_id', hotel.id)
        .eq('category', category)
        .maybeSingle();

      if (existing?.id) {
        // UPDATE core answer first, then translate best-effort
        const { error } = await client
          .from('eve_knowledge')
          .update({ answer, updated_at: NOW() })
          .eq('id', existing.id);
        if (error) {
          message = { type: 'error', text: `${bt('evk.msg.updatefail', lang)}: ${error.message}` };
        } else {
          message = { type: 'success', text: bt('evk.msg.catupdated', lang).replace('{cat}', catLabel) };
          try {
            const { data: existingRow } = await client
              .from('eve_knowledge')
              .select('answer_i18n')
              .eq('id', existing.id).maybeSingle();
            const aI18n = await translateField(
              `eve_knowledge.${category}.${existing.id}.answer`,
              existingRow?.answer_i18n,
              answer,
            );
            await client.from('eve_knowledge')
              .update({ answer_i18n: aI18n })
              .eq('id', existing.id);
          } catch (_) { /* translation failed — core text saved */ }
        }
      } else {
        // INSERT first with base-language i18n, then translate
        const baseAI18n = { [hotelDefaultLang]: makeI18nEntry(answer) };
        const { data: newRow, error } = await client
          .from('eve_knowledge')
          .insert({ hotel_id: hotel.id, category, answer, answer_i18n: baseAI18n, language_code: hotelDefaultLang })
          .select('id').single();
        if (error) {
          message = { type: 'error', text: `${bt('evk.msg.createfail', lang)}: ${error.message}` };
        } else {
          message = { type: 'success', text: bt('evk.msg.catsaved', lang).replace('{cat}', catLabel) };
          try {
            const aI18n = await translateField(`eve_knowledge.${category}.new.answer`, baseAI18n, answer);
            await client.from('eve_knowledge')
              .update({ answer_i18n: aI18n })
              .eq('id', newRow!.id);
          } catch (_) { /* translation failed — entry saved with base language */ }
        }
      }
    }
  }
}

const { data: knowledgeRows } = await client
  .from('eve_knowledge')
  .select('id, category, question, answer, question_i18n, answer_i18n, sort_order, created_at, updated_at')
  .eq('hotel_id', hotel.id)
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

const { data: eveSettingsRow } = await client
  .from('hotel_settings')
  .select('eve_enabled')
  .eq('hotel_id', hotel.id)
  .maybeSingle();
const eveEnabled = eveSettingsRow?.eve_enabled ?? false;

function pickI18n(value: any, lang: string, fallback: string): string {
  if (!value || typeof value !== 'object') return fallback ?? '';
  return value[lang]?.value || value[hotelDefaultLang]?.value || value['de']?.value || fallback || '';
}

const faqs           = (knowledgeRows ?? []).filter(r => r.category === 'faq');
const rulesRow       = (knowledgeRows ?? []).find(r => r.category === 'rules');
const directionsRow  = (knowledgeRows ?? []).find(r => r.category === 'directions');
---

<Layout title="Eve · Wissen" activeTab="backoffice">
  <div
    class="settings-page"
    x-data={`{ highlightId: ${JSON.stringify(highlightId)} }`}
    x-init="if (highlightId) { setTimeout(() => { const el = document.getElementById('faq-' + highlightId); if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'center' }); } }, 100); setTimeout(() => { highlightId = null }, 2500) }"
  >

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('tab.backoffice', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current"><span class="eve-gradient">Eve</span> {bt('nav.eve', lang).slice(4)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('evk.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('evk.hero.sub', lang)}</p>
    </section>

    {message && (
      <script is:inline define:vars={{ m: message.text, t: message.type === 'success' ? 'success' : 'error' }}>
        window.addEventListener('DOMContentLoaded', function () { window.retahaToast && window.retahaToast(m, t); });
      </script>
    )}

    <div class="ev-wrap">

      <!-- Modul-Status -->
      <div class="ev-card">
        <div class="ev-card-head">
          <span class="ev-card-title"><span class="eve-gradient">Eve</span> {bt('nav.eve', lang).slice(4)}</span>
        </div>
        <p class="ev-hint" style="margin-bottom:14px">{bt('si.mod.hint', lang)}</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={eveEnabled} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
        </div>
      </div>

      <EveSubNav currentPath={Astro.url.pathname} lang={lang} />

      <div class="s-warning-row">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
        </svg>
        <span>
          {bt('evk.warn.pre', lang)} (<strong>{LANG_LABELS[hotelDefaultLang] ?? hotelDefaultLang}</strong>). {bt('evk.warn.post', lang)}
        </span>
      </div>

      <!-- ── FAQ ── -->
      <div class="ev-card" id="faq-section">
        <div class="ev-card-head">
          <span class="ev-card-title">{bt('evk.faq.title', lang)}</span>
        </div>
        <p class="ev-hint" style="margin-bottom:16px" set:html={bt('evk.faq.sub', lang).replace('{link}', `<a href="/eve/settings" style="color:var(--petrol,#14616E);font-weight:600;text-decoration:none">${bt('evk.faq.sublink', lang)}</a>`)}></p>

        <!-- Aus Website lernen -->
        <div class="ev-learn-block">
          <div class="ev-learn-text">
            <span class="ev-learn-title">Aus eurer Website lernen</span>
            <span class="ev-hint" style="margin-top:0">Eve liest die hinterlegte Hotel-Website und schlägt automatisch FAQs vor — danach bearbeitbar.</span>
          </div>
          <button type="button" class="ev-aurora-btn" data-eve-learn-btn>
            <svg class="ev-aurora-spk" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
            Aus Website lernen
          </button>
        </div>

        <!-- Neue FAQ -->
        <form method="POST" style="margin-top:16px">
          <input type="hidden" name="_action" value="faq_create" />
          <div class="ev-field">
            <label class="ev-label ev-label--req" for="faq-question">{bt('evk.faq.question', lang)}</label>
            <input type="text" id="faq-question" name="question" required
              placeholder="z.B. Wann ist Check-out?"
              class="s-input" style="width:100%;box-sizing:border-box" autocomplete="off" />
          </div>
          <div class="ev-field">
            <label class="ev-label ev-label--req" for="faq-answer">{bt('evk.faq.answer', lang)}</label>
            <textarea id="faq-answer" name="answer" required rows="3"
              placeholder="z.B. 11:00 Uhr. Late-Check-out bis 13:00 für €15 möglich."
              class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:80px"
            ></textarea>
          </div>
          <div class="ev-card-foot">
            <button type="submit" class="v9-btn ev-btn-primary">{bt('evk.faq.add', lang)}</button>
          </div>
        </form>

        {faqs.length === 0 && (
          <p class="ev-empty-hint">{bt('evk.faq.empty', lang)}</p>
        )}

        {faqs.length > 0 && (
          <div class="ev-list">
            {faqs.map(faq => (
              <article
                id={`faq-${faq.id}`}
                class="ev-item"
                x-data={`{ editing: false, highlight: highlightId === '${faq.id}' }`}
                x-init="if (highlight) { setTimeout(() => { highlight = false }, 2500) }"
                :class="highlight ? 'ev-item--highlight' : ''"
              >
                <div x-show="!editing" class="ev-item__view">
                  <div class="ev-item__content">
                    <p class="ev-item__q">{pickI18n(faq.question_i18n, hotelDefaultLang, faq.question)}</p>
                    <p class="ev-item__a">{pickI18n(faq.answer_i18n, hotelDefaultLang, faq.answer)}</p>
                  </div>
                  <div class="ev-item__actions">
                    <button type="button" @click="editing = true" class="v9-btn ev-btn-ghost ev-action-btn">
                      {bt('si.items.edit', lang)}
                    </button>
                    <form method="POST" class="inline" onsubmit={`return confirm(${JSON.stringify(bt('evk.confirm.delete', lang))})`}>
                      <input type="hidden" name="_action" value="faq_delete" />
                      <input type="hidden" name="id" value={faq.id} />
                      <button type="submit" class="v9-btn ev-action-btn ev-action-btn--delete">{bt('nfc.delete', lang)}</button>
                    </form>
                  </div>
                </div>

                <form x-show="editing" method="POST" x-cloak>
                  <input type="hidden" name="_action" value="faq_update" />
                  <input type="hidden" name="id" value={faq.id} />
                  <div class="ev-item__edit-body">
                    <div class="ev-field" style="margin-bottom:0">
                      <label class="ev-label">{bt('evk.faq.question', lang)}</label>
                      <input type="text" name="question" required class="s-input" style="width:100%;box-sizing:border-box"
                        value={pickI18n(faq.question_i18n, hotelDefaultLang, faq.question)} />
                    </div>
                    <div class="ev-field" style="margin-bottom:0">
                      <label class="ev-label">{bt('evk.faq.answer', lang)}</label>
                      <textarea name="answer" required rows="3" class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:80px"
                      >{pickI18n(faq.answer_i18n, hotelDefaultLang, faq.answer)}</textarea>
                    </div>
                  </div>
                  <div class="ev-item__edit-footer">
                    <button type="submit" class="v9-btn ev-btn-primary">{bt('common.save', lang)}</button>
                    <button type="button" @click="editing = false" class="v9-btn ev-btn-ghost">{bt('common.cancel', lang)}</button>
                  </div>
                </form>
              </article>
            ))}
          </div>
        )}
      </div>

      <!-- ── Hausregeln ── -->
      <div class="ev-card" x-data={`{
        eveOpen: false,
        evePrompt: '',
        eveLoading: false,
        eveError: '',
        val: ${JSON.stringify(pickI18n(rulesRow?.answer_i18n, hotelDefaultLang, rulesRow?.answer ?? ''))},
        async generate() {
          this.eveLoading = true; this.eveError = '';
          try {
            const r = await fetch('/api/admin/eve/generate-field', {
              method: 'POST', headers: {'Content-Type':'application/json'},
              body: JSON.stringify({ prompt: this.evePrompt, field: 'rules' })
            });
            const d = await r.json();
            if (d.ok) { this.val = d.text; this.eveOpen = false; this.evePrompt = ''; }
            else { this.eveError = d.message || 'Fehler beim Generieren.'; }
          } catch { this.eveError = 'Netzwerk-Fehler. Versuche es erneut.'; }
          this.eveLoading = false;
        }
      }`}>
        <div class="ev-card-head">
          <span class="ev-card-title">{bt('evk.cat.rules', lang)}</span>
          <button type="button" class="ev-aurora-btn" @click="eveOpen = !eveOpen">
            <svg class="ev-aurora-spk" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
            Mit Eve schreiben
          </button>
        </div>
        <p class="ev-hint" style="margin-bottom:14px">{bt('evk.rules.sub', lang)}</p>

        <!-- Eve-Modal -->
        <div class="ev-eve-overlay" x-show="eveOpen" x-cloak
          @click.self="if (!eveLoading) { eveOpen = false; eveError = ''; }"
          @keydown.escape.window="if (eveOpen && !eveLoading) { eveOpen = false; eveError = ''; }">
          <div class="ev-eve-modal">
            <div class="ev-eve-mhd">
              <span class="ev-eve-mhd-title">
                <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
                Hausregeln schreiben
              </span>
              <button type="button" class="ev-eve-close" @click="eveOpen = false; eveError = ''" :disabled="eveLoading">✕</button>
            </div>
            <textarea class="s-input ev-eve-ta" x-model="evePrompt"
              placeholder="z.B. Haustiere erlaubt, kein Rauchen, Ruhezeit ab 22 Uhr, WLAN kostenfrei …"
              :disabled="eveLoading"
              @keydown.meta.enter.prevent="generate()"
              @keydown.ctrl.enter.prevent="generate()"
            ></textarea>
            <p class="ev-eve-err" x-show="eveError" x-cloak x-text="eveError"></p>
            <div class="ev-eve-mft">
              <button type="button" class="ev-eve-cancel" @click="eveOpen = false; eveError = ''" :disabled="eveLoading">Abbrechen</button>
              <button type="button" class="ev-aurora-btn" @click="generate()" :disabled="eveLoading || !evePrompt.trim()">
                <svg class="ev-aurora-spk" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
                <span x-text="eveLoading ? 'Eve schreibt …' : 'Mit Eve schreiben'"></span>
              </button>
            </div>
          </div>
        </div>

        <form method="POST">
          <input type="hidden" name="_action" value="rules_save" />
          <textarea name="answer" rows="6" x-model="val"
            placeholder="z.B. Rauchen ist im gesamten Hotel verboten. Haustiere sind willkommen (Anmeldung vor Anreise). Ruhezeit 22:00–07:00."
            class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:120px"
          ></textarea>
          <div class="ev-card-foot">
            <button type="submit" class="v9-btn ev-btn-primary">{bt('evk.rules.save', lang)}</button>
          </div>
        </form>
      </div>

      <!-- ── Anfahrt ── -->
      <div class="ev-card" x-data={`{
        eveOpen: false,
        evePrompt: '',
        eveLoading: false,
        eveError: '',
        val: ${JSON.stringify(pickI18n(directionsRow?.answer_i18n, hotelDefaultLang, directionsRow?.answer ?? ''))},
        async generate() {
          this.eveLoading = true; this.eveError = '';
          try {
            const r = await fetch('/api/admin/eve/generate-field', {
              method: 'POST', headers: {'Content-Type':'application/json'},
              body: JSON.stringify({ prompt: this.evePrompt, field: 'directions' })
            });
            const d = await r.json();
            if (d.ok) { this.val = d.text; this.eveOpen = false; this.evePrompt = ''; }
            else { this.eveError = d.message || 'Fehler beim Generieren.'; }
          } catch { this.eveError = 'Netzwerk-Fehler. Versuche es erneut.'; }
          this.eveLoading = false;
        }
      }`}>
        <div class="ev-card-head">
          <span class="ev-card-title">{bt('evk.cat.directions', lang)}</span>
          <button type="button" class="ev-aurora-btn" @click="eveOpen = !eveOpen">
            <svg class="ev-aurora-spk" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
            Mit Eve schreiben
          </button>
        </div>
        <p class="ev-hint" style="margin-bottom:14px">{bt('evk.dir.sub', lang)}</p>

        <!-- Eve-Modal -->
        <div class="ev-eve-overlay" x-show="eveOpen" x-cloak
          @click.self="if (!eveLoading) { eveOpen = false; eveError = ''; }"
          @keydown.escape.window="if (eveOpen && !eveLoading) { eveOpen = false; eveError = ''; }">
          <div class="ev-eve-modal">
            <div class="ev-eve-mhd">
              <span class="ev-eve-mhd-title">
                <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
                Anfahrt schreiben
              </span>
              <button type="button" class="ev-eve-close" @click="eveOpen = false; eveError = ''" :disabled="eveLoading">✕</button>
            </div>
            <textarea class="s-input ev-eve-ta" x-model="evePrompt"
              placeholder="z.B. Adresse, Parkplätze im Hof, 5 Min. vom Bahnhof, Flughafen-Shuttle auf Anfrage …"
              :disabled="eveLoading"
              @keydown.meta.enter.prevent="generate()"
              @keydown.ctrl.enter.prevent="generate()"
            ></textarea>
            <p class="ev-eve-err" x-show="eveError" x-cloak x-text="eveError"></p>
            <div class="ev-eve-mft">
              <button type="button" class="ev-eve-cancel" @click="eveOpen = false; eveError = ''" :disabled="eveLoading">Abbrechen</button>
              <button type="button" class="ev-aurora-btn" @click="generate()" :disabled="eveLoading || !evePrompt.trim()">
                <svg class="ev-aurora-spk" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
                <span x-text="eveLoading ? 'Eve schreibt …' : 'Mit Eve schreiben'"></span>
              </button>
            </div>
          </div>
        </div>

        <form method="POST">
          <input type="hidden" name="_action" value="directions_save" />
          <textarea name="answer" rows="6" x-model="val"
            placeholder="z.B. Vom Flughafen BER: S-Bahn S9 bis Zoologischer Garten, dann U-Bahn U1 zur Uhlandstraße. Parkplätze im Innenhof (18€/Nacht)."
            class="s-input" style="width:100%;box-sizing:border-box;resize:vertical;min-height:120px"
          ></textarea>
          <div class="ev-card-foot">
            <button type="submit" class="v9-btn ev-btn-primary">{bt('evk.dir.save', lang)}</button>
          </div>
        </form>
      </div>

    </div>
  </div>
</Layout>

<script is:inline>
  (function () {
    var btn = document.querySelector('[data-eve-learn-btn]');
    if (!btn) return;
    btn.addEventListener('click', async function () {
      var orig = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Eve liest die Website …';
      try {
        var res = await fetch('/api/admin/eve/learn-from-website', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}',
        });
        var data = await res.json().catch(function () { return {}; });
        if (data.ok) {
          if (window.retahaToast) window.retahaToast((data.count || 0) + ' FAQ(s) aus der Website übernommen.', 'success');
          setTimeout(function () { window.location.reload(); }, 900);
          return;
        }
        var msg = data.message || 'Konnte die Website nicht auswerten.';
        var toastOpts = data.error === 'no_website'
          ? { action: { label: 'Zu den Hotel-Einstellungen', href: '/profile/settings' } }
          : {};
        if (window.retahaToast) window.retahaToast(msg, 'error', toastOpts);
      } catch (e) {
        if (window.retahaToast) window.retahaToast('Netzwerk-Fehler. Versuche es erneut.', 'error');
      }
      btn.disabled = false;
      btn.textContent = orig;
    });
  })();
</script>

