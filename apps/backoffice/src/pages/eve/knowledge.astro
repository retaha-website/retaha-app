---
import Layout from '../../layouts/Layout.astro';
import EveSubNav from '../../components/admin/EveSubNav.astro';
import ModStatusLed from '../../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { invalidateTranslationsForKnowledge } from '@retaha/eve';
import { mergeAndTranslate, asLanguageCode } from '@retaha/i18n';

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServiceRoleInstance();

const { data: hotelLangRow } = await client
  .from('hotels').select('default_language, enabled_languages')
  .eq('id', hotel.id).maybeSingle();
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';
const hotelEnabledLangs: string[] = Array.isArray(hotelLangRow?.enabled_languages)
  ? hotelLangRow.enabled_languages : ['de','en','fr','es'];
const LANG_LABELS: Record<string, string> = {
  de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands',
  ru: 'Русский', ar: 'العربية', zh: '中文',
};
const otherEnabledLabel = hotelEnabledLangs.filter(l => l !== hotelDefaultLang)
  .map(l => LANG_LABELS[l] || l).join(', ');

const NOW = () => new Date().toISOString();
const makeI18nEntry = (value: string) => ({ value, source: 'original', updated_at: NOW() });

async function translateField(label: string, existing: any, value: string) {
  const result = await mergeAndTranslate(existing, value, asLanguageCode(hotelDefaultLang), { logLabel: label });
  return Object.keys(result.i18n).length > 0 ? result.i18n : null;
}

let message: { type: 'success' | 'error'; text: string } | null = null;
let highlightId: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'faq_create') {
    const question = form.get('question')?.toString().trim() ?? '';
    const answer   = form.get('answer')?.toString().trim() ?? '';
    if (!question || !answer) {
      message = { type: 'error', text: 'Frage und Antwort sind Pflichtfelder.' };
    } else {
      // INSERT first with base-language i18n — row is committed before translation
      const baseQI18n = { [hotelDefaultLang]: makeI18nEntry(question) };
      const baseAI18n = { [hotelDefaultLang]: makeI18nEntry(answer) };
      const { data, error } = await client
        .from('eve_knowledge')
        .insert({
          hotel_id: hotel.id,
          category: 'faq',
          question, answer,
          question_i18n: baseQI18n,
          answer_i18n: baseAI18n,
          language_code: hotelDefaultLang,
        })
        .select('id')
        .single();
      if (error) {
        message = { type: 'error', text: `Anlegen fehlgeschlagen: ${error.message}` };
      } else {
        highlightId = data?.id ?? null;
        message = { type: 'success', text: 'FAQ-Eintrag hinzugefügt.' };
        // Translate and update i18n — entry already saved, this is best-effort
        try {
          const [qI18n, aI18n] = await Promise.all([
            translateField('eve_knowledge.faq_create.question', baseQI18n, question),
            translateField('eve_knowledge.faq_create.answer',   baseAI18n, answer),
          ]);
          await client.from('eve_knowledge')
            .update({ question_i18n: qI18n, answer_i18n: aI18n })
            .eq('id', data!.id);
        } catch (_) { /* translation failed — entry saved with base language */ }
      }
    }
  }

  else if (action === 'faq_update') {
    const id       = form.get('id')?.toString();
    const question = form.get('question')?.toString().trim() ?? '';
    const answer   = form.get('answer')?.toString().trim() ?? '';
    if (!id || !question || !answer) {
      message = { type: 'error', text: 'Fehlende Felder beim Update.' };
    } else {
      // UPDATE core text first — saved regardless of translation outcome
      const { error: coreErr } = await client
        .from('eve_knowledge')
        .update({ question, answer, updated_at: NOW() })
        .eq('id', id)
        .eq('hotel_id', hotel.id);
      if (coreErr) {
        message = { type: 'error', text: `Update fehlgeschlagen: ${coreErr.message}` };
      } else {
        message = { type: 'success', text: 'FAQ-Eintrag aktualisiert.' };
        highlightId = id;
        // Translate and update i18n — best-effort after core save
        try {
          const { data: existingFaq } = await client
            .from('eve_knowledge')
            .select('question_i18n, answer_i18n')
            .eq('id', id).eq('hotel_id', hotel.id).maybeSingle();
          const [qI18n, aI18n] = await Promise.all([
            translateField(`eve_knowledge.${id}.question`, existingFaq?.question_i18n, question),
            translateField(`eve_knowledge.${id}.answer`,   existingFaq?.answer_i18n,   answer),
          ]);
          await client.from('eve_knowledge')
            .update({ question_i18n: qI18n, answer_i18n: aI18n })
            .eq('id', id).eq('hotel_id', hotel.id);
          await invalidateTranslationsForKnowledge(id);
        } catch (_) { /* translation failed — core text saved */ }
      }
    }
  }

  else if (action === 'faq_delete') {
    const id = form.get('id')?.toString();
    if (!id) {
      message = { type: 'error', text: 'Keine ID übergeben.' };
    } else {
      await invalidateTranslationsForKnowledge(id);
      const { error } = await client
        .from('eve_knowledge')
        .delete()
        .eq('id', id)
        .eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
      } else {
        message = { type: 'success', text: 'FAQ-Eintrag gelöscht.' };
      }
    }
  }

  else if (action === 'rules_save' || action === 'directions_save') {
    const category = action === 'rules_save' ? 'rules' : 'directions';
    const answer = form.get('answer')?.toString().trim() ?? '';
    const catLabel = category === 'rules' ? 'Hausregeln' : 'Anfahrt';

    if (!answer) {
      const { error } = await client
        .from('eve_knowledge')
        .delete()
        .eq('hotel_id', hotel.id)
        .eq('category', category);
      if (error) {
        message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
      } else {
        message = { type: 'success', text: `${catLabel} gelöscht.` };
      }
    } else {
      const { data: existing } = await client
        .from('eve_knowledge')
        .select('id')
        .eq('hotel_id', hotel.id)
        .eq('category', category)
        .maybeSingle();

      if (existing?.id) {
        // UPDATE core answer first, then translate best-effort
        const { error } = await client
          .from('eve_knowledge')
          .update({ answer, updated_at: NOW() })
          .eq('id', existing.id);
        if (error) {
          message = { type: 'error', text: `Update fehlgeschlagen: ${error.message}` };
        } else {
          message = { type: 'success', text: `${catLabel} aktualisiert.` };
          try {
            const { data: existingRow } = await client
              .from('eve_knowledge')
              .select('answer_i18n')
              .eq('id', existing.id).maybeSingle();
            const aI18n = await translateField(
              `eve_knowledge.${category}.${existing.id}.answer`,
              existingRow?.answer_i18n,
              answer,
            );
            await client.from('eve_knowledge')
              .update({ answer_i18n: aI18n })
              .eq('id', existing.id);
          } catch (_) { /* translation failed — core text saved */ }
        }
      } else {
        // INSERT first with base-language i18n, then translate
        const baseAI18n = { [hotelDefaultLang]: makeI18nEntry(answer) };
        const { data: newRow, error } = await client
          .from('eve_knowledge')
          .insert({ hotel_id: hotel.id, category, answer, answer_i18n: baseAI18n, language_code: hotelDefaultLang })
          .select('id').single();
        if (error) {
          message = { type: 'error', text: `Anlegen fehlgeschlagen: ${error.message}` };
        } else {
          message = { type: 'success', text: `${catLabel} gespeichert.` };
          try {
            const aI18n = await translateField(`eve_knowledge.${category}.new.answer`, baseAI18n, answer);
            await client.from('eve_knowledge')
              .update({ answer_i18n: aI18n })
              .eq('id', newRow!.id);
          } catch (_) { /* translation failed — entry saved with base language */ }
        }
      }
    }
  }
}

const { data: knowledgeRows } = await client
  .from('eve_knowledge')
  .select('id, category, question, answer, question_i18n, answer_i18n, sort_order, created_at, updated_at')
  .eq('hotel_id', hotel.id)
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

const { data: eveSettingsRow } = await client
  .from('hotel_settings')
  .select('eve_enabled')
  .eq('hotel_id', hotel.id)
  .maybeSingle();
const eveEnabled = eveSettingsRow?.eve_enabled ?? false;

function pickI18n(value: any, lang: string, fallback: string): string {
  if (!value || typeof value !== 'object') return fallback ?? '';
  return value[lang]?.value || value[hotelDefaultLang]?.value || value['de']?.value || fallback || '';
}

const faqs           = (knowledgeRows ?? []).filter(r => r.category === 'faq');
const rulesRow       = (knowledgeRows ?? []).find(r => r.category === 'rules');
const directionsRow  = (knowledgeRows ?? []).find(r => r.category === 'directions');
---

<Layout title="Eve · Wissen" activeTab="backoffice">
  <div
    class="settings-page"
    x-data={`{ highlightId: ${JSON.stringify(highlightId)} }`}
    x-init="if (highlightId) { setTimeout(() => { const el = document.getElementById('faq-' + highlightId); if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'center' }); } }, 100); setTimeout(() => { highlightId = null }, 2500) }"
  >

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/eve/knowledge" class="breadcrumb__crumb">Eve Concierge</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Wissen</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">— EVE · KI-CONCIERGE —</span>
      <h1 class="settings-hero__title">Eve's Wissen<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">Pflege Frage-Antwort-Paare, Hausregeln und Anfahrt. Eve nutzt das im Gast-Chat.</p>
    </section>

    {message && (
      <div class={`s-flash ${message.type === 'success' ? 's-flash--ok' : 's-flash--err'}`}>
        {message.text}
      </div>
    )}

    <div class="s-warning-row" style="margin-bottom: 20px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
      </svg>
      <span>
        Pflege das Wissen von Eve in deiner Standardsprache (<strong>{LANG_LABELS[hotelDefaultLang] ?? hotelDefaultLang}</strong>). Eve übersetzt automatisch in alle verfügbaren Sprachen.
      </span>
    </div>

    <div class="settings-sections">

      <!-- 01 Modul-Status -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Eve Concierge</h2>
          <span class="s-card__num">01</span>
        </div>
        <div class="s-card__body">
          <p class="field__hint">Ein/Aus wird in der Gäste-App-Vorschau gesteuert.</p>
          <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <ModStatusLed on={eveEnabled} />
            <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">In der Gäste-App-Vorschau steuern →</a>
          </div>
        </div>
      </section>

      <EveSubNav currentPath={Astro.url.pathname} />

      <!-- ── FAQ ── -->
      <section class="s-card" id="faq-section">
        <div class="s-card__head">
          <h2 class="s-card__title">Häufige Fragen</h2>
          <span class="s-card__num">02</span>
        </div>
        <p class="s-card__sub" style="margin: -16px 0 20px;">Fakten die Eve genau beantworten soll — Check-out-Zeit, WLAN-Passwort, Frühstückszeiten, Anfahrt. Verhaltensregeln ("was soll Eve tun wenn…") gehören in den <a href="/eve/settings" class="s-btn-link">Einstellungs-Tab →</a></p>

        <form method="POST">
          <input type="hidden" name="_action" value="faq_create" />
          <div class="s-card__body">
            <div class="field field--row">
              <label class="field__label field__label--req" for="faq-question">Frage</label>
              <input
                type="text" id="faq-question" name="question" required
                placeholder="z.B. Wann ist Check-out?"
                class="s-input" autocomplete="off"
              />
            </div>
            <div class="field field--row">
              <label class="field__label field__label--req" for="faq-answer">Antwort</label>
              <textarea
                id="faq-answer" name="answer" required rows="3"
                placeholder="z.B. 11:00 Uhr. Late-Check-out bis 13:00 für €15 möglich."
                class="s-input s-textarea"
              ></textarea>
            </div>
          </div>
          <div class="s-card__footer">
            <button type="submit" class="v9-btn">+ FAQ hinzufügen</button>
          </div>
        </form>

        {faqs.length === 0 && (
          <p class="ev-empty-hint">Noch keine FAQs angelegt.</p>
        )}

        {faqs.length > 0 && (
          <div class="ev-list">
            {faqs.map(faq => (
              <article
                id={`faq-${faq.id}`}
                class="ev-item"
                x-data={`{ editing: false, highlight: highlightId === '${faq.id}' }`}
                x-init="if (highlight) { setTimeout(() => { highlight = false }, 2500) }"
                :class="highlight ? 'ev-item--highlight' : ''"
              >
                <div x-show="!editing" class="ev-item__view">
                  <div class="ev-item__content">
                    <p class="ev-item__q">{pickI18n(faq.question_i18n, hotelDefaultLang, faq.question)}</p>
                    <p class="ev-item__a">{pickI18n(faq.answer_i18n, hotelDefaultLang, faq.answer)}</p>
                  </div>
                  <div class="ev-item__actions">
                    <button
                      type="button" @click="editing = true"
                      class="v9-btn v9-btn--ghost ev-action-btn"
                    >Bearbeiten</button>
                    <form method="POST" class="inline" onsubmit="return confirm('Diesen Eintrag wirklich löschen?')">
                      <input type="hidden" name="_action" value="faq_delete" />
                      <input type="hidden" name="id" value={faq.id} />
                      <button type="submit" class="v9-btn v9-btn--ghost ev-action-btn ev-action-btn--delete">Löschen</button>
                    </form>
                  </div>
                </div>

                <form x-show="editing" method="POST" x-cloak>
                  <input type="hidden" name="_action" value="faq_update" />
                  <input type="hidden" name="id" value={faq.id} />
                  <div class="ev-item__edit-body">
                    <div class="field field--row">
                      <label class="field__label">Frage</label>
                      <input
                        type="text" name="question" required class="s-input"
                        value={pickI18n(faq.question_i18n, hotelDefaultLang, faq.question)}
                      />
                    </div>
                    <div class="field field--row">
                      <label class="field__label">Antwort</label>
                      <textarea name="answer" required rows="3" class="s-input s-textarea"
                      >{pickI18n(faq.answer_i18n, hotelDefaultLang, faq.answer)}</textarea>
                    </div>
                  </div>
                  <div class="ev-item__edit-footer">
                    <button type="submit" class="v9-btn">Speichern</button>
                    <button type="button" @click="editing = false" class="v9-btn v9-btn--ghost">Abbrechen</button>
                  </div>
                </form>
              </article>
            ))}
          </div>
        )}
      </section>

      <!-- ── Hausregeln ── -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Hausregeln</h2>
          <span class="s-card__num">03</span>
        </div>
        <p class="s-card__sub" style="margin: -16px 0 20px;">Frei-Text. Eve referenziert das wenn Gäste nach Regeln fragen (Rauchen, Haustiere, Ruhezeit, etc.).</p>

        <form method="POST">
          <input type="hidden" name="_action" value="rules_save" />
          <div class="s-card__body">
            <textarea
              name="answer" rows="6"
              placeholder="z.B. Rauchen ist im gesamten Hotel verboten. Haustiere sind willkommen (Anmeldung vor Anreise). Ruhezeit 22:00–07:00."
              class="s-input s-textarea"
            >{pickI18n(rulesRow?.answer_i18n, hotelDefaultLang, rulesRow?.answer ?? '')}</textarea>
          </div>
          <div class="s-card__footer">
            <button type="submit" class="v9-btn">Hausregeln speichern</button>
          </div>
        </form>
      </section>

      <!-- ── Anfahrt ── -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Anfahrt</h2>
          <span class="s-card__num">04</span>
        </div>
        <p class="s-card__sub" style="margin: -16px 0 20px;">Wie kommt der Gast ans Hotel? ÖPNV-Tipps, Parkplatz-Info, Flughafen-Verbindung.</p>

        <form method="POST">
          <input type="hidden" name="_action" value="directions_save" />
          <div class="s-card__body">
            <textarea
              name="answer" rows="6"
              placeholder="z.B. Vom Flughafen BER: S-Bahn S9 bis Zoologischer Garten, dann U-Bahn U1 zur Uhlandstraße. Parkplätze im Innenhof (18€/Nacht)."
              class="s-input s-textarea"
            >{pickI18n(directionsRow?.answer_i18n, hotelDefaultLang, directionsRow?.answer ?? '')}</textarea>
          </div>
          <div class="s-card__footer">
            <button type="submit" class="v9-btn">Anfahrt speichern</button>
          </div>
        </form>
      </section>

    </div>
  </div>
</Layout>

<style>
  [x-cloak] { display: none !important; }

  /* Touch-target & active state (iPad) */
  .v9-btn { min-height: 44px; }
  .v9-btn:active:not(:disabled) { background: var(--te-yellow); color: #0A0A0A; }
  .v9-btn.v9-btn--ghost:active:not(:disabled) { background: var(--bg-deep); color: var(--ink); }

  /* Textarea variant */
  .s-textarea { resize: vertical; min-height: 80px; }

  /* FAQ List */
  .ev-list {
    border-top: 1px solid var(--border);
    margin-top: 24px;
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ev-item {
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg);
    transition: border-color 300ms ease, box-shadow 300ms ease;
  }
  .ev-item--highlight {
    border-color: var(--te-yellow) !important;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--te-yellow) 30%, transparent);
  }


  .ev-item__view {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 16px;
  }
  .ev-item__content { flex: 1; min-width: 0; }
  .ev-item__q {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink); margin: 0 0 6px;
  }
  .ev-item__a {
    font-size: 13px; color: var(--ink-soft);
    line-height: 1.55; margin: 0;
    white-space: pre-wrap;
  }
  .ev-item__actions {
    display: flex; gap: 6px; flex-shrink: 0; align-items: center;
  }

  .ev-action-btn {
    padding: 6px 12px !important;
    min-height: 36px !important;
    font-size: 10px !important;
  }
  .ev-action-btn--delete {
    color: var(--burgund) !important;
    border-color: color-mix(in srgb, var(--burgund) 30%, transparent) !important;
  }
  .ev-action-btn--delete:hover { background: var(--burgund-soft) !important; }

  .ev-item__edit-body {
    display: flex; flex-direction: column; gap: 16px;
    padding: 14px 16px 0;
  }
  .ev-item__edit-footer {
    display: flex; gap: 8px; padding: 12px 16px;
    border-top: 1px solid var(--border); margin-top: 14px;
  }

  .ev-empty-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--ink-muted);
    text-align: center; padding: 24px; margin: 16px 0 0;
    border-top: 1px solid var(--border);
  }
</style>
