---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

// ─── POST-HANDLER ──────────────────────────────────────────────────────────
type SaveResult = { section: string; ok: boolean; msg: string };
let saved: SaveResult | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString() ?? '';

  if (action === 'hotel_identity') {
    const name           = form.get('name')?.toString().trim() || null;
    const classification = form.get('classification')?.toString() || null;
    const hotel_type     = form.get('hotel_type')?.toString() || null;
    if (!name) {
      saved = { section: 'hotel_identity', ok: false, msg: 'Hotel-Name ist ein Pflichtfeld.' };
    } else {
      const { error } = await client.from('hotels')
        .update({ name, classification, hotel_type })
        .eq('id', hotel.id);
      saved = error
        ? { section: 'hotel_identity', ok: false, msg: error.message }
        : { section: 'hotel_identity', ok: true,  msg: '✓ Gespeichert' };
    }

  } else if (action === 'address_contact') {
    const address_street = form.get('address_street')?.toString().trim() || null;
    const address_zip    = form.get('address_zip')?.toString().trim()    || null;
    const city           = form.get('city')?.toString().trim()           || null;
    const country        = form.get('country')?.toString().trim()        || null;
    const phone          = form.get('phone')?.toString().trim()          || null;
    const email          = form.get('email')?.toString().trim()          || null;
    const website        = form.get('website')?.toString().trim()        || null;

    let lat: number | null = null, lng: number | null = null;
    if (address_street && city) {
      try {
        const { geocodeAddress, buildAddressQuery } = await import('../lib/places/geocoding');
        const q = buildAddressQuery({ street: address_street, zip: address_zip, city, country });
        const r = await geocodeAddress(q);
        if (r) { lat = r.lat; lng = r.lng; }
      } catch { /* geocoding non-fatal */ }
    }

    const updates: Record<string, unknown> = { address_street, address_zip, city, country, phone, email, website };
    if (lat !== null && lng !== null) { updates.latitude = lat; updates.longitude = lng; }

    const { error } = await client.from('hotels').update(updates).eq('id', hotel.id);
    saved = error
      ? { section: 'address_contact', ok: false, msg: error.message }
      : { section: 'address_contact', ok: true, msg: lat ? `✓ Gespeichert · 📍 ${lat.toFixed(4)}, ${lng!.toFixed(4)}` : '✓ Gespeichert' };

  } else if (action === 'business_data') {
    const { error } = await client.from('hotels').update({
      legal_form:          form.get('legal_form')?.toString().trim()          || null,
      company_name:        form.get('company_name')?.toString().trim()        || null,
      commercial_register: form.get('commercial_register')?.toString().trim() || null,
      vat_id:              form.get('vat_id')?.toString().trim()              || null,
      tax_number:          form.get('tax_number')?.toString().trim()          || null,
    }).eq('id', hotel.id);
    saved = error
      ? { section: 'business_data', ok: false, msg: error.message }
      : { section: 'business_data', ok: true, msg: '✓ Gespeichert' };

  } else if (action === 'billing_address') {
    const sameAsHotel = form.get('billing_same_as_hotel') === 'on';
    let updates: Record<string, unknown>;
    if (sameAsHotel) {
      const { data: h } = await client.from('hotels')
        .select('address_street,address_zip,city,country,company_name')
        .eq('id', hotel.id).maybeSingle();
      updates = {
        billing_recipient: form.get('billing_recipient')?.toString().trim() || (h as any)?.company_name || null,
        billing_email:     form.get('billing_email')?.toString().trim()     || null,
        billing_street:    (h as any)?.address_street,
        billing_zip:       (h as any)?.address_zip,
        billing_city:      (h as any)?.city,
        billing_country:   (h as any)?.country,
      };
    } else {
      updates = {
        billing_recipient: form.get('billing_recipient')?.toString().trim() || null,
        billing_email:     form.get('billing_email')?.toString().trim()     || null,
        billing_street:    form.get('billing_street')?.toString().trim()    || null,
        billing_zip:       form.get('billing_zip')?.toString().trim()       || null,
        billing_city:      form.get('billing_city')?.toString().trim()      || null,
        billing_country:   form.get('billing_country')?.toString().trim()   || null,
      };
    }
    const { error } = await client.from('hotels').update(updates).eq('id', hotel.id);
    saved = error
      ? { section: 'billing_address', ok: false, msg: error.message }
      : { section: 'billing_address', ok: true, msg: '✓ Gespeichert' };

  } else if (action === 'team_security') {
    // mfa_required_for_team ist der korrekte Spaltenname in der DB
    const mfa_required_for_team = form.get('mfa_required') === 'on';
    const session_timeout_hours = parseInt(form.get('session_timeout_hours')?.toString() || '4') || 4;
    const { error } = await client.from('hotels')
      .update({ mfa_required_for_team, session_timeout_hours })
      .eq('id', hotel.id);
    saved = error
      ? { section: 'team_security', ok: false, msg: error.message }
      : { section: 'team_security', ok: true, msg: '✓ Gespeichert' };
  }
}

// ─── DATEN LADEN ───────────────────────────────────────────────────────────
const { data: h } = await client.from('hotels').select(`
  name, classification, hotel_type,
  address_street, address_zip, city, country,
  phone, email, website,
  legal_form, company_name, commercial_register, vat_id, tax_number,
  billing_recipient, billing_email,
  billing_street, billing_zip, billing_city, billing_country,
  mfa_required_for_team, session_timeout_hours
`).eq('id', hotel.id).maybeSingle();

const d = (h ?? {}) as Record<string, unknown>;
function val(key: string, fallback = '') { return (d[key] as string) ?? fallback; }
function isChecked(key: string) { return d[key] === true; }
function isSelected(key: string, value: string, fallback = '') {
  return (d[key] as string ?? fallback) === value;
}
---

<Layout title="Einstellungen" activeTab="backoffice" hotelName={String(d.name ?? '')} hotelLogoUrl={hotel.logo_url}>

  <div class="settings-page">

    <!-- BREADCRUMB -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Einstellungen</span>
    </nav>

    <!-- HERO -->
    <section class="settings-hero">
      <span class="settings-hero__eyebrow">admin-einstellungen</span>
      <h1 class="settings-hero__title">Hotel-Einstellungen<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">Hier verwaltest du die Daten und Regeln deines Hotels.</p>
    </section>

    <div class="settings-sections">

      <!-- ── SECTION 1: HOTEL-IDENTITÄT ─────────────────────────────────── -->
      <section class="s-card" id="hotel-identity">
        <div class="s-card__head">
          <h2 class="s-card__title">Hotel-Identität</h2>
          <span class="s-card__num">01</span>
        </div>

        {saved?.section === 'hotel_identity' && (
          <div class={`s-flash ${saved.ok ? 's-flash--ok' : 's-flash--err'}`}>{saved.msg}</div>
        )}

        <form method="POST" class="s-card__body">
          <input type="hidden" name="_action" value="hotel_identity" />

          <div class="field field--row">
            <label class="field__label field__label--req" for="hotel-name">Hotel-Name</label>
            <div class="field__input-wrap">
              <input type="text" id="hotel-name" name="name" class="s-input"
                value={val('name')} placeholder="z.B. The Gate Garden" required />
              <span class="field__hint">Wird überall verwendet — Header, E-Mails, Gäste-App</span>
            </div>
          </div>

          <div class="field field--row">
            <span class="field__label">Klassifikation</span>
            <div class="radio-cards" role="radiogroup">
              {[['3','3 Sterne'],['4','4 Sterne'],['4s','4 Superior'],['5','5 Sterne'],['boutique','Boutique']].map(([v, l]) => (
                <label class={`radio-card ${val('classification') === v ? 'is-active' : ''}`}>
                  <input type="radio" name="classification" value={v}
                    checked={val('classification') === v} class="sr-only" />
                  {l}
                </label>
              ))}
            </div>
          </div>

          <div class="field field--row">
            <label class="field__label" for="hotel-type">Hotel-Typ</label>
            <div class="s-select-wrap">
              <select id="hotel-type" name="hotel_type" class="s-select">
                <option value="city"     selected={isSelected('hotel_type','city')}>Stadt-Hotel</option>
                <option value="resort"   selected={isSelected('hotel_type','resort')}>Resort</option>
                <option value="wellness" selected={isSelected('hotel_type','wellness')}>Wellness-Hotel</option>
                <option value="business" selected={isSelected('hotel_type','business')}>Business-Hotel</option>
                <option value="boutique" selected={isSelected('hotel_type','boutique')}>Boutique-Hotel</option>
              </select>
            </div>
          </div>

          <div class="s-card__footer">
            <button type="submit" class="s-btn">Speichern</button>
          </div>
        </form>
      </section>

      <!-- ── SECTION 2: ADRESSE & KONTAKT ──────────────────────────────── -->
      <section class="s-card" id="address-contact">
        <div class="s-card__head">
          <h2 class="s-card__title">Adresse & Kontakt</h2>
          <span class="s-card__num">02</span>
        </div>

        {saved?.section === 'address_contact' && (
          <div class={`s-flash ${saved.ok ? 's-flash--ok' : 's-flash--err'}`}>{saved.msg}</div>
        )}

        <form method="POST" class="s-card__body">
          <input type="hidden" name="_action" value="address_contact" />

          <div class="field field--row">
            <label class="field__label" for="address-street">Straße</label>
            <input type="text" id="address-street" name="address_street" class="s-input"
              value={val('address_street')} placeholder="Invalidenstraße 122" />
          </div>

          <div class="field field--row">
            <label class="field__label" for="address-zip">PLZ / Stadt</label>
            <div class="field__split">
              <input type="text" id="address-zip" name="address_zip" class="s-input s-input--zip"
                value={val('address_zip')} placeholder="10115" />
              <input type="text" name="city" class="s-input"
                value={val('city')} placeholder="Berlin" />
            </div>
          </div>

          <div class="field field--row">
            <label class="field__label" for="address-country">Land</label>
            <div class="s-select-wrap">
              <select id="address-country" name="country" class="s-select">
                <option value="DE" selected={isSelected('country','DE','DE')}>Deutschland</option>
                <option value="AT" selected={isSelected('country','AT')}>Österreich</option>
                <option value="CH" selected={isSelected('country','CH')}>Schweiz</option>
                <option value="LU" selected={isSelected('country','LU')}>Luxemburg</option>
              </select>
            </div>
          </div>

          <div class="s-divider-label">— Kontakt (für Gäste sichtbar) —</div>

          <div class="field field--row">
            <label class="field__label" for="hotel-phone">Telefon</label>
            <input type="tel" id="hotel-phone" name="phone" class="s-input"
              value={val('phone')} placeholder="+49 30 123 456" />
          </div>

          <div class="field field--row">
            <label class="field__label" for="hotel-email">E-Mail</label>
            <input type="email" id="hotel-email" name="email" class="s-input"
              value={val('email')} placeholder="info@hotel.de" />
          </div>

          <div class="field field--row">
            <label class="field__label" for="hotel-website">Website</label>
            <input type="url" id="hotel-website" name="website" class="s-input"
              value={val('website')} placeholder="https://hotel.de" />
          </div>

          <div class="s-card__footer">
            <button type="submit" class="s-btn">Speichern</button>
          </div>
        </form>
      </section>

      <!-- ── SECTION 3: GESCHÄFTSDATEN ─────────────────────────────────── -->
      <section class="s-card" id="business-data">
        <div class="s-card__head">
          <h2 class="s-card__title">Geschäftsdaten</h2>
          <span class="s-card__num">03</span>
        </div>

        {saved?.section === 'business_data' && (
          <div class={`s-flash ${saved.ok ? 's-flash--ok' : 's-flash--err'}`}>{saved.msg}</div>
        )}

        <form method="POST" class="s-card__body">
          <input type="hidden" name="_action" value="business_data" />

          <div class="field field--row">
            <label class="field__label" for="legal-form">Rechtsform</label>
            <div class="s-select-wrap">
              <select id="legal-form" name="legal_form" class="s-select">
                <option value="">— Bitte wählen —</option>
                {[['GmbH','GmbH'],['GmbH & Co. KG','GmbH & Co. KG'],['UG','UG (haftungsbeschränkt)'],['AG','AG'],['KG','KG'],['OHG','OHG'],['GbR','GbR'],['Einzelunternehmen','Einzelunternehmen']].map(([v,l]) => (
                  <option value={v} selected={val('legal_form') === v}>{l}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="field field--row">
            <label class="field__label" for="company-name">Firmenname</label>
            <input type="text" id="company-name" name="company_name" class="s-input"
              value={val('company_name')} placeholder="The Gate Garden Hotel GmbH" />
          </div>

          <div class="field field--row">
            <label class="field__label" for="commercial-register">Handelsregister-Nr.</label>
            <input type="text" id="commercial-register" name="commercial_register" class="s-input"
              value={val('commercial_register')} placeholder="HRB 12345" />
          </div>

          <div class="field field--row">
            <label class="field__label" for="vat-id">USt-ID</label>
            <input type="text" id="vat-id" name="vat_id" class="s-input"
              value={val('vat_id')} placeholder="DE123456789" />
          </div>

          <div class="field field--row">
            <label class="field__label" for="tax-number">Steuernummer</label>
            <input type="text" id="tax-number" name="tax_number" class="s-input"
              value={val('tax_number')} placeholder="12/345/67890" />
          </div>

          <div class="s-card__footer">
            <button type="submit" class="s-btn">Speichern</button>
          </div>
        </form>
      </section>

      <!-- ── SECTION 4: RECHNUNGSADRESSE ──────────────────────────────── -->
      <section class="s-card" id="billing-address">
        <div class="s-card__head">
          <h2 class="s-card__title">Rechnungsadresse</h2>
          <span class="s-card__num">04</span>
        </div>
        <p class="s-card__sub">Für das retaha-Abo</p>

        {saved?.section === 'billing_address' && (
          <div class={`s-flash ${saved.ok ? 's-flash--ok' : 's-flash--err'}`}>{saved.msg}</div>
        )}

        <form method="POST" class="s-card__body">
          <input type="hidden" name="_action" value="billing_address" />

          <label class="toggle-row">
            <input type="checkbox" name="billing_same_as_hotel" id="billing-same" class="sr-only" />
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
            <span class="toggle-label">Wie Hotel-Adresse übernehmen</span>
          </label>

          <div id="billing-fields">
            <div class="field field--row">
              <label class="field__label" for="billing-recipient">Empfänger</label>
              <input type="text" id="billing-recipient" name="billing_recipient" class="s-input"
                value={val('billing_recipient')} placeholder="The Gate Garden Hotel GmbH" />
            </div>

            <div class="field field--row">
              <label class="field__label" for="billing-email">Rechnungs-E-Mail</label>
              <input type="email" id="billing-email" name="billing_email" class="s-input"
                value={val('billing_email')} placeholder="buchhaltung@hotel.de" />
            </div>

            <div class="field field--row">
              <label class="field__label" for="billing-street">Straße</label>
              <input type="text" id="billing-street" name="billing_street" class="s-input"
                value={val('billing_street')} placeholder="Invalidenstraße 122" />
            </div>

            <div class="field field--row">
              <label class="field__label" for="billing-zip">PLZ / Stadt</label>
              <div class="field__split">
                <input type="text" id="billing-zip" name="billing_zip" class="s-input s-input--zip"
                  value={val('billing_zip')} placeholder="10115" />
                <input type="text" name="billing_city" class="s-input"
                  value={val('billing_city')} placeholder="Berlin" />
              </div>
            </div>

            <div class="field field--row">
              <label class="field__label" for="billing-country">Land</label>
              <div class="s-select-wrap">
                <select id="billing-country" name="billing_country" class="s-select">
                  <option value="DE" selected={isSelected('billing_country','DE','DE')}>Deutschland</option>
                  <option value="AT" selected={isSelected('billing_country','AT')}>Österreich</option>
                  <option value="CH" selected={isSelected('billing_country','CH')}>Schweiz</option>
                  <option value="LU" selected={isSelected('billing_country','LU')}>Luxemburg</option>
                </select>
              </div>
            </div>
          </div>

          <div class="s-card__footer">
            <button type="submit" class="s-btn">Speichern</button>
          </div>
        </form>
      </section>

      <!-- ── SECTION 5: TEAM-SICHERHEIT ────────────────────────────────── -->
      <section class="s-card" id="team-security">
        <div class="s-card__head">
          <h2 class="s-card__title">Team-Sicherheit</h2>
          <span class="s-card__num">05</span>
        </div>

        {saved?.section === 'team_security' && (
          <div class={`s-flash ${saved.ok ? 's-flash--ok' : 's-flash--err'}`}>{saved.msg}</div>
        )}

        <div class="s-warning-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               width="16" height="16" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <circle cx="12" cy="16" r="0.5" fill="currentColor"/>
          </svg>
          <span>Deine persönliche 2FA findest du unter
            <a href="/account/sicherheit">Account → Sicherheit</a>
          </span>
        </div>

        <form method="POST" class="s-card__body">
          <input type="hidden" name="_action" value="team_security" />

          <div class="field field--row">
            <span class="field__label">2FA für alle Mitarbeiter</span>
            <label class="toggle-row">
              <input type="checkbox" name="mfa_required" class="sr-only"
                checked={isChecked('mfa_required_for_team')} />
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
              <span class="toggle-label">Mitarbeiter ohne 2FA können sich nicht anmelden</span>
            </label>
          </div>

          <div class="field field--row">
            <label class="field__label" for="session-timeout">Session-Timeout</label>
            <div class="s-select-wrap">
              <select id="session-timeout" name="session_timeout_hours" class="s-select">
                <option value="1"  selected={isSelected('session_timeout_hours','1')}>1 Stunde</option>
                <option value="2"  selected={isSelected('session_timeout_hours','2')}>2 Stunden</option>
                <option value="4"  selected={isSelected('session_timeout_hours','4','4')}>4 Stunden</option>
                <option value="8"  selected={isSelected('session_timeout_hours','8')}>8 Stunden</option>
                <option value="24" selected={isSelected('session_timeout_hours','24')}>24 Stunden</option>
                <option value="0"  selected={isSelected('session_timeout_hours','0')}>Kein Timeout</option>
              </select>
            </div>
          </div>

          <div class="s-card__footer">
            <a href="/admin/team-security" class="s-btn-link">↗ Audit-Log & Team-Verwaltung</a>
            <button type="submit" class="s-btn">Speichern</button>
          </div>
        </form>
      </section>

    </div>
  </div>

</Layout>

<script>
  // Radio-Cards toggle
  document.querySelectorAll('.radio-cards').forEach(group => {
    group.querySelectorAll<HTMLLabelElement>('.radio-card').forEach(card => {
      const input = card.querySelector('input[type="radio"]') as HTMLInputElement;
      card.addEventListener('click', () => {
        group.querySelectorAll('.radio-card').forEach(c => c.classList.remove('is-active'));
        card.classList.add('is-active');
        if (input) input.checked = true;
      });
    });
  });

  // Rechnungsadresse Toggle
  const billingSame = document.getElementById('billing-same') as HTMLInputElement;
  const billingFields = document.getElementById('billing-fields');
  billingSame?.addEventListener('change', () => {
    if (billingFields) billingFields.style.opacity = billingSame.checked ? '0.4' : '1';
  });
</script>

<style>
  .settings-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }
  @media (max-width: 768px) { .settings-page { padding: 0 20px 64px; } }

  /* BREADCRUMB */
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-muted);
  }
  .breadcrumb__sep { color: var(--ink-faint); }
  .breadcrumb__crumb { color: var(--ink-muted); text-decoration: none; transition: color 150ms; }
  .breadcrumb__crumb:hover { color: var(--ink); }
  .breadcrumb__crumb--current { color: var(--ink); font-weight: 500; }

  /* HERO */
  .settings-hero {
    padding: 40px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }
  .settings-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
    color: #0A0A0A; background: var(--te-yellow);
    padding: 5px 10px; display: inline-block;
    margin-bottom: 20px; border-radius: var(--r-sm);
    text-transform: lowercase;
  }
  .settings-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(32px, 5vw, 52px); font-weight: 400;
    line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 10px;
    color: var(--ink);
  }
  .dot-pink { color: var(--pink); }
  .settings-hero__sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.04em;
  }

  /* SECTIONS */
  .settings-sections { display: flex; flex-direction: column; gap: 20px; }

  /* CARD */
  .s-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 32px;
  }
  @media (max-width: 768px) { .s-card { padding: 24px 20px; } }

  .s-card__head {
