---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import { getEnv } from '@retaha/db';
import QRCode from 'qrcode';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'settings.read')) return new Response('Forbidden', { status: 403 });
const canWrite = hasPermission(myRole, 'settings.write');

const client = createSupabaseServiceRoleInstance();
const { data: tagRows } = await client
  .from('nfc_tags')
  .select('id, label, target_type, target_value, is_active, scan_count, last_scanned_at, created_at')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false });
const tags = (tagRows ?? []) as any[];

const siteOrigin = (getEnv('PUBLIC_SITE_URL') || 'http://localhost:4321').replace(/\/$/, '');

const tagQrMap = new Map<string, string>();
for (const t of tags) {
  const url = `${siteOrigin}/n/${t.id}`;
  try {
    const dataUrl = await QRCode.toDataURL(url, {
      errorCorrectionLevel: 'M',
      margin: 2,
      width: 280,
    });
    tagQrMap.set(t.id, dataUrl);
  } catch (err) {
    console.warn('[nfc-tags] qr generation failed for', t.id, (err as Error).message);
  }
}

const TYPE_LABELS: Record<string, string> = {
  guest_stay:    bt('nfc.type.stay', lang),
  hotel_general: bt('nfc.type.general', lang),
  room:          bt('nfc.type.room', lang),
  custom_url:    bt('nfc.type.url', lang),
};

function targetSummary(t: any): string {
  if (t.target_type === 'room' && t.target_value?.room_number) return `${bt('nfc.target.room', lang)} ${t.target_value.room_number}`;
  if (t.target_type === 'custom_url' && t.target_value?.url) {
    try { return new URL(t.target_value.url).host; } catch { return t.target_value.url; }
  }
  if (t.target_type === 'hotel_general') return bt('nfc.target.general', lang);
  if (t.target_type === 'guest_stay' && t.target_value?.stay_id) return 'Stay ' + String(t.target_value.stay_id).slice(0, 8);
  return '—';
}

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString(lang, { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

// Client-Strings für Alpine-Component (über JSON-Block #nfc-i18n)
const tJs = {
  labelMissing: bt('nfc.js.labelmissing', lang),
  error: bt('nfc.js.error', lang),
  tagCreated: bt('nfc.js.tagcreated', lang),
  bulkRange: bt('nfc.js.bulkrange', lang),
  tagsCreated: bt('nfc.js.tagscreated', lang),
};
---

<Layout title="NFC-Tags" activeTab="backoffice">
  <div class="settings-page" x-data="nfcTagsAdmin()">
    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('nfc.title', lang) + '<span class="h-dot">.</span>'}></h1>
      <p class="settings-hero__sub" set:html={bt('nfc.sub', lang)}></p>
    </section>

    <section class="nf-howto">
      <p class="nf-section-eyebrow">{bt('nfc.howto.title', lang)}</p>
      <div class="nf-steps">
        <div class="nf-step">
          <span class="nf-step-num">1</span>
          <p class="nf-step-text" set:html={bt('nfc.step1', lang)}></p>
        </div>
        <div class="nf-step">
          <span class="nf-step-num">2</span>
          <p class="nf-step-text" set:html={bt('nfc.step2', lang)}></p>
        </div>
        <div class="nf-step">
          <span class="nf-step-num">3</span>
          <p class="nf-step-text" set:html={bt('nfc.step3', lang)}></p>
        </div>
      </div>
    </section>

    {canWrite && (
      <section class="nf-form-row">
        <button class="nf-btn-primary" type="button" @click="single = !single; bulk = false">
          <span x-text={`single ? ${JSON.stringify(bt('nfc.close', lang))} : ${JSON.stringify(bt('nfc.newtag.btn', lang))}`}></span>
        </button>
        <button class="nf-btn-ghost" type="button" @click="bulk = !bulk; single = false">
          <span x-text={`bulk ? ${JSON.stringify(bt('nfc.close', lang))} : ${JSON.stringify(bt('nfc.bulk.btn', lang))}`}></span>
        </button>
      </section>
    )}

    {canWrite && (
      <>
        <section class="nf-create" x-show="single" x-cloak>
          <h3 class="nf-form-title">{bt('nfc.form.newtag', lang)}</h3>
          <label class="nf-field">
            <span class="nf-label">{bt('nfc.label', lang)}</span>
            <input type="text" x-model="form.label" placeholder="z.B. Lobby Empfang" class="nf-input" maxlength="60" />
          </label>
          <label class="nf-field">
            <span class="nf-label">{bt('nfc.type', lang)}</span>
            <select x-model="form.target_type" class="nf-input">
              <option value="hotel_general">{bt('nfc.type.general.opt', lang)}</option>
              <option value="room">{bt('nfc.type.room.opt', lang)}</option>
              <option value="custom_url">{bt('nfc.type.url.opt', lang)}</option>
              <option value="guest_stay">{bt('nfc.type.stay.opt', lang)}</option>
            </select>
          </label>
          <label class="nf-field" x-show="form.target_type === 'room'">
            <span class="nf-label">{bt('nfc.roomnr', lang)}</span>
            <input type="text" x-model="form.room_number" placeholder="z.B. 204" class="nf-input" />
          </label>
          <label class="nf-field" x-show="form.target_type === 'custom_url'">
            <span class="nf-label">{bt('nfc.url', lang)}</span>
            <input type="url" x-model="form.url" placeholder="https://www.google.com/maps/place/…" class="nf-input" />
          </label>
          <label class="nf-field" x-show="form.target_type === 'guest_stay'">
            <span class="nf-label">{bt('nfc.stayid', lang)}</span>
            <input type="text" x-model="form.stay_id" placeholder="UUID" class="nf-input" />
          </label>
          <template x-if="form.error">
            <p class="nf-error" x-text="form.error"></p>
          </template>
          <div class="nf-actions">
            <button type="button" class="nf-btn-primary" :disabled="form.busy" @click="createTag()" x-text={`form.busy ? ${JSON.stringify(bt('nfc.creating', lang))} : ${JSON.stringify(bt('nfc.create', lang))}`}></button>
          </div>
        </section>

        <section class="nf-create" x-show="bulk" x-cloak>
          <h3 class="nf-form-title">{bt('nfc.bulk.title', lang)}</h3>
          <p class="nf-form-hint">{bt('nfc.bulk.hint', lang)}</p>
          <div class="nf-row">
            <label class="nf-field">
              <span class="nf-label">{bt('nfc.from', lang)}</span>
              <input type="number" min="1" x-model.number="bulkForm.from" class="nf-input nf-input--narrow" />
            </label>
            <label class="nf-field">
              <span class="nf-label">{bt('nfc.to', lang)}</span>
              <input type="number" min="1" x-model.number="bulkForm.to" class="nf-input nf-input--narrow" />
            </label>
            <label class="nf-field nf-flex-1">
              <span class="nf-label">{bt('nfc.prefix', lang)}</span>
              <input type="text" x-model="bulkForm.prefix" placeholder="z.B. Zimmer" class="nf-input" />
            </label>
          </div>
          <template x-if="bulkForm.error">
            <p class="nf-error" x-text="bulkForm.error"></p>
          </template>
          <div class="nf-actions">
            <button type="button" class="nf-btn-primary" :disabled="bulkForm.busy" @click="createBulk()" x-text={`bulkForm.busy ? ${JSON.stringify(bt('nfc.creating', lang))} : (bulkForm.to - bulkForm.from + 1) + ' ' + ${JSON.stringify(bt('nfc.bulk.createsuffix', lang))}`}></button>
          </div>
        </section>
      </>
    )}

    <section class="nf-list-section">
      <p class="nf-section-eyebrow">{tags.length} {tags.length === 1 ? bt('nfc.tag.one', lang) : bt('nfc.tag.many', lang)}</p>
      {tags.length === 0 ? (
        <div class="nf-empty"><p>{bt('nfc.empty', lang)}</p></div>
      ) : (
        <ul class="nf-list">
          {tags.map((t) => (
            <li class={`nf-tag-card${!t.is_active ? ' nf-tag-card--off' : ''}`} x-data={`{ showQr: false, busy: false }`}>
              <div class="nf-tag-main">
                <div class="nf-tag-head">
                  <span class={`nf-tag-pill${t.is_active ? ' is-on' : ''}`}>{t.is_active ? bt('nfc.pill.active', lang) : bt('nfc.pill.inactive', lang)}</span>
                  <span class="nf-tag-type">{TYPE_LABELS[t.target_type] ?? t.target_type}</span>
                </div>
                <h3 class="nf-tag-label">{t.label}</h3>
                <p class="nf-tag-target">→ {targetSummary(t)}</p>
                <div class="nf-tag-meta">
                  <span><strong>{t.scan_count}</strong> {bt('nfc.scans', lang)}</span>
                  <span class="nf-tag-meta-sep">·</span>
                  <span>{bt('nfc.last', lang)} {fmtDate(t.last_scanned_at)}</span>
                </div>
              </div>
              <div class="nf-tag-actions">
                <button class="nf-btn-ghost nf-btn-small" type="button" @click="showQr = !showQr" x-text={`showQr ? ${JSON.stringify(bt('nfc.qr.hide', lang))} : ${JSON.stringify(bt('nfc.qr.show', lang))}`}></button>
                {canWrite && (
                  <button
                    class="nf-btn-danger nf-btn-small"
                    type="button"
                    :disabled="busy"
                    @click={`if (!confirm(${JSON.stringify(bt('nfc.js.deleteconfirm', lang))})) return; busy = true; fetch('/api/admin/nfc-tags/${t.id}', { method: 'DELETE', credentials: 'include' }).then(r => r.json()).then(d => { busy = false; if (d.ok) { window.retahaToastFlash && window.retahaToastFlash(${JSON.stringify(bt('nfc.js.deleted', lang))}); location.reload(); } else { window.retahaToast && window.retahaToast(${JSON.stringify(bt('nfc.js.deletefail', lang))} + ' ' + (d.error || 'unbekannt'), 'error'); } })`}
                  >{bt('nfc.delete', lang)}</button>
                )}
              </div>
              <div x-show="showQr" x-cloak class="nf-qr">
                {tagQrMap.has(t.id) ? (
                  <>
                    <img src={tagQrMap.get(t.id)} alt={bt('nfc.qr.alt', lang).replace('{label}', t.label)} class="nf-qr-img" />
                    <p class="nf-qr-help">{bt('nfc.qr.help', lang)}</p>
                    <code class="nf-qr-url">{`${siteOrigin}/n/${t.id}`}</code>
                  </>
                ) : (
                  <p class="nf-qr-help">{bt('nfc.qr.failed', lang)}</p>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>

  <script type="application/json" id="nfc-i18n" is:inline set:html={JSON.stringify(tJs)}></script>

  <script>
    const T = JSON.parse(document.getElementById('nfc-i18n')?.textContent || '{}');
    document.addEventListener('alpine:init', () => {
      // @ts-expect-error - Alpine global
      window.Alpine.data('nfcTagsAdmin', () => ({
        single: false,
        bulk: false,
        form: {
          label: '', target_type: 'hotel_general', room_number: '', url: '', stay_id: '',
          busy: false, error: '',
        },
        bulkForm: { from: 101, to: 110, prefix: 'Zimmer', busy: false, error: '' },

        async createTag() {
          if (this.form.busy) return;
          this.form.error = '';
          const payload: any = { label: this.form.label?.trim(), target_type: this.form.target_type };
          if (!payload.label) { this.form.error = T.labelMissing; return; }
          if (this.form.target_type === 'room') payload.target_value = { room_number: this.form.room_number?.trim() };
          if (this.form.target_type === 'custom_url') payload.target_value = { url: this.form.url?.trim() };
          if (this.form.target_type === 'guest_stay') payload.target_value = { stay_id: this.form.stay_id?.trim() };
          this.form.busy = true;
          try {
            const res = await fetch('/api/admin/nfc-tags/create', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json();
            if (!data.ok) { this.form.error = data.error || T.error; return; }
            window.retahaToastFlash && window.retahaToastFlash(T.tagCreated);
            location.reload();
          } finally { this.form.busy = false; }
        },

        async createBulk() {
          if (this.bulkForm.busy) return;
          this.bulkForm.error = '';
          if (this.bulkForm.to < this.bulkForm.from) { this.bulkForm.error = T.bulkRange; return; }
          this.bulkForm.busy = true;
          try {
            const res = await fetch('/api/admin/nfc-tags/create', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ bulk: { mode: 'room_range', from: this.bulkForm.from, to: this.bulkForm.to, label_prefix: this.bulkForm.prefix } }),
            });
            const data = await res.json();
            if (!data.ok) { this.bulkForm.error = data.error || T.error; return; }
            window.retahaToastFlash && window.retahaToastFlash(T.tagsCreated);
            location.reload();
          } finally { this.bulkForm.busy = false; }
        },
      }));
    });
  </script>

  <style>
    :global(.h-dot) { color: #14616E; }

    .nf-section-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-muted); margin: 0 0 8px;
    }

    .nf-howto {
      background: var(--bg-deep); padding: 20px; margin-bottom: 24px;
      border-left: 3px solid #14616E; border-radius: 16px;
    }
    .nf-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 12px; }
    @media (max-width: 720px) { .nf-steps { grid-template-columns: 1fr; } }
    .nf-step { display: flex; gap: 10px; align-items: flex-start; }
    .nf-step-num {
      width: 24px; height: 24px; background: #14616E; color: #fff;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 500; flex-shrink: 0;
    }
    .nf-step-text { margin: 2px 0 0; font-size: 13px; line-height: 1.5; color: var(--ink-soft); }
    .nf-step-text strong { color: var(--ink); }

    .nf-form-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }

    .nf-btn-primary {
      padding: 10px 18px; background: #14616E; color: #fff;
      border: none; border-radius: 8px; cursor: pointer;
      font-family: inherit; font-size: 13px; font-weight: 500; transition: filter .15s;
    }
    .nf-btn-primary:hover:not(:disabled) { filter: brightness(1.08); }
    .nf-btn-primary:disabled { opacity: .5; cursor: not-allowed; }
    .nf-btn-ghost {
      padding: 10px 18px; background: transparent; color: var(--ink-muted);
      border: 1px solid var(--border); border-radius: 8px;
      cursor: pointer; font-family: inherit; font-size: 13px; transition: color .15s, border-color .15s;
    }
    .nf-btn-ghost:hover { color: var(--ink); border-color: var(--ink); }
    .nf-btn-ghost:disabled { opacity: .5; cursor: not-allowed; }
    .nf-btn-small { padding: 6px 12px; font-size: 12px; }
    .nf-btn-danger {
      padding: 10px 18px; background: transparent; color: #c0392b;
      border: 1px solid #c0392b; border-radius: 8px;
      cursor: pointer; font-family: inherit; font-size: 13px; transition: background .15s;
    }
    .nf-btn-danger:hover:not(:disabled) { background: rgba(192,57,43,.08); }

    .nf-create {
      background: var(--surface); border: 1px solid var(--border);
      padding: 24px; margin-bottom: 24px; border-radius: 16px;
    }
    .nf-form-title { font-size: 14px; font-weight: 500; margin: 0 0 12px; }
    .nf-form-hint { font-size: 12px; color: var(--ink-muted); font-style: italic; margin: 0 0 12px; }
    .nf-field { display: block; margin-bottom: 12px; }
    .nf-label {
      display: block; font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-muted); margin-bottom: 8px;
    }
    .nf-input {
      width: 100%; box-sizing: border-box; padding: 10px 13px;
      font-family: inherit; font-size: 14px; border: 1px solid var(--border);
      border-radius: 8px; background: var(--surface); color: var(--ink); transition: border-color .15s;
    }
    .nf-input:focus { outline: none; border-color: #14616E; box-shadow: 0 0 0 3px rgba(20,97,110,.10); }
    .nf-input--narrow { width: 100px; }
    .nf-row { display: flex; gap: 12px; align-items: end; flex-wrap: wrap; }
    .nf-flex-1 { flex: 1; min-width: 160px; }
    .nf-actions {
      display: flex; gap: 8px; justify-content: flex-end;
      padding-top: 16px; border-top: 1px solid var(--border); margin-top: 8px;
    }
    .nf-error { color: #c0392b; font-size: 13px; margin: 8px 0; }

    .nf-list-section { margin-top: 24px; }
    .nf-empty {
      padding: 48px 24px; background: var(--surface);
      border: 1px dashed var(--border); border-radius: 16px;
      text-align: center; color: var(--ink-muted); font-style: italic;
    }
    .nf-empty p { margin: 0; }
    .nf-list { list-style: none; padding: 0; margin: 12px 0 0; display: flex; flex-direction: column; gap: 10px; }

    .nf-tag-card {
      background: var(--surface); border: 1px solid var(--border);
      padding: 20px; border-radius: 16px;
      display: grid; grid-template-columns: 1fr auto; gap: 12px;
      transition: border-color .15s, box-shadow .15s;
    }
    .nf-tag-card:hover { border-color: rgba(20,97,110,.3); box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .nf-tag-card--off { opacity: .55; }
    .nf-tag-main { min-width: 0; }
    .nf-tag-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
    .nf-tag-pill {
      font-family: 'JetBrains Mono', monospace; font-size: 10px;
      padding: 3px 10px; text-transform: uppercase; letter-spacing: 0.05em;
      background: var(--bg-deep); color: var(--ink-muted); border-radius: 99px;
    }
    .nf-tag-pill.is-on { background: rgba(76,175,80,.1); color: #4CAF50; border: 1px solid rgba(76,175,80,.35); }
    .nf-tag-type { font-size: 11px; color: var(--ink-muted); }
    .nf-tag-label { font-size: 16px; font-weight: 500; margin: 0 0 4px; color: var(--ink); }
    .nf-tag-target { font-size: 12px; color: var(--ink-soft); margin: 0 0 6px; font-family: 'JetBrains Mono', monospace; }
    .nf-tag-meta { font-size: 11px; color: var(--ink-muted); display: flex; gap: 6px; }
    .nf-tag-meta strong { color: var(--ink); font-weight: 500; }
    .nf-tag-meta-sep { color: var(--ink-faint); }
    .nf-tag-actions { display: flex; flex-direction: column; gap: 6px; align-items: flex-end; }
    @media (max-width: 600px) { .nf-tag-card { grid-template-columns: 1fr; } .nf-tag-actions { flex-direction: row; } }

    .nf-qr { grid-column: 1 / -1; padding-top: 16px; border-top: 1px solid var(--border); margin-top: 8px; text-align: center; }
    .nf-qr-img { display: block; margin: 0 auto 12px; max-width: 240px; width: 100%; height: auto; }
    .nf-qr-help { font-size: 12px; color: var(--ink-soft); margin: 0 0 8px; line-height: 1.5; }
    .nf-qr-url {
      font-family: 'JetBrains Mono', monospace; font-size: 11px;
      padding: 6px 10px; background: var(--bg-deep); border-radius: 6px;
      color: var(--ink); word-break: break-all; display: inline-block;
    }
  </style>
</Layout>
