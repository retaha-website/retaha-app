---
import Layout from '../layouts/Layout.astro';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
---
<Layout title={bt('hlp.titleplain', lang)} activeTab="backoffice">
  <section class="stub-page">
    <p class="stub-page__eyebrow">{bt('hlp.eyebrow', lang)}</p>
    <h1 class="stub-page__title" set:html={bt('hlp.title', lang)}></h1>
    <div class="stub-page__channels">
      <a href="https://wa.me/4915224046716" class="channel">
        <span class="channel__label">WhatsApp</span>
        <span class="channel__val">+49 152 240 46716</span>
      </a>
      <a href="mailto:support@retaha.de" class="channel">
        <span class="channel__label">{bt('hlp.ch.email', lang)}</span>
        <span class="channel__val">support@retaha.de</span>
      </a>
      <a href="tel:+4971316161950" class="channel">
        <span class="channel__label">{bt('hlp.ch.phone', lang)}</span>
        <span class="channel__val">+49 7131 616 1950</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .stub-page {
    max-width: 800px;
    margin: 64px auto;
    padding: 0 32px;
  }
  .stub-page__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .stub-page__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.025em;
    margin-bottom: 32px;
  }
  .stub-page__channels { display: flex; flex-direction: column; gap: 2px; }
  .channel {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    align-items: center;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: var(--r);
    text-decoration: none;
    transition: all 200ms ease;
  }
  .channel:hover { border-color: var(--ink); background: var(--bg-deep); }
  .channel__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--petrol, #14616E);
    text-transform: uppercase;
  }
  .channel__val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--ink);
  }
</style>
