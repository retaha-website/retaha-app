---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, getUserRole, hasPermission } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const billingRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!billingRole || !hasPermission(billingRole, 'hotel.billing')) {
  return Astro.redirect('/overview?error=billing_owner_only');
}

const currentPlan: string = (hotel as any).plan ?? 'lite';
---

<Layout
  title={bt('sub.titleplain', lang)}
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
>
  <script is:inline define:vars={{
    SUB_ERR_TRIAL: bt('sub.err.trial', lang),
    SUB_TRIAL_SENT: bt('sub.trial.sent', lang),
    SUB_HOTEL_NAME: hotel.name,
    SUB_USER_EMAIL: user.email ?? '',
  }}>
    window.__SUB_T__ = {
      errTrial: SUB_ERR_TRIAL,
      trialSent: SUB_TRIAL_SENT,
      hotelName: SUB_HOTEL_NAME,
      userEmail: SUB_USER_EMAIL,
    };
  </script>
  <div
    class="settings-page"
    x-data="{
      loading: '',
      downgradeConfirm: false,
      leadModal: false,
      leadPlan: '',
      leadPhone: '',
      leadTime: '',
      leadNote: '',
      leadSent: false,
      openLeadModal(plan) {
        this.leadPlan = plan;
        this.leadPhone = '';
        this.leadTime = '';
        this.leadNote = '';
        this.leadSent = false;
        this.leadModal = true;
      },
      async submitLead() {
        this.loading = 'lead';
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              plan: this.leadPlan,
              phone: this.leadPhone || undefined,
              preferred_time: this.leadTime || undefined,
              note: this.leadNote || undefined,
            })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          this.leadSent = true;
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      },
      async downgradeLite() {
        this.loading = 'lite';
        try {
          const res = await fetch('/api/subscription/downgrade-to-lite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.location.reload();
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
          this.downgradeConfirm = false;
        }
      },
      async requestAddon(addon) {
        this.loading = addon;
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ addon })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.retahaToast?.(window.__SUB_T__.trialSent, 'success');
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      }
    }"
  >

    <!-- ── Wow-Abo-Page ──────────────────────────────────────────────────── -->
    <div class="wow-page">

      <!-- Hero -->
      <div class="wow-hero">
        <div class="wow-eyebrow">retaha · Hospitality</div>
        <h1 class="wow-h1">Startet kostenlos.<br>Wachst, <span class="wow-g">wenn es sich lohnt.</span></h1>
        <p class="wow-sub">Kein Tarif-Dschungel, keine Preisschilder. Wählt, wie weit ihr gehen wollt — und seht, was jede Stufe für euch tut.</p>
      </div>

      <!-- Plan Cards -->
      <div class="wow-cards">

        <!-- LITE -->
        <div class={`wow-tier wow-tier--lite${currentPlan === 'lite' ? ' wow-tier--current' : ''}`}>
          {currentPlan === 'lite' && <div class="wow-your-plan">Euer aktueller Plan</div>}
          <div class="wow-tcap">Lite · Kostenlos</div>
          <h2 class="wow-tier__h2">Kostenlos modern werden.</h2>
          <div class="wow-frame">Eure Gästemappe wird digital — null Kosten, null Risiko.</div>
          <ul class="wow-bl">
            <li class="wow-b"><span class="wow-chk wow-chk--sage">✓</span><span>Gästemappe digital — <b>nie wieder nachdrucken</b></span></li>
            <li class="wow-b"><span class="wow-chk wow-chk--sage">✓</span><span>Eve beantwortet Gästefragen 24/7</span></li>
            <li class="wow-b"><span class="wow-chk wow-chk--sage">✓</span><span>Weniger Nachfragen am Empfang</span></li>
          </ul>
          <div class="wow-cta-wrap">
            {currentPlan === 'lite' ? (
              <span class="wow-cta wow-cta--current" aria-disabled="true">Euer Plan ✓</span>
            ) : (
              <Fragment>
                <div x-show="!downgradeConfirm" style="display:none">
                  <button type="button" class="wow-cta wow-cta--free" @click="downgradeConfirm = true" :disabled="loading !== ''">Kostenlos starten</button>
                </div>
                <div x-show="downgradeConfirm" class="wow-downgrade" style="display:none">
                  <p class="wow-downgrade__warn">{bt('sub.btn.toLite.warning', lang)}</p>
                  <div class="wow-downgrade__btns">
                    <button type="button" class="wow-cta wow-cta--danger" @click="downgradeLite()" :disabled="loading === 'lite'">
                      <span x-show="loading !== 'lite'">Ja, wechseln</span>
                      <span x-show="loading === 'lite'" style="display:none">…</span>
                    </button>
                    <button type="button" class="wow-cta wow-cta--ghost" @click="downgradeConfirm = false" :disabled="loading === 'lite'">Abbrechen</button>
                  </div>
                </div>
              </Fragment>
            )}
          </div>
        </div>

        <!-- PRO -->
        <div class={`wow-tier wow-tier--pro${currentPlan === 'pro' ? ' wow-tier--current' : ''}`}>
          {currentPlan === 'pro' && <div class="wow-your-plan">Euer aktueller Plan</div>}
          <div class="wow-tcap">Pro</div>
          <h2 class="wow-tier__h2">Eure Marke, mehr Reichweite, weniger Arbeit.</h2>
          <div class="wow-frame">Die Mappe sieht aus wie euer Haus — und Eve nimmt Arbeit ab.</div>
          <ul class="wow-bl">
            <li class="wow-b"><span class="wow-chk wow-chk--petrol">✓</span><span>Euer Branding statt Vorlage</span></li>
            <li class="wow-b"><span class="wow-chk wow-chk--petrol">✓</span><span>10 Sprachen automatisch</span></li>
            <li class="wow-b"><span class="wow-chk wow-chk--petrol">✓</span><span><b>Eve handelt</b>, nicht nur antworten</span></li>
          </ul>
          <div class="wow-cta-wrap">
            {currentPlan === 'pro' ? (
              <span class="wow-cta wow-cta--current" aria-disabled="true">Euer Plan ✓</span>
            ) : (
              <button type="button" class="wow-cta" @click="openLeadModal('pro')" :disabled="loading !== ''">Vertrieb kontaktieren</button>
            )}
          </div>
        </div>

        <!-- PREMIUM -->
        <div class={`wow-tier wow-tier--prem${currentPlan === 'premium' ? ' wow-tier--current' : ''}`}>
          <div class="wow-ribbon">{currentPlan === 'premium' ? 'Euer aktueller Plan' : 'Empfohlen · zahlt sich aus'}</div>
          <div class="wow-sheen" aria-hidden="true"></div>
          <div class="wow-tcap">Premium</div>
          <h2 class="wow-tier__h2">Mehr Direktumsatz, Wiederkehrer, weniger Aufwand.</h2>
          <div class="wow-frame">Die Stufe, die nicht nur kostet — sondern verdient.</div>
          <ul class="wow-bl">
            <li class="wow-b wow-b--money"><span class="wow-chk wow-chk--money">✓</span><span>Direkt buchen — <b>15–25 % OTA-Provision gespart</b></span></li>
            <li class="wow-b"><span class="wow-chk wow-chk--money">✓</span><span>Erstgäste zu Stammgästen (Wallet, Loyalty)</span></li>
            <li class="wow-b"><span class="wow-chk wow-chk--money">✓</span><span>Self-Check-out &amp; Tür per App</span></li>
          </ul>
          <div class="wow-cta-wrap">
            {currentPlan === 'premium' ? (
              <span class="wow-cta wow-cta--current" aria-disabled="true">Euer Plan ✓</span>
            ) : (
              <button type="button" class="wow-cta wow-cta--prem" @click="openLeadModal('premium')" :disabled="loading !== ''">Vertrieb kontaktieren</button>
            )}
          </div>
        </div>

        <!-- ENTERPRISE -->
        <div class={`wow-tier wow-tier--ent${currentPlan === 'enterprise' ? ' wow-tier--current' : ''}`}>
          {currentPlan === 'enterprise' && <div class="wow-your-plan">Euer aktueller Plan</div>}
          <div class="wow-tcap">Enterprise</div>
          <h2 class="wow-tier__h2">Für Gruppen: eure eigene App, zentral.</h2>
          <div class="wow-frame">Eure eigene Welt — für Ketten und Gruppen.</div>
          <ul class="wow-bl">
            <li class="wow-b"><span class="wow-chk">✓</span><span>Eure eigene <b>White-Label-App</b></span></li>
            <li class="wow-b"><span class="wow-chk">✓</span><span>Mehrere Häuser zentral</span></li>
            <li class="wow-b"><span class="wow-chk">✓</span><span>API + fester Ansprechpartner</span></li>
          </ul>
          <div class="wow-cta-wrap">
            {currentPlan === 'enterprise' ? (
              <span class="wow-cta wow-cta--current" aria-disabled="true">Euer Plan ✓</span>
            ) : (
              <button type="button" class="wow-cta" @click="openLeadModal('enterprise')" :disabled="loading !== ''">Kontakt aufnehmen</button>
            )}
          </div>
        </div>

      </div>

      <!-- Eve Show / Wow Moment -->
      <div class="wow-show">
        <div class="wow-show__txt">
          <span class="wow-tag">Zeigen statt aufzählen</span>
          <h3 class="wow-show__h3">Tippe ein Feature an — sieh, was es <span class="wow-au">kann.</span></h3>
          <p class="wow-show__p">Jedes gesperrte Modul zeigt eine kurze Live-Vorschau, statt nur einen Haken in einer Liste. Hier: ein Gast fragt, <b>Eve handelt</b> — und bucht direkt aufs Zimmer.</p>
          <p class="wow-show__note">Der Unterschied zwischen „Microsite-Builder ✓" und dem Gefühl, zu <i>sehen</i>, wie der Umsatz reinkommt.</p>
        </div>
        <div class="wow-demo" aria-hidden="true">
          <div class="wow-demo__aurora"></div>
          <div class="wow-demo__scr">
            <div class="wow-demo__head">
              <span class="wow-demo__orb"></span>
              <span class="wow-demo__lbl">Eve · live</span>
            </div>
            <div class="wow-bub wow-bub--guest">Können wir Spätabreise um 14 Uhr buchen?</div>
            <div class="wow-bub wow-bub--eve">Erledige ich — Late Check-out bis 14:00, 25 €.</div>
            <div class="wow-act">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4"><path d="M5 12l5 5L20 6"/></svg>
              Auf Zimmer 204 gebucht
            </div>
          </div>
        </div>
      </div>

      <!-- Closing CTA -->
      <div class="wow-close">
        <h3 class="wow-close__h3">Fangt heute kostenlos an.</h3>
        <p class="wow-close__p">Lite kostet nichts und ist in Minuten live. Wenn ihr mehr wollt, reden wir — kein Risiko, kein Abo-Zwang.</p>
        <div class="wow-close__btns">
          {currentPlan !== 'lite' && (
            <button
              type="button"
              class="wow-cbtn wow-cbtn--light"
              @click="window.confirm('Zu Lite wechseln? Premium-Funktionen werden deaktiviert.') && downgradeLite()"
              :disabled="loading !== ''"
            >
              Kostenlos starten
            </button>
          )}
          {currentPlan === 'lite' && (
            <span class="wow-cbtn-curr">Euer Plan: Lite ✓</span>
          )}
          <button type="button" class="wow-cbtn wow-cbtn--outline" @click="openLeadModal('premium')" :disabled="loading !== ''">Vertrieb kontaktieren</button>
        </div>
      </div>

    </div>

    <!-- ── Lead-Modal ────────────────────────────────────────────────────── -->
    <div class="lead-overlay" x-show="leadModal" x-cloak @click.self="leadModal = false" style="display:none">
      <div class="lead-modal" @keydown.escape.window="leadModal = false" role="dialog" aria-modal="true">

        <!-- Bestätigung nach Absenden -->
        <div x-show="leadSent" class="lead-sent" style="display:none">
          <div class="lead-sent__icon">✓</div>
          <h2 class="lead-sent__title">Danke — wir melden uns!</h2>
          <p class="lead-sent__sub">Deine Anfrage ist eingegangen. Wir kommen in Kürze auf dich zu.</p>
          <button type="button" class="v9-btn v9-btn--primary lead-close-btn" @click="leadModal = false">
            Schließen
          </button>
        </div>

        <!-- Formular -->
        <div x-show="!leadSent" style="display:none">
          <div class="lead-modal__head">
            <div>
              <p class="lead-modal__eyebrow">Upgrade-Interesse</p>
              <h2 class="lead-modal__title">
                Kontakt für <span class="lead-plan-chip" x-text="leadPlan.toUpperCase()"></span>
              </h2>
            </div>
            <button type="button" class="lead-modal__close" @click="leadModal = false" aria-label="Schließen">✕</button>
          </div>

          <!-- Read-only Hotel-Info -->
          <div class="lead-readonlys">
            <div class="lead-readonly">
              <span class="lead-readonly__label">Hotel</span>
              <span class="lead-readonly__val" x-text="window.__SUB_T__.hotelName"></span>
            </div>
            <div class="lead-readonly">
              <span class="lead-readonly__label">E-Mail</span>
              <span class="lead-readonly__val" x-text="window.__SUB_T__.userEmail"></span>
            </div>
          </div>

          <form class="lead-form" @submit.prevent="submitLead()">
            <div class="lead-field">
              <label class="lead-label" for="lead-phone">Telefon</label>
              <input
                id="lead-phone"
                type="tel"
                class="s-input lead-input"
                placeholder="+49 123 456789"
                x-model="leadPhone"
                autocomplete="tel"
              />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-time">Wunsch-Zeitfenster</label>
              <input
                id="lead-time"
                type="text"
                class="s-input lead-input"
                placeholder="z.B. Mo–Fr 9–12 Uhr"
                x-model="leadTime"
              />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-note">Notiz <span style="color:var(--ink-muted)">(optional)</span></label>
              <textarea
                id="lead-note"
                class="s-input lead-input"
                rows="3"
                placeholder="Was noch wichtig ist…"
                x-model="leadNote"
                style="resize:vertical"
              ></textarea>
            </div>

            <div class="lead-actions">
              <button type="button" class="v9-btn v9-btn--ghost" @click="leadModal = false">
                Abbrechen
              </button>
              <button
                type="submit"
                class="v9-btn v9-btn--primary lead-submit"
                :disabled="loading === 'lead'"
              >
                <span x-show="loading !== 'lead'">Anfrage absenden →</span>
                <span x-show="loading === 'lead'" style="display:none">Wird gesendet…</span>
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>

  </div>
</Layout>

<style>
  /* ── Lead Modal ─────────────────────────────────────────────────────────── */
  .lead-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.45);
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }
  .lead-modal {
    background: var(--surface, #fff);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 16px;
    padding: 28px;
    width: 100%; max-width: 480px;
    box-shadow: 0 20px 60px rgba(0,0,0,.12);
  }
  .lead-modal__head {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 20px; gap: 12px;
  }
  .lead-modal__eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink-muted, #888);
    margin: 0 0 4px;
  }
  .lead-modal__title {
    font-size: 18px; font-weight: 600; color: var(--ink, #1a1a1a);
    margin: 0; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .lead-plan-chip {
    background: var(--petrol, #14616E);
    color: #fff; font-size: 11px; font-weight: 600; letter-spacing: .08em;
    padding: 2px 8px; border-radius: 6px;
  }
  .lead-modal__close {
    background: none; border: none; cursor: pointer;
    color: var(--ink-muted, #888); font-size: 16px; line-height: 1;
    padding: 4px; border-radius: 6px; flex-shrink: 0;
  }
  .lead-modal__close:hover { color: var(--ink, #1a1a1a); background: var(--surface-alt, #f4f4f3); }
  .lead-readonlys {
    display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;
  }
  .lead-readonly {
    background: var(--surface-alt, #f4f4f3);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 8px; padding: 8px 12px;
    display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 140px;
  }
  .lead-readonly__label {
    font-size: 10px; font-weight: 500; letter-spacing: .06em;
    text-transform: uppercase; color: var(--ink-muted, #888);
  }
  .lead-readonly__val {
    font-size: 13px; font-weight: 500; color: var(--ink, #1a1a1a);
    word-break: break-all;
  }
  .lead-form { display: flex; flex-direction: column; gap: 14px; }
  .lead-field { display: flex; flex-direction: column; gap: 5px; }
  .lead-label { font-size: 13px; font-weight: 500; color: var(--ink, #1a1a1a); }
  .lead-input { width: 100%; }
  .lead-actions {
    display: flex; gap: 8px; justify-content: flex-end; margin-top: 6px;
  }
  .lead-submit { min-width: 160px; }
  .lead-sent {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 16px 0;
  }
  .lead-sent__icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--petrol, #14616E); color: #fff;
    font-size: 24px; display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .lead-sent__title { font-size: 18px; font-weight: 600; margin: 0 0 8px; }
  .lead-sent__sub { font-size: 14px; color: var(--ink-muted, #888); margin: 0 0 24px; }
  .lead-close-btn { min-width: 120px; }

  /* ── Wow-Abo-Page ───────────────────────────────────────────────────────── */
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');

  .wow-page {
    --sage: #5C9070; --sageBg: #E9F1EC;
    
    --purp: #5B4B8A; --purpLine: #D8CFE8; --purpBg: #F0EDF6;
    --money: #2E6B4E; --moneyBg: #E6F1EA;
    --auA: #14616E; --auB: #1AA0B0; --auC: #5B7CE0;
    --w-ink: #0E0D0B; --w-ink2: #56524B; --w-ink3: #9E988E;
    --w-card: #FFFFFF; --w-line: #E7E3DB; --w-line2: #F0ECE4;
    --sg: 'Space Grotesk', sans-serif; --mn: 'JetBrains Mono', monospace;
    padding: 46px 0 80px;
  }

  /* Hero */
  .wow-hero { text-align: center; margin-bottom: 46px; }
  .wow-eyebrow {
    font-family: var(--mn); font-size: 10px; letter-spacing: .34em;
    text-transform: uppercase; color: var(--w-ink3); margin-bottom: 16px;
  }
  .wow-h1 {
    font-family: var(--sg); font-weight: 700; font-size: 40px;
    line-height: 1.05; letter-spacing: -.03em;
    color: var(--w-ink); margin: 0 0 14px;
  }
  .wow-g {
    background: linear-gradient(100deg, var(--auA), var(--auB) 55%, var(--auC));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .wow-sub {
    font-size: 15px; color: var(--w-ink2); max-width: 520px;
    margin: 0 auto; line-height: 1.6;
  }

  /* Cards grid */
  .wow-cards {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 14px; align-items: stretch; margin-bottom: 54px;
  }
  @media (max-width: 960px)  { .wow-cards { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px)  { .wow-cards { grid-template-columns: 1fr; } }

  /* Single card */
  .wow-tier {
    position: relative; background: var(--w-card);
    border: 1px solid var(--w-line); border-radius: 18px;
    padding: 24px 22px; display: flex; flex-direction: column;
    transition: transform .32s cubic-bezier(.2,.7,.3,1), box-shadow .32s;
    overflow: hidden;
  }
  .wow-tier:hover { transform: translateY(-7px); box-shadow: 0 28px 50px -30px rgba(0,0,0,.38); }
  .wow-tier--current { border-width: 2px; }
  .wow-tier--lite.wow-tier--current    { border-color: var(--sage); }
  .wow-tier--pro.wow-tier--current     { border-color: var(--pinkInk); }
  .wow-tier--prem.wow-tier--current    { border-color: var(--purp); }
  .wow-tier--ent.wow-tier--current     { border-color: var(--w-ink); }

  /* Premium: elevated + ribbon */
  .wow-tier--prem {
    border-color: var(--purpLine);
    box-shadow: 0 24px 48px -30px rgba(91,76,138,.45);
    transform: translateY(-6px);
    padding-top: 48px;
  }
  .wow-tier--prem:hover { transform: translateY(-13px); }

  .wow-ribbon {
    position: absolute; top: 0; left: 0; right: 0; height: 34px;
    background: var(--purp); display: flex; align-items: center; justify-content: center;
    font-family: var(--mn); font-size: 8.5px; letter-spacing: .14em;
    text-transform: uppercase; color: #fff;
  }

  @keyframes wow-sheen { 0%,72%{left:-60%} 100%{left:130%} }
  .wow-sheen {
