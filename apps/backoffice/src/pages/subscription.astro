---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels } from '@retaha/auth';
import { calculateTrialStatus } from '../lib/trial-status';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const currentPlan: string = (hotel as any).plan ?? 'lite';
const currentAddons: string[] = (hotel as any).addons ?? [];
const trial = calculateTrialStatus(hotel);
const trialEndFormatted = trial.endsAt?.toLocaleDateString('de-DE', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const TIER_RANK: Record<string, number> = { lite: 0, pro: 1, premium: 2, enterprise: 3 };

const PLANS = [
  {
    key: 'lite',
    label: 'Lite',
    tagline: 'Gäste-Basis',
    popular: false,
    price: '49',
    priceYear: '470,40',
    priceYearlyPerMonth: '39,20',
    modules: [
      'Willkommens-Hub', 'WLAN-Info (QR)', 'Frühstück-Buchung',
      'Service-Anfragen', 'Post-Stay Feedback', 'Action-Cards (5 Kacheln)',
    ],
  },
  {
    key: 'pro',
    label: 'Pro',
    tagline: 'Smart & Reichweite',
    popular: false,
    price: '249',
    priceYear: '2.390,40',
    priceYearlyPerMonth: '199,20',
    modules: [
      'Alles in Lite',
      'Empfehlungen (Google Places)', '10 Sprachen automatisch',
      'NFC-Tag Management', 'Pre-Stay Messaging', '9 Stay-Push-Trigger',
    ],
  },
  {
    key: 'premium',
    label: 'Premium',
    tagline: 'Volle Suite mit KI',
    price: '549',
    priceYear: '5.270,40',
    priceYearlyPerMonth: '439,20',
    popular: true,
    modules: [
      'Alles in Pro',
      'Eve KI-Concierge (inklusive)', 'Wallet-Pass + CRM',
      'Marketing (Drips + Kampagnen)', 'Loyalty-Program',
      'Referral-Program', 'Best-Price-Guarantee', 'Microsite-Builder',
    ],
  },
  {
    key: 'enterprise',
    label: 'Enterprise',
    tagline: 'Auf Anfrage',
    popular: false,
    price: null,
    priceYear: null,
    priceYearlyPerMonth: null,
    modules: [
      'Alles in Premium',
      'Multi-Property Management', 'White-Label App',
      'API-Zugang (direkt)', 'Custom Email-Domain',
      'Dedizierter Account Manager',
    ],
  },
];

const PLAN_LABEL: Record<string, string> = {
  lite: 'Lite', pro: 'Pro', premium: 'Premium', enterprise: 'Enterprise',
};

const showEveAddon = currentPlan === 'lite' || currentPlan === 'pro';
const hasEveAddon  = currentAddons.includes('eve');
---

<Layout
  title="Plan & Pakete"
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
>
  <div
    class="settings-page"
    x-data="{
      interval: 'monthly',
      loading: '',
      checkoutError: '',
      async checkout(plan) {
        this.loading = plan;
        this.checkoutError = '';
        try {
          const res = await fetch('/api/stripe/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ plan, interval: this.interval })
          });
          const data = await res.json();
          if (!res.ok || !data.url) throw new Error(data.error || 'Checkout nicht verfügbar');
          window.location.href = data.url;
        } catch(e) {
          this.checkoutError = e.message;
          this.loading = '';
        }
      },
      async checkoutAddon(addon) {
        this.loading = addon;
        this.checkoutError = '';
        try {
          const res = await fetch('/api/stripe/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ addon })
          });
          const data = await res.json();
          if (!res.ok || !data.url) throw new Error(data.error || 'Checkout nicht verfügbar');
          window.location.href = data.url;
        } catch(e) {
          this.checkoutError = e.message;
          this.loading = '';
        }
      }
    }"
  >

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Plan & Pakete</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">Abrechnung</span>
      <h1 class="settings-hero__title">Wähle das richtige Paket<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">
        {trial.isInTrial
          ? `Du bist im Trial${trialEndFormatted ? ` — endet am ${trialEndFormatted}` : ''}. Alle Pakete enthalten monatliche Kündigung.`
          : 'Alle Pakete monatlich kündbar. Jahresabo spart 20 %.'}
      </p>
    </section>

    <div class="settings-sections">

      <!-- 01 Aktueller Plan -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Aktueller Plan</h2>
          <span class="s-card__num">01</span>
        </div>
        <div class="s-card__body">
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span class={`sub-plan-badge sub-plan-badge--${currentPlan}`}>
              {PLAN_LABEL[currentPlan] ?? currentPlan}
            </span>
            {trial.isInTrial && trialEndFormatted && (
              <span class="sub-trial-note">Trial endet am {trialEndFormatted}</span>
            )}
          </div>
        </div>
      </section>

      <!-- 02 Pakete -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Pakete vergleichen</h2>
          <span class="s-card__num">02</span>
        </div>
        <div class="s-card__body">

          <!-- Interval Toggle -->
          <div class="sub-interval-toggle" style="margin-bottom:24px">
            <button
              type="button"
              @click="interval = 'monthly'"
              :class="interval === 'monthly' ? 'v9-btn v9-btn--primary sub-interval-btn' : 'v9-btn v9-btn--ghost sub-interval-btn'"
            >
              Monatlich
            </button>
            <button
              type="button"
              @click="interval = 'yearly'"
              :class="interval === 'yearly' ? 'v9-btn v9-btn--primary sub-interval-btn' : 'v9-btn v9-btn--ghost sub-interval-btn'"
            >
              Jährlich <span class="sub-discount-badge">−20 %</span>
            </button>
          </div>

          <!-- Checkout-Fehler -->
          <div
            x-show="checkoutError !== ''"
            style="display:none"
            class="s-flash s-flash--err"
            role="alert"
          >
            <span x-text="checkoutError"></span>
            <button type="button" @click="checkoutError = ''" class="sub-flash-close" aria-label="Schließen">×</button>
          </div>

          <!-- Plans Grid -->
          <div class="sub-plans-grid">
            {PLANS.map(plan => {
              const rank = TIER_RANK[plan.key] ?? 0;
              const curRank = TIER_RANK[currentPlan] ?? 0;
              const isCurrent   = plan.key === currentPlan;
              const isUpgrade   = rank > curRank;
              const isDowngrade = rank < curRank;

              return (
                <div class={[
                  'sub-plan-card',
                  isCurrent   ? 'sub-plan-card--current'   : '',
                  isUpgrade   ? 'sub-plan-card--upgrade'    : '',
                  isDowngrade ? 'sub-plan-card--downgrade'  : '',
                  plan.popular && !isCurrent ? 'sub-plan-card--popular' : '',
                ].filter(Boolean).join(' ')}>

                  {plan.popular && !isCurrent && (
                    <div class="sub-plan-card__bar sub-plan-card__bar--popular">Empfohlen</div>
                  )}
                  {isCurrent && (
                    <div class="sub-plan-card__bar sub-plan-card__bar--current">Dein aktueller Plan</div>
                  )}

                  <div class="sub-plan-card__head">
                    <span class={`sub-plan-tier sub-plan-tier--${plan.key}`}>{plan.label}</span>
                    <span class="sub-plan-tagline">{plan.tagline}</span>
                  </div>

                  <div class="sub-plan-card__price">
                    {plan.price !== null ? (
                      <>
                        <div x-show="interval === 'monthly'">
                          <span class="sub-plan-price-num">{plan.price} €</span>
                          <span class="sub-plan-price-per">/Monat</span>
                          <div class="sub-plan-price-year">
                            Jährlich: {plan.priceYear} € <span class="sub-discount-tag">−20 %</span>
                          </div>
                        </div>
                        <div x-show="interval === 'yearly'" style="display:none">
                          <span class="sub-plan-price-num">{plan.priceYearlyPerMonth} €</span>
                          <span class="sub-plan-price-per">/Monat</span>
                          <div class="sub-plan-price-year">
                            {plan.priceYear} €/Jahr · <span class="sub-discount-tag">20 % gespart</span>
                          </div>
                        </div>
                      </>
                    ) : (
                      <span class="sub-plan-price-custom">Individuell</span>
                    )}
                  </div>

                  <ul class="sub-plan-modules">
                    {plan.modules.map(m => (
                      <li class="sub-plan-module-item">
                        <span class="sub-plan-module-check" aria-hidden="true">✓</span>
                        {m}
                      </li>
                    ))}
                  </ul>

                  <div class="sub-plan-card__cta">
                    {isCurrent ? (
                      <button type="button" class="v9-btn v9-btn--ghost sub-plan-btn sub-plan-btn--current" disabled>
                        Aktueller Plan
                      </button>
                    ) : plan.key === 'enterprise' ? (
                      <a href="mailto:hallo@retaha.de" class="v9-btn v9-btn--ghost sub-plan-btn">
                        Kontakt aufnehmen
                      </a>
                    ) : isUpgrade ? (
                      <button
                        type="button"
                        class="v9-btn v9-btn--primary sub-plan-btn"
                        @click={`checkout('${plan.key}')`}
                        :disabled="loading !== ''"
                        :class={`loading === '${plan.key}' ? 'v9-btn v9-btn--primary sub-plan-btn sub-plan-btn--loading' : 'v9-btn v9-btn--primary sub-plan-btn'`}
                      >
                        <span x-show={`loading !== '${plan.key}'`}>Upgrade auf {plan.label}</span>
                        <span x-show={`loading === '${plan.key}'`} style="display:none">Wird vorbereitet…</span>
                      </button>
                    ) : (
                      <button type="button" class="v9-btn v9-btn--ghost sub-plan-btn sub-plan-btn--downgrade" disabled>
                        Downgrade auf {plan.label}
                      </button>
                    )}
                  </div>
                </div>
              );
            })}
          </div>

        </div>
      </section>

      <!-- 03 Eve Add-on (nur für Lite & Pro) -->
      {showEveAddon && (
        <section class="s-card">
          <div class="s-card__head">
            <h2 class="s-card__title">Add-ons</h2>
            <span class="s-card__num">03</span>
          </div>
          <div class="s-card__body">
            <div class="sub-addon-card">
              <div class="sub-addon-card__left">
                <div class="sub-addon-card__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                       stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="sub-addon-card__label">Eve KI-Concierge — Add-on</p>
                  <p class="sub-addon-card__desc">
                    KI-Assistent für Gäste: Fragen, Buchungen, Empfehlungen — 24/7.
                    {hasEveAddon
                      ? ' Bereits gebucht — Danke!'
                      : ' Für Lite und Pro als monatliches Add-on buchbar.'}
                  </p>
                </div>
              </div>
              <div class="sub-addon-card__right">
                <span class="sub-addon-price">89 € <span class="sub-addon-price-per">/Monat</span></span>
                {hasEveAddon ? (
                  <span class="sub-addon-badge">Aktiv</span>
                ) : (
                  <button
                    type="button"
                    class="v9-btn v9-btn--primary"
                    @click="checkoutAddon('eve')"
                    :disabled="loading !== ''"
                    :class="loading === 'eve' ? 'v9-btn v9-btn--primary sub-plan-btn--loading' : 'v9-btn v9-btn--primary'"
                  >
                    <span x-show="loading !== 'eve'">Hinzufügen</span>
                    <span x-show="loading === 'eve'" style="display:none">Wird vorbereitet…</span>
                  </button>
                )}
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Footer-Notiz -->
      <div class="sub-footer-note">
        <p>
          Sichere Zahlung via Stripe. Monatlich kündbar, keine versteckten Gebühren.
          Fragen? <a href="mailto:hallo@retaha.de" class="sub-footer-link">hallo@retaha.de</a>
        </p>
        <a href="/uebersicht" class="v9-btn v9-btn--ghost">← Zurück zur Übersicht</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  /* ── Plan badge (current plan indicator in 01 card) ──────────────────────── */
  .sub-plan-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em;
    padding: 4px 10px; border-radius: 99px; text-transform: uppercase;
  }
  .sub-plan-badge--lite       { background: #f5f5f5; color: #1a1a1a; border: 1px solid #d0d0d0; }
  .sub-plan-badge--pro        { background: #edf7f0; color: #2e7d4f; border: 1px solid #a8d5b8; }
  .sub-plan-badge--premium    { background: #f4f0fb; color: #6d28d9; border: 1px solid #c4b5f5; }
  .sub-plan-badge--enterprise { background: #1a1a1a; color: #fff;    border: 1px solid #1a1a1a; }

  .sub-trial-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); letter-spacing: 0.04em;
  }

  /* ── Interval Toggle ─────────────────────────────────────────────────────── */
  .sub-interval-toggle { display: flex; gap: 6px; flex-wrap: wrap; }
  .sub-interval-btn { display: flex; align-items: center; gap: 6px; }

  .sub-discount-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; font-weight: 500; letter-spacing: 0.06em;
    color: #2e7d4f; background: #edf7f0;
    padding: 1px 5px; border-radius: 4px;
  }

  /* ── Flash close button ──────────────────────────────────────────────────── */
  .sub-flash-close {
    background: none; border: none; cursor: pointer;
    font-size: 16px; color: inherit; line-height: 1;
    padding: 0; flex-shrink: 0; margin-left: auto;
  }

  /* ── Plans Grid ──────────────────────────────────────────────────────────── */
  .sub-plans-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 1000px) { .sub-plans-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .sub-plans-grid { grid-template-columns: 1fr; } }

  /* ── Plan Card ───────────────────────────────────────────────────────────── */
  .sub-plan-card {
    border: 1px solid var(--border);
    border-radius: var(--r, 8px);
    background: var(--surface);
    padding: 20px;
    display: flex; flex-direction: column;
    position: relative; overflow: hidden;
    transition: box-shadow 150ms;
  }
  .sub-plan-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); }
  .sub-plan-card--current  { border-color: var(--ink, #1a1a1a); border-width: 2px; }
  .sub-plan-card--popular  { border-color: #7c3aed; }
  .sub-plan-card--downgrade { opacity: 0.65; }

  .sub-plan-card__bar {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
    text-align: center; padding: 4px;
    margin: -20px -20px 16px;
  }
  .sub-plan-card__bar--popular { background: #7c3aed; color: #fff; }
  .sub-plan-card__bar--current { background: var(--ink, #1a1a1a); color: #fff; }

  .sub-plan-card__head { margin-bottom: 14px; }

  .sub-plan-tier {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 99px; border: 1px solid;
    display: inline-block; margin-bottom: 6px;
  }
  .sub-plan-tier--lite       { background: transparent; color: #555; border-color: #ccc; }
  .sub-plan-tier--pro        { background: #edf7f0;    color: #2e7d4f; border-color: #a8d5b8; }
  .sub-plan-tier--premium    { background: #f4f0fb;    color: #6d28d9; border-color: #c4b5f5; }
  .sub-plan-tier--enterprise { background: #1a1a1a;    color: #fff;    border-color: #1a1a1a; }

  .sub-plan-tagline {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px; color: var(--ink-muted); font-weight: 400;
  }

  .sub-plan-card__price {
    margin-bottom: 18px; border-bottom: 1px solid var(--border); padding-bottom: 16px;
  }
  .sub-plan-price-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 28px; font-weight: 300; color: var(--ink); letter-spacing: -0.02em; line-height: 1;
  }
  .sub-plan-price-per {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); margin-left: 2px;
  }
  .sub-plan-price-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); margin-top: 4px;
  }
  .sub-discount-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.08em;
    color: #2e7d4f; background: #edf7f0;
    padding: 1px 5px; border-radius: 4px;
  }
  .sub-plan-price-custom {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 22px; font-weight: 300; color: var(--ink);
  }

  .sub-plan-modules {
    list-style: none; padding: 0; margin: 0 0 20px;
    display: flex; flex-direction: column; gap: 6px; flex: 1;
  }
  .sub-plan-module-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); letter-spacing: 0.02em;
    display: flex; align-items: flex-start; gap: 7px; line-height: 1.4;
  }
  .sub-plan-module-check { color: #2e7d4f; flex-shrink: 0; font-size: 10px; margin-top: 1px; }

  .sub-plan-card__cta { margin-top: auto; }

  .sub-plan-btn {
    width: 100%; display: block; text-align: center; text-decoration: none;
    font-size: 10px !important;
  }
  .sub-plan-btn--current { opacity: 0.6; cursor: not-allowed; }
  .sub-plan-btn--downgrade { opacity: 0.5; cursor: not-allowed; }
  .sub-plan-btn--loading { opacity: 0.65; }

  /* ── Eve Add-on card ─────────────────────────────────────────────────────── */
  .sub-addon-card {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 24px;
    flex-wrap: wrap;
    padding: 16px 20px;
    border: 1px solid var(--border); border-radius: var(--r, 8px);
    background: var(--bg-deep, #F0EDE6);
  }
  .sub-addon-card__left { display: flex; align-items: flex-start; gap: 14px; flex: 1; min-width: 0; }
  .sub-addon-card__icon {
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--border); display: flex; align-items: center; justify-content: center;
    color: var(--ink-muted); flex-shrink: 0;
  }
  .sub-addon-card__label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 500; color: var(--ink); margin: 0 0 4px;
  }
  .sub-addon-card__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); line-height: 1.5; margin: 0; letter-spacing: 0.02em;
  }
  .sub-addon-card__right {
    display: flex; flex-direction: column; align-items: flex-end; gap: 10px; flex-shrink: 0;
  }
  .sub-addon-price {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px; font-weight: 300; color: var(--ink); line-height: 1;
  }
  .sub-addon-price-per {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted);
  }
  .sub-addon-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 99px;
    background: #edf7f0; color: #2e7d4f; border: 1px solid #a8d5b8;
  }

  /* ── Footer note ─────────────────────────────────────────────────────────── */
  .sub-footer-note {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--ink-muted); letter-spacing: 0.02em;
    padding: 16px 20px;
    border: 1px solid var(--border); border-radius: var(--r, 8px);
    background: var(--bg-deep, #F0EDE6);
  }
  .sub-footer-note p { margin: 0; }
  .sub-footer-link { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; }
</style>
