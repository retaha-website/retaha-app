---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, getUserRole, hasPermission } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const billingRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!billingRole || !hasPermission(billingRole, 'hotel.billing')) {
  return Astro.redirect('/overview?error=billing_owner_only');
}

const currentPlan: string = (hotel as any).plan ?? 'lite';

const CURRENT_LABEL = currentPlan === 'lite' ? 'Lite — Kostenlos'
  : currentPlan === 'pro' ? 'Pro'
  : currentPlan === 'premium' ? 'Premium' : 'Enterprise';
---

<Layout
  title={bt('sub.titleplain', lang)}
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
>
  <script is:inline define:vars={{
    SUB_ERR_TRIAL: bt('sub.err.trial', lang),
    SUB_TRIAL_SENT: bt('sub.trial.sent', lang),
    SUB_HOTEL_NAME: hotel.name,
    SUB_USER_EMAIL: user.email ?? '',
  }}>
    window.__SUB_T__ = {
      errTrial: SUB_ERR_TRIAL,
      trialSent: SUB_TRIAL_SENT,
      hotelName: SUB_HOTEL_NAME,
      userEmail: SUB_USER_EMAIL,
    };
  </script>
  <div
    class="settings-page"
    x-data="{
      loading: '',
      showAllPlans: false,
      downgradeConfirm: false,
      leadModal: false,
      leadPlan: '',
      leadPhone: '',
      leadTime: '',
      leadNote: '',
      leadSent: false,
      openLeadModal(plan) {
        this.leadPlan = plan;
        this.leadPhone = '';
        this.leadTime = '';
        this.leadNote = '';
        this.leadSent = false;
        this.leadModal = true;
      },
      async submitLead() {
        this.loading = 'lead';
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              plan: this.leadPlan,
              phone: this.leadPhone || undefined,
              preferred_time: this.leadTime || undefined,
              note: this.leadNote || undefined,
            })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          this.leadSent = true;
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      },
      async downgradeLite() {
        this.loading = 'lite';
        try {
          const res = await fetch('/api/subscription/downgrade-to-lite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.location.reload();
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
          this.downgradeConfirm = false;
        }
      },
      async requestAddon(addon) {
        this.loading = addon;
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ addon })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.retahaToast?.(window.__SUB_T__.trialSent, 'success');
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      }
    }"
  >

    <!-- ── Plan-Vergleichs-Matrix ──────────────────────────────────────────── -->
    <div class="pm-page">

      <header class="pm-head">
        <h1 class="pm-h1">Plan & Pakete</h1>
        <p class="pm-sub">Wähle das Paket, das zu eurem Haus passt — jederzeit anpassbar.</p>

        {currentPlan !== 'premium' && currentPlan !== 'enterprise' && (
          <div class="pm-promo">
            <div class="pm-promo-l">
              <div class="pm-promo-eye"><span class="pm-promo-dot"></span>Aktuell · {CURRENT_LABEL}</div>
              <h2 class="pm-promo-h2">Bereit für ein vollständiges PMS?</h2>
              <p class="pm-promo-p">Premium macht aus eurer digitalen Gästemappe ein komplettes System — Direktbuchung ohne Provision, euer eigenes PMS, Stammgäste und Self-Check-out. Schaut, was eure nächste Stufe freischaltet.</p>
              <a class="pm-promo-btn" href="#pm-pakete">Pakete ansehen
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke-width="2.4"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
              </a>
            </div>
            <div class="pm-promo-r" aria-hidden="true">
              <div class="pm-glyph"><svg width="26" height="26" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2.5"/><path d="M3 9h18M8 3v4M16 3v4M7.5 13h3M13.5 13h3M7.5 17h3"/></svg></div>
              <div class="pm-glyph pm-glyph--2"><svg width="26" height="26" viewBox="0 0 24 24"><circle cx="8.5" cy="8.5" r="4.5"/><path d="M11.5 11.5l8 8M16 16l2.5-2.5M18.5 18.5l2-2"/></svg></div>
              <div class="pm-glyph pm-glyph--3"><svg width="26" height="26" viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="2.5"/><path d="M3 10h18M6.5 14.5h4"/></svg></div>
            </div>
          </div>
        )}
      </header>

      <section class="pm-plans" id="pm-pakete" :class="{ 'pm-plans--all': showAllPlans }">

        <!-- LITE -->
        <div class="pm-card pm-card--lite">
          <div class="pm-card-name">Lite</div>
          <div class="pm-card-price">Kostenlos</div>
          <div class="pm-card-pq">für immer</div>
          {currentPlan === 'lite' ? (
            <span class="pm-cta pm-cta-now">Aktueller Plan</span>
          ) : (
            <button type="button" class="pm-cta pm-cta-solid" @click="window.confirm('Zu Lite wechseln? Premium-Funktionen werden deaktiviert.') && downgradeLite()" :disabled="loading !== ''">Zu Lite wechseln</button>
          )}
          <p class="pm-card-desc">Eure digitale Gästemappe — kostenlos starten und Gäste begeistern.</p>
          <div class="pm-card-fh">Lite enthält:</div>
          <div class="pm-feat">
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Digitale Gästemappe</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>WLAN, Hausinfos & Karten</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Concierge <span class="eve-gradient">Eve</span> — rund um die Uhr</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Gästewünsche & Feedback</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>1 Schnellzugriff-Kachel</div>
          </div>
        </div>

        <!-- PRO (nur in der vollen Ansicht) -->
        <div class="pm-card pm-card--pro" x-show="showAllPlans" style="display:none">
          <div class="pm-card-name">Pro</div>
          <div class="pm-card-price">Auf Anfrage</div>
          <div class="pm-card-pq">Marke & Reichweite</div>
          {currentPlan === 'pro' ? (
            <span class="pm-cta pm-cta-now">Aktueller Plan</span>
          ) : (
            <button type="button" class="pm-cta pm-cta-solid" @click="openLeadModal('pro')" :disabled="loading !== ''">Vertrieb kontaktieren</button>
          )}
          <p class="pm-card-desc">Euer eigener Auftritt und mehr Reichweite für direkte Gäste.</p>
          <div class="pm-card-fh">Alles aus Lite, plus:</div>
          <div class="pm-feat">
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Euer Look — Logo, Farbe, Design</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span><span class="eve-gradient">Eve</span> handelt — bucht & leitet weiter</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>10 Sprachen, automatisch</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Empfehlungen & Bewertungs-Funnel</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Pre-Stay — vor der Anreise erreichen</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>10 Schnellzugriff-Kacheln</div>
          </div>
        </div>

        <!-- PREMIUM -->
        <div class="pm-card pm-card--prem">
          <span class="pm-rectag">Empfohlen</span>
          <div class="pm-card-name">Premium</div>
          <div class="pm-card-price">Auf Anfrage</div>
          <div class="pm-card-pq">Zahlt sich aus</div>
          {currentPlan === 'premium' ? (
            <span class="pm-cta pm-cta-now">Aktueller Plan</span>
          ) : (
            <button type="button" class="pm-cta pm-cta-white" @click="openLeadModal('premium')" :disabled="loading !== ''">Vertrieb kontaktieren</button>
          )}
          <p class="pm-card-desc">Aus der Gästemappe wird ein komplettes System — inkl. eigenem PMS.</p>

          <!-- Kompakt (nur Lite + Premium sichtbar): Pro-Inhalte mit aufgelistet -->
          <div class="pm-card-fh" x-show="!showAllPlans">Alles aus Lite, plus:</div>
          <div class="pm-feat" x-show="!showAllPlans">
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Euer Look — Logo, Farbe, Design</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span><span class="eve-gradient">Eve</span> handelt — bucht & leitet weiter</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>10 Sprachen, automatisch</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Empfehlungen & Bewertungs-Funnel</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Pre-Stay — vor der Anreise erreichen</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Direktbuchung — Provision bleibt im Haus</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Stammgäste — Wallet & Treue</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Self-Check-out & Tür per Handy</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Eigenes PMS — inklusive</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Wiederkehr anstoßen</div>
          </div>

          <!-- Voll (alle Pakete sichtbar): Pro ist eigene Karte → nur Premium-Inhalte -->
          <div class="pm-card-fh" x-show="showAllPlans" style="display:none">Alles aus Pro, plus:</div>
          <div class="pm-feat" x-show="showAllPlans" style="display:none">
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Direktbuchung — Provision bleibt im Haus</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Stammgäste — Wallet & Treue</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Self-Check-out & Tür per Handy</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Eigenes PMS — inklusive</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Wiederkehr anstoßen</div>
          </div>
        </div>

        <!-- ENTERPRISE (nur in der vollen Ansicht) -->
        <div class="pm-card pm-card--ent" x-show="showAllPlans" style="display:none">
          <div class="pm-card-name">Enterprise</div>
          <div class="pm-card-price">Auf Anfrage</div>
          <div class="pm-card-pq">Für Gruppen</div>
          {currentPlan === 'enterprise' ? (
            <span class="pm-cta pm-cta-now">Aktueller Plan</span>
          ) : (
            <button type="button" class="pm-cta pm-cta-glass" @click="openLeadModal('enterprise')" :disabled="loading !== ''">Kontakt aufnehmen</button>
          )}
          <p class="pm-card-desc">Für mehrere Häuser — zentral verwaltet, individuell angebunden.</p>
          <div class="pm-card-fh">Alles aus Premium, plus:</div>
          <div class="pm-feat">
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Eigene App im App Store</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Mehrere Häuser zentral</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Anbindung an eure Systeme</div>
            <div class="pm-frow"><span class="pm-fchk"><svg width="9" height="9" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></span>Fester Ansprechpartner</div>
          </div>
        </div>

      </section>

      <div class="pm-allbtn-wrap">
        <button type="button" class="pm-allbtn" @click="showAllPlans = !showAllPlans" x-text="showAllPlans ? 'Weniger anzeigen ↑' : 'Alle Pakete ansehen ↓'">Alle Pakete ansehen ↓</button>
      </div>

    </div>

    <!-- ── Lead-Modal ────────────────────────────────────────────────────── -->
    <div class="lead-overlay" x-show="leadModal" x-cloak @click.self="leadModal = false" style="display:none">
      <div class="lead-modal" @keydown.escape.window="leadModal = false" role="dialog" aria-modal="true">

        <!-- Bestätigung nach Absenden -->
        <div x-show="leadSent" class="lead-sent" style="display:none">
          <div class="lead-sent__icon">✓</div>
          <h2 class="lead-sent__title">Danke — wir melden uns!</h2>
          <p class="lead-sent__sub">Deine Anfrage ist eingegangen. Wir kommen in Kürze auf dich zu.</p>
          <button type="button" class="v9-btn v9-btn--primary lead-close-btn" @click="leadModal = false">
            Schließen
          </button>
        </div>

        <!-- Formular -->
        <div x-show="!leadSent" style="display:none">
          <div class="lead-modal__head">
            <div>
              <p class="lead-modal__eyebrow">Upgrade-Interesse</p>
              <h2 class="lead-modal__title">
                Kontakt für <span class="lead-plan-chip" x-text="leadPlan.toUpperCase()"></span>
              </h2>
            </div>
            <button type="button" class="lead-modal__close" @click="leadModal = false" aria-label="Schließen">✕</button>
          </div>

          <!-- Read-only Hotel-Info -->
          <div class="lead-readonlys">
            <div class="lead-readonly">
              <span class="lead-readonly__label">Hotel</span>
              <span class="lead-readonly__val" x-text="window.__SUB_T__.hotelName"></span>
            </div>
            <div class="lead-readonly">
              <span class="lead-readonly__label">E-Mail</span>
              <span class="lead-readonly__val" x-text="window.__SUB_T__.userEmail"></span>
            </div>
          </div>

          <form class="lead-form" @submit.prevent="submitLead()">
            <div class="lead-field">
              <label class="lead-label" for="lead-phone">Telefon</label>
              <input
                id="lead-phone"
                type="tel"
                class="s-input lead-input"
                placeholder="+49 123 456789"
                x-model="leadPhone"
                autocomplete="tel"
              />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-time">Wunsch-Zeitfenster</label>
              <input
                id="lead-time"
                type="text"
                class="s-input lead-input"
                placeholder="z.B. Mo–Fr 9–12 Uhr"
                x-model="leadTime"
              />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-note">Notiz <span style="color:var(--ink-muted)">(optional)</span></label>
              <textarea
                id="lead-note"
                class="s-input lead-input"
                rows="3"
                placeholder="Was noch wichtig ist…"
                x-model="leadNote"
                style="resize:vertical"
              ></textarea>
            </div>

            <div class="lead-actions">
              <button type="button" class="v9-btn v9-btn--ghost" @click="leadModal = false">
                Abbrechen
              </button>
              <button
                type="submit"
                class="v9-btn v9-btn--primary lead-submit"
                :disabled="loading === 'lead'"
              >
                <span x-show="loading !== 'lead'">Anfrage absenden →</span>
                <span x-show="loading === 'lead'" style="display:none">Wird gesendet…</span>
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>

  </div>
</Layout>

<style>
  /* ── Lead Modal ─────────────────────────────────────────────────────────── */
  .lead-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.45);
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }
  .lead-modal {
    background: var(--surface, #fff);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 16px;
    padding: 28px;
    width: 100%; max-width: 480px;
    box-shadow: 0 20px 60px rgba(0,0,0,.12);
  }
  .lead-modal__head {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 20px; gap: 12px;
  }
  .lead-modal__eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink-muted, #888);
    margin: 0 0 4px;
  }
  .lead-modal__title {
    font-size: 18px; font-weight: 600; color: var(--ink, #1a1a1a);
    margin: 0; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .lead-plan-chip {
    background: var(--petrol, #14616E);
    color: #fff; font-size: 11px; font-weight: 600; letter-spacing: .08em;
    padding: 2px 8px; border-radius: 6px;
  }
  .lead-modal__close {
    background: none; border: none; cursor: pointer;
    color: var(--ink-muted, #888); font-size: 16px; line-height: 1;
    padding: 4px; border-radius: 6px; flex-shrink: 0;
  }
  .lead-modal__close:hover { color: var(--ink, #1a1a1a); background: var(--surface-alt, #f4f4f3); }
  .lead-readonlys {
    display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;
  }
  .lead-readonly {
    background: var(--surface-alt, #f4f4f3);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 8px; padding: 8px 12px;
    display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 140px;
  }
  .lead-readonly__label {
    font-size: 10px; font-weight: 500; letter-spacing: .06em;
    text-transform: uppercase; color: var(--ink-muted, #888);
  }
  .lead-readonly__val {
    font-size: 13px; font-weight: 500; color: var(--ink, #1a1a1a);
    word-break: break-all;
  }
  .lead-form { display: flex; flex-direction: column; gap: 14px; }
  .lead-field { display: flex; flex-direction: column; gap: 5px; }
  .lead-label { font-size: 13px; font-weight: 500; color: var(--ink, #1a1a1a); }
  .lead-input { width: 100%; }
  .lead-actions {
    display: flex; gap: 8px; justify-content: flex-end; margin-top: 6px;
  }
  .lead-submit { min-width: 160px; }
  .lead-sent {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 16px 0;
  }
  .lead-sent__icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--petrol, #14616E); color: #fff;
    font-size: 24px; display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .lead-sent__title { font-size: 18px; font-weight: 600; margin: 0 0 8px; }
  .lead-sent__sub { font-size: 14px; color: var(--ink-muted, #888); margin: 0 0 24px; }
  .lead-close-btn { min-width: 120px; }

  /* ── Wow-Abo-Page ───────────────────────────────────────────────────────── */
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');

  /* ── Plan-Vergleichs-Matrix ──────────────────────────────────────────────── */
  .pm-page {
    --pm-petrol: #14616E; --pm-petrol-d: #0e4d57;
    --pm-ink: #0A0A0A; --pm-muted: rgba(10,10,10,.50); --pm-faint: rgba(10,10,10,.26);
    --pm-border: rgba(10,10,10,.10); --pm-border-strong: #E5E4E0;
