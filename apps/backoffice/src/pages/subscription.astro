---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, getUserRole, hasPermission } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const billingRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!billingRole || !hasPermission(billingRole, 'hotel.billing')) {
  return Astro.redirect('/overview?error=billing_owner_only');
}

const currentPlan: string = (hotel as any).plan ?? 'lite';

// ── Plan-Vergleichs-Matrix (Hotelier-Sprache, kuratiert aus der Modul-Matrix) ──
// Zelltypen: yes = enthalten · no = nicht enthalten · lim(v) = Menge/Grenze (Mono).
const yes = { t: 'yes' as const };
const no = { t: 'no' as const };
const lim = (v: string, de = false) => ({ t: 'lim' as const, v, de });
const MATRIX: { label: string; rows: { name: string; hint?: string; cells: any[] }[] }[] = [
  { label: 'Eure digitale Gästemappe', rows: [
    { name: 'Digitale Gästemappe — nie wieder Mappen nachdrucken', cells: [yes, yes, yes, yes] },
    { name: 'WLAN, Hausinfos & Frühstückskarte für Gäste', cells: [yes, yes, yes, yes] },
    { name: 'Digitaler Concierge (Eve) — beantwortet Gästefragen rund um die Uhr', cells: [yes, yes, yes, yes] },
    { name: 'Gästewünsche sammeln & Feedback nach dem Aufenthalt', cells: [yes, yes, yes, yes] },
    { name: 'Schnellzugriff-Kacheln auf der Startseite', cells: [lim('1'), lim('10'), lim('10'), lim('10')] },
  ] },
  { label: 'Euer Auftritt & mehr Reichweite', rows: [
    { name: 'Euer Look statt Vorlage — Logo, Farbe, Design', cells: [lim('Standard', true), yes, yes, lim('eigenes')] },
    { name: 'Digitaler Concierge handelt — bucht & leitet an den Empfang weiter', cells: [no, yes, yes, yes] },
    { name: 'Gästemappe in 10 Sprachen, automatisch', cells: [lim('nur DE', true), yes, yes, yes] },
    { name: 'Empfehlungen aus der Umgebung für eure Gäste', cells: [no, yes, yes, yes] },
    { name: 'Schon vor der Anreise mit Gästen sprechen', cells: [no, yes, yes, yes] },
    { name: 'Auftritt ohne „Powered by retaha"', cells: [no, lim('dezent', true), yes, yes] },
    { name: 'Eigene Gäste-App-Adresse', cells: [lim('retaha.de', true), lim('hotelname'), lim('eig. Domain'), lim('eig. Domain')] },
  ] },
  { label: 'Mehr Direktumsatz & Stammgäste', rows: [
    { name: 'Direktbuchung — 15–25 % Portal-Provision bleibt im Haus', hint: 'Jede Buchung über Booking & Co. kostet euch Provision — bei Direktbuchung bleibt sie bei euch.', cells: [no, no, yes, yes] },
    { name: 'Aus Gästen werden Stammgäste — Wallet & Treueprogramm', cells: [no, no, yes, yes] },
    { name: 'Gäste zur Wiederkehr anstoßen — Nachrichten & Kampagnen', cells: [no, no, yes, yes] },
    { name: 'Self-Check-out & Türöffnung per Handy', cells: [no, no, yes, yes] },
    { name: 'Aufs Zimmer bestellen & auf die Zimmerrechnung buchen', cells: [no, no, yes, yes] },
    { name: 'Eigene Hotel-Software (PMS)', cells: [no, lim('anbinden'), lim('inklusive'), lim('inklusive')] },
  ] },
  { label: 'Für Gruppen & Ketten', rows: [
    { name: 'Eure eigene App im App Store (White-Label)', cells: [no, no, no, yes] },
    { name: 'Mehrere Häuser zentral steuern', cells: [no, no, no, yes] },
    { name: 'Anbindung an eure bestehenden Systeme (API)', cells: [no, no, no, yes] },
    { name: 'Fester Ansprechpartner', cells: [no, no, no, yes] },
  ] },
];
const TIERS = [
  { key: 'lite',       name: 'Lite',       sub: 'Kostenlos' },
  { key: 'pro',        name: 'Pro',        sub: 'Marke & Reichweite' },
  { key: 'premium',    name: 'Premium',    sub: 'Zahlt sich aus' },
  { key: 'enterprise', name: 'Enterprise', sub: 'Gruppen' },
];
---

<Layout
  title={bt('sub.titleplain', lang)}
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
>
  <script is:inline define:vars={{
    SUB_ERR_TRIAL: bt('sub.err.trial', lang),
    SUB_TRIAL_SENT: bt('sub.trial.sent', lang),
    SUB_HOTEL_NAME: hotel.name,
    SUB_USER_EMAIL: user.email ?? '',
  }}>
    window.__SUB_T__ = {
      errTrial: SUB_ERR_TRIAL,
      trialSent: SUB_TRIAL_SENT,
      hotelName: SUB_HOTEL_NAME,
      userEmail: SUB_USER_EMAIL,
    };
  </script>
  <div
    class="settings-page"
    x-data="{
      loading: '',
      downgradeConfirm: false,
      leadModal: false,
      leadPlan: '',
      leadPhone: '',
      leadTime: '',
      leadNote: '',
      leadSent: false,
      openLeadModal(plan) {
        this.leadPlan = plan;
        this.leadPhone = '';
        this.leadTime = '';
        this.leadNote = '';
        this.leadSent = false;
        this.leadModal = true;
      },
      async submitLead() {
        this.loading = 'lead';
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              plan: this.leadPlan,
              phone: this.leadPhone || undefined,
              preferred_time: this.leadTime || undefined,
              note: this.leadNote || undefined,
            })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          this.leadSent = true;
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      },
      async downgradeLite() {
        this.loading = 'lite';
        try {
          const res = await fetch('/api/subscription/downgrade-to-lite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.location.reload();
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
          this.downgradeConfirm = false;
        }
      },
      async requestAddon(addon) {
        this.loading = addon;
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ addon })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.retahaToast?.(window.__SUB_T__.trialSent, 'success');
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      }
    }"
  >

    <!-- ── Plan-Vergleichs-Matrix ──────────────────────────────────────────── -->
    <div class="pm-page">

      <section class="pm-hero">
        <div class="pm-eye">retaha · Hospitality</div>
        <h1 class="pm-h1">Startet kostenlos.<br>Wachst, <span class="pm-em">wenn es sich lohnt.</span></h1>
        <p class="pm-sub">Kein Tarif-Dschungel, keine Preisschilder. Seht Zeile für Zeile, was jede Stufe für euch tut.</p>
      </section>

      <div class="pm-matwrap">
        <table class="pm-mat">
          <thead>
            <tr>
              <th class="pm-feat"></th>
              {TIERS.map(tier => (
                <th class={tier.key === 'premium' ? 'pm-col-prem' : undefined}>
                  <div class="pm-th-inner">
                    {tier.key === 'premium' && <span class="pm-prem-cap">Empfohlen</span>}
                    <div class="pm-tier-name">{tier.name}</div>
                    <div class="pm-tier-sub">{tier.sub}</div>
                    {currentPlan === tier.key && <div class="pm-tier-now">Aktuell</div>}
                  </div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {MATRIX.map(group => (
              <Fragment>
                <tr class="pm-grp">
                  <td class="pm-feat"><span class="pm-gl">— {group.label}</span></td>
                  <td></td><td></td><td class="pm-col-prem"></td><td></td>
                </tr>
                {group.rows.map(row => (
                  <tr class="pm-row">
                    <td class="pm-feat"><span class="pm-fl">{row.name}{row.hint && <span class="pm-hint">{row.hint}</span>}</span></td>
                    {row.cells.map((cell, i) => (
                      <td class={i === 2 ? 'pm-col-prem' : undefined}>
                        {cell.t === 'yes' && (
                          <span class="pm-yes"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                        )}
                        {cell.t === 'no' && <span class="pm-no"></span>}
                        {cell.t === 'lim' && <span class={`pm-lim${cell.de ? ' pm-lim--de' : ''}`}>{cell.v}</span>}
                      </td>
                    ))}
                  </tr>
                ))}
              </Fragment>
            ))}

            <tr class="pm-cta-row">
              <td class="pm-feat"></td>
              <td>
                {currentPlan === 'lite' ? (
                  <span class="pm-cta pm-cta-now">Euer Plan ✓</span>
                ) : (
                  <button type="button" class="pm-cta pm-cta-out" @click="window.confirm('Zu Lite wechseln? Premium-Funktionen werden deaktiviert.') && downgradeLite()" :disabled="loading !== ''">Zu Lite →</button>
                )}
              </td>
              <td>
                {currentPlan === 'pro' ? (
                  <span class="pm-cta pm-cta-now">Euer Plan ✓</span>
                ) : (
                  <button type="button" class="pm-cta pm-cta-out" @click="openLeadModal('pro')" :disabled="loading !== ''">Vertrieb →</button>
                )}
              </td>
              <td class="pm-col-prem pm-col-prem--foot">
                {currentPlan === 'premium' ? (
                  <span class="pm-cta pm-cta-now">Euer Plan ✓</span>
                ) : (
                  <button type="button" class="pm-cta pm-cta-solid" @click="openLeadModal('premium')" :disabled="loading !== ''">Vertrieb →</button>
                )}
              </td>
              <td>
                {currentPlan === 'enterprise' ? (
                  <span class="pm-cta pm-cta-now">Euer Plan ✓</span>
                ) : (
                  <button type="button" class="pm-cta pm-cta-out" @click="openLeadModal('enterprise')" :disabled="loading !== ''">Kontakt →</button>
                )}
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="pm-foot">
        <span class="pm-mono">Petrol = enthalten · — = nicht enthalten</span><br>
        Premium bekommt alles außer den Gruppen-Funktionen — die Stufe, die nicht nur kostet, sondern verdient.
      </div>

    </div>

    <!-- ── Lead-Modal ────────────────────────────────────────────────────── -->
    <div class="lead-overlay" x-show="leadModal" x-cloak @click.self="leadModal = false" style="display:none">
      <div class="lead-modal" @keydown.escape.window="leadModal = false" role="dialog" aria-modal="true">

        <!-- Bestätigung nach Absenden -->
        <div x-show="leadSent" class="lead-sent" style="display:none">
          <div class="lead-sent__icon">✓</div>
          <h2 class="lead-sent__title">Danke — wir melden uns!</h2>
          <p class="lead-sent__sub">Deine Anfrage ist eingegangen. Wir kommen in Kürze auf dich zu.</p>
          <button type="button" class="v9-btn v9-btn--primary lead-close-btn" @click="leadModal = false">
            Schließen
          </button>
        </div>

        <!-- Formular -->
        <div x-show="!leadSent" style="display:none">
          <div class="lead-modal__head">
            <div>
              <p class="lead-modal__eyebrow">Upgrade-Interesse</p>
              <h2 class="lead-modal__title">
                Kontakt für <span class="lead-plan-chip" x-text="leadPlan.toUpperCase()"></span>
              </h2>
            </div>
            <button type="button" class="lead-modal__close" @click="leadModal = false" aria-label="Schließen">✕</button>
          </div>

          <!-- Read-only Hotel-Info -->
          <div class="lead-readonlys">
            <div class="lead-readonly">
              <span class="lead-readonly__label">Hotel</span>
              <span class="lead-readonly__val" x-text="window.__SUB_T__.hotelName"></span>
            </div>
            <div class="lead-readonly">
              <span class="lead-readonly__label">E-Mail</span>
              <span class="lead-readonly__val" x-text="window.__SUB_T__.userEmail"></span>
            </div>
          </div>

          <form class="lead-form" @submit.prevent="submitLead()">
            <div class="lead-field">
              <label class="lead-label" for="lead-phone">Telefon</label>
              <input
                id="lead-phone"
                type="tel"
                class="s-input lead-input"
                placeholder="+49 123 456789"
                x-model="leadPhone"
                autocomplete="tel"
              />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-time">Wunsch-Zeitfenster</label>
              <input
                id="lead-time"
                type="text"
                class="s-input lead-input"
                placeholder="z.B. Mo–Fr 9–12 Uhr"
                x-model="leadTime"
              />
            </div>
            <div class="lead-field">
              <label class="lead-label" for="lead-note">Notiz <span style="color:var(--ink-muted)">(optional)</span></label>
              <textarea
                id="lead-note"
                class="s-input lead-input"
                rows="3"
                placeholder="Was noch wichtig ist…"
                x-model="leadNote"
                style="resize:vertical"
              ></textarea>
            </div>

            <div class="lead-actions">
              <button type="button" class="v9-btn v9-btn--ghost" @click="leadModal = false">
                Abbrechen
              </button>
              <button
                type="submit"
                class="v9-btn v9-btn--primary lead-submit"
                :disabled="loading === 'lead'"
              >
                <span x-show="loading !== 'lead'">Anfrage absenden →</span>
                <span x-show="loading === 'lead'" style="display:none">Wird gesendet…</span>
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>

  </div>
</Layout>

<style>
  /* ── Lead Modal ─────────────────────────────────────────────────────────── */
  .lead-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.45);
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }
  .lead-modal {
    background: var(--surface, #fff);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 16px;
    padding: 28px;
    width: 100%; max-width: 480px;
    box-shadow: 0 20px 60px rgba(0,0,0,.12);
  }
  .lead-modal__head {
    display: flex; align-items: flex-start; justify-content: space-between;
    margin-bottom: 20px; gap: 12px;
  }
  .lead-modal__eyebrow {
    font-size: 11px; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink-muted, #888);
    margin: 0 0 4px;
  }
  .lead-modal__title {
    font-size: 18px; font-weight: 600; color: var(--ink, #1a1a1a);
    margin: 0; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .lead-plan-chip {
    background: var(--petrol, #14616E);
    color: #fff; font-size: 11px; font-weight: 600; letter-spacing: .08em;
    padding: 2px 8px; border-radius: 6px;
  }
  .lead-modal__close {
    background: none; border: none; cursor: pointer;
    color: var(--ink-muted, #888); font-size: 16px; line-height: 1;
    padding: 4px; border-radius: 6px; flex-shrink: 0;
  }
  .lead-modal__close:hover { color: var(--ink, #1a1a1a); background: var(--surface-alt, #f4f4f3); }
  .lead-readonlys {
    display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;
  }
  .lead-readonly {
    background: var(--surface-alt, #f4f4f3);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 8px; padding: 8px 12px;
    display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 140px;
  }
  .lead-readonly__label {
    font-size: 10px; font-weight: 500; letter-spacing: .06em;
    text-transform: uppercase; color: var(--ink-muted, #888);
  }
  .lead-readonly__val {
    font-size: 13px; font-weight: 500; color: var(--ink, #1a1a1a);
    word-break: break-all;
  }
  .lead-form { display: flex; flex-direction: column; gap: 14px; }
  .lead-field { display: flex; flex-direction: column; gap: 5px; }
  .lead-label { font-size: 13px; font-weight: 500; color: var(--ink, #1a1a1a); }
  .lead-input { width: 100%; }
  .lead-actions {
    display: flex; gap: 8px; justify-content: flex-end; margin-top: 6px;
  }
  .lead-submit { min-width: 160px; }
  .lead-sent {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 16px 0;
  }
  .lead-sent__icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--petrol, #14616E); color: #fff;
    font-size: 24px; display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .lead-sent__title { font-size: 18px; font-weight: 600; margin: 0 0 8px; }
  .lead-sent__sub { font-size: 14px; color: var(--ink-muted, #888); margin: 0 0 24px; }
  .lead-close-btn { min-width: 120px; }

  /* ── Wow-Abo-Page ───────────────────────────────────────────────────────── */
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap');

  /* ── Plan-Vergleichs-Matrix ──────────────────────────────────────────────── */
  .pm-page {
    --pm-petrol: #14616E; --pm-petrol-d: #0e4d57;
    --pm-ink: #0A0A0A; --pm-muted: rgba(10,10,10,.50); --pm-faint: rgba(10,10,10,.26);
    --pm-border: rgba(10,10,10,.10); --pm-border-strong: #E5E4E0;
    --pm-tint: rgba(20,97,110,.055); --pm-tint2: rgba(20,97,110,.09);
    --pm-surface: #fff; --pm-sage: #5C9070;
    --pm-sg: 'Space Grotesk', sans-serif; --pm-mn: 'JetBrains Mono', monospace;
    padding: 40px 0 80px;
  }

  /* Hero */
  .pm-hero { text-align: center; padding: 10px 0 4px; }
  .pm-eye { font-family: var(--pm-mn); font-size: 10px; letter-spacing: .3em; text-transform: uppercase; color: var(--pm-faint); margin-bottom: 18px; }
  .pm-h1 { font-family: var(--pm-sg); font-size: 40px; line-height: 1.07; letter-spacing: -.035em; font-weight: 700; margin: 0 0 16px; color: var(--pm-ink); }
  .pm-em { color: var(--pm-petrol); }
  .pm-sub { font-size: 15px; color: var(--pm-muted); max-width: 540px; margin: 0 auto; line-height: 1.6; }

  /* Matrix */
  .pm-matwrap { margin: 44px 0 24px; overflow-x: auto; }
  .pm-mat { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 760px; }
  .pm-mat th, .pm-mat td { padding: 0; text-align: center; vertical-align: middle; }
  .pm-feat { text-align: left; width: 34%; padding: 0 18px; }

  .pm-mat thead th { padding-bottom: 8px; position: relative; }
  .pm-th-inner { padding: 14px 10px 16px; }
  .pm-tier-name { font-family: var(--pm-mn); font-size: 13px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--pm-ink); }
  .pm-tier-sub { font-family: var(--pm-mn); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--pm-faint); margin-top: 5px; }
  .pm-tier-now { display: inline-block; font-family: var(--pm-mn); font-size: 8px; letter-spacing: .14em; text-transform: uppercase; color: var(--pm-sage); border: 1px solid var(--pm-sage); border-radius: 6px; padding: 2px 7px; margin-top: 7px; }

  /* Premium-Spalte (Held) */
  .pm-col-prem { background: var(--pm-tint); }
  .pm-mat thead th.pm-col-prem .pm-th-inner { border-radius: 14px 14px 0 0; border-top: 1.5px solid var(--pm-petrol); border-left: 1.5px solid var(--pm-petrol); border-right: 1.5px solid var(--pm-petrol); position: relative; overflow: hidden; }
  .pm-mat thead th.pm-col-prem .pm-th-inner::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(115deg,#14616E,#1AA0B0 34%,#5B7CE0 68%,#14616E 100%); background-size: 220% 100%; animation: pm-aurora 5s linear infinite; }
  @keyframes pm-aurora { 0% { background-position: 0% 50%; } 100% { background-position: 220% 50%; } }
  .pm-mat td.pm-col-prem { border-left: 1.5px solid var(--pm-petrol); border-right: 1.5px solid var(--pm-petrol); }
  .pm-col-prem--foot { border-bottom: 1.5px solid var(--pm-petrol); border-radius: 0 0 14px 14px; }
  .pm-prem-cap { position: absolute; top: -11px; left: 50%; transform: translateX(-50%); font-family: var(--pm-mn); font-size: 8px; letter-spacing: .16em; text-transform: uppercase; color: #fff; background: var(--pm-petrol); border-radius: 999px; padding: 4px 11px; white-space: nowrap; font-weight: 600; z-index: 2; }

  /* Gruppen + Zeilen */
  .pm-grp td { padding: 26px 18px 9px; text-align: left; }
  .pm-gl { font-family: var(--pm-mn); font-size: 9.5px; letter-spacing: .2em; text-transform: uppercase; color: var(--pm-petrol); }
  .pm-row td { border-top: 1px solid var(--pm-border); height: 52px; }
  .pm-row:hover td { background: rgba(10,10,10,.015); }
  .pm-row:hover td.pm-col-prem { background: var(--pm-tint2); }
  .pm-fl { font-size: 14px; letter-spacing: -.005em; color: var(--pm-ink); }
  .pm-hint { display: block; font-size: 11px; color: var(--pm-muted); margin-top: 2px; line-height: 1.4; }

  /* Zellen */
  .pm-yes { display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 50%; background: var(--pm-petrol); color: #fff; }
  .pm-no { display: inline-block; width: 24px; height: 2px; border-radius: 2px; background: var(--pm-faint); vertical-align: middle; }
  .pm-lim { font-family: var(--pm-mn); font-size: 12px; font-weight: 600; letter-spacing: .04em; color: var(--pm-petrol); }
  .pm-lim--de { color: var(--pm-muted); font-weight: 500; }

  /* CTA-Zeile */
  .pm-cta-row td { padding-top: 18px; }
