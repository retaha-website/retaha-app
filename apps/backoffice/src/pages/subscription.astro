---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, getUserRole, hasPermission } from '@retaha/auth';
import { calculateTrialStatus } from '../lib/trial-status';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const dateLocale = lang === 'de' ? 'de-DE' : lang;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

// Billing ist Owner-only (Matrix: manager = „kein Billing").
const billingRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!billingRole || !hasPermission(billingRole, 'hotel.billing')) {
  return Astro.redirect('/overview?error=billing_owner_only');
}

const currentPlan: string = (hotel as any).plan ?? 'lite';
const currentAddons: string[] = (hotel as any).addons ?? [];
const trial = calculateTrialStatus(hotel);
const trialEndFormatted = trial.endsAt?.toLocaleDateString(dateLocale, {
  day: 'numeric', month: 'long', year: 'numeric',
});

const TIER_RANK: Record<string, number> = { lite: 0, pro: 1, premium: 2, enterprise: 3 };
const allIn = (planLabel: string) => bt('sub.mod.allin', lang).replace('{plan}', planLabel);

const PLANS = [
  {
    key: 'lite',
    label: 'Lite',
    headline: bt('sub.plan.lite.headline', lang),
    frame: bt('sub.plan.lite.frame', lang),
    popular: false,
    isFree: true,
    paysOff: false,
    modules: [
      bt('sub.mod.welcomehub', lang), bt('sub.mod.wifi', lang), bt('sub.mod.breakfast', lang),
      bt('sub.mod.service', lang), bt('sub.mod.feedback', lang), bt('sub.mod.actioncards', lang),
      bt('sub.mod.eve.lite', lang),
    ],
  },
  {
    key: 'pro',
    label: 'Pro',
    headline: bt('sub.plan.pro.headline', lang),
    frame: bt('sub.plan.pro.frame', lang),
    popular: false,
    isFree: false,
    paysOff: false,
    modules: [
      allIn('Lite'),
      bt('sub.mod.places', lang), bt('sub.mod.langs', lang),
      bt('sub.mod.nfc', lang), bt('sub.mod.prestay', lang),
      bt('sub.mod.pmsext', lang),
      bt('sub.mod.eve.pro', lang),
    ],
  },
  {
    key: 'premium',
    label: 'Premium',
    headline: bt('sub.plan.premium.headline', lang),
    frame: bt('sub.plan.premium.frame', lang),
    popular: true,
    isFree: false,
    paysOff: true,
    modules: [
      allIn('Pro'),
      bt('sub.mod.staypush', lang),
      bt('sub.mod.eve', lang),
      bt('sub.mod.wallet', lang),
      bt('sub.mod.marketing', lang), bt('sub.mod.loyalty', lang),
      bt('sub.mod.referral', lang), bt('sub.mod.bestprice', lang),
      bt('sub.mod.microsite', lang),
      bt('sub.mod.ownpms', lang),
      bt('sub.mod.selfcheckout', lang), bt('sub.mod.dooropener', lang),
      bt('sub.mod.domain', lang), bt('sub.mod.emaildomain', lang),
    ],
  },
  {
    key: 'enterprise',
    label: 'Enterprise',
    headline: bt('sub.plan.enterprise.headline', lang),
    frame: bt('sub.plan.enterprise.frame', lang),
    popular: false,
    isFree: false,
    paysOff: false,
    modules: [
      allIn('Premium'),
      bt('sub.mod.multiprop', lang), bt('sub.mod.whitelabel', lang),
      bt('sub.mod.api', lang),
      bt('sub.mod.accountmgr', lang),
    ],
  },
];

const PLAN_LABEL: Record<string, string> = {
  lite: 'Lite', pro: 'Pro', premium: 'Premium', enterprise: 'Enterprise',
};

// Eve Add-on: alle Pläne; bei Premium + Enterprise ist Eve inklusive
const showEveAddon = true;
const hasEveAddon  = currentAddons.includes('eve');
const eveIncluded  = currentPlan === 'premium' || currentPlan === 'enterprise';
---

<Layout
  title={bt('sub.titleplain', lang)}
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
>
  <script is:inline define:vars={{
    SUB_ERR_TRIAL: bt('sub.err.trial', lang),
    SUB_TRIAL_SENT: bt('sub.trial.sent', lang),
  }}>
    window.__SUB_T__ = { errTrial: SUB_ERR_TRIAL, trialSent: SUB_TRIAL_SENT };
  </script>
  <div
    class="settings-page"
    x-data="{
      loading: '',
      async requestSales(plan) {
        this.loading = plan;
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ plan })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.retahaToast?.(window.__SUB_T__.trialSent, 'success');
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      },
      async requestAddon(addon) {
        this.loading = addon;
        try {
          const res = await fetch('/api/subscription/request-upgrade', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ addon })
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || window.__SUB_T__.errTrial);
          window.retahaToast?.(window.__SUB_T__.trialSent, 'success');
          this.loading = '';
        } catch(e) {
          window.retahaToast?.(e.message, 'error');
          this.loading = '';
        }
      }
    }"
  >

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('sub.crumb', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('sub.title', lang)}></h1>
      <p class="settings-hero__sub">
        {trial.isInTrial
          ? bt('sub.hero.trial', lang).replace('{ends}', trialEndFormatted ? bt('sub.hero.trialends', lang).replace('{date}', trialEndFormatted) : '')
          : bt('sub.hero.notrial', lang)}
      </p>
    </section>

    <div class="settings-sections">

      <!-- Aktueller Plan -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('sub.current.title', lang)}</h2>
        </div>
        <div class="s-card__body">
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span class={`sub-plan-badge sub-plan-badge--${currentPlan}`}>
              {PLAN_LABEL[currentPlan] ?? currentPlan}
            </span>
            {trial.isInTrial && trialEndFormatted && (
              <span class="sub-trial-note">{bt('sub.trialnote', lang).replace('{date}', trialEndFormatted)}</span>
            )}
          </div>
        </div>
      </section>

      <!-- Pakete -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">{bt('sub.compare.title', lang)}</h2>
        </div>
        <div class="s-card__body">

          <div class="sub-plans-grid">
            {PLANS.map(plan => {
              const rank = TIER_RANK[plan.key] ?? 0;
              const curRank = TIER_RANK[currentPlan] ?? 0;
              const isCurrent   = plan.key === currentPlan;
              const isDowngrade = rank < curRank;

              return (
                <div class={[
                  'sub-plan-card',
                  isCurrent   ? 'sub-plan-card--current'   : '',
                  isDowngrade ? 'sub-plan-card--downgrade'  : '',
                  plan.popular && !isCurrent ? 'sub-plan-card--popular' : '',
                ].filter(Boolean).join(' ')}>

                  {plan.popular && !isCurrent && (
                    <div class="sub-plan-card__bar sub-plan-card__bar--popular">{bt('sub.recommended', lang)}</div>
                  )}
                  {isCurrent && (
                    <div class="sub-plan-card__bar sub-plan-card__bar--current">{bt('sub.yourplan', lang)}</div>
                  )}

                  <div class="sub-plan-card__head">
                    <span class={`sub-plan-tier sub-plan-tier--${plan.key}`}>{plan.label}</span>
                    {plan.paysOff && (
                      <span class="sub-plan-paysoff">{bt('sub.paysoff', lang)}</span>
                    )}
                    {plan.isFree && (
                      <span class="sub-plan-free">{bt('sub.price.free', lang)}</span>
                    )}
                  </div>

                  <!-- Benefit headline (replaces price) -->
                  <div class="sub-plan-card__headline">
                    <p class="sub-plan-headline">{plan.headline}</p>
                    <p class="sub-plan-frame">{plan.frame}</p>
                  </div>

                  <ul class="sub-plan-modules">
                    {plan.modules.map(m => (
                      <li class="sub-plan-module-item">
                        <span class="sub-plan-module-check" aria-hidden="true">✓</span>
                        {m}
                      </li>
                    ))}
                  </ul>

                  <div class="sub-plan-card__cta">
                    {isCurrent ? (
                      <button type="button" class="v9-btn v9-btn--ghost sub-plan-btn sub-plan-btn--current" disabled>
                        {bt('sub.btn.current', lang)}
                      </button>
                    ) : plan.key === 'enterprise' ? (
                      <a href="mailto:hallo@retaha.de" class="v9-btn v9-btn--ghost sub-plan-btn">
                        {bt('sub.btn.contact', lang)}
                      </a>
                    ) : plan.key === 'lite' ? (
                      <a href="mailto:hallo@retaha.de" class="v9-btn v9-btn--ghost sub-plan-btn">
                        {bt('sub.btn.toLite', lang)}
                      </a>
                    ) : (
                      <button
                        type="button"
                        class="v9-btn v9-btn--primary sub-plan-btn"
                        @click={`requestSales('${plan.key}')`}
                        :disabled="loading !== ''"
                        :class={`{ 'sub-plan-btn--loading': loading === '${plan.key}' }`}
                      >
                        <span x-show={`loading !== '${plan.key}'`}>{bt('sub.btn.sales', lang)}</span>
                        <span x-show={`loading === '${plan.key}'`} style="display:none">{bt('sub.btn.trial.preparing', lang)}</span>
                      </button>
                    )}
                  </div>
                </div>
              );
            })}
          </div>

        </div>
      </section>

      <!-- Eve Add-on -->
      {showEveAddon && (
        <section class="s-card">
          <div class="s-card__head">
            <h2 class="s-card__title">{bt('sub.addons.title', lang)}</h2>
          </div>
          <div class="s-card__body">
            <div class="sub-evecard">
              <div class="sub-eve-head">
                <svg class="sub-eve-spk" width="14" height="14" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/>
                </svg>
                <b><span class="sub-eve-gradient">Eve</span> KI · Aktions-Agent</b>
                <div class="sub-eve-head-right">
                  {eveIncluded ? (
                    <span class="sub-addon-badge sub-addon-badge--included">{bt('sub.addon.eve.included', lang)}</span>
                  ) : hasEveAddon ? (
                    <span class="sub-addon-badge">{bt('sub.addon.active', lang)}</span>
                  ) : null}
                </div>
              </div>
              <p class="sub-eve-desc">{bt('sub.addon.eve.desc', lang)}</p>
              {!eveIncluded && !hasEveAddon && (
                <div class="sub-eve-row">
                  <span class="sub-addon-price">89 € <span class="sub-addon-price-per">{bt('sub.permonth', lang)}</span></span>
                  <button
                    type="button"
                    class="sub-eve-aurora-btn"
                    @click="requestAddon('eve')"
                    :disabled="loading !== ''"
                    :class="{ 'sub-eve-aurora-btn--loading': loading === 'eve' }"
                  >
                    <svg class="sub-eve-spk-anim" width="11" height="11" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
                    <span x-show="loading !== 'eve'">{bt('sub.btn.add', lang)}</span>
                    <span x-show="loading === 'eve'" style="display:none">{bt('sub.btn.trial.preparing', lang)}</span>
                  </button>
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      <!-- Footer-Notiz -->
      <div class="sub-footer-note">
        <p>
          {bt('sub.footer.note', lang)} <a href="mailto:hallo@retaha.de" class="sub-footer-link">hallo@retaha.de</a>
        </p>
        <a href="/overview" class="v9-btn v9-btn--ghost">{bt('sub.footer.back', lang)}</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  /* ── Layout-Overrides (wie /marketing: 16px-Radius, 32px-Gap) ───────────── */
  .breadcrumb { padding-top: 36px; }
  .settings-sections { gap: 32px; }
  .s-card { border-radius: 16px; }

  /* ── Plan badge (current plan indicator) ────────────────────────────────── */
  .sub-plan-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em;
    padding: 4px 10px; border-radius: 99px; text-transform: uppercase;
  }
  .sub-plan-badge--lite       { background: #f5f5f5; color: #1a1a1a; border: 1px solid #d0d0d0; }
  .sub-plan-badge--pro        { background: #edf7f0; color: #2e7d4f; border: 1px solid #a8d5b8; }
  .sub-plan-badge--premium    { background: #f4f0fb; color: #6d28d9; border: 1px solid #c4b5f5; }
  .sub-plan-badge--enterprise { background: #1a1a1a; color: #fff;    border: 1px solid #1a1a1a; }

  .sub-trial-note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); letter-spacing: 0.04em;
  }

  /* ── Plans Grid ──────────────────────────────────────────────────────────── */
  .sub-plans-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 1000px) { .sub-plans-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .sub-plans-grid { grid-template-columns: 1fr; } }

  /* ── Plan Card ───────────────────────────────────────────────────────────── */
  .sub-plan-card {
    border: 1px solid var(--border);
    border-radius: var(--r, 8px);
    background: var(--surface);
    padding: 20px;
    display: flex; flex-direction: column;
    position: relative; overflow: hidden;
    transition: box-shadow 150ms;
  }
  .sub-plan-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); }
  .sub-plan-card--current  { border-color: var(--ink, #1a1a1a); border-width: 2px; }
  .sub-plan-card--popular  { border-color: #7c3aed; }
  .sub-plan-card--downgrade { opacity: 0.6; }

  .sub-plan-card__bar {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
    text-align: center; padding: 4px;
    margin: -20px -20px 16px;
  }
  .sub-plan-card__bar--popular { background: #7c3aed; color: #fff; }
  .sub-plan-card__bar--current { background: var(--ink, #1a1a1a); color: #fff; }

  /* ── Card Head: tier badge + paysOff/free badge ─────────────────────────── */
  .sub-plan-card__head {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .sub-plan-tier {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 99px; border: 1px solid;
    display: inline-block;
  }
  .sub-plan-tier--lite       { background: transparent; color: #555; border-color: #ccc; }
  .sub-plan-tier--pro        { background: #edf7f0;    color: #2e7d4f; border-color: #a8d5b8; }
  .sub-plan-tier--premium    { background: #f4f0fb;    color: #6d28d9; border-color: #c4b5f5; }
  .sub-plan-tier--enterprise { background: #1a1a1a;    color: #fff;    border-color: #1a1a1a; }

  /* "Kostenlos" label for Lite */
  .sub-plan-free {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 99px;
    background: #e8f5ec; color: #2e7d4f; border: 1px solid #a8d5b8;
  }

  /* "zahlt sich aus" badge for Premium */
  .sub-plan-paysoff {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 99px;
    background: #e6f1ea; color: #2E6B4E; border: 1px solid #BBD8C7;
  }

  /* ── Benefit headline (replaces price) ──────────────────────────────────── */
  .sub-plan-card__headline {
    margin-bottom: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .sub-plan-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 700; line-height: 1.25;
    letter-spacing: -0.02em; color: var(--ink);
    margin: 0 0 6px;
  }

  .sub-plan-frame {
    font-size: 11.5px; line-height: 1.55; color: var(--ink-muted);
    margin: 0;
  }

  /* ── Module list ─────────────────────────────────────────────────────────── */
  .sub-plan-modules {
    list-style: none; padding: 0; margin: 0 0 20px;
    display: flex; flex-direction: column; gap: 6px; flex: 1;
  }
  .sub-plan-module-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); letter-spacing: 0.02em;
    display: flex; align-items: flex-start; gap: 7px; line-height: 1.4;
  }
  .sub-plan-module-check { color: #2e7d4f; flex-shrink: 0; font-size: 10px; margin-top: 1px; }

  .sub-plan-card__cta { margin-top: auto; }

  .sub-plan-btn {
    width: 100%; display: block; text-align: center; text-decoration: none;
    font-size: 10px !important;
  }
  .sub-plan-btn--current { opacity: 0.6; cursor: not-allowed; }
  .sub-plan-btn--loading { opacity: 0.65; }

  /* ── Eve Add-on card ────────────────────────────────────────────────────── */
  @keyframes sub-aurora-flow { to { background-position: 0 0, 240% 0; } }
  @keyframes sub-eve-twinkle { 0%,100%{transform:scale(1) rotate(0);opacity:1} 50%{transform:scale(1.3) rotate(90deg);opacity:.7} }

  .sub-evecard {
    position: relative;
    border: 1.6px solid transparent;
    border-radius: 16px;
    padding: 20px 22px;
    background: linear-gradient(var(--surface, #fff), var(--surface, #fff)) padding-box,
                linear-gradient(115deg,#14616E 0%,#1AA0B0 34%,#5B7CE0 68%,#14616E 100%) border-box;
    background-size: auto, 240% 100%;
    animation: sub-aurora-flow 7s linear infinite;
    box-shadow: 0 8px 30px rgba(45,91,208,.12);
  }
  .sub-eve-head {
    display: flex; align-items: center; gap: 9px; margin-bottom: 8px;
    font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 16px; color: var(--ink);
  }
  .sub-eve-head-right { margin-left: auto; }
  .sub-eve-spk { color: #2E72C8; flex-shrink: 0; animation: sub-eve-twinkle 2.4s ease-in-out infinite; }
  .sub-eve-spk-anim { animation: sub-eve-twinkle 2.4s ease-in-out infinite; }
  .sub-eve-gradient {
    background: linear-gradient(115deg,#14616E 0%,#1AA0B0 34%,#5B7CE0 68%,#14616E 100%);
    background-size: 240% 100%;
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    animation: sub-aurora-flow 5s linear infinite; font-weight: 700;
  }
  .sub-eve-desc {
    font-size: 13px; color: var(--ink-muted); line-height: 1.55; margin: 0 0 16px; max-width: 560px;
  }
  .sub-eve-row {
    display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }
  .sub-addon-price {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px; font-weight: 300; color: var(--ink); line-height: 1;
  }
  .sub-addon-price-per {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted);
  }
  .sub-eve-aurora-btn {
    cursor: pointer; display: inline-flex; align-items: center; gap: 7px;
    white-space: nowrap; border-radius: 9px; border: 0; color: #fff;
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: .05em; text-transform: uppercase;
    padding: 8px 13px;
    background: linear-gradient(115deg,#14616E 0%,#1AA0B0 34%,#5B7CE0 68%,#14616E 100%);
    background-size: 280% 100%;
    animation: sub-aurora-flow 6s linear infinite;
    box-shadow: 0 5px 16px rgba(20,97,110,.28);
    transition: transform .15s, box-shadow .2s;
  }
  .sub-eve-aurora-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 9px 26px rgba(45,91,208,.38); animation-duration: 2.2s; }
  .sub-eve-aurora-btn:disabled,
  .sub-eve-aurora-btn--loading { opacity: .55; cursor: not-allowed; transform: none; }
  .sub-addon-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 99px;
    background: #edf7f0; color: #2e7d4f; border: 1px solid #a8d5b8;
  }
  .sub-addon-badge--included {
    background: #f4f0fb; color: #6d28d9; border-color: #c4b5f5;
  }

  /* ── Footer note ─────────────────────────────────────────────────────────── */
  .sub-footer-note {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--ink-muted); letter-spacing: 0.02em;
    padding: 16px 20px;
    border: 1px solid var(--border); border-radius: var(--r, 8px);
    background: var(--bg-deep, #F0EDE6);
  }
  .sub-footer-note p { margin: 0; }
  .sub-footer-link { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; }
</style>
