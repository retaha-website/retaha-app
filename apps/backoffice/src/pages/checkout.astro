---
// Self-Checkout-Einstellungen (Backoffice).
//
// Ein 3-Wege-Status bildet die Konsistenz-Matrix ab und schreibt auf die
// vorhandene Datenbasis (kein neuer Aus-Wert):
//   Aus           → features.self_checkout = false        (Master, = Gast-Vorschau-Toggle)
//   Nur Infos     → features.self_checkout = true, self_checkout_mode = 'info'
//   Self-Checkout → features.self_checkout = true, self_checkout_mode = 'self'
// Checkout-Zeit (checkout_time) lebt jetzt hier (eine Quelle der Wahrheit);
// Check-in-Zeit bleibt unter Allgemein. Gast-Hinweis i18n in self_checkout_note.
//
// hotel_settings ist service-role-managed (wie Fruehstuecks-/Service-Zeiten).
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();

// ─── POST ──────────────────────────────────────────────────────────────────
let saved: { ok: boolean; msg: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const reTime = /^([01]\d|2[0-3]):[0-5]\d$/;
  const coRaw = form.get('checkout_time')?.toString().trim() || '';
  const ciRaw = form.get('checkin_time')?.toString().trim() || '';
  const noteDe = (form.get('note_de')?.toString() ?? '').trim().slice(0, 600);

  const note: Record<string, string> = {};
  if (noteDe) note.de = noteDe;

  const updates: Record<string, unknown> = {
    self_checkout_note: note,
    updated_at: new Date().toISOString(),
  };
  if (reTime.test(coRaw)) updates.checkout_time = coRaw;
  if (reTime.test(ciRaw)) updates.checkin_time = ciRaw;

  const { error } = await sb.from('hotel_settings').update(updates).eq('hotel_id', hotel.id);
  saved = error ? { ok: false, msg: error.message } : { ok: true, msg: bt('common.savedshort', lang) };
}

// ─── LADEN ─────────────────────────────────────────────────────────────────
const { data: hs } = await sb
  .from('hotel_settings')
  .select('features, self_checkout_mode, self_checkout_note, checkout_time, checkin_time')
  .eq('hotel_id', hotel.id).maybeSingle();

const features = ((hs?.features as Record<string, unknown>) ?? {});
const mode = (hs?.self_checkout_mode as string) === 'info' ? 'info' : 'self';
// Master-Zustand konsistent zum Gast-Vorschau-Toggle (Default an = !== false).
const scState = features.self_checkout === false ? 'off' : mode;
const checkoutTime = ((hs?.checkout_time as string) ?? '11:00').toString().substring(0, 5);
const checkinTime = ((hs?.checkin_time as string) ?? '15:00').toString().substring(0, 5);
const note = ((hs?.self_checkout_note as Record<string, string>) ?? {});
const noteDe = note.de ?? '';
const noteEn = note.en ?? '';

const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';
const scOn = scState !== 'off';

const plan = ((hotel as any).plan as string | undefined) ?? 'lite';
const isPremium = ['premium', 'enterprise'].includes(plan);
---

<Layout title="Checkout" activeTab="backoffice" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

  <div class="settings-page" style="padding-top:0">

    <nav class="breadcrumb" style="padding-top:36px" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('tab.backoffice', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.checkout', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('sc.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('sc.hero.sub', lang)}</p>
    </section>

    <form method="POST" class="sc-wrap">

      <!-- Modul-Status (read-only, Toggle nur in Gäste-Vorschau) -->
      <div class="sc-card">
        <div class="sc-card-head">
          <span class="sc-card-title">{bt('si.mod.title', lang)}</span>
        </div>
        <p class="sc-hint">{bt('si.mod.hint', lang)}</p>
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
          <ModStatusLed on={scOn} />
          <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">{bt('si.mod.link', lang)}</a>
        </div>
      </div>

      <!-- Self-Checkout Feature (Premium-Gate) -->
      {!isPremium && (
        <div class="sc-card">
          <div class="sc-card-head">
            <span class="sc-card-title">{bt('sc.feature.title', lang)}</span>
          </div>
          <div class="bf-locked-ctrl" aria-disabled="true">
            <span class="bf-lock-chip">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              PREMIUM
            </span>
            <div class="bf-locked-inner" aria-hidden="true">
              <p class="sc-hint" style="margin-bottom:14px">{bt('sc.feature.hint', lang)}</p>
              <label class="toggle-row bf-close-toggle" style="pointer-events:none;margin:0;gap:6px">
                <span class="bt-visual"><span class="bt-knob"></span></span>
                <span class="toggle-label" style="font-size:11px;color:var(--ink-muted)">{bt('sc.feature.title', lang)}</span>
              </label>
            </div>
            <p class="bf-lock-info">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;color:var(--petrol,#14616E)"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span set:html={bt('sc.feature.lite.info', lang)}></span>
              <a href="/unlock/self-checkout">{bt('sc.feature.unlock', lang)}</a>
            </p>
          </div>
        </div>
      )}

      <!-- Check-in + Check-out nebeneinander -->
      <div class="sc-time-row">
        <div class="sc-card">
          <div class="sc-card-head">
            <span class="sc-card-title">{bt('sc.time.checkin', lang)}</span>
          </div>
          <p class="sc-hint" style="margin-bottom:10px">{bt('sc.time.checkinhint', lang)}</p>
          <input type="time" id="checkin-time" name="checkin_time" class="s-input" value={checkinTime} style="width:fit-content" />
        </div>
        <div class="sc-card">
          <div class="sc-card-head">
            <span class="sc-card-title">{bt('sc.time.checkout', lang)}</span>
          </div>
          <p class="sc-hint" style="margin-bottom:10px">{bt('sc.time.checkouthint', lang)}</p>
          <input type="time" id="checkout-time" name="checkout_time" class="s-input" value={checkoutTime} style="width:fit-content" />
        </div>
      </div>

      <!-- Gast-Hinweis + Mit Eve schreiben -->
      <div class="sc-card" id="sc-note"
        x-data={`{
          eveOpen: false, evePrompt: '', eveLoading: false, eveError: '',
          valDe: ${JSON.stringify(noteDe)},
          async generate() {
            this.eveLoading = true; this.eveError = '';
            try {
              const r = await fetch('/api/admin/eve/generate-field', {
                method: 'POST', headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ prompt: this.evePrompt, field: 'checkout_note' })
              });
              const d = await r.json();
              if (d.ok) { this.valDe = d.text; this.eveOpen = false; this.evePrompt = ''; }
              else { this.eveError = d.message || 'Fehler beim Generieren.'; }
            } catch { this.eveError = 'Netzwerk-Fehler. Versuche es erneut.'; }
            this.eveLoading = false;
          }
        }`}
      >
        <div class="sc-card-head">
          <span class="sc-card-title">{bt('sc.note.title', lang)}</span>
          <button type="button" class="sc-aurora-btn" @click="eveOpen = true" aria-label="Mit Eve schreiben">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
            Mit Eve schreiben
          </button>
        </div>
        <p class="sc-hint" set:html={bt('sc.note.sub', lang)}></p>

        <div class="sc-field" style="margin-bottom:0">
          <label class="sc-label" for="note-de">{bt('sc.note.de', lang)}</label>
          <textarea id="note-de" name="note_de" class="s-input sc-textarea" rows="3"
            x-model="valDe"
            placeholder="z.B. Schlüsselkarte einfach im Zimmer lassen. Late-Checkout auf Anfrage an der Rezeption."></textarea>
        </div>
        <!-- Eve-Popup -->
        <div class="sc-eve-overlay" x-show="eveOpen" x-cloak @click.self="eveOpen=false" @keydown.escape.window="eveOpen=false">
          <div class="sc-eve-modal" @click.stop>
            <div class="sc-eve-mhd">
              <span class="sc-eve-mhd-title">Mit Eve schreiben</span>
              <button type="button" class="sc-eve-close" @click="eveOpen=false" aria-label="Schließen">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </button>
            </div>
            <p style="font-size:12px;color:var(--ink-muted);margin:0 0 12px">Beschreibe kurz, was im Checkout-Hinweis stehen soll — Eve schreibt den Text.</p>
            <textarea class="sc-eve-ta" x-model="evePrompt" rows="3"
              placeholder="z. B. Schlüssel in der Zimmerbox lassen, Late-Checkout bis 13 Uhr möglich"
              @keydown.meta.enter="generate()" @keydown.ctrl.enter="generate()"></textarea>
            <p x-show="eveError" x-cloak class="sc-eve-err" x-text="eveError"></p>
            <div class="sc-eve-mft">
              <button type="button" class="sc-eve-cancel" @click="eveOpen=false">{bt('common.cancel', lang)}</button>
              <button type="button" class="sc-aurora-btn" @click="generate()" :disabled="eveLoading || evePrompt.trim().length < 3">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                <span x-show="!eveLoading">Generieren</span>
                <span x-show="eveLoading" x-cloak>…</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Speichern -->
      <div class="sc-form-foot">
        <button type="submit" class="v9-btn sc-btn-primary">{bt('common.save', lang)}</button>
      </div>

    </form>
  </div>

  {saved && (
    <script is:inline set:html={`(function(){var m=${JSON.stringify(saved.msg)},t=${JSON.stringify(saved.ok ? 'success' : 'error')};function go(){window.retahaToast&&window.retahaToast(m,t)}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',go);else go();})();`}></script>
  )}

  <style>
    [x-cloak] { display: none !important; }

    /* ── V9-Karten ─────────────────────────────────────────────────────────── */
    .sc-wrap { display: flex; flex-direction: column; gap: 16px; }
    .sc-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 16px 18px; }
    .sc-card-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 12px; }
    .sc-card-title {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 13px; color: var(--ink);
    }
    .sc-card-title::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--petrol, #14616E); flex-shrink: 0; }
    .sc-hint { display: block; font-size: 11px; color: var(--ink-muted); line-height: 1.45; margin-top: 6px; margin-bottom: 14px; }

    /* ── Lite Locked Control (= breakfast/Zimmerservice pattern) ────────────── */
    .bf-locked-ctrl {
      position: relative; border: 1px dashed var(--petrol, #14616E);
      border-radius: 10px; padding: 14px 14px 12px; margin-top: 4px;
    }
    .bf-lock-chip {
      display: inline-flex; align-items: center; gap: 5px;
      position: absolute; top: -11px; right: 12px;
      background: var(--surface, #fff); padding: 2px 9px;
      border: 1px solid var(--petrol, #14616E); border-radius: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--petrol, #14616E);
    }
    .bf-locked-inner { opacity: 0.5; pointer-events: none; user-select: none; }
    .bf-lock-info {
      display: flex; align-items: center; gap: 8px; padding: 8px 12px;
      background: rgba(20,97,110,0.06); border: 1px solid rgba(20,97,110,0.18);
      border-radius: 8px; font-size: 12px; line-height: 1.45;
      color: var(--ink-soft, rgba(10,10,10,0.65)); margin: 10px 0 0;
    }
    .bf-lock-info a { color: var(--petrol, #14616E); text-decoration: none; font-weight: 600; }
    .bf-lock-info a:hover { text-decoration: underline; }
    .bf-close-toggle .bt-visual { border: none !important; background: transparent !important; }

    /* ── Zeiten nebeneinander ───────────────────────────────────────────────── */
    .sc-time-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 480px) { .sc-time-row { grid-template-columns: 1fr; } }

    /* ── Felder ─────────────────────────────────────────────────────────────── */
    .sc-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .sc-field:last-child { margin-bottom: 0; }
    .sc-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-muted); }
    .sc-textarea { resize: vertical; min-height: 56px; line-height: 1.5; width: 100%; box-sizing: border-box; }

    /* ── Speichern ──────────────────────────────────────────────────────────── */
    .sc-form-foot { display: flex; justify-content: flex-end; padding-top: 4px; }
    .sc-btn-primary { background: var(--petrol, #14616E) !important; color: #fff !important; border: none !important; border-radius: 7px; padding: 7px 16px !important; font-size: 10px !important; font-weight: 300 !important; }
    .sc-btn-primary:hover { filter: brightness(1.1); }

    /* ── Aurora-Button ──────────────────────────────────────────────────────── */
    .sc-aurora-btn {
      display: inline-flex; align-items: center; gap: 6px; flex-shrink: 0;
      font-family: 'JetBrains Mono', monospace; font-size: 8px; font-weight: 300; letter-spacing: 0.15em; text-transform: uppercase;
      padding: 7px 13px; border-radius: 8px; border: none; cursor: pointer; color: #fff;
      background: linear-gradient(115deg, #14616E 0%, #1AA0B0 34%, #5B7CE0 68%, #14616E 100%);
      background-size: 280% 100%; animation: sc-aurora-flow 6s linear infinite;
      transition: opacity .15s; white-space: nowrap;
    }
    .sc-aurora-btn:disabled { opacity: .5; cursor: not-allowed; }
    @keyframes sc-aurora-flow { 0%{background-position:100% 50%} 100%{background-position:0% 50%} }

    /* ── Eve-Popup ──────────────────────────────────────────────────────────── */
    .sc-eve-overlay {
      position: fixed; inset: 0; background: rgba(10,10,10,.45); z-index: 9999;
      display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    .sc-eve-modal {
      background: var(--surface, #fff); border-radius: 20px; padding: 28px;
      width: 100%; max-width: 480px; box-shadow: 0 24px 60px rgba(10,10,10,.18);
    }
    .sc-eve-mhd { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
    .sc-eve-mhd-title { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 15px; color: var(--ink); }
    .sc-eve-close {
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      border: none; background: none; cursor: pointer; color: var(--ink-muted); border-radius: 6px;
    }
    .sc-eve-close svg { width: 15px; height: 15px; }
    .sc-eve-close:hover { background: var(--bg-deep); color: var(--ink); }
    .sc-eve-ta {
      width: 100%; border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px;
      font-family: 'Inter', sans-serif; font-size: 13px; color: var(--ink);
      resize: vertical; min-height: 72px; outline: none; background: var(--bg, #FAFAF8);
      transition: border-color .12s; box-sizing: border-box; margin-bottom: 10px;
    }
    .sc-eve-ta:focus { border-color: var(--petrol, #14616E); }
    .sc-eve-err { font-size: 11px; color: #991B1B; margin: 0 0 10px; }
    .sc-eve-mft { display: flex; gap: 8px; justify-content: flex-end; align-items: center; }
    .sc-eve-cancel { font-size: 11px; font-weight: 300; color: var(--ink-muted); background: none; border: none; cursor: pointer; padding: 6px 10px; }
    .sc-eve-cancel:hover { color: var(--ink); }
  </style>

</Layout>
