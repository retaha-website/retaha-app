---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
import { DEFAULT_LOYALTY_CONFIG } from '@retaha/loyalty';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const sb = createSupabaseServiceRoleInstance();
const [{ data: cfgRow }, { data: hsRow }] = await Promise.all([
  sb.from('loyalty_config').select('points_per_night, tiers, rewards').eq('hotel_id', hotel.id).maybeSingle(),
  sb.from('hotel_settings').select('features').eq('hotel_id', hotel.id).maybeSingle(),
]);

const hasExistingConfig = !!cfgRow;
const initConfig = {
  points_per_night: cfgRow?.points_per_night ?? DEFAULT_LOYALTY_CONFIG.points_per_night,
  tiers: cfgRow?.tiers ?? DEFAULT_LOYALTY_CONFIG.tiers,
  rewards: cfgRow?.rewards ?? DEFAULT_LOYALTY_CONFIG.rewards,
};
const loyaltyEnabled = ((hsRow?.features ?? {}) as Record<string, unknown>).loyalty === true;
const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';
---

<Layout title="Loyalty" activeTab="backoffice" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

<div class="settings-page" style="padding-top:0">

  <nav class="breadcrumb" style="padding-top:36px" aria-label="Breadcrumb">
    <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">Loyalty-Programm</span>
  </nav>

  <section class="settings-hero">
    <h1 class="settings-hero__title">Stammgäste belohnen<span class="dot-pink">.</span></h1>
    <p class="settings-hero__sub">Punkte pro Nacht, Status-Stufen und Prämien — pro Hotel konfigurierbar.</p>
  </section>

  {!loyaltyEnabled && (
    <div class="ly-banner">
      Für Gäste noch nicht sichtbar — aktiviere <strong>„Loyalty-Programm"</strong> in der
      <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener">Gäste-Vorschau</a>.
    </div>
  )}

  <!-- ══ Alpine wrapper ══════════════════════════════════════════════════════ -->
  <div x-data={`loyaltyPage(${JSON.stringify({ initConfig, hasExisting: hasExistingConfig })})`}>

    <!-- ── Eve start card ──────────────────────────────────────────────────── -->
    <div id="ly-eve-anchor" class="evecard" x-show="phase === 'init'" x-cloak>
      <div class="ec-head">
        <svg class="ec-spk" width="15" height="15" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
        <b>Lass <span class="ec-gradient">Eve</span> dein Programm bauen</b>
      </div>
      <p class="ec-desc">Erzähl in einem Satz von deinem Haus — Eve schlägt Punkte, Stufen und Prämien vor, die passen. Du passt nur noch an.</p>
      <div class="ec-row">
        <input
          type="text"
          class="ec-brief"
          x-model="brief"
          @keydown.enter="generate()"
          placeholder="z.B. 4-Sterne Stadthotel, ruhig, viele Wiederkehrer"
          maxlength="300"
        />
        <button class="ly-btn ly-aurora" :disabled="busyGen || !brief.trim()" @click="generate()">
          <svg class="ec-spk-anim" width="13" height="13" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
          Programm erstellen
        </button>
      </div>
    </div>

    <!-- ── Generating ──────────────────────────────────────────────────────── -->
    <div class="ec-gen" x-show="phase === 'generating'" x-cloak>
      <span class="ec-orb"></span>
      Eve baut dein Treueprogramm …
    </div>

    <!-- ── Program ─────────────────────────────────────────────────────────── -->
    <div x-show="phase === 'program'" x-cloak>

      <!-- Eve-Reset -->
      <div class="ly-eve-reset-row">
        <button class="ly-btn ly-aurora" @click="phase = 'init'; brief = ''; $nextTick(() => document.getElementById('ly-eve-anchor')?.scrollIntoView({behavior:'smooth',block:'start'}))">
          <svg class="ec-spk-anim" width="12" height="12" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
          Mit Eve neu bauen
        </button>
      </div>

      <!-- Punkte pro Nacht -->
      <div class="ly-sec">
        <div class="ly-sec-head">
          <div class="ly-sec-l"><span class="ly-dot"></span><b>Punkte pro Nacht</b></div>
        </div>
        <div class="ly-ppn">
          <div>
            <div class="ly-ppn-label">Punkte, die ein Gast pro Übernachtung erhält</div>
          </div>
          <input
            type="number" min="0" max="999" inputmode="numeric"
            class="ly-ppn-input"
            x-model.number="config.points_per_night"
          />
        </div>
      </div>

      <!-- Status-Stufen -->
      <div class="ly-sec">
        <div class="ly-sec-head">
          <div class="ly-sec-l"><span class="ly-dot"></span><b>Status-Stufen</b></div>
        </div>
        <p class="ly-hint">Die Stufe richtet sich nach den <strong>jemals verdienten</strong> Punkten — sie sinkt beim Einlösen nicht.</p>

        <template x-for="(tier, ti) in config.tiers" :key="ti">
          <div class="ly-tier" :class="tierOpen[ti] ? 'open' : ''">
            <div class="ly-tier-hd" @click="tierOpen[ti] = !tierOpen[ti]">
              <div class="ly-tier-l">
                <svg class="ly-chev" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"/></svg>
                <span class="ly-tname" x-text="tier.name || 'Neue Stufe'"></span>
              </div>
              <span class="ly-tmeta">
                ab <span x-text="tier.threshold_points"></span> Pkt
                · <span x-text="tier.benefits.length"></span> Vorteile
              </span>
            </div>
            <div class="ly-tier-body">
              <!-- Name + Schwelle -->
              <div class="ly-tier-fields">
                <label class="ly-field">
                  <span class="ly-field-label">Name</span>
                  <input type="text" class="ly-input" x-model="tier.name" placeholder="z.B. Gold" />
                </label>
                <label class="ly-field ly-field--num">
                  <span class="ly-field-label">Ab Punkten</span>
                  <input type="number" min="0" inputmode="numeric" class="ly-input" x-model.number="tier.threshold_points" />
                </label>
                <button type="button" class="ly-remove-tier" @click.stop="config.tiers.splice(ti,1); delete tierOpen[ti]; $nextTick(() => window.retahaToast?.('Stufe entfernt'))" title="Stufe entfernen">×</button>
              </div>
              <!-- Vorteile -->
              <div class="ly-benefits">
                <template x-for="(b, bi) in tier.benefits" :key="bi">
                  <div class="ly-brow">
                    <input type="text" class="ly-bf" x-model="b.title" placeholder="Vorteil" />
                    <input type="text" class="ly-bf ly-bf--desc" x-model="b.desc" placeholder="Beschreibung (optional)" />
                    <button type="button" class="ly-rm-sm" @click="tier.benefits.splice(bi,1)" aria-label="Entfernen">×</button>
                  </div>
                </template>
              </div>
              <button class="ly-addb" @click="tier.benefits.push({title:'',desc:''})">+ Vorteil</button>
            </div>
          </div>
        </template>

        <button class="ly-add-dashed" @click="addTier()">+ Stufe</button>
      </div>

      <!-- Prämien -->
      <div class="ly-sec">
        <div class="ly-sec-head">
          <div class="ly-sec-l"><span class="ly-dot"></span><b>Prämien (einlösbar)</b></div>
        </div>

        <template x-for="(rw, ri) in config.rewards" :key="ri">
          <div class="ly-rew">
            <div class="ly-rew-l">
              <span class="ly-chk" :class="rw.active ? 'ly-chk--on' : ''" @click="rw.active = !rw.active" title="Aktiv/Inaktiv">
                <svg x-show="rw.active" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 13 10 18 19 6"/></svg>
              </span>
              <div class="ly-rew-info">
                <input type="text" class="ly-rew-title" x-model="rw.title" placeholder="Prämienname" />
                <input type="text" class="ly-rew-desc" x-model="rw.desc" placeholder="Kurzbeschreibung" />
              </div>
            </div>
            <div class="ly-rew-r">
              <div class="ly-cost-wrap">
                <input type="number" min="0" inputmode="numeric" class="ly-cost-input" x-model.number="rw.cost_points" />
                <span class="ly-cost-unit">Pkt</span>
              </div>
              <button type="button" class="ly-rm-sm ly-rm-sm--rew" @click="config.rewards.splice(ri,1)" aria-label="Entfernen">×</button>
            </div>
          </div>
        </template>

        <button class="ly-add-dashed" @click="addReward()">+ Prämie</button>
      </div>

      <!-- Speichern -->
      <div class="ly-save-row">
        <button class="ly-savebtn" :disabled="saving" @click="save()" x-text="saving ? 'Speichert …' : 'Speichern'"></button>
      </div>

    </div><!-- /program -->

  </div><!-- /x-data -->
</div><!-- /settings-page -->

<script>
  document.addEventListener('alpine:init', () => {
    (window as any).Alpine.data('loyaltyPage', (opts: any) => ({
      phase: opts.hasExisting ? 'program' : 'init',
      brief: '',
      config: JSON.parse(JSON.stringify(opts.initConfig)),
      tierOpen: {} as Record<number, boolean>,
      busyGen: false,
      busyTiers: false,
      busyRewards: false,
      saving: false,

      addTier() {
        this.config.tiers.push({ key: 'tier_' + Date.now(), name: '', threshold_points: 0, benefits: [] });
        const i = this.config.tiers.length - 1;
        this.tierOpen[i] = true;
      },
      addReward() {
        this.config.rewards.push({ id: 'reward_' + Date.now(), title: '', desc: '', cost_points: 0, active: true });
      },

      async generate() {
        const brief = (this.brief || '').trim();
        if (!brief || this.busyGen) return;
        this.busyGen = true;
        this.phase = 'generating';

        // sparkle burst on button (best-effort)
        try {
          const res = await fetch('/api/loyalty/generate', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ brief }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok) {
            this.config = {
              points_per_night: data.points_per_night ?? this.config.points_per_night,
              tiers: data.tiers ?? this.config.tiers,
              rewards: data.rewards ?? this.config.rewards,
            };
            this.tierOpen = {};
            if (this.config.tiers.length > 0) this.tierOpen[1] = true;
          } else {
            (window as any).retahaToast?.('Eve konnte kein Programm erstellen — bitte manuell aufbauen.', 'error');
          }
        } catch {
          (window as any).retahaToast?.('Verbindungsfehler', 'error');
        } finally {
          this.busyGen = false;
          this.phase = 'program';
        }
      },

      async suggestTiers() {
        if (this.busyTiers) return;
        this.busyTiers = true;
        try {
          const res = await fetch('/api/loyalty/generate', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ brief: this.brief || 'Hotel', section: 'tiers' }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok && data.tiers) {
            this.config.tiers = data.tiers;
            this.tierOpen = { 1: true };
            (window as any).retahaToast?.('Stufen von Eve aktualisiert');
          } else {
            (window as any).retahaToast?.('Konnte keine Vorschläge generieren', 'error');
          }
        } catch {
          (window as any).retahaToast?.('Verbindungsfehler', 'error');
        } finally { this.busyTiers = false; }
      },

      async suggestRewards() {
        if (this.busyRewards) return;
        this.busyRewards = true;
        try {
          const res = await fetch('/api/loyalty/generate', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ brief: this.brief || 'Hotel', section: 'rewards' }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok && data.rewards) {
            this.config.rewards = data.rewards;
            (window as any).retahaToast?.('Prämien von Eve aktualisiert');
          } else {
            (window as any).retahaToast?.('Konnte keine Vorschläge generieren', 'error');
          }
        } catch {
          (window as any).retahaToast?.('Verbindungsfehler', 'error');
        } finally { this.busyRewards = false; }
      },

      async save() {
        if (this.saving) return;
        this.saving = true;
        try {
          const res = await fetch('/api/loyalty/config', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(this.config),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.ok) throw new Error(data.error || 'Fehler beim Speichern');
          (window as any).retahaToast?.('Gespeichert');
        } catch (e: any) {
          (window as any).retahaToast?.(e?.message || 'Fehler beim Speichern', 'error');
        } finally { this.saving = false; }
      },
    }));
  });
</script>

<style>
  /* ── Tokens ─────────────────────────────────────────────────────────────── */
  :root {
    --ly-ink:  #0A0A0A;
    --ly-ink2: #5C5852;
    --ly-ink3: #A6A199;
    --ly-line: #E7E3DB;
    --ly-line2:#F0ECE4;
    --ly-ac:   #14616E;
    --ly-aurora: linear-gradient(115deg,#14616E 0%,#1AA0B0 34%,#5B7CE0 68%,#14616E 100%);
  }

  @keyframes ly-flow { to { background-position: 0 0, 240% 0; } }
  @keyframes ly-breathe { 0%,100%{transform:scale(1)} 50%{transform:scale(1.25)} }
  @keyframes ly-twinkle { 0%,100%{transform:scale(1) rotate(0);opacity:1} 50%{transform:scale(1.3) rotate(90deg);opacity:.7} }
  @keyframes ly-rise { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

  /* ── Banner ─────────────────────────────────────────────────────────────── */
  .ly-banner {
    background: color-mix(in srgb, #14616E 6%, transparent);
    border: 1px solid color-mix(in srgb, #14616E 20%, transparent);
    border-radius: 12px; padding: 12px 16px; font-size: 13px; color: var(--ly-ink); line-height: 1.5;
    margin-bottom: 22px;
  }
  .ly-banner a { color: var(--ly-ac); text-decoration: underline; }

  /* ── Eve card ────────────────────────────────────────────────────────────── */
  .evecard {
    position: relative;
    border: 1.6px solid transparent;
    border-radius: 16px;
    padding: 20px 22px;
    margin-bottom: 22px;
    background: linear-gradient(#fff,#fff) padding-box, var(--ly-aurora) border-box;
    background-size: auto, 240% 100%;
    animation: ly-flow 7s linear infinite;
    box-shadow: 0 8px 30px rgba(45,91,208,.12);
  }
  .ec-head {
    display: flex; align-items: center; gap: 9px; margin-bottom: 6px;
    font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 16px;
  }
  .ec-spk { color: #2E72C8; flex-shrink: 0; }
  .ec-gradient {
    background: var(--ly-aurora); background-size: 240% 100%;
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    animation: ly-flow 5s linear infinite; font-weight: 700;
  }
  .ec-desc {
    font-size: 13px; color: var(--ly-ink2); line-height: 1.55; margin-bottom: 16px; max-width: 560px;
  }
  .ec-row { display: flex; gap: 10px; align-items: stretch; }
  .ec-brief {
    flex: 1; border: 1px solid var(--ly-line); border-radius: 9px;
    padding: 11px 13px; font-size: 13px; color: var(--ly-ink2); background: #FBFAF7;
    outline: none; transition: border-color 150ms;
  }
  .ec-brief:focus { border-color: var(--ly-ac); background: #fff; }
  .ec-brief::placeholder { color: var(--ly-ink3); }

  /* Aurora button */
  .ly-btn {
    border: 0; cursor: pointer;
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: .05em; text-transform: uppercase;
    padding: 8px 13px; border-radius: 9px; display: inline-flex; align-items: center; gap: 7px;
    white-space: nowrap; transition: transform .15s, box-shadow .2s;
  }
  .ly-aurora {
    color: #fff;
    background: var(--ly-aurora); background-size: 280% 100%;
    animation: ly-flow 6s linear infinite;
    box-shadow: 0 5px 16px rgba(20,97,110,.28);
  }
  .ly-aurora:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 9px 26px rgba(45,91,208,.38); animation-duration: 2.2s; }
  .ly-aurora:disabled { opacity: .55; cursor: not-allowed; transform: none; }
  .ly-eve-reset-row { display: flex; justify-content: flex-end; margin-bottom: 16px; }

  .ec-spk-anim { animation: ly-twinkle 2.4s ease-in-out infinite; }

  /* ── Generating ──────────────────────────────────────────────────────────── */
  .ec-gen {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    padding: 40px; color: var(--ly-ac);
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .05em; text-transform: uppercase;
  }
  .ec-orb {
    width: 16px; height: 16px; border-radius: 50%;
    background: radial-gradient(circle at 34% 30%,#7FECE8,#1AA0B0 42%,#3A63D6 86%);
    animation: ly-breathe 1s ease-in-out infinite; flex-shrink: 0;
  }

  /* ── Program sections ────────────────────────────────────────────────────── */
  [x-show="phase === 'program'"] { animation: ly-rise .45s ease; }

  .ly-sec {
    background: #fff; border: 1px solid var(--ly-line); border-radius: 14px;
    padding: 18px 20px; margin-bottom: 16px;
  }
  .ly-sec-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .ly-sec-l { display: flex; align-items: center; gap: 9px; }
  .ly-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ly-ac); flex-shrink: 0; }
  .ly-sec-l b { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 15px; color: var(--ly-ink); }
  .ly-hint { font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.5; color: var(--ly-ink3); margin: 0 0 14px; }

  /* Eve suggest button */
  .ly-evesug {
    border: 1.3px solid #5B7CE0; color: #2E72C8; background: #fff;
    font-family: 'JetBrains Mono', monospace; font-size: 8.5px; letter-spacing: .04em; text-transform: uppercase;
    padding: 7px 10px; border-radius: 8px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
    transition: background 150ms;
  }
  .ly-evesug::before {
    content: '✦'; font-size: 9px;
  }
  .ly-evesug:hover:not(:disabled) { background: #F3F6FE; }
  .ly-evesug:disabled { opacity: .5; cursor: not-allowed; }


  /* Points per night */
  .ly-ppn {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    border: 1px solid var(--ly-line); border-radius: 9px; padding: 13px 14px; background: #FBFAF7;
  }
  .ly-ppn-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: .06em; text-transform: uppercase; color: var(--ly-ink3); }
  .ly-ppn-input {
    width: 70px; text-align: right;
    font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 22px; color: var(--ly-ink);
    border: none; background: transparent; outline: none;
  }

  /* Tier cards */
  .ly-tier {
    border: 1px solid var(--ly-line); border-radius: 11px; background: #fff;
    margin-bottom: 9px; overflow: hidden;
  }
  .ly-tier-hd {
    display: flex; align-items: center; justify-content: space-between;
    padding: 13px 15px; cursor: pointer; user-select: none;
    transition: background 150ms;
  }
  .ly-tier-hd:hover { background: #FBFAF7; }
  .ly-tier-l { display: flex; align-items: center; gap: 11px; }
  .ly-chev { color: var(--ly-ink3); transition: transform .2s; flex-shrink: 0; }
  .ly-tier.open .ly-chev { transform: rotate(90deg); }
  .ly-tname { font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 14px; color: var(--ly-ink); }
  .ly-tmeta { font-family: 'JetBrains Mono', monospace; font-size: 8.5px; letter-spacing: .05em; text-transform: uppercase; color: var(--ly-ink3); }

  .ly-tier-body { display: none; padding: 4px 15px 15px; border-top: 1px solid var(--ly-line2); }
  .ly-tier.open .ly-tier-body { display: block; }

  .ly-tier-fields { display: flex; align-items: flex-end; gap: 10px; margin: 12px 0; }
  .ly-field { display: flex; flex-direction: column; gap: 5px; flex: 1; }
  .ly-field--num { flex: 0 0 120px; }
  .ly-field-label { font-family: 'JetBrains Mono', monospace; font-size: 8.5px; letter-spacing: .1em; text-transform: uppercase; color: var(--ly-ink3); }
  .ly-input {
    border: 1px solid var(--ly-line); border-radius: 8px; padding: 9px 11px;
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--ly-ink); background: #FBFAF7;
    outline: none; transition: border-color 150ms; width: 100%; box-sizing: border-box;
  }
  .ly-input:focus { border-color: var(--ly-ac); background: #fff; }
  .ly-remove-tier {
    flex-shrink: 0; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    background: none; border: 1px solid var(--ly-line); border-radius: 7px; cursor: pointer;
    color: var(--ly-ink3); font-size: 17px; margin-bottom: 1px; transition: all 150ms;
  }
  .ly-remove-tier:hover { border-color: #991B1B; color: #991B1B; }

  .ly-benefits { display: flex; flex-direction: column; gap: 7px; }
  .ly-brow { display: flex; align-items: center; gap: 8px; }
  .ly-bf {
    flex: 1; border: 1px solid var(--ly-line); border-radius: 8px;
