---
import Layout from '../layouts/Layout.astro';
import ModStatusLed from '../components/shared/ModStatusLed.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { buildPhotoUrl, type PickCategory } from '../lib/places/google-client';
import { addPickToHotel } from '../lib/places/pick-actions';
import { mergeAndTranslate, asLanguageCode } from '@retaha/i18n';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const GUEST_APP_URL = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';

const { data: hotelLangRow } = await client
  .from('hotels')
  .select('default_language, enabled_languages')
  .eq('id', hotel.id)
  .maybeSingle();
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';
const hotelEnabledLangs: string[] = Array.isArray(hotelLangRow?.enabled_languages)
  ? hotelLangRow.enabled_languages : ['de','en','fr','es'];
const LANGUAGE_LABELS: Record<string, string> = {
  de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands',
  ru: 'Русский', ar: 'العربية', zh: '中文',
};
const otherEnabled = hotelEnabledLangs.filter(l => l !== hotelDefaultLang);
const otherEnabledLabel = otherEnabled.map(l => LANGUAGE_LABELS[l] || l).join(', ');

// Modul-Status aus hotel_settings.features.recommendations
const { data: settingsRow } = await client
  .from('hotel_settings')
  .select('features')
  .eq('hotel_id', hotel.id)
  .maybeSingle();
const features = ((settingsRow?.features as Record<string, unknown>) ?? {});
const recommendationsOn = features.recommendations !== false;

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'pick_add') {
    const placeId = form.get('place_id')?.toString().trim() ?? '';
    const cat = form.get('category')?.toString() ?? '';
    if (!placeId || !['restaurant', 'cafe', 'bar', 'activity', 'sight'].includes(cat)) {
      message = { type: 'error', text: 'Place-ID und Kategorie sind Pflicht.' };
    } else {
      const result = await addPickToHotel(client, hotel.id, placeId, cat as PickCategory);
      if (result.ok) {
        return Astro.redirect(`/places?cat=${cat}&saved=pick_added`);
      }
      message = { type: 'error', text: result.error ?? 'Pick anlegen fehlgeschlagen.' };
    }
  }

  else if (action === 'pick_update') {
    const id = form.get('id')?.toString();
    const note = form.get('hotel_note_default')?.toString().trim() || null;
    if (!id) {
      message = { type: 'error', text: 'Keine ID übergeben.' };
    } else {
      const { data: existing } = await client
        .from('hotel_place_picks')
        .select('hotel_note_i18n')
        .eq('id', id).eq('hotel_id', hotel.id).maybeSingle();

      const hookResult = await mergeAndTranslate(
        existing?.hotel_note_i18n as any,
        note ?? '',
        asLanguageCode(hotelDefaultLang),
        { logLabel: `place_picks.${id}.hotel_note` },
      );

      const updates: Record<string, any> = {
        hotel_note_i18n: Object.keys(hookResult.i18n).length > 0 ? hookResult.i18n : null,
        updated_at: new Date().toISOString(),
      };
      if (hotelDefaultLang === 'de') updates.hotel_note = note;

      const { error } = await client.from('hotel_place_picks').update(updates)
        .eq('id', id).eq('hotel_id', hotel.id);
      if (error) {
        message = { type: 'error', text: `Update fehlgeschlagen: ${error.message}` };
      } else {
        const langCount = Object.keys(hookResult.i18n).length;
        message = {
          type: 'success',
          text: `Notiz gespeichert — ${langCount} Sprachen` +
                (hookResult.failures.length ? ` · ${hookResult.failures.length} Übersetzungs-Fehler` : ''),
        };
      }
    }
  }

  else if (action === 'pick_delete') {
    const id = form.get('id')?.toString();
    if (!id) {
      message = { type: 'error', text: 'Keine ID übergeben.' };
    } else {
      const { error } = await client.from('hotel_place_picks').delete().eq('id', id).eq('hotel_id', hotel.id);
      if (error) message = { type: 'error', text: `Löschen fehlgeschlagen: ${error.message}` };
      else message = { type: 'success', text: 'Pick entfernt.' };
    }
  }

  else if (action === 'pick_move') {
    const id = form.get('id')?.toString();
    const dir = form.get('direction')?.toString();
    if (id && (dir === 'up' || dir === 'down')) {
      const { data: current } = await client
        .from('hotel_place_picks')
        .select('sort_order')
        .eq('id', id).single();
      const newOrder = (current?.sort_order ?? 0) + (dir === 'up' ? -1 : 1);
      await client.from('hotel_place_picks').update({
        sort_order: newOrder,
        updated_at: new Date().toISOString(),
      }).eq('id', id).eq('hotel_id', hotel.id);
      message = { type: 'success', text: dir === 'up' ? 'Nach oben verschoben.' : 'Nach unten verschoben.' };
    }
  }
}

// Tab logic: UI tab 'explore' = DB categories sight + activity combined
// This mirrors the guest app's TAB_DB_CATS mapping in recommendations.astro
type BackofficeTabKey = 'restaurant' | 'cafe' | 'bar' | 'explore';
const TABS: Array<{ key: BackofficeTabKey; label: string }> = [
  { key: 'restaurant', label: 'Restaurants' },
  { key: 'cafe',       label: 'Cafés' },
  { key: 'bar',        label: 'Bars' },
  { key: 'explore',    label: 'Sehenswertes' }, // DB: sight + activity
];
const VALID_TABS: BackofficeTabKey[] = ['restaurant', 'cafe', 'bar', 'explore'];

const rawCat = Astro.url.searchParams.get('cat') ?? '';
// Normalize legacy/DB categories (sight, activity) to the 'explore' UI tab
const activeTab: BackofficeTabKey =
  rawCat === 'sight' || rawCat === 'activity' ? 'explore' :
  VALID_TABS.includes(rawCat as BackofficeTabKey) ? rawCat as BackofficeTabKey :
  'restaurant';

// DB category for new picks on the explore tab — store as 'sight' by default
const activeDbCategory: PickCategory = activeTab === 'explore' ? 'sight' : activeTab;

const { data: hotelRow } = await client
  .from('hotels')
  .select('latitude, longitude')
  .eq('id', hotel.id)
  .maybeSingle();
const hasAddress = typeof hotelRow?.latitude === 'number' && typeof hotelRow?.longitude === 'number';

const { data: allPicks } = await client
  .from('hotel_place_picks')
  .select('id, place_id, category, hotel_note, hotel_note_i18n, cached_data, photo_references, sort_order, last_refresh')
  .eq('hotel_id', hotel.id)
  .order('sort_order', { ascending: true })
  .order('created_at', { ascending: false });

// Group picks by UI tab key (sight + activity both map to 'explore')
const picksByTab: Record<string, any[]> = {};
for (const p of allPicks ?? []) {
  const tabKey: BackofficeTabKey =
    (p.category === 'sight' || p.category === 'activity') ? 'explore' : p.category as BackofficeTabKey;
  if (!picksByTab[tabKey]) picksByTab[tabKey] = [];
  picksByTab[tabKey].push(p);
}
const activePicks = picksByTab[activeTab] ?? [];

// Nearby cache: for 'explore' fetch both sight + activity rows and merge
let nearbyHasCache = false;
let nearbyPlaces: any[] = [];

if (activeTab === 'explore') {
  const { data: exploreCaches } = await client
    .from('hotel_place_nearby_cache')
    .select('cached_places')
    .eq('hotel_id', hotel.id)
    .in('category', ['sight', 'activity']);
  if (exploreCaches && exploreCaches.length > 0) {
    nearbyHasCache = true;
    nearbyPlaces = exploreCaches.flatMap(c => (c.cached_places as any[]) ?? []);
  }
} else {
  const { data: nc } = await client
    .from('hotel_place_nearby_cache')
    .select('cached_places')
    .eq('hotel_id', hotel.id)
    .eq('category', activeTab)
    .maybeSingle();
  if (nc) { nearbyHasCache = true; nearbyPlaces = (nc.cached_places as any[]) ?? []; }
}

const pickPlaceIds = new Set(activePicks.map((p: any) => p.place_id));
const autoSuggestions = nearbyPlaces
  .filter((p: any) => !pickPlaceIds.has(p.placeId ?? p.place_id))
  .slice(0, 10);

const savedParam = Astro.url.searchParams.get('saved');
if (savedParam === 'pick_added' && !message) {
  message = { type: 'success', text: 'Pick hinzugefügt — bitte Notiz pflegen.' };
}


---

<Layout title="Empfehlungen" activeTab="backoffice">
  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Empfehlungen</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">Gäste-Module · Empfehlungen</span>
      <h1 class="settings-hero__title">Deine Empfehlungen<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">Restaurants, Cafés, Bars und Sehenswertes. Eve zeigt deine Picks zuerst.</p>
    </section>

    {message && (
      <div class={`s-flash ${message.type === 'success' ? 's-flash--ok' : 's-flash--err'}`}>
        {message.text}
      </div>
    )}

    {!hasAddress && (
      <div class="s-warning-row">
        <strong>Hotel-Adresse fehlt.</strong>
        Bitte zuerst die Adresse in den <a href="/admin/settings" class="s-link">Allgemeinen Einstellungen</a> pflegen — sonst können keine Empfehlungen in der Nähe gefunden werden.
      </div>
    )}

    <div class="settings-sections">

      <!-- 01 Modul -->
      <section class="s-card">
        <div class="s-card__head">
          <h2 class="s-card__title">Empfehlungsmodul</h2>
          <span class="s-card__num">01</span>
        </div>
        <div class="s-card__body">
          <p class="field__hint">Ein/Aus wird in der Gäste-App-Vorschau gesteuert.</p>
          <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <ModStatusLed on={recommendationsOn} />
            <a href={`${GUEST_APP_URL}/gast-vorschau`} target="_blank" rel="noopener" class="s-btn-link">In der Gäste-App-Vorschau steuern →</a>
          </div>
        </div>
      </section>

      <!-- Kategorie-Tabs -->
      <nav class="places-tabs" aria-label="Kategorien">
        {TABS.map(tab => (
          <a
            href={`/places?cat=${tab.key}`}
            class:list={['places-tab', { 'is-active': activeTab === tab.key }]}
            aria-current={activeTab === tab.key ? 'page' : undefined}
          >
            {tab.label}
            {(picksByTab[tab.key]?.length ?? 0) > 0 && (
              <span class="places-tab__count">{picksByTab[tab.key].length}</span>
            )}
          </a>
        ))}
      </nav>

      <!-- 02 Suche & Hinzufügen -->
      <section class="s-card" id="add-pick">
        <div class="s-card__head">
          <h2 class="s-card__title">{TABS.find(t => t.key === activeTab)?.label} suchen</h2>
          <span class="s-card__num">02</span>
        </div>

        <div class="s-card__body" x-data={`placesAutocomplete('${activeDbCategory}', ${hasAddress ? 'true' : 'false'})`}>
          <div class="s-input-wrap" style="position:relative">
            <input
              type="text"
              x-model="query"
              x-on:input.debounce.300ms="search()"
              placeholder={hasAddress ? `${TABS.find(t => t.key === activeTab)?.label} suchen…` : 'Erst Adresse in Einstellungen hinterlegen…'}
              :disabled="!hasAddress || pending"
              class="s-input"
              autocomplete="off"
            />
            <span x-show="pending" x-cloak class="places-search-spinner">…</span>

            <div
              x-show="suggestions.length > 0"
              x-cloak
              class="places-dropdown"
            >
              <template x-for="s in suggestions" :key="s.placeId">
                <form method="POST" class="places-dropdown-item">
                  <input type="hidden" name="_action" value="pick_add" />
                  <input type="hidden" name="category" :value="category" />
                  <input type="hidden" name="place_id" :value="s.placeId" />
                  <button type="submit" class="places-dropdown-btn">
                    <span class="places-dropdown-main" x-text="s.mainText"></span>
                    <span class="places-dropdown-sub" x-text="s.secondaryText"></span>
                  </button>
                </form>
              </template>
            </div>
          </div>
          <p class="s-hint">Name eingeben (mind. 2 Zeichen). Eve empfiehlt deine Picks zuerst.</p>
        </div>
      </section>

      <!-- 03 Deine Picks -->
      <section class="s-card" id="picks-list">
        <div class="s-card__head">
          <h2 class="s-card__title">
            Deine Picks
            {activePicks.length > 0 && <span class="s-card__title-count">({activePicks.length})</span>}
          </h2>
          <span class="s-card__num">03</span>
        </div>

        <div class="s-card__body">
          {activePicks.length === 0 && (
            <p class="places-empty">Noch keine Picks in dieser Kategorie. Suche oben nach einem Ort.</p>
          )}
          {activePicks.length > 0 && (
            <p class="s-hint">Ziehen zum Sortieren — die oberste Empfehlung zeigt Eve dem Gast zuerst.</p>
          )}

          <div class="picks-list" x-data="picksSort()">
            {activePicks.map((pick: any, idx: number) => {
              const cd = (pick.cached_data ?? {}) as any;
              const photoUrl = pick.photo_references?.[0] ? buildPhotoUrl(pick.photo_references[0], 400) : null;
              const currentNote = pick.hotel_note_i18n?.[hotelDefaultLang]?.value ?? pick.hotel_note ?? '';
              const openNow: boolean | null = (cd.opening_hours != null && cd.opening_hours.openNow != null)
                ? Boolean(cd.opening_hours.openNow) : null;
              return (
                <div
                  class="pc"
                  data-pick-id={pick.id}
                  x-data={`pickCardRefresh('${pick.id}')`}
                  :class={`{'pc-drag-over': dragTarget === '${pick.id}', 'pc-dragging': dragItem === '${pick.id}'}`}
                >
                  <!-- VIEW -->
                  <div x-show="!editing">
                    <div
                      class="pc-photo"
                      role="img"
                      aria-label={cd.name ?? ''}
                      style={photoUrl ? `background-image:url(${photoUrl})` : undefined}
                    >
                      <span class="pc-rank" data-rank-badge>#{idx + 1}</span>
                      <span
                        class="pc-drag"
                        @click.stop
                        @pointerdown.stop={`dndPtrDown($event, '${pick.id}')`}
                        aria-label="Reihenfolge ändern"
                      >
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true">
                          <circle cx="9" cy="6" r="1.6"/><circle cx="15" cy="6" r="1.6"/>
                          <circle cx="9" cy="12" r="1.6"/><circle cx="15" cy="12" r="1.6"/>
                          <circle cx="9" cy="18" r="1.6"/><circle cx="15" cy="18" r="1.6"/>
                        </svg>
                      </span>
                      {cd.rating != null && (
                        <span class="pc-rating">
                          <span class="pc-star" aria-hidden="true">★</span>
                          {cd.rating} · {cd.user_ratings_total ?? 0}
                        </span>
                      )}
                      {openNow !== null && (
                        <span class={openNow ? 'pc-status pc-status--open' : 'pc-status pc-status--closed'}>
                          {openNow ? 'GEÖFFNET' : 'GESCHLOSSEN'}
                        </span>
                      )}
                    </div>

                    <div class="pc-body">
                      <div class="pc-name">{cd.name ?? '(Name fehlt)'}</div>
                      <div class="pc-addr">{cd.formatted_address ?? ''}</div>

                      {currentNote ? (
                        <div class="pc-note">
                          <span class="pc-note__label">Deine Notiz</span>
                          {currentNote}
                        </div>
                      ) : (
                        <div class="pc-note-empty" x-on:click="editing = true">+ Notiz hinzufügen</div>
                      )}

                      <div class="pc-foot">
                        <button type="button" class="pc-btn" x-on:click="editing = true" title="Notiz bearbeiten" aria-label="Notiz bearbeiten">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/>
                          </svg>
                        </button>
                        <button type="button" class="pc-btn" :disabled="refreshing" x-on:click="refresh()" :title="refreshing ? '…' : 'Daten aktualisieren'" aria-label="Google-Daten aktualisieren">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/>
                          </svg>
                        </button>
                        <form method="POST" class="pc-btn-form" x-on:submit.prevent="if(confirm('Pick wirklich entfernen?')) $el.submit()">
                          <input type="hidden" name="_action" value="pick_delete" />
                          <input type="hidden" name="id" value={pick.id} />
                          <button type="submit" class="pc-btn pc-btn--del" title="Entfernen" aria-label="Pick entfernen">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                              <path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/>
                            </svg>
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>

                  <!-- EDIT -->
                  <form x-show="editing" x-cloak method="POST" class="pc-edit">
                    <input type="hidden" name="_action" value="pick_update" />
                    <input type="hidden" name="id" value={pick.id} />
                    <div class="s-field">
                      <label class="s-label">
                        Hotel-Notiz ({LANGUAGE_LABELS[hotelDefaultLang] ?? hotelDefaultLang})
                      </label>
                      <textarea
                        name="hotel_note_default"
                        rows={3}
                        placeholder='z.B. „Unser Lieblings-Italiener für Geschäftsessen — bitte Risotto probieren!"'
                        class="s-textarea"
                      >{currentNote}</textarea>
                      {otherEnabled.length > 0 && (
                        <p class="s-hint">Wird automatisch in {otherEnabledLabel} übersetzt.</p>
                      )}
                    </div>
                    <div class="s-card__footer">
                      <button type="submit" class="v9-btn v9-btn--ink">Speichern</button>
                      <button type="button" x-on:click="editing = false" class="v9-btn v9-btn--ghost">Abbrechen</button>
                    </div>
                  </form>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- 04 Auto-Empfehlungen -->
      <section class="s-card" id="nearby" x-data={`placesRefresh('${activeTab}')`}>
        <div class="s-card__head">
          <h2 class="s-card__title">
            Mehr in der Nähe
            {autoSuggestions.length > 0 && <span class="s-card__title-count">({autoSuggestions.length})</span>}
          </h2>
          <span class="s-card__num">04</span>
        </div>

        <div class="s-card__body">
          <div class="places-nearby-head">
            <p class="s-hint">Automatische Vorschläge aus Google Places in deiner Umgebung.</p>
            <button
              type="button"
              class="places-refresh-icon-btn"
              :disabled="refreshing"
              x-on:click="refreshNearby()"
              title="Empfehlungen aktualisieren"
              aria-label="Empfehlungen aktualisieren"
            >
              <svg x-show="!refreshing" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M13 2.5A6 6 0 0 1 8 14 6 6 0 0 1 2 8a6 6 0 0 1 9.43-4.93"/>
                <polyline points="10 2 13 2 13 5"/>
              </svg>
              <span x-show="refreshing" x-cloak aria-hidden="true">…</span>
            </button>
          </div>

          <p
            x-show="refreshMessage"
            x-cloak
            class="s-flash"
            :class="refreshOk ? 's-flash--ok' : 's-flash--err'"
            x-text="refreshMessage"
          ></p>

          {!nearbyHasCache && (
            <p class="places-empty">
              Noch keine Auto-Empfehlungen. Klick auf "Aktualisieren" um Google Places abzufragen.
            </p>
          )}

          {autoSuggestions.length === 0 && nearbyHasCache && (
            <p class="places-empty">Alle Vorschläge sind bereits in deinen Picks.</p>
          )}

          <div class="nearby-list">
            {autoSuggestions.map((s: any) => (
              <div class="nearby-item">
                <div class="nearby-item__info">
                  <span class="nearby-item__name">
                    {s.name ?? '(kein Name)'}
                    {s.rating && <span class="nearby-item__rating"><span class="s-star" aria-hidden="true">★</span> {s.rating} ({s.userRatingCount ?? 0})</span>}
                  </span>
                  <span class="nearby-item__addr">{s.formattedAddress ?? s.address ?? ''}</span>
                </div>
                <form method="POST">
                  <input type="hidden" name="_action" value="pick_add" />
                  <input type="hidden" name="category" value={activeDbCategory} />
                  <input type="hidden" name="place_id" value={s.placeId ?? s.place_id} />
                  <button type="submit" class="v9-btn v9-btn--ghost v9-btn--sm">+ Zu Picks</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      </section>

    </div><!-- .settings-sections -->

  </div><!-- .settings-page -->
</Layout>

<script is:inline>
  // is:inline runs synchronously during HTML parsing, BEFORE the Layout's deferred module script
  // calls Alpine.start(). This ensures our alpine:init listener is registered before that event fires.
  document.addEventListener('alpine:init', function () {
    var A = window.Alpine;
    if (!A) return;

    A.data('placesAutocomplete', function (category, hasAddress) {
      return {
        category: category,
        hasAddress: hasAddress,
        query: '',
        suggestions: [],
        pending: false,

        search: async function () {
          var q = this.query.trim();
          if (q.length < 2) { this.suggestions = []; return; }
          this.pending = true;
          try {
            var res = await fetch('/api/admin/places/autocomplete?q=' + encodeURIComponent(q) + '&category=' + this.category);
            var body = await res.json();
            this.suggestions = body.ok ? (body.suggestions || []) : [];
          } catch (_) {
            this.suggestions = [];
          } finally {
            this.pending = false;
          }
        },
      };
    });

    A.data('placesRefresh', function (category) {
      return {
        category: category,
        refreshing: false,
        refreshMessage: '',
        refreshOk: true,

        refreshNearby: async function () {
          this.refreshing = true;
          this.refreshMessage = '';
          try {
            // 'explore' tab maps to DB categories sight + activity — refresh both
            var cats = this.category === 'explore' ? ['sight', 'activity'] : [this.category];
            var total = 0;
            for (var i = 0; i < cats.length; i++) {
              var cat = cats[i];
              var res = await fetch('/api/admin/places/refresh-nearby', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ category: cat }),
              });
              var body = await res.json();
              if (!body.ok) {
                this.refreshOk = false;
                this.refreshMessage = 'Fehler: ' + (body.error || 'unbekannt');
                return;
              }
              total += body.total_places_cached || 0;
            }
            this.refreshOk = true;
            this.refreshMessage = 'Aktualisiert — ' + total + ' Places gefunden. (Seite neu laden für Anzeige.)';
          } catch (err) {
            this.refreshOk = false;
            this.refreshMessage = 'Netzwerk-Fehler: ' + (err && err.message ? err.message : String(err));
          } finally {
            this.refreshing = false;
          }
        },
      };
    });

    A.data('pickCardRefresh', function (pickId) {
      return {
        pickId: pickId,
        editing: false,
        refreshing: false,

        refresh: async function () {
          this.refreshing = true;
          try {
            var res = await fetch('/api/admin/places/refresh-pick', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: this.pickId }),
            });
            var body = await res.json();
            if (!body.ok) console.warn('[pick refresh]', body.error);
          } catch (err) {
            console.warn('[pick refresh] network', err);
          } finally {
            this.refreshing = false;
          }
        },
      };
    });

    // Drag & Drop — exakt wie breakfast.astro (Pointer Events auf window, kein setPointerCapture wegen iOS)
    A.data('picksSort', function () {
      return {
        dragItem: null,
        dragTarget: null,
        _ptrItem: null,
        _ptrMoveHandler: null,
        _ptrUpHandler: null,

        dndPtrDown: function (e, pickId) {
          e.preventDefault();
          this._ptrItem = pickId;
          this.dragItem = pickId;
          var pid = e.pointerId;
          var self = this;

          self._ptrMoveHandler = function (ev) {
            if (ev.pointerId !== pid) return;
            ev.preventDefault();
            var el = document.elementFromPoint(ev.clientX, ev.clientY);
            var row = el && el.closest('[data-pick-id]');
            if (row) {
              var targetId = row.dataset.pickId;
              if (targetId && targetId !== self._ptrItem) {
                self.dragTarget = targetId;
              }
            }
          };
          self._ptrUpHandler = function (ev) {
            if (ev.pointerId !== pid) return;
            window.removeEventListener('pointermove', self._ptrMoveHandler);
            window.removeEventListener('pointerup', self._ptrUpHandler);
            window.removeEventListener('pointercancel', self._ptrUpHandler);
            if (self._ptrItem && self.dragTarget) {
              self._dndPerform(self.dragTarget);
            } else {
              self.dragItem = null;
              self.dragTarget = null;
            }
            self._ptrItem = null;
            self._ptrMoveHandler = null;
            self._ptrUpHandler = null;
          };
          window.addEventListener('pointermove', self._ptrMoveHandler, { passive: false });
          window.addEventListener('pointerup', self._ptrUpHandler);
          window.addEventListener('pointercancel', self._ptrUpHandler);
        },

        _dndPerform: async function (targetId) {
          var list = this.$el;
          var items = Array.from(list.querySelectorAll('[data-pick-id]'));
          var fromEl = items.find(function (el) { return el.dataset.pickId === this.dragItem; }, this);
          var toEl   = items.find(function (el) { return el.dataset.pickId === targetId; });

          if (!fromEl || !toEl || fromEl === toEl) {
            this.dragItem = null; this.dragTarget = null; return;
          }
          var fromIdx = items.indexOf(fromEl);
          var toIdx   = items.indexOf(toEl);

          if (fromIdx < toIdx) { toEl.after(fromEl); } else { toEl.before(fromEl); }

          var reordered = Array.from(list.querySelectorAll('[data-pick-id]'));
          var newOrder = reordered.map(function (el) { return el.dataset.pickId; });

          // Update visible rank badges (#1, #2 …)
          reordered.forEach(function (el, i) {
            var badge = el.querySelector('[data-rank-badge]');
            if (badge) badge.textContent = '#' + (i + 1);
          });

          this.dragItem = null;
          this.dragTarget = null;

          try {
            var res = await fetch('/api/admin/places/reorder', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ ids: newOrder }),
            });
            var body = await res.json();
            if (!body.ok) console.warn('[picks reorder]', body.error);
          } catch (err) {
            console.warn('[picks reorder] network', err);
          }
        },
      };
    });
  });
</script>

