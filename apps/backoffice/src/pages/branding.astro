---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getBranding } from '../lib/branding/get-branding';
import LogoSection    from '../components/branding/LogoSection.astro';
import ColorsSection  from '../components/branding/ColorsSection.astro';
import ThemeSection   from '../components/branding/ThemeSection.astro';
import AssetsSection  from '../components/branding/AssetsSection.astro';
import BrandMiniPreview from '../components/branding/BrandMiniPreview.astro';
import DemoQrCard from '../components/shared/DemoQrCard.astro';
import { getOrCreateShowcaseUrl } from '../lib/demo/get-showcase-url';
import { createPreviewToken } from '../lib/preview/preview-token';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

// ─── POST-HANDLER ──────────────────────────────────────────────────────────
type SaveResult = { section: string; ok: boolean; msg: string };
let saved: SaveResult | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString() ?? '';

  if (action === 'colors') {
    const brand_primary   = form.get('brand_primary')?.toString().trim()   || null;
    const brand_secondary = form.get('brand_secondary')?.toString().trim() || null;
    const { error } = await client.from('hotels')
      .update({ brand_primary, brand_secondary })
      .eq('id', hotel.id);
    saved = error
      ? { section: 'colors', ok: false, msg: error.message }
      : { section: 'colors', ok: true, msg: '✓ Farben gespeichert' };

  } else if (action === 'theme') {
    const brand_theme = form.get('brand_theme')?.toString();
    const validThemes = ['coffee','ocean','forest','custom'];
    if (!brand_theme || !validThemes.includes(brand_theme)) {
      saved = { section: 'theme', ok: false, msg: 'Ungültiges Theme.' };
    } else {
      const { error } = await client.from('hotels')
        .update({ brand_theme, theme: brand_theme })
        .eq('id', hotel.id);
      saved = error
        ? { section: 'theme', ok: false, msg: error.message }
        : { section: 'theme', ok: true, msg: '✓ Theme gespeichert' };
    }

  } else if (action === 'identity') {
    const design_identity = form.get('design_identity')?.toString();
    const validIdentities = ['classic', 'bauhaus', 'editorial'];
    if (!design_identity || !validIdentities.includes(design_identity)) {
      saved = { section: 'identity', ok: false, msg: 'Ungültige Design-Identität.' };
    } else {
      const { error } = await client.from('hotels')
        .update({ design_identity })
        .eq('id', hotel.id);
      saved = error
        ? { section: 'identity', ok: false, msg: error.message }
        : { section: 'identity', ok: true, msg: '✓ Design-Identität gespeichert' };
    }

  }
}

// ─── DATEN LADEN ───────────────────────────────────────────────────────────
const branding = await getBranding(Astro.cookies, Astro.request);
if (!branding) return Astro.redirect('/uebersicht');

const demoUrl = await getOrCreateShowcaseUrl(hotel.id, user.id);

const domain = import.meta.env.RETAHA_DOMAIN ?? 'retaha.de';
const hotelBase = hotel.slug ? `https://${hotel.slug}.${domain}` : `https://app.${domain}`;
const previewUrls: Record<string, string> = {};
for (const id of ['classic', 'bauhaus', 'editorial', 'maison']) {
  const t = createPreviewToken(hotel.id, id);
  previewUrls[id] = `${hotelBase}/g/preview?t=${t}`;
}
---

<Layout title="Branding" activeTab="backoffice" hotelName={hotel.name} hotelLogoUrl={hotel.logo_url}>

  <div class="branding-page">

    <!-- BREADCRUMB -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Branding</span>
    </nav>

    <!-- HERO -->
    <section class="branding-hero">
      <span class="branding-hero__eyebrow">Brand-Identity</span>
      <h1 class="branding-hero__title">Branding & Marken-Identität<span class="dot-pink">.</span></h1>
      <p class="branding-hero__sub">Logo, Farben und Theme deines Hotels — überall sichtbar.</p>
    </section>

    <!-- FLASH (Seiten-übergreifend) -->
    {saved && (
      <div class={`page-flash ${saved.ok ? 'page-flash--ok' : 'page-flash--err'}`}>
        {saved.msg}
      </div>
    )}

    <!-- LAYOUT: Sections + Sticky Mini-Preview -->
    <div class="branding-layout">

      <div class="branding-sections">
        <LogoSection branding={branding} />
        <ColorsSection branding={branding} />
        <ThemeSection branding={branding} demoUrl={demoUrl} previewUrls={previewUrls} />
        <AssetsSection branding={branding} />
      </div>

      <div class="branding-col-right">
        <div class="branding-sidebar">
          <BrandMiniPreview branding={branding} hotelName={hotel.name} />
          <DemoQrCard demoUrl={demoUrl} compact />
        </div>
      </div>

    </div>
  </div>

  <!-- Custom Confirm Modal -->
  <div id="bConfirmModal" role="dialog" aria-modal="true" hidden>
    <div class="bcm-backdrop" id="bConfirmBackdrop"></div>
    <div class="bcm-box">
      <p class="bcm-msg" id="bConfirmMsg">Wirklich entfernen?</p>
      <div class="bcm-actions">
        <button class="bcm-btn bcm-btn--cancel" id="bConfirmCancel" type="button">Abbrechen</button>
        <button class="bcm-btn bcm-btn--ok" id="bConfirmOk" type="button">Entfernen</button>
      </div>
    </div>
  </div>

</Layout>

<style>
  .branding-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }
  @media (max-width: 768px) { .branding-page { padding: 0 20px 64px; } }

  /* BREADCRUMB */
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-muted);
  }
  .breadcrumb__sep { color: var(--ink-faint); }
  .breadcrumb__crumb { color: var(--ink-muted); text-decoration: none; transition: color 150ms; }
  .breadcrumb__crumb:hover { color: var(--ink); }
  .breadcrumb__crumb--current { color: var(--ink); font-weight: 500; }

  /* HERO */
  .branding-hero {
    padding: 40px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
  }
  .branding-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
    color: #0A0A0A; background: var(--te-yellow);
    padding: 5px 10px; display: inline-block;
    margin-bottom: 20px; border-radius: var(--r-sm);
  }
  .branding-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 4.5vw, 48px); font-weight: 400;
    line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 10px; color: var(--ink);
  }
  .dot-pink { color: var(--pink); }
  .branding-hero__sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.04em;
  }

  /* FLASH */
  .page-flash {
    margin-bottom: 20px; padding: 12px 16px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; border-radius: var(--r-sm);
  }
  .page-flash--ok  { background: var(--sage-soft); color: var(--sage-strong); border: 1px solid var(--sage); }
  .page-flash--err { background: var(--burgund-soft); color: var(--burgund); border: 1px solid var(--burgund); }

  /* LAYOUT */
  .branding-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 32px;
    align-items: start;
  }
  .branding-sections { display: flex; flex-direction: column; gap: 32px; min-width: 0; }

  /* Wrapper füllt die volle rechte Grid-Spalte (gleich hoch wie linke Spalte) */
  .branding-col-right { min-height: 100%; }

  /* Sidebar selbst: sticky + scrollbar */
  .branding-sidebar {
    position: sticky; top: 100px;
    display: flex; flex-direction: column; gap: 16px;
    height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: thin;
    padding-right: 4px;
  }

  @media (max-width: 1024px) {
    .branding-layout { grid-template-columns: 1fr; }
    .branding-col-right { display: none; }
  }

  /* ── Custom Confirm Modal ── */
  #bConfirmModal { position: fixed; inset: 0; z-index: 9999; }
  #bConfirmModal[hidden] { display: none !important; }
  #bConfirmModal:not([hidden]) { display: flex; align-items: center; justify-content: center; }
  .bcm-backdrop {
    position: absolute; inset: 0;
    background: rgba(10,10,10,0.45);
    backdrop-filter: blur(6px);
  }
  .bcm-box {
    position: relative; z-index: 1;
    background: var(--surface);
    border: 1px solid var(--border-medium);
    border-radius: var(--r);
    padding: 28px 28px 22px;
    min-width: 300px; max-width: 400px; width: 90%;
    box-shadow: 0 24px 64px rgba(10,10,10,0.22);
  }
  .bcm-msg {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 17px; font-weight: 500;
    color: var(--ink); margin: 0 0 24px; line-height: 1.3;
  }
  .bcm-actions { display: flex; gap: 10px; justify-content: flex-end; }
  .bcm-btn {
    padding: 9px 20px; border-radius: var(--r-sm); cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 500; letter-spacing: 0.1em;
    transition: all 150ms ease; border: 1px solid transparent;
  }
  .bcm-btn--cancel {
    background: var(--surface); border-color: var(--border);
    color: var(--ink-soft);
  }
  .bcm-btn--cancel:hover { background: var(--bg-deep); color: var(--ink); }
  .bcm-btn--ok {
    background: var(--burgund); border-color: var(--burgund); color: #fff;
  }
  .bcm-btn--ok:hover { opacity: 0.82; }
</style>

<script>
  // ── Custom Confirm Modal ────────────────────────────────────────────────────
  const _bcModal   = document.getElementById('bConfirmModal')!;
  const _bcMsg     = document.getElementById('bConfirmMsg')!;
  const _bcOk      = document.getElementById('bConfirmOk')!;
  const _bcCancel  = document.getElementById('bConfirmCancel')!;
  const _bcBackdrop = document.getElementById('bConfirmBackdrop')!;

  (window as any).__brandConfirm = (message: string, onOk: () => void) => {
    _bcMsg.textContent = message;
    _bcModal.hidden = false;

    const close = () => { _bcModal.hidden = true; };
    const handleOk     = () => { close(); onOk(); };
    const handleCancel = () => close();

    _bcOk.addEventListener('click', handleOk, { once: true });
    _bcCancel.addEventListener('click', handleCancel, { once: true });
    _bcBackdrop.addEventListener('click', handleCancel, { once: true });
  };

  // ── Scroll routing ──────────────────────────────────────────────────────────
  const sections = document.querySelector<HTMLElement>('.branding-sections');
  const sidebar  = document.querySelector<HTMLElement>('.branding-sidebar');
  const phoneEl  = document.querySelector<HTMLElement>('.brand-preview__phone');

  // Document-Level: alles rechts von der linken Spalte → Sidebar scrollen
  // (deckt Grid-Spalte UND Seiten-Rand rechts vom max-width Container ab)
  document.addEventListener('wheel', (e) => {
    if (!sections || !sidebar) return;

    // Trennlinie = rechte Kante der linken Spalte
    const sectionsRight = sections.getBoundingClientRect().right;
    if (e.clientX <= sectionsRight) return; // linke Seite → normaler Page-Scroll

    // Direkt auf dem Phone → Phone selbst scrollen lassen
    if (phoneEl) {
      const r = phoneEl.getBoundingClientRect();
      if (e.clientX >= r.left && e.clientX <= r.right &&
          e.clientY >= r.top  && e.clientY <= r.bottom) {
        return;
      }
    }

    // Rechte Seite (inkl. Rand) → Sidebar scrollen
    const maxScroll = sidebar.scrollHeight - sidebar.clientHeight;
    if (maxScroll <= 0) return;
    e.preventDefault();
    sidebar.scrollTop = Math.max(0, Math.min(maxScroll, sidebar.scrollTop + e.deltaY));
  }, { capture: true, passive: false });
</script>
