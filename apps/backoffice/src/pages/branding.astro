---
import Layout from '../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getBranding } from '@retaha/auth';
import LogoSection    from '../components/branding/LogoSection.astro';
import ColorsSection  from '../components/branding/ColorsSection.astro';
import ThemeSection   from '../components/branding/ThemeSection.astro';
import AssetsSection  from '../components/branding/AssetsSection.astro';
import BrandMiniPreview from '../components/branding/BrandMiniPreview.astro';
import DemoQrCard from '@retaha/ui/components/shared/DemoQrCard.astro';
import { getOrCreateShowcaseUrl } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

type SaveResult = { section: string; ok: boolean; msg: string };
let saved: SaveResult | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString() ?? '';

  if (action === 'colors') {
    const currentPlan = ((hotel as any).plan as string | undefined) ?? 'lite';
    if (currentPlan === 'lite') {
      saved = { section: 'colors', ok: false, msg: 'Farbauswahl ist nur im Pro-Plan verfügbar.' };
    } else {
    const brand_primary = form.get('brand_primary')?.toString().trim() || null;
    const { error } = await client.from('hotels')
      .update({ brand_primary })
      .eq('id', hotel.id);
    saved = error
      ? { section: 'colors', ok: false, msg: error.message }
      : { section: 'colors', ok: true, msg: '✓ Farben gespeichert' };
    }

  } else if (action === 'theme') {
    const brand_theme = form.get('brand_theme')?.toString();
    const validThemes = ['coffee','ocean','forest','custom'];
    if (!brand_theme || !validThemes.includes(brand_theme)) {
      saved = { section: 'theme', ok: false, msg: bt('brand.msg.invalidtheme', lang) };
    } else {
      const { error } = await client.from('hotels')
        .update({ brand_theme, theme: brand_theme })
        .eq('id', hotel.id);
      saved = error
        ? { section: 'theme', ok: false, msg: error.message }
        : { section: 'theme', ok: true, msg: '✓ Theme gespeichert' };
    }

  } else if (action === 'identity') {
    const design_identity = form.get('design_identity')?.toString();
    const validIdentities = ['classic', 'bauhaus', 'editorial', 'maison'];
    if (!design_identity || !validIdentities.includes(design_identity)) {
      saved = { section: 'identity', ok: false, msg: bt('brand.msg.invalididentity', lang) };
    } else {
      const currentPlan = ((hotel as any).plan as string | undefined) ?? 'lite';
      if (currentPlan === 'lite' && design_identity !== 'bauhaus') {
        saved = { section: 'identity', ok: false, msg: 'Nur Bauhaus ist im Lite-Plan verfügbar.' };
      } else {
        const { error } = await client.from('hotels')
          .update({ design_identity })
          .eq('id', hotel.id);
        saved = error
          ? { section: 'identity', ok: false, msg: error.message }
          : { section: 'identity', ok: true, msg: '✓ Design-Identität gespeichert' };
      }
    }
  }
}

const branding = await getBranding(Astro.cookies, Astro.request);
if (!branding) {
  return Astro.redirect('/overview');
}

const demoUrl = await getOrCreateShowcaseUrl(hotel.id, user.id);
---

<Layout title="Branding" activeTab="backoffice">

  <div class="settings-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('tab.backoffice', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('nav.branding', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('brand.hero.title', lang)}></h1>
      <p class="settings-hero__sub">{bt('brand.hero.sub', lang)}</p>
    </section>

    {saved && (
      <script is:inline set:html={`(function(){var m=${JSON.stringify(saved.ok ? bt('common.savedshort', lang) : saved.msg)},t=${JSON.stringify(saved.ok ? 'success' : 'error')};function go(){window.retahaToast&&window.retahaToast(m,t)}if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',go);else go();})();`}></script>
    )}

    <div class="branding-layout">

      <div class="branding-sections">
        <LogoSection branding={branding} lang={lang} />
        <ColorsSection branding={branding} lang={lang} plan={((hotel as any).plan as string | undefined) ?? 'lite'} />
        <ThemeSection branding={branding} hotelName={hotel.name} lang={lang} plan={((hotel as any).plan as string | undefined) ?? 'lite'} />
        <AssetsSection branding={branding} lang={lang} plan={((hotel as any).plan as string | undefined) ?? 'lite'} />
      </div>

      <div class="branding-col-right">
        <div class="branding-sidebar">
          <BrandMiniPreview branding={branding} hotelName={hotel.name} lang={lang} />
          <DemoQrCard demoUrl={demoUrl} compact />
        </div>
      </div>

    </div>

    <script type="application/json" id="brand-i18n" is:inline set:html={JSON.stringify({
      uploadfail: bt('brand.js.uploadfail', lang),
      removefail: bt('brand.js.removefail', lang),
      logoSaved: bt('brand.js.logo.saved', lang),
      logoConfirm: bt('brand.js.logo.confirm', lang),
      logoRemoved: bt('brand.js.logo.removed', lang),
      assetSavedStatus: bt('brand.js.asset.savedstatus', lang),
      assetSaved: bt('brand.js.asset.saved', lang),
      assetConfirm: bt('brand.js.asset.confirm', lang),
      assetRemovedStatus: bt('brand.js.asset.removedstatus', lang),
      assetRemoved: bt('brand.js.asset.removed', lang),
      openGuest: bt('brand.preview.openguest', lang),
    })}></script>
  </div>

  <div id="bConfirmModal" role="dialog" aria-modal="true" hidden>
    <div class="bcm-backdrop" id="bConfirmBackdrop"></div>
    <div class="bcm-box">
      <p class="bcm-msg" id="bConfirmMsg"></p>
      <div class="bcm-actions">
        <button class="bcm-btn bcm-btn--cancel" id="bConfirmCancel" type="button">{bt('common.cancel', lang)}</button>
        <button class="bcm-btn bcm-btn--ok" id="bConfirmOk" type="button">{bt('common.remove', lang)}</button>
      </div>
    </div>
  </div>

</Layout>

<style>
  .breadcrumb { padding-top: 36px; }

  .branding-layout {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 48px;
    align-items: start;
  }
  .branding-sections { display: flex; flex-direction: column; gap: 20px; min-width: 0; }

  .branding-col-right { min-height: 100%; }
  .branding-sidebar {
    position: sticky; top: 100px;
    display: flex; flex-direction: column; gap: 16px;
    height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: thin;
    padding-right: 4px;
  }

  @media (max-width: 1024px) {
    .branding-layout { grid-template-columns: 1fr; }
    .branding-col-right { display: none; }
  }

  #bConfirmModal { position: fixed; inset: 0; z-index: 9999; }
  #bConfirmModal[hidden] { display: none !important; }
  #bConfirmModal:not([hidden]) { display: flex; align-items: center; justify-content: center; }
  .bcm-backdrop {
    position: absolute; inset: 0;
    background: rgba(10,10,10,0.45);
    backdrop-filter: blur(6px);
  }
  .bcm-box {
    position: relative; z-index: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 28px 24px;
    min-width: 300px; max-width: 400px; width: 90%;
    box-shadow: 0 24px 64px rgba(10,10,10,0.18);
  }
  .bcm-msg {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px; font-weight: 500;
    color: var(--ink); margin: 0 0 24px; line-height: 1.35;
  }
  .bcm-actions { display: flex; gap: 8px; justify-content: flex-end; }
  .bcm-btn {
    padding: 7px 18px; cursor: pointer; border-radius: 9px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px; font-weight: 300;
    transition: all 150ms ease; border: 1px solid transparent;
  }
  .bcm-btn--cancel {
    background: transparent; border-color: var(--border-medium, rgba(10,10,10,.16));
    color: var(--ink-muted);
  }
  .bcm-btn--cancel:hover { background: var(--bg-deep, #F5F4F2); color: var(--ink); }
  .bcm-btn--ok {
    background: var(--petrol, #14616E); border-color: var(--petrol, #14616E); color: #fff;
  }
  .bcm-btn--ok:hover { background: #0f4f59; border-color: #0f4f59; }
</style>

<script>
  const _bcModal   = document.getElementById('bConfirmModal')!;
  const _bcMsg     = document.getElementById('bConfirmMsg')!;
  const _bcOk      = document.getElementById('bConfirmOk')!;
  const _bcCancel  = document.getElementById('bConfirmCancel')!;
  const _bcBackdrop = document.getElementById('bConfirmBackdrop')!;

  (window as any).__brandConfirm = (message: string, onOk: () => void) => {
    _bcMsg.textContent = message;
    _bcModal.hidden = false;

    const close = () => { _bcModal.hidden = true; };
    const handleOk     = () => { close(); onOk(); };
    const handleCancel = () => close();

    _bcOk.addEventListener('click', handleOk, { once: true });
    _bcCancel.addEventListener('click', handleCancel, { once: true });
    _bcBackdrop.addEventListener('click', handleCancel, { once: true });
  };

  const sections = document.querySelector<HTMLElement>('.branding-sections');
  const sidebar  = document.querySelector<HTMLElement>('.branding-sidebar');

  document.addEventListener('wheel', (e) => {
    if (!sections || !sidebar) return;
    if (!sidebar.contains(e.target as Node)) return;
    const maxScroll = sidebar.scrollHeight - sidebar.clientHeight;
    if (maxScroll <= 0) return;
    e.preventDefault();
    sidebar.scrollTop = Math.max(0, Math.min(maxScroll, sidebar.scrollTop + e.deltaY));
  }, { capture: true, passive: false });
</script>
