---
import Layout from '../layouts/Layout.astro';
import {
  getUser,
  getUserHotels,
  createSupabaseServiceRoleInstance,
} from '@retaha/auth';
import { signPairToken } from '@retaha/auth';
import { getEnv } from '@retaha/db';
import QRCode from 'qrcode';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);
const dateLocale = lang === 'de' ? 'de-DE' : lang;

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const supabase = createSupabaseServiceRoleInstance();

// Heutige Anreisen — Brief: state=Confirmed + check_in_date = heute.
// Pragmatic-Erweiterung: nächste 7 Tage falls heute nichts ist (besseres
// Demo-Erlebnis). Über/in-house Anreisen werden hervorgehoben.
const todayUtc = new Date();
todayUtc.setUTCHours(0, 0, 0, 0);
const horizonDays = 30;
const sevenDaysOut = new Date(todayUtc.getTime() + horizonDays * 86_400_000);

const { data: stays } = await supabase
  .from('stays')
  .select(`
    id, check_in, check_out, state, room_id, wallet_pass_id,
    rooms(room_number, room_name, room_code),
    guests(first_name, last_name),
    wallet_passes:wallet_pass_id(visit_count),
    stay_requests(id, chips, allergies, occasion, note, status)
  `)
  .eq('hotel_id', hotel.id)
  .eq('is_active', true)
  .in('state', ['Confirmed', 'Started'])
  .gte('check_in', todayUtc.toISOString())
  .lt('check_in', sevenDaysOut.toISOString())
  .order('check_in', { ascending: true })
  .limit(50);

const baseUrl = getEnv('PUBLIC_SITE_URL') ?? `http://localhost:4321`;

interface StayRequest {
  id: string;
  chips: string[];
  allergies: string | null;
  occasion: string | null;
  note: string | null;
  status: 'open' | 'seen' | 'done';
}

interface PreparedStay {
  id: string;
  guestName: string;
  roomLabel: string;
  roomCode: string | null;
  checkInLabel: string;
  isToday: boolean;
  pairUrl: string | null;
  qrDataUrl: string | null;
  /** Sprint Wallet Modul E: visit_count des verknüpften Wallet-Passes (1 = Erstbesuch). */
  visitCount: number;
  request: StayRequest | null;
}

const prepared: PreparedStay[] = [];
for (const s of stays ?? []) {
  const g = s.guests as any;
  const r = s.rooms as any;
  const checkIn = s.check_in ? new Date(s.check_in) : null;
  const today = new Date();
  const isToday = !!checkIn && checkIn.toDateString() === today.toDateString();

  // Pair-Token + QR
  const pairToken = await signPairToken({ stay_id: s.id, hotel_id: hotel.id });
  let pairUrl: string | null = null;
  let qrDataUrl: string | null = null;
  if (pairToken) {
    pairUrl = `${baseUrl.replace(/\/$/, '')}/api/pair?token=${encodeURIComponent(pairToken)}`;
    qrDataUrl = await QRCode.toDataURL(pairUrl, {
      errorCorrectionLevel: 'M',
      margin: 2,
      width: 280,
      color: { dark: 'var(--theme-text-primary)', light: 'var(--theme-bg-primary)' },
    });
  }

  const wp = (s as any).wallet_passes;
  const wpRow = Array.isArray(wp) ? wp[0] : wp;
  const visitCount = wpRow?.visit_count ?? 0;

  const rawReq = (s as any).stay_requests;
  const reqRow = Array.isArray(rawReq) ? rawReq[0] : rawReq;
  const request: StayRequest | null = reqRow ? {
    id: reqRow.id,
    chips: reqRow.chips ?? [],
    allergies: reqRow.allergies ?? null,
    occasion: reqRow.occasion ?? null,
    note: reqRow.note ?? null,
    status: reqRow.status ?? 'open',
  } : null;

  prepared.push({
    id: s.id,
    guestName: [g?.first_name, g?.last_name].filter(Boolean).join(' ').trim() || bt('ci.guest.default', lang),
    roomLabel: r?.room_number ? `${r.room_number}${r.room_name ? ` (${r.room_name})` : ''}` : r?.room_name ?? '—',
    roomCode: r?.room_code ?? null,
    checkInLabel: checkIn
      ? checkIn.toLocaleDateString(dateLocale, { weekday: 'short', day: '2-digit', month: '2-digit' })
      : '?',
    isToday,
    pairUrl,
    qrDataUrl,
    visitCount,
    request,
  });
}

const todayCount = prepared.filter(p => p.isToday).length;
const tokenAvailable = prepared.some(p => p.qrDataUrl !== null);
---

<Layout title="Check-ins" activeTab="backoffice" hotelName={hotel.name}>

<style is:global>
[x-cloak] { display: none !important; }

.ci-stay-card {
  border: 1px solid var(--border);
  border-radius: var(--r, 8px);
  padding: 16px 20px;
  background: var(--surface);
  transition: border-color .12s, box-shadow .12s;
}
.ci-stay-card--today {
  border-color: var(--accent, #C06A3C);
}
.ci-stay-card:hover {
  box-shadow: 0 2px 8px rgba(10,10,10,.05);
}

.ci-stay__meta { font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 4px; }
.ci-stay__name { font-size: 16px; font-weight: 500; color: var(--ink); font-family: 'Space Grotesk', sans-serif; }
.ci-stay__room { font-size: 13px; color: var(--ink-muted); margin-top: 2px; }

.ci-badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.05em;
  padding: 2px 8px; border-radius: 3px;
  margin-left: 8px; vertical-align: middle;
}
.ci-badge--vip { background: var(--burgund, #8C2128); color: #fff; }
.ci-badge--returning { background: var(--accent, #C06A3C); color: #fff; }

.ci-qr-panel {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.ci-qr-panel__inner {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
@media (min-width: 640px) {
  .ci-qr-panel__inner { flex-direction: row; align-items: flex-start; }
}
.ci-qr-img {
  background: #fff;
  padding: 12px;
  border: 1px solid var(--border);
  border-radius: var(--r-sm, 4px);
  flex-shrink: 0;
}
.ci-qr-steps { flex: 1; min-width: 0; }
.ci-qr-steps ol {
  font-size: 13px; color: var(--ink-muted); line-height: 1.7;
  padding-left: 18px; margin: 8px 0 0;
}
.ci-qr-note {
  font-size: 11px; font-style: italic; color: var(--ink-muted); margin-top: 10px;
}

.ci-wishes {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.ci-wishes__head {
  font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--ink-muted); margin-bottom: 10px;
}
.ci-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
.ci-chip {
  font-size: 11px; padding: 3px 9px;
  border: 1px solid var(--border); border-radius: 3px;
  color: var(--ink-muted); background: var(--surface);
}
.ci-allergy {
  padding: 8px 12px; margin-bottom: 8px;
  border-left: 3px solid #8C2128;
  background: rgba(140,33,40,0.06);
  font-size: 13px; color: var(--ink); border-radius: 0 var(--r-sm,4px) var(--r-sm,4px) 0;
}
.ci-note { font-size: 13px; color: var(--ink-muted); font-style: italic; margin-top: 4px; }
.ci-occasion { font-size: 13px; color: var(--ink-muted); margin-bottom: 4px; }
.ci-occasion strong { color: var(--ink); font-weight: 500; }

.ci-wishes__actions { display: flex; gap: 6px; flex-shrink: 0; }

.ci-stay-list { display: flex; flex-direction: column; gap: 10px; }

.ci-today-badge {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--accent, #C06A3C);
  margin-bottom: 16px;
}

.ci-empty {
  padding: 48px 32px;
  text-align: center;
  border: 1px solid var(--border);
  border-radius: var(--r, 8px);
  background: var(--surface);
}
.ci-empty__title { font-size: 13px; color: var(--ink-muted); font-style: italic; margin-bottom: 8px; }
.ci-empty__sub { font-size: 13px; color: var(--ink-muted); max-width: 420px; margin: 0 auto; }

.ci-arch-note {
  font-size: 11px; font-style: italic; color: var(--ink-muted);
  margin-top: 4px; line-height: 1.6; max-width: 680px;
}
</style>

<div class="settings-page">

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('ci.crumb', lang)}</span>
  </nav>

  <section class="settings-hero">
    <span class="settings-hero__eyebrow">{bt('ci.hero.eyebrow', lang)}</span>
    <h1 class="settings-hero__title" set:html={bt('ci.hero.title', lang)}></h1>
    <p class="settings-hero__sub">{bt('ci.hero.sub', lang)}</p>
  </section>

  <div class="settings-sections">

    <!-- 01 Anreisen -->
    <section class="s-card">
      <div class="s-card__head">
        <h2 class="s-card__title">{bt('ci.card.title', lang)}</h2>
        <span class="s-card__num">01</span>
      </div>
      <div class="s-card__body">

        {!tokenAvailable && prepared.length > 0 && (
          <div class="s-flash s-flash--err" style="margin-bottom: 16px;" set:html={bt('ci.nosecret', lang)}></div>
        )}

        {prepared.length === 0 ? (
          <div class="ci-empty">
            <p class="ci-empty__title">{bt('ci.empty.title', lang)}</p>
            <p class="ci-empty__sub">{bt('ci.empty.sub', lang)}</p>
          </div>
        ) : (
          <div>
            {todayCount > 0 && (
              <p class="ci-today-badge">{(todayCount === 1 ? bt('ci.today.one', lang) : bt('ci.today.many', lang)).replace('{n}', String(todayCount))}</p>
            )}

            <div class="ci-stay-list">
              {prepared.map(p => (
                <div
                  x-data={`{ open: false }`}
                  class={`ci-stay-card${p.isToday ? ' ci-stay-card--today' : ''}`}
                >
                  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
                    <div style="min-width:0;flex:1;">
                      <p class="ci-stay__meta">
                        {p.checkInLabel}{p.isToday ? ` · ${bt('ci.today.word', lang)}` : ''}
                      </p>
                      <p class="ci-stay__name">
                        {p.guestName}
                        {p.visitCount >= 5 && (
                          <span class="ci-badge ci-badge--vip">&#9733; {bt('ci.badge.regular', lang).replace('{n}', String(p.visitCount))}</span>
                        )}
                        {p.visitCount >= 2 && p.visitCount < 5 && (
                          <span class="ci-badge ci-badge--returning">&#9733; {bt('ci.badge.visit', lang).replace('{n}', String(p.visitCount))}</span>
                        )}
                      </p>
                      <p class="ci-stay__room">
                        {bt('ci.room', lang)} {p.roomLabel}
                        {p.roomCode && (
                          <> &middot; <span style="font-family:'JetBrains Mono',monospace;font-size:11px;">{p.roomCode}</span></>
                        )}
                      </p>
                    </div>

                    {p.qrDataUrl && (
                      <button
                        type="button"
                        @click="open = !open"
                        class="v9-btn v9-btn--primary v9-btn--sm"
                      >
                        <span x-show="!open">{bt('ci.qr.open', lang)}</span>
                        <span x-show="open" x-cloak>{bt('ci.qr.close', lang)}</span>
                      </button>
                    )}
                  </div>

                  {p.qrDataUrl && (
                    <div x-show="open" x-cloak x-transition class="ci-qr-panel">
                      <div class="ci-qr-panel__inner">
                        <div class="ci-qr-img">
                          <img src={p.qrDataUrl} alt={bt('ci.qr.alt', lang).replace('{name}', p.guestName)} width="280" height="280" />
                        </div>
                        <div class="ci-qr-steps">
                          <p class="ci-stay__meta">{bt('ci.qr.guide', lang)}</p>
                          <ol>
                            <li>{bt('ci.qr.step1', lang)}</li>
                            <li>{bt('ci.qr.step2', lang)}</li>
                            <li>{bt('ci.qr.step3', lang)}</li>
                          </ol>
                          <p class="ci-qr-note">{bt('ci.qr.note', lang)}</p>
                        </div>
                      </div>
                    </div>
                  )}

                  {p.request && (
                    <div
                      x-data={`{ status: '${p.request.status}', saving: false, async setStatus(s) { if (this.saving) return; this.saving = true; await fetch('/api/requests/update-status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: '${p.request.id}', status: s }) }); this.status = s; this.saving = false; } }`}
                      class="ci-wishes"
                    >
                      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
                        <div style="flex:1;min-width:0;">
                          <p class="ci-wishes__head">{bt('ci.wishes.head', lang)}</p>

                          {p.request.chips.filter(c => c !== 'allergies' && c !== 'occasion').length > 0 && (
                            <div class="ci-chips">
                              {p.request.chips.filter(c => c !== 'allergies' && c !== 'occasion').map(slug => (
                                <span class="ci-chip">{bt('ci.chip.' + slug, lang)}</span>
                              ))}
                            </div>
                          )}

                          {p.request.allergies && (
                            <div class="ci-allergy">
                              <strong>{bt('ci.wishes.allergy', lang)}</strong> {p.request.allergies}
                            </div>
                          )}

                          {p.request.occasion && (
                            <p class="ci-occasion">{bt('ci.wishes.occasion', lang)} <strong>{p.request.occasion}</strong></p>
                          )}

                          {p.request.note && (
                            <p class="ci-note">„{p.request.note}"</p>
                          )}
                        </div>

                        <div class="ci-wishes__actions">
                          <button
                            type="button"
                            @click="setStatus('open')"
                            :class="status === 'open' ? 'v9-btn v9-btn--primary v9-btn--sm' : 'v9-btn v9-btn--ghost v9-btn--sm'"
                            :disabled="saving"
                          >{bt('ci.status.open', lang)}</button>
                          <button
                            type="button"
                            @click="setStatus('seen')"
                            :class="status === 'seen' ? 'v9-btn v9-btn--primary v9-btn--sm' : 'v9-btn v9-btn--ghost v9-btn--sm'"
                            :disabled="saving"
                          >{bt('ci.status.seen', lang)}</button>
                          <button
                            type="button"
                            @click="setStatus('done')"
                            :class="status === 'done' ? 'v9-btn v9-btn--primary v9-btn--sm' : 'v9-btn v9-btn--ghost v9-btn--sm'"
                            :disabled="saving"
                          >{bt('ci.status.done', lang)}</button>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

      </div>
      <div class="s-card__footer">
        <p class="ci-arch-note">{bt('ci.archnote', lang)}</p>
      </div>
    </section>

  </div>
</div>

</Layout>
