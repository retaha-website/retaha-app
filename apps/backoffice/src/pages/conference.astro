---
import Layout from '../layouts/Layout.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServiceRoleInstance();

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();

  if (action === 'save_times') {
    const updates = {
      conference_start_time: form.get('conference_start_time')?.toString() || '08:00',
      conference_end_time: form.get('conference_end_time')?.toString() || '20:00',
      conference_slot_minutes: parseInt(form.get('conference_slot_minutes')?.toString() || '60') || 60,
      updated_at: new Date().toISOString(),
    };

    const { error } = await client
      .from('hotel_settings')
      .upsert({ hotel_id: hotel.id, ...updates }, { onConflict: 'hotel_id' });

    if (error) {
      message = { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` };
    } else {
      message = { type: 'success', text: bt('conf.msg.timessaved', lang) };
    }
  } else if (action === 'save_rooms') {
    const roomsJson = form.get('rooms_json')?.toString();
    if (roomsJson) {
      try {
        const rooms = JSON.parse(roomsJson);
        if (!Array.isArray(rooms)) throw new Error('Salons müssen Array sein');

        const { error } = await client
          .from('hotel_settings')
          .upsert({ hotel_id: hotel.id, conference_rooms: rooms, updated_at: new Date().toISOString() }, { onConflict: 'hotel_id' });

        if (error) {
          message = { type: 'error', text: `${bt('prof.msg.savefail', lang)}: ${error.message}` };
        } else {
          message = { type: 'success', text: bt('conf.msg.roomssaved', lang) };
        }
      } catch (e: any) {
        message = { type: 'error', text: `${bt('conf.msg.invaliddata', lang)}: ${e.message || 'unbekannt'}` };
      }
    }
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select('conference_rooms, conference_start_time, conference_end_time, conference_slot_minutes')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const rooms = ((settings?.conference_rooms as any[]) || []);
const startTime = ((settings as any)?.conference_start_time || '08:00').substring(0, 5);
const endTime = ((settings as any)?.conference_end_time || '20:00').substring(0, 5);
const slotMin = (settings as any)?.conference_slot_minutes || 60;

// Client-Strings für das is:inline-Script (define:vars)
const tJs = {
  salon: bt('conf.js.salon', lang),
  remove: bt('common.remove', lang),
  slug: bt('conf.js.slug', lang),
  capacity: bt('conf.js.capacity', lang),
  nameDe: bt('conf.js.namede', lang),
  nameEn: bt('conf.js.nameen', lang),
  descDe: bt('conf.js.descde', lang),
  descEn: bt('conf.js.descen', lang),
  confirm: bt('conf.js.confirm', lang),
  newRoom: bt('conf.js.newroom', lang),
};
---

<Layout title="Konferenz" activeTab="backoffice">
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber="05"
      sectionLabel={bt('nav.conference', lang)}
      headlineLight={bt('conf.hl.light', lang)}
      headlineBold={bt('conf.hl.bold', lang)}
      subtitle={bt('conf.subtitle', lang)}
    />
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <section class="bg-white border border-anthrazit/[0.12] p-6 mb-6">
    <h2 class="text-xl font-medium mb-4">{bt('conf.times.title', lang)}</h2>
    <form method="POST">
      <input type="hidden" name="_action" value="save_times" />
      <div class="grid grid-cols-3 gap-4">
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">{bt('conf.times.start', lang)}</span>
          <input type="time" name="conference_start_time" value={startTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit" />
        </label>
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">{bt('conf.times.end', lang)}</span>
          <input type="time" name="conference_end_time" value={endTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit" />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">{bt('conf.times.slot', lang)}</span>
          <input type="number" name="conference_slot_minutes" value={slotMin} min="15" max="240" step="15"
            class="bauhaus-input" />
        </label>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" class="bauhaus-button bauhaus-button--primary">
          {bt('conf.times.save', lang)}
        </button>
      </div>
    </form>
  </section>

  <section class="bg-white border border-anthrazit/[0.12] p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-medium">{bt('conf.rooms.title', lang)}</h2>
      <button type="button" id="add-room-btn" class="bauhaus-button bauhaus-button--secondary">
        {bt('conf.rooms.add', lang)}
      </button>
    </div>

    <form method="POST" id="rooms-form">
      <input type="hidden" name="_action" value="save_rooms" />
      <input type="hidden" name="rooms_json" id="rooms-json-input" />
      <div id="rooms-container" class="space-y-4 mb-6"></div>
      <div class="flex justify-end pt-4 border-t border-anthrazit/[0.12]">
        <button type="submit" class="bauhaus-button bauhaus-button--primary">
          {bt('conf.rooms.save', lang)}
        </button>
      </div>
    </form>
  </section>

  <script is:inline define:vars={{ initialRooms: rooms, t: tJs }}>
    let rooms = JSON.parse(JSON.stringify(initialRooms || []));

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      })[c]);
    }

    function render() {
      const container = document.getElementById('rooms-container');
      container.innerHTML = '';

      rooms.forEach((room, idx) => {
        const div = document.createElement('div');
        div.className = 'border border-anthrazit/[0.12] p-4';
        div.innerHTML = `
          <div class="flex justify-between items-start mb-3">
            <span class="bg-anthrazit/[0.04] text-anthrazit/70 text-xs px-2 py-1 font-mono-display">${t.salon} ${idx + 1}</span>
            <button type="button" data-action="delete" data-idx="${idx}" class="bauhaus-button bauhaus-button--ghost">${t.remove}</button>
          </div>
          <div class="grid grid-cols-12 gap-3">
            <label class="bauhaus-field col-span-4">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">${t.slug}</span>
              <input type="text" data-idx="${idx}" data-field="id" value="${escapeHtml(room.id || '')}" placeholder="z.B. salon-linde" class="bauhaus-input bauhaus-input--mono" />
            </label>
            <label class="bauhaus-field col-span-2">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">${t.capacity}</span>
              <input type="number" data-idx="${idx}" data-field="capacity" value="${room.capacity || 8}" min="1" max="100" class="bauhaus-input" />
            </label>
            <div class="col-span-6"></div>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">${t.nameDe}</span>
              <input type="text" data-idx="${idx}" data-field="name_de" value="${escapeHtml(room.name_de || '')}" class="bauhaus-input" />
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">${t.nameEn}</span>
              <input type="text" data-idx="${idx}" data-field="name_en" value="${escapeHtml(room.name_en || '')}" class="bauhaus-input" />
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">${t.descDe}</span>
              <textarea data-idx="${idx}" data-field="description_de" rows="2" class="bauhaus-textarea">${escapeHtml(room.description_de || '')}</textarea>
            </label>
            <label class="bauhaus-field col-span-6">
              <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">${t.descEn}</span>
              <textarea data-idx="${idx}" data-field="description_en" rows="2" class="bauhaus-textarea">${escapeHtml(room.description_en || '')}</textarea>
            </label>
          </div>
        `;
        container.appendChild(div);
      });

      container.querySelectorAll('input, textarea').forEach(el => {
        el.addEventListener('input', e => {
          const idx = parseInt(e.target.dataset.idx);
          const field = e.target.dataset.field;
          rooms[idx][field] = field === 'capacity' ? (parseInt(e.target.value) || 0) : e.target.value;
        });
      });

      container.querySelectorAll('[data-action="delete"]').forEach(btn => {
        btn.addEventListener('click', e => {
          const idx = parseInt(e.currentTarget.dataset.idx);
          if (confirm(t.confirm)) { rooms.splice(idx, 1); render(); }
        });
      });

      document.getElementById('rooms-json-input').value = JSON.stringify(rooms);
    }

    document.getElementById('add-room-btn').addEventListener('click', () => {
      rooms.push({ id: 'salon-' + Date.now(), name_de: t.newRoom, name_en: '', capacity: 8, description_de: '', description_en: '' });
      render();
    });

    document.getElementById('rooms-form').addEventListener('submit', () => {
      document.getElementById('rooms-json-input').value = JSON.stringify(rooms);
    });

    render();
  </script>
</Layout>
