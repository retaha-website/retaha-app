---
// retaha Account — Hub /profil (Konto-Sektion). Sidebar/Header via AccountShell.
// Sicherheit (2FA) lebt auf eigener Seite /profil/sicherheit.
//
// REINE Präsentation: Speicher-Logik 1:1 (user_profiles-Upsert RLS-scoped;
// Supabase-Auth updateUser für E-Mail/Passwort), in die Kachel-Editoren verschoben.
import Layout from '../layouts/Layout.astro';
import AccountShell from '../components/account/AccountShell.astro';
import { getUser, createSupabaseServerInstance } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const ROLE_LABELS: Record<string, string> = { owner: 'Inhaber', manager: 'Manager', staff: 'Mitarbeiter' };

let message: { type: 'success' | 'error'; text: string } | null = null;
let attemptedAction: string | undefined;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();
  attemptedAction = action;

  if (action === 'save_profile') {
    const first = (form.get('first_name')?.toString() ?? '').trim();
    const last  = (form.get('last_name')?.toString() ?? '').trim();
    if (!first || !last) {
      message = { type: 'error', text: 'Vor- und Nachname dürfen nicht leer sein.' };
    } else {
      const { error } = await client.from('user_profiles').upsert(
        { user_id: user.id, first_name: first, last_name: last, updated_at: new Date().toISOString() },
        { onConflict: 'user_id' },
      );
      message = error
        ? { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` }
        : { type: 'success', text: 'Gespeichert.' };
    }
  }

  else if (action === 'change_email') {
    const newEmail = (form.get('email')?.toString() ?? '').trim();
    if (!newEmail || !newEmail.includes('@')) {
      message = { type: 'error', text: 'Bitte eine gültige E-Mail-Adresse eingeben.' };
    } else if (newEmail === user.email) {
      message = { type: 'error', text: 'Das ist bereits deine aktuelle E-Mail.' };
    } else {
      const { error } = await client.auth.updateUser({ email: newEmail });
      message = error
        ? { type: 'error', text: `E-Mail-Änderung fehlgeschlagen: ${error.message}` }
        : { type: 'success', text: 'Bestätigungs-Mail an die neue Adresse gesendet — aktiv erst nach Bestätigung.' };
    }
  }

  else if (action === 'change_password') {
    const pw  = form.get('password')?.toString() ?? '';
    const pw2 = form.get('password_confirm')?.toString() ?? '';
    if (pw.length < 8) {
      message = { type: 'error', text: 'Passwort muss mindestens 8 Zeichen haben.' };
    } else if (pw !== pw2) {
      message = { type: 'error', text: 'Die Passwörter stimmen nicht überein.' };
    } else {
      const { error } = await client.auth.updateUser({ password: pw });
      message = error
        ? { type: 'error', text: `Passwort-Änderung fehlgeschlagen: ${error.message}` }
        : { type: 'success', text: 'Passwort geändert.' };
    }
  }
}

const [{ data: profile }, { data: hotelUser }] = await Promise.all([
  client.from('user_profiles').select('first_name, last_name').eq('user_id', user.id).maybeSingle(),
  client.from('hotel_users').select('role').eq('user_id', user.id).maybeSingle(),
]);

const firstName    = profile?.first_name ?? '';
const lastName     = profile?.last_name ?? '';
const currentEmail = user.email ?? '';
const role         = (hotelUser?.role ?? 'staff') as string;
const roleLabel    = ROLE_LABELS[role] ?? role;
const fullName     = [firstName, lastName].filter(Boolean).join(' ');
const initials     = (firstName.charAt(0) || currentEmail.charAt(0)).toUpperCase();
const avatarUrl    = ((user.user_metadata as Record<string, unknown> | undefined)?.avatar_url as string | undefined) ?? null;

// Bei Validierungsfehler öffnet der betroffene Editor nach dem Reload wieder.
const errorTile = message?.type === 'error'
  ? (attemptedAction === 'save_profile' ? 'name'
    : attemptedAction === 'change_email' ? 'email'
    : attemptedAction === 'change_password' ? 'password'
    : null)
  : null;
---

<Layout title="retaha Account" activeTab="backoffice">
  <AccountShell active="konto" initials={initials} displayName={fullName || currentEmail} roleLabel={roleLabel} avatarUrl={avatarUrl}>

    {message && (
      <script is:inline define:vars={{ m: message.text, t: message.type === 'success' ? 'success' : 'error' }}>
        window.addEventListener('DOMContentLoaded', function () { window.retahaToast && window.retahaToast(m, t); });
      </script>
    )}

    <section class="acct__section" id="konto">
      <div class="acct__section-head">
        <h2 class="acct__section-title">Konto</h2>
        <p class="acct__section-desc">Dein persönliches retaha-Konto — Name, E-Mail, Passwort.</p>
      </div>

      <div class="acct-tiles" x-data={`{ open: ${JSON.stringify(errorTile)} }`}>

        <!-- NAME -->
        <div class="acct-tile acct-tile--editable" x-bind:class="{ 'is-open': open === 'name' }">
          <button
            type="button" class="acct-tile__face"
            x-show="open !== 'name'"
            x-bind:aria-expanded="(open === 'name').toString()" aria-controls="ed-name"
            x-on:click="open = 'name'; $nextTick(() => document.getElementById('first_name')?.focus())"
          >
            <span class="acct-tile__corner">
              <svg class="acct-tile__edit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            </span>
            <span class="acct-tile__label">Name</span>
            <span class={`acct-tile__value${fullName ? '' : ' acct-tile__value--empty'}`}>{fullName || 'Noch nicht hinterlegt'}</span>
          </button>
          <div class="acct-tile__editor" id="ed-name" x-show="open === 'name'" x-cloak>
            <span class="acct-tile__label">Name bearbeiten</span>
            <form method="POST">
              <input type="hidden" name="_action" value="save_profile" />
              <div class="acct-row2">
                <div class="field">
                  <label class="field__label field__label--req" for="first_name">Vorname</label>
                  <div class="field__input-wrap">
                    <input type="text" id="first_name" name="first_name" value={firstName} required maxlength="60" autocomplete="given-name" class="s-input" />
                  </div>
                </div>
                <div class="field">
                  <label class="field__label field__label--req" for="last_name">Nachname</label>
                  <div class="field__input-wrap">
                    <input type="text" id="last_name" name="last_name" value={lastName} required maxlength="60" autocomplete="family-name" class="s-input" />
                  </div>
                </div>
              </div>
              <span class="field__hint">Wird für die persönliche Ansprache in E-Mails genutzt.</span>
              <div class="acct-editor__actions">
                <button type="button" class="v9-btn v9-btn--ghost" x-on:click="open = null">Abbrechen</button>
                <button type="submit" class="v9-btn">Speichern</button>
              </div>
            </form>
          </div>
        </div>

        <!-- E-MAIL -->
        <div class="acct-tile acct-tile--editable" x-bind:class="{ 'is-open': open === 'email' }">
          <button
            type="button" class="acct-tile__face"
            x-show="open !== 'email'"
            x-bind:aria-expanded="(open === 'email').toString()" aria-controls="ed-email"
            x-on:click="open = 'email'; $nextTick(() => document.getElementById('email')?.focus())"
          >
            <span class="acct-tile__corner">
              <svg class="acct-tile__edit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            </span>
            <span class="acct-tile__label">E-Mail</span>
            <span class="acct-tile__value">{currentEmail}</span>
          </button>
          <div class="acct-tile__editor" id="ed-email" x-show="open === 'email'" x-cloak>
            <span class="acct-tile__label">E-Mail ändern</span>
            <form method="POST">
              <input type="hidden" name="_action" value="change_email" />
              <div class="acct-row2">
                <div class="field">
                  <span class="field__label">Aktuell</span>
                  <div class="pr-readonly"><span>{currentEmail}</span></div>
                </div>
                <div class="field">
                  <label class="field__label" for="email">Neue E-Mail</label>
                  <div class="field__input-wrap">
                    <input type="email" id="email" name="email" placeholder="neu@beispiel.de" autocomplete="email" class="s-input" />
                  </div>
                </div>
              </div>
              <span class="field__hint">Bestätigungs-Mail geht an die neue Adresse; aktiv erst nach Bestätigung.</span>
              <div class="acct-editor__actions">
                <button type="button" class="v9-btn v9-btn--ghost" x-on:click="open = null">Abbrechen</button>
                <button type="submit" class="v9-btn">E-Mail ändern</button>
              </div>
            </form>
          </div>
        </div>

        <!-- PASSWORT -->
        <div class="acct-tile acct-tile--editable" x-bind:class="{ 'is-open': open === 'password' }">
          <button
            type="button" class="acct-tile__face"
            x-show="open !== 'password'"
            x-bind:aria-expanded="(open === 'password').toString()" aria-controls="ed-password"
            x-on:click="open = 'password'; $nextTick(() => document.getElementById('password')?.focus())"
          >
            <span class="acct-tile__corner">
              <svg class="acct-tile__edit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            </span>
            <span class="acct-tile__label">Passwort</span>
            <span class="acct-tile__value acct-tile__value--mask">••••••••</span>
          </button>
          <div class="acct-tile__editor" id="ed-password" x-show="open === 'password'" x-cloak>
            <span class="acct-tile__label">Passwort ändern</span>
            <form method="POST">
              <input type="hidden" name="_action" value="change_password" />
              <div class="acct-row2">
                <div class="field">
                  <label class="field__label" for="password">Neues Passwort</label>
                  <div class="field__input-wrap">
                    <input type="password" id="password" name="password" minlength="8" autocomplete="new-password" class="s-input" />
                  </div>
                </div>
                <div class="field">
                  <label class="field__label" for="password_confirm">Wiederholen</label>
                  <div class="field__input-wrap">
                    <input type="password" id="password_confirm" name="password_confirm" minlength="8" autocomplete="new-password" class="s-input" />
                  </div>
                </div>
              </div>
              <span class="field__hint">Mindestens 8 Zeichen.</span>
              <div class="acct-editor__actions">
                <button type="button" class="v9-btn v9-btn--ghost" x-on:click="open = null">Abbrechen</button>
                <button type="submit" class="v9-btn">Passwort ändern</button>
              </div>
            </form>
          </div>
        </div>

        <!-- ROLLE (read-only) -->
        <div class="acct-tile acct-tile--readonly">
          <div class="acct-tile__face acct-tile__face--static">
            <span class="acct-tile__label">Rolle</span>
            <span class="acct-tile__value">{roleLabel}</span>
            <span class="acct-tile__hint">vom Hotel zugewiesen</span>
          </div>
        </div>

      </div>
    </section>

  </AccountShell>
</Layout>

<style>
  /* ── Konto-Kacheln (Zustand-zuerst, alle gleich groß) ── */
  .acct-tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; align-items: start; }
  @media (max-width: 560px) { .acct-tiles { grid-template-columns: 1fr; } }

  .acct-tile {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); overflow: hidden; transition: border-color 150ms ease;
  }
  .acct-tile.is-open { border-color: var(--te-yellow); }

  .acct-tile__face {
    position: relative; display: flex; flex-direction: column; gap: 12px;
    width: 100%; min-height: 150px; box-sizing: border-box;
    text-align: left; padding: 34px 32px 36px;
    background: transparent; border: none; font: inherit; color: inherit;
    transition: background 150ms ease;
  }
  button.acct-tile__face { cursor: pointer; }
  .acct-tile--editable:hover { border-color: var(--te-yellow); }
  .acct-tile--editable:hover .acct-tile__face { background: var(--te-yellow-soft); }
  .acct-tile--editable:hover .acct-tile__edit { color: var(--ink); }
  .acct-tile__face:focus-visible {
    outline: none; background: var(--te-yellow-soft);
    box-shadow: inset 0 0 0 2px var(--te-yellow);
  }
  .acct-tile__face--static { cursor: default; }

  .acct-tile__corner { position: absolute; top: 30px; right: 30px; display: inline-flex; align-items: center; gap: 8px; }
  .acct-tile__edit { width: 15px; height: 15px; color: var(--ink-faint); transition: color 150ms ease; }
  .acct-tile__label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
  }
  .acct-tile__value {
    font-family: 'Inter Tight', sans-serif; font-size: 17px; font-weight: 500;
    letter-spacing: -0.01em; color: var(--ink);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 28px;
  }
  .acct-tile__value--empty { color: var(--ink-muted); font-weight: 400; }
  .acct-tile__value--mask { letter-spacing: 0.18em; }
  .acct-tile__hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.06em; color: var(--ink-faint); margin-top: 2px;
  }

  /* Editor (Inline-Aufklappen) */
  .acct-tile__editor { display: flex; flex-direction: column; gap: 20px; padding: 32px 32px 34px; }
  .acct-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }
  @media (max-width: 560px) { .acct-row2 { grid-template-columns: 1fr; } }
  .acct-row2 .field__label { padding-top: 0; }
  .acct-editor__actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 2px; }

  /* Read-only-Feld im V9-Stil (E-Mail „Aktuell") */
  .pr-readonly {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); padding: 10px 14px;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; color: var(--ink);
    word-break: break-word;
  }

  .v9-btn { min-height: 44px; }
</style>
