---
/**
 * /admin/sicherheit — 2FA Setup-Wizard (4 Steps)
 *
 * v9 design system rewrite — uses s-card, breadcrumb, settings-hero, v9-btn patterns.
 *
 * Steps:
 *   1. Vorbereiten (Checklist) — kein API-Call
 *   2. QR-Code (calls /api/mfa/setup-start, holt secret + qr_data_url)
 *   3. Verifizieren (calls /api/mfa/setup-verify, liefert recovery_codes)
 *   4. Recovery-Codes anzeigen + Confirm-Checkbox -> /uebersicht
 *
 * Notiz: User-Spec sagte 'apps/dashboard/src/pages/admin/team-security.astro'
 * fuer Enforcement. Aktuelle Architektur trennt aber:
 *   - apps/dashboard = /app/* Operations
 *   - apps/backoffice = /admin/* Configuration
 * Daher /admin/sicherheit + /admin/team-security in BACKOFFICE.
 *
 * Sprint-J-Backlog: PDF-Download (pdf-lib), Email an User nach Setup-Complete.
 */

import { getUser, getUserHotels } from '@retaha/auth';
import Layout from '../layouts/Layout.astro';
import TrianglePulse from '@retaha/ui/components/TrianglePulse.astro';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

// ?required=true wenn von Team-Pflicht-Redirect kommend
const isRequired = Astro.url.searchParams.get('required') === 'true';
---

<Layout title="Zwei-Faktor-Authentifizierung" activeTab="backoffice">

<style is:global>
  [x-cloak] { display: none !important; }

  /* ── Step indicator ────────────────────────────────────────────────────────── */
  .sec-step-indicator {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin-bottom: 32px;
  }
  .sec-step-cell {
    padding-top: 12px;
    border-top: 2px solid var(--border);
    transition: border-color 400ms ease;
  }
  .sec-step-cell.is-active  { border-top-color: var(--accent); }
  .sec-step-cell.is-complete { border-top-color: #5C9070; }
  .sec-step-cell__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 4px;
  }
  .sec-step-cell.is-active .sec-step-cell__label,
  .sec-step-cell.is-complete .sec-step-cell__label { color: var(--ink); }
  .sec-step-cell__title {
    font-size: 13px; font-weight: 500; color: var(--ink);
  }
  .sec-step-cell.is-not-yet .sec-step-cell__title { color: var(--ink-muted); opacity: 0.5; }
  .sec-step-cell__num {
    display: inline-block;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
    margin-right: 8px;
  }
  .sec-step-cell.is-complete .sec-step-cell__num { color: #5C9070; }
  .sec-step-cell.is-not-yet .sec-step-cell__num { color: var(--ink-muted); opacity: 0.4; }

  /* ── Error banner ──────────────────────────────────────────────────────────── */
  .sec-error {
    padding: 12px 16px;
    background: rgba(140, 33, 40, 0.06);
    border-left: 3px solid #8C2128;
    border-radius: var(--r-sm, 4px);
    margin-bottom: 24px;
    font-size: 13px;
    color: var(--ink);
  }
  .sec-error::before {
    content: "▲ ";
    color: #8C2128;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
  }

  /* ── Step panels ───────────────────────────────────────────────────────────── */
  .sec-panel {
    animation: secPanelEnter 400ms ease;
  }
  @keyframes secPanelEnter {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sec-panel { animation: none; }
  }

  /* ── Enforcement notice ────────────────────────────────────────────────────── */
  .sec-enforcement {
    padding: 14px 16px;
    background: rgba(192, 106, 60, 0.06);
    border-left: 3px solid var(--accent);
    border-radius: var(--r-sm, 4px);
    margin-bottom: 24px;
    font-size: 13px;
    color: var(--ink);
  }

  /* ── Checklist (Step 1) ────────────────────────────────────────────────────── */
  .sec-checklist { display: flex; flex-direction: column; gap: 10px; }
  .sec-checklist-item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r, 8px);
  }
  .sec-checklist-item__num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.1em;
    color: var(--accent);
    flex-shrink: 0;
    padding-top: 2px;
  }
  .sec-checklist-item__content h4 {
    font-size: 13px; font-weight: 500;
    color: var(--ink); margin-bottom: 4px;
  }
  .sec-checklist-item__content p {
    font-size: 12px; color: var(--ink-muted); line-height: 1.5;
  }
  .sec-checklist-item__content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(192, 106, 60, 0.3);
  }
  .sec-checklist-item__content a:hover { border-bottom-color: var(--accent); }

  /* ── QR display (Step 2) ───────────────────────────────────────────────────── */
  .sec-qr-display {
    display: grid; grid-template-columns: 1fr; gap: 24px;
    margin-bottom: 24px;
  }
  @media (min-width: 640px) {
    .sec-qr-display { grid-template-columns: auto 1fr; align-items: center; }
  }
  .sec-qr-code {
    width: 192px; height: 192px;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--r, 8px);
    padding: 14px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .sec-qr-code img { width: 100%; height: 100%; }
  .sec-qr-info h4 {
    font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 10px;
  }
  .sec-qr-info p {
    font-size: 12px; color: var(--ink-muted); line-height: 1.55; margin-bottom: 14px;
  }
  .sec-secret-toggle {
    display: inline-flex; align-items: center; gap: 6px;
    background: transparent; border: 1px solid var(--border);
    padding: 7px 12px;
    border-radius: var(--r-sm, 4px);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-muted);
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease;
  }
  .sec-secret-toggle:hover { border-color: var(--ink); color: var(--ink); }
  .sec-secret-value {
    margin-top: 10px; padding: 10px 12px;
    background: var(--bg-deep, #F0EDE6);
    border-radius: var(--r-sm, 4px);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink);
    letter-spacing: 0.1em; word-break: break-all;
  }

  /* ── TOTP code inputs (Step 3) ─────────────────────────────────────────────── */
  .sec-code-group {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
    margin-bottom: 24px;
    max-width: 360px;
  }
  .sec-code-input {
    width: 100%; aspect-ratio: 1; max-height: 54px;
    border: 1.5px solid var(--border);
    border-radius: var(--r-sm, 4px);
    background: white;
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px; font-weight: 500;
    text-align: center;
    color: var(--ink);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .sec-code-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(192, 106, 60, 0.15);
  }
  .sec-code-input.is-filled { border-color: var(--ink-muted); }

  /* ── Recovery codes (Step 4) ───────────────────────────────────────────────── */
  .sec-complete-indicator {
    display: flex; align-items: center; justify-content: center; gap: 12px;
    padding: 24px 0;
    margin-bottom: 8px;
  }
  .sec-complete-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: #5C9070;
  }
  .sec-recovery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r, 8px);
    margin-bottom: 20px;
  }
  .sec-recovery-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; letter-spacing: 0.08em;
    color: var(--ink);
    padding: 8px 10px;
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--r-sm, 4px);
    text-align: center;
  }
  .sec-recovery-actions {
    display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;
  }
  .sec-recovery-warning {
    padding: 14px 16px;
    background: rgba(140, 33, 40, 0.05);
    border-left: 3px solid #8C2128;
    border-radius: var(--r-sm, 4px);
    margin-bottom: 24px;
    font-size: 13px;
    color: var(--ink);
  }
  .sec-recovery-warning::before {
    content: "▲ ";
    color: #8C2128;
    font-family: 'JetBrains Mono', monospace;
    font-weight: bold;
  }
  .sec-recovery-warning strong { color: var(--ink); font-weight: 500; }
  .sec-recovery-checkbox {
    display: flex; align-items: flex-start; gap: 10px;
    margin-bottom: 24px;
    cursor: pointer;
  }
  .sec-recovery-checkbox input {
    margin-top: 3px; width: 16px; height: 16px;
    accent-color: var(--accent);
    cursor: pointer; flex-shrink: 0;
  }
  .sec-recovery-checkbox label {
    font-size: 13px; color: var(--ink); cursor: pointer; line-height: 1.5;
  }

  /* ── Step action bar ───────────────────────────────────────────────────────── */
  .sec-actions {
    display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
    margin-top: 20px;
  }

  /* Print: only show recovery codes */
  @media print {
    body * { visibility: hidden; }
    .sec-recovery-grid, .sec-recovery-grid * { visibility: visible; }
    .sec-recovery-grid { position: absolute; top: 0; left: 0; background: white; border: 1px solid black; }
  }
</style>

<div class="settings-page"
  x-data={`{
    step: 1,
    code: ['', '', '', '', '', ''],
    secretRevealed: false,
    confirmedSaved: false,

    // Aus API setup-start
    qrDataUrl: null,
    secretForManualEntry: null,
    isStarting: false,

    // Aus API setup-verify
    recoveryCodes: [],
    isVerifying: false,

    errorMessage: '',

    isComplete() { return this.code.every(d => d !== ''); },

    onCodeInput(index, event) {
      const value = event.target.value.replace(/\\D/g, '').slice(-1);
      this.code[index] = value;
      this.errorMessage = '';
      if (value && index < 5) {
        this.$refs['input' + (index + 1)]?.focus();
      }
    },
    onCodeKeydown(index, event) {
      if (event.key === 'Backspace' && !this.code[index] && index > 0) {
        this.code[index - 1] = '';
        this.$refs['input' + (index - 1)]?.focus();
      }
    },

    async advance() {
      if (this.step === 1) {
        await this.startSetup();
        if (!this.qrDataUrl) return;
        this.step = 2;
      } else if (this.step === 2) {
        this.step = 3;
        setTimeout(() => this.$refs.input0?.focus(), 200);
      } else if (this.step === 3) {
        await this.verifySetup();
      }
    },

    back() {
      if (this.step > 1) {
        this.step--;
        this.errorMessage = '';
      }
    },

    async startSetup() {
      this.isStarting = true;
      this.errorMessage = '';
      try {
        const res = await fetch('/api/mfa/setup-start', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.ok) {
          this.qrDataUrl = data.qr_data_url;
          this.secretForManualEntry = data.secret_for_manual_entry;
        } else {
          this.errorMessage = data.message || 'Setup konnte nicht gestartet werden.';
        }
      } catch {
        this.errorMessage = 'Netzwerk-Fehler.';
      } finally {
        this.isStarting = false;
      }
    },

    async verifySetup() {
      if (!this.isComplete()) return;
      this.isVerifying = true;
      this.errorMessage = '';
      try {
        const res = await fetch('/api/mfa/setup-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code: this.code.join('') })
        });
        const data = await res.json();
        if (res.ok && data.ok) {
          this.recoveryCodes = data.recovery_codes;
          this.step = 4;
        } else {
          this.errorMessage = data.message || 'Code ungültig. Bitte erneut versuchen.';
          this.code = ['', '', '', '', '', ''];
          setTimeout(() => this.$refs.input0?.focus(), 100);
        }
      } catch {
        this.errorMessage = 'Netzwerk-Fehler.';
      } finally {
        this.isVerifying = false;
      }
    },

    async copyRecoveryCodes() {
      try {
        await navigator.clipboard.writeText(this.recoveryCodes.join('\\n'));
        alert('Codes in die Zwischenablage kopiert.');
      } catch {
        alert('Kopieren fehlgeschlagen — bitte manuell auswählen.');
      }
    },

    printRecoveryCodes() {
      window.print();
    }
  }`}>

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__crumb breadcrumb__crumb--current">Sicherheit &amp; 2FA</span>
  </nav>

  <!-- Hero -->
  <section class="settings-hero">
    <span class="settings-hero__eyebrow">— Sicherheit —</span>
    <h1 class="settings-hero__title">Zwei-Faktor-Authentifizierung<span class="dot-pink">.</span></h1>
    <p class="settings-hero__sub">
      Schütze dein retaha-Konto mit einem zusätzlichen Sicherheits-Schlüssel.
      Du brauchst eine Authenticator-App auf deinem Smartphone — wir empfehlen
      Google Authenticator, 1Password oder den iCloud-Schlüsselbund.
    </p>
  </section>

  <!-- Enforcement notice -->
  {isRequired && (
    <div class="sec-enforcement">
      <strong>Pflicht-Setup:</strong> Dein Hotel-Owner hat 2FA für das Team aktiviert. Du musst es jetzt einrichten.
    </div>
  )}

  <div class="settings-sections">

    <!-- Wizard card -->
    <section class="s-card">
      <div class="s-card__head">
        <h2 class="s-card__title">2FA einrichten</h2>
        <span class="s-card__num">01</span>
      </div>

      <div class="s-card__body">

        <!-- Step indicator -->
        <nav class="sec-step-indicator" aria-label="Setup-Fortschritt">
          {[
            { num: '01', title: 'Vorbereiten' },
            { num: '02', title: 'QR-Code scannen' },
            { num: '03', title: 'Code verifizieren' },
            { num: '04', title: 'Recovery-Codes' },
          ].map((cell, i) => (
            <div class="sec-step-cell" x-bind:class={`{
              'is-active': step === ${i + 1},
              'is-complete': step > ${i + 1},
              'is-not-yet': step < ${i + 1}
            }`}>
              <p class="sec-step-cell__label">
                <span class="sec-step-cell__num">{cell.num}</span>SCHRITT
              </p>
              <p class="sec-step-cell__title">{cell.title}</p>
            </div>
          ))}
        </nav>

        <!-- Global error banner -->
        <div x-show="errorMessage" x-cloak class="sec-error" x-text="errorMessage"></div>

        <!-- ── STEP 1: VORBEREITEN ─────────────────────────────────────────────── -->
        <div class="sec-panel" x-show="step === 1">
          <p class="field__hint" style="margin-bottom:20px;">
            Bevor wir starten — bereite eine <strong>Authenticator-App</strong> auf deinem
            Smartphone vor. Falls du noch keine hast, kein Problem:
          </p>

          <div class="sec-checklist">
            <div class="sec-checklist-item">
              <span class="sec-checklist-item__num">01</span>
              <div class="sec-checklist-item__content">
                <h4>Authenticator-App installieren</h4>
                <p>
                  Empfohlen:
                  <a href="https://apps.apple.com/de/app/google-authenticator/id388497605" target="_blank" rel="noopener">Google Authenticator</a>,
                  <a href="https://1password.com" target="_blank" rel="noopener">1Password</a>
                  oder der iCloud-Schlüsselbund (bereits auf deinem iPhone).
                </p>
              </div>
            </div>
            <div class="sec-checklist-item">
              <span class="sec-checklist-item__num">02</span>
              <div class="sec-checklist-item__content">
                <h4>Smartphone bereithalten</h4>
                <p>Du brauchst es für den QR-Code-Scan im nächsten Schritt.</p>
              </div>
            </div>
            <div class="sec-checklist-item">
              <span class="sec-checklist-item__num">03</span>
              <div class="sec-checklist-item__content">
                <h4>Recovery-Codes notieren</h4>
                <p>
                  Am Ende bekommst du 8 Backup-Codes für den Notfall — falls du dein
                  Phone verlierst. Halte einen Drucker oder Stift bereit.
                </p>
              </div>
            </div>
          </div>

          <div class="sec-actions">
            <button class="v9-btn v9-btn--primary" x-on:click="advance()" x-bind:disabled="isStarting">
              <span x-show="!isStarting">Ich bin bereit</span>
              <span x-show="isStarting" x-cloak>Wird vorbereitet …</span>
            </button>
          </div>
        </div>

        <!-- ── STEP 2: QR-CODE ────────────────────────────────────────────────── -->
        <div class="sec-panel" x-show="step === 2" x-cloak>
          <p class="field__hint" style="margin-bottom:20px;">
            Öffne deine Authenticator-App und tippe auf <strong>"+ Hinzufügen"</strong>.
            Scanne dann den QR-Code mit der Kamera.
          </p>

          <div class="sec-qr-display">
            <div class="sec-qr-code">
              <img x-bind:src="qrDataUrl" alt="QR-Code für Authenticator-App-Setup" x-show="qrDataUrl" />
            </div>

            <div class="sec-qr-info">
              <h4>retaha · 2FA Setup</h4>
              <p>
                Falls dein Phone den QR-Code nicht scannen kann, kannst du den
                Setup-Schlüssel auch manuell eintippen:
              </p>
              <button class="sec-secret-toggle" type="button" x-on:click="secretRevealed = !secretRevealed">
                <span x-text="secretRevealed ? '← Schlüssel verbergen' : '→ Schlüssel anzeigen'"></span>
              </button>
              <div x-show="secretRevealed" x-cloak class="sec-secret-value" x-text="secretForManualEntry"></div>
            </div>
          </div>

          <div class="sec-actions">
            <button class="v9-btn v9-btn--ghost" type="button" x-on:click="back()">← Zurück</button>
            <button class="v9-btn v9-btn--primary" x-on:click="advance()">
              Weiter zur Verifizierung
            </button>
          </div>
        </div>

        <!-- ── STEP 3: VERIFIZIEREN ──────────────────────────────────────────── -->
        <div class="sec-panel" x-show="step === 3" x-cloak>
          <p class="field__hint" style="margin-bottom:20px;">
            Deine App zeigt jetzt einen <strong>6-stelligen Code</strong> der alle 30 Sekunden
            neu generiert wird. Gib den aktuellen Code hier ein:
          </p>

          <div class="sec-code-group">
            {Array.from({ length: 6 }).map((_, index) => (
              <input
                type="text"
                inputmode="numeric"
                autocomplete="one-time-code"
                maxlength="1"
                class="sec-code-input s-input s-input--mono"
                x-bind:class={`{ 'is-filled': code[${index}] !== '' }`}
                x-ref={`input${index}`}
                x-bind:value={`code[${index}]`}
                x-on:input={`onCodeInput(${index}, $event)`}
                x-on:keydown={`onCodeKeydown(${index}, $event)`}
                x-bind:disabled="isVerifying"
                aria-label={`Ziffer ${index + 1} von 6`}
              />
            ))}
          </div>

          <div class="sec-actions">
            <button class="v9-btn v9-btn--ghost" type="button" x-on:click="back()">← Zurück</button>
            <button class="v9-btn v9-btn--primary"
                    x-bind:disabled="!isComplete() || isVerifying"
                    x-on:click="verifySetup()">
              <span x-show="!isVerifying">Code prüfen</span>
              <span x-show="isVerifying" x-cloak>Wird geprüft …</span>
            </button>
          </div>
        </div>

        <!-- ── STEP 4: RECOVERY-CODES ────────────────────────────────────────── -->
        <div class="sec-panel" x-show="step === 4" x-cloak>

          <div class="sec-complete-indicator">
            <TrianglePulse variant="sage" motion="once" label="Setup erfolgreich abgeschlossen" />
            <span class="sec-complete-label">Erfolgreich aktiviert</span>
          </div>

          <p class="field__hint" style="text-align:center;margin-bottom:20px;">
            2FA ist jetzt aktiv. Hier sind deine <strong>8 Recovery-Codes</strong> — bewahre
            sie sicher auf. Jeder Code funktioniert nur einmal und ersetzt deine
            Authenticator-App im Notfall.
          </p>

          <div class="sec-recovery-grid">
            <template x-for="rcode in recoveryCodes" x-bind:key="rcode">
              <span class="sec-recovery-code" x-text="rcode"></span>
            </template>
          </div>

          <div class="sec-recovery-actions">
            <button class="v9-btn v9-btn--ghost" type="button" x-on:click="copyRecoveryCodes()">
              Codes kopieren
            </button>
            <button class="v9-btn v9-btn--ghost" type="button" x-on:click="printRecoveryCodes()">
              Drucken
            </button>
          </div>

          <div class="sec-recovery-warning">
            <strong>Wichtig:</strong> Diese Codes werden dir NICHT erneut angezeigt.
            Bewahre sie an einem sicheren Ort auf — z.B. im Passwort-Manager oder
            gedruckt im Safe.
          </div>

          <div class="sec-recovery-checkbox">
            <input type="checkbox" id="confirm-saved" x-model="confirmedSaved" />
            <label for="confirm-saved">
              Ich habe meine Recovery-Codes sicher gespeichert.
            </label>
          </div>

          <div class="sec-actions">
            <a class="v9-btn v9-btn--primary"
               x-bind:class="confirmedSaved ? '' : 'is-disabled'"
               x-bind:href="confirmedSaved ? '/uebersicht' : '#'"
               style="flex:1;text-decoration:none;justify-content:center;">
              fertig — zum Dashboard
            </a>
          </div>
        </div>

      </div><!-- /.s-card__body -->
    </section>

  </div><!-- /.settings-sections -->
</div><!-- /.settings-page -->

</Layout>
