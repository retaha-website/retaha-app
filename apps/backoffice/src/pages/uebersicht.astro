---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/uebersicht/HeroSection.astro';
import RackBanner from '../components/uebersicht/RackBanner.astro';
import SetupStatus from '../components/uebersicht/SetupStatus.astro';
import AppGrid from '../components/uebersicht/AppGrid.astro';
import LiveTilesSection from '../components/uebersicht/LiveTilesSection.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { normalizeStage } from '../lib/uebersicht/setup-stage';
import { getLiveData } from '../lib/uebersicht/live-data';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const supabase = createSupabaseServerInstance(Astro.cookies, Astro.request);

// setup_progress laden + automatisch auf 30 setzen wenn Hotel-Name vorhanden
let rawProgress: number | null = null;
try {
  const { data } = await supabase
    .from('hotels')
    .select('setup_progress, name')
    .eq('id', hotel.id)
    .maybeSingle();
  rawProgress = (data as any)?.setup_progress ?? null;

  // Pflichtfeld (Hotel-Name) gesetzt, aber Fortschritt noch unter 30?
  // → automatisch auf 30 hochsetzen ohne dass der User nochmal speichern muss
  const hotelName = (data as any)?.name;
  if (hotelName && (rawProgress ?? 0) < 30) {
    await supabase.from('hotels')
      .update({ setup_progress: 30 })
      .eq('id', hotel.id);
    rawProgress = 30;
  }
} catch { /* Spalte existiert noch nicht — DB-Migration ausstehend */ }

const stage = normalizeStage(rawProgress);
const liveData = await getLiveData(hotel.id);

// User-Initial für Avatar (erster Buchstabe der Email)
const userInitial = (user.email ?? 'K').charAt(0).toUpperCase();
---

<Layout
  title="Übersicht"
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLocation={hotel.city ?? undefined}
  hotelLogoUrl={hotel.logo_url}
  userInitial={userInitial}
>
  <HeroSection stage={stage} />
  <RackBanner stage={stage} />
  <SetupStatus stage={stage} />
  <AppGrid stage={stage} />
  <LiveTilesSection tiles={liveData} />
</Layout>
