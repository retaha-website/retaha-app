---
import Layout from '../layouts/Layout.astro';
import OnboardingHero from '../components/uebersicht/OnboardingHero.astro';
import OnboardingStep2 from '../components/uebersicht/OnboardingStep2.astro';
import HeroSection from '../components/uebersicht/HeroSection.astro';
import RackBanner from '../components/uebersicht/RackBanner.astro';
import SetupStatus from '../components/uebersicht/SetupStatus.astro';
import AppGrid from '../components/uebersicht/AppGrid.astro';
import LiveTilesSection from '../components/uebersicht/LiveTilesSection.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { normalizeStage } from '../lib/uebersicht/setup-stage';
import { getLiveData } from '../lib/uebersicht/live-data';
import { getLang } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const supabase = createSupabaseServerInstance(Astro.cookies, Astro.request);

// setup_progress laden + automatisch anpassen basierend auf konfigurierten Feldern
let rawProgress: number | null = null;
try {
  const { data } = await supabase
    .from('hotels')
    .select('setup_progress, name, logo_primary, brand_primary, brand_theme')
    .eq('id', hotel.id)
    .maybeSingle();
  rawProgress = (data as any)?.setup_progress ?? null;

  const hotelName    = (data as any)?.name;
  const logoSet      = !!((data as any)?.logo_primary);
  const colorCustom  = (data as any)?.brand_primary && (data as any).brand_primary !== '#FF4A82';
  const themeCustom  = (data as any)?.brand_theme && (data as any).brand_theme !== 'coffee';
  const brandingDone = logoSet || colorCustom || themeCustom;

  const current = rawProgress ?? 0;
  let target = current;

  // Stufe 15: Hotel-Name (Pflichtfeld) gesetzt
  if (hotelName && current < 15) target = 15;
  // Stufe 30: Branding konfiguriert (Logo ODER eigene Farbe/Theme)
  if (hotelName && brandingDone && current < 30) target = 30;

  if (target > current) {
    await supabase.from('hotels').update({ setup_progress: target }).eq('id', hotel.id);
    rawProgress = target;
  }
} catch { /* Spalte existiert noch nicht — DB-Migration ausstehend */ }

const stage = normalizeStage(rawProgress);
const liveData = await getLiveData(hotel.id);

// User-Initial für Avatar (erster Buchstabe der Email)
const userInitial = (user.email ?? 'K').charAt(0).toUpperCase();
---

<Layout
  title="Übersicht"
  activeTab="backoffice"
  hotelName={hotel.name}
  hotelLocation={hotel.city ?? undefined}
  hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}
  userInitial={userInitial}
>
  <div data-onboarding-flow>
    <OnboardingHero hotelName={hotel.name} />
    <OnboardingStep2 hotelId={hotel.id} hotelName={hotel.name} userId={user.id} />
  </div>

  <div data-dashboard>
    <HeroSection stage={stage} lang={lang} />
    <RackBanner stage={stage} lang={lang} />
    <SetupStatus stage={stage} lang={lang} />
    <AppGrid stage={stage} lang={lang} />
    <LiveTilesSection tiles={liveData} lang={lang} />
  </div>

  <script is:inline>
    (function () {
      var flow  = document.querySelector('[data-onboarding-flow]');
      if (!flow) return;
      var step1 = flow.querySelector('[data-onb-step="1"]');
      var step2 = flow.querySelector('[data-onb-step="2"]');

      // Setup-Step füllt die volle Bildschirmhöhe — Step-Balken sitzt unten.
      function fit(el) {
        if (!el || el.style.display === 'none') return;
        el.style.minHeight = '';
        var top = el.getBoundingClientRect().top + (window.scrollY || window.pageYOffset || 0);
        el.style.minHeight = Math.max(520, window.innerHeight - top - 16) + 'px';
      }
      function visibleStep() {
        if (step1 && step1.style.display !== 'none') return step1;
        if (step2 && step2.style.display !== 'none') return step2;
        return null;
      }
      function fitVisible() { fit(visibleStep()); }

      fitVisible();
      window.addEventListener('resize', fitVisible);

      // „Weiter" (Step 1) → Step 1 raus, Step 2 rein. Rahmen bleibt identisch.
      function goStep2() {
        if (step1) step1.style.display = 'none';
        if (step2) {
          step2.style.display = 'flex';
          requestAnimationFrame(function () { fit(step2); });
        }
        window.scrollTo({ top: 0 });
      }
      // „Setup überspringen" → Flow ganz weg, Dashboard darunter kommt hoch.
      function skip() {
        flow.style.display = 'none';
        window.scrollTo({ top: 0 });
      }

      document.querySelectorAll('[data-onb-action="next"]').forEach(function (b) {
        b.addEventListener('click', function (e) { e.preventDefault(); goStep2(); });
      });
      document.querySelectorAll('[data-onb-action="skip"]').forEach(function (b) {
        b.addEventListener('click', function (e) { e.preventDefault(); skip(); });
      });
    })();
  </script>
</Layout>
