---
import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import {
  STAY_PUSH_TRIGGER_LABELS, STAY_PUSH_TRIGGER_VARIABLES,
} from '@retaha/marketing';
import { VARIABLE_UI_DEFS } from '@retaha/marketing';
import { STAY_PUSH_DEFAULTS } from '@retaha/wallet';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.write')) return new Response('Forbidden', { status: 403 });

const triggerType = Astro.params.trigger_type;
if (!triggerType || !(triggerType in STAY_PUSH_TRIGGER_LABELS)) {
  return Astro.redirect('/stay-pushes');
}

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: existing } = await client
  .from('stay_push_templates')
  .select('id, title_i18n, body_i18n, is_active')
  .eq('hotel_id', hotel.id)
  .eq('trigger_type', triggerType)
  .maybeSingle();

const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '';
  return jsonb[hotelDefaultLang]?.value ?? '';
}
const defaults = STAY_PUSH_DEFAULTS[triggerType] ?? { title: '', body: '' };
const initialTitle = existing ? pickI18n(existing.title_i18n) : defaults.title;
const initialBody  = existing ? pickI18n(existing.body_i18n)  : defaults.body;
const initialActive = existing?.is_active ?? false;

const allowedVars = STAY_PUSH_TRIGGER_VARIABLES[triggerType] ?? [];
const STAY_VAR_LABELS: Record<string, string> = {
  ...Object.fromEntries(VARIABLE_UI_DEFS.map(v => [v.key, v.label])),
  checkout_time: 'Check-out-Zeit',
  room_number:   'Zimmer-Nummer',
  guest_count:   'Gäste-Anzahl',
  date:          'Datum',
  time:          'Uhrzeit',
};
const spEditorT = {
  noTitle: bt('sp.editor.notitle', lang),
  noText: bt('sp.editor.notext', lang),
  titleRequired: bt('sp.editor.titlerequired', lang),
  bodyRequired: bt('sp.editor.bodyrequired', lang),
  unknownVars: bt('sp.editor.unknownvars', lang),
  forbiddenVars: bt('sp.editor.forbiddenvars', lang),
  saveFail: bt('sp.editor.savefail', lang),
  netErr: bt('sp.editor.neterr', lang),
};

const DEMO_VARS = {
  first_name: 'Anna',
  last_name: 'Schmidt',
  hotel_name: hotel.name,
  visit_count: 3,
  last_visit_date: '24.12.2025',
  first_visit_date: '15.07.2024',
  checkout_time: '11:00',
  room_number: '204',
  guest_count: '4',
  date: '14. Juli 2026',
  time: '19:30',
};
---

<Layout title={`Stay-Push · ${STAY_PUSH_TRIGGER_LABELS[triggerType]}`} activeTab="backoffice">
  <div class="sp-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <a href="/stay-pushes" class="breadcrumb__crumb">{bt('sp.eyebrow', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('sp.trigger.' + triggerType + '.label', lang)}</span>
    </nav>

    <header class="sp-header">
      <p class="sp-eyebrow">{bt('sp.eyebrow', lang)}</p>
      <h1 class="sp-title">{bt('sp.trigger.' + triggerType + '.label', lang)}<span class="h-dot">.</span></h1>
      <p class="sp-sub">{bt('sp.trigger.' + triggerType + '.desc', lang)}</p>
    </header>

    <div class="se-grid" x-data="stayPushEditor()" x-init="init()">

      <!-- Form -->
      <div class="se-panel">

        <!-- Active-Toggle -->
        <div class="se-toggle-row">
          <div class="se-toggle-info">
            <p class="se-toggle-label">{bt('bf.modal.active', lang)}</p>
            <p class="se-toggle-hint" x-text={`form.is_active ? ${JSON.stringify(bt('sp.editor.toggleon', lang))} : ${JSON.stringify(bt('sp.editor.toggleoff', lang))}`}></p>
          </div>
          <label class="toggle-row" @click.prevent="form.is_active = !form.is_active">
            <span class="bt-visual" :class="{'is-checked': form.is_active}">
              <span class="bt-knob"></span>
            </span>
          </label>
        </div>

        <div class="se-divider"></div>

        <!-- Title -->
        <div class="se-field">
          <label class="se-label" for="se-title">{bt('sp.editor.titlelabel', lang)}</label>
          <input
            id="se-title"
            type="text"
            x-model="form.title"
            :placeholder={`${JSON.stringify(bt('sp.editor.titlelabel', lang))}`}
            class="se-input"
            maxlength="60"
          />
          <p class="se-hint">{bt('sp.editor.titlehint', lang)}</p>
        </div>

        <!-- Body -->
        <div class="se-field">
          <label class="se-label" for="se-body">{bt('sp.editor.body', lang)}</label>
          <textarea
            id="se-body"
            x-model="form.body"
            rows="4"
            placeholder="z.B. Schön dass du da bist, {{first_name}}."
            class="se-input se-textarea"
            maxlength="1024"
          ></textarea>
          <p class="se-hint" set:html={bt('sp.editor.hint', lang)}></p>
        </div>

        <!-- Variable chips -->
        <div class="se-field">
          <p class="se-label">{bt('sp.editor.vars', lang)}</p>
          <div class="se-var-chips">
            {allowedVars.map(v => (
              <button type="button" class="se-var-chip" @click={`insertVar('${v}')`}>
                {STAY_VAR_LABELS[v]}
                <code>{`{{${v}}}`}</code>
              </button>
            ))}
          </div>
        </div>

        <!-- Error -->
        <template x-if="errorMsg">
          <div class="se-error" x-text="errorMsg"></div>
        </template>

        <!-- Actions -->
        <div class="se-actions">
          <a href="/stay-pushes" class="se-btn-ghost">{bt('common.cancel', lang)}</a>
          <button
            type="button"
            class="se-btn-primary"
            :disabled="submitting"
            @click="save()"
            x-text={`submitting ? ${JSON.stringify(bt('sp.editor.saving', lang))} : ${JSON.stringify(bt('common.save', lang))}`}
          ></button>
        </div>
      </div>

      <!-- Preview -->
      <div class="se-preview-panel">
        <p class="se-preview-eyebrow">{bt('sp.editor.preview', lang)}</p>
        <p class="se-preview-hint">{bt('sp.editor.previewhint', lang)}</p>

        <div class="se-mockup">
          <div class="se-mockup-frame">
            <div class="se-mockup-status">retaha · Wallet-Push</div>
            <div class="se-mockup-card">
              <div class="se-mockup-brand">
                <span class="se-mockup-logo">{hotel.name.slice(0, 1).toUpperCase()}</span>
                <div>
                  <div class="se-mockup-hotel">{hotel.name}</div>
                  <div class="se-mockup-now">{bt('sp.editor.now', lang)}</div>
                </div>
              </div>
              <div class="se-mockup-title" x-text="previewTitle"></div>
              <div class="se-mockup-body" x-text="previewBody"></div>
            </div>
            <div class="se-mockup-note">{bt('sp.editor.mockupnote', lang)}</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{
    INITIAL: { title: initialTitle, body: initialBody, is_active: initialActive },
    TRIGGER: triggerType,
    DEMO: DEMO_VARS,
    SET: spEditorT,
  }}>
    window.__RETAHA_SE__ = { INITIAL, TRIGGER, DEMO, T: SET };
  </script>

  <script>
    function renderVars(text: string, ctx: Record<string, unknown>) {
      const re = /\{\{\s*([a-z_][a-z0-9_]*)\s*\}\}/gi;
      return text.replace(re, (full: string, name: string) => {
        const key = String(name).toLowerCase();
        if (key in ctx) {
          const v = ctx[key];
          return v == null ? '' : String(v);
        }
        return full;
      });
    }

    document.addEventListener('alpine:init', () => {
      // @ts-expect-error - Alpine global
      window.Alpine.data('stayPushEditor', () => ({
        cfg: (window as any).__RETAHA_SE__,
        submitting: false,
        errorMsg: '' as string,
        form: { title: '', body: '', is_active: false },

        init() {
          this.form.title = this.cfg.INITIAL.title;
          this.form.body  = this.cfg.INITIAL.body;
          this.form.is_active = this.cfg.INITIAL.is_active;
        },

        insertVar(key: string) {
          this.form.body += this.form.body && !this.form.body.endsWith(' ') ? ` {{${key}}}` : `{{${key}}}`;
        },

        get previewTitle() {
          return renderVars(this.form.title || this.cfg.T.noTitle, this.cfg.DEMO);
        },
        get previewBody() {
          return renderVars(this.form.body || this.cfg.T.noText, this.cfg.DEMO);
        },

        async save() {
          if (this.submitting) return;
          this.errorMsg = '';
          if (!this.form.title?.trim()) { this.errorMsg = this.cfg.T.titleRequired; return; }
          if (!this.form.body?.trim())  { this.errorMsg = this.cfg.T.bodyRequired; return; }

          this.submitting = true;
          try {
            const res = await fetch(`/api/stay-push/${this.cfg.TRIGGER}`, {
              method: 'PUT', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                title_default: this.form.title.trim(),
                body_default:  this.form.body.trim(),
                is_active: this.form.is_active,
              }),
            });
            const data = await res.json();
            if (!data.ok) {
              if (data.error === 'invalid_variables') {
                const parts: string[] = [];
                if (data.unknown?.length)   parts.push(this.cfg.T.unknownVars + ' ' + data.unknown.map((v: string) => `{{${v}}}`).join(', '));
                if (data.forbidden?.length) parts.push(this.cfg.T.forbiddenVars + ' ' + data.forbidden.map((v: string) => `{{${v}}}`).join(', '));
                this.errorMsg = parts.join(' · ');
              } else {
                this.errorMsg = data.error || this.cfg.T.saveFail;
              }
              return;
            }
            window.location.href = '/stay-pushes';
          } catch (err: any) {
            this.errorMsg = this.cfg.T.netErr + ' ' + (err.message || 'unbekannt');
          } finally {
            this.submitting = false;
          }
        },
      }));
    });
  </script>

  <style>
    .breadcrumb { padding-top: 28px; }
    :global(.h-dot) { color: #14616E; }

    /* Page container — flat/minimal like /nfc-tags */
    .sp-page { max-width: 1000px; margin: 0 auto; padding: 0 24px 60px; }

    /* Header */
    .sp-header { margin: 20px 0 24px; }
    .sp-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #14616E;
      margin: 0 0 6px;
    }
    .sp-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; }
    .sp-sub { margin: 0; font-size: 14px; color: var(--ink-soft); max-width: 720px; line-height: 1.5; }

    /* Two-col grid */
    .se-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 20px;
      align-items: flex-start;
    }
    @media (max-width: 960px) { .se-grid { grid-template-columns: 1fr; } }

    /* Form panel — flat, no border-radius */
    .se-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 24px;
    }

    /* Active toggle row */
    .se-toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 20px;
    }
    .se-toggle-label {
      font-size: 14px;
      font-weight: 500;
      color: var(--ink);
      margin: 0 0 2px;
    }
    .se-toggle-hint {
      font-size: 12px;
      color: var(--ink-muted);
      margin: 0;
    }

    .se-divider { height: 1px; background: var(--border); margin: 0 0 20px; }

    /* Fields */
    .se-field { margin-bottom: 20px; }
    .se-label {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 6px;
    }
    .se-input {
      width: 100%;
      box-sizing: border-box;
      padding: 9px 12px;
      font-family: inherit;
      font-size: 14px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--ink);
      transition: border-color .15s;
    }
    .se-input:focus { outline: none; border-color: #14616E; }
    .se-textarea { resize: vertical; min-height: 96px; line-height: 1.5; }
    .se-hint {
      margin: 6px 0 0;
      font-size: 12px;
      color: var(--ink-muted);
      line-height: 1.45;
    }
    .se-hint code {
      background: var(--bg-deep);
      padding: 1px 5px;
      font-family: 'JetBrains Mono', monospace;
      color: #14616E;
      font-style: normal;
    }

    /* Variable chips — flat */
    .se-var-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .se-var-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      background: var(--bg-deep);
      border: 1px solid var(--border);
      color: var(--ink-muted);
      cursor: pointer;
      font-family: inherit;
      font-size: 12px;
      transition: background .12s, color .12s, border-color .12s;
    }
    .se-var-chip:hover { background: rgba(20,97,110,.08); color: #14616E; border-color: rgba(20,97,110,.3); }
    .se-var-chip code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      opacity: .75;
      color: inherit;
    }

    /* Error */
    .se-error {
      padding: 12px 14px;
      background: rgba(122, 21, 21, .06);
      color: #7a1515;
      font-size: 13px;
      border-left: 3px solid #c0392b;
      margin: 0 0 16px;
    }

    /* Actions */
    .se-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      margin-top: 4px;
    }
    .se-btn-ghost {
      padding: 10px 18px;
      background: transparent;
      color: var(--ink-soft);
      border: 1px solid var(--border);
      text-decoration: none;
      font-size: 13px;
      font-family: inherit;
      cursor: pointer;
      transition: color .15s, border-color .15s;
    }
    .se-btn-ghost:hover { color: var(--ink); border-color: var(--ink); }
    .se-btn-primary {
      padding: 10px 22px;
      background: var(--ink, #1a1a1a);
      color: var(--surface, #fff);
      border: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      font-family: inherit;
      transition: background .15s;
    }
    .se-btn-primary:hover:not(:disabled) { background: #14616E; }
    .se-btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    /* Preview panel — flat, no border-radius */
    .se-preview-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 24px;
    }
    .se-preview-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin: 0 0 4px;
    }
    .se-preview-hint {
      font-size: 12px;
      color: var(--ink-muted);
      margin: 0 0 20px;
    }

    /* Phone mockup */
    .se-mockup { display: flex; justify-content: center; }
    .se-mockup-frame {
      width: 100%;
      max-width: 260px;
      background: #12262d;
      padding: 14px 10px 22px;
      border-radius: 24px;
      box-shadow: 0 16px 40px -12px rgba(0,0,0,.28);
    }
    .se-mockup-status {
      color: rgba(255,255,255,.5);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-align: center;
      padding: 4px 0 12px;
      font-family: 'JetBrains Mono', monospace;
    }
    .se-mockup-card {
      background: #fff;
      padding: 13px;
      border-radius: 10px;
      margin: 0 6px;
    }
    .se-mockup-brand { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .se-mockup-logo {
      width: 28px;
      height: 28px;
      background: #14616E;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      border-radius: 4px;
      font-family: 'Space Grotesk', sans-serif;
    }
    .se-mockup-hotel { font-size: 12px; font-weight: 600; color: #111; font-family: 'Space Grotesk', sans-serif; }
    .se-mockup-now { font-size: 10px; color: #888; }
    .se-mockup-title { font-size: 14px; font-weight: 600; color: #111; margin: 0 0 5px; line-height: 1.3; font-family: 'Space Grotesk', sans-serif; }
    .se-mockup-body { font-size: 12px; line-height: 1.5; color: #555; white-space: pre-wrap; }
    .se-mockup-note {
      color: rgba(255,255,255,.35);
      font-size: 9px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-align: center;
      padding-top: 12px;
      font-family: 'JetBrains Mono', monospace;
    }
  </style>
</Layout>
