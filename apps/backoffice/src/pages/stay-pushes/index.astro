---
import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import {
  STAY_PUSH_TRIGGER_ORDER,
} from '@retaha/marketing';
import { STAY_PUSH_DEFAULTS } from '@retaha/wallet';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) return new Response('Forbidden', { status: 403 });

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: templates } = await client
  .from('stay_push_templates')
  .select('trigger_type, title_i18n, body_i18n, is_active, updated_at')
  .eq('hotel_id', hotel.id);

const tplByTrigger = new Map((templates ?? []).map((t: any) => [t.trigger_type, t]));
const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '';
  return jsonb[hotelDefaultLang]?.value ?? (Object.values(jsonb)[0] as any)?.value ?? '';
}

const activeCount = STAY_PUSH_TRIGGER_ORDER.filter(t => {
  const tpl = tplByTrigger.get(t) as any;
  return tpl?.is_active === true;
}).length;
---

<Layout title="Stay-Pushes" activeTab="backoffice">
  <div
    class="settings-page"
    x-data={`{
      showToneInput: false,
      eveTone: '',
      busySet: false,
      eveSuggestions: [],
      applyStates: {},
      async generateSet() {
        this.busySet = true;
        this.eveSuggestions = [];
        try {
          const res = await fetch('/api/stay-pushes/generate', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tone: this.eveTone.trim() }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) { alert('Eve konnte keine Texte generieren. Bitte versuche es erneut.'); return; }
          this.eveSuggestions = data.suggestions ?? [];
          this.applyStates = {};
        } catch { alert('Netzwerkfehler — bitte erneut versuchen.'); }
        finally { this.busySet = false; }
      },
      async applyOne(s) {
        this.applyStates[s.trigger_type] = 'busy';
        try {
          const res = await fetch('/api/stay-push/' + s.trigger_type, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title_default: s.title, body_default: s.body }),
          });
          this.applyStates[s.trigger_type] = res.ok ? 'done' : 'err';
        } catch { this.applyStates[s.trigger_type] = 'err'; }
      },
    }`}
  >

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/overview" class="breadcrumb__crumb">{bt('nav.sec.overview', lang)}</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">{bt('sp.eyebrow', lang)}</span>
    </nav>

    <section class="settings-hero">
      <h1 class="settings-hero__title" set:html={bt('sp.title', lang)}></h1>
      <p class="settings-hero__sub" set:html={bt('sp.sub', lang)}></p>
    </section>

    <!-- KPI-Bar -->
    <div class="sp-kpis">
      <div class="sp-kpi">
        <div class="sp-kpi-label">Aktive Trigger</div>
        <div class="sp-kpi-value">{activeCount}</div>
        <div class="sp-kpi-sub">von {STAY_PUSH_TRIGGER_ORDER.length} gesamt</div>
      </div>
      <div class="sp-kpi">
        <div class="sp-kpi-label">Konfiguriert</div>
        <div class="sp-kpi-value">{tplByTrigger.size}</div>
        <div class="sp-kpi-sub">Hotel-eigene Templates</div>
      </div>
    </div>

    <!-- Eve Box -->
    <div class="evecard">
      <div class="ec-head">
        <svg class="ec-spk" width="15" height="15" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
        <b><span class="ec-gradient">Eve</span> kennt euer Haus</b>
      </div>

      <div x-show="!busySet">
        <p class="ec-desc">Eve liest eure Hoteldaten und bringt alle 9 Nachrichten in einen Ton, der zu eurem Haus passt — ihr müsst nichts eingeben. Ein Klick, gegenlesen, aktivieren.</p>
        <div class="ec-primary-row">
          <button class="ly-btn ly-aurora" @click="generateSet()">
            <svg class="ec-spk-anim" width="13" height="13" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>
            Mit Eve anpassen
          </button>
        </div>

        <!-- Optionaler Ton-Override (sekundär, eingeklappt) -->
        <div class="ec-tone-toggle">
          <button type="button" class="ec-tone-toggle-btn" @click="showToneInput = !showToneInput">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" :style="showToneInput ? 'transform:rotate(90deg)' : ''" style="transition:transform .15s; flex-shrink:0"><path d="M9 18l6-6-6-6"/></svg>
            Ton lieber selbst vorgeben?
          </button>
        </div>
        <div x-show="showToneInput" x-cloak class="ec-tone-field">
          <input
            type="text"
            class="ec-brief"
            x-model="eveTone"
            @keydown.enter="generateSet()"
            placeholder="z. B. entspannt und per Du"
            maxlength="200"
          />
        </div>
      </div>

      <div class="ec-gen" x-show="busySet">
        <div class="ec-sk">
          <i></i>
          <i></i>
          <i></i>
        </div>
      </div>

      <template x-if="eveSuggestions.length > 0">
        <div class="ec-results">
          <div class="ec-results-head">
            <span class="ec-results-label">Vorschläge von Eve</span>
          </div>
          <div class="ec-results-list">
            <template x-for="s in eveSuggestions" :key="s.trigger_type">
              <div class="ec-result-item">
                <div class="ec-result-texts">
                  <span class="ec-result-trigger" x-text="s.trigger_type.replace(/_/g, ' ')"></span>
                  <strong class="ec-result-title" x-text="s.title"></strong>
                  <span class="ec-result-body" x-text="s.body"></span>
                </div>
                <div class="ec-result-actions">
                  <button
                    class="ec-apply-btn"
                    :class="applyStates[s.trigger_type] === 'done' ? 'ec-apply-btn--done' : applyStates[s.trigger_type] === 'err' ? 'ec-apply-btn--err' : ''"
                    :disabled="applyStates[s.trigger_type] === 'busy' || applyStates[s.trigger_type] === 'done'"
                    @click="applyOne(s)"
                    x-text="applyStates[s.trigger_type] === 'done' ? '✓ Gespeichert' : applyStates[s.trigger_type] === 'err' ? 'Fehler' : applyStates[s.trigger_type] === 'busy' ? '…' : 'Übernehmen'"
                  ></button>
                  <button
                    class="ec-dismiss-btn"
                    :disabled="applyStates[s.trigger_type] === 'busy'"
                    @click="eveSuggestions = eveSuggestions.filter(x => x.trigger_type !== s.trigger_type)"
                    aria-label="Ablehnen"
                  >✕</button>
                </div>
              </div>
            </template>
          </div>
        </div>
      </template>
    </div>

    <!-- Trigger-Grid -->
    <div class="sp-grid">
      {STAY_PUSH_TRIGGER_ORDER.map((trigger) => {
        const t = tplByTrigger.get(trigger) as any;
        const defaults = STAY_PUSH_DEFAULTS[trigger] ?? { title: '', body: '' };
        const previewTitle = pickI18n(t?.title_i18n) || defaults.title;
        const previewBody  = pickI18n(t?.body_i18n)  || defaults.body;
        const isActive = t?.is_active === true;
        return (
          <a href={`/stay-pushes/${trigger}`} class={`sp-card${isActive ? '' : ' sp-card--off'}`}>
            <div class="sp-card-head">
              <div class="sp-pill-wrap">
                <span class={`sp-pill${isActive ? ' sp-pill--active' : ''}`}>
                  {isActive ? bt('nfc.pill.active', lang) : bt('nfc.pill.inactive', lang)}
                </span>
              </div>
            </div>
            <p class="sp-card-trigger">{bt('sp.trigger.' + trigger + '.label', lang)}</p>
            <p class="sp-card-preview">
              {previewTitle ? previewTitle : <em>{bt('sp.notconfigured', lang)}</em>}
            </p>
            {previewBody && <p class="sp-card-body">{previewBody}</p>}
            <p class="sp-card-desc">{bt('sp.trigger.' + trigger + '.desc', lang)}</p>
          </a>
        );
      })}
    </div>

    <div class="sp-footnote" set:html={bt('sp.footnote', lang)}></div>
  </div>

  <style>
    /* CSS vars for Eve Box (same as action-cards) */
    .settings-page {
      --ly-aurora: linear-gradient(115deg,#14616E 0%,#1AA0B0 34%,#5B7CE0 68%,#14616E 100%);
      --ly-ink:   var(--ink,   rgba(10,10,10,0.88));
      --ly-ink2:  var(--ink-soft,  rgba(10,10,10,0.65));
      --ly-ink3:  var(--ink-muted, rgba(10,10,10,0.42));
      --ly-line:  var(--border-medium, rgba(10,10,10,0.16));
      --ly-line2: var(--bg-deep, #F0EFEA);
      --ly-ac:    #14616E;
      --ly-surf:  var(--surface, #FFFFFF);
    }
    @keyframes ly-flow    { to { background-position: 0 0, 240% 0; } }
    @keyframes ly-breathe { 0%,100%{transform:scale(1)} 50%{transform:scale(1.25)} }
    @keyframes ly-twinkle { 0%,100%{transform:scale(1) rotate(0);opacity:1} 50%{transform:scale(1.3) rotate(90deg);opacity:.7} }

    .breadcrumb { padding-top: 36px; }
    :global(.h-dot) { color: #14616E; }

    /* ── Eve card ───────────────────────────────────────────────────────────── */
    .evecard {
      position: relative;
      border: 1.6px solid transparent;
      border-radius: 16px;
      padding: 20px 22px;
      margin-bottom: 28px;
      background: linear-gradient(#fff,#fff) padding-box, var(--ly-aurora) border-box;
      background-size: auto, 240% 100%;
      animation: ly-flow 7s linear infinite;
      box-shadow: 0 8px 30px rgba(45,91,208,.12);
    }
    .ec-head {
      display: flex; align-items: center; gap: 9px; margin-bottom: 6px;
      font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 16px;
    }
    .ec-spk { color: #2E72C8; flex-shrink: 0; }
    .ec-gradient {
      background: var(--ly-aurora); background-size: 240% 100%;
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
      animation: ly-flow 5s linear infinite; font-weight: 700;
    }
    .ec-desc { font-size: 13px; color: var(--ly-ink2); line-height: 1.55; margin-bottom: 16px; max-width: 560px; }
    .ec-primary-row { margin-bottom: 14px; }
    .ec-tone-toggle { margin-bottom: 0; }
    .ec-tone-toggle-btn {
      background: none; border: none; padding: 0; cursor: pointer;
      font-size: 12px; color: var(--ly-ink3); display: inline-flex; align-items: center; gap: 5px;
      font-family: inherit; transition: color .15s;
    }
    .ec-tone-toggle-btn:hover { color: var(--ly-ac); }
    .ec-tone-field { margin-top: 10px; }
    .ec-row { display: flex; gap: 10px; align-items: stretch; }
    .ec-brief {
      flex: 1; border: 1px solid var(--ly-line); border-radius: 12px;
      padding: 10px 14px; font-size: 14px; font-family: 'Space Grotesk', sans-serif;
      color: var(--ly-ink); background: var(--ly-surf);
      outline: none; transition: border-color 150ms, box-shadow 150ms; width: 100%; box-sizing: border-box;
    }
    .ec-brief:focus { border-color: var(--ly-ac); box-shadow: 0 0 0 3px rgba(20,97,110,0.12); }
    .ec-brief::placeholder { color: var(--ly-ink3); }
    .ec-spk-anim { animation: ly-twinkle 2.4s ease-in-out infinite; }
    .ec-gen { padding: 28px 0 20px; }
    .ec-sk { display: flex; flex-direction: column; gap: 9px; width: 74%; }
    .ec-sk i {
      display: block; height: 9px; border-radius: 5px;
      background: var(--ly-line2, #ECE8E0); position: relative; overflow: hidden;
    }
    .ec-sk i::after {
      content: ''; position: absolute; inset: 0; transform: translateX(-100%);
      background: linear-gradient(90deg, transparent, rgba(26,160,176,.6), rgba(91,124,224,.6), transparent);
      animation: ec-sk-sweep 1.6s ease-in-out infinite;
    }
    .ec-sk i:nth-child(1) { width: 88%; }
    .ec-sk i:nth-child(2) { width: 100%; }
    .ec-sk i:nth-child(2)::after { animation-delay: .18s; }
    .ec-sk i:nth-child(3) { width: 60%; }
    .ec-sk i:nth-child(3)::after { animation-delay: .36s; }
    @keyframes ec-sk-sweep { to { transform: translateX(100%); } }

    /* Aurora button */
    .ly-btn {
      cursor: pointer; display: inline-flex; align-items: center; gap: 7px;
      white-space: nowrap; border-radius: 9px;
    }
    .ly-aurora {
      color: #fff; border: 0;
      font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: .05em; text-transform: uppercase;
      padding: 8px 13px;
      background: var(--ly-aurora); background-size: 280% 100%;
      animation: ly-flow 6s linear infinite;
      box-shadow: 0 5px 16px rgba(20,97,110,.28);
      transition: transform .15s, box-shadow .2s;
    }
    .ly-aurora:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 9px 26px rgba(45,91,208,.38); animation-duration: 2.2s; }
    .ly-aurora:disabled { opacity: .55; cursor: not-allowed; transform: none; }

    /* Results list */
    .ec-results { margin-top: 16px; border-top: 1px solid rgba(20,97,110,.18); padding-top: 14px; }
    .ec-results-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .ec-results-label {
      font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ly-ac); font-weight: 500;
    }
    .ec-results-list { display: flex; flex-direction: column; gap: 8px; }
    .ec-result-item {
      display: flex; align-items: center; justify-content: space-between; gap: 14px;
      padding: 10px 14px; border-radius: 10px; background: rgba(20,97,110,.04);
      border: 1px solid rgba(20,97,110,.10);
    }
    .ec-result-texts { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
    .ec-result-trigger {
      font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--ly-ink3); margin-bottom: 2px;
    }
    .ec-result-title { font-size: 13px; font-weight: 600; color: var(--ly-ink); }
    .ec-result-body {
      font-size: 12px; color: var(--ly-ink2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .ec-apply-btn {
      flex-shrink: 0;
      padding: 6px 12px; font-size: 12px; font-weight: 500; font-family: inherit;
      border: 1px solid var(--ly-ac); border-radius: 8px;
      background: transparent; color: var(--ly-ac);
      cursor: pointer; white-space: nowrap;
      transition: background .15s, color .15s;
    }
    .ec-apply-btn:hover:not(:disabled) { background: var(--ly-ac); color: #fff; }
    .ec-apply-btn:disabled { opacity: .5; cursor: not-allowed; }
    .ec-apply-btn--done { background: #14616E; color: #fff; border-color: #14616E; }
    .ec-apply-btn--err  { border-color: #c0392b; color: #c0392b; }
    .ec-result-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .ec-dismiss-btn {
      aspect-ratio: 1; align-self: stretch;
      display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border, #e5e4e0); border-radius: 7px;
      background: transparent; color: var(--ly-ink3); font-size: 11px;
      cursor: pointer; transition: background .12s, color .12s, border-color .12s;
      flex-shrink: 0; line-height: 1;
    }
    .ec-dismiss-btn:hover:not(:disabled) { background: #fef2f2; border-color: #fca5a5; color: #c0392b; }
    .ec-dismiss-btn:disabled { opacity: .4; cursor: not-allowed; }

    /* KPI mini-bar */
    .sp-kpis { display: flex; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
    .sp-kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 20px 24px; min-width: 140px; }
    .sp-kpi-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 6px; }
    .sp-kpi-value { font-family: 'Space Grotesk', sans-serif; font-size: 30px; font-weight: 500; line-height: 1; color: var(--ink); margin-bottom: 4px; }
    .sp-kpi-sub { font-size: 12px; color: var(--ink-muted); }

    /* Grid — 3 Karten pro Zeile */
    .sp-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    @media (max-width: 900px) { .sp-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .sp-grid { grid-template-columns: 1fr; } }

    .sp-card {
      display: flex;
      flex-direction: column;
      padding: 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      text-decoration: none;
      color: inherit;
      transition: box-shadow .16s ease, transform .16s ease;
    }
    .sp-card:hover { box-shadow: 0 12px 32px rgba(40,30,20,.10); transform: translateY(-2px); }
    /* Inactive: dim only the border, not the text */
    .sp-card--off { border-color: rgba(0,0,0,.07); background: var(--bg-deep, #F7F6F2); }
    .sp-card--off .sp-card-trigger,
    .sp-card--off .sp-card-preview,
    .sp-card--off .sp-card-body,
    .sp-card--off .sp-card-desc { opacity: .55; }

    .sp-card-head { margin-bottom: 12px; }

    /* Status pill — ce-seg style (wie in Kampagnen-Editor Kanal) */
    .sp-pill-wrap {
      display: inline-flex;
      border: 1px solid var(--border, #E5E4E0);
      border-radius: 10px;
      padding: 3px;
      background: var(--surface, #fff);
    }
    .sp-pill {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      padding: 5px 10px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 7px;
      font-weight: 500;
      color: var(--ink-muted);
      background: transparent;
    }
    .sp-pill--active { background: #14616E; color: #fff; }

    .sp-card-trigger {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 15px;
      font-weight: 500;
      color: var(--ink);
      margin: 0 0 6px;
      letter-spacing: -0.01em;
    }
    .sp-card-preview {
      margin: 0 0 4px;
      font-family: 'Inter Tight', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: var(--ink-soft, var(--ink-muted));
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .sp-card-preview em { color: var(--ink-muted); font-style: italic; }
    .sp-card-body {
      margin: 0 0 8px;
      font-family: 'Inter Tight', sans-serif;
      font-size: 12px;
      color: var(--ink-muted);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      flex: 1;
    }
    .sp-card-desc { margin: 0; font-size: 11px; color: var(--ink-muted); line-height: 1.45; }

    .sp-footnote { margin-top: 32px; padding: 16px 20px; background: var(--surface); border: 1px solid var(--border); border-radius: 14px; font-size: 13px; line-height: 1.5; color: var(--ink-soft, var(--ink-muted)); }
    .sp-footnote strong { color: var(--ink); }
    .sp-footnote code { background: var(--bg-deep); padding: 1px 6px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink); }
  </style>
</Layout>
