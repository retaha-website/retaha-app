---
import Layout from '../../layouts/Layout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import {
  STAY_PUSH_TRIGGER_ORDER,
} from '@retaha/marketing';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user || !user.email) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.read')) return new Response('Forbidden', { status: 403 });

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: templates } = await client
  .from('stay_push_templates')
  .select('trigger_type, title_i18n, is_active, updated_at')
  .eq('hotel_id', hotel.id);

const tplByTrigger = new Map((templates ?? []).map((t: any) => [t.trigger_type, t]));
const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '';
  return jsonb[hotelDefaultLang]?.value ?? Object.values(jsonb)[0]?.value ?? '';
}
---

<Layout title="Stay-Pushes" activeTab="backoffice">
  <div class="sp-page">
    <header class="sp-header">
      <p class="sp-eyebrow">{bt('sp.eyebrow', lang)}</p>
      <h1 class="sp-title" set:html={bt('sp.title', lang)}></h1>
      <p class="sp-sub" set:html={bt('sp.sub', lang)}></p>
    </header>

    <div class="sp-list">
      {STAY_PUSH_TRIGGER_ORDER.map((trigger) => {
        const t = tplByTrigger.get(trigger) as any;
        const preview = pickI18n(t?.title_i18n);
        const active = t?.is_active !== false;
        return (
          <a href={`/stay-pushes/${trigger}`} class={`sp-card${active ? '' : ' sp-card--off'}`}>
            <div class="sp-card-head">
              <span class={`sp-pill${active ? ' is-on' : ''}`}>{active ? bt('nfc.pill.active', lang) : bt('nfc.pill.inactive', lang)}</span>
              <span class="sp-card-trigger">{bt('sp.trigger.' + trigger + '.label', lang)}</span>
            </div>
            <p class="sp-card-preview">{preview || <em>{bt('sp.notconfigured', lang)}</em>}</p>
            <p class="sp-card-sub">{bt('sp.trigger.' + trigger + '.desc', lang)}</p>
          </a>
        );
      })}
    </div>

    <div class="sp-footnote" set:html={bt('sp.footnote', lang)}></div>
  </div>

  <style>
    .sp-page { --surface-raised: var(--bg-deep); max-width: 1000px; margin: 0 auto; padding: 0 24px 60px; }
    .sp-header { margin: 20px 0 28px; }
    .sp-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--te-pink, #FF4A82); margin: 0 0 6px; }
    .sp-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; }
    .sp-sub { margin: 0; font-size: 14px; color: var(--ink-soft); max-width: 720px; line-height: 1.5; }
    .sp-sub strong { color: var(--ink); }

    .sp-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px; }
    .sp-card { display: block; background: var(--surface); border: 1px solid var(--border); padding: 18px; text-decoration: none; color: inherit; transition: border-color .15s, transform .15s; }
    .sp-card:hover { border-color: var(--ink); transform: translateY(-1px); }
    .sp-card--off { opacity: .55; }
    .sp-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .sp-pill { font-size: 10px; padding: 3px 8px; text-transform: uppercase; letter-spacing: 0.05em; background: var(--surface-raised); color: var(--ink-muted); }
    .sp-pill.is-on { background: rgba(76,175,80,.1); color: #4CAF50; border: 1px solid rgba(76,175,80,.35); }
    .sp-card-trigger { font-size: 12px; font-weight: 500; color: var(--ink); letter-spacing: 0.02em; }
    .sp-card-preview { font-size: 14px; color: var(--ink); margin: 6px 0; line-height: 1.4; }
    .sp-card-preview em { color: var(--ink-muted); font-style: italic; }
    .sp-card-sub { font-size: 11px; color: var(--ink-muted); margin: 0; line-height: 1.45; }

    .sp-footnote { margin-top: 32px; padding: 14px 18px; background: var(--surface-raised); border-left: 3px solid var(--border); font-size: 13px; line-height: 1.5; color: var(--ink-soft); }
    .sp-footnote strong { color: var(--ink); }
    .sp-footnote code { background: var(--surface); padding: 1px 5px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink); }
  </style>
</Layout>
