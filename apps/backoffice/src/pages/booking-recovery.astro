import Layout from '../layouts/Layout.astro';
import ComingSoonModal from '@retaha/ui/components/admin/ComingSoonModal.astro';
import { getUser, getUserHotels } from '@retaha/auth';
import { getLang, bt } from '../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');
---

<Layout title="Booking-Recovery" activeTab="backoffice">
  <ComingSoonModal
    feature_name="buchungs-recovery"
    feature_eyebrow={bt('cs.recovery.eyebrow', lang)}
    feature_description={bt('cs.recovery.desc', lang)}
    planned_release="Q1 2027"
    status_label={bt('cs.status', lang)}
    meta_label={bt('cs.meta', lang)}
    back_label={bt('cs.back', lang)}
    close_label={bt('cs.close', lang)}
  />
</Layout>
