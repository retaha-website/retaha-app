---
import OnboardingLayout from '../../../layouts/OnboardingLayout.astro';
import { t } from '../../../i18n/helpers';
import { getUser, createSupabaseServerInstance } from '@retaha/auth';
import type { AdminLocale } from '../../../i18n/types';

const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const ssrClient = createSupabaseServerInstance(Astro.cookies, Astro.request);

// Vorbelegung: existing user_profile laden falls schon angelegt
const { data: existingProfile } = await ssrClient
  .from('user_profiles')
  .select('first_name, last_name')
  .eq('user_id', user.id)
  .maybeSingle();

let errors: Record<string, string> = {};
let formData = {
  first_name: existingProfile?.first_name ?? '',
  last_name: existingProfile?.last_name ?? '',
};

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  formData = {
    first_name: (data.get('first_name')?.toString() ?? '').trim(),
    last_name: (data.get('last_name')?.toString() ?? '').trim(),
  };

  if (!formData.first_name) errors.first_name = t('onboarding.setup.error_required', userLocale);
  if (!formData.last_name) errors.last_name = t('onboarding.setup.error_required', userLocale);

  if (Object.keys(errors).length === 0) {
    // Upsert via RLS-Client (auth.uid() === user.id check greift)
    const { error } = await ssrClient
      .from('user_profiles')
      .upsert(
        {
          user_id: user.id,
          first_name: formData.first_name,
          last_name: formData.last_name,
          updated_at: new Date().toISOString(),
        },
        { onConflict: 'user_id' },
      );

    if (error) {
      errors._global = 'Speichern fehlgeschlagen: ' + error.message;
    } else {
      return Astro.redirect('/onboarding/setup/hotel');
    }
  }
}
---

<OnboardingLayout title="Dein Name" locale={userLocale}>
  <main class="onboarding-wizard-page">

    <section class="onboarding-wizard-content">
      <p class="onboarding-wizard-eyebrow">— Schritt 1 von 3 —</p>
      <h1 class="onboarding-wizard-headline">
        <span class="onboarding-wizard-headline-light">Schön dich</span>
        <span class="onboarding-wizard-headline-bold">kennenzulernen<span class="onboarding-wizard-dot">.</span></span>
      </h1>
      <p class="onboarding-wizard-subtitle">
        Wie heißt du? Wir nutzen das, um dich in Emails persönlich anzusprechen.
      </p>

      {errors._global && (
        <div class="onboarding-wizard-error" style="margin-bottom: 20px; padding: 12px 16px; background:#fee; border-left:4px solid #c00; color:#900; font-size:13px">
          {errors._global}
        </div>
      )}

      <form method="POST" class="onboarding-wizard-form">
        <div class="onboarding-wizard-field-row">
          <label class="onboarding-wizard-field">
            <span class="onboarding-wizard-field-eyebrow">— Vorname —</span>
            <input
              type="text"
              name="first_name"
              value={formData.first_name}
              required
              autocomplete="given-name"
              class={`onboarding-wizard-input${errors.first_name ? ' is-error' : ''}`}
              placeholder="z.B. Kristin"
              autofocus
            />
            {errors.first_name && <span class="onboarding-wizard-field-error">{errors.first_name}</span>}
          </label>

          <label class="onboarding-wizard-field">
            <span class="onboarding-wizard-field-eyebrow">— Nachname —</span>
            <input
              type="text"
              name="last_name"
              value={formData.last_name}
              required
              autocomplete="family-name"
              class={`onboarding-wizard-input${errors.last_name ? ' is-error' : ''}`}
              placeholder="z.B. Riewe"
            />
            {errors.last_name && <span class="onboarding-wizard-field-error">{errors.last_name}</span>}
          </label>
        </div>

        <div class="onboarding-wizard-actions">
          <button type="submit" class="onboarding-wizard-button onboarding-wizard-button--primary">
            Weiter →
          </button>
        </div>
      </form>
    </section>

  </main>
</OnboardingLayout>
