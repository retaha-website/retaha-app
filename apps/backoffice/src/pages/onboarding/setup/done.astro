---
import OnboardingLayout from '../../../layouts/OnboardingLayout.astro';
import { t } from '../../../i18n/helpers';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { calculateTrialStatus } from '../../../lib/trial-status';
import type { AdminLocale } from '../../../i18n/types';

const userLocale: AdminLocale = (Astro.locals.locale ?? 'de') as AdminLocale;

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/onboarding/setup/hotel?error=no_hotel_yet');

// Trial-End-Datum via zentralem Helper (single source of truth)
const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: hotelRow } = await client
  .from('hotels')
  .select('trial_started_at, subscription_status')
  .eq('id', hotel.id)
  .maybeSingle();

const trialStatus = hotelRow
  ? calculateTrialStatus(hotelRow as { trial_started_at: string | null; subscription_status: string })
  : null;
const trialEndDate = trialStatus?.endsAt ?? null;

const trialEndFormatted = trialEndDate?.toLocaleDateString(userLocale === 'en' ? 'en-US' : 'de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<OnboardingLayout title={t('onboarding.setup.done_page_title', userLocale)} locale={userLocale}>
  <main class="onboarding-wizard-page">

    <section class="onboarding-wizard-strip">
      <div class="onboarding-wizard-strip-inner">
        <div class="onboarding-wizard-progress">
          <div class="onboarding-wizard-progress-markers" aria-hidden="true">
            <span class="onboarding-wizard-progress-marker onboarding-wizard-progress-marker--circle is-active"></span>
            <span class="onboarding-wizard-progress-line is-active"></span>
            <span class="onboarding-wizard-progress-marker onboarding-wizard-progress-marker--triangle is-active"></span>
            <span class="onboarding-wizard-progress-line is-active"></span>
            <span class="onboarding-wizard-progress-marker onboarding-wizard-progress-marker--square is-active is-current"></span>
          </div>
          <p class="onboarding-wizard-progress-label">— {t('onboarding.setup.step3_progress', userLocale)} —</p>
        </div>
        <p class="onboarding-wizard-brand">retaha</p>
      </div>
    </section>

    <section class="onboarding-done-hero">
      <div class="onboarding-done-hero-inner">
        <div class="onboarding-done-hero-markers" aria-hidden="true">
          <span class="onboarding-done-hero-marker onboarding-done-hero-marker--circle"></span>
          <span class="onboarding-done-hero-marker onboarding-done-hero-marker--line"></span>
          <span class="onboarding-done-hero-marker onboarding-done-hero-marker--square"></span>
        </div>

        <p class="onboarding-done-hero-eyebrow">— {t('onboarding.setup.done_eyebrow', userLocale)} —</p>

        <h1 class="onboarding-done-hero-headline">
          <span class="onboarding-done-hero-headline-light">{t('onboarding.setup.done_headline_light', userLocale)}</span>
          <span class="onboarding-done-hero-headline-bold">{t('onboarding.setup.done_headline_bold', userLocale)}<span class="onboarding-done-hero-headline-punkt">.</span></span>
        </h1>

        {trialEndFormatted && (
          <p class="onboarding-done-hero-sub">
            {t('onboarding.setup.done_trial_text', userLocale)} {trialEndFormatted}.
          </p>
        )}

        <div class="onboarding-done-ctas">
          <a href="/uebersicht?onboarding=tour_start" class="onboarding-done-cta onboarding-done-cta--primary">
            <span class="onboarding-done-cta-bullet" aria-hidden="true"></span>
            {t('onboarding.setup.done_cta_tour', userLocale)}
          </a>
          <a href="/uebersicht" class="onboarding-done-cta onboarding-done-cta--secondary">
            {t('onboarding.setup.done_cta_direct', userLocale)} →
          </a>
        </div>
      </div>
    </section>

    <section class="onboarding-done-next">
      <div class="onboarding-done-next-inner">
        <p class="onboarding-done-next-eyebrow">— {t('onboarding.setup.done_next_eyebrow', userLocale)} —</p>
        <h2 class="onboarding-done-next-headline">
          {t('onboarding.setup.done_next_headline_a', userLocale)}{' '}
          <span class="onboarding-done-next-headline-bold">{t('onboarding.setup.done_next_headline_b', userLocale)}</span><span class="onboarding-done-next-headline-punkt">.</span>
        </h2>

        <div class="onboarding-done-next-grid">
          <article>
            <span class="onboarding-done-next-marker onboarding-done-next-marker--circle" aria-hidden="true"></span>
            <p class="onboarding-done-next-eyebrow-item">— {t('onboarding.setup.next_1_eyebrow', userLocale)} —</p>
            <p class="onboarding-done-next-text">{t('onboarding.setup.next_1_text', userLocale)}</p>
          </article>

          <article>
            <span class="onboarding-done-next-marker onboarding-done-next-marker--triangle" aria-hidden="true"></span>
            <p class="onboarding-done-next-eyebrow-item">— {t('onboarding.setup.next_2_eyebrow', userLocale)} —</p>
            <p class="onboarding-done-next-text">{t('onboarding.setup.next_2_text', userLocale)}</p>
          </article>

          <article>
            <span class="onboarding-done-next-marker onboarding-done-next-marker--square" aria-hidden="true"></span>
            <p class="onboarding-done-next-eyebrow-item">— {t('onboarding.setup.next_3_eyebrow', userLocale)} —</p>
            <p class="onboarding-done-next-text">{t('onboarding.setup.next_3_text', userLocale)}</p>
          </article>
        </div>
      </div>
    </section>

  </main>
</OnboardingLayout>
