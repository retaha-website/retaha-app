---
// Fonts
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
// @retaha/ui CSS (enthält @import "tailwindcss" + @theme + Bauhaus-Komponenten)
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/v9-colors.css';
import '@retaha/ui/styles/tokens.css';
import '@retaha/ui/styles/global.css';
import '@retaha/ui/styles/retaha.css';
import '@retaha/ui/styles/icons.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/pills.css';
import '@retaha/ui/styles/components/menu.css';
import '@retaha/ui/styles/components/settings.css';
import '@retaha/ui/styles/components/status-markers.css';

import Header from '../components/header/Header.astro';
import Footer from '../components/footer/Footer.astro';
import { getUserProfileForLayout } from '../lib/auth/get-user-profile';

interface Props {
  title: string;
  activeTab: 'gast' | 'backoffice' | 'admin';
  hotelName?: string;
  hotelLocation?: string;
  hotelStars?: number;
  hotelLogoUrl?: string | null;
}

const {
  title,
  activeTab,
  hotelName,
  hotelLocation,
  hotelStars,
  hotelLogoUrl,
} = Astro.props;

const userProfile = await getUserProfileForLayout(Astro.cookies, Astro.request);

if (!userProfile) {
  const authUrl = import.meta.env.AUTH_APP_URL ?? 'https://auth.retaha.de';
  return Astro.redirect(`${authUrl}/login`);
}

if (userProfile.role === 'staff') {
  return Astro.redirect('/uebersicht');
}

const displayHotelName    = hotelName    ?? userProfile.hotel_name;
const displayHotelLogoUrl = hotelLogoUrl !== undefined ? hotelLogoUrl : userProfile.hotel_logo_url;

---

<!DOCTYPE html>
<html lang={userProfile.language} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FAFAF8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · retaha</title>
  </head>
  <body>
    <Header
      activeTab={activeTab}
      user={userProfile}
      hotelName={displayHotelName}
      hotelLocation={hotelLocation}
      hotelStars={hotelStars}
      hotelLogoUrl={displayHotelLogoUrl}
    />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Theme-Toggle
      const stored = localStorage.getItem('v9-theme');
      if (stored === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>

    <script>
      // Alpine.js — für alle Pages (admin + V9)
      import Alpine from 'alpinejs';
      import collapse from '@alpinejs/collapse';
      Alpine.plugin(collapse);
      // @ts-expect-error
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
