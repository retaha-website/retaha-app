---
// Fonts
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
// @retaha/ui CSS (enthält @import "tailwindcss" + @theme + Bauhaus-Komponenten)
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/v9-colors.css';
import '@retaha/ui/styles/tokens.css';
import '@retaha/ui/styles/global.css';
import '@retaha/ui/styles/retaha.css';
import '@retaha/ui/styles/icons.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/pills.css';
import '@retaha/ui/styles/components/menu.css';
import '@retaha/ui/styles/components/settings.css';
import '@retaha/ui/styles/components/admin-page.css';
import '@retaha/ui/styles/components/status-markers.css';

import Header from '../components/header/Header.astro';
import Footer from '@retaha/ui/components/shared/Footer.astro';
import ConfirmModal from '../components/shared/ConfirmModal.astro';
import Toast from '@retaha/ui/components/shared/Toast.astro';
import { getUserProfileForLayout } from '../lib/auth/get-user-profile';
import { isRTL } from '@retaha/i18n';

interface Props {
  title: string;
  activeTab: 'gast' | 'backoffice' | 'admin';
  hotelName?: string;
  hotelLocation?: string;
  hotelStars?: number;
  hotelLogoUrl?: string | null;
}

const {
  title,
  activeTab,
  hotelName,
  hotelLocation,
  hotelStars,
  hotelLogoUrl,
} = Astro.props;

const userProfile = await getUserProfileForLayout(Astro.cookies, Astro.request);

if (!userProfile) {
  const authUrl = import.meta.env.AUTH_APP_URL ?? 'https://auth.retaha.de';
  return Astro.redirect(`${authUrl}/login`);
}

if (userProfile.role === 'staff') {
  return Astro.redirect('/overview');
}

const displayHotelName    = hotelName    ?? userProfile.hotel_name;
const displayHotelLogoUrl = hotelLogoUrl !== undefined ? hotelLogoUrl : userProfile.hotel_logo_url;

---

<!DOCTYPE html>
<html lang={userProfile.language} dir={isRTL(userProfile.language) ? 'rtl' : 'ltr'} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FAFAF8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/apple-touch-icon-167x167.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon-precomposed.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title} · retaha</title>
  </head>
  <body>
    <Header
      activeTab={activeTab}
      user={userProfile}
      hotelName={displayHotelName}
      hotelLocation={hotelLocation}
      hotelStars={hotelStars}
      hotelLogoUrl={displayHotelLogoUrl}
    />
    <main>
      <slot />
    </main>
    <Footer />
    <ConfirmModal />
    <Toast />

    <script>
      // Theme-Toggle
      const stored = localStorage.getItem('v9-theme');
      if (stored === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>

    <script is:inline>
      // Sprachcode (?lang=) an interne Links anhängen, damit er beim Navigieren
      // erhalten bleibt. DE = Standard → keine URL-Verschmutzung.
      (function () {
        var qp = new URLSearchParams(location.search).get('lang');
        var m = document.cookie.match(/(?:^|;\s*)retaha_lang=([^;]+)/);
        var cookieLang = m ? decodeURIComponent(m[1]) : null;
        var lang = qp || cookieLang;
        if (!lang || lang === 'de') return;
        // Cookie sicherstellen (z. B. geteilter ?lang=-Link ohne Cookie).
        if (cookieLang !== lang) {
          document.cookie = 'retaha_lang=' + lang + '; path=/; max-age=31536000; samesite=lax';
        }
        document.querySelectorAll('a[href^="/"]').forEach(function (a) {
          var href = a.getAttribute('href');
          if (!href || href.charAt(1) === '/' || /[?&]lang=/.test(href)) return;
          a.setAttribute('href', href + (href.indexOf('?') === -1 ? '?' : '&') + 'lang=' + lang);
        });
      })();
    </script>

    <script>
      // Alpine.js — für alle Pages (admin + V9)
      import Alpine from 'alpinejs';
      import collapse from '@alpinejs/collapse';
      Alpine.plugin(collapse);
      // @ts-expect-error
      window.Alpine = Alpine;

      // Shared component: binary toggles that save immediately via API
      Alpine.data('persistToggle', ({ initial, field }: { initial: boolean; field: string }) => ({
        checked: Boolean(initial),
        saving: false,
        error: '',
        async toggle(e: Event) {
          const newVal = (e.target as HTMLInputElement).checked;
          const prev = this.checked;
          this.checked = newVal;
          this.saving = true;
          this.error = '';
          try {
            const res = await fetch('/api/admin/hotel-settings/toggle', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ field, value: newVal }),
            });
            const data = await res.json();
            if (!data.ok) {
              this.checked = prev;
              this.error = data.error || 'Fehler beim Speichern';
              (window as any).retahaToast?.(this.error, 'error');
            }
          } catch {
            this.checked = prev;
            this.error = 'Netzwerk-Fehler';
            (window as any).retahaToast?.(this.error, 'error');
          } finally {
            this.saving = false;
          }
        },
      }));

      // Shared component: per-section AJAX save with dirty-state tracking
      Alpine.data('sectionSave', ({
        initial,
        section,
        endpoint = '/api/admin/breakfast/section',
      }: {
        initial: Record<string, string>;
        section: string;
        endpoint?: string;
      }) => ({
        data: { ...initial } as Record<string, string>,
        original: { ...initial } as Record<string, string>,
        saving: false,
        success: false,
        error: '',
        _timer: null as ReturnType<typeof setTimeout> | null,
        _beforeUnload: null as ((e: BeforeUnloadEvent) => void) | null,

        init() {
          this._beforeUnload = (e: BeforeUnloadEvent) => {
            if (this.isDirty) { e.preventDefault(); e.returnValue = ''; }
          };
          window.addEventListener('beforeunload', this._beforeUnload);
        },

        destroy() {
          if (this._beforeUnload) window.removeEventListener('beforeunload', this._beforeUnload);
        },

        get isDirty(): boolean {
          const d = this.data as Record<string, string>;
          const o = this.original as Record<string, string>;
          return Object.keys(o).some(k => String(d[k] ?? '') !== String(o[k] ?? ''));
        },

        async save() {
          if (!this.isDirty || this.saving) return;
          this.saving = true;
          this.success = false;
          this.error = '';
          if (this._timer) clearTimeout(this._timer);
          try {
            const res = await fetch(endpoint, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ section, ...(this.data as Record<string, string>) }),
            });
            const d = await res.json();
            if (!d.ok) {
              this.error = d.error || 'Fehler beim Speichern';
              (window as any).retahaToast?.(this.error, 'error');
            } else {
              this.original = { ...(this.data as Record<string, string>) };
              this.success = false;
              (window as any).retahaToast?.('Gespeichert');
            }
          } catch {
            this.error = 'Netzwerk-Fehler';
            (window as any).retahaToast?.(this.error, 'error');
          } finally {
            this.saving = false;
          }
        },
      }));

      Alpine.start();
    </script>
  </body>
</html>
