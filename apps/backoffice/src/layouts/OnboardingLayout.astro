---
import '@retaha/ui/styles/global.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/pills.css';
import '@retaha/ui/styles/components/onboarding.css';

interface Props {
  title: string;
  locale?: string;
}

const { title, locale = 'de' } = Astro.props;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white min-h-screen font-sans antialiased text-anthrazit">
    <slot />
  </body>
</html>
