---
// Theme-Variables zuerst — definiert die --theme-*-Tokens, auf die
// global.css's @theme-Block via var() referenziert.
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/tokens.css';
import '@retaha/ui/styles/global.css';
import '@retaha/ui/styles/retaha.css';
import '@retaha/ui/styles/icons.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/pills.css';
import '@retaha/ui/styles/components/menu.css';
import '@retaha/ui/styles/components/settings.css';
import '@retaha/ui/styles/components/status-markers.css';
// Theme-Fonts via @fontsource (self-hosted, DSGVO-konform)
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import AdminFooter from './AdminFooter.astro';
import NotificationBell from '@retaha/ui/components/admin/NotificationBell.astro';
import TrianglePulse from '@retaha/ui/components/TrianglePulse.astro';
import type { TrialUrgency } from '@retaha/ui/components/admin/NotificationBell.astro';
import { calculateTrialStatus, TRIAL_DURATION_DAYS } from '../lib/trial-status';
import { t } from '../i18n/helpers';
import { resolveTheme } from '@retaha/ui/theme';

interface Props {
  title: string;
  hotel: {
    name: string;
    slug: string;
    logo_url?: string | null;
    logo_primary?: string | null;
    logo_dark?: string | null;
    trial_started_at?: string | null;
    subscription_status?: string;
    theme?: string | null;
  };
  user: { email: string };
  activeTab?: string;
}

const { title, hotel, user } = Astro.props;
const userLocale = Astro.locals.locale;
const currentPath = Astro.url.pathname;

// Theme: Preview-Query > hotel.theme > Default
const activeTheme = resolveTheme({
  hotelTheme: hotel.theme,
  requestUrl: Astro.url,
});

// Sprint I Phase 1: Trial-Status-Berechnung wandert vom NotificationBell-
// Component ins Layout, damit die Bell als reine packages/ui-Component
// keine app-spezifischen Imports (trial-status.ts, i18n/helpers) braucht.
const trialStatus = calculateTrialStatus({
  trial_started_at: hotel.trial_started_at ?? null,
  subscription_status: hotel.subscription_status ?? '',
});
const trialUrgency: TrialUrgency = trialStatus.urgencyLevel;
const trialHasNotification = trialStatus.isInTrial || trialStatus.urgencyLevel === 'expired';
const trialCurrentDay = Math.max(
  1,
  Math.min(TRIAL_DURATION_DAYS - trialStatus.daysRemaining + 1, TRIAL_DURATION_DAYS),
);

const trialHeadlineKey =
  trialUrgency === 'warning'  ? 'notification_bell.headline_warning' :
  trialUrgency === 'critical' ? 'notification_bell.headline_critical' :
  trialUrgency === 'expired'  ? 'notification_bell.headline_expired' :
                                'notification_bell.headline_normal';

const trialBodyKey =
  trialUrgency === 'warning'  ? 'notification_bell.body_warning' :
  trialUrgency === 'critical' ? 'notification_bell.body_critical' :
  trialUrgency === 'expired'  ? 'notification_bell.body_expired' :
                                'notification_bell.body_normal';

const trialCtaKey =
  trialUrgency === 'critical' || trialUrgency === 'expired'
    ? 'notification_bell.cta_critical'
    : 'notification_bell.cta_normal';

const trialTexts = {
  eyebrow:        'bell',
  headline:       t(trialHeadlineKey, userLocale),
  body:           t(trialBodyKey, userLocale),
  cta:            t(trialCtaKey, userLocale),
  ariaLabel:      t('notification_bell.aria_label', userLocale),
  popoverAria:    t('notification_bell.popover_aria', userLocale),
  testphaseLabel: t('notification_bell.testphase_label', userLocale),
  daysLabel:      t('notification_bell.days_label', userLocale),
};

const hotelLogoUrl = hotel.logo_primary ?? hotel.logo_dark ?? hotel.logo_url ?? null;
---

<!DOCTYPE html>
<html lang="de" data-theme={activeTheme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · retaha backoffice</title>
  </head>
  <body
    class="min-h-screen bauhaus-app-body antialiased"
    x-data="{ menuOpen: false }"
    @keydown.escape.window="menuOpen = false"
    x-init="$watch('menuOpen', v => { document.body.style.overflow = v ? 'hidden' : '' })"
  >
    <!-- Top bar: Slug links, Logo/Name zentriert, Bell+Burger rechts -->
    <header class="border-b border-stein bg-bone">
      <div class="max-w-6xl mx-auto px-6 py-4 grid grid-cols-[1fr_auto_1fr] items-center gap-4">

        <!-- LINKS: Slug -->
        <div class="justify-self-start min-w-0">
          <span class="text-xs font-mono truncate hidden sm:inline" style="color: var(--theme-text-muted);">/{hotel.slug}</span>
        </div>

        <!-- MITTE: Hotel-Logo oder Fallback auf Hotel-Name -->
        <div class="justify-self-center min-w-0 max-w-md">
          {hotelLogoUrl ? (
            <img
              src={hotelLogoUrl}
              alt={hotel.name}
              class="h-7 w-auto object-contain"
              style="max-height: 28px;"
            />
          ) : (
            <p class="m-0 truncate" style="font-family: var(--theme-font-headline); font-size: 20px; font-weight: 300; color: var(--theme-text-primary); letter-spacing: -0.01em; line-height: 1;">
              {hotel.name}
            </p>
          )}
        </div>

        <!-- RECHTS: Live-Marker + Bell + Burger -->
        <div class="justify-self-end flex items-center gap-6">
          <span class="live-marker">
            <TrianglePulse variant="white" label="App ist online" />
            <span>live</span>
          </span>
          <NotificationBell
            urgency={trialUrgency}
            hasNotification={trialHasNotification}
            currentDay={trialCurrentDay}
            totalDays={TRIAL_DURATION_DAYS}
            ctaHref="/admin/subscription"
            texts={trialTexts}
          />
          <button
            type="button"
            class="menu-trigger"
            :class="{ 'menu-trigger-active': menuOpen }"
            aria-label="Navigation"
            :aria-expanded="menuOpen.toString()"
            @click="menuOpen = !menuOpen"
          >
            <span class="menu-trigger-shapes">
              <span class="menu-trigger-circle"></span>
              <span class="menu-trigger-line"></span>
              <span class="menu-trigger-square"></span>
            </span>
            <span class="menu-trigger-label">menu</span>
          </button>
        </div>

      </div>
    </header>

    <!-- Editorial Menu (Sub-Header-Overlay) -->
    <div
      class="editorial-menu"
      :class="{ 'is-open': menuOpen }"
      aria-label="Hauptmenü"
    >
      <nav
        class="editorial-menu-nav"
        x-data="{ expandedGroup: null, toggle(g) { this.expandedGroup = this.expandedGroup === g ? null : g } }"
        aria-label="Backoffice Navigation"
      >
        <!-- User-Email + Logout -->
        <div class="menu-user-section">
          <span class="menu-user-email">{user.email}</span>
          <form method="POST" action="/admin/auth/logout">
            <button type="submit" class="menu-logout-btn">{t('nav.logout', userLocale)}</button>
          </form>
        </div>

        <!-- Sprint E3 Phase 1 — Cross-Nav zum Operations-Dashboard (/app)
             Nach Sprint-F-Monorepo-Split: dashboard.retaha.de (Cross-Domain-Link) -->
        <a
          href="/app"
          class="menu-direct-link"
          style="border-left: 3px solid var(--theme-accent); padding-left: 13px;"
        >
          → Operations-Dashboard
        </a>

        <!-- ÜBERSICHT — direkter Link, kein Akkordeon -->
        <a
          href="/uebersicht"
          class={`menu-direct-link${currentPath === '/uebersicht' ? ' is-active' : ''}`}
        >
          {currentPath === '/uebersicht' && <span class="active-dot" aria-hidden="true"></span>}
          {t('nav.overview', userLocale)}
        </a>

        <!-- GRUPPE: GÄSTE -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('gaeste')" :class="{ 'is-expanded': expandedGroup === 'gaeste' }" :aria-expanded="expandedGroup === 'gaeste'">
            <span class="group-label">{t('nav.group_gaeste', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'gaeste'">
            <a href="/admin/concierge" class={`menu-item${currentPath === '/admin/concierge' ? ' is-active' : ''}`}>
              {currentPath === '/admin/concierge' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.concierge', userLocale)}
            </a>
            <a href="/admin/eve/knowledge" class={`menu-item${currentPath?.startsWith('/admin/eve') ? ' is-active' : ''}`}>
              {currentPath?.startsWith('/admin/eve') && <span class="active-dot" aria-hidden="true"></span>}
              Eve
            </a>
            <a href="/admin/places" class={`menu-item${currentPath?.startsWith('/admin/places') ? ' is-active' : ''}`}>
              {currentPath?.startsWith('/admin/places') && <span class="active-dot" aria-hidden="true"></span>}
              Empfehlungen
            </a>
            <a href="/admin/guests" class={`menu-item${currentPath === '/admin/guests' ? ' is-active' : ''}`}>
              {currentPath === '/admin/guests' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.guests', userLocale)}
            </a>
            <a href="/admin/wallet" class={`menu-item${currentPath === '/admin/wallet' ? ' is-active' : ''}`}>
              {currentPath === '/admin/wallet' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.wallet', userLocale)}
            </a>
          </div>
        </div>

        <!-- GRUPPE: BUCHUNGEN & SERVICES -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('buchungen')" :class="{ 'is-expanded': expandedGroup === 'buchungen' }" :aria-expanded="expandedGroup === 'buchungen'">
            <span class="group-label">{t('nav.group_buchungen', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'buchungen'">
            <a href="/admin/checkins" class={`menu-item${currentPath === '/admin/checkins' ? ' is-active' : ''}`}>
              {currentPath === '/admin/checkins' && <span class="active-dot" aria-hidden="true"></span>}
              Check-ins
            </a>
            <a href="/admin/feedback" class={`menu-item${currentPath === '/admin/feedback' ? ' is-active' : ''}`}>
              {currentPath === '/admin/feedback' && <span class="active-dot" aria-hidden="true"></span>}
              Bewertungen
            </a>
            <a href="/admin/nfc-tags" class={`menu-item${currentPath === '/admin/nfc-tags' ? ' is-active' : ''}`}>
              {currentPath === '/admin/nfc-tags' && <span class="active-dot" aria-hidden="true"></span>}
              NFC-Tags
            </a>
            <a href="/admin/showcase" class={`menu-item${currentPath === '/admin/showcase' ? ' is-active' : ''}`}>
              {currentPath === '/admin/showcase' && <span class="active-dot" aria-hidden="true"></span>}
              Showcase
            </a>
            <a href="/app/bookings" class="menu-item" title="Im Operations-Dashboard">
              {t('nav.bookings', userLocale)}
              <span style="opacity: 0.4; margin-left: 4px; font-size: 10px;">↗</span>
            </a>
            <a href="/admin/breakfast" class={`menu-item${currentPath === '/admin/breakfast' ? ' is-active' : ''}`}>
              {currentPath === '/admin/breakfast' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.breakfast', userLocale)}
            </a>
            <a href="/admin/menu" class={`menu-item${currentPath?.startsWith('/admin/menu') ? ' is-active' : ''}`}>
              {currentPath?.startsWith('/admin/menu') && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.menu', userLocale)}
            </a>
            <a href="/admin/service" class={`menu-item${currentPath === '/admin/service' ? ' is-active' : ''}`}>
              {currentPath === '/admin/service' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.service', userLocale)}
            </a>
            <a href="/admin/conference" class={`menu-item${currentPath === '/admin/conference' ? ' is-active' : ''}`}>
              {currentPath === '/admin/conference' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.conference', userLocale)}
            </a>
            <a href="/admin/spa" class={`menu-item${currentPath === '/admin/spa' ? ' is-active' : ''}`}>
              {currentPath === '/admin/spa' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.spa', userLocale)}
            </a>
            <a href="/admin/restaurant" class={`menu-item${currentPath === '/admin/restaurant' ? ' is-active' : ''}`}>
              {currentPath === '/admin/restaurant' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.restaurant', userLocale)}
            </a>
          </div>
        </div>

        <!-- GRUPPE: INHALTE -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('inhalte')" :class="{ 'is-expanded': expandedGroup === 'inhalte' }" :aria-expanded="expandedGroup === 'inhalte'">
            <span class="group-label">{t('nav.group_inhalte', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'inhalte'">
            <a href="/admin/action-cards" class={`menu-item${(currentPath === '/admin/action-cards' || currentPath === '/admin/recommendations') ? ' is-active' : ''}`}>
              {(currentPath === '/admin/action-cards' || currentPath === '/admin/recommendations') && <span class="active-dot" aria-hidden="true"></span>}
              Action-Cards
            </a>
            <a href="/admin/microsite" class={`menu-item${currentPath === '/admin/microsite' ? ' is-active' : ''}`}>
              {currentPath === '/admin/microsite' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.microsite', userLocale)}
            </a>
            <a href="/admin/seo" class={`menu-item${currentPath === '/admin/seo' ? ' is-active' : ''}`}>
              {currentPath === '/admin/seo' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.seo', userLocale)}
            </a>
          </div>
        </div>

        <!-- GRUPPE: MARKETING -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('marketing')" :class="{ 'is-expanded': expandedGroup === 'marketing' }" :aria-expanded="expandedGroup === 'marketing'">
            <span class="group-label">{t('nav.group_marketing', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'marketing'">
            <a href="/admin/marketing" class={`menu-item${currentPath?.startsWith('/admin/marketing') ? ' is-active' : ''}`}>
              {currentPath?.startsWith('/admin/marketing') && <span class="active-dot" aria-hidden="true"></span>}
              Wallet-Marketing
            </a>
            <a href="/admin/stay-pushes" class={`menu-item${currentPath?.startsWith('/admin/stay-pushes') ? ' is-active' : ''}`}>
              {currentPath?.startsWith('/admin/stay-pushes') && <span class="active-dot" aria-hidden="true"></span>}
              Stay-Pushes
            </a>
            <a href="/admin/email-campaigns" class={`menu-item${currentPath === '/admin/email-campaigns' ? ' is-active' : ''}`}>
              {currentPath === '/admin/email-campaigns' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.email_campaigns', userLocale)}
            </a>
            <a href="/admin/reviews" class={`menu-item${currentPath === '/admin/reviews' ? ' is-active' : ''}`}>
              {currentPath === '/admin/reviews' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.reviews', userLocale)}
            </a>
            <a href="/admin/pre-stay" class={`menu-item${currentPath === '/admin/pre-stay' ? ' is-active' : ''}`}>
              {currentPath === '/admin/pre-stay' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.pre_stay', userLocale)}
            </a>
            <a href="/admin/referrals" class={`menu-item${currentPath === '/admin/referrals' ? ' is-active' : ''}`}>
              {currentPath === '/admin/referrals' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.referrals', userLocale)}
            </a>
            <a href="/admin/loyalty" class={`menu-item${currentPath === '/admin/loyalty' ? ' is-active' : ''}`}>
              {currentPath === '/admin/loyalty' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.loyalty', userLocale)}
            </a>
          </div>
        </div>

        <!-- GRUPPE: VERKAUF -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('verkauf')" :class="{ 'is-expanded': expandedGroup === 'verkauf' }" :aria-expanded="expandedGroup === 'verkauf'">
            <span class="group-label">{t('nav.group_verkauf', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'verkauf'">
            <a href="/admin/booking-engine" class={`menu-item${currentPath === '/admin/booking-engine' ? ' is-active' : ''}`}>
              {currentPath === '/admin/booking-engine' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.booking_engine', userLocale)}
            </a>
            <a href="/admin/best-price" class={`menu-item${currentPath === '/admin/best-price' ? ' is-active' : ''}`}>
              {currentPath === '/admin/best-price' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.best_price', userLocale)}
            </a>
            <a href="/admin/booking-recovery" class={`menu-item${currentPath === '/admin/booking-recovery' ? ' is-active' : ''}`}>
              {currentPath === '/admin/booking-recovery' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.booking_recovery', userLocale)}
            </a>
            <a href="/admin/self-checkout" class={`menu-item${currentPath === '/admin/self-checkout' ? ' is-active' : ''}`}>
              {currentPath === '/admin/self-checkout' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.self_checkout', userLocale)}
            </a>
          </div>
        </div>

        <!-- GRUPPE: INTEGRATIONEN -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('integrationen')" :class="{ 'is-expanded': expandedGroup === 'integrationen' }" :aria-expanded="expandedGroup === 'integrationen'">
            <span class="group-label">{t('nav.group_integrationen', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'integrationen'">
            <a href="/admin/whatsapp" class={`menu-item${currentPath === '/admin/whatsapp' ? ' is-active' : ''}`}>
              {currentPath === '/admin/whatsapp' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.whatsapp', userLocale)}
            </a>
            <a href="/admin/gmb" class={`menu-item${currentPath === '/admin/gmb' ? ' is-active' : ''}`}>
              {currentPath === '/admin/gmb' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.gmb', userLocale)}
            </a>
            <a href="/admin/wallet-keys" class={`menu-item${currentPath === '/admin/wallet-keys' ? ' is-active' : ''}`}>
              {currentPath === '/admin/wallet-keys' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.wallet_keys', userLocale)}
            </a>
            <a href="/admin/pms" class={`menu-item${currentPath === '/admin/pms' ? ' is-active' : ''}`}>
              {currentPath === '/admin/pms' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.pms', userLocale)}
            </a>
            <a href="/admin/email-domain" class={`menu-item${currentPath === '/admin/email-domain' ? ' is-active' : ''}`}>
              {currentPath === '/admin/email-domain' && <span class="active-dot" aria-hidden="true"></span>}
              Email-Domain
            </a>
          </div>
        </div>

        <!-- GRUPPE: EINSTELLUNGEN -->
        <div class="menu-group">
          <button type="button" class="menu-group-header" @click="toggle('einstellungen')" :class="{ 'is-expanded': expandedGroup === 'einstellungen' }" :aria-expanded="expandedGroup === 'einstellungen'">
            <span class="group-label">{t('nav.group_einstellungen', userLocale)}</span>
            <span class="group-chevron" aria-hidden="true">+</span>
          </button>
          <div class="menu-group-items" x-show="expandedGroup === 'einstellungen'">
            <a href="/features" class={`menu-item${currentPath === '/features' ? ' is-active' : ''}`}>
              {currentPath === '/features' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.features', userLocale)}
            </a>
            <a href="/admin/settings" class={`menu-item${currentPath === '/admin/settings' ? ' is-active' : ''}`}>
              {currentPath === '/admin/settings' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.settings', userLocale)}
            </a>
            <a href="/admin/subscription" class={`menu-item${currentPath === '/admin/subscription' ? ' is-active' : ''}`}>
              {currentPath === '/admin/subscription' && <span class="active-dot" aria-hidden="true"></span>}
              {t('nav.subscription', userLocale)}
            </a>
            <a href="/admin/team" class={`menu-item${currentPath === '/admin/team' ? ' is-active' : ''}`}>
              {currentPath === '/admin/team' && <span class="active-dot" aria-hidden="true"></span>}
              Team
            </a>
          </div>
        </div>

      </nav>
    </div>

    <!-- Page content -->
    <main class="max-w-6xl mx-auto px-6 py-10">
      <slot />
    </main>

    <AdminFooter />

    <style>
      .live-marker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--color-anthrazit, #1A1A1A);
        border-radius: 99px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.7);
        text-transform: lowercase;
      }
    </style>

    <script>
      import Alpine from 'alpinejs';
      import collapse from '@alpinejs/collapse';
      Alpine.plugin(collapse);
      // @ts-expect-error - expose for debugging
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
