---
// Sprint E4 · Phase 4 — Sub-Navigation für /admin/eve/*
//
// Tabs für die Eve-Section. Hält UI-Konsistenz zwischen Knowledge (Phase 4),
// Personality-Settings (Phase 5) und später Audit-Log (Backlog).

interface Props {
  /** Pfad der aktuellen Seite (Astro.url.pathname) für active-state. */
  currentPath: string;
}

const { currentPath } = Astro.props;

const tabs = [
  { href: '/eve/knowledge',   label: 'Wissen',        slug: 'knowledge' },
  { href: '/eve/settings',    label: 'Persönlichkeit', slug: 'settings'  },
  { href: '/eve/feedback',    label: 'Feedback',       slug: 'feedback'  },
];
---

<nav class="eve-subnav" aria-label="Eve Sub-Navigation">
  <div class="eve-subnav-inner">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class={`eve-subnav-tab${currentPath === tab.href ? ' is-active' : ''}`}
        aria-current={currentPath === tab.href ? 'page' : undefined}
      >
        {tab.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .eve-subnav {
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }
  .eve-subnav-inner {
    display: flex;
    gap: 0;
  }
  .eve-subnav-tab {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    min-height: 44px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
    margin-bottom: -1px;
  }
  .eve-subnav-tab:hover { color: var(--ink); }
  .eve-subnav-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--ink);
    font-weight: 500;
  }
</style>
