---
// Drip-Editor — V9-Redesign (optisch identisch mit CampaignEditor / MarketingEditor).
// Logik (Alpine, SortableJS, API-Calls) unverändert.

interface Tpl { id: string; name: string; }
interface InitialStep { template_id: string; delay_days: number; }
interface Props {
  drip?: {
    id: string;
    name: string;
    trigger_type: string;
    trigger_config: any;
    is_active: boolean;
  } | null;
  initialSteps?: InitialStep[];
  templates: Tpl[];
}
const p = Astro.props as Props;
const isEdit = !!p.drip;

import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

const TRIGGERS = [
  { value: 'wallet_add',            label: bt('dr.trigger.wallet_add', lang) },
  { value: 'first_visit',           label: bt('dr.trigger.first_visit', lang) },
  { value: 'checkout',              label: bt('dr.trigger.checkout', lang) },
  { value: 'anniversary',           label: bt('dr.trigger.anniversary', lang) },
  { value: 'visit_count_milestone', label: bt('dr.trigger.visit_count_milestone', lang) },
  { value: 'seasonal',              label: bt('dr.trigger.seasonal', lang) },
];

const dreT = {
  saving: bt('dre.saving', lang),
  saveEdit: bt('dre.save.edit', lang),
  saveCreate: bt('dre.save.create', lang),
  errName: bt('dre.err.name', lang),
  errStep: bt('dre.err.step', lang),
  errTpl: bt('dre.err.tpl', lang),
  errMilestone: bt('dre.err.milestone', lang),
  errUpdate: bt('dre.err.update', lang),
  errStepsUpdate: bt('dre.err.stepsupdate', lang),
  errSave: bt('dre.err.save', lang),
  errNet: bt('dre.err.net', lang),
  errUnknown: bt('dre.err.unknown', lang),
  toastSaved: bt('dre.toast.saved', lang),
};
---

<div class="dre-wrap" x-data="dripEditor()">

  <!-- ── Settings-Karte ────────────────────────────────────────────── -->
  <div class="dre-card">
    <div class="dre-card-head">
      <span class="dre-card-title">{bt('dre.settings', lang)}</span>
    </div>

    <div class="dre-field">
      <span class="dre-label">{bt('dre.name', lang)}</span>
      <input type="text" x-model="form.name" placeholder={bt('dre.name.ph', lang)} class="s-input" style="width:100%;box-sizing:border-box" />
    </div>

    <div class="dre-ctrl-row">
      <div class="dre-field dre-field--grow">
        <span class="dre-label">{bt('dre.trigger', lang)}</span>
        <div class="s-select-wrap">
          <select x-model="form.trigger_type" class="s-select">
            {TRIGGERS.map(t => <option value={t.value}>{t.label}</option>)}
          </select>
        </div>
      </div>

      <div class="dre-field dre-field--shrink">
        <span class="dre-label">{bt('dre.active', lang)}</span>
        <div class="dre-seg">
          <button type="button" :class="!form.is_active ? 'is-on' : ''" @click="form.is_active = false">
            {bt('dre.inactive', lang) || 'Inaktiv'}
          </button>
          <button type="button" :class="form.is_active ? 'is-on' : ''" @click="form.is_active = true">
            {bt('dre.active.on', lang) || 'Aktiv'}
          </button>
        </div>
      </div>
    </div>

    <!-- Trigger-Config: Meilensteine -->
    <div x-show="form.trigger_type === 'visit_count_milestone'" x-cloak class="dre-cfg-block">
      <span class="dre-label">{bt('dre.milestones.label', lang)}</span>
      <input type="text" x-model="form.milestones_input" placeholder="5, 10, 25" class="s-input" style="width:100%;box-sizing:border-box" />
      <p class="dre-hint">{bt('dre.milestones.hint', lang)}</p>
    </div>

    <!-- Trigger-Config: Saisonales -->
    <div x-show="form.trigger_type === 'seasonal'" x-cloak class="dre-cfg-block">
      <span class="dre-label">{bt('dre.seasonal.label', lang)}</span>
      <div class="dre-ctrl-row dre-ctrl-row--sm">
        <div class="dre-field dre-field--grow">
          <span class="dre-label-small">{bt('dre.month', lang)}</span>
          <div class="s-select-wrap">
            <select x-model.number="form.seasonal_month" class="s-select">
              {Array.from({ length: 12 }, (_, i) => <option value={i + 1}>{bt('dre.month.' + (i + 1), lang)}</option>)}
            </select>
          </div>
        </div>
        <div class="dre-field" style="flex: 0 0 120px">
          <span class="dre-label-small">{bt('dre.day', lang)}</span>
          <input type="number" min="1" max="31" x-model.number="form.seasonal_day" class="s-input" />
        </div>
      </div>
      <p class="dre-hint">{bt('dre.seasonal.hint', lang)}</p>
    </div>
  </div>

  <!-- ── Step-Builder-Karte ─────────────────────────────────────────── -->
  <div class="dre-card">
    <div class="dre-card-head">
      <span class="dre-card-title">{bt('dr.step.many', lang)}</span>
      <button type="button" class="dre-add-btn" @click="addStep()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        {bt('dre.addstep', lang)}
      </button>
    </div>
    <p class="dre-hint" set:html={bt('dre.steps.hint', lang)}></p>

    <ul id="de-steps-list" class="dre-steps-list">
      <template x-for="(step, idx) in form.steps" :key="step._key">
        <li class="dre-step-card" :data-key="step._key">
          <span class="dre-step-grip de-step-grip" aria-label={bt('dre.move', lang)}>
            <svg width="12" height="16" viewBox="0 0 12 16" fill="currentColor"><circle cx="4" cy="3" r="1.5"/><circle cx="8" cy="3" r="1.5"/><circle cx="4" cy="8" r="1.5"/><circle cx="8" cy="8" r="1.5"/><circle cx="4" cy="13" r="1.5"/><circle cx="8" cy="13" r="1.5"/></svg>
          </span>
          <span class="dre-step-num" x-text="(idx + 1)"></span>
          <div class="dre-step-body">
            <div class="dre-step-field">
              <span class="dre-label-small">{bt('dre.template', lang)}</span>
              <div class="s-select-wrap">
                <select x-model="step.template_id" class="s-select">
                  <option value="">{bt('dre.choose', lang)}</option>
                  {p.templates.map(t => <option value={t.id}>{t.name}</option>)}
                </select>
              </div>
            </div>
            <div class="dre-step-field dre-step-field--delay">
              <span class="dre-label-small">{bt('dre.delay.label', lang)}</span>
              <div class="dre-delay-row">
                <input type="number" min="0" x-model.number="step.delay_days" class="s-input s-input--sm dre-delay-input" />
                <span class="dre-delay-unit">{bt('dre.delay.days', lang) || 'Tage'}</span>
              </div>
            </div>
          </div>
          <button type="button" class="dre-step-remove" @click="removeStep(idx)" aria-label={bt('dre.remove', lang)}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </li>
      </template>
    </ul>

    <template x-if="form.steps.length === 0">
      <div class="dre-empty">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="16" x2="12" y2="16"/></svg>
        <p>{bt('dre.empty', lang)}</p>
      </div>
    </template>
  </div>

  <template x-if="errorMsg">
    <div class="dre-flash" x-text="errorMsg"></div>
  </template>

  <div class="dre-actions">
    <a href="/marketing/drips" class="v9-btn dre-btn-ghost">{bt('dre.cancel', lang)}</a>
    <button type="button" class="v9-btn dre-btn-primary" :disabled="submitting" @click="save()"
      x-text="submitting ? cfg.T.saving : (isEditMode ? cfg.T.saveEdit : cfg.T.saveCreate)"></button>
  </div>
</div>

<script is:inline define:vars={{
  IS_EDIT: isEdit,
  DRIP: p.drip ?? null,
  INITIAL_STEPS: p.initialSteps ?? [],
  DRE_T: dreT,
}}>
  window.__RETAHA_DE__ = { IS_EDIT, DRIP, INITIAL_STEPS, T: DRE_T };
</script>

<script>
  import Sortable from 'sortablejs';

  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('dripEditor', () => ({
      cfg: (window as any).__RETAHA_DE__,
      submitting: false,
      errorMsg: '' as string,
      _nextKey: 1,
      form: {
        name: '',
        trigger_type: 'wallet_add',
        is_active: false,
        milestones_input: '5, 10, 25',
        seasonal_month: 12,
        seasonal_day: 24,
        steps: [] as Array<{ _key: number; template_id: string; delay_days: number }>,
      },

      get isEditMode() { return this.cfg.IS_EDIT; },

      init() {
        if (this._inited) return;
        this._inited = true;
        if (this.cfg.IS_EDIT && this.cfg.DRIP) {
          const d = this.cfg.DRIP;
          this.form.name = d.name;
          this.form.trigger_type = d.trigger_type;
          this.form.is_active = d.is_active;
          if (d.trigger_type === 'visit_count_milestone' && Array.isArray(d.trigger_config?.milestones)) {
            this.form.milestones_input = d.trigger_config.milestones.join(', ');
          }
          if (d.trigger_type === 'seasonal' && d.trigger_config) {
            this.form.seasonal_month = d.trigger_config.month ?? 12;
            this.form.seasonal_day = d.trigger_config.day ?? 24;
          }
        }
        for (const s of this.cfg.INITIAL_STEPS) {
          this.form.steps.push({ _key: this._nextKey++, template_id: s.template_id, delay_days: s.delay_days });
        }
        setTimeout(() => this._initSortable(), 0);
      },

      _initSortable() {
        const list = document.getElementById('de-steps-list');
        if (!list) return;
        Sortable.create(list, {
          handle: '.de-step-grip',
          animation: 150,
          forceFallback: true,
          fallbackTolerance: 5,
          onEnd: (evt: any) => {
            const oldI = evt.oldIndex; const newI = evt.newIndex;
            if (oldI === newI || oldI == null || newI == null) return;
            const moved = this.form.steps.splice(oldI, 1)[0];
            this.form.steps.splice(newI, 0, moved);
            this.form.steps = [...this.form.steps];
          },
        });
      },

      addStep() {
        this.form.steps.push({ _key: this._nextKey++, template_id: '', delay_days: 0 });
      },

      removeStep(idx: number) {
        this.form.steps.splice(idx, 1);
      },

      _buildTriggerConfig(): any {
        if (this.form.trigger_type === 'visit_count_milestone') {
          const milestones = this.form.milestones_input.split(',')
            .map(s => parseInt(s.trim(), 10))
            .filter(n => Number.isFinite(n) && n > 0);
          return { milestones };
        }
        if (this.form.trigger_type === 'seasonal') {
          return { month: this.form.seasonal_month, day: this.form.seasonal_day };
        }
        return null;
      },

      async save() {
        if (this.submitting) return;
        this.errorMsg = '';

        if (!this.form.name?.trim()) { this.errorMsg = this.cfg.T.errName; return; }
        if (this.form.steps.length === 0) { this.errorMsg = this.cfg.T.errStep; return; }
        for (const s of this.form.steps) {
          if (!s.template_id) { this.errorMsg = this.cfg.T.errTpl; return; }
        }

        const triggerConfig = this._buildTriggerConfig();
        if (this.form.trigger_type === 'visit_count_milestone' && (!triggerConfig.milestones || triggerConfig.milestones.length === 0)) {
          this.errorMsg = this.cfg.T.errMilestone;
          return;
        }

        const stepsPayload = this.form.steps.map(s => ({ template_id: s.template_id, delay_days: s.delay_days }));

        this.submitting = true;
        try {
          if (this.cfg.IS_EDIT) {
            const r1 = await fetch(`/api/marketing/drips/${this.cfg.DRIP.id}`, {
              method: 'PUT', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name: this.form.name.trim(),
                trigger_config: triggerConfig,
                is_active: this.form.is_active,
              }),
            });
            const d1 = await r1.json();
            if (!d1.ok) { this.errorMsg = d1.error || this.cfg.T.errUpdate; return; }
            const r2 = await fetch(`/api/marketing/drips/${this.cfg.DRIP.id}/steps`, {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ steps: stepsPayload }),
            });
            const d2 = await r2.json();
            if (!d2.ok) { this.errorMsg = d2.error || this.cfg.T.errStepsUpdate; return; }
            window.location.href = `/marketing/drips/${this.cfg.DRIP.id}`;
          } else {
            const res = await fetch('/api/marketing/drips/create', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name: this.form.name.trim(),
                trigger_type: this.form.trigger_type,
                trigger_config: triggerConfig,
                is_active: this.form.is_active,
                steps: stepsPayload,
              }),
            });
            const data = await res.json();
            if (!data.ok) { this.errorMsg = data.error || this.cfg.T.errSave; return; }
            (window as any).retahaToastFlash?.((this.cfg.T.toastSaved));
            window.location.href = `/marketing/drips/${data.id}`;
          }
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ' ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.submitting = false;
        }
      },
    }));
  });
</script>

<style>
[x-cloak] { display: none !important; }

.dre-wrap { display: flex; flex-direction: column; gap: 16px; }

/* ── Label + Hints ───────────────────────────────────────────────── */
.dre-label {
  display: block;
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--ink-muted, #666); margin-bottom: 6px;
}
.dre-label-small {
  display: block;
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--ink-muted, #666); margin-bottom: 5px;
}
.dre-hint {
  display: block; font-size: 11px; color: var(--ink-muted, #666);
  margin-top: 6px; line-height: 1.45;
}
.dre-hint :global(code) {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  background: var(--bg-deep, #F5F4F2); padding: 1px 5px; border-radius: 4px;
  color: var(--petrol, #14616E);
}
.dre-field { display: block; margin-bottom: 14px; }
.dre-field--grow { flex: 1 1 0; min-width: 0; }
.dre-field--shrink { flex: 0 0 auto; }

/* ── Cards ───────────────────────────────────────────────────────── */
.dre-card {
  background: var(--surface, #fff);
  border: 1px solid var(--border, #E5E4E0);
  border-radius: 16px;
  padding: 20px 22px;
}
.dre-card-head {
  display: flex; align-items: center; justify-content: space-between;
  gap: 10px; margin-bottom: 18px;
}
.dre-card-title {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'Space Grotesk', sans-serif; font-weight: 600;
  font-size: 14px; color: var(--ink, #0A0A0A);
}
.dre-card-title::before {
  content: ''; width: 7px; height: 7px;
  border-radius: 50%; background: var(--petrol, #14616E);
}

/* ── Control row ─────────────────────────────────────────────────── */
.dre-ctrl-row {
  display: flex; gap: 14px; align-items: flex-end; flex-wrap: wrap;
}
.dre-ctrl-row--sm { flex-wrap: nowrap; }

/* ── Segmented control (Aktiv / Inaktiv) ─────────────────────────── */
.dre-seg {
  display: inline-flex; gap: 3px;
  border: 1px solid var(--border, #E5E4E0);
  border-radius: 10px; padding: 3px;
  background: var(--surface, #fff);
}
.dre-seg button {
  appearance: none; border: 0; background: transparent; cursor: pointer;
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.05em; text-transform: uppercase;
  color: var(--ink-muted, #666);
  padding: 7px 11px; border-radius: 7px;
  white-space: nowrap; transition: background 120ms, color 120ms;
}
.dre-seg button:hover:not(.is-on) { color: var(--petrol, #14616E); }
.dre-seg button.is-on { background: var(--petrol, #14616E); color: #fff; }

/* ── Trigger-Config-Block ────────────────────────────────────────── */
.dre-cfg-block {
  margin-top: 2px; margin-bottom: 4px;
  padding: 14px 16px;
  background: color-mix(in srgb, var(--petrol, #14616E) 4%, transparent);
  border: 1px solid color-mix(in srgb, var(--petrol, #14616E) 18%, transparent);
  border-radius: 10px;
}

/* ── Add-Step-Button ─────────────────────────────────────────────── */
.dre-add-btn {
  display: inline-flex; align-items: center; gap: 6px;
  border: 1px solid var(--petrol, #14616E);
  color: var(--petrol, #14616E); background: transparent;
  border-radius: 8px; padding: 6px 12px;
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.05em; text-transform: uppercase;
  cursor: pointer; white-space: nowrap;
  transition: background 120ms, color 120ms;
}
.dre-add-btn:hover {
  background: var(--petrol, #14616E); color: #fff;
}
.dre-add-btn svg { flex-shrink: 0; }

/* ── Step-Liste ──────────────────────────────────────────────────── */
.dre-steps-list { list-style: none; padding: 0; margin: 12px 0 0; display: flex; flex-direction: column; gap: 8px; }

.dre-step-card {
  display: grid;
  grid-template-columns: 28px 28px 1fr 32px;
  gap: 10px; align-items: center;
  padding: 14px 12px;
  background: var(--surface, #fff);
  border: 1px solid var(--border, #E5E4E0);
  border-radius: 12px;
  transition: border-color 120ms, box-shadow 120ms;
}
.dre-step-card:hover { border-color: var(--petrol, #14616E); }

.dre-step-grip {
  cursor: grab; color: var(--ink-faint, #C0BEB8);
  display: flex; align-items: center; justify-content: center;
  user-select: none;
}
.dre-step-grip:active { cursor: grabbing; color: var(--ink-muted, #666); }

.dre-step-num {
  width: 26px; height: 26px;
  background: var(--petrol, #14616E); color: #fff;
  font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; flex-shrink: 0;
}

.dre-step-body {
  display: grid; grid-template-columns: 1fr 140px; gap: 10px; align-items: end;
}
@media (max-width: 640px) { .dre-step-body { grid-template-columns: 1fr; } }

.dre-step-field { display: block; }
.dre-step-field--delay { }

.dre-delay-row { display: flex; align-items: center; gap: 7px; }
.dre-delay-input { width: 70px !important; text-align: center; }
.dre-delay-unit {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ink-muted, #666); white-space: nowrap;
}

.dre-step-remove {
  width: 28px; height: 28px;
  background: transparent;
  border: 1px solid var(--border, #E5E4E0);
  border-radius: 6px;
  color: var(--ink-muted, #666);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background 120ms, color 120ms, border-color 120ms;
}
.dre-step-remove:hover {
  background: rgba(185, 28, 28, 0.06);
  color: #b91c1c; border-color: #b91c1c;
}

:global(.sortable-ghost) { opacity: 0.3; background: rgba(20,97,110,0.06) !important; }
:global(.sortable-chosen) { box-shadow: 0 4px 16px rgba(0,0,0,.10); }

/* ── Leer-Zustand ────────────────────────────────────────────────── */
.dre-empty {
  margin-top: 12px; padding: 32px 20px;
  border: 1.5px dashed var(--border, #E5E4E0);
  border-radius: 12px;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  color: var(--ink-faint, #C0BEB8); text-align: center;
}
.dre-empty p { margin: 0; font-size: 13px; }

/* ── Flash + Actions ─────────────────────────────────────────────── */
.dre-flash {
  padding: 12px 16px;
  background: rgba(140, 33, 40, 0.06); color: #7a1515;
  font-size: 13px; border-left: 3px solid #8C2128;
  border-radius: 0 12px 12px 0;
}
.dre-actions { display: flex; gap: 10px; justify-content: flex-end; align-items: center; }
.dre-btn-ghost {
  background: transparent !important; color: var(--ink-muted, #666) !important;
  border: 1px solid var(--border, #E5E4E0) !important; border-radius: 8px;
  text-decoration: none;
}
.dre-btn-ghost:hover {
  color: var(--ink, #0A0A0A) !important; border-color: var(--ink, #0A0A0A) !important;
  background: transparent !important;
}
.dre-btn-primary {
  background: var(--petrol, #14616E) !important;
  color: #fff !important; border: none !important; border-radius: 8px;
}
.dre-btn-primary:hover:not(:disabled) { filter: brightness(1.1); }
.dre-btn-primary:disabled { opacity: .5; cursor: not-allowed; }
</style>
