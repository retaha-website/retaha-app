---
// V9 Campaign-Editor — Aufbau neu (Vorschlag A + C-Inhaltslogik)
//
// Aufbau: Setup-Zeile oben (Anlass · Name · Empfänger · Kanal) → zweigeteilt
// (Composer links mit Kanal-Inhalts-Tabs, sticky Live-Vorschau rechts mit
// Kanal-Umschalter) → Versand + Aktionen unten.
//
// C-Full: getrennter Inhalt je Kanal. E-Mail = Betreff + Rich-Text + CTA
// (title/body/cta, immer Primär-Inhalt). Wallet-Push = optionaler kurzer
// Titel + Text (push_title/push_body) — leer → Versand kürzt den E-Mail-Text.

import { VARIABLE_UI_DEFS } from '@retaha/marketing';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

interface Tpl {
  id: string;
  name: string;
  title_i18n: any;
  body_i18n: any;
  cta_label_i18n: any | null;
  cta_url: string | null;
  hero_image_url: string | null;
}

interface SegmentCounts {
  allWallet: number;
  allEmail: number;
  loyal: number;
  lapsed: number;
}

interface Props {
  templates: Tpl[];
  hotelName: string;
  hotelDefaultLang: string;
  enabledLangs: string[];
  brandPrimary: string;
  logoUrl: string | null;
  segmentCounts: SegmentCounts;
}
const p = Astro.props as Props;

const LANGS_DISPLAY = p.enabledLangs.length > 0 ? p.enabledLangs : [p.hotelDefaultLang];

// Anlass = Vorlage. Auswahl füllt Inhalt + Empfänger-Empfehlung vor.
const ANLASS_DEFS = [
  {
    id: 'adhoc',
    eyebrow: 'Frei',
    label: 'Ad-hoc (leer)',
    title: '',
    body: '',
    cta_label: '',
    segment: 'all',
  },
  {
    id: 'zimmer',
    eyebrow: 'Auslastung',
    label: 'Zimmer füllen',
    title: 'Freie Zimmer – jetzt buchen & sparen',
    body: '<p>Wir haben noch wenige freie Zimmer verfügbar. Nutze deine Chance auf einen entspannten Aufenthalt – jetzt buchen und profitiere von unserem Kurzfrist-Angebot.</p>',
    cta_label: 'Jetzt buchen',
    segment: 'all',
  },
  {
    id: 'wiederkehrer',
    eyebrow: 'Retention',
    label: 'Wiederkehrer zurückholen',
    title: 'Wir vermissen dich, {{first_name}}!',
    body: '<p>Es ist eine Weile her, seit wir dich zuletzt begrüßen durften. Wir würden uns sehr freuen, dich bald wieder im {{hotel_name}} willkommen zu heißen.</p>',
    cta_label: 'Zimmer reservieren',
    segment: 'lapsed',
  },
  {
    id: 'saison',
    eyebrow: 'Saisonangebot',
    label: 'Saison-Angebot',
    title: 'Unser aktuelles Saison-Highlight',
    body: '<p>Die neue Saison bringt besondere Angebote und Erlebnisse. Entdecke unser Saisonpaket und genieße unvergessliche Momente bei uns im {{hotel_name}}.</p>',
    cta_label: 'Angebot ansehen',
    segment: 'all',
  },
  {
    id: 'event',
    eyebrow: 'Event',
    label: 'Event ankündigen',
    title: 'Einladung: Besonderes Event im {{hotel_name}}',
    body: '<p>Wir laden dich herzlich zu einem besonderen Abend bei uns ein. Freue dich auf ein unvergessliches Erlebnis in einzigartiger Atmosphäre.</p>',
    cta_label: 'Mehr erfahren',
    segment: 'all',
  },
];

const DEMO_CTX = {
  first_name: 'Anna',
  last_name: 'Schmidt',
  hotel_name: p.hotelName,
  visit_count: 3,
  last_visit_date: '24.12.2025',
  first_visit_date: '15.07.2024',
};

// Client-Strings (Alpine) — via define:vars
const ceT = {
  editorPlaceholder: bt('ce.editor.placeholder', lang),
  eveWriting: bt('ce.eve.writing', lang),
  eveWrite: bt('ce.eve.write', lang),
  errAiNotConf: bt('ce.err.ainotconf', lang),
  errEve: bt('ce.err.eve', lang),
  promptLink: bt('ce.prompt.link', lang),
  alertUrl: bt('ce.alert.url', lang),
  noTitle: bt('ce.preview.notitle', lang),
  noText: bt('ce.preview.notext', lang),
  noSubject: bt('ce.email.nosubject', lang),
  errName: bt('ce.err.name', lang),
  errTitle: bt('ce.err.title', lang),
  errBody: bt('ce.err.body', lang),
  errChannel: bt('ce.err.channel', lang),
  errDate: bt('ce.err.date', lang),
  errUnknownVars: bt('ce.err.unknownvars', lang),
  errSave: bt('ce.err.save', lang),
  errNet: bt('ce.err.net', lang),
  errUnknown: bt('ce.err.unknown', lang),
  saving: bt('ce.saving', lang),
  saveCreate: bt('ce.save', lang),
  toastSaved: bt('ce.toast.saved', lang),
  pushChars: bt('ce.push.chars', lang),
};
---

<div class="ce-wrap" x-data="campaignEditor()" x-init="init()">

  <!-- ── Setup-Zeile (oben, volle Breite) ──────────────────────────────────── -->
  <div class="ce-setup">
    <div class="ce-setup-field ce-setup-anlass">
      <span class="ce-label">{bt('ce.anlass', lang)}</span>
      <select class="s-input s-input--sm s-input--auto" x-model="form.anlass" @change="selectAnlass(form.anlass)">
        {ANLASS_DEFS.map(t => <option value={t.id}>{bt('ce.anlass.' + t.id + '.label', lang)}</option>)}
      </select>
    </div>

    <div class="ce-setup-field ce-setup-name">
      <span class="ce-label">{bt('ce.name', lang)}</span>
      <input type="text" x-model="form.name" placeholder={bt('ce.name.ph', lang)} class="s-input" />
    </div>

    <div class="ce-setup-field ce-setup-seg">
      <span class="ce-label">{bt('ce.recipients', lang)}</span>
      <div class="ce-seg-row">
        <button type="button" class="ce-seg-chip" :class="form.segment === 'all' ? 'is-on' : ''" @click="form.segment = 'all'">
          <span class="ce-seg-name">{bt('ce.seg.all', lang)}</span>
          <span class="ce-seg-count" x-text="segAll"></span>
        </button>
        <button type="button" class="ce-seg-chip" :class="form.segment === 'loyal' ? 'is-on' : ''" @click="form.segment = 'loyal'">
          <span class="ce-seg-name">{bt('ce.seg.loyal', lang)}</span>
          <span class="ce-seg-count" x-text="segLoyal"></span>
        </button>
        <button type="button" class="ce-seg-chip" :class="form.segment === 'lapsed' ? 'is-on' : ''" @click="form.segment = 'lapsed'">
          <span class="ce-seg-name">{bt('ce.seg.lapsed', lang)}</span>
          <span class="ce-seg-count" x-text="segLapsed"></span>
        </button>
      </div>
    </div>

    <div class="ce-setup-field ce-setup-ch">
      <span class="ce-label">{bt('ce.channel', lang)}</span>
      <div class="ce-channel-row">
        <button type="button" class="ce-ch-chip" :class="form.channels.includes('wallet_push') ? 'is-on' : ''" @click="toggleChannel('wallet_push')">{bt('cm.ch.wallet_push', lang)}</button>
        <button type="button" class="ce-ch-chip" :class="form.channels.includes('email') ? 'is-on' : ''" @click="toggleChannel('email')">{bt('cm.ch.email', lang)}</button>
      </div>
    </div>
  </div>

  <!-- ── Zweigeteilt: Composer (links) + Vorschau (rechts, sticky) ─────────── -->
  <div class="ce-main">

    <!-- LINKS — Composer -->
    <div class="ce-composer">

      <!-- Eve-Assist im Feld (kein zweiter Block) -->
      <div class="ce-eve-row">
        <input type="text" x-model="eve.prompt" class="s-input ce-eve-input"
          placeholder={bt('ce.eve.ph', lang)}
          @keydown.enter.prevent="eveWrite()" :disabled="eve.loading" />
        <button type="button" class="v9-btn ce-eve-btn" @click="eveWrite()"
          :disabled="eve.loading || !eve.prompt.trim()"
          x-text="eve.loading ? cfg.T.eveWriting : cfg.T.eveWrite"></button>
      </div>

      <!-- Kanal-Inhalts-Tabs (nur wenn BEIDE Kanäle) -->
      <template x-if="form.channels.length === 2">
        <div class="ce-ctabs">
          <button type="button" :class="contentTab === 'email' ? 'is-on' : ''" @click="contentTab = 'email'">{bt('cm.ch.email', lang)}</button>
          <button type="button" :class="contentTab === 'push' ? 'is-on' : ''" @click="contentTab = 'push'">{bt('cm.ch.wallet_push', lang)}</button>
        </div>
      </template>

      <!-- ── E-Mail / Primär-Inhalt (immer im DOM → TipTap bleibt gemountet) ── -->
      <div class="ce-panel" x-show="contentTab === 'email' || form.channels.length < 2">
        <label class="ce-field">
          <span class="ce-label" x-text="form.channels.includes('email') ? cfgLabel.subject : cfgLabel.title"></span>
          <input type="text" x-model="form.title" placeholder={bt('ce.title.ph', lang)} class="s-input s-input--lg" />
        </label>

        <div class="ce-toolbar">
          <button type="button" @click="exec('toggleBold')"   :class="active.bold ? 'is-on' : ''" title={bt('ce.tb.bold', lang)}><strong>B</strong></button>
          <button type="button" @click="exec('toggleItalic')" :class="active.italic ? 'is-on' : ''" title={bt('ce.tb.italic', lang)} class="ce-tb-i"><em>I</em></button>
          <button type="button" @click="exec('toggleHeading', {level: 2})" :class="active.h2 ? 'is-on' : ''" title={bt('ce.tb.h2', lang)}>H2</button>
          <button type="button" @click="exec('toggleBulletList')"  :class="active.bullet  ? 'is-on' : ''" title={bt('ce.tb.bullet', lang)}>•</button>
          <button type="button" @click="exec('toggleOrderedList')" :class="active.ordered ? 'is-on' : ''" title={bt('ce.tb.ordered', lang)}>1.</button>
          <button type="button" @click="setLink()" :class="active.link ? 'is-on' : ''" title={bt('ce.tb.link', lang)}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
        </div>

        <div id="ce-tiptap-mount" class="ce-editor"></div>

        <div class="ce-var-chips">
          <span class="ce-var-label">{bt('ce.var.label', lang)}</span>
          {VARIABLE_UI_DEFS.map(v => (
            <button type="button" class="ce-var-chip" @click={`insertVariable('${v.key}')`} :title="`Beispiel: ${v.example}`">
              {`{{${v.key}}}`}
            </button>
          ))}
        </div>

        <div class="ce-field" style="margin-top:16px">
          <span class="ce-label">{bt('ce.cta', lang)}</span>
          <div class="ce-cta-row">
            <input type="text" x-model="form.cta_label" placeholder={bt('ce.cta.labelph', lang)} class="s-input" />
            <input type="url" x-model="form.cta_url" placeholder="https://…" class="s-input" />
          </div>
        </div>
      </div>

      <!-- ── Wallet-Push-Inhalt (nur wenn BEIDE Kanäle, Push-Tab) ──────────── -->
      <div class="ce-panel" x-show="form.channels.length === 2 && contentTab === 'push'" x-cloak>
        <div class="ce-push-head">
          <span class="ce-hint" set:html={bt('ce.push.note', lang)}></span>
          <button type="button" class="ce-push-fill" @click="fillPushFromEmail()">{bt('ce.push.fromemail', lang)}</button>
        </div>

        <label class="ce-field">
          <span class="ce-label">{bt('ce.push.title', lang)}</span>
          <input type="text" x-model="form.push_title" maxlength="80" placeholder={bt('ce.push.titleph', lang)} class="s-input" />
        </label>

        <label class="ce-field">
          <span class="ce-label">{bt('ce.push.body', lang)}</span>
          <textarea x-model="form.push_body" maxlength="240" rows="3" placeholder={bt('ce.push.bodyph', lang)} class="s-input ce-push-textarea"></textarea>
          <span class="ce-hint ce-push-count"><span x-text="(form.push_body || '').length"></span> / 240 {bt('ce.push.chars', lang)}</span>
        </label>

        <div class="ce-var-chips">
          <span class="ce-var-label">{bt('ce.var.label', lang)}</span>
          {VARIABLE_UI_DEFS.map(v => (
            <button type="button" class="ce-var-chip" @click={`insertPushVariable('${v.key}')`} :title="`Beispiel: ${v.example}`">
              {`{{${v.key}}}`}
            </button>
          ))}
        </div>
      </div>

    </div>

    <!-- RECHTS — Live-Vorschau (sticky) -->
    <div class="ce-preview">
      <div class="ce-preview-head">
        <div class="ce-preview-toggle">
          <button type="button" x-show="form.channels.includes('wallet_push')" :class="previewChannel === 'wallet' ? 'is-on' : ''" @click="previewChannel = 'wallet'">{bt('cm.ch.wallet_push', lang)}</button>
          <button type="button" x-show="form.channels.includes('email')" :class="previewChannel === 'email' ? 'is-on' : ''" @click="previewChannel = 'email'">{bt('cm.ch.email', lang)}</button>
        </div>
        <select x-model="previewLang" class="s-input s-input--sm s-input--auto" aria-label={bt('ce.preview.langaria', lang)}>
          {LANGS_DISPLAY.map(l => <option value={l}>{l.toUpperCase()}</option>)}
        </select>
      </div>

      <!-- Wallet-Push Mockup (nutzt Push-Inhalt, Fallback E-Mail) -->
      <div x-show="previewChannel === 'wallet' && form.channels.includes('wallet_push')">
        <div class="ce-mockup">
          <div class="ce-mockup-frame">
            <div class="ce-mockup-status">{bt('ce.mockup.notif', lang)}</div>
            <div class="ce-mockup-card">
              <div class="ce-mockup-brand">
                <span class="ce-mockup-logo" style={`background:${p.brandPrimary}`}>{p.hotelName.slice(0, 1).toUpperCase()}</span>
                <div>
                  <div class="ce-mockup-hotel">{p.hotelName}</div>
                  <div class="ce-mockup-now">{bt('ce.mockup.now', lang)}</div>
                </div>
              </div>
              <div class="ce-mockup-title" x-text="previewPushTitle"></div>
              <div class="ce-mockup-body" x-text="previewPushBody"></div>
              <template x-if="form.cta_label && form.cta_url">
                <div class="ce-mockup-cta">
                  <span class="ce-mockup-cta-label" x-text="previewCtaLabel"></span>
                </div>
              </template>
              <div class="ce-mockup-footer">{bt('ce.mockup.unsub', lang)}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- E-Mail Mockup -->
      <div x-show="previewChannel === 'email' && form.channels.includes('email')">
        <div class="ce-email-frame">
          <div class="ce-email-from">
            <div class="ce-email-avatar" style={`background:${p.brandPrimary}`}>{p.hotelName.slice(0, 1).toUpperCase()}</div>
            <div>
              <div class="ce-email-sender">{p.hotelName}</div>
              <div class="ce-email-addr">{bt('ce.email.via', lang)}</div>
            </div>
          </div>
          <div class="ce-email-subject" x-text={`previewTitle || ${JSON.stringify(bt('ce.email.nosubject', lang))}`}></div>
          <div class="ce-email-body" x-html="previewBody"></div>
          <template x-if="form.cta_label">
            <div class="ce-email-cta-wrap">
              <span class="ce-email-cta-btn" style={`background:${p.brandPrimary}`} x-text="previewCtaLabel"></span>
            </div>
          </template>
          <div class="ce-email-footer">{bt('ce.email.footer', lang).replace('{hotel}', p.hotelName)} · <span style="text-decoration:underline">{bt('ce.mockup.unsub', lang)}</span></div>
        </div>
      </div>
    </div>

  </div>

  <!-- Error Flash -->
  <template x-if="errorMsg">
    <div class="ce-flash" x-text="errorMsg"></div>
  </template>

  <!-- ── Versand + Aktionen (unten) ────────────────────────────────────────── -->
  <div class="ce-footer">
    <div class="ce-footer-fields">
      <div class="ce-setup-field">
        <span class="ce-label">{bt('ce.lang', lang)}</span>
        <select x-model="form.target_lang" class="s-input s-input--sm s-input--auto">
          <option value="">{bt('ce.lang.all', lang)}</option>
          {LANGS_DISPLAY.map(l => <option value={l}>{l.toUpperCase()}</option>)}
        </select>
      </div>
      <div class="ce-setup-field">
        <span class="ce-label">{bt('ce.send', lang)}</span>
        <div class="ce-send-row">
          <div class="ce-radio-group">
            <label class="ce-radio"><input type="radio" x-model="form.schedule_mode" value="now" /><span>{bt('ce.send.now', lang)}</span></label>
            <label class="ce-radio"><input type="radio" x-model="form.schedule_mode" value="later" /><span>{bt('ce.send.later', lang)}</span></label>
          </div>
          <input type="datetime-local" x-show="form.schedule_mode === 'later'" x-cloak x-model="form.scheduled_at" class="s-input s-input--sm s-input--auto" />
        </div>
      </div>
    </div>
    <div class="ce-actions">
      <a href="/marketing/campaigns" class="v9-btn ce-btn-ghost">{bt('dre.cancel', lang)}</a>
      <button type="button" class="v9-btn ce-btn-primary" :disabled="submitting" @click="save()"
        x-text="submitting ? cfg.T.saving : cfg.T.saveCreate"></button>
    </div>
  </div>

</div>

<script is:inline define:vars={{
  TEMPLATES: p.templates,
  HOTEL_NAME: p.hotelName,
  HOTEL_DEFAULT: p.hotelDefaultLang,
  DEMO_CTX,
  ANLASS_DEFS,
  BRAND_PRIMARY: p.brandPrimary,
  LOGO_URL: p.logoUrl,
  SEGMENT_COUNTS: p.segmentCounts,
  CE_T: ceT,
  CE_LABELS: { subject: bt('ce.title', lang), title: bt('ce.push.title', lang) },
}}>
  window.__RETAHA_CE__ = {
    TEMPLATES, HOTEL_NAME, HOTEL_DEFAULT, DEMO_CTX,
    ANLASS: ANLASS_DEFS, BRAND_PRIMARY, LOGO_URL,
    SEGMENT_COUNTS, T: CE_T, LABELS: CE_LABELS,
  };
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Link from '@tiptap/extension-link';
  import Placeholder from '@tiptap/extension-placeholder';

  function renderVars(text: string, ctx: any, footer?: any): string {
    const REGEX = /\{\{\s*([a-z_][a-z0-9_]*)\s*\}\}/gi;
    return text.replace(REGEX, (full, name: string) => {
      const key = name.toLowerCase();
      if (key in ctx) return String(ctx[key] ?? '');
      if (footer && key in footer) return footer[key] ?? '';
      return full;
    });
  }

  function stripHtmlToText(html: string): string {
    const tmp = document.createElement('div');
    tmp.innerHTML = html || '';
    return (tmp.textContent || (tmp as any).innerText || '').replace(/\s+/g, ' ').trim();
  }

  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('campaignEditor', () => ({
      cfg: (window as any).__RETAHA_CE__,
      cfgLabel: (window as any).__RETAHA_CE__.LABELS,
      editor: null as any,
      submitting: false,
      errorMsg: '' as string,
      active: { bold: false, italic: false, h2: false, bullet: false, ordered: false, link: false },
      previewLang: 'de',
      previewChannel: 'wallet' as 'wallet' | 'email',
      contentTab: 'email' as 'email' | 'push',
      eve: { prompt: '', loading: false },
      form: {
        anlass: 'adhoc' as string,
        name: '',
        channels: ['wallet_push', 'email'] as string[],
        segment: 'all' as string,
        target_lang: '',
        schedule_mode: 'now' as 'now' | 'later',
        scheduled_at: '',
        title: '',
        body_html: '<p></p>',
        cta_label: '',
        cta_url: '',
        push_title: '',
        push_body: '',
      },

      init() {
        this.previewLang = this.cfg.HOTEL_DEFAULT;
        const mount = document.getElementById('ce-tiptap-mount');
        if (!mount) return;
        this.editor = new Editor({
          element: mount,
          extensions: [
            StarterKit.configure({ heading: { levels: [2, 3] }, link: false }),
            Link.configure({ openOnClick: false, autolink: false, linkOnPaste: false }),
            Placeholder.configure({ placeholder: this.cfg.T.editorPlaceholder, showOnlyCurrent: false }),
          ],
          content: '<p></p>',
          onUpdate: () => {
            this.form.body_html = this.editor.getHTML();
            this._refreshActive();
          },
          onSelectionUpdate: () => this._refreshActive(),
        });
      },

      selectAnlass(id: string) {
        const tile = this.cfg.ANLASS.find((t: any) => t.id === id);
        if (!tile) return;
        this.form.anlass = id;
        this.form.title = tile.title;
        this.form.cta_label = tile.cta_label;
        this.form.segment = tile.segment;
        const body = tile.body || '<p></p>';
        this.form.body_html = body;
        if (this.editor) this.editor.commands.setContent(body);
      },

      toggleChannel(ch: string) {
        if (this.form.channels.includes(ch)) {
          if (this.form.channels.length > 1) {
            this.form.channels = this.form.channels.filter((x: string) => x !== ch);
          }
        } else {
          this.form.channels = [...this.form.channels, ch];
        }
        // Vorschau-Kanal + Inhalts-Tab konsistent halten
        const pvChannel = this.previewChannel === 'wallet' ? 'wallet_push' : 'email';
        if (!this.form.channels.includes(pvChannel)) {
          this.previewChannel = this.form.channels.includes('wallet_push') ? 'wallet' : 'email';
        }
        if (this.form.channels.length < 2) this.contentTab = 'email';
      },

      get segAll() {
        const { allWallet, allEmail } = this.cfg.SEGMENT_COUNTS;
        const total = (this.form.channels.includes('wallet_push') ? allWallet : 0)
                    + (this.form.channels.includes('email') ? allEmail : 0);
        return total > 0 ? total.toLocaleString('de') : '—';
      },
      get segLoyal() {
        const n = this.cfg.SEGMENT_COUNTS.loyal;
        return n > 0 ? n.toLocaleString('de') : '—';
      },
      get segLapsed() {
        const n = this.cfg.SEGMENT_COUNTS.lapsed;
        return n > 0 ? n.toLocaleString('de') : '—';
      },

      fillPushFromEmail() {
        this.form.push_title = (this.form.title || '').slice(0, 80);
        const plain = stripHtmlToText(this.editor ? this.editor.getHTML() : this.form.body_html);
        this.form.push_body = plain.slice(0, 240);
      },

      insertPushVariable(key: string) {
        this.form.push_body = (this.form.push_body || '') + `{{${key}}}`;
      },

      async eveWrite() {
        if (!this.eve.prompt.trim() || this.eve.loading) return;
        this.eve.loading = true;
        this.errorMsg = '';
        try {
          const res = await fetch('/api/marketing/campaigns/generate-with-eve', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: this.eve.prompt }),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'ai_not_configured'
              ? this.cfg.T.errAiNotConf
              : (data.error || this.cfg.T.errEve);
            return;
          }
          this.form.title = data.title;
          const body = data.body_html || '<p></p>';
          this.form.body_html = body;
          if (this.editor) this.editor.commands.setContent(body);
          if (data.cta_label) this.form.cta_label = data.cta_label;
          this.form.anlass = 'adhoc';
          this.contentTab = 'email';
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ' ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.eve.loading = false;
        }
      },

      _refreshActive() {
        if (!this.editor) return;
        const e = this.editor;
        this.active = {
          bold: e.isActive('bold'), italic: e.isActive('italic'),
          h2: e.isActive('heading', { level: 2 }),
          bullet: e.isActive('bulletList'), ordered: e.isActive('orderedList'),
          link: e.isActive('link'),
        };
      },

      exec(cmd: string, opts: any = {}) {
        if (!this.editor) return;
        (this.editor.chain().focus() as any)[cmd](opts).run();
      },

      setLink() {
        if (!this.editor) return;
        const url = window.prompt(this.cfg.T.promptLink, this.editor.getAttributes('link').href || 'https://');
        if (url === null) return;
        if (url === '') {
          this.editor.chain().focus().extendMarkRange('link').unsetLink().run();
          return;
        }
        if (!/^(https?:|mailto:)/i.test(url)) { alert(this.cfg.T.alertUrl); return; }
        this.editor.chain().focus().extendMarkRange('link').setLink({ href: url, target: '_blank' }).run();
      },

      insertVariable(key: string) {
        if (!this.editor) return;
        this.editor.chain().focus().insertContent(`{{${key}}}`).run();
      },

      get previewTitle() {
        return renderVars(this.form.title || this.cfg.T.noTitle, this.cfg.DEMO_CTX);
      },
      get previewBody() {
        const html = this.form.body_html || `<p class="ce-empty">${this.cfg.T.noText}</p>`;
        return renderVars(html, this.cfg.DEMO_CTX, { unsubscribe_link: '#' });
      },
      get previewCtaLabel() {
        return renderVars(this.form.cta_label || '', this.cfg.DEMO_CTX);
      },
      // Push-Vorschau: eigener Push-Inhalt, Fallback auf (gekürzten) E-Mail-Inhalt.
      get previewPushTitle() {
        const t = (this.form.push_title && this.form.push_title.trim()) ? this.form.push_title : this.form.title;
        return renderVars(t || this.cfg.T.noTitle, this.cfg.DEMO_CTX);
      },
      get previewPushBody() {
        const raw = (this.form.push_body && this.form.push_body.trim())
          ? this.form.push_body
          : stripHtmlToText(this.form.body_html);
        return renderVars(raw || this.cfg.T.noText, this.cfg.DEMO_CTX);
      },

      async save() {
        if (this.submitting) return;
        this.errorMsg = '';
        const bodyHtml = this.editor ? this.editor.getHTML() : this.form.body_html;

        if (!this.form.name?.trim()) { this.errorMsg = this.cfg.T.errName; return; }
        if (this.form.channels.length === 0) { this.errorMsg = this.cfg.T.errChannel; return; }
        if (!this.form.title?.trim()) { this.errorMsg = this.cfg.T.errTitle; return; }
        if (!bodyHtml?.trim() || bodyHtml === '<p></p>') { this.errorMsg = this.cfg.T.errBody; return; }

        const target_filter: any = {};
        if (this.form.segment === 'loyal') target_filter.min_visit_count = 3;
        if (this.form.segment === 'lapsed') target_filter.min_visit_count = 1;
        if (this.form.target_lang) target_filter.language = this.form.target_lang;

        const payload: any = {
          name: this.form.name.trim(),
          channels: this.form.channels,
          target_filter: Object.keys(target_filter).length ? target_filter : null,
          title_default: this.form.title.trim(),
          body_default_html: bodyHtml,
          cta_label_default: this.form.cta_label?.trim() || null,
          cta_url: this.form.cta_url?.trim() || null,
        };
        // Separater Push-Inhalt nur, wenn BEIDE Kanäle aktiv + ausgefüllt.
        // (Push-only nutzt title/body als Inhalt; leer → Versand kürzt die E-Mail.)
        if (this.form.channels.includes('wallet_push') && this.form.channels.includes('email')) {
          const pt = this.form.push_title?.trim() || '';
          const pb = this.form.push_body?.trim() || '';
          if (pt) payload.push_title_default = pt;
          if (pb) payload.push_body_default = pb;
        }
        if (this.form.schedule_mode === 'later') {
          if (!this.form.scheduled_at) { this.errorMsg = this.cfg.T.errDate; return; }
          payload.scheduled_at = new Date(this.form.scheduled_at).toISOString();
        }

        this.submitting = true;
        try {
          const res = await fetch('/api/marketing/campaigns/create', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'invalid_variables'
              ? `${this.cfg.T.errUnknownVars} ${(data.unknown || []).join(', ')}`
              : (data.error || this.cfg.T.errSave);
            return;
          }
          window.retahaToastFlash && window.retahaToastFlash(this.cfg.T.toastSaved);
          window.location.href = `/marketing/campaigns/${data.id}`;
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ' ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.submitting = false;
        }
      },
    }));
  });
</script>

