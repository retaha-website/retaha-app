---
// V9 Campaign-Editor — Komposition B (Kanal-Karten)
//
// Setup-Zeile oben (Anlass · Name · Empfänger · Kanal · Versand · Sprache).
// Darunter pro aktivem Kanal EINE Karte mit ihren Feldern UND ihrer Mini-Vorschau
// direkt darunter — kein getrennter Vorschau-Bereich, kein Edit/Vorschau-Mismatch.
//
// C-Full: getrennter Inhalt je Kanal. E-Mail-Karte = Betreff + Rich-Text + CTA
// (title/body/cta). Wallet-Karte = kurzer Titel + Text (push_title/push_body).
// Wallet-only → der Push-Inhalt wird zum Primär-Inhalt (title/body sind NOT NULL).

import { VARIABLE_UI_DEFS } from '@retaha/marketing';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

interface Tpl {
  id: string; name: string; title_i18n: any; body_i18n: any;
  cta_label_i18n: any | null; cta_url: string | null; hero_image_url: string | null;
}
interface SegmentCounts { allWallet: number; allEmail: number; loyal: number; lapsed: number; }
interface Props {
  templates: Tpl[]; hotelName: string; hotelDefaultLang: string; enabledLangs: string[];
  brandPrimary: string; logoUrl: string | null; segmentCounts: SegmentCounts;
}
const p = Astro.props as Props;

const ANLASS_DEFS = [
  { id: 'adhoc', eyebrow: 'Frei', label: 'Ad-hoc (leer)', title: '', body: '', cta_label: '', segment: 'all' },
  { id: 'zimmer', eyebrow: 'Auslastung', label: 'Zimmer füllen', title: 'Freie Zimmer – jetzt buchen & sparen', body: '<p>Wir haben noch wenige freie Zimmer verfügbar. Nutze deine Chance auf einen entspannten Aufenthalt – jetzt buchen und profitiere von unserem Kurzfrist-Angebot.</p>', cta_label: 'Jetzt buchen', segment: 'all' },
  { id: 'wiederkehrer', eyebrow: 'Retention', label: 'Wiederkehrer zurückholen', title: 'Wir vermissen dich, {{first_name}}!', body: '<p>Es ist eine Weile her, seit wir dich zuletzt begrüßen durften. Wir würden uns sehr freuen, dich bald wieder im {{hotel_name}} willkommen zu heißen.</p>', cta_label: 'Zimmer reservieren', segment: 'lapsed' },
  { id: 'saison', eyebrow: 'Saisonangebot', label: 'Saison-Angebot', title: 'Unser aktuelles Saison-Highlight', body: '<p>Die neue Saison bringt besondere Angebote und Erlebnisse. Entdecke unser Saisonpaket und genieße unvergessliche Momente bei uns im {{hotel_name}}.</p>', cta_label: 'Angebot ansehen', segment: 'all' },
  { id: 'event', eyebrow: 'Event', label: 'Event ankündigen', title: 'Einladung: Besonderes Event im {{hotel_name}}', body: '<p>Wir laden dich herzlich zu einem besonderen Abend bei uns ein. Freue dich auf ein unvergessliches Erlebnis in einzigartiger Atmosphäre.</p>', cta_label: 'Mehr erfahren', segment: 'all' },
];

const DEMO_CTX = {
  first_name: 'Anna', last_name: 'Schmidt', hotel_name: p.hotelName,
  visit_count: 3, last_visit_date: '24.12.2025', first_visit_date: '15.07.2024',
};

const ceT = {
  editorPlaceholder: bt('ce.editor.placeholder', lang),
  eveWriting: bt('ce.eve.writing', lang),
  eveWrite: bt('ce.eve.write', lang),
  errAiNotConf: bt('ce.err.ainotconf', lang),
  errEve: bt('ce.err.eve', lang),
  promptLink: bt('ce.prompt.link', lang),
  alertUrl: bt('ce.alert.url', lang),
  noTitle: bt('ce.preview.notitle', lang),
  noText: bt('ce.preview.notext', lang),
  noSubject: bt('ce.email.nosubject', lang),
  errName: bt('ce.err.name', lang),
  errTitle: bt('ce.err.title', lang),
  errBody: bt('ce.err.body', lang),
  errChannel: bt('ce.err.channel', lang),
  errDate: bt('ce.err.date', lang),
  errUnknownVars: bt('ce.err.unknownvars', lang),
  errSave: bt('ce.err.save', lang),
  errNet: bt('ce.err.net', lang),
  errUnknown: bt('ce.err.unknown', lang),
  saving: bt('ce.saving', lang),
  saveCreate: bt('ce.save', lang),
  toastSaved: bt('ce.toast.saved', lang),
};
---

<div class="ce-wrap" x-data="campaignEditor()">

  <!-- ── Anlass + Name (zwei getrennte Boxen oben) ────────────────────────── -->
  <div class="ce-top">
    <div class="ce-box ce-box--anlass">
      <span class="ce-label">{bt('ce.anlass', lang)}</span>
      <div class="s-select-wrap">
        <select class="s-select" x-model="form.anlass" @change="selectAnlass(form.anlass)">
          {ANLASS_DEFS.map(t => <option value={t.id}>{bt('ce.anlass.' + t.id + '.label', lang)}</option>)}
        </select>
      </div>
    </div>
    <div class="ce-box ce-box--name">
      <span class="ce-label">{bt('ce.name', lang)}</span>
      <input type="text" x-model="form.name" placeholder={bt('ce.name.ph', lang)} class="s-input" />
    </div>
  </div>

  <!-- ── Empfänger · Kanal · Versand (eine Box mit Switchern) ─────────────── -->
  <div class="ce-box ce-controls">
    <div class="ce-ctrl-field">
      <span class="ce-label">{bt('ce.recipients', lang)}</span>
      <div class="ce-seg">
        <button type="button" :class="form.segment === 'all' ? 'is-on' : ''" @click="form.segment = 'all'">{bt('ce.seg.all', lang)}<span class="ce-seg-cnt" x-text="segAll"></span></button>
        <button type="button" :class="form.segment === 'loyal' ? 'is-on' : ''" @click="form.segment = 'loyal'">{bt('ce.seg.loyal', lang)}<span class="ce-seg-cnt" x-text="segLoyal"></span></button>
        <button type="button" :class="form.segment === 'lapsed' ? 'is-on' : ''" @click="form.segment = 'lapsed'">{bt('ce.seg.lapsed', lang)}<span class="ce-seg-cnt" x-text="segLapsed"></span></button>
      </div>
    </div>
    <div class="ce-ctrl-field">
      <span class="ce-label">{bt('ce.channel', lang)}</span>
      <div class="ce-seg">
        <button type="button" :class="form.channels.includes('wallet_push') ? 'is-on' : ''" @click="toggleChannel('wallet_push')">{bt('cm.ch.wallet_push', lang)}</button>
        <button type="button" :class="form.channels.includes('email') ? 'is-on' : ''" @click="toggleChannel('email')">{bt('cm.ch.email', lang)}</button>
      </div>
    </div>
    <div class="ce-ctrl-field">
      <span class="ce-label">{bt('ce.send', lang)}</span>
      <div class="ce-send-row">
        <div class="ce-seg">
          <button type="button" :class="form.schedule_mode === 'now' ? 'is-on' : ''" @click="form.schedule_mode = 'now'">{bt('ce.send.now', lang)}</button>
          <button type="button" :class="form.schedule_mode === 'later' ? 'is-on' : ''" @click="setScheduleLater()">{bt('ce.send.later', lang)}</button>
        </div>
        <input type="datetime-local" x-show="form.schedule_mode === 'later'" x-cloak x-model="form.scheduled_at" class="s-input s-input--sm s-input--auto" />
      </div>
    </div>
  </div>

  <p class="ce-autolang">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    {bt('ce.autolang', lang)}
  </p>

  <!-- ── Kanal-Karten (Edit + Mini-Vorschau zusammen) ─────────────────────── -->
  <div class="ce-cards">

    <!-- Wallet-Push Karte -->
    <div class="ce-card" x-show="form.channels.includes('wallet_push')">
      <div class="ce-card-head">
        <span class="ce-card-title ce-card-title--wallet">{bt('cm.ch.wallet_push', lang)}</span>
        <button type="button" class="ce-card-action" x-show="form.channels.includes('email')" @click="fillPushFromEmail()">{bt('ce.push.fromemail', lang)}</button>
      </div>

      <label class="ce-field">
        <span class="ce-label">{bt('ce.push.title', lang)}</span>
        <input type="text" x-model="form.push_title" maxlength="80" placeholder={bt('ce.push.titleph', lang)} class="s-input" />
      </label>
      <label class="ce-field">
        <span class="ce-label">{bt('ce.push.body', lang)}</span>
        <textarea x-model="form.push_body" maxlength="240" rows="3" placeholder={bt('ce.push.bodyph', lang)} class="s-input ce-textarea"></textarea>
        <span class="ce-hint ce-count"><span x-text="(form.push_body || '').length"></span> / 240 {bt('ce.push.chars', lang)}</span>
      </label>
      <label class="ce-field">
        <span class="ce-label">{bt('ce.push.deeplink', lang)}</span>
        <input type="url" x-model="form.cta_url" placeholder="https://…" class="s-input" />
      </label>
      <div class="ce-var-chips">
        <span class="ce-var-label">{bt('ce.var.label', lang)}</span>
        {VARIABLE_UI_DEFS.map(v => (
          <button type="button" class="ce-var-chip" @click={`insertPushVariable('${v.key}')`}>{`{{${v.key}}}`}</button>
        ))}
      </div>

      <div class="ce-card-pv">
        <span class="ce-pv-label">{bt('ce.preview', lang)}</span>
        <div class="ce-mockup">
          <div class="ce-mockup-frame">
            <div class="ce-mockup-status">{bt('ce.mockup.notif', lang)}</div>
            <div class="ce-mockup-card">
              <div class="ce-mockup-brand">
                <span class="ce-mockup-logo" style={`background:${p.brandPrimary}`}>{p.hotelName.slice(0, 1).toUpperCase()}</span>
                <div><div class="ce-mockup-hotel">{p.hotelName}</div><div class="ce-mockup-now">{bt('ce.mockup.now', lang)}</div></div>
              </div>
              <div class="ce-mockup-title" x-text="previewPushTitle"></div>
              <div class="ce-mockup-body" x-text="previewPushBody"></div>
              <template x-if="form.cta_url">
                <div class="ce-mockup-cta"><span class="ce-mockup-cta-label" x-text="previewCtaLabel || '→'"></span></div>
              </template>
              <div class="ce-mockup-footer">{bt('ce.mockup.unsub', lang)}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- E-Mail Karte -->
    <div class="ce-card" x-show="form.channels.includes('email')">
      <div class="ce-card-head">
        <span class="ce-card-title ce-card-title--email">{bt('cm.ch.email', lang)}</span>
      </div>

      <div class="ce-field">
        <span class="ce-label">{bt('ce.title', lang)}</span>
        <div class="ce-title-row">
          <input type="text" x-model="form.title" placeholder={bt('ce.title.ph', lang)} class="s-input" />
          <button type="button" class="ce-card-action ce-eve-btn" @click="openEve('title')"
            x-text="cfg.T.eveWrite"></button>
        </div>
      </div>

      <div class="ce-toolbar">
        <button type="button" @click="exec('toggleBold')"   :class="active.bold ? 'is-on' : ''" title={bt('ce.tb.bold', lang)}><strong>B</strong></button>
        <button type="button" @click="exec('toggleItalic')" :class="active.italic ? 'is-on' : ''" title={bt('ce.tb.italic', lang)} class="ce-tb-i"><em>I</em></button>
        <button type="button" @click="exec('toggleHeading', {level: 2})" :class="active.h2 ? 'is-on' : ''" title={bt('ce.tb.h2', lang)}>H2</button>
        <button type="button" @click="exec('toggleBulletList')"  :class="active.bullet  ? 'is-on' : ''" title={bt('ce.tb.bullet', lang)}>•</button>
        <button type="button" @click="exec('toggleOrderedList')" :class="active.ordered ? 'is-on' : ''" title={bt('ce.tb.ordered', lang)}>1.</button>
        <button type="button" @click="setLink()" :class="active.link ? 'is-on' : ''" title={bt('ce.tb.link', lang)}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
        <button type="button" class="ce-card-action ce-eve-btn ce-eve-toolbar-btn" @click="openEve('body')"
          x-text="cfg.T.eveWrite"></button>
      </div>
      <div class="ce-editor-wrap">
        <div id="ce-tiptap-mount" class="ce-editor"></div>
        <div class="ce-editor-ph" x-show="isEditorEmpty" x-cloak>{bt('ce.editor.placeholder', lang)}</div>
      </div>

      <div class="ce-var-chips">
        <span class="ce-var-label">{bt('ce.var.label', lang)}</span>
        {VARIABLE_UI_DEFS.map(v => (
          <button type="button" class="ce-var-chip" @click={`insertVariable('${v.key}')`}>{`{{${v.key}}}`}</button>
        ))}
      </div>

      <div class="ce-field" style="margin-top:14px">
        <span class="ce-label">{bt('ce.cta', lang)}</span>
        <div class="ce-cta-row">
          <input type="text" x-model="form.cta_label" placeholder={bt('ce.cta.labelph', lang)} class="s-input" />
          <input type="url" x-model="form.cta_url" placeholder="https://…" class="s-input" />
        </div>
      </div>

      <div class="ce-card-pv">
        <span class="ce-pv-label">{bt('ce.preview', lang)}</span>
        <div class="ce-email-frame">
          <div class="ce-email-from">
            <div class="ce-email-avatar" style={`background:${p.brandPrimary}`}>{p.hotelName.slice(0, 1).toUpperCase()}</div>
            <div><div class="ce-email-sender">{p.hotelName}</div><div class="ce-email-addr">{bt('ce.email.via', lang)}</div></div>
          </div>
          <div class="ce-email-subject" x-text={`previewTitle || ${JSON.stringify(bt('ce.email.nosubject', lang))}`}></div>
          <div class="ce-email-body" x-html="previewBody"></div>
          <template x-if="form.cta_label">
            <div class="ce-email-cta-wrap"><span class="ce-email-cta-btn" style={`background:${p.brandPrimary}`} x-text="previewCtaLabel"></span></div>
          </template>
          <div class="ce-email-footer">{bt('ce.email.footer', lang).replace('{hotel}', p.hotelName)} · <span style="text-decoration:underline">{bt('ce.mockup.unsub', lang)}</span></div>
        </div>
      </div>
    </div>

  </div>

  <template x-if="errorMsg && !eve.open"><div class="ce-flash" x-text="errorMsg"></div></template>

  <div class="ce-actions">
    <a href="/marketing/campaigns" class="v9-btn ce-btn-ghost">{bt('dre.cancel', lang)}</a>
    <button type="button" class="v9-btn ce-btn-primary" :disabled="submitting" @click="save()" x-text="submitting ? cfg.T.saving : cfg.T.saveCreate"></button>
  </div>

  <!-- ── Eve-Modal ────────────────────────────────────────────────────────── -->
  <div class="ce-eve-overlay" x-show="eve.open" x-cloak
    @click.self="if(!eve.loading) eve.open = false"
    @keydown.escape.window="if(eve.open && !eve.loading) eve.open = false">
    <div class="ce-eve-modal">
      <div class="ce-eve-mhd">
        <span class="ce-eve-mhd-title" x-text="eve.mode === 'title' ? '✦ Betreff formulieren' : '✦ Text formulieren'"></span>
        <button type="button" class="ce-eve-close" @click="eve.open = false" :disabled="eve.loading">✕</button>
      </div>
      <textarea class="s-input ce-eve-ta" x-model="eve.prompt"
        placeholder={bt('ce.eve.ph', lang)}
        :disabled="eve.loading"
        @keydown.meta.enter.prevent="eveWrite()"
        @keydown.ctrl.enter.prevent="eveWrite()"></textarea>
      <p class="ce-eve-err" x-show="errorMsg" x-cloak x-text="errorMsg"></p>
      <div class="ce-eve-mft">
        <button type="button" class="ce-eve-cancel" @click="eve.open = false" :disabled="eve.loading">
          {bt('dre.cancel', lang)}
        </button>
        <button type="button" class="ce-card-action ce-eve-gen" @click="eveWrite()"
          :disabled="eve.loading || !eve.prompt.trim()"
          x-text="eve.loading ? cfg.T.eveWriting : cfg.T.eveWrite"></button>
      </div>
    </div>
  </div>

</div>

<script is:inline define:vars={{
  TEMPLATES: p.templates, HOTEL_NAME: p.hotelName, HOTEL_DEFAULT: p.hotelDefaultLang,
  DEMO_CTX, ANLASS_DEFS, BRAND_PRIMARY: p.brandPrimary, LOGO_URL: p.logoUrl,
  SEGMENT_COUNTS: p.segmentCounts, CE_T: ceT,
}}>
  window.__RETAHA_CE__ = {
    TEMPLATES, HOTEL_NAME, HOTEL_DEFAULT, DEMO_CTX,
    ANLASS: ANLASS_DEFS, BRAND_PRIMARY, LOGO_URL, SEGMENT_COUNTS, T: CE_T,
  };
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Link from '@tiptap/extension-link';

  function renderVars(text: string, ctx: any, footer?: any): string {
    const REGEX = /\{\{\s*([a-z_][a-z0-9_]*)\s*\}\}/gi;
    return text.replace(REGEX, (full, name: string) => {
      const key = name.toLowerCase();
      if (key in ctx) return String(ctx[key] ?? '');
      if (footer && key in footer) return footer[key] ?? '';
      return full;
    });
  }
  function stripHtmlToText(html: string): string {
    const tmp = document.createElement('div');
    tmp.innerHTML = html || '';
    return (tmp.textContent || (tmp as any).innerText || '').replace(/\s+/g, ' ').trim();
  }
  function escapeHtml(s: string): string {
    return (s || '').replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m] as string));
  }

  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('campaignEditor', () => ({
      cfg: (window as any).__RETAHA_CE__,
      editor: null as any,
      submitting: false,
      errorMsg: '' as string,
      active: { bold: false, italic: false, h2: false, bullet: false, ordered: false, link: false },
      eve: { prompt: '', loading: false, open: false, mode: 'title' as string },
      form: {
        anlass: 'adhoc' as string, name: '', channels: ['wallet_push', 'email'] as string[],
        segment: 'all' as string, target_lang: '', schedule_mode: 'now' as 'now' | 'later', scheduled_at: '',
        title: '', body_html: '<p></p>', cta_label: '', cta_url: '', push_title: '', push_body: '',
      },

      _mountEditor(content: string) {
        if (this.editor) { this.editor.destroy(); this.editor = null; }
        const mount = document.getElementById('ce-tiptap-mount');
        if (!mount) return;
        this.editor = new Editor({
          element: mount,
          extensions: [
            StarterKit.configure({ heading: { levels: [2, 3] }, link: false }),
            Link.configure({ openOnClick: false, autolink: false, linkOnPaste: false }),
          ],
          content,
          onUpdate: () => { this.form.body_html = this.editor.getHTML(); this._refreshActive(); },
          onSelectionUpdate: () => this._refreshActive(),
        });
      },
      init() {
        if (this.editor) return;
        this._mountEditor('<p></p>');
      },
      openEve(mode: string) { this.eve.mode = mode; this.eve.open = true; this.errorMsg = ''; },

      selectAnlass(id: string) {
        const tile = this.cfg.ANLASS.find((t: any) => t.id === id);
        if (!tile) return;
        this.form.anlass = id;
        this.form.title = tile.title;
        this.form.cta_label = tile.cta_label;
        this.form.segment = tile.segment;
        const body = tile.body || '<p></p>';
        this.form.body_html = body;
        this._mountEditor(body);
      },

      toggleChannel(ch: string) {
        if (this.form.channels.includes(ch)) {
          if (this.form.channels.length > 1) this.form.channels = this.form.channels.filter((x: string) => x !== ch);
        } else {
          this.form.channels = [...this.form.channels, ch];
        }
      },

      // „Geplant" gewählt → Datum-Feld als Beispiel mit heute vorbefüllen
      // (nächste volle Stunde, damit es sicher in der Zukunft liegt).
      setScheduleLater() {
        this.form.schedule_mode = 'later';
        if (!this.form.scheduled_at) {
          const d = new Date(Date.now() + 60 * 60 * 1000);
          d.setMinutes(0, 0, 0);
          const pad = (n: number) => String(n).padStart(2, '0');
          this.form.scheduled_at = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
        }
      },

      get segAll() {
        const { allWallet, allEmail } = this.cfg.SEGMENT_COUNTS;
        const total = (this.form.channels.includes('wallet_push') ? allWallet : 0) + (this.form.channels.includes('email') ? allEmail : 0);
        return total > 0 ? total.toLocaleString('de') : '—';
      },
      get segLoyal() { const n = this.cfg.SEGMENT_COUNTS.loyal; return n > 0 ? n.toLocaleString('de') : '—'; },
      get segLapsed() { const n = this.cfg.SEGMENT_COUNTS.lapsed; return n > 0 ? n.toLocaleString('de') : '—'; },

      // Editor leer? — aus form.body_html (via getHTML in onUpdate, reaktiv).
      get isEditorEmpty() {
        const txt = (this.form.body_html || '').replace(/<[^>]*>/g, '').replace(/&nbsp;/g, ' ').trim();
        return txt === '';
      },

      fillPushFromEmail() {
        this.form.push_title = (this.form.title || '').slice(0, 80);
        this.form.push_body = stripHtmlToText(this.editor ? this.editor.getHTML() : this.form.body_html).slice(0, 240);
      },
      insertPushVariable(key: string) { this.form.push_body = (this.form.push_body || '') + `{{${key}}}`; },

      async eveWrite() {
        if (!this.eve.prompt.trim() || this.eve.loading) return;
        this.eve.loading = true; this.errorMsg = '';
        try {
          const res = await fetch('/api/marketing/campaigns/generate-with-eve', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: this.eve.prompt }),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'ai_not_configured' ? this.cfg.T.errAiNotConf : (data.error || this.cfg.T.errEve);
            return;
          }
          if (this.eve.mode !== 'body') this.form.title = data.title;
          if (this.eve.mode !== 'title') {
            const body = data.body_html || '<p></p>';
            this.form.body_html = body;
            if (data.cta_label) this.form.cta_label = data.cta_label;
            setTimeout(() => { this._mountEditor(body); }, 0);
          }
          this.form.anlass = 'adhoc';
          this.eve.open = false;
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ': ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.eve.loading = false;
        }
      },

      _refreshActive() {
        if (!this.editor) return;
        const e = this.editor;
        this.active = {
          bold: e.isActive('bold'), italic: e.isActive('italic'), h2: e.isActive('heading', { level: 2 }),
          bullet: e.isActive('bulletList'), ordered: e.isActive('orderedList'), link: e.isActive('link'),
        };
      },
      exec(cmd: string, opts: any = {}) { if (!this.editor) return; (this.editor.chain().focus() as any)[cmd](opts).run(); },
      setLink() {
        if (!this.editor) return;
        const url = window.prompt(this.cfg.T.promptLink, this.editor.getAttributes('link').href || 'https://');
        if (url === null) return;
        if (url === '') { this.editor.chain().focus().extendMarkRange('link').unsetLink().run(); return; }
        if (!/^(https?:|mailto:)/i.test(url)) { alert(this.cfg.T.alertUrl); return; }
        this.editor.chain().focus().extendMarkRange('link').setLink({ href: url, target: '_blank' }).run();
      },
      insertVariable(key: string) { if (!this.editor) return; this.editor.chain().focus().insertContent(`{{${key}}}`).run(); },

      get previewTitle() { return renderVars(this.form.title || this.cfg.T.noTitle, this.cfg.DEMO_CTX); },
      get previewBody() {
        const html = this.form.body_html || `<p class="ce-empty">${this.cfg.T.noText}</p>`;
        return renderVars(html, this.cfg.DEMO_CTX, { unsubscribe_link: '#' });
      },
      get previewCtaLabel() { return renderVars(this.form.cta_label || '', this.cfg.DEMO_CTX); },
      get previewPushTitle() {
        const t = (this.form.push_title && this.form.push_title.trim()) ? this.form.push_title : this.form.title;
        return renderVars(t || this.cfg.T.noTitle, this.cfg.DEMO_CTX);
      },
      get previewPushBody() {
        const raw = (this.form.push_body && this.form.push_body.trim()) ? this.form.push_body : stripHtmlToText(this.form.body_html);
        return renderVars(raw || this.cfg.T.noText, this.cfg.DEMO_CTX);
      },

      async save() {
        if (this.submitting) return;
        this.errorMsg = '';
        const hasEmail = this.form.channels.includes('email');
        const hasWallet = this.form.channels.includes('wallet_push');
        const emailBody = this.editor ? this.editor.getHTML() : this.form.body_html;

        if (!this.form.name?.trim()) { this.errorMsg = this.cfg.T.errName; return; }
        if (this.form.channels.length === 0) { this.errorMsg = this.cfg.T.errChannel; return; }
        if (hasEmail) {
          if (!this.form.title?.trim()) { this.errorMsg = this.cfg.T.errTitle; return; }
          if (!emailBody?.trim() || emailBody === '<p></p>') { this.errorMsg = this.cfg.T.errBody; return; }
        }
        if (hasWallet && !hasEmail) {
          if (!this.form.push_title?.trim()) { this.errorMsg = this.cfg.T.errTitle; return; }
          if (!this.form.push_body?.trim()) { this.errorMsg = this.cfg.T.errBody; return; }
        }

        const target_filter: any = {};
        if (this.form.segment === 'loyal') target_filter.min_visit_count = 3;
        if (this.form.segment === 'lapsed') target_filter.min_visit_count = 1;
        if (this.form.target_lang) target_filter.language = this.form.target_lang;

        // Kanal-Inhalt → API. Wallet-only: Push-Inhalt wird Primär-Inhalt (title/body NOT NULL).
        let titleDefault: string, bodyDefault: string;
        let pushTitleDefault: string | null = null, pushBodyDefault: string | null = null;
        if (hasEmail) {
          titleDefault = this.form.title.trim();
          bodyDefault = emailBody;
          if (hasWallet) {
            if (this.form.push_title?.trim()) pushTitleDefault = this.form.push_title.trim();
            if (this.form.push_body?.trim()) pushBodyDefault = this.form.push_body.trim();
          }
        } else {
          titleDefault = this.form.push_title.trim();
          bodyDefault = `<p>${escapeHtml(this.form.push_body.trim())}</p>`;
        }

        const payload: any = {
          name: this.form.name.trim(),
          channels: this.form.channels,
          target_filter: Object.keys(target_filter).length ? target_filter : null,
          title_default: titleDefault,
          body_default_html: bodyDefault,
          cta_label_default: this.form.cta_label?.trim() || null,
          cta_url: this.form.cta_url?.trim() || null,
        };
        if (pushTitleDefault) payload.push_title_default = pushTitleDefault;
        if (pushBodyDefault) payload.push_body_default = pushBodyDefault;
        if (this.form.schedule_mode === 'later') {
          if (!this.form.scheduled_at) { this.errorMsg = this.cfg.T.errDate; return; }
          payload.scheduled_at = new Date(this.form.scheduled_at).toISOString();
        }

        this.submitting = true;
        try {
          const res = await fetch('/api/marketing/campaigns/create', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'invalid_variables'
              ? `${this.cfg.T.errUnknownVars} ${(data.unknown || []).join(', ')}`
              : (data.error || this.cfg.T.errSave);
            return;
          }
          window.retahaToastFlash && window.retahaToastFlash(this.cfg.T.toastSaved);
          window.location.href = `/marketing/campaigns/${data.id}`;
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ' ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.submitting = false;
        }
      },
    }));
  });
</script>

