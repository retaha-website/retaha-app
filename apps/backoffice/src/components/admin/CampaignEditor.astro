---
// V9 Campaign-Editor — Hebel 1-5
//
// Hebel 1: Dual-Channel-Preview (Wallet + E-Mail)
// Hebel 2: Anlass-Kacheln ersetzen Template-Dropdown
// Hebel 3: "✦ Mit Eve schreiben" — AI-Generierung via Haiku
// Hebel 4: Benannte Segmente mit echten Zählern
// Hebel 5: Personalisierungs-Chips ersetzen Variable-Dropdown

import { VARIABLE_UI_DEFS } from '@retaha/marketing';

interface Tpl {
  id: string;
  name: string;
  title_i18n: any;
  body_i18n: any;
  cta_label_i18n: any | null;
  cta_url: string | null;
  hero_image_url: string | null;
}

interface SegmentCounts {
  allWallet: number;
  allEmail: number;
  loyal: number;
  lapsed: number;
}

interface Props {
  templates: Tpl[];
  hotelName: string;
  hotelDefaultLang: string;
  enabledLangs: string[];
  brandPrimary: string;
  logoUrl: string | null;
  segmentCounts: SegmentCounts;
}
const p = Astro.props as Props;

const LANGS_DISPLAY = p.enabledLangs.length > 0 ? p.enabledLangs : [p.hotelDefaultLang];

// Anlass-Kacheln — server-side definition, passed to client via define:vars
const ANLASS_DEFS = [
  {
    id: 'zimmer',
    eyebrow: 'Auslastung',
    label: 'Zimmer füllen',
    title: 'Freie Zimmer – jetzt buchen & sparen',
    body: '<p>Wir haben noch wenige freie Zimmer verfügbar. Nutze deine Chance auf einen entspannten Aufenthalt – jetzt buchen und profitiere von unserem Kurzfrist-Angebot.</p>',
    cta_label: 'Jetzt buchen',
    segment: 'all',
  },
  {
    id: 'wiederkehrer',
    eyebrow: 'Retention',
    label: 'Wiederkehrer zurückholen',
    title: 'Wir vermissen dich, {{first_name}}!',
    body: '<p>Es ist eine Weile her, seit wir dich zuletzt begrüßen durften. Wir würden uns sehr freuen, dich bald wieder im {{hotel_name}} willkommen zu heißen.</p>',
    cta_label: 'Zimmer reservieren',
    segment: 'lapsed',
  },
  {
    id: 'saison',
    eyebrow: 'Saisonangebot',
    label: 'Saison-Angebot',
    title: 'Unser aktuelles Saison-Highlight',
    body: '<p>Die neue Saison bringt besondere Angebote und Erlebnisse. Entdecke unser Saisonpaket und genieße unvergessliche Momente bei uns im {{hotel_name}}.</p>',
    cta_label: 'Angebot ansehen',
    segment: 'all',
  },
  {
    id: 'event',
    eyebrow: 'Event',
    label: 'Event ankündigen',
    title: 'Einladung: Besonderes Event im {{hotel_name}}',
    body: '<p>Wir laden dich herzlich zu einem besonderen Abend bei uns ein. Freue dich auf ein unvergessliches Erlebnis in einzigartiger Atmosphäre.</p>',
    cta_label: 'Mehr erfahren',
    segment: 'all',
  },
  {
    id: 'adhoc',
    eyebrow: 'Frei',
    label: 'Ad-hoc (leer)',
    title: '',
    body: '',
    cta_label: '',
    segment: 'all',
  },
];

const DEMO_CTX = {
  first_name: 'Anna',
  last_name: 'Schmidt',
  hotel_name: p.hotelName,
  visit_count: 3,
  last_visit_date: '24.12.2025',
  first_visit_date: '15.07.2024',
};
---

<div class="ce-wrap" x-data="campaignEditor()" x-init="init()">

  <!-- ── Anlass-Kacheln (Hebel 2) ──────────────────────────────────────── -->
  <div class="ce-anlass-row">
    {ANLASS_DEFS.map(tile => (
      <button
        type="button"
        class="ce-anlass-tile"
        :class={`form.anlass === '${tile.id}' ? 'is-on' : ''`}
        @click={`selectAnlass('${tile.id}')`}
      >
        <span class="ce-tile-eyebrow">{tile.eyebrow}</span>
        <span class="ce-tile-label">{tile.label}</span>
      </button>
    ))}
  </div>

  <!-- ── 3-Spalten-Grid ─────────────────────────────────────────────────── -->
  <div class="ce-grid">

    <!-- ── Spalte 1: Einstellungen ──────────────────────────────────────── -->
    <div class="ce-col ce-col-settings">

      <p class="ce-col-eyebrow">Einstellungen</p>

      <label class="ce-field">
        <span class="ce-label">Kampagnen-Name</span>
        <input type="text" x-model="form.name" placeholder="z.B. Sommerfest 2026" class="s-input" />
      </label>

      <!-- Kanal (Hebel 1) -->
      <div class="ce-field">
        <span class="ce-label">Kanal</span>
        <div class="ce-channel-row">
          <button type="button"
            class="ce-ch-chip"
            :class="form.channels.includes('wallet_push') ? 'is-on' : ''"
            @click="toggleChannel('wallet_push')"
          >Wallet-Push</button>
          <button type="button"
            class="ce-ch-chip"
            :class="form.channels.includes('email') ? 'is-on' : ''"
            @click="toggleChannel('email')"
          >E-Mail</button>
        </div>
        <span class="ce-hint">Wallet = Pass-Holder · E-Mail = DOI-Opt-ins. Min. 1 Kanal.</span>
      </div>

      <!-- Empfänger-Segmente (Hebel 4) -->
      <div class="ce-field">
        <span class="ce-label">Empfänger</span>
        <div class="ce-seg-row">
          <button type="button"
            class="ce-seg-chip"
            :class="form.segment === 'all' ? 'is-on' : ''"
            @click="form.segment = 'all'"
          >
            <span class="ce-seg-name">Alle</span>
            <span class="ce-seg-count" x-text="segAll"></span>
          </button>
          <button type="button"
            class="ce-seg-chip"
            :class="form.segment === 'loyal' ? 'is-on' : ''"
            @click="form.segment = 'loyal'"
          >
            <span class="ce-seg-name">Stammgäste</span>
            <span class="ce-seg-count" x-text="segLoyal"></span>
          </button>
          <button type="button"
            class="ce-seg-chip"
            :class="form.segment === 'lapsed' ? 'is-on' : ''"
            @click="form.segment = 'lapsed'"
          >
            <span class="ce-seg-name">Länger nicht da</span>
            <span class="ce-seg-count" x-text="segLapsed"></span>
          </button>
        </div>
        <span class="ce-hint">Stammgäste = ≥ 3 Besuche. Länger nicht da = &gt; 90 Tage.</span>
      </div>

      <label class="ce-field">
        <span class="ce-label">Sprache</span>
        <select x-model="form.target_lang" class="s-input ce-input-sm">
          <option value="">Alle Sprachen</option>
          {LANGS_DISPLAY.map(l => <option value={l}>{l.toUpperCase()}</option>)}
        </select>
      </label>

      <div class="ce-field">
        <span class="ce-label">Versand</span>
        <div class="ce-radio-group">
          <label class="ce-radio">
            <input type="radio" x-model="form.schedule_mode" value="now" />
            <span>Sofort</span>
          </label>
          <label class="ce-radio">
            <input type="radio" x-model="form.schedule_mode" value="later" />
            <span>Geplant</span>
          </label>
        </div>
        <label x-show="form.schedule_mode === 'later'" x-cloak style="display:block;margin-top:8px">
          <input type="datetime-local" x-model="form.scheduled_at" class="s-input" />
        </label>
      </div>

    </div>

    <!-- ── Spalte 2: Editor ──────────────────────────────────────────────── -->
    <div class="ce-col ce-col-editor">

      <p class="ce-col-eyebrow">Inhalt ({p.hotelDefaultLang.toUpperCase()})</p>
      <p class="ce-hint" style="margin-bottom:16px">Auto-Translation in alle aktivierten Sprachen beim Speichern.</p>

      <!-- Mit Eve schreiben (Hebel 3) -->
      <div class="ce-eve-row">
        <input
          type="text"
          x-model="eve.prompt"
          class="s-input ce-eve-input"
          placeholder="Was ist der Anlass? z.B. «Wir haben ein neues Wellness-Angebot»"
          @keydown.enter.prevent="eveWrite()"
          :disabled="eve.loading"
        />
        <button
          type="button"
          class="v9-btn ce-eve-btn"
          @click="eveWrite()"
          :disabled="eve.loading || !eve.prompt.trim()"
          x-text="eve.loading ? 'Eve schreibt …' : '✦ Mit Eve schreiben'"
        ></button>
      </div>

      <div class="ce-divider">
        <span>oder selbst schreiben</span>
      </div>

      <label class="ce-field">
        <span class="ce-label">Titel / Betreff</span>
        <input
          type="text"
          x-model="form.title"
          placeholder="z.B. Sommer im Garten — ab Juni"
          class="s-input ce-input-title"
        />
      </label>

      <!-- Toolbar -->
      <div class="ce-toolbar">
        <button type="button" @click="exec('toggleBold')"   :class="active.bold ? 'is-on' : ''" title="Fett"><strong>B</strong></button>
        <button type="button" @click="exec('toggleItalic')" :class="active.italic ? 'is-on' : ''" title="Kursiv" class="ce-tb-i"><em>I</em></button>
        <button type="button" @click="exec('toggleHeading', {level: 2})" :class="active.h2 ? 'is-on' : ''" title="Überschrift">H2</button>
        <button type="button" @click="exec('toggleBulletList')"  :class="active.bullet  ? 'is-on' : ''" title="Liste">•</button>
        <button type="button" @click="exec('toggleOrderedList')" :class="active.ordered ? 'is-on' : ''" title="Nummernliste">1.</button>
        <button type="button" @click="setLink()" :class="active.link ? 'is-on' : ''" title="Link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
      </div>

      <div id="ce-tiptap-mount" class="ce-editor"></div>

      <!-- Personalisierungs-Chips (Hebel 5) -->
      <div class="ce-var-chips">
        <span class="ce-var-label">Personalisierung:</span>
        {VARIABLE_UI_DEFS.map(v => (
          <button type="button" class="ce-var-chip" @click={`insertVariable('${v.key}')`} :title="`Beispiel: ${v.example}`">
            {`{{${v.key}}}`}
          </button>
        ))}
      </div>

      <div class="ce-field" style="margin-top:16px">
        <span class="ce-label">CTA-Button (optional)</span>
        <div class="ce-cta-row">
          <input type="text" x-model="form.cta_label" placeholder="z.B. Jetzt buchen" class="s-input" />
          <input type="url" x-model="form.cta_url" placeholder="https://…" class="s-input" />
        </div>
      </div>

    </div>

    <!-- ── Spalte 3: Vorschau ─────────────────────────────────────────────── -->
    <div class="ce-col ce-col-preview">

      <div class="ce-preview-head">
        <p class="ce-col-eyebrow" style="margin:0">Vorschau</p>
        <select x-model="previewLang" class="s-input ce-input-sm" aria-label="Vorschau-Sprache">
          {LANGS_DISPLAY.map(l => <option value={l}>{l.toUpperCase()}</option>)}
        </select>
      </div>

      <!-- Wallet-Push Mockup -->
      <template x-if="form.channels.includes('wallet_push')">
        <div>
          <p class="ce-preview-eyebrow">WALLET-PUSH</p>
          <div class="ce-mockup">
            <div class="ce-mockup-frame">
              <div class="ce-mockup-status">retaha · Benachrichtigung</div>
              <div class="ce-mockup-card">
                <div class="ce-mockup-brand">
                  <span class="ce-mockup-logo">{p.hotelName.slice(0, 1).toUpperCase()}</span>
                  <div>
                    <div class="ce-mockup-hotel">{p.hotelName}</div>
                    <div class="ce-mockup-now">jetzt</div>
                  </div>
                </div>
                <div class="ce-mockup-title" x-text="previewTitle"></div>
                <div class="ce-mockup-body" x-html="previewBody"></div>
                <template x-if="form.cta_label && form.cta_url">
                  <div class="ce-mockup-cta">
                    <span class="ce-mockup-cta-label" x-text="previewCtaLabel"></span>
                  </div>
                </template>
                <div class="ce-mockup-footer">Abmelden</div>
              </div>
            </div>
          </div>
        </div>
      </template>

      <!-- E-Mail Mockup (Hebel 1) -->
      <template x-if="form.channels.includes('email')">
        <div>
          <p class="ce-preview-eyebrow" :style="form.channels.includes('wallet_push') ? 'margin-top:20px' : ''">E-MAIL</p>
          <div class="ce-email-frame">
            <div class="ce-email-from">
              <div class="ce-email-avatar" style={`background:${p.brandPrimary}`}>
                {p.hotelName.slice(0, 1).toUpperCase()}
              </div>
              <div>
                <div class="ce-email-sender">{p.hotelName}</div>
                <div class="ce-email-addr">via retaha Marketing</div>
              </div>
            </div>
            <div class="ce-email-subject" x-text="previewTitle || '(kein Betreff)'"></div>
            <div class="ce-email-body" x-html="previewBody"></div>
            <template x-if="form.cta_label">
              <div class="ce-email-cta-wrap">
                <span class="ce-email-cta-btn" style={`background:${p.brandPrimary}`} x-text="previewCtaLabel"></span>
              </div>
            </template>
            <div class="ce-email-footer">Du erhältst diese E-Mail, weil du Marketing-Updates von {p.hotelName} abonniert hast. · <span style="text-decoration:underline">Abmelden</span></div>
          </div>
        </div>
      </template>

    </div>

  </div>

  <!-- Error Flash -->
  <template x-if="errorMsg">
    <div class="ce-flash" x-text="errorMsg"></div>
  </template>

  <!-- Actions -->
  <div class="ce-actions">
    <a href="/marketing/campaigns" class="v9-btn ce-btn-ghost">Abbrechen</a>
    <button
      type="button"
      class="v9-btn ce-btn-primary"
      :disabled="submitting"
      @click="save()"
      x-text="submitting ? 'Wird gespeichert …' : 'Kampagne anlegen'"
    ></button>
  </div>

</div>

<script is:inline define:vars={{
  TEMPLATES: p.templates,
  HOTEL_NAME: p.hotelName,
  HOTEL_DEFAULT: p.hotelDefaultLang,
  DEMO_CTX,
  ANLASS_DEFS,
  BRAND_PRIMARY: p.brandPrimary,
  LOGO_URL: p.logoUrl,
  SEGMENT_COUNTS: p.segmentCounts,
}}>
  window.__RETAHA_CE__ = {
    TEMPLATES, HOTEL_NAME, HOTEL_DEFAULT, DEMO_CTX,
    ANLASS: ANLASS_DEFS, BRAND_PRIMARY, LOGO_URL,
    SEGMENT_COUNTS,
  };
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Link from '@tiptap/extension-link';
  import Placeholder from '@tiptap/extension-placeholder';

  function pickI18n(jsonb: any, fallback: string, lang: string): string {
    if (!jsonb) return '';
    return jsonb[lang]?.value ?? jsonb[fallback]?.value ?? '';
  }

  function renderVars(text: string, ctx: any, footer?: any): string {
    const REGEX = /\{\{\s*([a-z_][a-z0-9_]*)\s*\}\}/gi;
    return text.replace(REGEX, (full, name: string) => {
      const key = name.toLowerCase();
      if (key in ctx) return String(ctx[key] ?? '');
      if (footer && key in footer) return footer[key] ?? '';
      return full;
    });
  }

  document.addEventListener('alpine:init', () => {
    // @ts-expect-error - Alpine global
    window.Alpine.data('campaignEditor', () => ({
      cfg: (window as any).__RETAHA_CE__,
      editor: null as any,
      submitting: false,
      errorMsg: '' as string,
      active: { bold: false, italic: false, h2: false, bullet: false, ordered: false, link: false },
      previewLang: 'de',
      eve: { prompt: '', loading: false },
      form: {
        anlass: 'adhoc' as string,
        name: '',
        channels: ['wallet_push', 'email'] as string[],
        segment: 'all' as string,
        target_lang: '',
        schedule_mode: 'now' as 'now' | 'later',
        scheduled_at: '',
        title: '',
        body_html: '<p></p>',
        cta_label: '',
        cta_url: '',
      },

      init() {
        this.previewLang = this.cfg.HOTEL_DEFAULT;
        const mount = document.getElementById('ce-tiptap-mount');
        if (!mount) return;
        this.editor = new Editor({
          element: mount,
          extensions: [
            StarterKit.configure({ heading: { levels: [2, 3] }, link: false }),
            Link.configure({ openOnClick: false, autolink: false, linkOnPaste: false }),
            Placeholder.configure({ placeholder: 'Was möchtest du sagen? Variablen wie {{first_name}} werden beim Versand ersetzt.' }),
          ],
          content: '<p></p>',
          onUpdate: () => {
            this.form.body_html = this.editor.getHTML();
            this._refreshActive();
          },
          onSelectionUpdate: () => this._refreshActive(),
        });
      },

      selectAnlass(id: string) {
        const tile = this.cfg.ANLASS.find((t: any) => t.id === id);
        if (!tile) return;
        this.form.anlass = id;
        this.form.title = tile.title;
        this.form.cta_label = tile.cta_label;
        this.form.segment = tile.segment;
        const body = tile.body || '<p></p>';
        this.form.body_html = body;
        if (this.editor) this.editor.commands.setContent(body);
      },

      toggleChannel(ch: string) {
        if (this.form.channels.includes(ch)) {
          if (this.form.channels.length > 1) {
            this.form.channels = this.form.channels.filter((x: string) => x !== ch);
          }
        } else {
          this.form.channels = [...this.form.channels, ch];
        }
      },

      get segAll() {
        const { allWallet, allEmail } = this.cfg.SEGMENT_COUNTS;
        const total = (this.form.channels.includes('wallet_push') ? allWallet : 0)
                    + (this.form.channels.includes('email') ? allEmail : 0);
        return total > 0 ? total.toLocaleString('de') : '—';
      },
      get segLoyal() {
        const n = this.cfg.SEGMENT_COUNTS.loyal;
        return n > 0 ? n.toLocaleString('de') : '—';
      },
      get segLapsed() {
        const n = this.cfg.SEGMENT_COUNTS.lapsed;
        return n > 0 ? n.toLocaleString('de') : '—';
      },

      async eveWrite() {
        if (!this.eve.prompt.trim() || this.eve.loading) return;
        this.eve.loading = true;
        this.errorMsg = '';
        try {
          const res = await fetch('/api/marketing/campaigns/generate-with-eve', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: this.eve.prompt }),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'ai_not_configured'
              ? 'KI nicht konfiguriert.'
              : (data.error || 'Eve-Fehler');
            return;
          }
          this.form.title = data.title;
          const body = data.body_html || '<p></p>';
          this.form.body_html = body;
          if (this.editor) this.editor.commands.setContent(body);
          if (data.cta_label) this.form.cta_label = data.cta_label;
          this.form.anlass = 'adhoc';
        } catch (err: any) {
          this.errorMsg = 'Netzwerk-Fehler: ' + (err.message || 'unbekannt');
        } finally {
          this.eve.loading = false;
        }
      },

      _refreshActive() {
        if (!this.editor) return;
        const e = this.editor;
        this.active = {
          bold: e.isActive('bold'), italic: e.isActive('italic'),
          h2: e.isActive('heading', { level: 2 }),
          bullet: e.isActive('bulletList'), ordered: e.isActive('orderedList'),
          link: e.isActive('link'),
        };
      },

      exec(cmd: string, opts: any = {}) {
        if (!this.editor) return;
        (this.editor.chain().focus() as any)[cmd](opts).run();
      },

      setLink() {
        if (!this.editor) return;
        const url = window.prompt('Link-URL:', this.editor.getAttributes('link').href || 'https://');
        if (url === null) return;
        if (url === '') {
          this.editor.chain().focus().extendMarkRange('link').unsetLink().run();
          return;
        }
        if (!/^(https?:|mailto:)/i.test(url)) { alert('Nur https:// oder mailto:'); return; }
        this.editor.chain().focus().extendMarkRange('link').setLink({ href: url, target: '_blank' }).run();
      },

      insertVariable(key: string) {
        if (!this.editor) return;
        this.editor.chain().focus().insertContent(`{{${key}}}`).run();
      },

      get previewTitle() {
        return renderVars(this.form.title || '(kein Titel)', this.cfg.DEMO_CTX);
      },
      get previewBody() {
        const html = this.form.body_html || '<p class="ce-empty">(kein Text)</p>';
        return renderVars(html, this.cfg.DEMO_CTX, { unsubscribe_link: '#' });
      },
      get previewCtaLabel() {
        return renderVars(this.form.cta_label || '', this.cfg.DEMO_CTX);
      },

      async save() {
        if (this.submitting) return;
        this.errorMsg = '';
        const bodyHtml = this.editor ? this.editor.getHTML() : this.form.body_html;

        if (!this.form.name?.trim()) { this.errorMsg = 'Bitte gib einen Namen an.'; return; }
        if (!this.form.title?.trim()) { this.errorMsg = 'Bitte gib einen Titel an.'; return; }
        if (!bodyHtml?.trim() || bodyHtml === '<p></p>') { this.errorMsg = 'Bitte schreib einen Text.'; return; }
        if (this.form.channels.length === 0) { this.errorMsg = 'Bitte mindestens einen Kanal auswählen.'; return; }

        const target_filter: any = {};
        if (this.form.segment === 'loyal') target_filter.min_visit_count = 3;
        if (this.form.segment === 'lapsed') target_filter.min_visit_count = 1;
        if (this.form.target_lang) target_filter.language = this.form.target_lang;

        const payload: any = {
          name: this.form.name.trim(),
          channels: this.form.channels,
          target_filter: Object.keys(target_filter).length ? target_filter : null,
          title_default: this.form.title.trim(),
          body_default_html: bodyHtml,
          cta_label_default: this.form.cta_label?.trim() || null,
          cta_url: this.form.cta_url?.trim() || null,
        };
        if (this.form.schedule_mode === 'later') {
          if (!this.form.scheduled_at) { this.errorMsg = 'Bitte wähle ein Datum.'; return; }
          payload.scheduled_at = new Date(this.form.scheduled_at).toISOString();
        }

        this.submitting = true;
        try {
          const res = await fetch('/api/marketing/campaigns/create', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'invalid_variables'
              ? `Unbekannte Variablen: ${(data.unknown || []).join(', ')}`
              : (data.error || 'Speichern fehlgeschlagen.');
            return;
          }
          window.retahaToastFlash && window.retahaToastFlash('Kampagne gespeichert');
          window.location.href = `/marketing/campaigns/${data.id}`;
        } catch (err: any) {
          this.errorMsg = 'Netzwerk-Fehler: ' + (err.message || 'unbekannt');
        } finally {
          this.submitting = false;
