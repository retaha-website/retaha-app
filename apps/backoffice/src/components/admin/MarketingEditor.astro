---
// Marketing-Template-Editor — Blaupause: Campaign-Editor (Komposition B, Petrol).
//
// Zwei Boxen oben (Name · Kategorie), Auto-Sprach-Hinweis, darunter EINE
// Inhalts-Karte (Eve · Betreff · Rich-Text · Variablen · CTA · Hero-Bild) mit
// Mini-Mail-Vorschau direkt darunter — identische Optik zur „Neue Kampagne".
//
// Ein Template = wiederverwendbarer E-Mail-Inhalt (title/body/cta/hero). Kein
// Empfänger/Kanal/Versand (das ist kampagnen-spezifisch). Edit-Modus über
// templateId + PUT; Create über POST. Payload-Vertrag unverändert zur API.

import { VARIABLE_UI_DEFS } from '@retaha/marketing';
import { getLang, bt } from '../../lib/i18n';
const lang = getLang(Astro.cookies, Astro.request);

interface Props {
  templateId: string | null;
  initialTitle: string;
  initialBodyHtml: string;
  initialCtaLabel: string;
  initialCtaUrl: string;
  initialHeroUrl: string;
  initialName: string;
  initialCategory: string | null;
  hotelDefaultLang: string;
  hotelName: string;
  brandPrimary: string;
  logoUrl: string | null;
}
const p = Astro.props as Props;

const isEdit = !!p.templateId;
const apiUrl = isEdit
  ? `/api/marketing/templates/${p.templateId}`
  : '/api/marketing/templates/create';
const apiMethod = isEdit ? 'PUT' : 'POST';

const CATEGORIES = [
  { value: '',           label: bt('me.cat.none', lang) },
  { value: 'newsletter', label: bt('tm.cat.newsletter', lang) },
  { value: 'event',      label: bt('tm.cat.event', lang) },
  { value: 'promotion',  label: bt('tm.cat.promotion', lang) },
  { value: 'seasonal',   label: bt('tm.cat.seasonal', lang) },
];

const DEMO_CTX = {
  first_name: 'Anna', last_name: 'Schmidt', hotel_name: p.hotelName,
  visit_count: 3, last_visit_date: '24.12.2025', first_visit_date: '15.07.2024',
};

// Client-Strings (Alpine) — via define:vars. Soweit möglich dieselben Keys wie
// der Campaign-Editor (ce.*), damit Optik + Wording 1:1 identisch sind.
const meT = {
  editorPlaceholder: bt('ce.editor.placeholder', lang),
  eveWriting: bt('ce.eve.writing', lang),
  eveWrite: bt('ce.eve.write', lang),
  errAiNotConf: bt('ce.err.ainotconf', lang),
  errEve: bt('ce.err.eve', lang),
  promptLink: bt('ce.prompt.link', lang),
  alertUrl: bt('ce.alert.url', lang),
  promptImage: bt('me.prompt.image', lang),
  alertImageHttps: bt('me.alert.imagehttps', lang),
  noTitle: bt('ce.preview.notitle', lang),
  noText: bt('ce.preview.notext', lang),
  noSubject: bt('ce.email.nosubject', lang),
  errName: bt('me.err.name', lang),
  errTitle: bt('me.err.title', lang),
  errBody: bt('me.err.body', lang),
  errUnknownVars: bt('me.err.unknownvars', lang),
  errForbiddenVars: bt('me.err.forbiddenvars', lang),
  errSave: bt('me.err.save', lang),
  errNet: bt('me.err.net', lang),
  errUnknown: bt('me.err.unknown', lang),
  saving: bt('me.saving', lang),
  saveCreate: bt('me.save.create', lang),
  saveEdit: bt('dre.save.edit', lang),
  toastSaved: bt('me.toast.saved', lang),
};
---

<div class="me-wrap" x-data="marketingEditor()">

  <!-- ── Name + Kategorie (zwei getrennte Boxen oben) ─────────────────────── -->
  <div class="me-top">
    <div class="me-box me-box--name">
      <span class="me-label">{bt('me.name', lang)}</span>
      <input type="text" x-model="form.name" placeholder={bt('me.name.ph', lang)} class="s-input" />
    </div>
    <div class="me-box me-box--cat">
      <span class="me-label">{bt('me.category', lang)}</span>
      <div class="s-select-wrap">
        <select class="s-select" x-model="form.category">
          {CATEGORIES.map(c => <option value={c.value}>{c.label}</option>)}
        </select>
      </div>
    </div>
  </div>

  <p class="me-autolang">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    {bt('ce.autolang', lang)}
  </p>

  <!-- ── Inhalts-Karte (Edit + Mini-Vorschau zusammen) ────────────────────── -->
  <div class="me-card">
    <div class="me-card-head">
      <span class="me-card-title">{bt('me.content', lang)}</span>
      <button type="button" class="me-aurora-btn" @click="openEve('full', $el)">
        <svg class="me-eve-spk" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
        Mit Eve schreiben
      </button>
    </div>

    <div class="me-field">
      <span class="me-label">{bt('ce.title', lang)}</span>
      <input type="text" x-model="form.title" placeholder={bt('ce.title.ph', lang)} class="s-input" style="width:100%;box-sizing:border-box" />
    </div>

    <div class="me-toolbar">
      <button type="button" @click="exec('toggleBold')"   :class="active.bold ? 'is-on' : ''" title={bt('ce.tb.bold', lang)}><strong>B</strong></button>
      <button type="button" @click="exec('toggleItalic')" :class="active.italic ? 'is-on' : ''" title={bt('ce.tb.italic', lang)} class="me-tb-i"><em>I</em></button>
      <button type="button" @click="exec('toggleHeading', {level: 2})" :class="active.h2 ? 'is-on' : ''" title={bt('ce.tb.h2', lang)}>H2</button>
      <button type="button" @click="exec('toggleBulletList')"  :class="active.bullet  ? 'is-on' : ''" title={bt('ce.tb.bullet', lang)}>•</button>
      <button type="button" @click="exec('toggleOrderedList')" :class="active.ordered ? 'is-on' : ''" title={bt('ce.tb.ordered', lang)}>1.</button>
      <button type="button" @click="setLink()" :class="active.link ? 'is-on' : ''" title={bt('ce.tb.link', lang)}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
      <button type="button" @click="setImage()" title={bt('me.tb.image', lang)}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      </button>
    </div>
    <div class="me-editor-wrap">
      <div id="me-tiptap-mount" class="me-editor"></div>
      <div class="me-editor-ph" x-show="isEditorEmpty" x-cloak>{bt('ce.editor.placeholder', lang)}</div>
    </div>

    <div class="me-var-chips">
      <span class="me-var-label">{bt('ce.var.label', lang)}</span>
      {VARIABLE_UI_DEFS.map(v => (
        <button type="button" class="me-var-chip" @click={`insertVariable('${v.key}')`}>{`{{${v.key}}}`}</button>
      ))}
    </div>

    <div class="me-field" style="margin-top:14px">
      <span class="me-label">{bt('ce.cta', lang)}</span>
      <div class="me-cta-row">
        <input type="text" x-model="form.ctaLabel" placeholder={bt('ce.cta.labelph', lang)} class="s-input" />
        <input type="url" x-model="form.ctaUrl" placeholder="https://…" class="s-input" />
      </div>
    </div>

    <label class="me-field" style="margin-top:14px">
      <span class="me-label">{bt('me.hero.label', lang)}</span>
      <input type="url" x-model="form.heroUrl" placeholder="https://…" class="s-input" />
      <span class="me-hint">{bt('me.hero.hint', lang)}</span>
    </label>

    <div class="me-card-pv">
      <span class="me-pv-label">{bt('ce.preview', lang)}</span>
      <div class="me-email-frame">
        <div class="me-email-from">
          <div class="me-email-avatar" style={`background:${p.brandPrimary}`}>{p.hotelName.slice(0, 1).toUpperCase()}</div>
          <div><div class="me-email-sender">{p.hotelName}</div><div class="me-email-addr">{bt('ce.email.via', lang)}</div></div>
        </div>
        <template x-if="form.heroUrl">
          <img class="me-email-hero" :src="form.heroUrl" alt="" />
        </template>
        <div class="me-email-subject" x-text={`previewTitle || ${JSON.stringify(bt('ce.email.nosubject', lang))}`}></div>
        <div class="me-email-body" x-html="previewBody"></div>
        <template x-if="form.ctaLabel">
          <div class="me-email-cta-wrap"><span class="me-email-cta-btn" style={`background:${p.brandPrimary}`} x-text="previewCtaLabel"></span></div>
        </template>
        <div class="me-email-footer">{bt('ce.email.footer', lang).replace('{hotel}', p.hotelName)} · <span style="text-decoration:underline">{bt('ce.mockup.unsub', lang)}</span></div>
      </div>
    </div>
  </div>

  <template x-if="errorMsg && !eve.open"><div class="me-flash" x-text="errorMsg"></div></template>

  <div class="me-actions">
    <a href="/marketing/templates" class="v9-btn me-btn-ghost">{bt('dre.cancel', lang)}</a>
    <button type="button" class="v9-btn me-btn-primary" :disabled="submitting" @click="save()"
      x-text="submitting ? cfg.T.saving : (isEdit ? cfg.T.saveEdit : cfg.T.saveCreate)"></button>
  </div>

  <!-- ── Eve-Modal ────────────────────────────────────────────────────────── -->
  <div class="me-eve-overlay" x-show="eve.open" x-cloak
    @click.self="if(!eve.loading) eve.open = false"
    @keydown.escape.window="if(eve.open && !eve.loading) eve.open = false">
    <div class="me-eve-modal">
      <div class="me-eve-mhd">
        <span class="me-eve-mhd-title">E-Mail schreiben</span>
        <button type="button" class="me-eve-close" @click="eve.open = false" :disabled="eve.loading">✕</button>
      </div>
      <textarea class="s-input me-eve-ta" x-model="eve.prompt"
        placeholder={bt('ce.eve.ph', lang)}
        :disabled="eve.loading"
        @keydown.meta.enter.prevent="eveWrite()"
        @keydown.ctrl.enter.prevent="eveWrite()"></textarea>
      <p class="me-eve-err" x-show="errorMsg" x-cloak x-text="errorMsg"></p>
      <div class="me-eve-mft">
        <button type="button" class="me-eve-cancel" @click="eve.open = false" :disabled="eve.loading">
          {bt('dre.cancel', lang)}
        </button>
        <button type="button" class="me-aurora-btn" @click="eveWrite()"
          :disabled="eve.loading || !eve.prompt.trim()">
          <svg class="me-eve-spk" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z" fill="currentColor"/></svg>
          Mit Eve schreiben
        </button>
      </div>
    </div>
  </div>

  <!-- ── Link-Modal ────────────────────────────────────────────────────────── -->
  <div class="me-eve-overlay" x-show="link.open" x-cloak
    @click.self="link.open = false"
    @keydown.escape.window="if(link.open) link.open = false">
    <div class="me-eve-modal">
      <div class="me-eve-mhd">
        <span class="me-eve-mhd-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          Link einfügen
        </span>
        <button type="button" class="me-eve-close" @click="link.open = false">✕</button>
      </div>
      <span class="me-label" style="margin-bottom:8px;display:block">URL</span>
      <input type="url" x-model="link.url" class="s-input" style="width:100%;box-sizing:border-box"
        placeholder="https://… oder mailto:…"
        @keydown.enter.prevent="applyLink()"
        @keydown.escape.prevent="link.open = false" />
      <p class="me-hint" style="margin-top:6px">Leer lassen zum Entfernen des Links.</p>
      <div class="me-eve-mft">
        <button type="button" class="me-eve-cancel" @click="link.open = false">{bt('dre.cancel', lang)}</button>
        <button type="button" class="me-modal-ok-btn" @click="applyLink()">Übernehmen</button>
      </div>
    </div>
  </div>

  <!-- ── Bild-Upload-Modal ─────────────────────────────────────────────────── -->
  <div class="me-eve-overlay" x-show="imgModal.open" x-cloak
    @click.self="if(!imgModal.uploading) imgModal.open = false"
    @keydown.escape.window="if(imgModal.open && !imgModal.uploading) imgModal.open = false">
    <div class="me-eve-modal">
      <div class="me-eve-mhd">
        <span class="me-eve-mhd-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          Bild einfügen
        </span>
        <button type="button" class="me-eve-close" @click="if(!imgModal.uploading) imgModal.open = false" :disabled="imgModal.uploading">✕</button>
      </div>
      <div class="me-img-drop" @click="$refs.imgFile.click()">
        <template x-if="!imgModal.preview">
          <div class="me-img-drop-inner">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            <span>Klicken zum Hochladen</span>
            <span class="me-img-drop-hint">JPG · PNG · WebP · max. 5 MB</span>
          </div>
        </template>
        <template x-if="imgModal.preview">
          <img :src="imgModal.preview" class="me-img-preview" alt="Vorschau" />
        </template>
      </div>
      <input type="file" x-ref="imgFile" accept="image/*" class="me-img-file-input" @change="onImgSelect($event)" />
      <div class="me-eve-err" x-show="imgModal.err" x-cloak x-text="imgModal.err"></div>
      <div class="me-eve-mft">
        <button type="button" class="me-eve-cancel" @click="if(!imgModal.uploading) imgModal.open = false" :disabled="imgModal.uploading">{bt('dre.cancel', lang)}</button>
        <button type="button" class="me-modal-ok-btn" @click="insertImage()" :disabled="!imgModal.hasFile || imgModal.uploading" x-text="imgModal.uploading ? 'Hochladen…' : 'Einfügen'"></button>
      </div>
    </div>
  </div>

</div>

<script is:inline define:vars={{
  API_URL: apiUrl, API_METHOD: apiMethod, IS_EDIT: isEdit,
  HOTEL_NAME: p.hotelName, BRAND_PRIMARY: p.brandPrimary, DEMO_CTX,
  INITIAL: {
    title: p.initialTitle, body: p.initialBodyHtml, ctaLabel: p.initialCtaLabel,
    ctaUrl: p.initialCtaUrl, heroUrl: p.initialHeroUrl, name: p.initialName,
    category: p.initialCategory ?? '',
  },
  ME_T: meT,
}}>
  window.__RETAHA_ME__ = {
    API_URL, API_METHOD, IS_EDIT, HOTEL_NAME, BRAND_PRIMARY, DEMO_CTX, INITIAL, T: ME_T,
  };
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Link from '@tiptap/extension-link';
  import Image from '@tiptap/extension-image';

  function renderVars(text: string, ctx: any, footer?: any): string {
    const REGEX = /\{\{\s*([a-z_][a-z0-9_]*)\s*\}\}/gi;
    return text.replace(REGEX, (full, name: string) => {
      const key = name.toLowerCase();
      if (key in ctx) return String(ctx[key] ?? '');
      if (footer && key in footer) return footer[key] ?? '';
      return full;
    });
  }
  document.addEventListener('alpine:init', () => {
    let _meEditor: any = null;
    let _pendingFile: File | null = null;

    // @ts-expect-error - Alpine global
    window.Alpine.data('marketingEditor', () => {
      const CFG = (window as any).__RETAHA_ME__;
      return {
      cfg: CFG,
      get isEdit() { return this.cfg.IS_EDIT; },
      submitting: false,
      errorMsg: '' as string,
      active: { bold: false, italic: false, h2: false, bullet: false, ordered: false, link: false },
      eve: { prompt: '', loading: false, open: false, mode: 'full' as string },
      link: { open: false, url: '' },
      imgModal: { open: false, preview: '', hasFile: false, uploading: false, err: '' },
      form: {
        name:     CFG.INITIAL.name     ?? '',
        category: CFG.INITIAL.category ?? '',
        title:    CFG.INITIAL.title    ?? '',
        body_html: CFG.INITIAL.body    || '<p></p>',
        ctaLabel: CFG.INITIAL.ctaLabel ?? '',
        ctaUrl:   CFG.INITIAL.ctaUrl   ?? '',
        heroUrl:  CFG.INITIAL.heroUrl  ?? '',
      },

      _mountEditor(content: string) {
        if (_meEditor) { _meEditor.destroy(); _meEditor = null; }
        const mount = document.getElementById('me-tiptap-mount');
        if (!mount) return;
        mount.innerHTML = '';
        _meEditor = new Editor({
          element: mount,
          extensions: [
            StarterKit.configure({ heading: { levels: [2, 3] }, link: false }),
            Link.configure({ openOnClick: false, autolink: false, linkOnPaste: false }),
            Image.configure({}),
          ],
          content,
          onUpdate: () => { this.form.body_html = _meEditor.getHTML(); this._refreshActive(); },
          onSelectionUpdate: () => this._refreshActive(),
        });
      },
      init() {
        if (_meEditor) return;
        this._mountEditor(this.form.body_html);
      },
      openEve(mode: string, el?: HTMLElement) {
        if (el) this.burstEve(el);
        this.eve.mode = mode; this.eve.open = true; this.errorMsg = '';
      },
      burstEve(el: HTMLElement) {
        const colors = ['#5B7CE0', '#1AA0B0', '#14616E', '#7FECE8'];
        const svg = '<svg width="6" height="6" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l2.2 7.8L22 12l-7.8 2.2L12 22l-2.2-7.8L2 12l7.8-2.2z"/></svg>';
        for (let i = 0; i < 10; i++) {
          const p = document.createElement('span');
          p.className = 'me-aurora-particle';
          const ang = Math.random() * Math.PI * 2;
          const dist = 26 + Math.random() * 30;
          p.style.setProperty('--tx', Math.cos(ang) * dist + 'px');
          p.style.setProperty('--ty', Math.sin(ang) * dist + 'px');
          p.style.color = colors[i % colors.length];
          p.innerHTML = svg;
          el.appendChild(p);
          setTimeout(() => p.remove(), 700);
        }
      },

      get isEditorEmpty() {
        const txt = (this.form.body_html || '').replace(/<[^>]*>/g, '').replace(/&nbsp;/g, ' ').trim();
        return txt === '';
      },

      async eveWrite() {
        if (!this.eve.prompt.trim() || this.eve.loading) return;
        this.eve.loading = true; this.errorMsg = '';
        try {
          const res = await fetch('/api/marketing/campaigns/generate-with-eve', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: this.eve.prompt }),
          });
          const data = await res.json();
          if (!data.ok) {
            this.errorMsg = data.error === 'ai_not_configured' ? this.cfg.T.errAiNotConf : (data.error || this.cfg.T.errEve);
            return;
          }
          this.form.title = data.title;
          const body = data.body_html || '<p></p>';
          this.form.body_html = body;
          if (data.cta_label) this.form.ctaLabel = data.cta_label;
          setTimeout(() => { this._mountEditor(body); }, 0);
          this.eve.open = false;
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ': ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.eve.loading = false;
        }
      },

      _refreshActive() {
        if (!_meEditor) return;
        const e = _meEditor;
        this.active = {
          bold: e.isActive('bold'), italic: e.isActive('italic'), h2: e.isActive('heading', { level: 2 }),
          bullet: e.isActive('bulletList'), ordered: e.isActive('orderedList'), link: e.isActive('link'),
        };
      },
      exec(cmd: string, opts: any = {}) {
        if (!_meEditor) return;
        const ch = (_meEditor.chain().focus() as any);
        (Object.keys(opts).length ? ch[cmd](opts) : ch[cmd]()).run();
      },
      setLink() {
        if (!_meEditor) return;
        this.link.url = _meEditor.getAttributes('link').href || '';
        this.link.open = true;
      },
      applyLink() {
        if (!_meEditor) return;
        const url = this.link.url.trim();
        this.link.open = false;
        if (!url) { _meEditor.chain().focus().extendMarkRange('link').unsetLink().run(); return; }
        if (!/^(https?:|mailto:)/i.test(url)) { this.errorMsg = this.cfg.T.alertUrl || 'Ungültige URL'; return; }
        _meEditor.chain().focus().extendMarkRange('link').setLink({ href: url, target: '_blank' }).run();
      },
      setImage() {
        _pendingFile = null;
        this.imgModal.open = true; this.imgModal.preview = ''; this.imgModal.hasFile = false; this.imgModal.err = '';
      },
      onImgSelect(evt: Event) {
        const file = (evt.target as HTMLInputElement).files?.[0];
        if (!file) return;
        if (!file.type.startsWith('image/')) { this.imgModal.err = 'Nur Bilddateien erlaubt'; return; }
        if (file.size > 5 * 1024 * 1024) { this.imgModal.err = 'Zu groß — max 5 MB'; return; }
        this.imgModal.err = '';
        _pendingFile = file;
        this.imgModal.hasFile = true;
        const reader = new FileReader();
        reader.onload = (e: ProgressEvent<FileReader>) => { this.imgModal.preview = (e.target?.result as string) || ''; };
        reader.readAsDataURL(file);
      },
      async insertImage() {
        if (!_meEditor || !_pendingFile) return;
        this.imgModal.uploading = true; this.imgModal.err = '';
        try {
          const fd = new FormData();
          fd.append('file', _pendingFile);
          const res = await fetch('/api/marketing/upload-asset', { method: 'POST', credentials: 'include', body: fd });
          const data = await res.json();
          if (!data.ok) { this.imgModal.err = data.error || 'Upload fehlgeschlagen'; return; }
          _meEditor.chain().focus().setImage({ src: data.url, alt: '' }).run();
          this.imgModal.open = false; this.imgModal.preview = ''; this.imgModal.hasFile = false; _pendingFile = null;
        } catch (err: any) {
          this.imgModal.err = 'Netzwerkfehler: ' + (err.message || 'Unbekannt');
        } finally {
          this.imgModal.uploading = false;
        }
      },
      insertVariable(key: string) { if (!_meEditor) return; _meEditor.chain().focus().insertContent(`{{${key}}}`).run(); },

      get previewTitle() { return renderVars(this.form.title || this.cfg.T.noTitle, this.cfg.DEMO_CTX); },
      get previewBody() {
        const html = this.form.body_html || `<p class="me-empty">${this.cfg.T.noText}</p>`;
        return renderVars(html, this.cfg.DEMO_CTX, { unsubscribe_link: '#' });
      },
      get previewCtaLabel() { return renderVars(this.form.ctaLabel || '', this.cfg.DEMO_CTX); },

      async save() {
        if (this.submitting) return;
        this.errorMsg = '';
        const bodyHtml = _meEditor ? _meEditor.getHTML() : this.form.body_html;

        if (!this.form.name?.trim())  { this.errorMsg = this.cfg.T.errName; return; }
        if (!this.form.title?.trim()) { this.errorMsg = this.cfg.T.errTitle; return; }
        if (!bodyHtml?.trim() || bodyHtml === '<p></p>') { this.errorMsg = this.cfg.T.errBody; return; }

        const payload: any = {
          name: this.form.name.trim(),
          category: this.form.category || null,
          title_default: this.form.title.trim(),
          body_default_html: bodyHtml,
          cta_label_default: this.form.ctaLabel?.trim() || null,
          cta_url: this.form.ctaUrl?.trim() || null,
          hero_image_url: this.form.heroUrl?.trim() || null,
        };

        this.submitting = true;
        try {
          const res = await fetch(this.cfg.API_URL, {
            method: this.cfg.API_METHOD, credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) {
            if (data.error === 'invalid_variables') {
              const parts: string[] = [];
              if (data.unknown?.length)   parts.push(this.cfg.T.errUnknownVars + ' ' + data.unknown.map((v: string) => `{{${v}}}`).join(', '));
              if (data.forbidden?.length) parts.push(this.cfg.T.errForbiddenVars + ' ' + data.forbidden.map((v: string) => `{{${v}}}`).join(', '));
              this.errorMsg = parts.join(' · ');
            } else {
              this.errorMsg = data.error || this.cfg.T.errSave;
            }
            return;
          }
          (window as any).retahaToastFlash?.((this.cfg.T.toastSaved));
          window.location.href = '/marketing/templates';
        } catch (err: any) {
          this.errorMsg = this.cfg.T.errNet + ' ' + (err.message || this.cfg.T.errUnknown);
        } finally {
          this.submitting = false;
        }
      },
      };
    });
  });
</script>

