---
interface Props {
  hotelName?: string;
  guestName?: string;
  roomNumber?: string;
  arrivalDate?: string;
  departureDate?: string;
  nights?: number;
  city?: string;
  brandPrimary?: string | null;
}

const {
  hotelName = "The Gate Garden",
  guestName = "Maximilian",
  roomNumber = "204",
  arrivalDate = "06. Juni",
  departureDate = "09. Juni",
  nights = 3,
  city = "Berlin",
  brandPrimary = null,
} = Astro.props;
---

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&display=swap');
</style>

<div class="ed-wrap" style={brandPrimary ? `--olive:${brandPrimary}` : undefined}>
  <div class="phone">
    <div class="notch"></div>
    <div class="app">
      <div class="statusbar">
        <span>09:24</span>
        <div class="statusbar__icons">
          <svg viewBox="0 0 24 24"><path d="M2 22h2v-8H2v8m4 0h2V10H6v12m4 0h2V6h-2v16m4 0h2V2h-2v20"/></svg>
          <svg viewBox="0 0 24 24"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
          <svg viewBox="0 0 24 24"><rect x="2" y="6" width="18" height="12" rx="2" stroke-width="0"/></svg>
        </div>
      </div>

      <div class="hotel-head">
        <div class="hotel-mark">
          <span class="hotel-mark__name">{hotelName}</span>
          <span class="hotel-mark__room">Zimmer {roomNumber}</span>
        </div>
        <div class="hotel-head__lang">DE</div>
      </div>

      <section class="hero">
        <div class="hero__eyebrow">{city} · Frühsommer 2026</div>
        <h1 class="hero__title">Schön, dass Sie<br /><em>da sind, {guestName}.</em></h1>
        <p class="hero__sub">Wir freuen uns auf drei gemeinsame Tage. Hier finden Sie alles, was den Aufenthalt einfacher macht.</p>
      </section>

      <div class="stay">
        <div class="stay__col">
          <div class="stay__label">Anreise</div>
          <div class="stay__value">{arrivalDate}</div>
        </div>
        <div class="stay__col">
          <div class="stay__label">Abreise</div>
          <div class="stay__value">{departureDate}</div>
        </div>
        <div class="stay__col">
          <div class="stay__label">Nächte</div>
          <div class="stay__value stay__value-num">{nights}</div>
        </div>
      </div>

      <div class="divider">
        <div class="divider__line"></div>
        <div class="divider__dot"></div>
        <div class="divider__line"></div>
      </div>

      <section class="actions">
        <div class="actions__head">
          <h2 class="actions__title">Was Sie brauchen</h2>
          <span class="actions__num">04 Wege</span>
        </div>
        <div class="action-list">
          <div class="action">
            <div class="action__num">01</div>
            <div class="action__body">
              <div class="action__title">WLAN verbinden</div>
              <div class="action__sub">In Sekunden eingerichtet</div>
            </div>
            <div class="action__arrow">→</div>
          </div>
          <div class="action">
            <div class="action__num">02</div>
            <div class="action__body">
              <div class="action__title">Frühstück buchen</div>
              <div class="action__sub">Slot für Ihren Morgen wählen</div>
            </div>
            <div class="action__arrow">→</div>
          </div>
          <div class="action">
            <div class="action__num">03</div>
            <div class="action__body">
              <div class="action__title">Service anfragen</div>
              <div class="action__sub">Wir kümmern uns</div>
            </div>
            <div class="action__arrow">→</div>
          </div>
        </div>
      </section>

      <div class="feature">
        <div class="feature__eyebrow">Empfehlung des Hauses</div>
        <h3 class="feature__title">Drei Cafés in fünf Minuten Fußweg, <em>direkt um die Ecke.</em></h3>
        <p class="feature__sub">Vom kleinsten in der Linienstraße bis zum lautesten am Hackeschen Markt.</p>
      </div>

      <nav class="tabs">
        <a class="tab is-active" href="#">
          <svg viewBox="0 0 24 24"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg>
          <span class="tab__label">Start</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          <span class="tab__label"><span class="eve-gradient">Eve</span></span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/></svg>
          <span class="tab__label">Tipps</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span class="tab__label">Service</span>
        </a>
      </nav>
    </div>
  </div>
</div>

<style>
  .ed-wrap {
    --cream: #FAF7F0;
    --cream-deep: #F4EFE3;
    --ink: #2B2A28;
    --ink-muted: #6B6862;
    --ink-faint: #A8A39A;
    --olive: #4A5C2A;
    --olive-soft: #E6E8DC;
    --hair: #D4CFC2;
    --hair-strong: #B8B2A4;
  }

  .phone {
    width: 390px; height: 844px;
    background: var(--cream);
    border-radius: 54px;
    box-shadow:
      0 0 0 12px #2B2A28,
      0 0 0 14px #3A3833,
      0 50px 100px -20px rgba(43,42,40,.5);
    overflow: hidden; position: relative;
    display: flex; flex-direction: column;
    font-family: 'Inter', sans-serif;
    color: var(--ink);
  }
  .notch {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 120px; height: 32px; background: #2B2A28;
    border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; z-index: 50;
  }
  .app {
    flex: 1; display: flex; flex-direction: column;
    padding-top: 54px; overflow-y: auto;
    scrollbar-width: none;          /* Mini-Preview ohne Scrollbar */
  }
  .app::-webkit-scrollbar { display: none; }
  .statusbar {
    padding: 0 28px;
    display: flex; justify-content: space-between; align-items: center;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
    margin-bottom: 24px; color: var(--ink);
  }
  .statusbar__icons { display: flex; gap: 6px; align-items: center; }
  .statusbar__icons svg { width: 14px; height: 14px; fill: var(--ink); }

  .hotel-head {
    padding: 8px 28px 24px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .hotel-mark { display: flex; align-items: baseline; gap: 10px; }
  .hotel-mark__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-weight: 500; letter-spacing: .005em; font-style: italic;
  }
  .hotel-mark__room {
    font-family: 'Inter', sans-serif;
    font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--ink-muted); font-weight: 500;
  }
  .hotel-head__lang {
    font-family: 'Inter', sans-serif; font-size: 11px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--olive);
    cursor: pointer; font-weight: 500;
  }

  .hero { padding: 8px 28px 24px; }
  .hero__eyebrow {
    display: flex; align-items: center; gap: 12px;
    font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 500;
    letter-spacing: .22em; text-transform: uppercase; color: var(--olive);
    margin-bottom: 20px;
  }
  .hero__eyebrow::after {
    content: ''; flex: 1; height: 1px; background: var(--olive); opacity: .3;
  }
  .hero__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 46px; line-height: 1.05; font-weight: 400;
    letter-spacing: -.015em; margin-bottom: 12px; color: var(--ink);
  }
  .hero__title em { font-style: italic; font-weight: 500; color: var(--olive); }
  .hero__sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px; font-style: italic; color: var(--ink-muted);
    line-height: 1.45; max-width: 88%;
  }

  .divider { margin: 24px 28px; display: flex; align-items: center; gap: 14px; }
  .divider__line { flex: 1; height: 1px; background: var(--hair); }
  .divider__dot { width: 5px; height: 5px; background: var(--olive); transform: rotate(45deg); }

  .stay {
    margin: 0 28px 8px; padding: 16px 0;
    border-top: 1px solid var(--hair); border-bottom: 1px solid var(--hair);
    display: flex; justify-content: space-between;
    font-family: 'Inter', sans-serif;
  }
  .stay__col { display: flex; flex-direction: column; gap: 2px; }
  .stay__label {
    font-size: 9px; letter-spacing: .2em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 500;
  }
  .stay__value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px; font-weight: 500; letter-spacing: -.005em;
    font-style: italic; color: var(--ink);
  }
  .stay__value-num { font-style: normal; font-weight: 400; }

  .actions { padding: 32px 28px 20px; }
  .actions__head {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 24px;
  }
  .actions__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-weight: 400; font-style: italic;
    letter-spacing: -.01em; color: var(--ink);
  }
  .actions__num {
    font-family: 'Inter', sans-serif; font-size: 10px;
    letter-spacing: .18em; color: var(--ink-faint);
    font-weight: 500; text-transform: uppercase;
  }
  .action-list { display: flex; flex-direction: column; }
  .action {
    padding: 18px 0; border-bottom: 1px solid var(--hair);
    display: flex; align-items: center; gap: 16px;
    cursor: pointer; transition: padding 250ms ease;
  }
  .action:last-child { border-bottom: 0; }
  .action__num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic; color: var(--olive);
    font-size: 24px; font-weight: 300; width: 24px;
  }
  .action__body { flex: 1; }
  .action__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px; font-weight: 500; letter-spacing: -.005em;
    margin-bottom: 2px; color: var(--ink);
  }
  .action__sub {
    font-family: 'Inter', sans-serif; font-size: 11px;
    letter-spacing: .04em; color: var(--ink-muted); font-weight: 400;
  }
  .action__arrow {
    color: var(--olive); font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-style: italic; font-weight: 300;
  }

  .feature {
    margin: 24px 28px 28px; padding: 24px;
    background: var(--olive-soft); position: relative;
  }
  .feature::before {
    content: ''; position: absolute; top: 14px; left: 14px;
    width: 8px; height: 8px; border: 1px solid var(--olive);
  }
  .feature::after {
    content: ''; position: absolute; bottom: 14px; right: 14px;
    width: 8px; height: 8px; border: 1px solid var(--olive);
  }
  .feature__eyebrow {
    font-family: 'Inter', sans-serif; font-size: 10px;
    letter-spacing: .22em; text-transform: uppercase; color: var(--olive);
    font-weight: 500; margin-bottom: 10px;
  }
  .feature__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px; line-height: 1.15; font-weight: 400;
    font-style: italic; color: var(--ink);
    letter-spacing: -.01em; margin-bottom: 8px;
  }
  .feature__title em { font-style: normal; color: var(--olive); }
  .feature__sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px; font-style: italic; color: var(--ink-muted); line-height: 1.4;
  }

  .tabs {
    margin-top: auto; padding: 14px 24px 28px;
    border-top: 1px solid var(--hair); background: var(--cream);
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;
  }
  .tab {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 6px 4px; cursor: pointer;
    text-decoration: none; color: var(--ink-faint);
    transition: color 250ms ease; position: relative;
  }
  .tab svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.25; }
  .tab__label {
    font-family: 'Inter', sans-serif; font-size: 9px;
    letter-spacing: .16em; text-transform: uppercase; font-weight: 400;
  }
  .tab.is-active { color: var(--olive); }
  .tab.is-active .tab__label { font-weight: 600; }
  .tab.is-active::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 20px; height: 1px; background: var(--olive);
  }
</style>
