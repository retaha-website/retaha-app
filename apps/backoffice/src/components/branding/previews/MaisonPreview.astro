---
interface Props {
  hotelName?: string;
  guestName?: string;
  roomNumber?: string;
  roomLabel?: string;
  arrivalDate?: string;
  departureDate?: string;
  nightsRoman?: string;
  city?: string;
  brandPrimary?: string | null;
}

const {
  hotelName = "The Gate Garden",
  guestName = "Maximilian",
  roomNumber = "204",
  roomLabel = "Zimmer Zweihundert Vier",
  arrivalDate = "06. Juni",
  departureDate = "09. Juni",
  nightsRoman = "III",
  city = "Berlin Mitte",
  brandPrimary = null,
} = Astro.props;
---

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap');
</style>

<div class="ms-wrap" style={brandPrimary ? `--gold:${brandPrimary}` : undefined}>
  <div class="phone">
    <div class="notch"></div>
    <div class="app">
      <div class="statusbar">
        <span>09:24</span>
        <div class="statusbar__icons">
          <svg viewBox="0 0 24 24"><path d="M2 22h2v-8H2v8m4 0h2V10H6v12m4 0h2V6h-2v16m4 0h2V2h-2v20"/></svg>
          <svg viewBox="0 0 24 24"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
          <svg viewBox="0 0 24 24"><rect x="2" y="6" width="18" height="12" rx="2" stroke-width="0"/></svg>
        </div>
      </div>

      <div class="hotel-head">
        <div class="hotel-head__sup">{city} · Est. 2024</div>
        <div class="hotel-head__name">{hotelName}</div>
        <div class="hotel-head__sub">{roomLabel}</div>
        <div class="hotel-head__lang">DE</div>
      </div>

      <div class="ornament">
        <div class="ornament__line"></div>
        <div class="ornament__rhombus ornament__rhombus--small"></div>
        <div class="ornament__rhombus"></div>
        <div class="ornament__rhombus ornament__rhombus--small"></div>
        <div class="ornament__line"></div>
      </div>

      <section class="hero">
        <div class="hero__eyebrow">Wir heißen Sie willkommen</div>
        <h1 class="hero__title">{guestName},<br /><em>schön, dass Sie da sind.</em></h1>
        <p class="hero__sub">Drei Tage zu Gast. Wir hoffen, Sie finden bei uns Ruhe — und alles, was Sie wünschen.</p>
      </section>

      <div class="stay">
        <div class="stay__col">
          <div class="stay__label">Anreise</div>
          <div class="stay__value">{arrivalDate}</div>
        </div>
        <div class="stay__col">
          <div class="stay__label">Abreise</div>
          <div class="stay__value">{departureDate}</div>
        </div>
        <div class="stay__col">
          <div class="stay__label">Nächte</div>
          <div class="stay__value">{nightsRoman}</div>
        </div>
      </div>

      <section class="actions">
        <div class="actions__head">
          <h2 class="actions__title">Zu Ihren Diensten</h2>
          <div class="actions__sub">Vier Wege uns zu erreichen</div>
        </div>
        <div class="action-list">
          <div class="action">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></svg>
            </div>
            <div class="action__body">
              <div class="action__title">WLAN</div>
              <div class="action__sub">Mit einem Druck verbinden</div>
            </div>
            <div class="action__arrow">→</div>
          </div>
          <div class="action">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/></svg>
            </div>
            <div class="action__body">
              <div class="action__title">Frühstück</div>
              <div class="action__sub">Ihren Slot reservieren</div>
            </div>
            <div class="action__arrow">→</div>
          </div>
          <div class="action">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            </div>
            <div class="action__body">
              <div class="action__title">Service</div>
              <div class="action__sub">Wir kümmern uns persönlich</div>
            </div>
            <div class="action__arrow">→</div>
          </div>
        </div>
      </section>

      <div class="concierge">
        <div class="concierge__eyebrow">Persönliche Empfehlung</div>
        <div class="concierge__title">Drei Cafés <em>in unmittelbarer Nähe.</em></div>
        <div class="concierge__sub">Mit den besten Croissants Berlins.</div>
      </div>

      <nav class="tabs">
        <a class="tab is-active" href="#">
          <svg viewBox="0 0 24 24"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg>
          <span class="tab__label">Start</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          <span class="tab__label"><span class="eve-gradient">Eve</span></span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/></svg>
          <span class="tab__label">Tipps</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span class="tab__label">Service</span>
        </a>
      </nav>
    </div>
  </div>
</div>

<style>
  .ms-wrap {
    --bg: #1A1410;
    --bg-deep: #0F0B08;
    --cream: #E8D9B5;
    --cream-faint: #C4B595;
    --cream-muted: #8A7E66;
    --gold: #C9A36A;
    --gold-bright: #E0BC85;
    --hair: #3A2D24;
    --hair-strong: #5C4937;
  }

  .phone {
    width: 390px; height: 844px;
    background: var(--bg); border-radius: 54px;
    box-shadow:
      0 0 0 12px #0A0805,
      0 0 0 14px #1F1815,
      0 50px 100px -20px rgba(0,0,0,.8),
      inset 0 0 80px rgba(201,163,106,.04);
    overflow: hidden; position: relative;
    display: flex; flex-direction: column;
    font-family: 'Cormorant Garamond', serif;
    color: var(--cream);
  }
  .notch {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 120px; height: 32px; background: #0A0805;
    border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; z-index: 50;
  }
  .app {
    flex: 1; display: flex; flex-direction: column;
    padding-top: 54px; overflow-y: auto;
    scrollbar-width: none;          /* Mini-Preview ohne Scrollbar */
    background:
      radial-gradient(circle at 50% 0%, rgba(201,163,106,.05) 0%, transparent 50%),
      radial-gradient(circle at 50% 100%, rgba(140,33,40,.04) 0%, transparent 60%);
  }
  .app::-webkit-scrollbar { display: none; }
  .statusbar {
    padding: 0 28px;
    display: flex; justify-content: space-between; align-items: center;
    font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500;
    color: var(--cream); margin-bottom: 24px;
  }
  .statusbar__icons { display: flex; gap: 6px; align-items: center; }
  .statusbar__icons svg { width: 14px; height: 14px; fill: var(--cream); }

  .hotel-head {
    padding: 8px 28px 16px;
    text-align: center; border-bottom: 1px solid var(--hair);
    position: relative;
  }
  .hotel-head__sup {
    font-family: 'DM Sans', sans-serif; font-size: 9px;
    letter-spacing: .32em; text-transform: uppercase;
    color: var(--gold); font-weight: 400; margin-bottom: 4px;
  }
  .hotel-head__name {
    font-family: 'Bodoni Moda', serif;
    font-size: 22px; font-weight: 500; letter-spacing: .05em;
    text-transform: uppercase; color: var(--cream); margin-bottom: 3px;
  }
  .hotel-head__sub {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 13px; color: var(--cream-faint);
  }
  .hotel-head__lang {
    position: absolute; top: 8px; right: 28px;
    font-family: 'DM Sans', sans-serif; font-size: 10px;
    letter-spacing: .22em; color: var(--gold);
    font-weight: 400; text-transform: uppercase; cursor: pointer;
  }

  .ornament {
    display: flex; align-items: center; justify-content: center;
    gap: 12px; padding: 20px 0;
  }
  .ornament__line { width: 60px; height: 1px; background: var(--gold); opacity: .6; }
  .ornament__rhombus { width: 7px; height: 7px; background: var(--gold); transform: rotate(45deg); }
  .ornament__rhombus--small { width: 4px; height: 4px; opacity: .5; }

  .hero { padding: 8px 32px 28px; text-align: center; }
  .hero__eyebrow {
    font-family: 'DM Sans', sans-serif; font-size: 10px;
    letter-spacing: .32em; text-transform: uppercase; color: var(--gold);
    font-weight: 400; margin-bottom: 18px;
  }
  .hero__title {
    font-family: 'Bodoni Moda', serif;
    font-size: 38px; line-height: 1.1; font-weight: 400;
    letter-spacing: -.005em; color: var(--cream); margin-bottom: 14px;
  }
  .hero__title em {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic; font-weight: 300;
    color: var(--gold); font-size: 36px;
  }
  .hero__sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px; font-style: italic; color: var(--cream-faint);
    line-height: 1.5; max-width: 88%; margin: 0 auto;
  }

  .stay {
    margin: 8px 32px 20px; padding: 20px 0;
    border-top: 1px solid var(--hair); border-bottom: 1px solid var(--hair);
    display: flex; justify-content: space-between;
    position: relative; text-align: center;
  }
  .stay::before, .stay::after {
    content: ''; position: absolute; left: 50%; transform: translateX(-50%) rotate(45deg);
    width: 6px; height: 6px; background: var(--bg); border: 1px solid var(--gold);
  }
  .stay::before { top: -4px; }
  .stay::after { bottom: -4px; }
  .stay__col { flex: 1; }
  .stay__label {
    font-family: 'DM Sans', sans-serif; font-size: 9px;
    letter-spacing: .24em; text-transform: uppercase;
    color: var(--cream-muted); font-weight: 400; margin-bottom: 6px;
  }
  .stay__value {
    font-family: 'Bodoni Moda', serif;
    font-size: 18px; font-weight: 500; color: var(--cream); letter-spacing: .005em;
  }

  .actions { padding: 24px 32px 16px; }
  .actions__head { text-align: center; margin-bottom: 24px; }
  .actions__title {
    font-family: 'Bodoni Moda', serif; font-style: italic;
    font-size: 22px; font-weight: 400; color: var(--cream);
    letter-spacing: -.005em; margin-bottom: 4px;
  }
  .actions__sub {
    font-family: 'DM Sans', sans-serif; font-size: 9px;
    letter-spacing: .3em; text-transform: uppercase; color: var(--gold); font-weight: 400;
  }
  .action-list { display: flex; flex-direction: column; gap: 0; }
  .action {
    padding: 18px 0; border-bottom: 1px solid var(--hair);
    display: flex; align-items: center; gap: 18px;
    cursor: pointer; transition: background 300ms ease; position: relative;
  }
  .action:last-child { border-bottom: 0; }
  .action__icon {
    width: 42px; height: 42px;
    border: 1px solid var(--gold); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    position: relative; flex-shrink: 0;
  }
  .action__icon::before {
    content: ''; position: absolute; top: -3px; left: 50%; transform: translateX(-50%) rotate(45deg);
    width: 4px; height: 4px; background: var(--gold);
  }
  .action__icon svg { width: 18px; height: 18px; stroke: var(--gold); fill: none; stroke-width: 1; }
  .action__body { flex: 1; }
  .action__title {
    font-family: 'Bodoni Moda', serif;
    font-size: 18px; font-weight: 500; color: var(--cream);
    letter-spacing: .005em; margin-bottom: 2px;
  }
  .action__sub {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 13px; color: var(--cream-muted);
  }
  .action__arrow { color: var(--gold); font-family: 'Bodoni Moda', serif; font-size: 18px; font-weight: 300; }

  .concierge {
    margin: 20px 32px 24px; padding: 24px 20px;
    background: var(--bg-deep); border: 1px solid var(--gold);
    position: relative; text-align: center;
  }
  .concierge::before, .concierge::after {
    content: ''; position: absolute;
    width: 14px; height: 14px; border: 1px solid var(--gold);
  }
  .concierge::before { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
  .concierge::after { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }
  .concierge__eyebrow {
    font-family: 'DM Sans', sans-serif; font-size: 9px;
    letter-spacing: .32em; text-transform: uppercase; color: var(--gold);
    font-weight: 400; margin-bottom: 10px;
  }
  .concierge__title {
    font-family: 'Bodoni Moda', serif;
    font-size: 22px; font-weight: 400; line-height: 1.2;
    color: var(--cream); letter-spacing: .005em; margin-bottom: 6px;
  }
  .concierge__title em {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-weight: 300; color: var(--gold);
  }
  .concierge__sub {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 14px; color: var(--cream-faint);
  }

  .tabs {
    margin-top: auto; padding: 14px 24px 28px;
    border-top: 1px solid var(--hair); background: var(--bg);
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;
    position: relative;
  }
  .tabs::before {
    content: ''; position: absolute; top: -5px; left: 50%; transform: translateX(-50%) rotate(45deg);
    width: 8px; height: 8px; background: var(--bg); border: 1px solid var(--gold);
  }
  .tab {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 8px 4px; cursor: pointer;
    text-decoration: none; color: var(--cream-muted);
    transition: color 300ms ease; position: relative;
  }
  .tab svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.25; }
  .tab__label {
    font-family: 'DM Sans', sans-serif; font-size: 9px;
    letter-spacing: .22em; text-transform: uppercase; font-weight: 400;
  }
  .tab.is-active { color: var(--gold); }
  .tab.is-active .tab__label { font-weight: 500; color: var(--gold-bright); }
  .tab.is-active::after {
    content: ''; position: absolute; bottom: -12px; left: 50%; transform: translateX(-50%) rotate(45deg);
    width: 4px; height: 4px; background: var(--gold);
  }
</style>
