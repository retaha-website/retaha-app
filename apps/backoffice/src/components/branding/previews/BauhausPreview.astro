---
interface Props {
  hotelName?: string;
  hotelInitial?: string;
  guestName?: string;
  roomNumber?: string;
  arrivalDate?: string;
  departureDate?: string;
  nights?: number;
  brandPrimary?: string | null;
}

const {
  hotelName = "The Gate Garden",
  hotelInitial = hotelName?.charAt(0) ?? "G",
  guestName = "Maximilian",
  roomNumber = "204",
  arrivalDate = "06. Juni",
  departureDate = "09. Juni",
  nights = 3,
  brandPrimary = null,
} = Astro.props;
---

<div class="bh-wrap" style={brandPrimary ? `--pink:${brandPrimary}` : undefined}>
  <div class="phone">
    <div class="notch"></div>
    <div class="app">
      <div class="statusbar">
        <span>09:24</span>
        <div class="statusbar__icons">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2 22h2v-8H2v8m4 0h2V10H6v12m4 0h2V6h-2v16m4 0h2V2h-2v20"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="6" width="18" height="12" rx="2" stroke-width="0"/><rect x="20" y="10" width="2" height="4"/></svg>
        </div>
      </div>

      <div class="hotel-head">
        <div class="hotel-mark">
          <div class="hotel-mark__logo">{hotelInitial}</div>
          <div class="hotel-mark__name">
            {hotelName}
            <span>Berlin · ZIMMER {roomNumber}</span>
          </div>
        </div>
        <div class="hotel-head__lang">DE</div>
      </div>

      <section class="hero">
        <span class="hero__eyebrow">Willkommen</span>
        <h1 class="hero__title">Hallo, {guestName}<span class="hero__title-dot"></span></h1>
        <p class="hero__sub">Du bist seit gestern bei uns. Brauchst du etwas?</p>
      </section>

      <div class="stay">
        <div class="stay__col">
          <div class="stay__label">Anreise</div>
          <div class="stay__value">{arrivalDate}</div>
        </div>
        <div class="stay__divider"></div>
        <div class="stay__col">
          <div class="stay__label">Abreise</div>
          <div class="stay__value">{departureDate}</div>
        </div>
        <div class="stay__divider"></div>
        <div class="stay__col">
          <div class="stay__label">Nächte</div>
          <div class="stay__value">{nights}</div>
        </div>
      </div>

      <section class="actions">
        <div class="actions__head">
          <h2 class="actions__title">Was du brauchst</h2>
          <span class="actions__num">04</span>
        </div>
        <div class="actions__grid">
          <div class="action">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></svg>
            </div>
            <div>
              <div class="action__title">WLAN-Code</div>
              <div class="action__sub">Sofort verbinden</div>
            </div>
          </div>
          <div class="action">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            </div>
            <div>
              <div class="action__title">Frühstück</div>
              <div class="action__sub">Slot buchen</div>
            </div>
          </div>
          <div class="action action--featured">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </div>
            <div>
              <div class="action__title">Frag Eve</div>
              <div class="action__sub">24/7 Concierge</div>
            </div>
          </div>
          <div class="action">
            <div class="action__icon">
              <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            </div>
            <div>
              <div class="action__title">Service</div>
              <div class="action__sub">Anfrage senden</div>
            </div>
          </div>
        </div>
      </section>

      <div class="slider-preview">
        <div class="slider-card slider-card--main">
          <div class="slider-card__eyebrow">Empfehlung</div>
          <div class="slider-card__title">Schöne Cafés in 5 Min</div>
          <div class="slider-card__sub">Drei Tipps um die Ecke</div>
          <div class="slider-card__cta">Mehr erfahren →</div>
        </div>
        <div class="slider-card slider-card--peek">
          <div class="slider-card__eyebrow">Highlight</div>
          <div class="slider-card__title">Abendessen</div>
        </div>
      </div>

      <nav class="tabs">
        <a class="tab is-active" href="#">
          <svg viewBox="0 0 24 24"><path d="M3 12l9-9 9 9M5 10v10h14V10"/></svg>
          <span class="tab__label">Start</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          <span class="tab__label">Eve</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/></svg>
          <span class="tab__label">Tipps</span>
        </a>
        <a class="tab" href="#">
          <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span class="tab__label">Service</span>
        </a>
      </nav>
    </div>
  </div>
</div>

<style>
  .bh-wrap {
    --bg: #FAFAF7;
    --bg-deep: #F2F1EC;
    --ink: #0A0A0A;
    --ink-muted: #5C5C5C;
    --ink-faint: #A3A3A3;
    --pink: #FF4A82;
    --pink-soft: rgba(255,74,130,.12);
    --yellow: #FFE600;
    --yellow-soft: #FFFAB8;
    --border: #E5E4DF;
    --border-medium: #C9C7C0;
    --r: 12px;
    --r-sm: 8px;
  }

  .phone {
    width: 390px;
    height: 844px;
    background: var(--bg);
    border-radius: 54px;
    box-shadow:
      0 0 0 12px #0A0A0A,
      0 0 0 14px #1F1F1F,
      0 50px 100px -20px rgba(0,0,0,.4);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    font-family: 'Space Grotesk', sans-serif;
    color: var(--ink);
  }
  .notch {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 120px; height: 32px; background: #0A0A0A;
    border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; z-index: 50;
  }
  .app {
    flex: 1; display: flex; flex-direction: column;
    padding-top: 54px; overflow-y: auto;
    scrollbar-width: none;          /* Mini-Preview ohne Scrollbar */
  }
  .app::-webkit-scrollbar { display: none; }
  .statusbar {
    padding: 0 28px;
    display: flex; justify-content: space-between; align-items: center;
    font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 600;
    margin-bottom: 18px;
  }
  .statusbar__icons { display: flex; gap: 6px; align-items: center; }
  .statusbar__icons svg { width: 14px; height: 14px; }

  .hotel-head {
    padding: 16px 24px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--border);
  }
  .hotel-mark { display: flex; align-items: center; gap: 10px; }
  .hotel-mark__logo {
    width: 32px; height: 32px;
    background: var(--ink); color: var(--bg);
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 14px;
    letter-spacing: .04em;
  }
  .hotel-mark__name { font-size: 12px; font-weight: 500; letter-spacing: -.01em; }
  .hotel-mark__name span {
    display: block;
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--ink-faint);
    margin-top: 1px;
  }
  .hotel-head__lang {
    width: 32px; height: 32px; border: 1px solid var(--border); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 500;
  }

  .hero { padding: 36px 24px 28px; }
  .hero__eyebrow {
    display: inline-block;
    background: var(--yellow); color: var(--ink);
    padding: 4px 10px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 600;
    letter-spacing: .14em; text-transform: uppercase;
    border-radius: 4px; margin-bottom: 14px;
  }
  .hero__title {
    font-size: 42px; line-height: 1.05; font-weight: 500;
    letter-spacing: -.025em; margin-bottom: 8px;
  }
  .hero__title-dot {
    display: inline-block; width: 12px; height: 12px;
    background: var(--pink); border-radius: 50%;
    vertical-align: baseline; margin-left: 2px;
  }
  .hero__sub { font-size: 14px; color: var(--ink-muted); line-height: 1.5; }

  .stay {
    margin: 0 24px 24px;
    border: 1px solid var(--border); border-radius: var(--r);
    padding: 18px 20px;
    display: flex; align-items: center; gap: 20px;
    background: #fff;
  }
  .stay__col { flex: 1; }
  .stay__label {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--ink-faint);
    margin-bottom: 4px;
  }
  .stay__value { font-size: 15px; font-weight: 500; letter-spacing: -.01em; }
  .stay__divider { width: 1px; height: 36px; background: var(--border); }

  .actions { padding: 0 24px 20px; }
  .actions__head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .actions__title { font-size: 14px; font-weight: 500; letter-spacing: -.01em; }
  .actions__num {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: .14em; color: var(--ink-faint);
  }
  .actions__grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  }
  .action {
    background: #fff; border: 1px solid var(--border); border-radius: var(--r);
    padding: 16px; cursor: pointer; transition: all 200ms ease;
    position: relative; min-height: 120px;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .action__icon {
    width: 32px; height: 32px;
    border: 1px solid var(--ink); border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
  }
  .action__icon svg { width: 18px; height: 18px; stroke: var(--ink); fill: none; stroke-width: 1.5; }
  .action__title { font-size: 14px; font-weight: 500; letter-spacing: -.01em; margin-top: 14px; }
  .action__sub {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: .12em; text-transform: uppercase; color: var(--ink-faint);
    margin-top: 4px;
  }
  .action--featured {
    background: var(--ink); color: var(--bg); border-color: var(--ink);
  }
  .action--featured .action__icon { border-color: var(--bg); }
  .action--featured .action__icon svg { stroke: var(--bg); }
  .action--featured .action__sub { color: rgba(255,255,255,.5); }

  .slider-preview {
    display: flex; gap: 10px;
    padding: 0 24px 20px; overflow: hidden;
  }
  .slider-card {
    border-radius: var(--r);
    border: 1px solid var(--border);
    background: var(--card-bg);
    padding: 14px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .slider-card--main { flex: 0 0 75%; }
  .slider-card--peek { flex: 0 0 calc(25% - 10px); opacity: 0.5; }
  .slider-card__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 8px;
    letter-spacing: .14em; text-transform: uppercase;
    color: rgba(10,10,10,.45); margin-bottom: 2px;
  }
  .slider-card__title { font-size: 14px; font-weight: 500; line-height: 1.2; }
  .slider-card__sub { font-size: 11px; opacity: .7; }
  .slider-card__cta {
    margin-top: 8px; font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--pink);
  }

  .tabs {
    margin-top: auto; padding: 12px 8px 28px;
    border-top: 1px solid var(--border); background: var(--bg);
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;
  }
  .tab {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 8px 4px; cursor: pointer;
    text-decoration: none; color: var(--ink-faint);
    transition: color 200ms ease;
    position: relative;
  }
  .tab svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.5; }
  .tab__label {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: .12em; text-transform: uppercase;
  }
  .tab.is-active { color: var(--ink); }
  .tab.is-active .tab__label { font-weight: 600; }
  .tab.is-active::after {
    content: ''; width: 4px; height: 4px; background: var(--pink);
    border-radius: 50%; position: absolute;
  }
</style>
