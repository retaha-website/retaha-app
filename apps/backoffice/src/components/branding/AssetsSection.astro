---
import BrandSection from './BrandSection.astro';
import type { BrandingData } from '@retaha/auth';
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props { branding: BrandingData; lang: LanguageCode; plan?: string; }
const { branding, lang, plan = 'lite' } = Astro.props;
const isLite = plan === 'lite';

const assets = [
  { key: 'splash_background', labelKey: 'brand.asset.1.label', hintKey: 'brand.asset.1.hint', ratio: '9/16',  proOnly: false },
  { key: 'wallet_pass_bg',    labelKey: 'brand.asset.2.label', hintKey: 'brand.asset.2.hint', ratio: '16/9', proOnly: true  },
  { key: 'email_header',      labelKey: 'brand.asset.3.label', hintKey: 'brand.asset.3.hint', ratio: '16/9', proOnly: true  },
];
---

<BrandSection title={bt('brand.assets.title', lang)} num="04" lang={lang} optional>
  <div class="asset-grid">
    {assets.map(a => {
      const locked = isLite && a.proOnly;
      const url = branding[a.key as keyof BrandingData] as string | null;
      return (
        <div class:list={['asset-slot', locked && 'asset-slot--locked']} data-slot={a.key}>
          <div class="asset-slot__head">
            <span class="asset-slot__label">
              {bt(a.labelKey, lang)}
              {locked && (
                <span class="asset-slot__pro-badge">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
                  Pro
                </span>
              )}
            </span>
            <span class="asset-slot__hint">{bt(a.hintKey, lang)}</span>
          </div>
          {locked ? (
            <div class="asset-slot__drop asset-slot__drop--locked" style={`aspect-ratio:${a.ratio}`}>
              <div class="asset-slot__lock-body">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
                <span>Nur im <a href="/subscription">Pro-Plan</a></span>
              </div>
            </div>
          ) : (
            <div class="asset-slot__drop" style={`aspect-ratio:${a.ratio}`} data-key={a.key}>
              <img class="asset-slot__img" alt="" src={url || undefined} hidden={!url || undefined} />
              <div class="asset-slot__empty" hidden={!!url || undefined}>
                <span class="asset-slot__plus">+</span>
                <span class="asset-slot__cta">{bt('brand.drop.cta', lang)}</span>
              </div>
              <input type="file" class="asset-slot__input" accept="image/jpeg,image/png,image/webp" data-key={a.key} />
            </div>
          )}
          {!locked && (
            <>
              <div class="asset-slot__actions" hidden={!url || undefined}>
                <button class="asset-slot__btn" data-action="replace" data-key={a.key} type="button">{bt('brand.replace', lang)}</button>
                <button class="asset-slot__btn asset-slot__btn--del" data-action="delete" data-key={a.key} type="button">{bt('common.remove', lang)}</button>
              </div>
              <div class="asset-slot__status" hidden></div>
            </>
          )}
        </div>
      );
    })}
  </div>
</BrandSection>

<style>
  .asset-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }
  .asset-slot { display: flex; flex-direction: column; gap: 8px; }
  .asset-slot__head { display: flex; flex-direction: column; gap: 2px; }
  .asset-slot__label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.1em; color: var(--ink); font-weight: 500;
  }
  .asset-slot__hint {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.06em; color: var(--ink-muted);
  }
  .asset-slot__pro-badge {
    display: inline-flex; align-items: center; gap: 3px;
    margin-left: 6px; vertical-align: middle;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: 4px; padding: 2px 5px;
    font-family: 'JetBrains Mono', monospace; font-size: 8px;
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-muted);
  }

  .asset-slot--locked { opacity: 0.55; }

  .asset-slot__drop {
    position: relative; background: var(--bg-deep);
    border: 1px dashed var(--border-medium); border-radius: var(--r-sm);
    overflow: hidden; cursor: pointer; transition: all 200ms;
    display: flex; align-items: center; justify-content: center;
  }
  .asset-slot__drop:hover { background: rgba(20,97,110,0.06); border-color: var(--petrol, #14616E); }

  .asset-slot__drop--locked { cursor: not-allowed; }
  .asset-slot__drop--locked:hover { background: var(--bg-deep); border-color: var(--border-medium); }
  .asset-slot__lock-body {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: var(--ink-muted);
  }
  .asset-slot__lock-body svg { opacity: 0.6; }
  .asset-slot__lock-body span {
    font-family: 'Space Grotesk', sans-serif; font-size: 11px; color: var(--ink-muted);
  }
  .asset-slot__lock-body a { color: var(--petrol, #14616E); font-weight: 600; text-decoration: none; }
  .asset-slot__lock-body a:hover { text-decoration: underline; }
  .asset-slot__drop.has-image { border-style: solid; border-color: var(--sage); }
  .asset-slot__img { width: 100%; height: 100%; object-fit: cover; }
  .asset-slot__empty { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .asset-slot__plus { font-size: 22px; font-weight: 300; color: var(--ink-faint); line-height: 1; }
  .asset-slot__cta {
    font-family: 'Space Grotesk', sans-serif; font-size: 11px; color: var(--ink-soft);
  }
  .asset-slot__input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

  .asset-slot__actions { display: flex; gap: 6px; }
  .asset-slot__actions[hidden] { display: none !important; }
  .asset-slot__empty[hidden] { display: none !important; }
  .asset-slot__btn {
    flex: 1; padding: 6px 10px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-sm); cursor: pointer; transition: all 150ms;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.08em; color: var(--ink-soft);
  }
  .asset-slot__btn:hover { background: var(--bg-deep, #F5F4F2); color: var(--ink); }
  .asset-slot__btn--del:hover { background: var(--burgund-soft); color: var(--burgund); border-color: var(--burgund); }

  .asset-slot__status {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.06em; padding: 6px 10px; border-radius: var(--r-sm);
  }
  .asset-slot__status--ok  { background: var(--sage-soft); color: var(--sage-strong); }
  .asset-slot__status--err { background: var(--burgund-soft); color: var(--burgund); }
</style>

<script>
  const T = JSON.parse(document.getElementById('brand-i18n')?.textContent || '{}');
  function showStatus(slot: HTMLElement, ok: boolean, msg: string) {
    const el = slot.querySelector<HTMLElement>('.asset-slot__status');
    if (!el) return;
    el.textContent = msg;
    el.className = `asset-slot__status asset-slot__status--${ok ? 'ok' : 'err'}`;
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 3000);
  }

  function bindSlot(slot: HTMLElement) {
    const input = slot.querySelector<HTMLInputElement>('.asset-slot__input');
    if (!input) return;

    input.addEventListener('change', async () => {
      const file = input.files?.[0];
      if (!file) return;
      const key = input.dataset.key!;
      const drop = slot.querySelector<HTMLElement>('.asset-slot__drop')!;

      // Optimistic preview — toggle existing elements (kein innerHTML, kein Scope-Bug)
      const reader = new FileReader();
      reader.onload = () => {
        const img = drop.querySelector<HTMLImageElement>('.asset-slot__img')!;
        img.src = reader.result as string;
        img.hidden = false;
        const empty = drop.querySelector<HTMLElement>('.asset-slot__empty');
        if (empty) empty.hidden = true;
        drop.classList.add('has-image');
      };
      reader.readAsDataURL(file);

      const fd = new FormData();
      fd.append('key', key); fd.append('file', file);
      const res = await fetch('/api/branding/upload-logo', { method: 'POST', body: fd });
      if (res.ok) {
        showStatus(slot, true, T.assetSavedStatus);
        (window as any).retahaToast?.(T.assetSaved);
        const actions = slot.querySelector<HTMLElement>('.asset-slot__actions');
        if (actions) {
          actions.hidden = false;
          actions.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(b => b.dataset.key = key);
        }
        // Live-Preview: Splash-Background → Hero-Hintergrund im Phone
        if (key === 'splash_background') {
          const heroBg = document.querySelector<HTMLElement>('#brandPhoneScreen .gate-hero-bg');
          if (heroBg && reader.result) heroBg.style.backgroundImage = `url('${reader.result}')`;
        }
      } else {
        const j = await res.json();
        showStatus(slot, false, `✗ ${j.error}`);
        (window as any).retahaToast?.(`${T.uploadfail}: ${j.error}`, 'error');
        // Optimistic preview zurücksetzen
        const img = drop.querySelector<HTMLImageElement>('.asset-slot__img')!;
        img.src = ''; img.hidden = true;
        const empty = drop.querySelector<HTMLElement>('.asset-slot__empty');
        if (empty) empty.hidden = false;
        drop.classList.remove('has-image');
        input.value = '';
      }
    });
  }

  function bindActions(slot: HTMLElement) {
    slot.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.key!;
        const drop = slot.querySelector<HTMLElement>('.asset-slot__drop')!;
        if (btn.dataset.action === 'replace') {
          slot.querySelector<HTMLInputElement>('.asset-slot__input')?.click();
        } else if (btn.dataset.action === 'delete') {
          (window as any).__brandConfirm(T.assetConfirm, async () => {
            const fd = new FormData();
            fd.append('key', key); fd.append('delete', 'true');
            const res = await fetch('/api/branding/upload-logo', { method: 'POST', body: fd });
            if (res.ok) {
              const img = drop.querySelector<HTMLImageElement>('.asset-slot__img');
              if (img) { img.src = ''; img.hidden = true; }
              const empty = drop.querySelector<HTMLElement>('.asset-slot__empty');
              if (empty) empty.hidden = false;
              drop.classList.remove('has-image');
              const actions = slot.querySelector<HTMLElement>('.asset-slot__actions');
              if (actions) actions.hidden = true;
              showStatus(slot, true, T.assetRemovedStatus);
              (window as any).retahaToast?.(T.assetRemoved);
              if (key === 'splash_background') {
                const heroBg = document.querySelector<HTMLElement>('#brandPhoneScreen .gate-hero-bg');
                if (heroBg) heroBg.style.backgroundImage = '';
              }
            } else {
              (window as any).retahaToast?.(T.removefail, 'error');
            }
          });
        }
      });
    });
  }

  document.querySelectorAll<HTMLElement>('.asset-slot').forEach(slot => {
    bindSlot(slot);
    bindActions(slot);
  });
</script>
