---
import BrandSection from './BrandSection.astro';
import ColorPicker from './ColorPicker.astro';
import type { BrandingData } from '@retaha/auth';
import { computeBrandPalette } from '@retaha/auth';
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props { branding: BrandingData; lang: LanguageCode; plan?: string; }
const { branding, lang, plan = 'lite' } = Astro.props;

const isLite = plan === 'lite';
const PETROL = '#14616E';
const primary = isLite ? PETROL : (branding.brand_primary ?? PETROL);
const palette = computeBrandPalette(primary);
---

<BrandSection title={bt('brand.colors.title', lang)} num="02" lang={lang}>
  {isLite && (
    <div class="cs-lite-info">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span>Die Farbauswahl ist nur im <strong>Pro-Plan</strong> verfügbar. Im Lite-Plan wird Retaha Petrol verwendet. <a href="/subscription" class="cs-lite-link">Jetzt auf Pro upgraden →</a></span>
    </div>
  )}

  <form method="POST" id="colorsForm">
    <input type="hidden" name="_action" value="colors" />

    <!-- Primary -->
    <div class="field field--row">
      <label class="field__label req" for="brand-primary">{bt('brand.colors.primary', lang)}</label>
      <div class="color-row">
        <input type="text" id="brand-primary" name="brand_primary" class="s-input color-hex"
          value={primary} placeholder="#14616E" maxlength="7"
          disabled={isLite} readonly={isLite} />
        {!isLite && <ColorPicker targetId="brand-primary" value={primary} ariaLabel={bt('brand.colors.pickeria', lang)} />}
      </div>
    </div>
    {!isLite && <p class="field__hint">{bt('brand.colors.hint', lang)}</p>}

    <!-- Palette-Rollen -->
    <div class="variants">
      <span class="variants__label">{bt('brand.colors.palette', lang)}</span>
      <div class="variant-grid" id="variantGrid">
        <div class="variant-chip" id="chip-accent" style={`background:${primary}`}>
          <span class="variant-chip__role">{bt('brand.role.accent', lang)}</span>
          <span class="variant-chip__hex" id="chip-accent-hex">{primary}</span>
        </div>
        <div class="variant-chip" id="chip-hover" style={`background:${palette.hover}`}>
          <span class="variant-chip__role">{bt('brand.role.hover', lang)}</span>
          <span class="variant-chip__hex" id="chip-hover-hex">{palette.hover}</span>
        </div>
        <div class="variant-chip" id="chip-soft" style={`background:${palette.soft}`}>
          <span class="variant-chip__role">{bt('brand.role.soft', lang)}</span>
          <span class="variant-chip__hex" id="chip-soft-hex">{palette.soft}</span>
        </div>
        <div class="variant-chip" id="chip-on" style={`background:${palette.onAccent}`}>
          <span class="variant-chip__role">{bt('brand.role.onaccent', lang)}</span>
          <span class="variant-chip__hex" id="chip-on-hex">{palette.onAccent}</span>
        </div>
      </div>
    </div>

    {!isLite && (
      <div class="s-card__footer">
        <button type="submit" class="brand-save-btn">{bt('common.save', lang)}</button>
      </div>
    )}
  </form>
</BrandSection>

<style>
  /* Lite-Plan Infobox */
  .cs-lite-info {
    display: flex; align-items: flex-start; gap: 8px;
    background: rgba(20, 97, 110, 0.06); border: 1px solid rgba(20, 97, 110, 0.18);
    border-radius: 8px; padding: 8px 12px;
    font-size: 12px; color: var(--ink-soft, rgba(10,10,10,0.65));
    line-height: 1.45; margin-bottom: 16px;
  }
  .cs-lite-info svg { color: var(--petrol, #14616E); }
  .cs-lite-link { color: var(--petrol, #14616E); font-weight: 600; text-decoration: none; }
  .cs-lite-link:hover { text-decoration: underline; }

  form { display: flex; flex-direction: column; gap: 24px; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field--row {
    display: grid; grid-template-columns: minmax(140px, 200px) 1fr;
    gap: 20px; align-items: center;
  }
  @media (max-width: 600px) { .field--row { grid-template-columns: 1fr; } }
  .field__label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.08em; font-weight: 500; color: var(--ink);
  }
  .field__label.req::after { content: ' *'; color: var(--petrol, #14616E); }
  .field__hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--ink-muted); letter-spacing: 0.04em; margin-top: -8px;
  }
  .color-row { display: flex; align-items: center; gap: 10px; }
  .s-input {
    background: var(--surface); border: 1px solid var(--border-medium);
    border-radius: var(--r-sm); padding: 10px 14px;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    color: var(--ink); transition: all 150ms; flex: 1;
  }
  .s-input:focus { outline: none; border-color: var(--petrol, #14616E); box-shadow: 0 0 0 3px rgba(20,97,110,0.12); }
  .s-input:disabled { opacity: 0.65; cursor: not-allowed; background: var(--bg-deep, #F0EFEA); }

  .variants { margin-top: 4px; }
  .variants__label {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
    display: block; margin-bottom: 10px;
  }
  .variant-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .variant-chip {
    aspect-ratio: 1.4; border-radius: var(--r-sm); padding: 10px;
    display: flex; flex-direction: column; justify-content: space-between;
    border: 1px solid var(--border);
  }
  .variant-chip__role {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 600;
    color: var(--ink); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .variant-chip__hex { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--ink-muted); }
  .s-card__footer { margin-top: 8px; display: flex; justify-content: flex-end; }
  .brand-save-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--petrol, #14616E); color: #fff;
    border: 1px solid var(--petrol, #14616E); border-radius: 9px;
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 500;
    padding: 7px 18px; cursor: pointer; transition: background 150ms, border-color 150ms;
  }
  .brand-save-btn:hover { background: #0f4f59; border-color: #0f4f59; }
  .brand-save-btn:disabled { opacity: 0.45; cursor: not-allowed; }
</style>

<script>
  function computePalette(hex: string) {
    if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return null;
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    function mixWhite(t: number) {
      const mr = Math.round(r + (255 - r) * t);
      const mg = Math.round(g + (255 - g) * t);
      const mb = Math.round(b + (255 - b) * t);
      return `#${mr.toString(16).padStart(2,'0')}${mg.toString(16).padStart(2,'0')}${mb.toString(16).padStart(2,'0')}`;
    }
    function sRGB(c: number) { const v = c/255; return v <= 0.03928 ? v/12.92 : Math.pow((v+0.055)/1.055, 2.4); }
    const lum = 0.2126*sRGB(r) + 0.7152*sRGB(g) + 0.0722*sRGB(b);
    return { accent: hex, hover: mixWhite(0.65), soft: mixWhite(0.90), onAccent: lum > 0.179 ? '#0A0A0A' : '#FFFFFF' };
  }

  function updateChips(hex: string) {
    const p = computePalette(hex);
    if (!p) return;
    const setChip = (id: string, color: string) => {
      const el = document.getElementById(id) as HTMLElement | null;
      if (el) { el.style.background = color; const hx = el.querySelector('.variant-chip__hex') as HTMLElement | null; if (hx) hx.textContent = color; }
    };
    setChip('chip-accent', p.accent);
    setChip('chip-hover',  p.hover);
    setChip('chip-soft',   p.soft);
    setChip('chip-on',     p.onAccent);
  }

  function syncFromHex(hexInput: HTMLInputElement) {
    const hex = hexInput.value.trim();
    if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return;
    if (hexInput.id === 'brand-primary') {
      updateChips(hex);
      document.querySelector<HTMLElement>('.bh-wrap')?.style.setProperty('--pink', hex);
      document.querySelector<HTMLElement>('.ed-wrap')?.style.setProperty('--olive', hex);
      document.querySelector<HTMLElement>('.ms-wrap')?.style.setProperty('--gold', hex);
    }
  }

  document.querySelectorAll<HTMLInputElement>('.color-hex').forEach(input => {
    input.addEventListener('input', () => syncFromHex(input));
    syncFromHex(input);
  });
</script>
