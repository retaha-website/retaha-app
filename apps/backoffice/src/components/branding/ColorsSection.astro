---
import BrandSection from './BrandSection.astro';
import ColorPicker from './ColorPicker.astro';
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props { branding: BrandingData; }
const { branding } = Astro.props;

const primary   = branding.brand_primary   ?? '#FF4A82';
const secondary = branding.brand_secondary ?? '';
---

<BrandSection title="Brand-Farben" num="02">
  <form method="POST" id="colorsForm">
    <input type="hidden" name="_action" value="colors" />

    <!-- Primary -->
    <div class="field field--row">
      <label class="field__label req" for="brand-primary">Primärfarbe *</label>
      <div class="color-row">
        <input type="text" id="brand-primary" name="brand_primary" class="s-input color-hex"
          value={primary} placeholder="#FF4A82" maxlength="7" />
        <ColorPicker targetId="brand-primary" value={primary} ariaLabel="Farbwähler Primärfarbe" />
      </div>
    </div>
    <p class="field__hint">Hauptakzentfarbe der Gäste-App (CTAs, Eve-Chat, Action-Karten)</p>

    <!-- Secondary -->
    <div class="field field--row">
      <label class="field__label" for="brand-secondary">Sekundärfarbe</label>
      <div class="color-row">
        <input type="text" id="brand-secondary" name="brand_secondary" class="s-input color-hex"
          value={secondary} placeholder="Optional · #8C2128" maxlength="7" />
        <ColorPicker targetId="brand-secondary" value={secondary || '#8C2128'} ariaLabel="Farbwähler Sekundärfarbe" />
      </div>
    </div>

    <!-- Auto-Varianten -->
    <div class="variants">
      <span class="variants__label">Auto-Varianten</span>
      <div class="variant-grid" id="variantGrid">
        {[['10%','Hover-Tint'],['25%','Weich'],['60%','Gedimmt'],['100%','Primär']].map(([pct, hint]) => (
          <div class="variant-chip variant-chip--auto">
            <span class="variant-chip__pct">{pct}</span>
            <span class="variant-chip__hint">{hint}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="s-card__footer">
      <button type="submit" class="s-btn">Speichern</button>
    </div>
  </form>
</BrandSection>

<style>
  form { display: flex; flex-direction: column; gap: 24px; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field--row {
    display: grid; grid-template-columns: minmax(140px, 200px) 1fr;
    gap: 20px; align-items: center;
  }
  @media (max-width: 600px) { .field--row { grid-template-columns: 1fr; } }
  .field__label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.08em; font-weight: 500; color: var(--ink);
  }
  .field__label.req::after { content: ' *'; color: var(--pink); }
  .field__hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--ink-muted); letter-spacing: 0.04em; margin-top: -8px;
  }
  .color-row { display: flex; align-items: center; gap: 10px; }
  .s-input {
    background: var(--surface); border: 1px solid var(--border-medium);
    border-radius: var(--r-sm); padding: 10px 14px;
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
    color: var(--ink); transition: all 150ms; flex: 1;
  }
  .s-input:focus { outline: none; border-color: var(--ink); background: var(--te-yellow-soft); }

  .variants { margin-top: 4px; }
  .variants__label {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
    display: block; margin-bottom: 10px;
  }
  .variant-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .variant-chip {
    aspect-ratio: 1.4; border-radius: var(--r-sm); padding: 10px;
    display: flex; flex-direction: column; justify-content: space-between;
    border: 1px solid var(--border);
  }
  .variant-chip__pct { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500; color: var(--ink); }
  .variant-chip__hint { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--ink-muted); }
  .s-card__footer { margin-top: 8px; display: flex; justify-content: flex-end; }
  .s-btn {
    background: var(--ink); color: var(--bg); padding: 10px 24px; border: none;
    border-radius: var(--r-sm); font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 500; letter-spacing: 0.14em; cursor: pointer; transition: all 200ms;
  }
  .s-btn:hover { background: var(--te-yellow); color: #0A0A0A; }
</style>

<script>
  function updateVariants(hex: string) {
    if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return;
    const chips = document.querySelectorAll('.variant-chip--auto');
    const alphas = ['1A', '40', '99', 'FF'];
    chips.forEach((chip, i) => {
      (chip as HTMLElement).style.background = `${hex}${alphas[i]}`;
    });
  }

  function syncFromHex(hexInput: HTMLInputElement) {
    const hex = hexInput.value.trim();
    if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return;

    if (hexInput.id === 'brand-primary') {
      updateVariants(hex);
      // Mini-Phone-Preview live updaten — jede Theme-Preview hat eigene Accent-Var
      document.querySelector<HTMLElement>('.bh-wrap')?.style.setProperty('--pink', hex);
      document.querySelector<HTMLElement>('.ed-wrap')?.style.setProperty('--olive', hex);
      document.querySelector<HTMLElement>('.ms-wrap')?.style.setProperty('--gold', hex);
    }
  }

  // Hex-Input (direkte Eingabe) → Varianten
  document.querySelectorAll<HTMLInputElement>('.color-hex').forEach(input => {
    input.addEventListener('input', () => syncFromHex(input));
    syncFromHex(input); // Initialer Sync
  });
</script>
