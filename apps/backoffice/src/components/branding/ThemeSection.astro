---
import BrandSection from './BrandSection.astro';
import type { BrandingData } from '@retaha/auth';
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props {
  branding: BrandingData;
  hotelName?: string;
  lang: LanguageCode;
  plan?: string;
}

const { branding, lang, plan = 'lite' } = Astro.props;
const isLite = plan === 'lite';

const SHOW_ALL_IDENTITIES = true;

const raw = branding.design_identity ?? 'bauhaus';
const active = isLite ? 'bauhaus' : (['bauhaus', 'editorial', 'maison'].includes(raw) ? raw : 'bauhaus');
---

<BrandSection title={bt('brand.theme.title', lang)} num="03" lang={lang}>
  {isLite && (
    <div class="di-lite-info">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span>Im Lite-Plan ist nur Bauhaus verfügbar. <a href="/subscription" class="di-lite-link">Jetzt auf Pro upgraden →</a></span>
    </div>
  )}
  <div
    x-data={`{ theme: '${active}' }`}
    x-init="$watch('theme', t => $dispatch('brand-theme-selected', { theme: t }))"
  >
    <form method="POST" id="identityForm">
      <input type="hidden" name="_action" value="identity" />
      <input type="hidden" name="design_identity" x-bind:value="theme" />

      <div class="di-cards">

        <button
          class="di-card"
          type="button"
          :class="theme === 'bauhaus' ? 'is-active' : ''"
          @click="theme = 'bauhaus'"
        >
          <div class="di-card__hint di-card__hint--bauhaus">
            <span class="bh-initial">B</span>
            <span class="bh-pink-dot"></span>
          </div>
          <div class="di-card__body">
            <div class="di-card__title bauhaus-title">Bauhaus</div>
            <div class="di-card__desc">{bt('brand.theme.bauhaus.desc', lang)}</div>
            <div class="di-card__meta">{bt('brand.theme.bauhaus.meta', lang)}</div>
          </div>
        </button>

        {SHOW_ALL_IDENTITIES && (
          <>
            <button
              class:list={['di-card', isLite && 'di-card--locked']}
              type="button"
              :class="theme === 'editorial' ? 'is-active' : ''"
              @click={!isLite ? "theme = 'editorial'" : undefined}
              disabled={isLite || undefined}
            >
              <div class="di-card__hint di-card__hint--editorial">
                <span class="ed-name">Editorial</span>
              </div>
              <div class="di-card__body">
                <div class="di-card__title editorial-title">Editorial</div>
                <div class="di-card__desc">Magazinhaft · Storytelling</div>
                <div class="di-card__meta">Cormorant Garamond · Olive</div>
              </div>
              {isLite && (
                <span class="di-card__pro-badge">
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
                  Pro
                </span>
              )}
            </button>

            <button
              class:list={['di-card', isLite && 'di-card--locked']}
              type="button"
              :class="theme === 'maison' ? 'is-active' : ''"
              @click={!isLite ? "theme = 'maison'" : undefined}
              disabled={isLite || undefined}
            >
              <div class="di-card__hint di-card__hint--maison">
                <span class="ms-name">MAISON</span>
                <span class="ms-rhombus"></span>
              </div>
              <div class="di-card__body">
                <div class="di-card__title maison-title">Maison</div>
                <div class="di-card__desc">Klassisch · Opulent</div>
                <div class="di-card__meta">Bodoni Moda · Gold-Rauten</div>
              </div>
              {isLite && (
                <span class="di-card__pro-badge">
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
                  Pro
                </span>
              )}
            </button>
          </>
        )}

      </div>

      <div class="di-info">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <p>{bt('brand.theme.info', lang)}</p>
      </div>

      {!isLite && (
        <div class="s-card__footer">
          <button type="submit" class="brand-save-btn">{bt('common.save', lang)}</button>
        </div>
      )}
    </form>
  </div>
</BrandSection>

<style>
  /* Lite info box */
  .di-lite-info {
    display: flex; align-items: flex-start; gap: 8px;
    background: rgba(20, 97, 110, 0.06); border: 1px solid rgba(20, 97, 110, 0.18);
    border-radius: 8px; padding: 8px 12px;
    font-size: 12px; color: var(--ink-soft, rgba(10,10,10,0.65));
    line-height: 1.45; margin-bottom: 14px;
  }
  .di-lite-info svg { color: var(--petrol, #14616E); }
  .di-lite-link { color: var(--petrol, #14616E); font-weight: 600; text-decoration: none; }
  .di-lite-link:hover { text-decoration: underline; }

  .di-cards { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }

  .di-card {
    position: relative;
    display: flex; align-items: center;
    width: 100%; text-align: left; padding: 0;
    border: 1px solid var(--border); border-radius: var(--r);
    background: var(--surface); cursor: pointer;
    transition: border-color 200ms, box-shadow 200ms, transform 200ms;
    overflow: hidden;
    -webkit-appearance: none; appearance: none;
  }
  .di-card:hover {
    border-color: var(--ink-faint);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,.06);
  }
  .di-card.is-active {
    border-color: var(--petrol, #14616E);
    box-shadow: 0 0 0 2px rgba(20,97,110,0.12);
  }

  .di-card--locked {
    opacity: 0.45; cursor: not-allowed;
  }
  .di-card--locked:hover { transform: none; box-shadow: none; border-color: var(--border); }

  .di-card__pro-badge {
    display: inline-flex; align-items: center; gap: 4px;
    margin-right: 14px; flex-shrink: 0;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: 5px; padding: 3px 7px;
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* Hint strip */
  .di-card__hint {
    width: 76px; min-height: 80px; flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 7px; padding: 12px 8px;
  }
  .di-card__hint--bauhaus  { background: #F5F5F3; }
  .di-card__hint--editorial { background: #FAF7F0; }
  .di-card__hint--maison   { background: #1A1410; }

  .bh-initial {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 28px; font-weight: 600;
    color: #0A0A0A; letter-spacing: -.03em; line-height: 1;
  }
  .bh-pink-dot { width: 8px; height: 8px; background: var(--petrol, #14616E); border-radius: 50%; }

  .ed-name {
    font-family: 'Georgia', serif;
    font-size: 13px; font-style: italic; font-weight: 400;
    color: #2B2A28; letter-spacing: .005em;
    border-bottom: 1px solid #4A5C2A; padding-bottom: 2px;
  }

  .ms-name {
    font-family: 'Georgia', serif;
    font-size: 10px; font-weight: 400;
    color: #E8D9B5; letter-spacing: .1em; text-transform: uppercase;
  }
  .ms-rhombus { width: 6px; height: 6px; background: #C9A36A; transform: rotate(45deg); }

  /* Card body */
  .di-card__body { padding: 14px 16px 14px 12px; flex: 1; }

  .di-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 500; color: var(--ink);
    margin-bottom: 3px;
  }
  .bauhaus-title::after {
    content: '';
    display: inline-block; width: 6px; height: 6px;
    background: var(--petrol, #14616E); border-radius: 50%;
    margin-left: 5px; vertical-align: middle;
  }
  .editorial-title {
    font-family: 'Georgia', serif; font-style: italic;
    border-bottom: 1px solid #4A5C2A;
    display: inline-block; padding-bottom: 1px;
    color: var(--ink); font-size: 15px; font-weight: 400;
  }
  .maison-title {
    font-family: 'Georgia', serif; letter-spacing: .04em;
  }
  .maison-title::after {
    content: '';
    display: inline-block; width: 5px; height: 5px;
    background: #C9A36A; transform: rotate(45deg);
    margin-left: 6px; vertical-align: middle;
  }
  .di-card__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-soft);
    letter-spacing: .02em; line-height: 1.5;
  }
  .di-card__meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; color: var(--ink-faint);
    letter-spacing: .1em; text-transform: uppercase; margin-top: 2px;
  }

  .di-info {
    padding: 12px 14px; background: var(--bg-deep);
    border-radius: var(--r-sm); border: 1px solid var(--border);
    display: flex; gap: 10px; align-items: flex-start;
    margin-bottom: 20px;
  }
  .di-info svg { flex-shrink: 0; color: var(--ink-muted); margin-top: 1px; }
  .di-info p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; line-height: 1.5; color: var(--ink-soft); margin: 0;
  }

  .s-card__footer { margin-top: 4px; display: flex; justify-content: flex-end; }
  .brand-save-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--petrol, #14616E); color: #fff;
    border: 1px solid var(--petrol, #14616E); border-radius: 9px;
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 500;
    padding: 7px 18px; cursor: pointer; transition: background 150ms, border-color 150ms;
  }
  .brand-save-btn:hover { background: #0f4f59; border-color: #0f4f59; }
  .brand-save-btn:disabled { opacity: 0.45; cursor: not-allowed; }
</style>
