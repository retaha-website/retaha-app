---
import BrandSection from './BrandSection.astro';
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props { branding: BrandingData; }
const { branding } = Astro.props;

const active = branding.design_identity ?? 'classic';

const identities = [
  {
    key: 'classic',
    label: 'Classic',
    description: 'Das aktuelle Gäste-App-Design',
    badge: 'Aktuell',
    previewHeadline: 'Willkommen',
    previewCta: 'Check-in starten',
  },
  {
    key: 'bauhaus',
    label: 'Bauhaus',
    description: 'Minimal, geometrisch, modern',
    badge: 'Default · Neu',
    previewHeadline: 'willkommen',
    previewCta: 'check-in starten',
  },
  {
    key: 'editorial',
    label: 'Editorial',
    description: 'Warm, Serif, Magazin-Feel',
    badge: 'Neu',
    previewHeadline: 'Willkommen',
    previewCta: 'Check-in starten',
  },
];
---

<BrandSection title="Design-Identität" num="03">
  <form method="POST" id="identityForm">
    <input type="hidden" name="_action" value="identity" />
    <input type="hidden" name="design_identity" id="identityValue" value={active} />

    <div class="identity-grid">
      {identities.map(id => (
        <button
          class={`identity-card ${active === id.key ? 'is-active' : ''}`}
          data-key={id.key}
          type="button"
        >
          <div class={`identity-preview identity-preview--${id.key}`}>
            {active === id.key && <span class="identity-badge">Aktiv</span>}
            <div class="identity-preview__inner">
              <div class="identity-preview__headline">{id.previewHeadline}</div>
              <div class="identity-preview__line"></div>
              <div class="identity-preview__cta">{id.previewCta}</div>
            </div>
          </div>

          <div class="identity-card__body">
            <div class="identity-card__head">
              <span class="identity-card__label">{id.label}</span>
              {id.badge && <span class="identity-card__badge">{id.badge}</span>}
            </div>
            <span class="identity-card__desc">{id.description}</span>
          </div>
        </button>
      ))}
    </div>

    <div class="identity-info">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
      <p>Brand-Farben (Abschnitt 02) werden in alle Identitäten als Primary übernommen.
        <a href="/gast-vorschau">→ Live-Vorschau ansehen</a>
      </p>
    </div>

    <div class="s-card__footer">
      <button type="submit" class="s-btn">Speichern</button>
    </div>
  </form>
</BrandSection>

<style>
  .identity-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 700px) {
    .identity-grid { grid-template-columns: 1fr; }
  }

  /* Card */
  .identity-card {
    display: flex; flex-direction: column;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--r); overflow: hidden;
    cursor: pointer; transition: border-color 200ms, box-shadow 200ms, transform 200ms;
    text-align: left; padding: 0;
    background: var(--surface);
    -webkit-appearance: none; appearance: none;
  }
  .identity-card:hover { border-color: var(--ink-faint); transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,.07); }
  .identity-card.is-active { border-color: var(--sage); box-shadow: 0 0 0 2px var(--sage-soft); }

  /* Preview — fills top of card */
  .identity-preview {
    flex: 1; min-height: 200px;
    width: 100%; align-self: stretch;
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; justify-content: center;
    padding: 24px;
    border-bottom: 1px solid var(--border);
  }
  .identity-preview__inner {
    display: flex; flex-direction: column;
    align-items: flex-start; gap: 10px;
    pointer-events: none;
    width: 100%;
  }

  /* Active badge — inside preview, top-right */
  .identity-badge {
    position: absolute; top: 12px; right: 12px; z-index: 1;
    background: var(--sage); color: #fff;
    padding: 3px 10px; border-radius: 99px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
  }

  /* ── Classic ── */
  .identity-preview--classic { background: #FAFAF8; }
  .identity-preview--classic .identity-preview__headline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 26px; font-weight: 400; color: #1A1A1A; line-height: 1.1;
  }
  .identity-preview--classic .identity-preview__line {
    width: 10px; height: 10px; border-radius: 50%; background: #FF4A82;
  }
  .identity-preview--classic .identity-preview__cta {
    background: #1A1A1A; color: #fff;
    padding: 7px 14px; font-size: 10px;
    font-family: 'Space Grotesk', sans-serif; font-weight: 500;
    border-radius: 4px; align-self: stretch; text-align: center;
  }

  /* ── Bauhaus ── */
  .identity-preview--bauhaus { background: #F5F5F3; }
  .identity-preview--bauhaus .identity-preview__headline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 26px; font-weight: 600; color: #0A0A0A;
    letter-spacing: -0.03em; text-transform: lowercase; line-height: 1.05;
  }
  .identity-preview--bauhaus .identity-preview__line {
    width: 32px; height: 2px; background: #FF4A82; border-radius: 0;
  }
  .identity-preview--bauhaus .identity-preview__cta {
    background: #0A0A0A; color: #F5F5F3;
    padding: 7px 14px; font-size: 9px;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.14em; text-transform: uppercase;
    border-radius: 8px; align-self: stretch; text-align: center;
  }

  /* ── Editorial ── */
  .identity-preview--editorial { background: #FAF7F2; }
  .identity-preview--editorial .identity-preview__headline {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 30px; font-weight: 400; color: #1F1812; line-height: 1.1;
  }
  .identity-preview--editorial .identity-preview__line {
    width: 44px; height: 1px; background: #8C2128;
  }
  .identity-preview--editorial .identity-preview__cta {
    background: #1F1812; color: #FAF7F2;
    padding: 7px 16px; font-size: 10px;
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    border-radius: 6px; letter-spacing: 0.01em; align-self: stretch; text-align: center;
  }

  /* Card body — compact info strip at bottom */
  .identity-card__body {
    padding: 14px 18px 16px;
    display: flex; flex-direction: column; gap: 3px;
    background: var(--surface);
  }
  .identity-card__head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .identity-card__label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 500; color: var(--ink);
  }
  .identity-card__badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 2px 7px; background: var(--bg-deep); color: var(--ink-muted); border-radius: 99px;
  }
  .identity-card__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-muted); letter-spacing: 0.02em; line-height: 1.4;
  }

  form { display: flex; flex-direction: column; gap: 24px; }

  .identity-info {
    padding: 14px 18px; background: var(--bg-deep); border-radius: var(--r-sm);
    display: flex; gap: 12px; align-items: flex-start;
  }
  .identity-info svg { flex-shrink: 0; color: var(--ink-muted); margin-top: 1px; }
  .identity-info p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; line-height: 1.5; color: var(--ink-soft); margin: 0;
  }
  .identity-info a { color: var(--ink); text-decoration: underline; margin-left: 6px; }

  .s-card__footer { display: flex; justify-content: flex-end; }
  .s-btn {
    background: var(--ink); color: var(--bg); padding: 10px 24px; border: none;
    border-radius: var(--r-sm); font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 500; letter-spacing: 0.14em; cursor: pointer; transition: all 200ms;
  }
  .s-btn:hover { background: var(--te-yellow); color: #0A0A0A; }
</style>

<script>
  const cards = document.querySelectorAll<HTMLButtonElement>('.identity-card');
  const hiddenInput = document.getElementById('identityValue') as HTMLInputElement;

  cards.forEach(card => {
    card.addEventListener('click', () => {
      cards.forEach(c => {
        c.classList.remove('is-active');
        c.querySelector('.identity-badge')?.remove();
      });
      card.classList.add('is-active');
      if (hiddenInput) hiddenInput.value = card.dataset.key!;

      const badge = document.createElement('span');
      badge.className = 'identity-badge'; badge.textContent = 'Aktiv';
      card.querySelector('.identity-preview')?.appendChild(badge);

      // Mini-Phone-Preview updaten
      const phoneView = document.querySelector<HTMLElement>('.guest-phone-view');
      if (phoneView) {
        phoneView.setAttribute('data-theme', card.dataset.key!);
      }
    });
  });
</script>
