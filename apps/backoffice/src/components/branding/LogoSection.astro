---
import BrandSection from './BrandSection.astro';
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props { branding: BrandingData; }
const { branding } = Astro.props;

const slots = [
  { key: 'logo_primary',  label: 'Primary',      hint: 'Wort + Symbol · Header, E-Mails',   required: true },
  { key: 'logo_icon',     label: 'Icon Only',     hint: 'Symbol · Favicon, App-Icon, Wallet' },
  { key: 'logo_wordmark', label: 'Wordmark Only', hint: 'Nur Text · Footer, Briefkopf'       },
  { key: 'logo_dark',     label: 'Dark Variant',  hint: 'Für dunkle Hintergründe'            },
];
---

<BrandSection title="Logo" num="01">
  <div class="logo-grid">
    {slots.map(slot => {
      const url = branding[slot.key as keyof BrandingData] as string | null;
      return (
        <div class="logo-slot" data-key={slot.key}>
          <div class="logo-slot__head">
            <span class="logo-slot__label">
              {slot.label}
              {slot.required && <span class="req">*</span>}
            </span>
            <span class="logo-slot__hint">{slot.hint}</span>
          </div>
          <div class={`logo-slot__drop ${url ? 'has-image' : ''}`}>
            <img src={url || undefined} alt={`Logo ${slot.label}`} class="logo-slot__img" hidden={!url || undefined} />
            <div class="logo-slot__empty" hidden={!!url || undefined}>
              <span class="logo-slot__plus">+</span>
              <span class="logo-slot__cta">Ablegen oder klicken</span>
              <span class="logo-slot__fmt">SVG · PNG</span>
            </div>
            <input type="file" class="logo-slot__input" accept="image/svg+xml,image/png,image/jpeg" data-key={slot.key} />
          </div>
          <div class="logo-slot__actions" hidden={!url || undefined}>
            <button class="logo-slot__btn" data-action="replace" data-key={slot.key} type="button">Ersetzen</button>
            <button class="logo-slot__btn logo-slot__btn--del" data-action="delete" data-key={slot.key} type="button">Entfernen</button>
          </div>
        </div>
      );
    })}
  </div>

</BrandSection>

<style>
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }
  .logo-slot { display: flex; flex-direction: column; gap: 8px; }
  .logo-slot__head { display: flex; flex-direction: column; gap: 2px; }
  .logo-slot__label {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.1em; color: var(--ink); font-weight: 500;
    display: flex; align-items: center; gap: 4px;
  }
  .req { color: var(--pink); }
  .logo-slot__hint {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.06em; color: var(--ink-muted);
  }
  .logo-slot__drop {
    position: relative; aspect-ratio: 16/10;
    background: var(--surface); border: 1px dashed var(--border-medium);
    border-radius: var(--r-sm);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 200ms ease; overflow: hidden;
  }
  .logo-slot__drop:hover { background: var(--te-yellow-soft); border-color: var(--ink); }
  .logo-slot__drop.has-image { border-style: solid; border-color: var(--sage); }
  .logo-slot__img { max-width: 80%; max-height: 80%; object-fit: contain; }
  .logo-slot__empty {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .logo-slot__plus { font-size: 22px; font-weight: 300; color: var(--ink-faint); line-height: 1; }
  .logo-slot__cta { font-family: 'Space Grotesk', sans-serif; font-size: 11px; color: var(--ink-soft); }
  .logo-slot__fmt {
    font-family: 'JetBrains Mono', monospace; font-size: 8px;
    letter-spacing: 0.14em; color: var(--ink-faint); text-transform: uppercase;
  }
  .logo-slot__input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .logo-slot__actions { display: flex; gap: 6px; }
  .logo-slot__actions[hidden] { display: none !important; }
  .logo-slot__empty[hidden] { display: none !important; }
  .logo-slot__btn {
    flex: 1; padding: 6px 10px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-sm); cursor: pointer; transition: all 150ms ease;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.08em; color: var(--ink-soft);
  }
  .logo-slot__btn:hover { background: var(--te-yellow-soft); color: var(--ink); }
  .logo-slot__btn--del:hover { background: var(--burgund-soft); color: var(--burgund); border-color: var(--burgund); }

</style>

<script>
  // Logo Upload
  document.querySelectorAll<HTMLInputElement>('.logo-slot__input').forEach(input => {
    input.addEventListener('change', async () => {
      const file = input.files?.[0];
      if (!file) return;
      const key = input.dataset.key!;
      const drop = input.closest('.logo-slot__drop') as HTMLElement;

      // Optimistic preview — toggle existing elements (kein innerHTML, kein Scope-Bug)
      const reader = new FileReader();
      reader.onload = () => {
        const img = drop.querySelector<HTMLImageElement>('.logo-slot__img')!;
        img.src = reader.result as string;
        img.hidden = false;
        const empty = drop.querySelector<HTMLElement>('.logo-slot__empty');
        if (empty) empty.hidden = true;
        drop.classList.add('has-image');
      };
      reader.readAsDataURL(file);

      const fd = new FormData();
      fd.append('key', key);
      fd.append('file', file);

      const res = await fetch('/api/branding/upload-logo', { method: 'POST', body: fd });
      const json = await res.json();
      if (!res.ok) { alert(`Upload fehlgeschlagen: ${json.error}`); return; }

      // Live-Preview im Phone updaten
      const phoneLogo = document.querySelector<HTMLImageElement>('#brandPhoneScreen .gate-hero-logo');
      const phoneFallback = document.querySelector<HTMLElement>('#brandPhoneScreen .gate-hero-name-fallback');
      if (key === 'logo_primary') {
        if (phoneLogo) { phoneLogo.src = json.url; phoneLogo.hidden = false; }
        if (phoneFallback) phoneFallback.hidden = true;
      } else if (key === 'logo_dark') {
        if (phoneLogo) { phoneLogo.src = json.url; phoneLogo.classList.remove('gate-hero-logo--invert'); }
      }

      // Buttons sind immer im HTML — einfach einblenden
      const slot = input.closest('.logo-slot') as HTMLElement;
      const actions = slot.querySelector<HTMLElement>('.logo-slot__actions');
      if (actions) {
        actions.hidden = false;
        actions.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(b => b.dataset.key = key);
      }
    });
  });

  function bindActionButtons(container: HTMLElement) {
    container.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const key = btn.dataset.key!;
        const action = btn.dataset.action!;
        const slot = btn.closest('.logo-slot') as HTMLElement;
        const drop = slot.querySelector('.logo-slot__drop') as HTMLElement;

        if (action === 'replace') {
          const input = slot.querySelector<HTMLInputElement>('.logo-slot__input');
          input?.click();
        } else if (action === 'delete') {
          (window as any).__brandConfirm('Logo wirklich entfernen?', async () => {
            const fd = new FormData();
            fd.append('key', key);
            fd.append('delete', 'true');
            const res = await fetch('/api/branding/upload-logo', { method: 'POST', body: fd });
            if (res.ok) {
              const img = drop.querySelector<HTMLImageElement>('.logo-slot__img');
              if (img) { img.src = ''; img.hidden = true; }
              const empty = drop.querySelector<HTMLElement>('.logo-slot__empty');
              if (empty) empty.hidden = false;
              drop.classList.remove('has-image');
              const actions = slot.querySelector<HTMLElement>('.logo-slot__actions');
              if (actions) actions.hidden = true;
              // Live-Preview zurücksetzen
              const phoneLogo = document.querySelector<HTMLImageElement>('#brandPhoneScreen .gate-hero-logo');
              const phoneFallback = document.querySelector<HTMLElement>('#brandPhoneScreen .gate-hero-name-fallback');
              if (key === 'logo_primary' && phoneLogo) {
                phoneLogo.hidden = true;
                if (phoneFallback) phoneFallback.hidden = false;
              }
            }
          });
        }
      });
    });
  }
  document.querySelectorAll<HTMLElement>('.logo-slot').forEach(slot => bindActionButtons(slot));

</script>
