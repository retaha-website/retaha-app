---
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props {
  branding: BrandingData;
  hotelName: string;
  demoUrl?: string | null;
}
const { demoUrl } = Astro.props;
---

<aside class="brand-preview">
  <div class="brand-preview__head">
    <span class="brand-preview__eyebrow">— Live-Vorschau —</span>
    <h3 class="brand-preview__title">Deine Marke</h3>
  </div>

  <!-- Phone Shell -->
  <div class="brand-preview__phone">
    <div class="brand-preview__notch"></div>
    <div class="brand-preview__screen" id="brandPhoneScreen">
      {demoUrl ? (
        <iframe
          class="brand-preview__iframe"
          src={demoUrl}
          title="Gäste-App Vorschau"
          sandbox="allow-scripts allow-same-origin allow-forms"
          loading="lazy"
          scrolling="no"
        ></iframe>
      ) : (
        <div class="brand-preview__placeholder">
          <span>Vorschau wird vorbereitet…</span>
        </div>
      )}
    </div>
  </div>

  <button class="brand-preview__link" id="open-guest-preview" type="button">
    → In Gäste-App öffnen
    <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M6 3l5 5-5 5"/>
    </svg>
  </button>
</aside>

<script>
  document.getElementById('open-guest-preview')?.addEventListener('click', async () => {
    const btn = document.getElementById('open-guest-preview') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const res = await fetch('/api/admin/preview-url');
      const data = await res.json();
      if (data?.url) {
        window.open(data.url, '_retaha_preview');
      }
    } catch {
      window.open('/gast-vorschau', '_retaha_preview');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '→ In Gäste-App öffnen <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 3l5 5-5 5"/></svg>';
    }
  });
</script>

<style>
  .brand-preview {
    display: flex; flex-direction: column; gap: 20px;
  }
  .brand-preview__head { display: flex; flex-direction: column; gap: 4px; }
  .brand-preview__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted);
  }
  .brand-preview__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 500;
    color: var(--ink); margin: 0;
  }
  .brand-preview__phone {
    width: 100%; max-width: 260px; aspect-ratio: 9/19;
    background: #0A0A0A; border-radius: 28px;
    position: relative; margin: 0 auto;
    box-shadow: 0 24px 48px rgba(10,10,10,0.18);
    overflow: hidden;
  }
  .brand-preview__notch {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    width: 64px; height: 16px; background: #0A0A0A; border-radius: 8px; z-index: 10;
  }
  .brand-preview__screen {
    position: absolute;
    inset: 10px;
    border-radius: 20px;
    overflow: hidden;
    background: #FAFAF8;
  }

  /* iframe: wird in voller mobiler Breite gerendert, dann auf 60% skaliert */
  .brand-preview__iframe {
    position: absolute;
    top: 0; left: 0;
    width: calc(100% / 0.58);
    height: calc(100% / 0.58);
    transform: scale(0.58);
    transform-origin: top left;
    border: none;
    pointer-events: none;
  }

  .brand-preview__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.1em; color: var(--ink-muted);
  }

  .brand-preview__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); text-decoration: none; cursor: pointer; width: 100%;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .brand-preview__link:hover:not(:disabled) { background: var(--te-yellow-soft); }
  .brand-preview__link:disabled { opacity: 0.5; cursor: wait; }
</style>
