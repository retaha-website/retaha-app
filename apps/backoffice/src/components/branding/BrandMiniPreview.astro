---
import GuestPhoneView from '@retaha/ui-guest/GuestPhoneView';
import type { GuestTheme } from '@retaha/ui-guest/types';
import { mapThemeName } from '@retaha/ui-guest/types';
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props { branding: BrandingData; hotelName: string; }
const { branding, hotelName } = Astro.props;

const theme: GuestTheme = {
  primary:        branding.brand_primary   ?? '#FF4A82',
  secondary:      branding.brand_secondary ?? undefined,
  themeName:      (branding.brand_theme    ?? 'coffee') as GuestTheme['themeName'],
  guestThemeName: mapThemeName(branding.brand_theme ?? 'coffee'),
  designIdentity: branding.design_identity ?? 'classic',
  logoUrl:        branding.logo_primary    ?? null,
  logoDarkUrl:    branding.logo_dark       ?? null,
  hotelName,
  eveName:        'Eve',
};
---

<aside class="brand-preview">
  <div class="brand-preview__head">
    <span class="brand-preview__eyebrow">— Live-Vorschau —</span>
    <h3 class="brand-preview__title">Deine Marke</h3>
  </div>

  <!-- Phone Shell -->
  <div class="brand-preview__phone">
    <div class="brand-preview__notch"></div>
    <div class="brand-preview__screen" id="brandPhoneScreen">
      <GuestPhoneView theme={theme} previewMode={true} />
    </div>
  </div>

  <a href="/gast-vorschau" class="brand-preview__link">
    → Vollständige Gast-Vorschau
    <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M6 3l5 5-5 5"/>
    </svg>
  </a>
</aside>

<script>
  // Live-Update: Brand-Color → --theme-accent im Phone
  document.querySelectorAll<HTMLInputElement>('[data-swatch]').forEach(input => {
    if (input.id !== 'brand-primary') return;
    input.addEventListener('input', () => {
      const phone = document.getElementById('brandPhoneScreen');
      if (phone && /^#[0-9A-Fa-f]{6}$/.test(input.value)) {
        phone.style.setProperty('--theme-accent', input.value);
        phone.style.setProperty('--theme-accent-hover', input.value);
      }
    });
  });
</script>

<style>
  .brand-preview {
    position: sticky; top: 100px; align-self: start;
    display: flex; flex-direction: column; gap: 20px;
  }
  .brand-preview__head { display: flex; flex-direction: column; gap: 4px; }
  .brand-preview__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted);
  }
  .brand-preview__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 500;
    color: var(--ink); margin: 0;
  }
  .brand-preview__phone {
    width: 100%; max-width: 260px; aspect-ratio: 9/19;
    background: #0A0A0A; border-radius: 28px; padding: 10px;
    position: relative; margin: 0 auto;
    box-shadow: 0 24px 48px rgba(10,10,10,0.18);
  }
  .brand-preview__notch {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    width: 64px; height: 16px; background: #0A0A0A; border-radius: 8px; z-index: 10;
  }
  .brand-preview__screen {
    width: 100%; height: 100%;
    border-radius: 20px; overflow: hidden;
  }
  .brand-preview__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); text-decoration: none;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .brand-preview__link:hover { background: var(--te-yellow-soft); }
</style>
