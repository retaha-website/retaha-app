---
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props { branding: BrandingData; hotelName: string; }
const { branding, hotelName } = Astro.props;

const primary = branding.brand_primary ?? '#FF4A82';
const logo    = branding.logo_primary ?? null;
---

<aside class="brand-preview">
  <div class="brand-preview__head">
    <span class="brand-preview__eyebrow">— Live-Vorschau —</span>
    <h3 class="brand-preview__title">Deine Marke</h3>
  </div>

  <div class="brand-preview__phone">
    <div class="brand-preview__notch"></div>
    <div class="brand-preview__screen">

      <!-- Status Bar -->
      <div class="bp-statusbar">
        <span>9:41</span>
        <span class="bp-statusbar__icons">▲ ◻</span>
      </div>

      <!-- Logo / Hotel-Name -->
      <div class="bp-header">
        <img id="previewLogo" src={logo ?? ''} alt={hotelName}
          class="bp-header__logo" style={logo ? '' : 'display:none'} />
        <span id="previewName" class="bp-header__name"
          style={logo ? 'display:none' : ''}>{hotelName}</span>
      </div>

      <!-- Hero-Card (Action-Card-Vorschau) -->
      <div class="bp-hero" id="previewHero" style={`background:${primary}18`}>
        <span class="bp-hero__eyebrow">— Empfang —</span>
        <p class="bp-hero__title">Check-in starten</p>
        <p class="bp-hero__desc">Schlüssel in 2 Minuten bereit.</p>
        <button class="bp-hero__cta" id="previewCta" style={`background:${primary}`} type="button">
          Jetzt einchecken
        </button>
      </div>

      <!-- Mini-Module-Row -->
      <div class="bp-modules">
        <div class="bp-mod"><span class="bp-mod__icon">💬</span><span>Eve</span></div>
        <div class="bp-mod"><span class="bp-mod__icon">📍</span><span>Tipps</span></div>
        <div class="bp-mod"><span class="bp-mod__icon">🛎</span><span>Service</span></div>
      </div>

      <!-- Bottom Nav -->
      <nav class="bp-tabs">
        <div class="bp-tab bp-tab--active">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M3 12L12 3l9 9"/><path d="M5 10v10h5v-6h4v6h5V10"/>
          </svg>
          <span>Start</span>
        </div>
        <div class="bp-tab">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          <span>Eve</span>
        </div>
        <div class="bp-tab">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
          <span>Tipps</span>
        </div>
        <div class="bp-tab">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <span>Service</span>
        </div>
      </nav>

    </div>
  </div>

  <a href="/gast-vorschau" class="brand-preview__link">
    → Vollständige Gast-Vorschau
    <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M6 3l5 5-5 5"/>
    </svg>
  </a>
</aside>

<style>
  .brand-preview {
    position: sticky; top: 100px; align-self: start;
    display: flex; flex-direction: column; gap: 20px;
  }
  .brand-preview__head { display: flex; flex-direction: column; gap: 4px; }
  .brand-preview__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted);
  }
  .brand-preview__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 500;
    color: var(--ink); margin: 0;
  }

  /* Phone Shell */
  .brand-preview__phone {
    width: 100%; max-width: 260px; aspect-ratio: 9/19;
    background: #0A0A0A; border-radius: 28px; padding: 10px;
    position: relative; margin: 0 auto;
    box-shadow: 0 24px 48px rgba(10,10,10,0.18);
  }
  .brand-preview__notch {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    width: 64px; height: 16px; background: #0A0A0A; border-radius: 8px; z-index: 10;
  }
  .brand-preview__screen {
    width: 100%; height: 100%; background: #FAFAF8; border-radius: 20px;
    overflow: hidden; display: flex; flex-direction: column;
  }

  /* Status Bar */
  .bp-statusbar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 14px 4px;
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    color: #0A0A0A; font-weight: 500; flex-shrink: 0;
  }
  .bp-statusbar__icons { opacity: 0.5; }

  /* Logo/Name Header */
  .bp-header {
    padding: 10px 14px 8px;
    display: flex; justify-content: center; align-items: center;
    flex-shrink: 0; min-height: 44px;
  }
  .bp-header__logo { max-width: 80px; max-height: 24px; object-fit: contain; }
  .bp-header__name {
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600;
    color: #0A0A0A; text-align: center;
  }

  /* Hero Card */
  .bp-hero {
    margin: 0 10px; border-radius: 14px; padding: 14px 12px;
    flex-shrink: 0;
  }
  .bp-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 7px;
    letter-spacing: 0.14em; color: rgba(10,10,10,0.45); text-transform: uppercase;
    display: block; margin-bottom: 6px;
  }
  .bp-hero__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 600;
    color: #0A0A0A; margin: 0 0 4px; line-height: 1.2;
  }
  .bp-hero__desc {
    font-family: 'Space Grotesk', sans-serif; font-size: 10px;
    color: rgba(10,10,10,0.55); margin: 0 0 10px;
  }
  .bp-hero__cta {
    display: block; width: 100%;
    padding: 8px 10px; color: white; border: none;
    border-radius: 8px; font-family: 'JetBrains Mono', monospace;
    font-size: 8px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; cursor: default; transition: background 200ms;
  }

  /* Module Row */
  .bp-modules {
    display: flex; gap: 6px; padding: 10px 10px 4px;
    flex-shrink: 0;
  }
  .bp-mod {
    flex: 1; background: white; border-radius: 10px;
    padding: 8px 4px; display: flex; flex-direction: column;
    align-items: center; gap: 4px;
    border: 1px solid rgba(10,10,10,0.06);
  }
  .bp-mod__icon { font-size: 14px; }
  .bp-mod span:last-child {
    font-family: 'JetBrains Mono', monospace; font-size: 7px;
    color: rgba(10,10,10,0.5); letter-spacing: 0.04em;
  }

  /* Bottom Tabs */
  .bp-tabs {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(10,10,10,0.07);
    padding: 6px 0 12px;
    background: white; margin-top: auto; flex-shrink: 0;
  }
  .bp-tab {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    padding: 4px; color: rgba(10,10,10,0.3);
  }
  .bp-tab--active { color: #0A0A0A; }
  .bp-tab span {
    font-family: 'JetBrains Mono', monospace; font-size: 7px;
    letter-spacing: 0.06em; text-transform: uppercase;
  }

  /* Link below phone */
  .brand-preview__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); text-decoration: none;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .brand-preview__link:hover { background: var(--te-yellow-soft); }
</style>
