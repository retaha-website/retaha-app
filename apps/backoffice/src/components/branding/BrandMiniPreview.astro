---
import BauhausPreview from './previews/BauhausPreview.astro';
import EditorialPreview from './previews/EditorialPreview.astro';
import MaisonPreview from './previews/MaisonPreview.astro';
import type { BrandingData } from '@retaha/auth';
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props { branding: BrandingData; hotelName: string; lang: LanguageCode; }
const { branding, hotelName, lang } = Astro.props;
const brandPrimary = branding.brand_primary ?? null;

const raw = branding.design_identity ?? 'bauhaus';
const active = ['bauhaus', 'editorial', 'maison'].includes(raw) ? raw : 'bauhaus';
---

<aside
  class="brand-preview"
  x-data={`{ theme: '${active}' }`}
  x-on:brand-theme-selected.window="theme = $event.detail.theme"
>
  <div class="brand-preview__head">
    <span class="brand-preview__eyebrow">{bt('brand.preview.eyebrow', lang)}</span>
    <h3
      class="brand-preview__title"
      x-text="theme === 'bauhaus' ? 'Bauhaus' : theme === 'editorial' ? 'Editorial' : 'Maison'"
    >{bt('brand.preview.title', lang)}</h3>
  </div>

  <!-- Skaliertes Phone-Preview -->
  <div class="bp-outer">
    <div class="bp-inner">
      <div x-show="theme === 'bauhaus'">
        <BauhausPreview hotelName={hotelName} brandPrimary={brandPrimary} />
      </div>
      <div x-show="theme === 'editorial'">
        <EditorialPreview hotelName={hotelName} brandPrimary={brandPrimary} />
      </div>
      <div x-show="theme === 'maison'">
        <MaisonPreview hotelName={hotelName} brandPrimary={brandPrimary} />
      </div>
    </div>
  </div>

  <button class="brand-preview__link" id="open-guest-preview" type="button">
    {bt('brand.preview.openguest', lang)}
    <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M6 3l5 5-5 5"/>
    </svg>
  </button>
</aside>

<script>
  const T = JSON.parse(document.getElementById('brand-i18n')?.textContent || '{}');
  // Live-Update: Brand-Color → Preview (color-change events from ColorsSection)
  document.querySelectorAll<HTMLInputElement>('[data-swatch]').forEach(input => {
    if (input.id !== 'brand-primary') return;
    input.addEventListener('input', () => {
      // Future: CSS-var injection into preview if needed
    });
  });

  // Vorschau-Button: Fenster sofort öffnen (Safari-Popup-Fix), dann URL eintragen
  document.getElementById('open-guest-preview')?.addEventListener('click', async () => {
    const btn = document.getElementById('open-guest-preview') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '…';
    // Fenster synchron im Click-Handler öffnen — Safari blockiert window.open nach await
    const win = window.open('', '_retaha_preview');
    try {
      const res = await fetch('/api/admin/preview-url');
      const data = await res.json();
      if (win) win.location.href = data?.url ?? 'https://app.retaha.de/gast-vorschau';
    } catch {
      if (win) win.location.href = 'https://app.retaha.de/gast-vorschau';
    } finally {
      btn.disabled = false;
      btn.innerHTML = T.openGuest + ' <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 3l5 5-5 5"/></svg>';
    }
  });
</script>

<style>
  .brand-preview { display: flex; flex-direction: column; gap: 16px; }

  .brand-preview__head { display: flex; flex-direction: column; gap: 4px; }
  .brand-preview__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted);
  }
  .brand-preview__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 500;
    color: var(--ink); margin: 0;
  }

  /* Scale phone 390×844 → ~300×650 (scale 0.77) */
  .bp-outer {
    width: 300px;
    height: 650px;
    overflow: hidden;
    position: relative;
    border-radius: 40px;
    margin: 4px auto 16px;
    /* phone bezel — box-shadow nicht von overflow:hidden geclippt */
    box-shadow:
      0 0 0 8px #0A0A0A,
      0 0 0 10px #2A2A2A,
      0 20px 48px -8px rgba(0,0,0,0.38);
  }
  .bp-inner {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 844px;
    transform: scale(0.7692);
    transform-origin: top left;
    pointer-events: none;
  }
  .bp-inner > div {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 844px;
  }

  .brand-preview__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); text-decoration: none; cursor: pointer; width: 100%;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .brand-preview__link:hover:not(:disabled) { background: var(--bg-deep, #F5F4F2); }
  .brand-preview__link:disabled { opacity: 0.5; cursor: wait; }
</style>
