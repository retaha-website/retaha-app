---
import type { BrandingData } from '../../lib/branding/get-branding';

interface Props { branding: BrandingData; hotelName: string; }
const { branding, hotelName } = Astro.props;

const primary = branding.brand_primary ?? '#FF4A82';
const logo    = branding.logo_primary ?? null;
---

<aside class="brand-preview">
  <div class="brand-preview__head">
    <span class="brand-preview__eyebrow">— Live-Vorschau —</span>
    <h3 class="brand-preview__title">Deine Marke</h3>
  </div>

  <div class="brand-preview__phone">
    <div class="brand-preview__notch"></div>
    <div class="brand-preview__screen">
      <div class="brand-preview__phone-header">
        {logo ? (
          <img id="previewLogo" src={logo} alt={hotelName} class="brand-preview__logo" />
        ) : (
          <span id="previewName" class="brand-preview__name">{hotelName}</span>
        )}
        {logo && <span id="previewName" class="brand-preview__name" style="display:none">{hotelName}</span>}
      </div>
      <div class="brand-preview__content">
        <span class="brand-preview__welcome">Willkommen</span>
        <h4 class="brand-preview__headline">Schön, dass du da bist<span style="color:var(--pink)">.</span></h4>
        <button class="brand-preview__cta" id="previewCta" style={`background:${primary}`} type="button">
          Check-in starten
        </button>
      </div>
    </div>
  </div>

  <a href="/gast-vorschau" class="brand-preview__link">
    → Vollständige Gast-Vorschau
    <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M6 3l5 5-5 5"/>
    </svg>
  </a>
</aside>

<style>
  .brand-preview {
    position: sticky; top: 100px; align-self: start;
    display: flex; flex-direction: column; gap: 20px;
  }
  .brand-preview__head { display: flex; flex-direction: column; gap: 4px; }
  .brand-preview__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted);
  }
  .brand-preview__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 500;
    color: var(--ink); margin: 0;
  }
  .brand-preview__phone {
    width: 100%; max-width: 240px; aspect-ratio: 9/19;
    background: #0A0A0A; border-radius: 24px; padding: 10px;
    position: relative; margin: 0 auto;
    box-shadow: 0 20px 40px rgba(10,10,10,0.15);
  }
  .brand-preview__notch {
    position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
    width: 60px; height: 14px; background: #0A0A0A; border-radius: 7px; z-index: 10;
  }
  .brand-preview__screen {
    width: 100%; height: 100%; background: white; border-radius: 16px;
    overflow: hidden; display: flex; flex-direction: column;
  }
  .brand-preview__phone-header {
    padding: 28px 16px 12px; display: flex; justify-content: center; align-items: center;
    min-height: 60px;
  }
  .brand-preview__logo { max-width: 90px; max-height: 28px; object-fit: contain; }
  .brand-preview__name {
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 500;
    color: #0A0A0A; text-align: center;
  }
  .brand-preview__content {
    flex: 1; padding: 12px 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .brand-preview__welcome {
    font-family: 'JetBrains Mono', monospace; font-size: 8px;
    letter-spacing: 0.14em; color: rgba(10,10,10,0.4); text-transform: uppercase;
  }
  .brand-preview__headline {
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500;
    line-height: 1.2; color: #0A0A0A; margin: 0;
  }
  .brand-preview__cta {
    margin-top: auto; padding: 8px 12px; color: white; border: none;
    border-radius: 8px; font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.1em; cursor: default;
    text-transform: uppercase; transition: background 200ms;
  }
  .brand-preview__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); text-decoration: none;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .brand-preview__link:hover { background: var(--te-yellow-soft); }
</style>
