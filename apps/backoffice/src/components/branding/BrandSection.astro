---
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props {
  title: string;
  num: string;
  optional?: boolean;
  lang: LanguageCode;
}
const { title, num, optional = false, lang } = Astro.props;
---

<section class="brand-section">
  <div class="brand-section__head">
    <div class="brand-section__l">
      <span class="brand-section__dot"></span>
      <b class="brand-section__title">
        {title}
        {optional && <span class="brand-section__opt">{bt('brand.optional', lang)}</span>}
      </b>
    </div>
    <span class="brand-section__num">{num}</span>
  </div>
  <div class="brand-section__body">
    <slot />
  </div>
</section>

<style>
  .brand-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    overflow: hidden;
  }

  .brand-section__head {
    display: flex; align-items: center; justify-content: space-between;
    margin: -14px -16px 14px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }
  .brand-section__l { display: flex; align-items: center; gap: 10px; }
  .brand-section__dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--petrol, #14616E); flex-shrink: 0;
  }
  .brand-section__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; font-weight: 600; color: var(--ink);
  }
  .brand-section__opt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 400;
    background: var(--bg-deep); padding: 3px 8px;
    border-radius: var(--r-sm); margin-left: 8px;
  }
  .brand-section__num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.2em;
    color: var(--ink-muted); text-transform: uppercase;
  }
  .brand-section__body { display: flex; flex-direction: column; gap: 20px; padding-bottom: 4px; }
</style>
