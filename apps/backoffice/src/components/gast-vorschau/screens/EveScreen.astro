---
---
<div class="eve-screen">
  <div class="eve-screen__head">
    <div class="eve-screen__avatar">E</div>
    <div>
      <p class="eve-screen__name">eve · concierge</p>
      <p class="eve-screen__status">● online</p>
    </div>
  </div>
  <div class="eve-screen__messages">
    <div class="eve-msg eve-msg--bot">
      <p>hallo! wie kann ich dir helfen?</p>
    </div>
    <div class="eve-msg eve-msg--bot">
      <p>frag mich nach restaurant-tipps, öffnungszeiten oder allem rund ums hotel.</p>
    </div>
    <div class="eve-msg eve-msg--user">
      <p>gibt es einen pool?</p>
    </div>
    <div class="eve-msg eve-msg--bot">
      <p>ja! der pool ist täglich 7–22 uhr geöffnet. handtücher liegen bereit.</p>
    </div>
  </div>
  <div class="eve-screen__input">
    <input type="text" placeholder="frag eve etwas..." readonly />
  </div>
</div>

<style>
  .eve-screen { display: flex; flex-direction: column; height: 100%; gap: 0; }
  .eve-screen__head {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 0; border-bottom: 1px solid rgba(10,10,10,0.08);
    margin-bottom: 16px;
  }
  .eve-screen__avatar {
    width: 32px; height: 32px; background: #0A0A0A; color: white;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 500;
  }
  .eve-screen__name { font-size: 13px; font-weight: 500; }
  .eve-screen__status { font-size: 11px; color: #5C9070; }
  .eve-screen__messages { flex: 1; display: flex; flex-direction: column; gap: 10px; overflow: hidden; }
  .eve-msg { max-width: 85%; }
  .eve-msg p { padding: 10px 13px; border-radius: 14px; font-size: 13px; line-height: 1.45; }
  .eve-msg--bot p { background: #F0EFEA; color: #0A0A0A; border-radius: 4px 14px 14px 14px; }
  .eve-msg--user { align-self: flex-end; }
  .eve-msg--user p { background: #0A0A0A; color: white; border-radius: 14px 4px 14px 14px; }
  .eve-screen__input {
    margin-top: 16px; padding-top: 12px; border-top: 1px solid rgba(10,10,10,0.08);
  }
  .eve-screen__input input {
    width: 100%; padding: 10px 14px;
    border: 1px solid rgba(10,10,10,0.12); border-radius: 20px;
    font-size: 13px; background: #F5F5F3; outline: none;
    font-family: inherit; color: rgba(10,10,10,0.45);
  }
</style>
