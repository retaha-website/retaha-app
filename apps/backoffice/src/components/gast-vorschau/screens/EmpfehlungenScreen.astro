---
const places = [
  { name: 'Café am Marktplatz', cat: 'Café', dist: '250m', rating: 4.6 },
  { name: 'Trattoria Bella', cat: 'Italienisch', dist: '400m', rating: 4.5 },
  { name: 'Stadtpark', cat: 'Park', dist: '550m', rating: 4.8 },
];
---

<div class="emp-screen">
  <p class="emp-screen__title">In der Nähe</p>
  {places.map(p => (
    <div class="emp-card">
      <div class="emp-card__img"></div>
      <div class="emp-card__body">
        <p class="emp-card__name">{p.name}</p>
        <p class="emp-card__meta">{p.cat} · {p.dist}</p>
        <p class="emp-card__rating">{'★'.repeat(Math.round(p.rating))} {p.rating}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .emp-screen { display: flex; flex-direction: column; gap: 14px; }
  .emp-screen__title { font-size: 16px; font-weight: 500; margin-bottom: 4px; }
  .emp-card {
    display: flex; gap: 12px; align-items: center;
    padding: 12px; background: #F5F1E8; border-radius: 12px;
  }
  .emp-card__img {
    width: 52px; height: 52px; background: rgba(10,10,10,0.08);
    border-radius: 8px; flex-shrink: 0;
  }
  .emp-card__name { font-size: 13px; font-weight: 500; margin-bottom: 3px; }
  .emp-card__meta { font-size: 11px; color: rgba(10,10,10,0.5); margin-bottom: 3px; }
  .emp-card__rating { font-size: 11px; color: #C8973F; }
</style>
