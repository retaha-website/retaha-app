---
const services = [
  { icon: '🛏', label: 'Zimmerservice', sub: '24h verfügbar' },
  { icon: '🧺', label: 'Wäsche', sub: 'bis 10 Uhr abgeben' },
  { icon: '🚗', label: 'Taxi', sub: 'sofort · ~5 min' },
  { icon: '💆', label: 'Spa-Termin', sub: 'nach Verfügbarkeit' },
];
---

<div class="svc-screen">
  <p class="svc-screen__title">Service</p>
  <p class="svc-screen__sub">was kann ich für dich tun?</p>
  <div class="svc-grid">
    {services.map(s => (
      <button class="svc-card" type="button">
        <span class="svc-card__icon">{s.icon}</span>
        <span class="svc-card__label">{s.label}</span>
        <span class="svc-card__sub">{s.sub}</span>
      </button>
    ))}
  </div>
</div>

<style>
  .svc-screen { display: flex; flex-direction: column; gap: 16px; }
  .svc-screen__title { font-size: 16px; font-weight: 500; }
  .svc-screen__sub { font-size: 13px; color: rgba(10,10,10,0.5); margin-top: -10px; }
  .svc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .svc-card {
    display: flex; flex-direction: column; align-items: flex-start; gap: 6px;
    padding: 16px 14px;
    background: #F5F1E8; border: none; border-radius: 14px;
    cursor: pointer; text-align: left;
    transition: background 150ms ease;
  }
  .svc-card:hover { background: #EDE8DC; }
  .svc-card__icon { font-size: 22px; }
  .svc-card__label { font-size: 13px; font-weight: 500; color: #0A0A0A; }
  .svc-card__sub { font-size: 10px; color: rgba(10,10,10,0.5); }
</style>
