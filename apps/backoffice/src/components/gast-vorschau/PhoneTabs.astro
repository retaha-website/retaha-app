---
const tabs = [
  { key: 'home',         label: 'Start',   icon: 'home'    },
  { key: 'eve',          label: 'Eve',     icon: 'chat'    },
  { key: 'empfehlungen', label: 'Tipps',   icon: 'compass' },
  { key: 'service',      label: 'Service', icon: 'bell'    },
];
---

<nav class="phone-tabs" aria-label="App-Navigation">
  {tabs.map((tab, i) => (
    <button
      class:list={['phone-tab', { 'is-active': i === 0 }]}
      data-view={tab.key}
      data-module={tab.key !== 'home' ? tab.key : undefined}
      type="button"
      aria-label={tab.label}
    >
      <svg class="phone-tab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {tab.icon === 'home'    && <><path d="M3 12L12 3l9 9"/><path d="M5 10v10h5v-6h4v6h5V10"/></>}
        {tab.icon === 'chat'    && <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>}
        {tab.icon === 'compass' && <><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></>}
        {tab.icon === 'bell'    && <><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></>}
      </svg>
      <span class="phone-tab__label">{tab.label}</span>
    </button>
  ))}
</nav>

<style>
  .phone-tabs {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(10,10,10,0.08);
    padding: 8px 4px 28px;
    background: white;
    flex-shrink: 0;
  }
  .phone-tab {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    background: transparent; border: none;
    padding: 8px 4px; cursor: pointer;
    color: rgba(10,10,10,0.4); transition: color 150ms ease;
  }
  .phone-tab:hover:not(:disabled) { color: rgba(10,10,10,0.75); }
  .phone-tab.is-active { color: #0A0A0A; }
  .phone-tab:disabled { opacity: 0.3; cursor: not-allowed; }
  .phone-tab__icon { width: 22px; height: 22px; }
  .phone-tab__label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; }
</style>

<script>
  import { updateState, subscribe } from '../../lib/gast-vorschau/state';

  document.querySelectorAll<HTMLButtonElement>('.phone-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.disabled) return;
      const view = btn.dataset.view as any;
      if (!view) return;
      document.querySelectorAll('.phone-tab').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      updateState({ view });
    });
  });

  // Disable tabs for deactivated modules
  subscribe(state => {
    document.querySelectorAll<HTMLButtonElement>('.phone-tab[data-module]').forEach(btn => {
      const mod = btn.dataset.module as keyof typeof state.modules;
      btn.disabled = !state.modules[mod];
    });
  });
</script>
