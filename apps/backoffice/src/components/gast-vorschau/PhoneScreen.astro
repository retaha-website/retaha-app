---
import GuestPhoneView from '@retaha/ui-guest/GuestPhoneView';
import type { GuestTheme } from '@retaha/ui-guest/types';
import { getBranding } from '../../lib/branding/get-branding';
import { getUser, getUserHotels } from '@retaha/auth';
import { mapThemeName } from '@retaha/ui-guest/types';

const user  = await getUser(Astro.cookies, Astro.request);
const hotels = user ? await getUserHotels(Astro.cookies, Astro.request) : null;
const hotel  = hotels?.[0]?.hotel;
const branding = hotel ? await getBranding(Astro.cookies, Astro.request) : null;

const theme: GuestTheme = {
  primary:        branding?.brand_primary   ?? '#FF4A82',
  secondary:      branding?.brand_secondary ?? undefined,
  themeName:      (branding?.brand_theme    ?? 'coffee') as GuestTheme['themeName'],
  guestThemeName: mapThemeName(branding?.brand_theme ?? 'coffee'),
  designIdentity: branding?.design_identity ?? 'classic',
  logoUrl:        branding?.logo_primary    ?? null,
  logoDarkUrl:    branding?.logo_dark       ?? null,
  hotelName:      hotel?.name               ?? 'Hotel',
  eveName:        'Eve',
};
---

<GuestPhoneView
  theme={theme}
  previewMode={true}
/>

<script>
  import { subscribe, type PreviewState } from '../../lib/gast-vorschau/state';

  type ModuleKey = keyof PreviewState['modules'];

  // Label → module-key mapping for .ws-action tiles
  const ACTION_LABEL_MAP: Record<string, ModuleKey> = {
    'frühstück':  'breakfast',
    'eve':        'eve',
    'service':    'service',
    'tipps':      'empfehlungen',
    'konferenz':  'conference',
    'checkout':   'self_checkout',
  };

  // Tab text → module-key mapping for .ws-tab bottom tabs
  const TAB_TEXT_MAP: Record<string, ModuleKey> = {
    'eve':     'eve',
    'tipps':   'empfehlungen',
    'service': 'service',
  };

  subscribe(state => {
    // 1 — Willkommenstext
    document.querySelectorAll<HTMLElement>('[data-screen="home"] .gate-hero-sub').forEach(el => {
      el.textContent = state.welcomeText;
    });

    // 2 — Action-Tiles ein-/ausblenden
    document.querySelectorAll<HTMLElement>('.ws-action').forEach(tile => {
      const labelEl = tile.querySelector<HTMLElement>('.ws-action__label');
      if (!labelEl) return;
      const labelKey = labelEl.textContent?.trim().toLowerCase() ?? '';
      const moduleKey = ACTION_LABEL_MAP[labelKey];
      if (moduleKey) {
        const visible = state.modules[moduleKey];
        tile.style.display = visible ? '' : 'none';
      }
    });

    // 3 — Bottom-Tabs dimmen (nicht verstecken — sonst bricht das Layout)
    document.querySelectorAll<HTMLElement>('.ws-tab').forEach(tab => {
      const spanText = tab.querySelector('span')?.textContent?.trim().toLowerCase() ?? '';
      const moduleKey = TAB_TEXT_MAP[spanText];
      if (moduleKey) {
        tab.style.opacity = state.modules[moduleKey] ? '1' : '0.3';
        tab.style.pointerEvents = state.modules[moduleKey] ? '' : 'none';
      }
    });

    // 4 — Hero Slider
    document.querySelectorAll<HTMLElement>('.ws-slider').forEach(slider => {
      slider.style.display = state.modules.action_cards ? '' : 'none';
    });

    // 5 — Wallet-Pass (soft card falls vorhanden)
    document.querySelectorAll<HTMLElement>('.ws-wallet, [data-module="wallet"]').forEach(el => {
      el.style.display = state.modules.wallet ? '' : 'none';
    });
  });
</script>
