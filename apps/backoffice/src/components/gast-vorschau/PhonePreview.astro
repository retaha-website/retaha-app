---
import TagPicker from './TagPicker.astro';
import PhoneFrame from './PhoneFrame.astro';
import type { NfcTag } from '../../lib/gast-vorschau/demo-data';
interface Props { tags: NfcTag[] }
const { tags } = Astro.props;
---

<div class="phone-preview">
  <TagPicker tags={tags} />
  <PhoneFrame />
</div>

<style>
  .phone-preview {
    position: sticky; top: 80px;
    align-self: start;
    display: flex; flex-direction: column; gap: 16px; align-items: center;
  }
  @media (max-width: 1000px) { .phone-preview { position: relative; top: 0; } }
</style>
