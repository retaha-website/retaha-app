---
import PhoneScreen from './PhoneScreen.astro';
---

<div class="phone-frame" aria-label="Telefon-Vorschau">
  <div class="phone-frame__notch" aria-hidden="true"></div>
  <div class="phone-frame__screen-area">
    <PhoneScreen />
  </div>
  <div class="phone-frame__home-bar" aria-hidden="true"></div>
</div>

<style>
  .phone-frame {
    width: 360px;
    height: 740px;
    background: #0A0A0A;
    border-radius: 44px;
    padding: 14px;
    position: relative;
    box-shadow:
      0 32px 80px rgba(10,10,10,0.22),
      0 8px 24px rgba(10,10,10,0.1),
      inset 0 0 0 1.5px rgba(255,255,255,0.06);
  }
  :global([data-theme="dark"]) .phone-frame {
    background: #1C1C1E;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6), inset 0 0 0 1.5px rgba(255,255,255,0.08);
  }
  .phone-frame__notch {
    position: absolute; top: 18px; left: 50%;
    transform: translateX(-50%);
    width: 120px; height: 34px;
    background: #0A0A0A;
    border-radius: 17px; z-index: 10;
  }
  :global([data-theme="dark"]) .phone-frame__notch { background: #1C1C1E; }
  .phone-frame__screen-area {
    width: 100%; height: 100%;
    background: white; border-radius: 32px; overflow: hidden; position: relative;
  }
  .phone-frame__home-bar {
    position: absolute; bottom: 8px; left: 50%;
    transform: translateX(-50%);
    width: 120px; height: 5px;
    background: rgba(255,255,255,0.3); border-radius: 3px; z-index: 10;
  }
  @media (max-width: 480px) {
    .phone-frame { width: 300px; height: 615px; border-radius: 36px; }
  }
</style>
