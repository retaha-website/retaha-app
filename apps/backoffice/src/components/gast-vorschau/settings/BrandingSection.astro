---
const themes = [
  { key: 'coffee', label: 'Coffee', colors: ['#3E2723','#A1887F','#D7CCC8'] },
  { key: 'ocean',  label: 'Ocean',  colors: ['#0D3B66','#3E92CC','#A8DADC'] },
  { key: 'forest', label: 'Forest', colors: ['#1B4332','#52B788','#D8F3DC'] },
];
---

<section class="settings-section">
  <div class="settings-section__head">
    <span class="settings-section__title">— Branding —</span>
    <span class="settings-section__hint">aus den Einstellungen</span>
  </div>
  <div class="theme-picker">
    {themes.map((theme, i) => (
      <button class:list={['theme-card', { 'is-active': i === 0 }]} data-theme-key={theme.key} type="button" aria-pressed={i === 0 ? 'true' : 'false'}>
        <div class="theme-card__swatches">
          {theme.colors.map(c => <span class="theme-card__swatch" style={`background:${c}`}></span>)}
        </div>
        <span class="theme-card__label">{theme.label}</span>
        <span class="theme-card__check" aria-hidden="true">✓</span>
      </button>
    ))}
  </div>
</section>

<style>
  .settings-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 24px 28px;
  }
  .settings-section__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .settings-section__title { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; color: var(--ink); font-weight: 500; text-transform: uppercase; }
  .settings-section__hint { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted); }
  .theme-picker { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .theme-card {
    display: flex; flex-direction: column; gap: 10px; padding: 14px;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); cursor: pointer; position: relative;
    transition: all 200ms ease;
  }
  .theme-card:hover { background: var(--te-yellow-soft); border-color: var(--ink-faint); }
  .theme-card.is-active { background: var(--surface); border-color: var(--sage); box-shadow: 0 0 0 2px var(--sage-soft); }
  .theme-card__swatches { display: flex; gap: 4px; }
  .theme-card__swatch { flex: 1; height: 22px; border-radius: 4px; }
  .theme-card__label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink); }
  .theme-card__check {
    position: absolute; top: 8px; right: 8px;
    width: 18px; height: 18px; background: var(--sage); color: white;
    border-radius: 50%; display: none; align-items: center; justify-content: center; font-size: 11px;
  }
  .theme-card.is-active .theme-card__check { display: flex; }
</style>

<script>
  import { updateState } from '../../../lib/gast-vorschau/state';
  document.querySelectorAll<HTMLButtonElement>('.theme-card').forEach(card => {
    card.addEventListener('click', () => {
      const theme = card.dataset.themeKey as any;
      document.querySelectorAll('.theme-card').forEach(c => { c.classList.remove('is-active'); c.setAttribute('aria-pressed','false'); });
      card.classList.add('is-active'); card.setAttribute('aria-pressed','true');
      updateState({ branding: { theme } });
    });
  });
</script>
