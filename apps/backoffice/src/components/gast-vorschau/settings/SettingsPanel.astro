---
import WelcomeSection from './WelcomeSection.astro';
import LanguageSection from './LanguageSection.astro';
import BrandLinkCard from './BrandLinkCard.astro';
import ModulesSection from './ModulesSection.astro';
import ActionsSection from './ActionsSection.astro';
import type { NfcTag } from '../../../lib/gast-vorschau/demo-data';
interface Props { tags: NfcTag[]; hotelName?: string }
const { tags, hotelName = 'Ihr Hotel' } = Astro.props;

const tabDefs = [
  { key: 'module',     label: 'Module' },
  { key: 'sprachen',   label: 'Sprachen' },
  { key: 'branding',   label: 'Branding' },
  { key: 'hero',       label: 'Hero-Karten' },
  { key: 'aktionen',   label: 'Aktionen' },
] as const;
---

<aside
  class="settings-panel"
  x-data="{ tab: 'module' }"
>
  <!-- Settings-Bar -->
  <nav class="sp-tabs" aria-label="Einstellungs-Bereiche">
    {tabDefs.map(t => (
      <button
        class="sp-tab"
        :class={`{ 'sp-tab--active': tab === '${t.key}' }`}
        @click={`tab = '${t.key}'`}
        type="button"
        aria-pressed={t.key === 'module' ? 'true' : 'false'}
        :aria-pressed={`tab === '${t.key}' ? 'true' : 'false'`}
      >
        {t.label}
      </button>
    ))}
  </nav>

  <!-- MODULE -->
  <div x-show="tab === 'module'" x-cloak>
    <WelcomeSection hotelName={hotelName} />
    <div style="margin-top:16px">
      <ModulesSection />
    </div>
  </div>

  <!-- SPRACHEN -->
  <div x-show="tab === 'sprachen'" x-cloak>
    <LanguageSection />
  </div>

  <!-- BRANDING -->
  <div x-show="tab === 'branding'" x-cloak>
    <BrandLinkCard />
  </div>

  <!-- HERO-KARTEN -->
  <div x-show="tab === 'hero'" x-cloak>
    <section class="settings-section">
      <div class="settings-section__head">
        <span class="settings-section__title">— Hero-Karten —</span>
        <a href="/admin/action-cards" class="settings-section__link">→ Editor öffnen</a>
      </div>
      <p class="sp-hero-hint">
        Hero-Karten erscheinen als swipeable Slider auf dem Startscreen.
        Erstellen und bearbeiten im Action-Card-Editor.
      </p>
      <a href="/admin/action-cards" class="sp-hero-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M12 8v8M8 12h8"/>
        </svg>
        Action-Cards bearbeiten
      </a>
    </section>
  </div>

  <!-- AKTIONEN -->
  <div x-show="tab === 'aktionen'" x-cloak>
    <ActionsSection tags={tags} />
  </div>
</aside>

<style>
  .settings-panel { display: flex; flex-direction: column; gap: 16px; }

  /* Settings-Bar */
  .sp-tabs {
    display: flex; gap: 4px; flex-wrap: wrap;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r); padding: 6px;
  }
  .sp-tab {
    flex: 1; min-width: 0;
    padding: 8px 10px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-muted); background: transparent;
    border: 1px solid transparent; border-radius: var(--r-sm);
    cursor: pointer; white-space: nowrap;
    transition: all 180ms ease;
  }
  .sp-tab:hover { color: var(--ink); background: var(--surface); }
  .sp-tab--active {
    color: var(--ink); background: var(--surface);
    border-color: var(--border-medium);
    font-weight: 500;
  }

  /* Hero-Karten Tab */
  .sp-hero-hint {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--ink-muted); line-height: 1.6;
    letter-spacing: 0.03em; margin-bottom: 16px;
  }
  .sp-hero-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 16px;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); color: var(--ink);
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.08em; text-decoration: none;
    transition: all 180ms ease;
  }
  .sp-hero-btn:hover { background: var(--te-yellow-soft); border-color: var(--border-medium); }

  [x-cloak] { display: none !important; }
</style>
