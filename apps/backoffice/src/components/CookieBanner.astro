---
// Sprint Legal/DSGVO Phase 2 — Cookie-Banner (Bauhaus, mobile-first)
//
// Ehrlichkeit: aktuell setzt die App KEINE Tracking-Cookies — nur
// technisch notwendige (Stay-Session, Auth, Onboarding-Locale) plus 2
// funktionale localStorage-Flags (retaha_eve_seen, bell_last_seen_state).
// Banner kommuniziert das ehrlich, ist präventiv für spätere Analytics.
//
// Nicht-blockierend: floating unten, kein Modal-Overlay. DSGVO erlaubt
// das für rein technische Cookies — Nutzung der App ist OHNE Klick auf
// "akzeptieren" möglich.
//
// Persistenz: nach Consent localStorage `retaha_consent_v{POLICY}` setzen,
// Banner kommt erst wieder bei neuer Policy-Version.
//
// Props:
//   - stayToken?: string  Optional, für Server-Logging mit stay_id

interface Props {
  stayToken?: string;
  privacyHref?: string;
}
const { stayToken, privacyHref } = Astro.props;
// Phase 3 — wenn Token vorhanden, nested-Route für Hotel-Name-Auflösung;
// sonst Standalone-Page mit generischem Text
const resolvedPrivacyHref = privacyHref ?? (stayToken ? `/g/${stayToken}/datenschutz` : '/g/datenschutz');
const POLICY_VERSION = '2026-06-01';
---

<div
  id="cookie-banner"
  data-policy-version={POLICY_VERSION}
  data-stay-token={stayToken ?? ''}
  data-privacy-href={resolvedPrivacyHref}
  hidden
>
  <div class="cb-inner">
    <div class="cb-text">
      <p class="cb-eyebrow themed-eyebrow-flank">Privatsphäre</p>
      <p class="cb-body">
        Diese App nutzt <strong>technisch notwendige Cookies</strong> für deine Sitzung.
        Funktionale Speicherung (z.B. ob du <em>Eve</em> schon gesehen hast) verbessert dein Erlebnis.
        <strong>Wir tracken dich nicht.</strong>
        <a href={resolvedPrivacyHref} class="cb-link">Datenschutz</a>
      </p>
    </div>

    <div class="cb-actions" data-mode="compact">
      <button type="button" class="cb-btn cb-btn--ghost" data-consent="rejected">Nur notwendige</button>
      <button type="button" class="cb-btn cb-btn--primary" data-consent="all">Alle akzeptieren</button>
      <button type="button" class="cb-btn cb-btn--link" data-action="expand">Einstellungen ▾</button>
    </div>

    <div class="cb-settings" data-mode="expanded" hidden>
      <label class="cb-toggle">
        <input type="checkbox" checked disabled />
        <span class="cb-toggle-label">
          <strong>Notwendig</strong>
          <span class="cb-toggle-hint">Stay-Session, Auth, Spracheinstellung. Immer aktiv — die App funktioniert sonst nicht.</span>
        </span>
      </label>
      <label class="cb-toggle">
        <input type="checkbox" id="cb-functional" checked />
        <span class="cb-toggle-label">
          <strong>Funktional</strong>
          <span class="cb-toggle-hint">Anonyme Komfort-Flags (z.B. Eve-Welcome-Status). Kein Tracking, keine Personenbezug.</span>
        </span>
      </label>
      <label class="cb-toggle">
        <input type="checkbox" id="cb-analytics" />
        <span class="cb-toggle-label">
          <strong>Analyse</strong>
          <span class="cb-toggle-hint">Aktuell nicht aktiv. Wird hier ankündigbar wenn wir's je einführen.</span>
        </span>
      </label>
      <div class="cb-settings-actions">
        <button type="button" class="cb-btn cb-btn--primary" data-action="save-settings">Auswahl speichern</button>
      </div>
    </div>
  </div>
</div>

<style>
  #cookie-banner {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 90;
    background: var(--theme-bg-primary);
    border-top: 1px solid var(--theme-text-primary);
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.12);
    font-family: 'Space Grotesk', system-ui, sans-serif;
    color: var(--theme-text-primary);
  }
  .cb-inner {
    max-width: 920px;
    margin: 0 auto;
    padding: 20px 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  @media (min-width: 768px) {
    .cb-inner {
      flex-direction: row;
      align-items: center;
      gap: 24px;
    }
    .cb-text { flex: 1; }
  }

  .cb-eyebrow {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--theme-accent);
    margin: 0 0 6px;
  }
  .cb-body { font-size: 13px; line-height: 1.5; margin: 0; color: color-mix(in srgb, var(--theme-text-primary) .85, transparent); }
  .cb-body strong { color: var(--theme-text-primary); }
  .cb-body em { font-style: italic; color: var(--theme-accent); }
  .cb-link {
    color: var(--theme-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 4px;
  }

  .cb-actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .cb-actions[hidden] { display: none; }

  .cb-btn {
    padding: 9px 16px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--theme-text-primary);
    cursor: pointer;
    background: var(--theme-bg-primary);
    color: var(--theme-text-primary);
    transition: background 0.15s, color 0.15s;
    font-family: inherit;
  }
  .cb-btn:hover { background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary); }
  .cb-btn--primary { background: var(--theme-accent); color: var(--theme-bg-primary); border-color: var(--theme-accent); }
  .cb-btn--primary:hover { background: var(--theme-accent-hover); border-color: var(--theme-accent-hover); }
  .cb-btn--ghost { background: transparent; }
  .cb-btn--link {
    background: transparent;
    border-color: transparent;
    color: color-mix(in srgb, var(--theme-text-primary) .6, transparent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cb-btn--link:hover { background: transparent; color: var(--theme-text-primary); }

  .cb-settings { display: flex; flex-direction: column; gap: 12px; padding-top: 6px; }
  .cb-settings[hidden] { display: none; }

  .cb-toggle {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid var(--theme-border);
    cursor: pointer;
  }
  .cb-toggle input { margin-top: 3px; accent-color: var(--theme-accent); }
  .cb-toggle input:disabled { opacity: 0.5; }
  .cb-toggle-label { display: flex; flex-direction: column; gap: 2px; font-size: 13px; }
  .cb-toggle-label strong { font-weight: 500; color: var(--theme-text-primary); }
  .cb-toggle-hint { font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); line-height: 1.4; }

  .cb-settings-actions { display: flex; justify-content: flex-end; }
</style>

<script is:inline>
  (function () {
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;
    const policy = banner.dataset.policyVersion;
    const stayToken = banner.dataset.stayToken || null;
    const flagKey = `retaha_consent_v${policy}`;
    if (localStorage.getItem(flagKey)) return;
    banner.hidden = false;

    const compact = banner.querySelector('[data-mode="compact"]');
    const expanded = banner.querySelector('[data-mode="expanded"]');

    function sendConsent(type) {
      // localStorage zuerst (auch wenn Beacon fehlschlägt: Banner bleibt weg)
      try { localStorage.setItem(flagKey, JSON.stringify({ type, at: Date.now() })); } catch (_) {}
      try {
        const payload = JSON.stringify({
          token: stayToken,
          consent_type: type,
          consent_given: type !== 'rejected',
        });
        const blob = new Blob([payload], { type: 'application/json' });
        navigator.sendBeacon('/api/g/consent', blob);
      } catch (_) { /* non-fatal — localStorage flag verhindert Banner-Wiederkehr */ }
      banner.hidden = true;
    }

    banner.querySelectorAll('[data-consent]').forEach(btn => {
      btn.addEventListener('click', () => sendConsent(btn.dataset.consent));
    });
    banner.querySelector('[data-action="expand"]')?.addEventListener('click', () => {
      compact.hidden = true;
      expanded.hidden = false;
    });
    banner.querySelector('[data-action="save-settings"]')?.addEventListener('click', () => {
      const fn = document.getElementById('cb-functional').checked;
      const an = document.getElementById('cb-analytics').checked;
      const type = an ? 'all' : (fn ? 'necessary' : 'rejected');
      sendConsent(type);
    });
  })();
</script>
