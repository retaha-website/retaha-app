---
import type { UserProfile } from '../../lib/types/user';
import { getInitials, getDisplayName } from '../../lib/types/user';

interface Props {
  user: UserProfile;
}

const { user } = Astro.props;
const initials = getInitials(user);
const name = getDisplayName(user);

const langLabel = user.language === 'en' ? 'EN' : 'DE';
---

<div class="user-dropdown" id="userDropdown" role="menu" aria-hidden="true">

  <!-- User-Header -->
  <div class="ud__header">
    <div class="ud__avatar-big" aria-hidden="true">{initials}</div>
    <div class="ud__user">
      <div class="ud__name">{name}</div>
      <div class="ud__email">{user.email}</div>
      <div class="ud__role">
        <span class="ud__role-badge">{user.role}</span>
        {user.hotel_name && <span class="ud__role-hotel">{user.hotel_name}</span>}
      </div>
    </div>
  </div>

  <div class="ud__divider"></div>

  <!-- Persönlich -->
  <div class="ud__items">
    <a href="/profil" class="ud__item" role="menuitem">
      <svg class="ud__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <div class="ud__item-text">
        <span class="ud__item-label">Mein Profil</span>
        <span class="ud__item-sub">Name · E-Mail · Passwort</span>
      </div>
      <span class="ud__item-arrow" aria-hidden="true">→</span>
    </a>

    <a href="/profil#security" class="ud__item" role="menuitem">
      <svg class="ud__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
      <div class="ud__item-text">
        <span class="ud__item-label">Sicherheit & 2FA</span>
        <span class="ud__item-sub">Passwort · Zwei-Faktor</span>
      </div>
      <span class="ud__item-arrow" aria-hidden="true">→</span>
    </a>

    <a href="/account/benachrichtigungen" class="ud__item" role="menuitem">
      <svg class="ud__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <div class="ud__item-text">
        <span class="ud__item-label">Benachrichtigungen</span>
        <span class="ud__item-sub">E-Mail · Push · WhatsApp</span>
      </div>
      <span class="ud__item-arrow" aria-hidden="true">→</span>
    </a>
  </div>

  <div class="ud__divider"></div>

  <!-- Allgemein -->
  <div class="ud__items">
    <button type="button" class="ud__item" id="langBtn" role="menuitem" aria-haspopup="menu">
      <svg class="ud__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      <div class="ud__item-text">
        <span class="ud__item-label">Sprache</span>
      </div>
      <span class="ud__item-value">{langLabel}</span>
    </button>

    <a href="/hilfe" class="ud__item" role="menuitem">
      <svg class="ud__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
      <div class="ud__item-text">
        <span class="ud__item-label">Hilfe & Support</span>
        <span class="ud__item-sub">WhatsApp · Mail · Docs</span>
      </div>
      <span class="ud__item-arrow" aria-hidden="true">→</span>
    </a>
  </div>

  <div class="ud__divider"></div>

  <!-- Abmelden -->
  <form action="/admin/auth/logout" method="POST" class="ud__logout">
    <button type="submit" class="ud__item ud__item--logout" role="menuitem">
      <svg class="ud__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
      <div class="ud__item-text">
        <span class="ud__item-label">Abmelden</span>
        <span class="ud__item-sub">{name}</span>
      </div>
    </button>
  </form>

</div>

<style>
  .user-dropdown {
    position: absolute;
    top: calc(100% + 16px);
    right: 0;
    width: 320px;
    background: var(--surface);
    border: 1px solid var(--ink);
    border-radius: var(--r);
    box-shadow: 0 16px 48px rgba(10,10,10,0.12), 0 4px 12px rgba(10,10,10,0.06);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 0ms 200ms;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .user-dropdown {
    box-shadow: 0 16px 48px rgba(0,0,0,0.5);
  }
  .user-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 200ms ease, transform 200ms ease, visibility 0ms 0ms;
  }

  .ud__header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px;
    background: var(--bg-deep);
  }
  .ud__avatar-big {
    width: 44px;
    height: 44px;
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    border-radius: var(--r-sm);
    flex-shrink: 0;
  }
  .ud__user { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .ud__name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.005em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ud__email {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ud__role {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
  }
  .ud__role-badge {
    padding: 2px 7px;
    background: var(--sage);
    color: white;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 99px;
  }
  .ud__role-hotel {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ud__divider { height: 1px; background: var(--border); }
  .ud__items { padding: 6px 0; }
  .ud__logout { padding: 6px 0; }

  .ud__item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 18px;
    cursor: pointer;
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    border: none;
    width: 100%;
    font-family: inherit;
    font-size: inherit;
    text-align: left;
    transition: background 150ms ease, padding-left 200ms ease;
  }
  .ud__item:hover {
    background: var(--te-yellow-soft);
    padding-left: 24px;
  }
  .ud__item:hover .ud__item-icon { color: var(--ink); }
  .ud__item:hover .ud__item-arrow {
    color: var(--ink);
    transform: translateX(4px);
  }

  .ud__item-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--ink-muted);
    transition: color 150ms ease;
  }
  .ud__item-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .ud__item-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .ud__item-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }
  .ud__item-arrow {
    color: var(--ink-faint);
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    transition: all 200ms ease;
  }
  .ud__item-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--ink);
    font-weight: 500;
    padding: 2px 7px;
    background: var(--bg-deep);
    border-radius: var(--r-sm);
  }

  .ud__item--logout:hover { background: var(--burgund-soft); }
  .ud__item--logout:hover .ud__item-icon { color: var(--burgund); }
  .ud__item--logout:hover .ud__item-label { color: var(--burgund); }
</style>
