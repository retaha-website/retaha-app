---
import { getMenuSections } from '../../lib/navigation/menu-items';
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;
const menuSections = getMenuSections(lang);
---

<div class="key-menu-dropdown" id="keyMenuDropdown" role="menu" aria-hidden="true">

  <!-- Search -->
  <div class="km-search">
    <svg class="km-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/>
      <line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input
      type="search"
      class="km-search__input"
      placeholder={bt('km.search.placeholder', lang)}
      aria-label={bt('km.search.aria', lang)}
      autocomplete="off"
    />
    <kbd class="km-search__kbd">ESC</kbd>
  </div>

  <div class="km-divider"></div>

  <!-- Sektionen -->
  <div class="km-body">
    {menuSections.map(section => (
      <div class="km-section">
        <span class="km-section__title">{section.title}</span>
        <div class="km-section__items">
          {section.items.map(item => (
            <a href={item.href} class="km-item" role="menuitem">
              <span class="km-item__icon" aria-hidden="true" set:html={item.icon} />
              <div class="km-item__text">
                <span class="km-item__label">{item.label}</span>
                {item.sub && <span class="km-item__sub">{item.sub}</span>}
              </div>
              <span class="km-item__arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    <!-- Empty State -->
    <div class="km-empty" hidden>
      <span class="km-empty__icon" aria-hidden="true">⌕</span>
      <p class="km-empty__text">{bt('km.empty', lang)}</p>
    </div>
  </div>

</div>

<style>
  .key-menu-dropdown {
    position: absolute;
    top: calc(100% + 16px);
    right: 0;
    width: 380px;
    max-height: 600px;
    background: var(--surface);
    border: 1px solid var(--ink);
    border-radius: var(--r);
    box-shadow: 0 16px 48px rgba(10,10,10,0.12), 0 4px 12px rgba(10,10,10,0.06);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 0ms 200ms;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .key-menu-dropdown {
    box-shadow: 0 16px 48px rgba(0,0,0,0.5);
  }
  .key-menu-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 200ms ease, transform 200ms ease, visibility 0ms 0ms;
  }
  @media (max-width: 480px) {
    .key-menu-dropdown { width: calc(100vw - 32px); right: -8px; }
  }

  /* Search */
  .km-search {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px; background: var(--bg-deep); flex-shrink: 0;
  }
  .km-search__icon { width: 16px; height: 16px; color: var(--ink-muted); flex-shrink: 0; }
  .km-search__input {
    flex: 1; background: transparent; border: none; outline: none;
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    letter-spacing: 0.04em; color: var(--ink);
  }
  .km-search__input::placeholder { color: var(--ink-muted); }
  .km-search__kbd {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 500;
    letter-spacing: 0.12em; color: var(--ink-muted);
    background: var(--surface); border: 1px solid var(--border);
    padding: 2px 6px; border-radius: var(--r-sm);
  }

  .km-divider { height: 1px; background: var(--border); flex-shrink: 0; }

  /* Body */
  .km-body { flex: 1; overflow-y: auto; padding: 4px 0; }
  .km-body::-webkit-scrollbar { width: 4px; }
  .km-body::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 2px; }

  /* Sections */
  .km-section { padding: 4px 0; border-bottom: 1px solid var(--border); }
  .km-section:last-child { border-bottom: none; }
  .km-section__title {
    display: block; padding: 10px 18px 4px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; color: var(--ink-muted); text-transform: uppercase; font-weight: 500;
  }

  /* Items */
  .km-item {
    display: flex; align-items: center; gap: 12px;
    padding: 9px 18px;
    text-decoration: none; color: var(--ink);
    transition: background 150ms ease, padding-left 200ms ease;
  }
  .km-item:hover { background: var(--petrol-soft); padding-left: 24px; }
  .km-item:hover .km-item__icon { color: var(--ink); }
  .km-item:hover .km-item__arrow { color: var(--ink); transform: translateX(4px); }

  .km-item__icon {
    width: 18px; height: 18px; flex-shrink: 0;
    color: var(--ink-muted); transition: color 150ms ease;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .km-item__icon :global(svg) { width: 100%; height: 100%; }

  .km-item__text { flex: 1; display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .km-item__label {
    font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 500;
    color: var(--ink); letter-spacing: -0.005em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .km-item__sub {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.08em; color: var(--ink-muted); text-transform: uppercase;
  }
  .km-item__arrow {
    color: var(--ink-faint); font-family: 'JetBrains Mono', monospace;
    font-size: 14px; transition: all 200ms ease; flex-shrink: 0;
  }

  /* Empty state */
  .km-empty { padding: 32px 24px; text-align: center; }
  .km-empty__icon { font-size: 24px; opacity: 0.35; display: block; margin-bottom: 8px; }
  .km-empty__text { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-muted); letter-spacing: 0.04em; }
</style>
