---
import type { UserProfile } from '../../lib/types/user';
import { getInitials } from '../../lib/types/user';
import { bt } from '@retaha/i18n';
import UserDropdown from './UserDropdown.astro';

interface Props {
  user: UserProfile;
}

const { user } = Astro.props;
const firstInitial = getInitials(user).charAt(0);
const lang = user.language;
---

<div class="user-menu" id="userMenu">
  <button
    class={`user-avatar${user.avatar_url ? ' has-photo' : ''}`}
    id="userAvatar"
    aria-label={bt('menu.avatar.open', lang)}
    aria-haspopup="menu"
    aria-expanded="false"
  >
    {user.avatar_url
      ? <img src={user.avatar_url} alt="" class="user-avatar-img" />
      : firstInitial}
  </button>

  <!-- Hinweis-Punkt: erscheint, wenn das Setup „geparkt" wurde (Setup überspringen) -->
  <span class="user-avatar-dot" data-onb-dot aria-hidden="true"></span>

  <UserDropdown user={user} />
</div>

<style>
  .user-menu { position: relative; }

  /* Hinweis-Punkt am Avatar (oben rechts) — nur sichtbar wenn Setup geparkt. */
  .user-avatar-dot {
    position: absolute;
    top: -3px; right: -3px;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--petrol, #14616E);
    box-shadow: 0 0 0 2px var(--surface, #fff);
    display: none;
    z-index: 2;
    pointer-events: none;
  }
  .user-avatar-dot.is-on { display: block; animation: onb-avatar-dot 2s ease-in-out infinite; }
  @keyframes onb-avatar-dot { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.25); } }

  .user-avatar {
    width: 32px;
    height: 32px;
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    border-radius: var(--r-sm);
    cursor: pointer;
    border: none;
    transition: all 200ms ease;
    position: relative;
    letter-spacing: 0;
  }
  .user-avatar:hover,
  .user-avatar.is-open {
    background: var(--petrol);
    color: #fff;
  }

  /* Profilfoto füllt den Avatar; Hover = Gelb-Ring statt Gelb-Fläche. */
  .user-avatar.has-photo { background: transparent; overflow: hidden; }
  .user-avatar-img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: var(--r-sm); }
  .user-avatar.has-photo:hover,
  .user-avatar.has-photo.is-open { background: transparent; box-shadow: 0 0 0 2px var(--petrol); }

  /* Mini-Pfeil unter Avatar wenn Dropdown offen */
  .user-avatar.is-open::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-bottom: 6px solid var(--surface);
    filter: drop-shadow(0 -1px 0 var(--border-medium));
    z-index: 101;
  }
</style>

<script>
  const userMenu  = document.getElementById('userMenu');
  const avatar    = document.getElementById('userAvatar');
  const dropdown  = document.getElementById('userDropdown');

  if (userMenu && avatar && dropdown) {
    const open = () => {
      document.dispatchEvent(new CustomEvent('retaha:menu-open', { detail: 'userMenu' }));
      avatar.classList.add('is-open');
      dropdown.classList.add('is-open');
      avatar.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('aria-hidden', 'false');
    };
    const close = () => {
      avatar.classList.remove('is-open');
      dropdown.classList.remove('is-open');
      avatar.setAttribute('aria-expanded', 'false');
      dropdown.setAttribute('aria-hidden', 'true');
    };

    avatar.addEventListener('click', (e) => {
      e.stopPropagation();
      avatar.classList.contains('is-open') ? close() : open();
    });

    document.addEventListener('click', (e) => {
      if (!userMenu.contains(e.target as Node)) close();
    });

    document.addEventListener('retaha:menu-open', (e: Event) => {
      if ((e as CustomEvent).detail !== 'userMenu') close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && avatar.classList.contains('is-open')) {
        close();
        avatar.focus();
      }
    });

    // Sprach-Picker — reines Vanilla-JS (Alpine-unabhängig). Toggle der Inline-
    // Optionsliste; Auswahl setzt das `retaha_lang`-Cookie + lädt neu.
    const langBtn = document.getElementById('langBtn');
    const langOptions = document.getElementById('langOptions');
    if (langBtn && langOptions) {
      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = langOptions.classList.toggle('is-open');
        langBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
      langOptions.querySelectorAll<HTMLButtonElement>('.ud__lang-opt').forEach((opt) => {
        opt.addEventListener('click', (e) => {
          e.stopPropagation();
          const l = opt.getAttribute('data-lang');
          if (!l) return;
          document.cookie = `retaha_lang=${l}; path=/; max-age=31536000; samesite=lax`;
          window.location.reload();
        });
      });
    }
  }
</script>
