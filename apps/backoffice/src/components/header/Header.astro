---
import HotelLogo from './HotelLogo.astro';
import HeaderTabs from './HeaderTabs.astro';
import KeyMenu from './KeyMenu.astro';
import Logo from '@retaha/ui/components/brand/Logo.astro';
import UserMenu from './UserMenu.astro';
import type { UserProfile } from '../../lib/types/user';

interface Props {
  activeTab: 'gast' | 'backoffice' | 'dashboard';
  user: UserProfile;
  hotelName?: string;
  hotelLocation?: string;
  hotelStars?: number;
  hotelLogoUrl?: string | null;
}

const {
  activeTab,
  user,
  hotelName,
  hotelLocation,
  hotelStars,
  hotelLogoUrl,
} = Astro.props;
---

<header class="head">
  <div class="head__inner">

    <!-- TOP-ROW: Brand · Hotel-Logo · Controls -->
    <div class="head__top">

      <div class="head__brand">
        <Logo variant="dark" size="sm" href="/uebersicht" ariaLabel="retaha – Zur Übersicht" class="head__brand-logo" />
      </div>

      <HotelLogo name={hotelName} location={hotelLocation} stars={hotelStars} logoUrl={hotelLogoUrl} />

      <div class="head__controls">
        <button class="head__btn" id="v9ThemeBtn" type="button" aria-label="Theme wechseln">
          <svg id="v9IconMoon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               width="14" height="14" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg id="v9IconSun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               width="14" height="14" style="display:none;" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
        </button>

        <KeyMenu />

        <UserMenu user={user} />
      </div>
    </div>

    <!-- TAB-ROW -->
    <HeaderTabs active={activeTab} />

  </div>
</header>

<style>
  .head {
    border-bottom: 1px solid var(--border-strong);
    background: var(--surface);
  }
  .head__inner {
    max-width: 1400px;
    margin: 0 auto;
  }
  .head__top {
    padding: 16px 32px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .head__top {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 16px 20px;
      justify-items: start;
    }
  }
  .head__brand {
    justify-self: start;
  }
  /* Logo-Farbe folgt dem Theme-Token */
  .head__brand-logo.brand-logo--dark { color: var(--ink); }
  .head__controls {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-self: end;
  }
  .head__btn {
    background: transparent;
    border: 1px solid var(--border);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    cursor: pointer;
    transition: all 150ms ease;
    border-radius: var(--r-sm);
  }
  .head__btn:hover {
    background: var(--te-yellow);
    color: #0A0A0A;
    border-color: var(--te-yellow);
  }
</style>

<script>
  const btn    = document.getElementById('v9ThemeBtn');
  const iconM  = document.getElementById('v9IconMoon');
  const iconS  = document.getElementById('v9IconSun');
  const html   = document.documentElement;

  let theme = localStorage.getItem('v9-theme') || 'light';
  html.setAttribute('data-theme', theme);
  if (iconM && iconS) {
    iconM.style.display = theme === 'light' ? 'block' : 'none';
    iconS.style.display = theme === 'dark'  ? 'block' : 'none';
  }

  btn?.addEventListener('click', () => {
    theme = theme === 'light' ? 'dark' : 'light';
    html.setAttribute('data-theme', theme);
    localStorage.setItem('v9-theme', theme);
    if (iconM && iconS) {
      iconM.style.display = theme === 'light' ? 'block' : 'none';
      iconS.style.display = theme === 'dark'  ? 'block' : 'none';
    }
  });
</script>
