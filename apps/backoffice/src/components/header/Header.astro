---
import HotelLogo from './HotelLogo.astro';
import HeaderTabs from './HeaderTabs.astro';
import KeyMenu from './KeyMenu.astro';
import Logo from '@retaha/ui/components/brand/Logo.astro';
import UserMenu from './UserMenu.astro';
import NotificationsDrawer from './NotificationsDrawer.astro';
import { calculateTrialStatus } from '../../lib/trial-status';
import type { UserProfile } from '../../lib/types/user';
import { bt } from '@retaha/i18n';

interface Props {
  activeTab: 'gast' | 'backoffice' | 'admin';
  user: UserProfile;
  hotelName?: string;
  hotelLocation?: string;
  hotelStars?: number;
  hotelLogoUrl?: string | null;
}

const {
  activeTab,
  user,
  hotelName,
  hotelLocation,
  hotelStars,
  hotelLogoUrl,
} = Astro.props;

// Testphasen-Status für das Banner im Benachrichtigungs-Drawer.
const trial = calculateTrialStatus({
  trial_started_at: user.hotel_trial_started_at,
  trial_ends_at: user.hotel_trial_ends_at,
  subscription_status: user.hotel_subscription_status,
});

// Setup übersprungen, aber nicht abgeschlossen → „Setup unvollständig"-Benachrichtigung.
const setupIncomplete = user.hotel_setup_skipped && !user.hotel_onboarding_done;
---

<header class="head">
  <div class="head__inner">

    <!-- TOP-ROW: Brand · Hotel-Logo · Controls -->
    <div class="head__top">

      <div class="head__brand">
        <Logo variant="dark" size="sm" href="/overview" ariaLabel="retaha – Zur Übersicht" class="head__brand-logo" />
      </div>

      <!-- Logo + Trennstrich + Switcher als eine zentrierte Einheit -->
      <div class="head__nav">
        <HotelLogo name={hotelName} location={hotelLocation} stars={hotelStars} logoUrl={hotelLogoUrl} />
        <span class="head__nav-divider" aria-hidden="true"></span>
        <HeaderTabs active={activeTab} lang={user.language} />
      </div>

      <div class="head__controls">
        {(() => {
          const p = user.hotel_plan ?? 'lite';
          if (p !== 'enterprise') {
            return <a href="/subscription" class={`head__plan-badge head__plan-badge--${p}`} title={`Dein Plan: ${p.toUpperCase()} — Abonnement ansehen`}>{p.toUpperCase()}</a>;
          }
        })()}

        <!-- Alle Icon-Buttons in einer gemeinsamen Box -->
        <div class="head__ctrl-group">
          <button class="head__btn" id="v9ThemeBtn" type="button" aria-label={bt('header.theme', user.language)}>
            <svg id="v9IconMoon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 width="14" height="14" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg id="v9IconSun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 width="14" height="14" style="display:none;" aria-hidden="true">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
            </svg>
          </button>
          <KeyMenu lang={user.language} plan={user.hotel_plan ?? 'lite'} />
          <UserMenu user={user} />
        </div>
      </div>
    </div>

    {(user.hotel_plan === 'lite' || !user.hotel_plan) && (
      <div class="head__strip">
        <span>Du nutzt <b>Lite</b> — die volle Suite wartet auf dich.</span>
        <a href="/subscription" class="head__strip-cta">Upgrade ansehen →</a>
      </div>
    )}
  </div>
</header>

<NotificationsDrawer trial={trial} qrNotifPending={user.hotel_qr_notif_pending} setupIncomplete={setupIncomplete} plan={user.hotel_plan} />

<style>
  .head {
    border-bottom: 1px solid var(--border-strong);
    background: var(--surface);
  }
  .head__inner {
    max-width: 1680px;
    margin: 0 auto;
  }
  .head__top {
    padding: 16px 32px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .head__top {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 16px 20px;
      justify-items: start;
    }
  }
  .head__brand {
    justify-self: start;
    display: flex;
    align-items: center;   /* Brand-Logo sauber vertikal mittig (statt Baseline) */
    /* Hover-Akzent des retaha-Logos auf Petrol (statt Pink-Fallback). Als
       vererbte Custom-Property gesetzt → erreicht die gescopte Logo-Komponente. */
    --theme-accent: var(--petrol);
  }
  /* Logo + Trennstrich + Switcher als eine zentrierte Einheit (eine Gruppe) */
  .head__nav {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-self: center;
  }
  .head__nav-divider {
    flex-shrink: 0;
    width: 1px;
    height: 26px;
    background: var(--ink-muted, rgba(10, 10, 10, 0.42));
  }
  @media (max-width: 900px) {
    .head__nav { flex-wrap: wrap; justify-self: start; }
    .head__nav-divider { display: none; }
  }
  .head__brand-logo.brand-logo--dark { color: var(--ink); --theme-accent: var(--petrol); }
  .head__controls {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-self: end;
  }
  /* Gemeinsame Box für alle Icon-Buttons rechts — wie ce-seg in Marketing */
  .head__ctrl-group {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 10px;
    padding: 3px;
  }
  .head__btn {
    background: transparent;
    border: none;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
    border-radius: 7px;
    flex-shrink: 0;
  }
  .head__btn:hover {
    background: var(--petrol);
    color: #fff;
  }

  /* KeyMenu-Button im Group-Context: kein eigener Rahmen, gleiche Höhe */
  .head__ctrl-group :global(.key-menu) {
    border: none;
    border-radius: 7px;
    height: 30px;
    padding: 0 10px 0 8px;
  }
  .head__ctrl-group :global(.key-menu:hover) {
    background: var(--petrol);
    color: #fff;
    border-color: transparent;
  }

  /* UserAvatar im Group-Context: Größe angleichen */
  .head__ctrl-group :global(.user-avatar) {
    width: 30px;
    height: 30px;
    border-radius: 7px;
  }
  .head__ctrl-group :global(.user-avatar-img) {
    border-radius: 7px;
  }

  /* Plan badge */
  .head__plan-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; letter-spacing: 0.16em; font-weight: 600;
    padding: 3px 8px; border-radius: 99px;
    border: 1px solid var(--border);
    color: var(--ink-muted);
    text-decoration: none; white-space: nowrap;
    transition: all 150ms ease;
    line-height: 1;
  }
  .head__plan-badge--lite {
    border-color: transparent;
    background: transparent;
    color: var(--petrol);
    padding-left: 0;
    padding-right: 0;
  }
  .head__plan-badge--lite:hover {
    opacity: 0.75;
  }
  .head__plan-badge--pro:hover,
  .head__plan-badge--premium:hover { background: var(--bg-deep); }

  /* Lite upgrade strip */
  .head__strip {
    display: flex; align-items: center; justify-content: center; gap: 16px;
    padding: 7px 32px;
    border-top: 1px solid rgba(255, 74, 130, 0.15);
    background: rgba(255, 74, 130, 0.03);
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.04em; color: var(--ink-muted);
  }
  .head__strip b { color: var(--ink); font-weight: 600; }
  .head__strip-cta {
    color: var(--pink, #FF4A82); text-decoration: none;
    font-weight: 600; transition: opacity 150ms;
  }
  .head__strip-cta:hover { opacity: 0.75; }
  @media (max-width: 600px) { .head__strip { flex-direction: column; gap: 4px; text-align: center; } }
</style>

<script>
  const btn    = document.getElementById('v9ThemeBtn');
  const iconM  = document.getElementById('v9IconMoon');
  const iconS  = document.getElementById('v9IconSun');
  const html   = document.documentElement;

  let theme = localStorage.getItem('v9-theme') || 'light';
  html.setAttribute('data-theme', theme);
  if (iconM && iconS) {
    iconM.style.display = theme === 'light' ? 'block' : 'none';
    iconS.style.display = theme === 'dark'  ? 'block' : 'none';
  }

  btn?.addEventListener('click', () => {
    theme = theme === 'light' ? 'dark' : 'light';
    html.setAttribute('data-theme', theme);
    localStorage.setItem('v9-theme', theme);
    if (iconM && iconS) {
      iconM.style.display = theme === 'light' ? 'block' : 'none';
      iconS.style.display = theme === 'dark'  ? 'block' : 'none';
    }
  });
</script>
