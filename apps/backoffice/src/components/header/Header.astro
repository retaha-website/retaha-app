---
// Dünner Wrapper um den geteilten Header (@retaha/ui). Backoffice = bo:'' (relative
// Routen), Gast-/Dashboard-Tabs absolut über GUEST_APP/DASHBOARD-Env.
import SharedHeader from '@retaha/ui/components/header/Header.astro';
import type { UserProfile } from '../../lib/types/user';

interface Props {
  activeTab: 'gast' | 'backoffice' | 'admin';
  user: UserProfile;
  hotelName?: string;
  hotelLocation?: string;
  hotelStars?: number;
  hotelLogoUrl?: string | null;
}

const { activeTab, user, hotelName, hotelLocation, hotelStars, hotelLogoUrl } = Astro.props;

const GUEST_APP = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';
const DASHBOARD = import.meta.env.DASHBOARD_URL ?? 'https://dashboard.retaha.de';
---

<SharedHeader
  activeTab={activeTab}
  user={user}
  hotelName={hotelName}
  hotelLocation={hotelLocation}
  hotelStars={hotelStars}
  hotelLogoUrl={hotelLogoUrl}
  bo=""
  guestBase={GUEST_APP}
  dashboardBase={DASHBOARD}
/>
