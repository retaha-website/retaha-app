---
import { bt, type LanguageCode } from '@retaha/i18n';
import SharedHeaderTabs from '@retaha/ui/components/header/HeaderTabs.astro';

type TabKey = 'gast' | 'backoffice' | 'admin';

interface Props {
  active: TabKey;
  lang: LanguageCode;
}

const { active, lang } = Astro.props;

const GUEST_APP = import.meta.env.GUEST_APP_URL ?? 'https://app.retaha.de';
const DASHBOARD = import.meta.env.DASHBOARD_URL  ?? 'https://dashboard.retaha.de';
---

<SharedHeaderTabs
  active={active}
  guestUrl={`${GUEST_APP}/gast-vorschau`}
  backofficeUrl="/overview"
  dashboardUrl={DASHBOARD}
  labels={{
    guest:      bt('tab.guest',      lang),
    backoffice: bt('tab.backoffice', lang),
    admin:      bt('tab.admin',      lang),
    here:       bt('tab.here',       lang),
    switchTo:   bt('tab.switch',     lang),
  }}
/>
