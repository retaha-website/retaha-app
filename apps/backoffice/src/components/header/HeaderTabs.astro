---
import { bt, type LanguageCode } from '@retaha/i18n';

type TabKey = 'gast' | 'backoffice' | 'admin';

interface Props {
  active: TabKey;
  lang: LanguageCode;
}

const { active, lang } = Astro.props;

const GUEST_APP  = import.meta.env.GUEST_APP_URL  ?? 'https://app.retaha.de';
const DASHBOARD  = import.meta.env.DASHBOARD_URL  ?? 'https://dashboard.retaha.de';

// Zwei Arbeitsflächen (Segmented-Switcher) + eine Vorschau (abgesetzt).
const workspaces = [
  { key: 'backoffice' as const, label: bt('tab.backoffice', lang), href: '/uebersicht', icon: 'sliders' },
  { key: 'admin'      as const, label: bt('tab.admin', lang),      href: DASHBOARD,     icon: 'grid'    },
];
const preview = { key: 'gast' as const, label: bt('tab.guest', lang), href: `${GUEST_APP}/gast-vorschau` };
---

<nav class="header-tabs" aria-label="Hauptnavigation">
  <!-- 2 Arbeitsflächen — verbundener Segmented-Switcher -->
  <div class="ht-seg" role="group" aria-label="Arbeitsflächen">
    {workspaces.map(tab => (
      <a
        href={tab.href}
        class:list={['ht-tab', { 'is-active': tab.key === active }]}
        title={tab.key === active ? bt('tab.here', lang) : `${bt('tab.switch', lang)} ${tab.label}`}
        aria-current={tab.key === active ? 'page' : undefined}
      >
        {tab.icon === 'sliders' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/>
            <line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/>
            <line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>
          </svg>
        )}
        {tab.icon === 'grid' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
        )}
        <span>{tab.label}</span>
      </a>
    ))}
  </div>

  <!-- Gast-Ansicht — Vorschau der Gästeseite, abgesetzt mit Augen-Affordanz -->
  <a
    href={preview.href}
    class:list={['ht-preview', { 'is-active': preview.key === active }]}
    title={`${bt('tab.switch', lang)} ${preview.label}`}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
    <span>{preview.label}</span>
  </a>
</nav>

<style>
  .header-tabs {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 8px 32px;
    border-top: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .header-tabs::-webkit-scrollbar { display: none; }
  @media (max-width: 900px) { .header-tabs { padding: 8px 20px; } }

  /* Segmented-Switcher: zwei verbundene Arbeitsflächen */
  .ht-seg {
    display: inline-flex;
    flex-shrink: 0;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    overflow: hidden;
  }
  .ht-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    text-decoration: none;
    color: var(--ink-muted);            /* nicht-aktiv = Geist */
    background: transparent;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease;
  }
  .ht-tab + .ht-tab { border-left: 1px solid var(--border); }
  .ht-tab svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.85; }
  .ht-tab:hover { background: var(--bg-deep); color: var(--ink); }           /* Hover = neutral */
  .ht-tab.is-active {
    color: var(--ink);
    background: var(--te-pink-soft);                                          /* sehr leiser Tint */
    box-shadow: inset 0 -2px 0 var(--te-pink);                               /* dünne Pink-Kante (Underline) */
  }
  .ht-tab.is-active svg { opacity: 1; }

  /* Gast-Ansicht — abgesetzte Vorschau (eigene Gruppe, Augen-Icon) */
  .ht-preview {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    text-decoration: none;
    color: var(--ink-muted);
    background: transparent;
    border: 1px dashed var(--border-medium);                                 /* gestrichelt = Vorschau, kein Workspace */
    border-radius: var(--r-sm);
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }
  .ht-preview svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.85; }
  .ht-preview:hover { background: var(--bg-deep); color: var(--ink); border-color: var(--ink-muted); }
  .ht-preview.is-active { color: var(--ink); border-style: solid; box-shadow: inset 0 -2px 0 var(--te-pink); }
</style>
