---
import { bt, type LanguageCode } from '@retaha/i18n';

type TabKey = 'gast' | 'backoffice' | 'admin';

interface Props {
  active: TabKey;
  lang: LanguageCode;
}

const { active, lang } = Astro.props;

const GUEST_APP  = import.meta.env.GUEST_APP_URL  ?? 'https://app.retaha.de';
const DASHBOARD  = import.meta.env.DASHBOARD_URL  ?? 'https://dashboard.retaha.de';

const tabs = [
  { key: 'gast'       as const, label: bt('tab.guest', lang),      href: `${GUEST_APP}/gast-vorschau`, icon: 'phone'   },
  { key: 'backoffice' as const, label: bt('tab.backoffice', lang), href: '/uebersicht',                icon: 'sliders' },
  { key: 'admin'      as const, label: bt('tab.admin', lang),      href: DASHBOARD,                    icon: 'grid'    },
];
---

<nav class="header-tabs" aria-label="Hauptnavigation">
  {tabs.map(tab => (
    <a
      href={tab.href}
      class:list={['header-tabs__tab', { 'is-active': tab.key === active }]}
      title={tab.key === active ? bt('tab.here', lang) : `${bt('tab.switch', lang)} ${tab.label}`}
      aria-current={tab.key === active ? 'page' : undefined}
    >
      {tab.icon === 'phone' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="6" y="2" width="12" height="20" rx="2"/>
          <line x1="11" y1="18" x2="13" y2="18"/>
        </svg>
      )}
      {tab.icon === 'sliders' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4"  y1="21" x2="4"  y2="14"/>
          <line x1="4"  y1="10" x2="4"  y2="3"/>
          <line x1="12" y1="21" x2="12" y2="12"/>
          <line x1="12" y1="8"  x2="12" y2="3"/>
          <line x1="20" y1="21" x2="20" y2="16"/>
          <line x1="20" y1="12" x2="20" y2="3"/>
          <line x1="1"  y1="14" x2="7"  y2="14"/>
          <line x1="9"  y1="8"  x2="15" y2="8"/>
          <line x1="17" y1="16" x2="23" y2="16"/>
        </svg>
      )}
      {tab.icon === 'grid' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3"  y="3"  width="7" height="9"/>
          <rect x="14" y="3"  width="7" height="5"/>
          <rect x="14" y="12" width="7" height="9"/>
          <rect x="3"  y="16" width="7" height="5"/>
        </svg>
      )}
      <span>{tab.label}</span>
    </a>
  ))}
</nav>

<style>
  .header-tabs {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 32px;
    border-top: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .header-tabs::-webkit-scrollbar { display: none; }

  @media (max-width: 900px) {
    .header-tabs { padding: 10px 20px; }
  }

  /* Quadratische Tiles: Icon mittig oben, Text darunter */
  .header-tabs__tab {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 62px;
    height: 62px;
    flex-shrink: 0;
    padding: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5px;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.62);
    background: var(--ink);                 /* voller Ink-Block (Stempel) */
    border: 1px solid var(--ink);
    border-radius: var(--r-sm);
    cursor: pointer;
    transition: all 200ms ease;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
  }
  .header-tabs__tab:hover {
    color: #fff;
    background: #1d1d1d;
    border-color: #1d1d1d;
  }
  /* Aktiver Stempel: Petrol-Akzent auf dem Ink-Block */
  .header-tabs__tab.is-active {
    color: #fff;
    box-shadow: inset 0 0 0 1.5px var(--petrol-on-dark);
  }
  .header-tabs__tab svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.72);
  }
  .header-tabs__tab:hover svg { color: #fff; }
  .header-tabs__tab.is-active svg { color: var(--petrol-on-dark); }
</style>
