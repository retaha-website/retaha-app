---
import { bt, type LanguageCode } from '@retaha/i18n';

type TabKey = 'gast' | 'backoffice' | 'admin';

interface Props {
  active: TabKey;
  lang: LanguageCode;
}

const { active, lang } = Astro.props;

const GUEST_APP  = import.meta.env.GUEST_APP_URL  ?? 'https://app.retaha.de';
const DASHBOARD  = import.meta.env.DASHBOARD_URL  ?? 'https://dashboard.retaha.de';

const tabs = [
  { key: 'gast'       as const, label: bt('tab.guest', lang),      href: `${GUEST_APP}/gast-vorschau`, icon: 'phone'   },
  { key: 'backoffice' as const, label: bt('tab.backoffice', lang), href: '/overview',                icon: 'sliders' },
  { key: 'admin'      as const, label: bt('tab.admin', lang),      href: DASHBOARD,                    icon: 'grid'    },
];
---

{/* Ansicht-Umschalter — sitzt als Einheit neben dem Hotel-Logo in der Kopfzeile.
    Petrol-Markierung gleitet (kein harter Sprung); beim ersten Login klappen die
    Kacheln gestaffelt aus der Marke heraus (einmal pro Gerät). */}
<nav class="header-tabs" id="viewSwitcher" aria-label="Ansicht wechseln">
  <span class="header-tabs__marker" data-marker aria-hidden="true"></span>
  {tabs.map((tab, i) => (
    <a
      href={tab.href}
      data-tab
      style={`--i: ${i}`}
      class:list={['header-tabs__tab', { 'is-active': tab.key === active }]}
      title={tab.key === active ? bt('tab.here', lang) : `${bt('tab.switch', lang)} ${tab.label}`}
      aria-current={tab.key === active ? 'page' : undefined}
    >
      {tab.icon === 'phone' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="7" y="3" width="10" height="18" rx="2"/>
          <path d="M11 18h2"/>
        </svg>
      )}
      {tab.icon === 'sliders' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h11M19 6h1M4 12h3M11 12h9M4 18h7M15 18h5"/>
          <circle cx="17" cy="6" r="2"/>
          <circle cx="9"  cy="12" r="2"/>
          <circle cx="13" cy="18" r="2"/>
        </svg>
      )}
      {tab.icon === 'grid' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="4"  y="4"  width="7" height="7" rx="1.5"/>
          <rect x="13" y="4"  width="7" height="7" rx="1.5"/>
          <rect x="4"  y="13" width="7" height="7" rx="1.5"/>
          <rect x="13" y="13" width="7" height="7" rx="1.5"/>
        </svg>
      )}
      <span class="header-tabs__lbl">{tab.label}</span>
    </a>
  ))}
</nav>

<style>
  /* Container: weißes Kästchen mit Outline — wie ce-seg in Marketing */
  .header-tabs {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #E5E4E0);
    border-radius: 10px;
    padding: 3px;
  }

  /* Gleitende Petrol-Füllung liegt hinter der aktiven Kachel */
  .header-tabs__marker {
    position: absolute;
    top: 0;
    left: 0;
    height: 0;
    width: 0;
    background: var(--petrol);
    border-radius: 7px;
    z-index: 0;
    opacity: 0;
    transform-origin: center;
    pointer-events: none;
    transition: left 320ms cubic-bezier(0.5, 0, 0.2, 1),
                top 320ms cubic-bezier(0.5, 0, 0.2, 1),
                width 320ms cubic-bezier(0.5, 0, 0.2, 1),
                height 320ms cubic-bezier(0.5, 0, 0.2, 1);
  }
  @keyframes marker-bloom {
    from { opacity: 0; transform: scale(0.32); }
    to   { opacity: 1; transform: scale(1); }
  }
  .header-tabs__marker.is-blooming {
    animation: marker-bloom 600ms cubic-bezier(0.22, 1, 0.36, 1) var(--bloom-delay, 0ms) both;
  }

  /* Kacheln: kein eigener Rahmen — nur der Container hat einen */
  @keyframes tab-sheen {
    0%, 72% { left: -70%; }
    100%     { left: 140%; }
  }

  .header-tabs__tab {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    height: 30px;
    padding: 0 10px;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: 0.05em;
    line-height: 1;
    color: var(--ink-muted);
    background: transparent;
    border: none;
    border-radius: 7px;
    cursor: pointer;
    transition: color 120ms ease;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
  }
  .header-tabs__tab:hover:not(.is-active) { color: var(--petrol); }
  .header-tabs__tab.is-active { color: #fff; }

  /* Sheen sweep on active tab (3× the mockup speed: 6.5 s × 3 = 19.5 s) */
  .header-tabs__tab.is-active::after {
    content: '';
    position: absolute;
    top: 0;
    left: -70%;
    width: 45%;
    height: 100%;
    background: linear-gradient(100deg, transparent, rgba(255,255,255,.36), transparent);
    transform: skewX(-18deg);
    pointer-events: none;
    animation: tab-sheen 19.5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .header-tabs__tab.is-active::after { animation: none; }
  }

  .header-tabs__tab svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--petrol);
    transition: color 120ms ease;
  }
  .header-tabs__tab.is-active svg { color: #fff; }

  /* Label: nur beim aktiven Tab sichtbar — inaktive bleiben reine Icon-Buttons */
  .header-tabs__lbl {
    display: block;
    max-width: 0;
    margin-left: 0;
    opacity: 0;
    overflow: hidden;
  }
  .header-tabs__tab.is-active .header-tabs__lbl {
    max-width: 120px;
    margin-left: 7px;
    opacity: 1;
  }

  /* Erstes Login: Kacheln klappen gestaffelt auf */
  @keyframes tab-unfold {
    from { opacity: 0; transform: translateX(-22px) scale(0.7); }
    to   { opacity: 1; transform: none; }
  }
  .header-tabs.is-unfolding .header-tabs__tab {
    animation: tab-unfold 400ms cubic-bezier(0.34, 1.3, 0.5, 1) backwards;
    animation-delay: calc(var(--i) * 100ms + 90ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .header-tabs__marker { transition: none; }
    .header-tabs__marker.is-blooming { animation: none; opacity: 1; }
    .header-tabs.is-unfolding .header-tabs__tab { animation: none; }
    .header-tabs__lbl { transition: none; }
  }

  @media (max-width: 900px) {
    .header-tabs__tab { height: 28px; padding: 0 8px; }
  }
</style>

<script is:inline>
  (function () {
    var nav = document.getElementById('viewSwitcher');
    if (!nav) return;
    var marker = nav.querySelector('[data-marker]');
    var tabs = Array.prototype.slice.call(nav.querySelectorAll('[data-tab]'));
    if (!marker || !tabs.length) return;

    function activeTab() { return nav.querySelector('[data-tab].is-active') || tabs[0]; }

    function place(el) {
      if (!el) return;
      marker.style.width = el.offsetWidth + 'px';
      marker.style.height = el.offsetHeight + 'px';
      marker.style.left = el.offsetLeft + 'px';
      marker.style.top = el.offsetTop + 'px';
    }

    // Stagger-Animation nur beim ersten Login (einmal pro Gerät).
    var firstTime = false;
    try {
      if (!localStorage.getItem('retaha-switcher-seen')) {
        firstTime = true;
        localStorage.setItem('retaha-switcher-seen', '1');
      }
    } catch (e) {}
    if (firstTime) nav.classList.add('is-unfolding');

    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    requestAnimationFrame(function () {
      // Ohne Transition direkt an die aktive Kachel setzen → KEIN Slide von links.
      marker.style.transition = 'none';
      place(activeTab());
      void marker.offsetWidth; // Reflow erzwingen
      marker.style.transition = '';
      if (reduce) { marker.style.opacity = '1'; return; }
      // Beim ersten Login erst pulsen, nachdem die Kacheln ausgeklappt sind.
      if (firstTime) marker.style.setProperty('--bloom-delay', '480ms');
      // Reveal = Puls von innen (Keyframe), nicht hereingleiten.
      marker.classList.add('is-blooming');
    });

    // Schrift (JetBrains Mono) lädt evtl. nach → die aktive Kachel wird breiter.
    // Markierung dann neu vermessen, sonst deckt sie die Kachel erst nach dem
    // ersten Hover voll ab.
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(function () {
        marker.style.transition = 'none';
        place(activeTab());
        void marker.offsetWidth;
        marker.style.transition = '';
      });
    }

    // Wechseln: Markierung gleitet zur angetippten Kachel, dann Navigation.
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function (e) {
        // Aktive Kachel: normale Navigation zum href zulassen (z. B. von einer
        // Backoffice-Unterseite zurück zu /overview). KEIN preventDefault.
        if (tab.classList.contains('is-active')) { return; }
        e.preventDefault();
        var href = tab.getAttribute('href');
        tabs.forEach(function (t) { t.classList.remove('is-active'); });
        tab.classList.add('is-active');
        place(tab);
        setTimeout(function () { if (href) window.location.href = href; }, reduce ? 0 : 320);
      });
    });

    // Bei Resize Markierung ohne Animation neu setzen.
    var rt;
    window.addEventListener('resize', function () {
      clearTimeout(rt);
      rt = setTimeout(function () {
        var prev = marker.style.transition;
        marker.style.transition = 'none';
        place(activeTab());
        requestAnimationFrame(function () { marker.style.transition = prev; });
      }, 120);
    });

    // Inaktive Tabs ändern beim Hover keine Breite mehr (Option A: nur Farbe).
    // Kein RAF-Tracking nötig.
  })();
</script>
