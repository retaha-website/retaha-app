---
interface Props {
  label?: string;
}
const { label = 'MENU' } = Astro.props;
---

<button class="key-menu" aria-label="Menü öffnen" aria-haspopup="menu" type="button">
  <svg class="key-menu__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <!-- Schlüssel-Ring oben -->
    <circle cx="12" cy="5" r="3" stroke="currentColor" stroke-width="2"/>
    <circle cx="12" cy="5" r="1" fill="currentColor"/>
    <!-- Schlüssel-Schaft -->
    <line x1="12" y1="8" x2="12" y2="14" stroke="currentColor" stroke-width="2"/>
    <!-- Bart = 3 horizontale Linien (Burger-Konvention) -->
    <line x1="12" y1="15" x2="18" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
    <line x1="12" y1="18" x2="16" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
    <line x1="12" y1="21" x2="18" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
  </svg>
  <span>{label}</span>
</button>

<style>
  .key-menu {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1px solid var(--border);
    padding: 6px 14px 6px 10px;
    cursor: pointer;
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    transition: all 150ms ease;
    border-radius: var(--r-sm);
  }
  .key-menu:hover {
    background: var(--bg-deep);
    color: var(--ink);
    border-color: var(--border-medium);
  }
  .key-menu__icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
</style>
