---
// Geteilte Hub-Shell für „retaha Account" (Sidebar + Header + Content-Slot).
// Genutzt von /profil (Konto) und /profil/sicherheit (Sicherheit) — gleiche
// Sidebar/Nav, nur aktiver Eintrag + Slot-Inhalt unterscheiden sich.
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props {
  active: 'konto' | 'security' | 'hotel' | 'team';
  initials: string;
  displayName: string;
  roleLabel: string;
  avatarUrl?: string | null;
  subtitle?: string;
  lang: LanguageCode;
}
const {
  active,
  initials,
  displayName,
  roleLabel,
  avatarUrl = null,
  subtitle,
  lang,
} = Astro.props;
const sub = subtitle ?? bt('hub.subtitle', lang);
---

<div class="acct">

  <!-- ── Sidebar ── -->
  <aside class="acct__sidebar">
    <div class="acct__user">
      <label class="acct__avatar" title={bt('hub.avatar.change', lang)}>
        {avatarUrl
          ? <img src={avatarUrl} alt={bt('hub.avatar.alt', lang)} class="acct__avatar-img" />
          : <span class="acct__avatar-initial" aria-hidden="true">{initials}</span>}
        <span class="acct__avatar-cam" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
        </span>
        <input type="file" accept="image/*" class="sr-only acct__avatar-input" aria-label={bt('hub.avatar.upload', lang)}
          data-msg-success={bt('hub.upload.success', lang)}
          data-msg-fail={bt('hub.upload.fail', lang)}
          data-msg-error={bt('hub.upload.error', lang)} />
      </label>
      <div class="acct__user-meta">
        <span class="acct__user-name">{displayName}</span>
        <span class="acct__user-role">{roleLabel}</span>
      </div>
    </div>

    <nav class="acct__nav" aria-label={bt('hub.nav.aria', lang)}>
      <div class="acct__navgroup">
        <span class="acct__navgroup-title">{bt('hub.group.account', lang)}</span>
        <a href="/profil" class={`acct__navitem${active === 'konto' ? ' is-active' : ''}`} aria-current={active === 'konto' ? 'page' : undefined}>{bt('hub.konto', lang)}</a>
        <a href="/profil/sicherheit" class={`acct__navitem${active === 'security' ? ' is-active' : ''}`} aria-current={active === 'security' ? 'page' : undefined}>{bt('hub.security', lang)}</a>
      </div>
      <div class="acct__navgroup">
        <span class="acct__navgroup-title">{bt('hub.group.hotel', lang)}</span>
        <a href="/profil/settings" class={`acct__navitem${active === 'hotel' ? ' is-active' : ''}`} aria-current={active === 'hotel' ? 'page' : undefined}>{bt('hub.hoteldata', lang)}</a>
        <a href="/team" class={`acct__navitem${active === 'team' ? ' is-active' : ''}`} aria-current={active === 'team' ? 'page' : undefined}>{bt('hub.team', lang)}</a>
      </div>
    </nav>
  </aside>

  <!-- ── Content ── -->
  <main class="acct__content">
    <header class="acct__header">
      <h1 class="acct__title">retaha Account<span class="dot-pink">.</span></h1>
      <p class="acct__sub">{sub}</p>
    </header>

    <slot />
  </main>
</div>

<style is:global>
  [x-cloak] { display: none !important; }

  /* ── Hub-Shell: Sidebar + Content ── */
  .acct {
    max-width: 1200px; margin: 0 auto; padding: 56px 32px 96px;
    display: grid; grid-template-columns: 232px 1fr; gap: 64px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .acct { grid-template-columns: 1fr; gap: 40px; padding: 36px 20px 72px; }
  }

  .acct__sidebar { position: sticky; top: 32px; display: flex; flex-direction: column; gap: 30px; }
  @media (max-width: 900px) { .acct__sidebar { position: static; top: 0; } }

  .acct__user {
    display: flex; align-items: center; gap: 14px;
    padding-top: 5px; padding-bottom: 28px; border-bottom: 1px solid var(--border);
  }
  /* Klickbarer Avatar — Foto oder Initiale, Hover/Fokus zeigt Kamera-Overlay. */
  .acct__avatar {
    position: relative; width: 44px; height: 44px; flex-shrink: 0;
    background: var(--ink); color: var(--bg);
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--r-sm); overflow: hidden; cursor: pointer;
  }
  .acct__avatar-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .acct__avatar-initial { font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 500; }
  .acct__avatar-cam {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: rgba(10, 10, 10, 0.5); color: #fff; opacity: 0; transition: opacity 150ms ease;
  }
  .acct__avatar:hover .acct__avatar-cam,
  .acct__avatar:focus-within .acct__avatar-cam { opacity: 1; }
  .acct__avatar-cam svg { width: 17px; height: 17px; }
  .acct__user-meta { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .acct__user-name {
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .acct__user-role {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
  }

  .acct__nav { display: flex; flex-direction: column; gap: 30px; }
  .acct__navgroup { display: flex; flex-direction: column; gap: 7px; }
  .acct__navgroup-title {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-muted);
    padding: 0 12px 4px;
  }
  .acct__navitem {
    display: block; padding: 11px 14px; border-radius: var(--r-sm);
    font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    color: var(--ink-soft); text-decoration: none;
    transition: background 150ms ease, color 150ms ease;
  }
  .acct__navitem:hover { background: rgba(20,97,110,.07); color: #14616E; }
  .acct__navitem.is-active { background: #14616E; color: #fff; font-weight: 500; }

  @media (max-width: 900px) {
    .acct__nav { flex-direction: row; flex-wrap: wrap; gap: 10px 20px; }
    .acct__navgroup { flex-direction: row; align-items: center; gap: 6px; flex-wrap: wrap; }
    .acct__navgroup-title { padding: 0; }
  }

  /* Content */
  .acct__content { min-width: 0; }
  .acct__header { padding: 0 0 40px; border-bottom: 1px solid var(--border); margin-bottom: 48px; }
  .acct__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(30px, 4.5vw, 46px); font-weight: 400;
    line-height: 1.04; letter-spacing: -0.025em; color: var(--ink);
  }
  .acct__sub {
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    color: var(--ink-muted); letter-spacing: 0.04em; margin-top: 14px;
  }

  .acct__section { margin-bottom: 72px; }
  .acct__section:last-child { margin-bottom: 0; }
  .acct__section-head { margin-bottom: 28px; }
  .acct__section-title {
    font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 500;
    letter-spacing: -0.01em; color: var(--ink);
  }
  .acct__section-desc {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--ink-muted); letter-spacing: 0.04em; margin-top: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .acct__navitem, .acct__avatar-cam { transition: none; }
  }
</style>

<script>
  // Profilfoto-Upload: File-Input → /api/account/avatar → Reload (alle Avatare frisch).
  document.querySelectorAll<HTMLInputElement>('.acct__avatar-input').forEach((input) => {
    input.addEventListener('change', async () => {
      const file = input.files?.[0];
      if (!file) return;
      const ds = input.dataset;
      const toast = (window as any).retahaToast as ((m: string, t?: string) => void) | undefined;
      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/account/avatar', { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || ds.msgFail || 'Upload fehlgeschlagen');
        toast?.(ds.msgSuccess || 'Profilfoto aktualisiert');
        setTimeout(() => window.location.reload(), 500);
      } catch (err) {
        toast?.(err instanceof Error ? err.message : (ds.msgError || 'Fehler beim Upload'), 'error');
        input.value = '';
      }
    });
  });
</script>
