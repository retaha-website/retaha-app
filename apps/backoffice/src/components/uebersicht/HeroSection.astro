---
import type { Stage } from '../../lib/uebersicht/setup-stage';
import { HERO_TEXTS } from '../../lib/uebersicht/setup-stage';

interface Props {
  stage: Stage;
}

const { stage } = Astro.props;
const text = HERO_TEXTS[stage];
---

<section class="hero">
  <span class="hero__eyebrow">Übersicht · Backoffice</span>
  <h1 class="hero__title" set:html={text.title}></h1>
  <p class="hero__sub">{text.sub}</p>
</section>

<style is:global>
  .hero__title strong { font-weight: 500; }
</style>

<style>
  .hero {
    max-width: 1400px;
    margin: 0 auto;
    padding: 64px 32px 32px;
  }
  @media (max-width: 768px) {
    .hero { padding: 40px 20px 24px; }
  }
  .hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: #0A0A0A;
    background: var(--te-yellow);
    padding: 5px 10px;
    display: inline-block;
    margin-bottom: 28px;
    font-weight: 500;
    border-radius: var(--r-sm);
  }
  .hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(44px, 8vw, 96px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-bottom: 24px;
    max-width: 1000px;
  }
  .hero__sub {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 600px;
  }
</style>
