---
import type { Stage } from '../../lib/uebersicht/setup-stage';
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props {
  stage: Stage;
  lang: LanguageCode;
}

const { stage, lang } = Astro.props;
---

<section class="hero">
  <h1 class="hero__title" set:html={bt(`hero.${stage}.title`, lang)}></h1>
  <p class="hero__sub">{bt(`hero.${stage}.sub`, lang)}</p>
</section>

<style is:global>
  .hero__title strong { font-weight: 500; }
  /* Punkt im Hero-Titel in Petrol (statt Pink) — Marken-Akzent. */
  .hero__title .dot-pink { color: var(--petrol); }
</style>

<style>
  .hero {
    max-width: 1400px;
    margin: 0 auto;
    padding: 64px 32px 32px;
  }
  @media (max-width: 768px) {
    .hero { padding: 40px 20px 24px; }
  }
  .hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: #fff;
    background: var(--petrol);
    padding: 5px 10px;
    display: inline-block;
    margin-bottom: 28px;
    font-weight: 500;
    border-radius: var(--r-sm);
  }
  .hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(44px, 8vw, 96px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-bottom: 24px;
    max-width: 1000px;
  }
  .hero__sub {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 600px;
  }
</style>
