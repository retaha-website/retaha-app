---
// Onboarding · Screen 2 — „Wähl deinen Look — und nimm ihn in die Hand."
//
// EIN Screen aus „Look wählen" + „QR-Reveal". Aufbau wie Step 1: links Copy
// (H1 + Sub + CTA, gleiche Position), rechts die Bühne mit drei Teilen:
//   Auswahl — Look-Karten (bestehende Themes). Ausgewählt = Petrol-Kante, kein Fill.
//   Mockup  — ECHTES /branding-Preview (BauhausPreview/EditorialPreview/
//             MaisonPreview im .bp-outer-Bezel). Wechselt live auf den Look.
//   QR      — echter QR; Link trägt ?design=<look> (showcase-only Override in
//             /g/[token].astro) → scannt genau den gewählten Look.
// Antippen schaltet Mockup + QR live um. Copy DE-only.

import BauhausPreview   from '../branding/previews/BauhausPreview.astro';
import EditorialPreview from '../branding/previews/EditorialPreview.astro';
import MaisonPreview    from '../branding/previews/MaisonPreview.astro';
import QRCode from 'qrcode';
import { createSupabaseServiceRoleInstance, getOrCreateShowcaseUrl } from '@retaha/auth';

interface Props {
  hotelId: string;
  hotelName?: string;
  userId: string;
}
const { hotelId, hotelName: hotelNameProp, userId } = Astro.props;

const sb = createSupabaseServiceRoleInstance();
const { data: h } = await sb
  .from('hotels')
  .select('name, design_identity, brand_primary')
  .eq('id', hotelId)
  .maybeSingle();

const hotelName = (h as any)?.name ?? hotelNameProp ?? 'Dein Hotel';
const brandPrimary: string | null = (h as any)?.brand_primary ?? null;

// Default-Auswahl = aktuelle Identität des Hotels (gleiche Remap wie Guest-App).
const IDENTITY_REMAP: Record<string, string> = {
  classic: 'bauhaus', bauhaus_manufaktur: 'bauhaus', premium_anthrazit: 'maison', warmes_burgund: 'editorial',
};
const rawIdentity = (h as any)?.design_identity ?? null;
const hotelIdentity = rawIdentity ? (IDENTITY_REMAP[rawIdentity] ?? rawIdentity) : 'bauhaus';

// Angebotene Look-Varianten = die bestehenden Guest-Themes / Design-Identitäten.
const LOOKS = [
  { id: 'bauhaus',   label: 'Bauhaus',   desc: 'Anti-Luxus · Selbstbewusst' },
  { id: 'editorial', label: 'Editorial', desc: 'Magazinhaft · Storytelling' },
  { id: 'maison',    label: 'Maison',    desc: 'Klassisch · Opulent' },
];
const defaultLook = LOOKS.some(l => l.id === hotelIdentity) ? hotelIdentity : 'bauhaus';

// Echter Showcase-Deep-Link (frisch — nie stale) + QR pro Look (?design=<id>).
let guestUrl: string | null = null;
try { guestUrl = await getOrCreateShowcaseUrl(hotelId, userId); } catch { /* nicht-fatal */ }
function withDesign(url: string, id: string): string {
  return `${url}${url.includes('?') ? '&' : '?'}design=${id}`;
}

const looks = [] as Array<{ id: string; label: string; desc: string; qrSvg: string | null }>;
for (const l of LOOKS) {
  let qrSvg: string | null = null;
  if (guestUrl) {
    try {
      qrSvg = await QRCode.toString(withDesign(guestUrl, l.id), {
        type: 'svg', errorCorrectionLevel: 'M', margin: 2,
        color: { dark: '#14616E', light: '#0000' },
      });
    } catch { /* QR nicht-fatal */ }
  }
  looks.push({ ...l, qrSvg });
}
---

<section class="lr" data-onb-step="2" style="display:none">
  <div class="lr-grid">

    <!-- Links: Copy (gleiche Position wie Step 1) -->
    <div class="lr-copy">
      <h1 class="lr-h1">Wähle deinen <span class="lr-nb">Look<span class="lr-dot"></span></span></h1>
      <p class="lr-sub">Tippe einen Look, sieh ihn sofort, scann ihn aufs Telefon.</p>
      <div class="lr-select">
        <!-- Auswahl: Look-Boxen (länger gezogen) -->
        <div class="lr-looks" role="radiogroup" aria-label="Gästemappen-Look wählen">
          {looks.map(l => (
            <button
              type="button"
              class:list={['di-card', { 'is-active': l.id === defaultLook }]}
              data-look={l.id}
              role="radio"
              aria-checked={l.id === defaultLook ? 'true' : 'false'}
            >
              {l.id === 'bauhaus' && (
                <div class="di-card__hint di-card__hint--bauhaus"><span class="bh-initial">B</span><span class="bh-pink-dot"></span></div>
              )}
              {l.id === 'editorial' && (
                <div class="di-card__hint di-card__hint--editorial"><span class="ed-name">Editorial</span></div>
              )}
              {l.id === 'maison' && (
                <div class="di-card__hint di-card__hint--maison"><span class="ms-name">MAISON</span><span class="ms-rhombus"></span></div>
              )}
              <div class="di-card__body">
                <div class:list={['di-card__title', `${l.id}-title`]}>{l.label}</div>
                <div class="di-card__desc">{l.desc}</div>
              </div>
            </button>
          ))}
        </div>

        <!-- QR (ohne Ecken), rechts neben der Auswahl -->
        <div class="lr-qr">
          <div class="lr-qr-stack">
            {looks.map(l => (
              <div class="lr-qr-view" data-look-qr={l.id} role="img" aria-label="QR-Code zur Gästemappe" style={l.id === defaultLook ? '' : 'display:none'}>
                {l.qrSvg ? <Fragment set:html={l.qrSvg} /> : <div class="lr-qr-fallback">QR n/v</div>}
              </div>
            ))}
          </div>
          <span class="lr-qr-cap">Mit der Kamera scannen.</span>
        </div>
      </div>

      <div class="lr-cta-row">
        <button type="button" class="lr-next" data-onb-goto="3">Weiter →</button>
        <button type="button" class="lr-skip" data-onb-action="skip">Setup überspringen</button>
      </div>
    </div>

    <!-- Rechts: Mockup — ECHTES /branding-Preview im .bp-outer-Bezel -->
    <div class="lr-stage">
      <div class="lr-phone">
        <div class="bp-outer">
          <div class="bp-inner">
            <div class="lr-view" data-look-view="bauhaus" style={defaultLook === 'bauhaus' ? '' : 'display:none'}>
              <BauhausPreview hotelName={hotelName} brandPrimary={brandPrimary} />
            </div>
            <div class="lr-view" data-look-view="editorial" style={defaultLook === 'editorial' ? '' : 'display:none'}>
              <EditorialPreview hotelName={hotelName} brandPrimary={brandPrimary} />
            </div>
            <div class="lr-view" data-look-view="maison" style={defaultLook === 'maison' ? '' : 'display:none'}>
              <MaisonPreview hotelName={hotelName} brandPrimary={brandPrimary} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Schritt-Balken — Schritt 2 aktiv, klickbar -->
  <div class="lr-steps" role="group" aria-label="Onboarding-Schritte">
    {[1, 2, 3, 4].map(i => (
      <button
        type="button"
        class:list={['lr-step', { 'is-active': i === 2 }]}
        data-onb-goto={i}
        aria-label={`Schritt ${i}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .lr {
    --petrol: #14616E;
    max-width: 1320px; width: 100%;
    margin: 8px auto 12px;
    padding: 28px 32px 36px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
  }
  .lr-grid {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px; align-items: center;
  }
  @media (max-width: 1100px) {
    .lr-grid { grid-template-columns: 1fr; gap: 32px; justify-items: center; text-align: center; }
  }

  /* Links: Copy — Headline-Stil wie Step 1 (.onb-headline) */
  .lr-copy { min-width: 0; max-width: 600px; }
  .lr-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(40px, 5vw, 72px); line-height: 0.98;
    letter-spacing: -0.035em; color: var(--ink); margin: 0 0 22px;
  }
  .lr-nb { white-space: nowrap; }
  .lr-dot {
    display: inline-block; width: 14px; height: 14px; border-radius: 50%;
    background: var(--petrol); margin-left: 4px; vertical-align: baseline;
  }
  .lr-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0 0 22px; max-width: 42ch;
  }
  @media (max-width: 1100px) { .lr-sub { margin-left: auto; margin-right: auto; } }

  /* Auswahl + QR nebeneinander, zwischen Sub und Button */
  .lr-select { display: flex; align-items: center; gap: 24px; margin: 0 0 26px; }
  @media (max-width: 1100px) { .lr-select { justify-content: center; } }
  @media (max-width: 560px) { .lr-select { flex-direction: column; align-items: center; } }

  .lr-cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 1100px) { .lr-cta-row { justify-content: center; } }
  .lr-next {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    cursor: pointer; transition: background 0.15s ease;
  }
  .lr-next:hover { background: var(--petrol); }
  .lr-skip {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; cursor: pointer; transition: color 0.15s ease;
  }
  .lr-skip:hover { color: var(--ink); }

  /* Rechts: Mockup */
  .lr-stage { display: flex; align-items: center; justify-content: center; }

  /* Auswahl: Look-Boxen (1:1 .di-card, Auswahl = Petrol-Kante, kein Fill).
     Länger gezogen: füllen die Breite links neben dem QR. */
  .lr-looks { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 10px; }
  @media (max-width: 560px) { .lr-looks { width: 100%; } }
  .di-card {
    display: flex; align-items: center;
    width: 100%; text-align: left; padding: 0;
    border: 1.5px solid var(--border); border-radius: var(--r);
    background: var(--surface); cursor: pointer;
    transition: border-color 200ms, box-shadow 200ms, transform 200ms;
    overflow: hidden;
    -webkit-appearance: none; appearance: none;
  }
  .di-card:hover { border-color: var(--ink-faint); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,.06); }
  /* Aktiv: gleiche Border-Stärke wie inaktiv, nur Petrol-Farbe (kein Doppelrand) */
  .di-card.is-active { border-color: var(--petrol); }
  .di-card__hint {
    width: 66px; min-height: 68px; flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 6px; padding: 10px 6px;
  }
  .di-card__hint--bauhaus { background: #F5F5F3; }
  .di-card__hint--editorial { background: #FAF7F0; }
  .di-card__hint--maison { background: #1A1410; }
  .bh-initial { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 600; color: #0A0A0A; letter-spacing: -.03em; line-height: 1; }
  .bh-pink-dot { width: 7px; height: 7px; background: #FF4A82; border-radius: 50%; }
  .ed-name { font-family: 'Georgia', serif; font-size: 11px; font-style: italic; color: #2B2A28; border-bottom: 1px solid #4A5C2A; padding-bottom: 2px; }
  .ms-name { font-family: 'Georgia', serif; font-size: 8px; color: #E8D9B5; letter-spacing: .1em; text-transform: uppercase; }
  .ms-rhombus { width: 5px; height: 5px; background: #C9A36A; transform: rotate(45deg); }
  .di-card__body { padding: 11px 16px; flex: 1; min-width: 0; }
  .di-card__title { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 2px; }
  .bauhaus-title::after { content: ''; display: inline-block; width: 6px; height: 6px; background: #FF4A82; border-radius: 50%; margin-left: 5px; vertical-align: middle; }
  .editorial-title { font-family: 'Georgia', serif; font-style: italic; border-bottom: 1px solid #4A5C2A; display: inline-block; padding-bottom: 1px; font-weight: 400; }
  .maison-title { font-family: 'Georgia', serif; letter-spacing: .04em; }
  .maison-title::after { content: ''; display: inline-block; width: 5px; height: 5px; background: #C9A36A; transform: rotate(45deg); margin-left: 6px; vertical-align: middle; }
  .di-card__desc { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; color: var(--ink-soft); letter-spacing: .02em; line-height: 1.45; }

  /* Mockup: 1:1 .bp-outer/.bp-inner aus /branding BrandMiniPreview */
  .lr-phone { display: flex; justify-content: center; }
  .bp-outer {
    width: 260px; height: 563px;
    overflow: hidden; position: relative; border-radius: 36px;
    box-shadow: 0 0 0 8px #0A0A0A, 0 0 0 10px #2A2A2A, 0 20px 48px -8px rgba(0,0,0,0.38);
  }
  .bp-inner {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 844px;
    transform: scale(0.6667); transform-origin: top left;
    pointer-events: none;
  }
  .lr-view { position: absolute; top: 0; left: 0; width: 390px; height: 844px; }

  /* QR: transparent, Petrol — ohne Ecken-Rahmen */
  .lr-qr { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .lr-qr-stack { position: relative; width: 156px; height: 156px; }
  .lr-qr-view { position: absolute; inset: 0; }
  .lr-qr-view :global(svg) { display: block; width: 100%; height: 100%; }
  .lr-qr-fallback { width: 100%; height: 100%; display: grid; place-items: center; font-size: 11px; color: var(--ink-muted); text-align: center; }
  .lr-qr-cap { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.04em; color: var(--ink-muted, rgba(10,10,10,0.42)); text-align: center; }

  /* Schritt-Balken */
  .lr-steps { display: flex; justify-content: center; align-items: center; gap: 8px; margin: 24px auto 0; }
  .lr-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    cursor: pointer; transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .lr-step.is-active { width: 46px; background: var(--petrol); }
  .lr-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .lr-step:disabled { cursor: default; }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-onb-step="2"]');
    if (!root) return;
    var cards = Array.prototype.slice.call(root.querySelectorAll('[data-look]'));
    var views = Array.prototype.slice.call(root.querySelectorAll('[data-look-view]'));
    var qrs = Array.prototype.slice.call(root.querySelectorAll('[data-look-qr]'));
    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        var id = card.getAttribute('data-look');
        cards.forEach(function (c) {
          var on = c === card;
          c.classList.toggle('is-active', on);
          c.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        views.forEach(function (v) { v.style.display = v.getAttribute('data-look-view') === id ? '' : 'none'; });
        qrs.forEach(function (q) { q.style.display = q.getAttribute('data-look-qr') === id ? '' : 'none'; });
      });
    });
  })();
</script>
