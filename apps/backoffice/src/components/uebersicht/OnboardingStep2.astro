---
// Onboarding · Screen 2 — „Wähl deinen Look — und nimm ihn in die Hand."
//
// EIN Screen aus „Look wählen" + „QR-Reveal". Aufbau wie Step 1: links Copy
// (H1 + Sub + CTA, gleiche Position), rechts die Bühne mit drei Teilen:
//   Auswahl — Look-Karten (bestehende Themes). Ausgewählt = Petrol-Kante, kein Fill.
//   Mockup  — ECHTES /branding-Preview (BauhausPreview/EditorialPreview/
//             MaisonPreview im .bp-outer-Bezel). Wechselt live auf den Look.
//   QR      — echter QR; Link trägt ?design=<look> (showcase-only Override in
//             /g/[token].astro) → scannt genau den gewählten Look.
// Antippen schaltet Mockup + QR live um. Copy DE-only.

import BauhausPreview   from '../branding/previews/BauhausPreview.astro';
import EditorialPreview from '../branding/previews/EditorialPreview.astro';
import MaisonPreview    from '../branding/previews/MaisonPreview.astro';
import QRCode from 'qrcode';
import { createSupabaseServiceRoleInstance, getOrCreateShowcaseUrl } from '@retaha/auth';

interface Props {
  hotelId: string;
  hotelName?: string;
  userId: string;
}
const { hotelId, hotelName: hotelNameProp, userId } = Astro.props;

const sb = createSupabaseServiceRoleInstance();
const { data: h } = await sb
  .from('hotels')
  .select('name, design_identity, brand_primary')
  .eq('id', hotelId)
  .maybeSingle();

const hotelName = (h as any)?.name ?? hotelNameProp ?? 'Dein Hotel';
const brandPrimary: string | null = (h as any)?.brand_primary ?? null;

// Default-Auswahl = aktuelle Identität des Hotels (gleiche Remap wie Guest-App).
const IDENTITY_REMAP: Record<string, string> = {
  classic: 'bauhaus', bauhaus_manufaktur: 'bauhaus', premium_anthrazit: 'maison', warmes_burgund: 'editorial',
};
const rawIdentity = (h as any)?.design_identity ?? null;
const hotelIdentity = rawIdentity ? (IDENTITY_REMAP[rawIdentity] ?? rawIdentity) : 'bauhaus';

// Angebotene Look-Varianten = die bestehenden Guest-Themes / Design-Identitäten.
const LOOKS = [
  { id: 'bauhaus',   label: 'Bauhaus',   desc: 'Anti-Luxus · Selbstbewusst' },
  { id: 'editorial', label: 'Editorial', desc: 'Magazinhaft · Storytelling' },
  { id: 'maison',    label: 'Maison',    desc: 'Klassisch · Opulent' },
];
const defaultLook = LOOKS.some(l => l.id === hotelIdentity) ? hotelIdentity : 'bauhaus';

// Echter Showcase-Deep-Link (frisch — nie stale) + QR pro Look (?design=<id>).
let guestUrl: string | null = null;
try { guestUrl = await getOrCreateShowcaseUrl(hotelId, userId); } catch { /* nicht-fatal */ }
function withDesign(url: string, id: string): string {
  return `${url}${url.includes('?') ? '&' : '?'}design=${id}`;
}

const looks = [] as Array<{ id: string; label: string; desc: string; url: string | null; qrSvg: string | null }>;
for (const l of LOOKS) {
  const url = guestUrl ? withDesign(guestUrl, l.id) : null;
  let qrSvg: string | null = null;
  if (url) {
    try {
      // Dunkel auf Hell wie DemoQrCard (gast-vorschau).
      qrSvg = await QRCode.toString(url, {
        type: 'svg', errorCorrectionLevel: 'M', margin: 1,
        color: { dark: '#0A0A0A', light: '#FAFAF8' },
      });
    } catch { /* QR nicht-fatal */ }
  }
  looks.push({ ...l, url, qrSvg });
}
---

<section class="lr" data-onb-step="2" style="display:none">
  <div class="lr-grid">

    <!-- Links: Copy (gleiche Position wie Step 1) -->
    <div class="lr-copy">
      <h1 class="lr-h1">Wähle deinen <span class="lr-nb">Look<span class="lr-dot"></span></span></h1>
      <p class="lr-sub">Jeder Look gibt deiner Gästemappe einen eigenen Charakter — von schlicht und selbstbewusst bis klassisch und opulent. Wähl einen aus, und du kannst ihn dir direkt aufs Handy holen, genau so, wie ihn deine Gäste sehen werden.</p>
      <!-- QR-Karte — reflektiert die rechts gewählte Designoption -->
      <div class="lr-qrcard">
        <div class="lr-qrcard__qr">
          <div class="lr-qr-stack">
            {looks.map(l => (
              <div class="lr-qr-view" data-look-qr={l.id} role="img" aria-label="QR-Code zur Gästemappe" style={l.id === defaultLook ? '' : 'display:none'}>
                {l.qrSvg ? <Fragment set:html={l.qrSvg} /> : <div class="lr-qr-fallback">QR n/v</div>}
              </div>
            ))}
          </div>
        </div>
        <p class="lr-qrcard__hint">Mit dem Handy scannen — deine Gästemappe im gewählten Look. Genau so erleben es deine Gäste.</p>
      </div>

      <div class="lr-cta-row">
        <button type="button" class="lr-next" data-onb-goto="3">Weiter →</button>
        <button type="button" class="lr-skip" data-onb-action="skip">Setup überspringen</button>
      </div>
    </div>

    <!-- Rechts: drei Designoptionen, jede mit echter Theme-Vorschau -->
    <div class="lr-options" role="radiogroup" aria-label="Gästemappen-Look wählen">
      {looks.map(l => (
        <button
          type="button"
          class:list={['lr-opt', { 'is-active': l.id === defaultLook }]}
          data-look={l.id}
          role="radio"
          aria-checked={l.id === defaultLook ? 'true' : 'false'}
        >
          <div class="lr-opt__meta">
            <span class="lr-opt__name">{l.label}</span>
            <span class="lr-opt__desc">{l.desc}</span>
          </div>
          <div class="lr-opt__preview">
            <div class="lr-opt__scaler">
              {l.id === 'bauhaus'   && <BauhausPreview   hotelName={hotelName} brandPrimary={brandPrimary} />}
              {l.id === 'editorial' && <EditorialPreview hotelName={hotelName} brandPrimary={brandPrimary} />}
              {l.id === 'maison'    && <MaisonPreview    hotelName={hotelName} brandPrimary={brandPrimary} />}
            </div>
            <span class="lr-opt__check" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="12" height="12"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- Schritt-Balken — Schritt 2 aktiv, klickbar -->
  <div class="lr-steps" role="group" aria-label="Onboarding-Schritte">
    {[1, 2, 3, 4].map(i => (
      <button
        type="button"
        class:list={['lr-step', { 'is-active': i === 2 }]}
        data-onb-goto={i}
        aria-label={`Schritt ${i}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .lr {
    --petrol: #14616E;
    max-width: 1320px; width: 100%;
    margin: 8px auto 12px;
    padding: 28px 32px 36px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
  }
  .lr-grid {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: auto auto;
    justify-content: center;       /* Gruppe mittig → Mockup näher an die Copy */
    gap: 56px; align-items: center;
  }
  @media (max-width: 1100px) {
    .lr-grid { grid-template-columns: 1fr; gap: 32px; justify-items: center; text-align: center; }
  }

  /* Links: Copy — Headline-Stil wie Step 1 (.onb-headline) */
  .lr-copy { min-width: 0; }
  .lr-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(44px, 6vw, 88px); line-height: 0.96;   /* = Step 1 */
    letter-spacing: -0.035em; color: var(--ink); margin: 0 0 22px;
    white-space: nowrap;   /* einzeilig */
  }
  @media (max-width: 560px) { .lr-h1 { white-space: normal; } }
  .lr-nb { white-space: nowrap; }
  .lr-dot {
    display: inline-block; width: 14px; height: 14px; border-radius: 50%;
    background: var(--petrol); margin-left: 4px; vertical-align: baseline;
  }
  .lr-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0 0 22px; max-width: 42ch;
  }
  @media (max-width: 1100px) { .lr-sub { margin-left: auto; margin-right: auto; } }

  .lr-cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 1100px) { .lr-cta-row { justify-content: center; } }
  .lr-next {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    cursor: pointer; transition: background 0.15s ease;
  }
  .lr-next:hover { background: var(--petrol); }
  .lr-skip {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; cursor: pointer; transition: color 0.15s ease;
  }
  .lr-skip:hover { color: var(--ink); }

  /* Rechts: drei Designoptionen NEBENEINANDER — Theme oben, Vorschau unten, ohne Rahmen */
  .lr-options { display: flex; flex-direction: row; flex-wrap: wrap; gap: 20px; justify-content: center; }
  .lr-opt {
    position: relative;
    display: flex; flex-direction: column; align-items: center; gap: 9px;
    width: 128px; padding: 0;
    border: none; background: transparent; cursor: pointer; text-align: center;
    -webkit-appearance: none; appearance: none;
  }
  .lr-opt__meta { display: flex; flex-direction: column; gap: 1px; align-items: center; }
  .lr-opt__name { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; color: var(--ink); letter-spacing: -0.01em; }
  .lr-opt.is-active .lr-opt__name { color: var(--petrol); }
  .lr-opt__desc { font-family: 'JetBrains Mono', monospace; font-size: 8.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.45)); }

  /* Vorschau OHNE Mockup-Rahmen: nur der Screen-Inhalt — Bezel (box-shadow) wird
     vom overflow:hidden geclippt, Notch + Statusbar oben weggecroppt (top-Offset). */
  .lr-opt__preview {
    position: relative;
    width: 128px; height: 240px;   /* höher = Smartphone-Hochformat, ohne untere Phone-Rundung */
    overflow: hidden; border-radius: var(--r-sm);
    outline: 2px solid transparent; outline-offset: 2px;
    transition: outline-color 0.15s ease;
  }
  .lr-opt.is-active .lr-opt__preview { outline-color: var(--petrol); }
  .lr-opt__scaler {
    position: absolute; top: -18px; left: 0;            /* Notch + Statusbar oben croppen */
    width: 390px; height: 844px;
    transform: scale(0.3282); transform-origin: top left;  /* 128 / 390 */
    pointer-events: none;
  }
  .lr-opt__check {
    position: absolute; top: 7px; right: 7px;
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--petrol); color: #fff;
    display: none; place-items: center; z-index: 3;
    box-shadow: 0 2px 8px -2px rgba(10,10,10,0.4);
  }
  .lr-opt.is-active .lr-opt__check { display: grid; }

  /* QR-Karte unter den Auswahl-Feldern — nur QR + kurzer Text, horizontal länger */
  .lr-qrcard {
    width: 100%; max-width: 600px; box-sizing: border-box;
    margin: 0 0 28px;
    display: flex; align-items: center; gap: 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 14px 18px;
  }
  @media (max-width: 1100px) { .lr-qrcard { margin-left: auto; margin-right: auto; } }
  .lr-qrcard__qr {
    flex-shrink: 0;
    background: var(--bg-deep); border-radius: var(--r-sm);
    padding: 8px; border: 1px solid var(--border);
  }
  .lr-qr-stack { position: relative; width: 96px; height: 96px; }
  .lr-qr-view { position: absolute; inset: 0; }
  .lr-qr-view :global(svg) { display: block; width: 100%; height: 100%; border-radius: 4px; }
  .lr-qr-fallback { width: 100%; height: 100%; display: grid; place-items: center; font-size: 10px; color: var(--ink-muted); text-align: center; }
  .lr-qrcard__hint {
    flex: 1; min-width: 0; margin: 0;
    font-family: 'JetBrains Mono', monospace; font-size: 10.5px;
    line-height: 1.55; color: var(--ink-muted); letter-spacing: 0.03em;
  }

  /* Schritt-Balken */
  .lr-steps { display: flex; justify-content: center; align-items: center; gap: 8px; margin: 24px auto 0; }
  .lr-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    cursor: pointer; transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .lr-step.is-active { width: 46px; background: var(--petrol); }
  .lr-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .lr-step:disabled { cursor: default; }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-onb-step="2"]');
    if (!root) return;
    var cards = Array.prototype.slice.call(root.querySelectorAll('[data-look]'));
    var qrs = Array.prototype.slice.call(root.querySelectorAll('[data-look-qr]'));
    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        var id = card.getAttribute('data-look');
        cards.forEach(function (c) {
          var on = c === card;
          c.classList.toggle('is-active', on);
          c.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        qrs.forEach(function (q) { q.style.display = q.getAttribute('data-look-qr') === id ? '' : 'none'; });
      });
    });
  })();
</script>
