---
// Onboarding · Screen 2 — „Sieh es als dein Gast." (QR-Reveal)
//
// Läuft als zweite Sektion DERSELBEN /uebersicht-Seite (gleiches Backoffice-
// Layout/Chrome wie Screen 1). Wird per JS ein-/ausgeblendet — kein Seitenwechsel.
// Links Copy + „Weiter", rechts der echte QR (transparent, Petrol, Scan-Rahmen)
// auf die Gästemappe des Betreibers. Copy DE-only.

import QRCode from 'qrcode';
import { getOrCreateShowcaseUrl } from '@retaha/auth';

interface Props {
  hotelId: string;
  hotelName?: string;
  userId: string;
}
const { hotelId, userId } = Astro.props;

// Echter Deep-Link auf die Gästemappe des Betreibers (frisch generiert — nie stale).
// SVG statt PNG = auflösungsunabhängig (nie verpixelt, auch auf Retina/3x-Displays).
// QR transparent (light: '#0000') + Petrol-Module ('#14616E') — keine weiße Fläche.
let guestUrl: string | null = null;
let qrSvg: string | null = null;
try {
  guestUrl = await getOrCreateShowcaseUrl(hotelId, userId);
  if (guestUrl) {
    qrSvg = await QRCode.toString(guestUrl, {
      type: 'svg', errorCorrectionLevel: 'M', margin: 2,
      color: { dark: '#14616E', light: '#0000' },
    });
  }
} catch { /* QR-Fehler nicht-fatal */ }
---

<section class="onb2" data-onb-step="2" style="display:none">
  <div class="onb2-split">

    <!-- Links: Copy -->
    <div class="onb2-left">
      <h1 class="onb2-h1">Sieh es als dein Gast<span class="onb2-dot"></span></h1>
      <p class="onb2-sub">Vom Bildschirm in die Hand: Scann den Code — und dein eigenes Hotel liegt auf deinem Telefon. Gästemappe und Eve, in deinem Branding. Genau das, was deine Gäste erleben.</p>

      <div class="onb2-cta-row">
        <a href="#" class="onb2-next" aria-disabled="true" title="Schritt 3 folgt">Weiter →</a>
        <button type="button" class="onb2-skip" data-onb-action="skip">Setup überspringen</button>
      </div>
    </div>

    <!-- Rechts: echter QR (transparent, Petrol, Scan-Rahmen) -->
    <div class="onb2-right">
      <div class="onb2-qr-frame">
        <span class="onb2-corner tl"></span>
        <span class="onb2-corner tr"></span>
        <span class="onb2-corner bl"></span>
        <span class="onb2-corner br"></span>
        <div class="onb2-qr" role="img" aria-label="QR-Code zur Gästemappe">
          {qrSvg
            ? <Fragment set:html={qrSvg} />
            : <div class="onb2-qr-fallback">QR konnte nicht erzeugt werden</div>}
        </div>
      </div>
      <span class="onb2-qr-cap">Mit der Kamera deines Handys scannen.</span>
    </div>

  </div>

  <!-- Schritt-Balken — Schritt 2 aktiv (segmentiert, wie Screen 1) -->
  <div class="onb2-steps" role="img" aria-label="Schritt 2 von 5">
    {[1, 2, 3, 4, 5].map(i => (
      <span class:list={['onb2-step', { 'is-active': i === 2 }]}></span>
    ))}
  </div>
</section>

<style>
  /* Volle Bildschirmhöhe wie Screen 1; JS verfeinert pro Header-Höhe. */
  .onb2 {
    --petrol: #14616E;
    max-width: 1140px; width: 100%;
    margin: 8px auto 12px;
    padding: 32px 32px 40px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
  }
  .onb2-split {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: 1fr minmax(0, 360px);
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 860px) {
    .onb2-split { grid-template-columns: 1fr; gap: 40px; justify-items: center; text-align: center; }
  }

  /* Links — Headline identisch zu Screen 1 (.onb-headline) */
  .onb2-left { min-width: 0; max-width: 560px; }
  .onb2-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(44px, 6vw, 88px); line-height: 0.96;
    letter-spacing: -0.035em; color: var(--ink); margin: 0 0 24px;
  }
  .onb2-dot {
    display: inline-block; width: 14px; height: 14px; border-radius: 50%;
    background: var(--petrol); margin-left: 4px; vertical-align: baseline;
  }
  .onb2-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0 0 28px; max-width: 44ch;
  }
  @media (max-width: 860px) { .onb2-sub { margin-left: auto; margin-right: auto; } }

  .onb2-cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 860px) { .onb2-cta-row { justify-content: center; } }
  .onb2-next {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    text-decoration: none; cursor: pointer;
    transition: background 0.15s ease;
  }
  .onb2-next:hover { background: #242424; }
  .onb2-skip {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; border: none; text-decoration: none;
    padding: 13px 8px; cursor: pointer; transition: color 0.15s ease;
  }
  .onb2-skip:hover { color: var(--ink); }

  /* Rechts — QR transparent, Petrol-Module, Scan-Rahmen (Viewfinder-Ecken) */
  .onb2-right { display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .onb2-qr-frame {
    position: relative;
    width: 300px; height: 300px;
    display: grid; place-items: center;
  }
  .onb2-qr { width: 248px; height: 248px; }
  .onb2-qr :global(svg) { display: block; width: 100%; height: 100%; }
  .onb2-qr-fallback {
    width: 100%; height: 100%; display: grid; place-items: center;
    font-size: 12px; color: var(--ink-muted); text-align: center;
  }
  .onb2-corner {
    position: absolute; width: 30px; height: 30px;
    border: 2.5px solid var(--petrol);
  }
  .onb2-corner.tl { top: 0; left: 0;  border-right: none; border-bottom: none; border-top-left-radius: 10px; }
  .onb2-corner.tr { top: 0; right: 0; border-left: none;  border-bottom: none; border-top-right-radius: 10px; }
  .onb2-corner.bl { bottom: 0; left: 0;  border-right: none; border-top: none; border-bottom-left-radius: 10px; }
  .onb2-corner.br { bottom: 0; right: 0; border-left: none;  border-top: none; border-bottom-right-radius: 10px; }
  .onb2-qr-cap {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.04em; color: var(--ink-muted, rgba(10,10,10,0.42));
  }

  /* Schritt-Balken (segmentiert, wie Screen 1) */
  .onb2-steps {
    display: flex; justify-content: center; align-items: center; gap: 8px;
    margin: 28px auto 0;
  }
  .onb2-step {
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    transition: width 0.3s ease, background 200ms ease;
  }
  .onb2-step.is-active { width: 46px; background: var(--petrol); }
</style>
