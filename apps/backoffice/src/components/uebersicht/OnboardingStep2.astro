---
// Onboarding · Screen 2 — „Wähle deinen Look." (visuelle Galerie)
//
// Galerie statt Listen-Auswahl: drei Karten nebeneinander, je eine pro Gästemappe-
// Theme (Bauhaus / Editorial / Maison). Jede Karte zeigt eine ECHTE, verkleinerte
// Vorschau des realen Gäste-Home im jeweiligen Theme (GuestPhoneView — nicht
// stilisiert nachgebaut). Auswahl = Petrol-Kante + Häkchen. Der QR erscheint erst
// NACH Auswahl, klein unter der Galerie, mit Deep-Link in genau diesen Look
// (?design=<theme>, showcase-only Override in /g/[token].astro). Copy DE-only.

import GuestPhoneView from '@retaha/ui-guest/GuestPhoneView';
import { mapThemeName, type GuestTheme } from '@retaha/ui-guest/types';
import QRCode from 'qrcode';
import { createSupabaseServiceRoleInstance, getOrCreateShowcaseUrl } from '@retaha/auth';

interface Props {
  hotelId: string;
  hotelName?: string;
  userId: string;
}
const { hotelId, hotelName: hotelNameProp, userId } = Astro.props;

const sb = createSupabaseServiceRoleInstance();
const { data: h } = await sb
  .from('hotels')
  .select('name, slug, logo_primary, logo_dark, theme, design_identity, splash_background, brand_primary')
  .eq('id', hotelId)
  .maybeSingle();

let eveName = 'Eve';
try {
  const { data: s } = await sb.from('hotel_settings').select('eve_name').eq('hotel_id', hotelId).maybeSingle();
  if (s?.eve_name) eveName = s.eve_name;
} catch { /* eve_name optional */ }

const hotelName = (h as any)?.name ?? hotelNameProp ?? 'Dein Hotel';
const brandTheme = (h as any)?.theme ?? 'coffee';
const rawBrand: string | null = (h as any)?.brand_primary ?? null;
// Phone-Akzent = echte Hotelfarbe; Default-Pink/leer → Sage-Fallback (kein Petrol).
const phoneAccent = rawBrand && rawBrand.toLowerCase() !== '#ff4a82' ? rawBrand : '#5C9070';

function themeFor(designIdentity: GuestTheme['designIdentity']): GuestTheme {
  return {
    primary: phoneAccent,
    themeName: (['coffee', 'ocean', 'forest', 'custom'].includes(brandTheme) ? brandTheme : 'coffee') as GuestTheme['themeName'],
    guestThemeName: mapThemeName(brandTheme),
    designIdentity,
    logoUrl: (h as any)?.logo_primary ?? null,
    logoDarkUrl: (h as any)?.logo_dark ?? null,
    heroBackground: (h as any)?.splash_background ?? null,
    hotelName,
    eveName,
  };
}

// Themes der Galerie (bestehende Guest-Design-Identitäten).
const LOOKS = [
  { id: 'bauhaus',   label: 'Bauhaus',   desc: 'Anti-Luxus · Selbstbewusst' },
  { id: 'editorial', label: 'Editorial', desc: 'Magazinhaft · Storytelling' },
  { id: 'maison',    label: 'Maison',    desc: 'Klassisch · Opulent' },
];

let guestUrl: string | null = null;
try { guestUrl = await getOrCreateShowcaseUrl(hotelId, userId); } catch { /* nicht-fatal */ }
function withDesign(url: string, id: string): string {
  return `${url}${url.includes('?') ? '&' : '?'}design=${id}`;
}

const looks = [] as Array<{ id: string; label: string; desc: string; theme: GuestTheme; qrSvg: string | null }>;
for (const l of LOOKS) {
  let qrSvg: string | null = null;
  if (guestUrl) {
    try {
      qrSvg = await QRCode.toString(withDesign(guestUrl, l.id), {
        type: 'svg', errorCorrectionLevel: 'M', margin: 1,
        color: { dark: '#0A0A0A', light: '#FAFAF8' },
      });
    } catch { /* QR nicht-fatal */ }
  }
  looks.push({ ...l, theme: themeFor(l.id as GuestTheme['designIdentity']), qrSvg });
}
---

<section class="lr" data-onb-step="2" style="display:none">
  <div class="lr-body">

    <div class="lr-head">
      <h1 class="lr-h1">Wähle deinen <span class="lr-nb">Look<span class="lr-dot"></span></span></h1>
      <p class="lr-sub">Jeder Look gibt deiner Gästemappe einen eigenen Charakter — von schlicht und selbstbewusst bis klassisch und opulent. Wähl einen aus, und du kannst ihn dir direkt aufs Handy holen, genau so, wie ihn deine Gäste sehen werden.</p>
    </div>

    <!-- Galerie: drei echte Theme-Vorschauen nebeneinander -->
    <div class="lr-gallery" role="radiogroup" aria-label="Gästemappen-Look wählen">
      {looks.map(l => (
        <button type="button" class="lr-gcard" data-look={l.id} data-look-name={l.label} role="radio" aria-checked="false">
          <div class="lr-gcard__frame">
            <div class="lr-gcard__scaler">
              <GuestPhoneView theme={l.theme} previewMode={true} noScroll={true} />
            </div>
            <span class="lr-gcard__check" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          </div>
          <div class="lr-gcard__meta">
            <span class="lr-gcard__name">{l.label}</span>
            <span class="lr-gcard__desc">{l.desc}</span>
          </div>
        </button>
      ))}
    </div>

    <!-- QR erst nach Auswahl; vorher nur ruhige Aufforderung -->
    <div class="lr-reveal">
      <p class="lr-reveal__prompt" data-reveal-prompt>Wähl einen Look, um ihn dir aufs Handy zu holen.</p>
      <div class="lr-reveal__card" data-reveal-card hidden>
        <div class="lr-reveal__qr">
          {looks.map(l => (
            <div class="lr-qr-view" data-look-qr={l.id} role="img" aria-label="QR-Code zur Gästemappe" hidden>
              {l.qrSvg ? <Fragment set:html={l.qrSvg} /> : <div class="lr-qr-fallback">QR n/v</div>}
            </div>
          ))}
        </div>
        <p class="lr-reveal__label" data-reveal-label></p>
      </div>
    </div>

    <div class="lr-cta-row">
      <button type="button" class="lr-next" data-onb-goto="3">Weiter →</button>
      <button type="button" class="lr-skip" data-onb-action="skip">Setup überspringen</button>
    </div>

  </div>

  <!-- Schritt-Balken — Schritt 2 aktiv, klickbar -->
  <div class="lr-steps" role="group" aria-label="Onboarding-Schritte">
    {[1, 2, 3, 4].map(i => (
      <button
        type="button"
        class:list={['lr-step', { 'is-active': i === 2 }]}
        data-onb-goto={i}
        aria-label={`Schritt ${i}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .lr {
    --petrol: #14616E;
    max-width: 1140px; width: 100%;
    margin: 8px auto 12px;
    padding: 26px 32px 32px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
  }
  .lr-body { flex: 1 1 auto; display: flex; flex-direction: column; justify-content: center; gap: 26px; }

  /* Kopf (zentriert) */
  .lr-head { text-align: center; max-width: 720px; margin: 0 auto; }
  .lr-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(36px, 4.6vw, 60px); line-height: 1.0;
    letter-spacing: -0.03em; color: var(--ink); margin: 0 0 14px;
    white-space: nowrap;
  }
  @media (max-width: 480px) { .lr-h1 { white-space: normal; } }
  .lr-nb { white-space: nowrap; }
  .lr-dot { display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: var(--petrol); margin-left: 4px; vertical-align: baseline; }
  .lr-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 15.5px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0 auto; max-width: 62ch;
  }

  /* Galerie */
  .lr-gallery { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; }
  .lr-gcard {
    -webkit-appearance: none; appearance: none; border: none; background: transparent;
    display: flex; flex-direction: column; align-items: center; gap: 12px;
    padding: 0; cursor: pointer; text-align: center;
  }
  .lr-gcard__frame {
    position: relative;
    width: 232px; height: 300px;
    overflow: hidden; border-radius: var(--r);
    border: 1.5px solid var(--border); background: #fff;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .lr-gcard:hover .lr-gcard__frame { border-color: var(--ink-faint); transform: translateY(-2px); box-shadow: 0 8px 26px -12px rgba(10,10,10,0.28); }
  .lr-gcard.is-active .lr-gcard__frame { border-color: var(--petrol); box-shadow: inset 0 0 0 1px var(--petrol); }
  .lr-gcard__scaler {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 804px;
    transform: scale(0.5949); transform-origin: top left;  /* 232 / 390 */
    pointer-events: none;
  }
  .lr-gcard__check {
    position: absolute; top: 8px; right: 8px;
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--petrol); color: #fff;
    display: none; place-items: center; z-index: 2;
    box-shadow: 0 2px 8px -2px rgba(10,10,10,0.4);
  }
  .lr-gcard.is-active .lr-gcard__check { display: grid; }
  .lr-gcard__meta { display: flex; flex-direction: column; gap: 2px; }
  .lr-gcard__name { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500; color: var(--ink); letter-spacing: -0.01em; }
  .lr-gcard.is-active .lr-gcard__name { color: var(--petrol); }
  .lr-gcard__desc { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.45)); }

  /* QR-Bereich */
  .lr-reveal { min-height: 108px; display: flex; align-items: center; justify-content: center; }
  .lr-reveal__prompt {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.08em; color: var(--ink-muted, rgba(10,10,10,0.45)); margin: 0; text-align: center;
  }
  .lr-reveal__prompt[hidden] { display: none; }
  .lr-reveal__card {
    display: flex; align-items: center; gap: 16px;
    padding: 12px 16px;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--r);
  }
  .lr-reveal__card[hidden] { display: none; }
  .lr-reveal__qr {
    flex-shrink: 0; width: 92px; height: 92px;
    background: var(--bg-deep); border-radius: var(--r-sm); border: 1px solid var(--border);
    padding: 7px; box-sizing: content-box;
  }
  .lr-qr-view { width: 92px; height: 92px; }
  .lr-qr-view[hidden] { display: none; }
  .lr-qr-view :global(svg) { display: block; width: 100%; height: 100%; border-radius: 4px; }
  .lr-qr-fallback { width: 100%; height: 100%; display: grid; place-items: center; font-size: 10px; color: var(--ink-muted); text-align: center; }
  .lr-reveal__label {
    margin: 0; max-width: 200px;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 13px; line-height: 1.45; color: var(--ink-soft, rgba(10,10,10,0.6));
  }

  /* CTA */
  .lr-cta-row { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .lr-next {
    -webkit-appearance: none; appearance: none; border: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    cursor: pointer; transition: background 0.15s ease;
  }
  .lr-next:hover { background: var(--petrol); }
  .lr-skip {
    -webkit-appearance: none; appearance: none; border: none;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; cursor: pointer; transition: color 0.15s ease;
  }
  .lr-skip:hover { color: var(--ink); }

  /* Schritt-Balken */
  .lr-steps { display: flex; justify-content: center; align-items: center; gap: 8px; margin: 22px auto 0; }
  .lr-step {
    -webkit-appearance: none; appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    cursor: pointer; transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .lr-step.is-active { width: 46px; background: var(--petrol); }
  .lr-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .lr-step:disabled { cursor: default; }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-onb-step="2"]');
    if (!root) return;
    var cards = Array.prototype.slice.call(root.querySelectorAll('.lr-gcard'));
    var qrs = Array.prototype.slice.call(root.querySelectorAll('[data-look-qr]'));
    var prompt = root.querySelector('[data-reveal-prompt]');
    var revealCard = root.querySelector('[data-reveal-card]');
    var label = root.querySelector('[data-reveal-label]');

    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        var id = card.getAttribute('data-look');
        var name = card.getAttribute('data-look-name') || '';
        cards.forEach(function (c) {
          var on = c === card;
          c.classList.toggle('is-active', on);
          c.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        qrs.forEach(function (q) { q.hidden = q.getAttribute('data-look-qr') !== id; });
        if (label) label.textContent = name + '-Look — scann, um ihn auf deinem Handy zu sehen.';
        if (prompt) prompt.hidden = true;
        if (revealCard) revealCard.hidden = false;
      });
    });
  })();
</script>
