---
// Onboarding · Screen 3 — „Wähl deinen Look." (mach's zu deinem)
//
// Läuft als dritte Sektion DERSELBEN /uebersicht-Seite (gleiches Backoffice-
// Layout/Chrome). Look-Auswahl + Mockup sind 1:1 von /branding übernommen:
//   - Look-Karte = .di-card (ThemeSection) — aktuell nur Bauhaus (wie dort,
//     SHOW_ALL_IDENTITIES=false). Weitere Looks später ergänzen.
//   - Mockup = BauhausPreview im .bp-outer-Bezel (BrandMiniPreview).
// Copy DE-only.

import BauhausPreview from '../branding/previews/BauhausPreview.astro';
import { createSupabaseServiceRoleInstance } from '@retaha/auth';

interface Props {
  hotelId: string;
  hotelName?: string;
}
const { hotelId, hotelName: hotelNameProp } = Astro.props;

// Echte Branding-Werte des Betreiber-Hotels (wie /branding: Name + Markenfarbe).
const sb = createSupabaseServiceRoleInstance();
const { data: h } = await sb
  .from('hotels')
  .select('name, brand_primary')
  .eq('id', hotelId)
  .maybeSingle();

const hotelName = (h as any)?.name ?? hotelNameProp ?? 'Dein Hotel';
const brandPrimary: string | null = (h as any)?.brand_primary ?? null;
---

<section class="onb3" data-onb-step="3" style="display:none">
  <div class="onb3-split">

    <!-- Links: Copy + Look-Auswahl (1:1 .di-card von /branding) -->
    <div class="onb3-left">
      <h1 class="onb3-h1">Wähl deinen <span class="onb3-nb">Look<span class="onb3-dot"></span></span></h1>
      <p class="onb3-sub">Mach's zu deinem. Deine Gästemappe trägt schon dein Branding — Logo, Farben, Eve. Tipp einen Look an, die Vorschau zeigt ihn dir sofort.</p>

      <div class="di-cards" role="radiogroup" aria-label="Gästemappen-Look wählen">
        <button class="di-card is-active" type="button" data-look="bauhaus" role="radio" aria-checked="true">
          <div class="di-card__hint di-card__hint--bauhaus">
            <span class="bh-initial">B</span>
            <span class="bh-pink-dot"></span>
          </div>
          <div class="di-card__body">
            <div class="di-card__title bauhaus-title">Bauhaus</div>
            <div class="di-card__desc">Anti-Luxus · Selbstbewusst</div>
            <div class="di-card__meta">Space Grotesk · Pink-Punkt</div>
          </div>
        </button>
      </div>
      <p class="onb3-hint">Weitere Looks kommen bald — dann tippst du dich durch und die Vorschau wechselt live.</p>

      <div class="onb3-cta-row">
        <button type="button" class="onb3-next" data-onb-goto="4" title="Weitere Schritte folgen">Weiter →</button>
        <button type="button" class="onb3-skip" data-onb-action="skip">Setup überspringen</button>
      </div>
    </div>

    <!-- Rechts: Mockup (1:1 BauhausPreview im .bp-outer-Bezel von /branding) -->
    <div class="onb3-right">
      <div class="bp-outer">
        <div class="bp-inner">
          <div>
            <BauhausPreview hotelName={hotelName} brandPrimary={brandPrimary} />
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Schritt-Balken — Schritt 3 aktiv, klickbar (vor/zurück) -->
  <div class="onb3-steps" role="group" aria-label="Onboarding-Schritte">
    {[1, 2, 3, 4, 5].map(i => (
      <button
        type="button"
        class:list={['onb3-step', { 'is-active': i === 3 }]}
        data-onb-goto={i}
        aria-label={`Schritt ${i}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .onb3 {
    --petrol: #14616E;
    max-width: 1140px; width: 100%;
    margin: 8px auto 12px;
    padding: 32px 32px 40px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
  }
  .onb3-split {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: 1fr minmax(0, 320px);
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 860px) {
    .onb3-split { grid-template-columns: 1fr; gap: 40px; justify-items: center; text-align: center; }
  }

  /* Links — Headline identisch zu Screen 1 */
  .onb3-left { min-width: 0; max-width: 560px; }
  .onb3-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(44px, 6vw, 88px); line-height: 0.96;
    letter-spacing: -0.035em; color: var(--ink); margin: 0 0 24px;
  }
  .onb3-nb { white-space: nowrap; }
  .onb3-dot {
    display: inline-block; width: 14px; height: 14px; border-radius: 50%;
    background: var(--petrol); margin-left: 4px; vertical-align: baseline;
  }
  .onb3-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0 0 24px; max-width: 46ch;
  }
  @media (max-width: 860px) { .onb3-sub { margin-left: auto; margin-right: auto; } }

  /* ── Look-Karte: 1:1 aus /branding ThemeSection (.di-card) ───────── */
  .di-cards { display: flex; flex-direction: column; gap: 10px; margin: 0 0 12px; }
  @media (max-width: 860px) { .di-cards { align-items: center; } }
  .di-card {
    display: flex; align-items: center;
    width: 100%; max-width: 360px; text-align: left; padding: 0;
    border: 1px solid var(--border); border-radius: var(--r);
    background: var(--surface); cursor: pointer;
    transition: border-color 200ms, box-shadow 200ms, transform 200ms;
    overflow: hidden;
    -webkit-appearance: none; appearance: none;
  }
  .di-card:hover {
    border-color: var(--ink-faint);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,.06);
  }
  .di-card.is-active {
    border-color: var(--sage);
    box-shadow: 0 0 0 2px var(--sage-soft);
  }
  .di-card__hint {
    width: 76px; min-height: 80px; flex-shrink: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 7px; padding: 12px 8px;
  }
  .di-card__hint--bauhaus { background: #F5F5F3; }
  .bh-initial {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 28px; font-weight: 600;
    color: #0A0A0A; letter-spacing: -.03em; line-height: 1;
  }
  .bh-pink-dot { width: 8px; height: 8px; background: #FF4A82; border-radius: 50%; }
  .di-card__body { padding: 14px 16px 14px 12px; flex: 1; }
  .di-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 500; color: var(--ink);
    margin-bottom: 3px;
  }
  .bauhaus-title::after {
    content: '';
    display: inline-block; width: 6px; height: 6px;
    background: #FF4A82; border-radius: 50%;
    margin-left: 5px; vertical-align: middle;
  }
  .di-card__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-soft);
    letter-spacing: .02em; line-height: 1.5;
  }
  .di-card__meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; color: var(--ink-faint);
    letter-spacing: .1em; text-transform: uppercase; margin-top: 2px;
  }

  .onb3-hint {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 13px; line-height: 1.5; color: var(--ink-muted, rgba(10,10,10,0.45));
    margin: 0 0 26px; max-width: 42ch;
  }
  @media (max-width: 860px) { .onb3-hint { margin-left: auto; margin-right: auto; } }

  .onb3-cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 860px) { .onb3-cta-row { justify-content: center; } }
  .onb3-next {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    cursor: pointer; transition: background 0.15s ease;
  }
  .onb3-next:hover { background: var(--petrol); }
  .onb3-next:disabled { opacity: 0.4; cursor: default; background: var(--ink); }
  .onb3-skip {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; cursor: pointer; transition: color 0.15s ease;
  }
  .onb3-skip:hover { color: var(--ink); }

  /* ── Mockup: 1:1 aus /branding BrandMiniPreview (.bp-outer/.bp-inner) ── */
  .onb3-right { display: flex; justify-content: center; }
  .bp-outer {
    width: 260px;
    height: 563px;
    overflow: hidden;
    position: relative;
    border-radius: 36px;
    margin: 4px auto;
    box-shadow:
      0 0 0 8px #0A0A0A,
      0 0 0 10px #2A2A2A,
      0 20px 48px -8px rgba(0,0,0,0.38);
  }
  .bp-inner {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 844px;
    transform: scale(0.6667);
    transform-origin: top left;
    pointer-events: none;
  }
  .bp-inner > div {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 844px;
  }

  /* Schritt-Balken (segmentiert, klickbar — wie Screen 1/2) */
  .onb3-steps {
    display: flex; justify-content: center; align-items: center; gap: 8px;
    margin: 28px auto 0;
  }
  .onb3-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    cursor: pointer;
    transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .onb3-step.is-active { width: 46px; background: var(--petrol); }
  .onb3-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .onb3-step:disabled { cursor: default; }
</style>
