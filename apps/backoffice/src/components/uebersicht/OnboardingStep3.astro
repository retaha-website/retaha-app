---
// Onboarding · Screen 3 — „Wähl deinen Look." (mach's zu deinem)
//
// Läuft als dritte Sektion DERSELBEN /uebersicht-Seite (gleiches Backoffice-
// Layout/Chrome). Links Copy + Look-Karten zum Antippen, rechts die echte
// Gästemappe-Home-Vorschau (GuestPhoneView) im gewählten Look — wechselt live.
// Aktuell gibt es nur EINEN Look (das aktuelle Branding); weitere folgen, dann
// erscheinen automatisch mehr Karten. Copy DE-only.

import GuestPhoneView from '@retaha/ui-guest/GuestPhoneView';
import { mapThemeName, type GuestTheme } from '@retaha/ui-guest/types';
import { createSupabaseServiceRoleInstance } from '@retaha/auth';

interface Props {
  hotelId: string;
  hotelName?: string;
}
const { hotelId, hotelName: hotelNameProp } = Astro.props;

// Branding-Daten des Betreiber-Hotels (echt — Vorschau zieht echte Werte).
const sb = createSupabaseServiceRoleInstance();
const { data: h } = await sb
  .from('hotels')
  .select('name, slug, logo_primary, logo_dark, theme, design_identity, splash_background, brand_primary')
  .eq('id', hotelId)
  .maybeSingle();

let eveName = 'Eve';
try {
  const { data: s } = await sb.from('hotel_settings').select('eve_name').eq('hotel_id', hotelId).maybeSingle();
  if (s?.eve_name) eveName = s.eve_name;
} catch { /* eve_name optional */ }

const hotelName = (h as any)?.name ?? hotelNameProp;
const brandTheme = (h as any)?.theme ?? 'coffee';
const designIdentity = ((h as any)?.design_identity ?? 'bauhaus') as GuestTheme['designIdentity'];
const rawBrand: string | null = (h as any)?.brand_primary ?? null;
// Phone-Akzent = echte Hotelfarbe; Default-Pink/leer → Sage-Fallback (kein Pink im Phone).
const phoneAccent = rawBrand && rawBrand.toLowerCase() !== '#ff4a82' ? rawBrand : '#5C9070';

const baseTheme: GuestTheme = {
  primary: phoneAccent,
  themeName: (['coffee', 'ocean', 'forest', 'custom'].includes(brandTheme) ? brandTheme : 'coffee') as GuestTheme['themeName'],
  guestThemeName: mapThemeName(brandTheme),
  designIdentity,
  logoUrl: (h as any)?.logo_primary ?? null,
  logoDarkUrl: (h as any)?.logo_dark ?? null,
  heroBackground: (h as any)?.splash_background ?? null,
  hotelName,
  eveName,
};

// Verfügbare Looks. Aktuell genau einer (das aktuelle Branding). Weitere Designs
// hier ergänzen → Karten + Live-Vorschau-Wechsel funktionieren automatisch.
const LOOK_LABELS: Record<string, string> = {
  bauhaus: 'Bauhaus', classic: 'Klassisch', editorial: 'Editorial', maison: 'Maison',
};
const looks = [
  { id: designIdentity, label: LOOK_LABELS[designIdentity] ?? 'Dein Look', theme: baseTheme },
];
---

<section class="onb3" data-onb-step="3" style="display:none">
  <div class="onb3-split">

    <!-- Links: Copy + Look-Auswahl -->
    <div class="onb3-left">
      <h1 class="onb3-h1">Wähl deinen Look<span class="onb3-dot"></span></h1>
      <p class="onb3-sub">Mach's zu deinem. Deine Gästemappe trägt schon dein Branding — Logo, Farben, Eve. Tipp einen Look an, die Vorschau zeigt ihn dir sofort.</p>

      <div class="onb3-looks" role="radiogroup" aria-label="Gästemappen-Look wählen">
        {looks.map((look, i) => (
          <button
            type="button"
            class:list={['onb3-look', { 'is-selected': i === 0 }]}
            data-look={look.id}
            role="radio"
            aria-checked={i === 0 ? 'true' : 'false'}
          >
            <span class="onb3-look-swatch" style={`background:${look.theme.primary}`}></span>
            <span class="onb3-look-text">
              <span class="onb3-look-name">{look.label}</span>
              <span class="onb3-look-sub">{i === 0 ? 'Aktiv' : 'Antippen'}</span>
            </span>
            <span class="onb3-look-check" aria-hidden="true">✓</span>
          </button>
        ))}
      </div>
      <p class="onb3-hint">Weitere Looks kommen bald — dann tippst du dich durch und die Vorschau wechselt live.</p>

      <div class="onb3-cta-row">
        <button type="button" class="onb3-next" data-onb-goto="4" title="Weitere Schritte folgen">Weiter →</button>
        <button type="button" class="onb3-skip" data-onb-action="skip">Setup überspringen</button>
      </div>
    </div>

    <!-- Rechts: echte Gästemappe-Home im gewählten Look -->
    <div class="onb3-right">
      <div class="onb3-phone-bezel">
        <div class="onb3-phone-scaler">
          {looks.map((look, i) => (
            <div data-look-preview={look.id} style={i === 0 ? '' : 'display:none'}>
              <GuestPhoneView theme={look.theme} previewMode={true} noScroll={true} />
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>

  <!-- Schritt-Balken — Schritt 3 aktiv, klickbar (vor/zurück) -->
  <div class="onb3-steps" role="group" aria-label="Onboarding-Schritte">
    {[1, 2, 3, 4, 5].map(i => (
      <button
        type="button"
        class:list={['onb3-step', { 'is-active': i === 3 }]}
        data-onb-goto={i}
        aria-label={`Schritt ${i}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .onb3 {
    --petrol: #14616E;
    max-width: 1140px; width: 100%;
    margin: 8px auto 12px;
    padding: 32px 32px 40px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
  }
  .onb3-split {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: 1fr minmax(0, 340px);
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 860px) {
    .onb3-split { grid-template-columns: 1fr; gap: 40px; justify-items: center; text-align: center; }
  }

  /* Links — Headline identisch zu Screen 1 */
  .onb3-left { min-width: 0; max-width: 560px; }
  .onb3-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(44px, 6vw, 88px); line-height: 0.96;
    letter-spacing: -0.035em; color: var(--ink); margin: 0 0 24px;
  }
  .onb3-dot {
    display: inline-block; width: 14px; height: 14px; border-radius: 50%;
    background: var(--petrol); margin-left: 4px; vertical-align: baseline;
  }
  .onb3-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0 0 24px; max-width: 46ch;
  }
  @media (max-width: 860px) { .onb3-sub { margin-left: auto; margin-right: auto; } }

  /* Look-Karten */
  .onb3-looks { display: flex; flex-wrap: wrap; gap: 12px; margin: 0 0 12px; }
  @media (max-width: 860px) { .onb3-looks { justify-content: center; } }
  .onb3-look {
    appearance: none; -webkit-appearance: none;
    display: inline-flex; align-items: center; gap: 12px;
    min-width: 180px; padding: 12px 16px;
    background: var(--surface, #fff);
    border: 1px solid var(--border, rgba(10,10,10,0.12));
    border-radius: var(--r, 12px);
    cursor: pointer; text-align: left;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .onb3-look:hover { border-color: var(--petrol); }
  .onb3-look.is-selected {
    border-color: var(--petrol);
    box-shadow: inset 0 0 0 1px var(--petrol);
    background: rgba(20, 97, 110, 0.05);
  }
  .onb3-look-swatch {
    flex-shrink: 0; width: 26px; height: 26px; border-radius: 7px;
    box-shadow: inset 0 0 0 1px rgba(10,10,10,0.10);
  }
  .onb3-look-text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .onb3-look-name {
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--ink); letter-spacing: -0.01em;
  }
  .onb3-look-sub {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.45));
  }
  .onb3-look-check {
    margin-left: auto; flex-shrink: 0;
    width: 18px; height: 18px; border-radius: 50%;
    display: grid; place-items: center;
    background: var(--petrol); color: #fff; font-size: 11px;
    opacity: 0; transform: scale(0.6); transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .onb3-look.is-selected .onb3-look-check { opacity: 1; transform: scale(1); }

  .onb3-hint {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 13px; line-height: 1.5; color: var(--ink-muted, rgba(10,10,10,0.45));
    margin: 0 0 26px; max-width: 42ch;
  }
  @media (max-width: 860px) { .onb3-hint { margin-left: auto; margin-right: auto; } }

  .onb3-cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  @media (max-width: 860px) { .onb3-cta-row { justify-content: center; } }
  .onb3-next {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    cursor: pointer; transition: background 0.15s ease;
  }
  .onb3-next:hover { background: var(--petrol); }
  .onb3-next:disabled { opacity: 0.4; cursor: default; background: var(--ink); }
  .onb3-skip {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; cursor: pointer; transition: color 0.15s ease;
  }
  .onb3-skip:hover { color: var(--ink); }

  /* Rechts: Phone */
  .onb3-right { display: flex; justify-content: center; }
  .onb3-phone-bezel {
    width: 320px; height: 660px;
    overflow: hidden; position: relative;
    border-radius: 44px;
    box-shadow:
      0 0 0 9px #0A0A0A,
      0 0 0 11px #2A2A2A,
      0 28px 64px -18px rgba(0,0,0,0.42);
    background: #000;
  }
  .onb3-phone-scaler {
    position: absolute; top: 0; left: 0;
    width: 390px; height: 804px;
    transform: scale(0.8205);   /* 320 / 390 */
    transform-origin: top left;
  }
  @media (max-width: 860px) {
    .onb3-phone-bezel { width: 280px; height: 578px; }
    .onb3-phone-scaler { transform: scale(0.7179); } /* 280 / 390 */
  }

  /* Schritt-Balken (segmentiert, klickbar — wie Screen 1/2) */
  .onb3-steps {
    display: flex; justify-content: center; align-items: center; gap: 8px;
    margin: 28px auto 0;
  }
  .onb3-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    cursor: pointer;
    transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .onb3-step.is-active { width: 46px; background: var(--petrol); }
  .onb3-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .onb3-step:disabled { cursor: default; }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-onb-step="3"]');
    if (!root) return;
    var cards = Array.prototype.slice.call(root.querySelectorAll('[data-look]'));
    var previews = Array.prototype.slice.call(root.querySelectorAll('[data-look-preview]'));
    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        var id = card.getAttribute('data-look');
        cards.forEach(function (c) {
          var on = c === card;
          c.classList.toggle('is-selected', on);
          c.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        previews.forEach(function (p) {
          p.style.display = (p.getAttribute('data-look-preview') === id) ? '' : 'none';
        });
      });
    });
  })();
</script>
