---
// Onboarding · Screen 3 — „Eve ist erst der Anfang." (Roadmap)
//
// Läuft als dritte Sektion DERSELBEN /overview-Seite. Kopf links oben, darunter
// eine volle-Breite-Box mit dem gerade abgeschlossenen Schritt (Gästemappe + Eve,
// markiert „Abgeschlossen"), darunter die nächsten zwei Schritte (Direktbuchung,
// Wallet/WhatsApp/Wiederkehr) klar als Steps nummeriert. Copy DE-only.
---

<section class="onb3" data-onb-step="3" style="display:none">
  <div class="onb3-body">

    <div class="onb3-head">
      <h1 class="onb3-h1">Eve ist erst der <span class="onb3-nb">Anfang<span class="onb3-dot"></span></span></h1>
      <p class="onb3-sub">Eve begleitet deine Gäste mitten im Aufenthalt — aber die Reise ist länger. Von der Direktbuchung bis zur Wiederkehr deckst du sie Schritt für Schritt ab. Kein Muss, nur ein Ausblick.</p>
    </div>

    <div class="onb3-list">

      <!-- Abgeschlossen (volle Breite) -->
      <article class="onb3-row onb3-row--done">
        <span class="onb3-ind onb3-ind--done" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <div class="onb3-row__body">
          <span class="onb3-row__phase">Während dem Aufenthalt · gerade aufgesetzt</span>
          <h2 class="onb3-row__title">Gästemappe &amp; Eve</h2>
          <p class="onb3-row__desc">Dein digitaler Concierge ist live — rund um die Uhr, in 11 Sprachen. Genau das hast du gerade aufgesetzt.</p>
        </div>
        <span class="onb3-row__status onb3-row__status--done">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="12" height="12"><polyline points="20 6 9 17 4 12"/></svg>
          Abgeschlossen
        </span>
      </article>

      <!-- Nächster Schritt 1 -->
      <article class="onb3-row onb3-row--step">
        <span class="onb3-ind onb3-ind--step" aria-hidden="true">2</span>
        <div class="onb3-row__body">
          <span class="onb3-row__phase">Vor der Anreise</span>
          <h2 class="onb3-row__title">Direktbuchung</h2>
          <p class="onb3-row__desc">Gäste buchen direkt bei dir — ohne Portalprovision. Mehr Marge und die eigene Beziehung von der ersten Sekunde an.</p>
        </div>
        <span class="onb3-row__status onb3-row__status--soon">Bald</span>
      </article>

      <!-- Nächster Schritt 2 -->
      <article class="onb3-row onb3-row--step">
        <span class="onb3-ind onb3-ind--step" aria-hidden="true">3</span>
        <div class="onb3-row__body">
          <span class="onb3-row__phase">Nach der Abreise</span>
          <h2 class="onb3-row__title">Wallet, WhatsApp &amp; Wiederkehr</h2>
          <p class="onb3-row__desc">Bleib in Kontakt: Wallet-Karte aufs Handy, Nachrichten per WhatsApp, Anreize für den nächsten Besuch — ob im Restaurant oder im Hotel.</p>
        </div>
        <span class="onb3-row__status onb3-row__status--soon">Bald</span>
      </article>

    </div>

    <div class="onb3-cta-row">
      <button type="button" class="onb3-next" data-onb-goto="4" title="Zum Abschluss">Weiter →</button>
      <button type="button" class="onb3-skip" data-onb-action="skip">Setup überspringen</button>
    </div>

  </div>

  <!-- Schritt-Balken — Schritt 3 aktiv, klickbar (vor/zurück) -->
  <div class="onb3-steps" role="group" aria-label="Onboarding-Schritte">
    <button type="button" class="onb3-back" data-onb-goto={2} aria-label="Ein Schritt zurück" title="Ein Schritt zurück">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15" aria-hidden="true"><path d="M3 9h11a5 5 0 0 1 0 10H9"/><polyline points="7 5 3 9 7 13"/></svg>
    </button>
    {[1, 2, 3, 4].map(i => (
      <button
        type="button"
        class:list={['onb3-step', { 'is-active': i === 3 }]}
        data-onb-goto={i}
        aria-label={`Schritt ${i}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .onb3 {
    --petrol: #14616E;
    --petrol-soft: rgba(20, 97, 110, 0.06);
    max-width: 1280px; width: calc(100% - 64px);
    margin: 32px auto 32px;
    padding: 32px 32px 40px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: 0 12px 26px rgba(0,0,0,.06);
  }
  .onb3-body {
    flex: 1 1 auto;
    display: flex; flex-direction: column; justify-content: center;
    gap: 28px;
  }

  /* Kopf — links bündig */
  .onb3-head { text-align: left; max-width: 1040px; }
  .onb3-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(40px, 5vw, 72px); line-height: 0.98;
    letter-spacing: -0.035em; color: var(--ink); margin: 0 0 16px;
  }
  .onb3-nb { white-space: nowrap; }
  .onb3-dot {
    display: inline-block; width: 14px; height: 14px; border-radius: 50%;
    background: var(--petrol); margin-left: 4px; vertical-align: baseline;
  }
  .onb3-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65));
    margin: 0; max-width: 90ch;
  }

  /* Roadmap-Liste (volle Breite) */
  .onb3-list { display: flex; flex-direction: column; gap: 12px; width: 100%; }
  .onb3-row {
    display: flex; align-items: center; gap: 18px;
    width: 100%; padding: 18px 22px;
    background: var(--surface);
    border: 1px solid var(--border); border-radius: var(--r);
  }
  .onb3-row--done {
    border-color: var(--petrol);
    box-shadow: inset 0 0 0 1px var(--petrol);
    background: var(--petrol-soft);
  }

  .onb3-ind {
    flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%;
    display: grid; place-items: center;
    font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 16px;
  }
  .onb3-ind--done { background: var(--petrol); color: #fff; }
  .onb3-ind--step { background: var(--bg-deep, #F0EFEA); color: var(--ink-muted, rgba(10,10,10,0.5)); border: 1px solid var(--border); }

  .onb3-row__body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .onb3-row__phase {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-muted, rgba(10,10,10,0.45));
  }
  .onb3-row--done .onb3-row__phase { color: var(--petrol); }
  .onb3-row__title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 500;
    font-size: 18px; letter-spacing: -0.015em; color: var(--ink); margin: 0;
  }
  .onb3-row__desc {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 13.5px; line-height: 1.5; color: var(--ink-soft, rgba(10,10,10,0.6)); margin: 0;
  }

  .onb3-row__status {
    flex-shrink: 0; display: inline-flex; align-items: center; gap: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 5px 11px; border-radius: 999px;
  }
  .onb3-row__status--done { color: #fff; background: var(--petrol); }
  .onb3-row__status--soon { color: var(--ink-faint, rgba(10,10,10,0.42)); border: 1px solid var(--border-medium, rgba(10,10,10,0.16)); }

  @media (max-width: 600px) {
    .onb3-row { flex-wrap: wrap; }
    .onb3-row__status { order: 3; }
  }

  /* CTA — links bündig */
  .onb3-cta-row { display: flex; align-items: center; justify-content: flex-start; gap: 12px; flex-wrap: wrap; }
  .onb3-next {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--surface); background: var(--ink);
    border-radius: var(--r, 12px); padding: 13px 26px;
    cursor: pointer; transition: background 0.15s ease;
  }
  .onb3-next:hover { background: var(--petrol); }
  .onb3-next:disabled { opacity: 0.4; cursor: default; background: var(--ink); }
  .onb3-skip {
    appearance: none; -webkit-appearance: none; border: none;
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    background: transparent; cursor: pointer; transition: color 0.15s ease;
  }
  .onb3-skip:hover { color: var(--ink); }

  /* Schritt-Balken (segmentiert, klickbar — wie Screen 1/2) */
  .onb3-steps {
    display: flex; justify-content: center; align-items: center; gap: 8px;
    margin: 28px auto 0;
  }
  .onb3-back {
    appearance: none; -webkit-appearance: none; border: none; background: transparent;
    display: inline-flex; align-items: center; justify-content: center;
    width: 24px; height: 24px; padding: 0; margin-right: 6px; flex: 0 0 auto;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    cursor: pointer; border-radius: 50%;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .onb3-back:hover { color: var(--petrol); background: var(--petrol-soft, rgba(20,97,110,0.08)); }
  .onb3-back:disabled { opacity: 0.35; cursor: default; }
  .onb3-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16));
    cursor: pointer;
    transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .onb3-step.is-active { width: 46px; background: var(--petrol); }
  .onb3-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .onb3-step:disabled { cursor: default; }
</style>
