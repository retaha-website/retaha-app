---
// Onboarding · letzte Sektion — „Du bist live."
//
// Belohnender Abschluss, zweispaltig. LINKS (linksbündig): Live-Badge · Headline ·
// Subtext · Trennstrich · Shop-Hinweis (gedruckte QR/NFC-Karten) · Support · CTA
// „Mach's komplett". RECHTS: Beispielfoto der Karte auf dem Nachttisch (Radius
// wie die Box). Copy DE-only.

interface Props { hotelId: string; userId: string; }
---

<section class="onb5" data-onb-step="4" style="display:none">
  <div class="onb5-body">

    <!-- Links: Copy + Shop + Support + CTA (linksbündig) -->
    <div class="onb5-main">
      <span class="onb5-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="12" height="12" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Live
      </span>

      <h1 class="onb5-h1">Du bist <span class="onb5-nb">live<span class="onb5-dot"></span></span></h1>
      <p class="onb5-sub">Deine Gästemappe ist online — Eve beantwortet ab jetzt jede Gästefrage, rund um die Uhr, in 11 Sprachen. Genau so, wie deine Gäste es erleben.</p>

      <hr class="onb5-divider" />

      <p class="onb5-shop">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span>Lieber gedruckte QR-Codes oder NFC-Karten aus Holz für die Zimmer? <a href="https://retaha.de/shop" target="_blank" rel="noopener" class="onb5-shop__link">Direkt im Shop bestellen</a></span>
      </p>

      <p class="onb5-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <span><strong>Fragen?</strong> Wir sind für dich da — hol dir jederzeit <a href="/hilfe" class="onb5-note__link">Support</a>.</span>
      </p>

      <div class="onb5-cta-row">
        <button type="button" class="onb5-next">
          <span class="onb5-next__label">Mach's komplett</span>
          <span class="onb5-next__arrow" aria-hidden="true">→</span>
          <span class="onb5-next__line" aria-hidden="true"></span>
        </button>
      </div>
    </div>

    <!-- Rechts: Beispielfoto (Karte auf dem Nachttisch) — Foto folgt -->
    <figure class="onb5-photo">
      <div class="onb5-photo__ph" aria-hidden="true">Beispielfoto folgt</div>
      <img src="/onboarding-karte-nachttisch.jpg" alt="Holzkarte mit QR-Code auf einem Nachttisch im Zimmer" onerror="this.remove()" />
    </figure>

  </div>

  <div class="onb5-steps" role="group" aria-label="Onboarding-Schritte">
    <button type="button" class="onb5-back" data-onb-goto={3} aria-label="Ein Schritt zurück" title="Ein Schritt zurück">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15" aria-hidden="true"><path d="M3 9h11a5 5 0 0 1 0 10H9"/><polyline points="7 5 3 9 7 13"/></svg>
    </button>
    {[1, 2, 3, 4].map(i => (
      <button type="button" class:list={['onb5-step', { 'is-active': i === 4 }]} data-onb-goto={i} aria-label={`Schritt ${i}`}></button>
    ))}
  </div>
</section>

<style>
  .onb5 {
    --petrol: #14616E;
    max-width: 1280px; width: calc(100% - 64px);
    margin: 32px auto 32px;
    padding: 32px 32px 40px;
    box-sizing: border-box;
    display: flex; flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: 0 12px 26px rgba(0,0,0,.06);
  }
  .onb5-body {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 440px);
    gap: 56px;
    align-items: center;
    width: 100%;
  }
  @media (max-width: 900px) {
    .onb5-body { grid-template-columns: 1fr; gap: 32px; }
  }

  /* Links — linksbündig */
  .onb5-main {
    display: flex; flex-direction: column; align-items: flex-start;
    gap: 16px; text-align: left; max-width: 600px;
  }

  .onb5-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: #fff; background: var(--petrol); padding: 5px 11px; border-radius: 999px;
  }

  .onb5-h1 {
    font-family: 'Space Grotesk', sans-serif; font-weight: 400;
    font-size: clamp(40px, 5vw, 72px); line-height: 0.98;
    letter-spacing: -0.035em; color: var(--ink); margin: 0;
  }
  .onb5-nb { white-space: nowrap; }
  .onb5-dot { display: inline-block; width: 14px; height: 14px; border-radius: 50%; background: var(--petrol); margin-left: 4px; vertical-align: baseline; }
  .onb5-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.6; color: var(--ink-soft, rgba(10,10,10,0.65)); margin: 0; max-width: 56ch;
  }

  .onb5-divider {
    width: 100%; height: 0; border: none; border-top: 1px solid var(--border);
    margin: 8px 0;
  }

  .onb5-shop {
    display: flex; align-items: flex-start; gap: 9px; margin: 0;
    font-family: 'Inter Tight', sans-serif; font-size: 13.5px; line-height: 1.5;
    color: var(--ink-soft, rgba(10,10,10,0.6));
  }
  .onb5-shop svg { color: var(--petrol); flex-shrink: 0; margin-top: 1px; }

  .onb5-note {
    display: flex; align-items: flex-start; gap: 9px; margin: 0;
    font-family: 'Inter Tight', sans-serif; font-size: 13.5px; line-height: 1.5; color: var(--ink-muted, rgba(10,10,10,0.55));
  }
  .onb5-note svg { color: var(--petrol); flex-shrink: 0; margin-top: 1px; }
  .onb5-note strong { color: var(--ink); font-weight: 600; }
  .onb5-note__link, .onb5-shop__link {
    color: var(--petrol); font-weight: 500;
    text-decoration: underline; text-underline-offset: 2px;
  }
  .onb5-note__link:hover, .onb5-shop__link:hover { text-decoration: none; }

  .onb5-cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 6px; }
  .onb5-next {
    --hover-dur: 850ms;
    --hover-ease: cubic-bezier(.65, 0, .35, 1);
    position: relative; display: inline-flex; align-items: center; gap: .7em;
    padding: 14px 4px;
    appearance: none; -webkit-appearance: none; border: none; background: none;
    font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 600;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink, #0A0A0A); cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color var(--hover-dur) var(--hover-ease);
  }
  .onb5-next__arrow {
    display: inline-block; color: var(--ink, #0A0A0A);
    transition: transform var(--hover-dur) var(--hover-ease), color var(--hover-dur) var(--hover-ease);
    will-change: transform;
  }
  .onb5-next__line {
    position: absolute; left: 4px; right: 4px; bottom: 8px; height: 1.5px;
    background: var(--petrol, #14616E);
    transform: scaleX(0); transform-origin: left center;
    transition: transform var(--hover-dur) var(--hover-ease);
    will-change: transform;
  }
  @media (hover: hover) {
    .onb5-next:hover { color: var(--petrol, #14616E); }
    .onb5-next:hover .onb5-next__arrow { transform: translateX(6px); color: var(--petrol, #14616E); }
    .onb5-next:hover .onb5-next__line { transform: scaleX(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .onb5-next, .onb5-next__arrow, .onb5-next__line { transition: none; }
  }

  /* Rechts — Beispielfoto: Karte auf dem Nachttisch (Radius wie die Box) */
  .onb5-photo {
    position: relative;
    margin: 0; width: 100%;
    border-radius: 24px; overflow: hidden;
    background: var(--surface); border: 1px solid var(--border);
    aspect-ratio: 3 / 4;
  }
  .onb5-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover; object-position: 50% 50%; display: block;
  }
  .onb5-photo__ph {
    position: absolute; inset: 0; display: grid; place-items: center;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-faint, rgba(10,10,10,0.35));
  }

  /* Schritt-Balken */
  .onb5-steps { display: flex; justify-content: center; align-items: center; gap: 8px; margin: 24px auto 0; }
  .onb5-back {
    appearance: none; -webkit-appearance: none; border: none; background: transparent;
    display: inline-flex; align-items: center; justify-content: center;
    width: 24px; height: 24px; padding: 0; margin-right: 6px; flex: 0 0 auto;
    color: var(--ink-muted, rgba(10,10,10,0.42));
    cursor: pointer; border-radius: 50%;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .onb5-back:hover { color: var(--petrol); background: var(--petrol-soft, rgba(20,97,110,0.08)); }
  .onb5-back:disabled { opacity: 0.35; cursor: default; }
  .onb5-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.16)); cursor: pointer;
    transition: width 0.3s ease, background 200ms ease, opacity 0.2s ease;
  }
  .onb5-step.is-active { width: 46px; background: var(--petrol); }
  .onb5-step:not(.is-active):not(:disabled):hover { background: var(--petrol); opacity: 0.45; }
  .onb5-step:disabled { cursor: default; }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-onb-step="5"]');
    if (!root) return;
    var btn = root.querySelector('.onb5-next');
    if (!btn) return;
    btn.addEventListener('click', function () {
      if (typeof window.__onbComplete === 'function') window.__onbComplete();
    });
  })();
</script>
