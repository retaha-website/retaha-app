---
// Schnellzugriff — Modul-Karten 1:1 nach der HTML-Vorlage: clean, keine Farben,
// fixe Höhe, Seiten-Screenshot perspektivisch geneigt (rotateX), läuft unten aus
// dem Rahmen. Icon = neutraler Fallback, solange kein Screenshot da ist.
// Screenshots: /previews/<key>.png (per onload wird das Icon ausgeblendet).
import type { LanguageCode } from '@retaha/i18n';

interface Props { lang: LanguageCode; }
const { lang: _lang } = Astro.props;

const svg = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${path}</svg>`;

const cards = [
  { key: 'branding',  label: 'Branding',      desc: 'Logo, Farben und Stil deiner Gästemappe.',                         href: '/branding',       icon: svg('<path d="M18.37 2.63 14 7l3 3 4.37-4.37a2.12 2.12 0 1 0-3-3Z"/><path d="M9 8c-2 0-3 1.5-3 3.5S5 15 3 15c1 2.5 3.5 4 6 4 2.8 0 4.5-1.7 4.5-4.5C13.5 12 12 8 9 8Z"/>') },
  { key: 'eve',       label: 'Eve Concierge', desc: 'Wissen und Einstellungen deiner KI-Gastgeberin.',                  href: '/eve/knowledge',  icon: svg('<circle cx="12" cy="8.5" r="3.5"/><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"/>') },
  { key: 'breakfast', label: 'Frühstück',     desc: 'Zeiten, Ort und Details, die deine Gäste im Gästebuch sehen.',     href: '/breakfast',      icon: svg('<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>') },
  { key: 'places',    label: 'Empfehlungen',  desc: 'Die besten Orte rund um dein Haus.',                               href: '/places',         icon: svg('<circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>') },
  { key: 'service',   label: 'Service',       desc: 'Service-Artikel, die Gäste anfragen können.',                      href: '/service-items',  icon: svg('<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>') },
  { key: 'checkout',  label: 'Self-Checkout', desc: 'Digitaler Check-out direkt vom Zimmer.',                           href: '/self-checkout',  icon: svg('<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>') },
  { key: 'marketing', label: 'Marketing',     desc: 'Kampagnen, Drip-Mails und Vorlagen.',                              href: '/marketing',      icon: svg('<path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/>') },
  { key: 'team',      label: 'Team',          desc: 'Mitglieder einladen und Rollen verwalten.',                        href: '/team',           icon: svg('<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>') },
  { key: 'general',   label: 'Einstellungen', desc: 'Allgemeine Hotel- und Konto-Einstellungen.',                       href: '/admin/settings', icon: svg('<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>') },
  { key: 'plan',      label: 'Abo',           desc: 'Plan, Rechnungen und Testphase.',                                  href: '/subscription',   icon: svg('<rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>') },
];
---

<section class="qa">
  <div class="qa__head">
    <span class="qa__eyebrow">Schnellzugriff</span>
  </div>

  <div class="qa__grid">
    {cards.map((c) => (
      <a class="qa__card" href={c.href}>
        <div class="qa__card-text">
          <h3 class="qa__card-title">{c.label}</h3>
          <p class="qa__card-desc">{c.desc}</p>
        </div>
        <div class="qa__card-preview">
          <span class="qa__card-icon" set:html={c.icon}></span>
          <img
            class="qa__card-shot"
            src={`/previews/${c.key}.png`}
            alt={`Vorschau: ${c.label}`}
            loading="lazy"
            onload="var p=this.previousElementSibling; if (p) p.style.display='none';"
            onerror="this.remove()"
          />
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .qa { max-width: 1400px; margin: 28px auto 0; padding: 0 32px 80px; }
  @media (max-width: 768px) { .qa { padding: 0 20px 56px; } }

  .qa__head { margin-bottom: 16px; }
  .qa__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.5));
  }

  .qa__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 18px;
  }
  @media (max-width: 640px) { .qa__grid { grid-template-columns: 1fr; } }

  /* ── Modul-Karte (Vorlage 1:1) ── */
  .qa__card {
    aspect-ratio: 1 / 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    display: flex; flex-direction: column;
    text-decoration: none;
    transition: box-shadow 0.16s ease, transform 0.16s ease;
  }
  .qa__card:hover { box-shadow: 0 12px 32px rgba(40,30,20,.10); transform: translateY(-2px); }

  .qa__card-text { padding: 22px 22px 0; }
  .qa__card-title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 16px;
    letter-spacing: -0.01em; color: var(--ink); margin: 0 0 7px;
  }
  .qa__card-desc {
    font-family: 'Inter Tight', sans-serif; font-weight: 400; font-size: 13.5px;
    line-height: 1.5; color: var(--ink-soft, #5C5852); margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .qa__card-preview { position: relative; flex: 1; margin-top: 18px; overflow: hidden; perspective: 1100px; }

  /* Neutraler Icon-Fallback (zentriert), nur sichtbar ohne Screenshot. */
  .qa__card-icon {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    width: 48px; height: 48px; border-radius: 12px;
    display: grid; place-items: center;
    background: var(--bg-deep, #f1efe9); color: var(--ink-muted, #A6A199);
  }
  .qa__card-icon :global(svg) { width: 24px; height: 24px; }

  /* Screenshot: 90% breit, perspektivisch geneigt + 15° nach links gedreht; sitzt
     höher und ragt über die Karten-Mitte. */
  .qa__card-shot {
    position: absolute; left: 50%; bottom: -165px;
    width: 300%; max-width: none; height: auto; display: block;
    transform: translateX(-50%) rotateX(10deg) rotateZ(-15deg);
    transform-origin: bottom center;
    border-radius: 10px;
    box-shadow: 0 18px 40px rgba(20,20,20,.18);
  }

  @media (prefers-reduced-motion: reduce) { .qa__card { transition: none; } }
</style>
