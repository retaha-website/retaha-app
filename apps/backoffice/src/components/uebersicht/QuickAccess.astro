---
// Schnellzugriff-Homescreen — kuratierte Kacheln zu den wichtigsten Bereichen,
// direkt unter dem Onboarding-Flow. Labels/Subs über die bestehenden nav.*-Keys
// (schon übersetzt); nur die Sektion-Überschrift ist DE.
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;

const svg = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${path}</svg>`;

// Reihenfolge = Wichtigkeit/Häufigkeit im Alltag.
const tiles = [
  { key: 'branding',     href: '/branding',       icon: svg('<circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/><path d="M2 12a10 10 0 0 0 10 10"/><path d="m8 12 2 2 4-4"/>') },
  { key: 'eve',          href: '/eve/knowledge',  icon: svg('<circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>') },
  { key: 'breakfast',    href: '/breakfast',      icon: svg('<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>') },
  { key: 'places',       href: '/places',         icon: svg('<circle cx="12" cy="11" r="3"/><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0z"/>') },
  { key: 'service',      href: '/service-items',  icon: svg('<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>') },
  { key: 'checkout',     href: '/self-checkout',  icon: svg('<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>') },
  { key: 'marketing',    href: '/marketing',      icon: svg('<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>') },
  { key: 'team',         href: '/team',           icon: svg('<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>') },
  { key: 'general',      href: '/admin/settings', icon: svg('<circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M4.93 19.07l1.41-1.41M19.07 19.07l-1.41-1.41M12 2v2M12 20v2M2 12h2M20 12h2"/>') },
  { key: 'subscription', href: '/subscription',   icon: svg('<rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>') },
];
---

<section class="qa">
  <div class="qa__head">
    <span class="qa__eyebrow">Schnellzugriff</span>
    <h2 class="qa__title">Alles griffbereit<span class="qa__dot" aria-hidden="true"></span></h2>
  </div>

  <div class="qa__grid">
    {tiles.map((t) => (
      <a class="qa__tile" href={t.href}>
        <span class="qa__icon" set:html={t.icon}></span>
        <span class="qa__text">
          <span class="qa__label">{bt(`nav.${t.key}`, lang)}</span>
          <span class="qa__sub">{bt(`nav.${t.key}.sub`, lang)}</span>
        </span>
        <span class="qa__arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  .qa {
    max-width: 1400px;
    margin: 0 auto;
    padding: 12px 32px 8px;
  }
  @media (max-width: 768px) { .qa { padding: 8px 20px; } }

  .qa__head { margin-bottom: 18px; }
  .qa__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-muted, rgba(10,10,10,0.5));
  }
  .qa__title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 500;
    font-size: 22px; letter-spacing: -0.01em; color: var(--ink); margin: 6px 0 0;
  }
  .qa__dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: var(--petrol); margin-left: 4px; }

  .qa__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media (max-width: 1100px) { .qa__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px)  { .qa__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; } }
  @media (max-width: 460px)  { .qa__grid { grid-template-columns: 1fr; } }

  .qa__tile {
    position: relative;
    display: flex; flex-direction: column; gap: 16px;
    padding: 24px;
    min-height: 180px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg, 16px);
    text-decoration: none;
    transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
  }
  .qa__tile:hover {
    border-color: var(--petrol);
    box-shadow: 0 14px 30px rgba(0,0,0,.08);
    transform: translateY(-3px);
  }

  .qa__icon {
    flex-shrink: 0;
    width: 60px; height: 60px; border-radius: 16px;
    display: grid; place-items: center;
    background: var(--petrol-soft, rgba(20,97,110,0.10));
    color: var(--petrol);
    transition: background 0.16s ease, color 0.16s ease;
  }
  .qa__tile:hover .qa__icon { background: var(--petrol); color: #fff; }
  .qa__icon :global(svg) { width: 28px; height: 28px; }

  .qa__text { display: flex; flex-direction: column; gap: 5px; min-width: 0; margin-top: auto; }
  .qa__label {
    font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 17px;
    color: var(--ink);
  }
  .qa__sub {
    font-family: 'Inter Tight', sans-serif; font-size: 13px; line-height: 1.45;
    color: var(--ink-muted, rgba(10,10,10,0.5));
  }

  .qa__arrow {
    position: absolute; top: 22px; right: 22px;
    color: var(--ink-faint, rgba(10,10,10,0.3)); font-size: 18px;
    opacity: 0; transform: translateX(-4px);
    transition: opacity 0.16s ease, transform 0.16s ease, color 0.16s ease;
  }
  .qa__tile:hover .qa__arrow { opacity: 1; transform: translateX(0); color: var(--petrol); }
</style>
