---
// Schnellzugriff als App-Launcher: quadratische, getönte Kacheln — jede mit eigenem
// Thema/Farbwelt, aber als Familie (gleiche Form, gleicher Icon-/Label-Stil).
// „testweise" — DE-Labels hartkodiert (i18n folgt).
import type { LanguageCode } from '@retaha/i18n';

interface Props { lang: LanguageCode; }
const { lang: _lang } = Astro.props;

const svg = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${path}</svg>`;

const apps = [
  { label: 'Branding',      href: '/branding',       theme: 'branding', icon: svg('<path d="M18.37 2.63 14 7l3 3 4.37-4.37a2.12 2.12 0 1 0-3-3Z"/><path d="M9 8c-2 0-3 1.5-3 3.5S5 15 3 15c1 2.5 3.5 4 6 4 2.8 0 4.5-1.7 4.5-4.5C13.5 12 12 8 9 8Z"/>') },
  { label: 'Eve Concierge', href: '/eve/knowledge',  theme: 'eve',      icon: svg('<circle cx="12" cy="8.5" r="3.5"/><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"/><path d="M18 3l.7 1.8L20.5 5.5l-1.8.7L18 8l-.7-1.8L15.5 5.5l1.8-.7Z"/>') },
  { label: 'Frühstück',     href: '/breakfast',      theme: 'breakfast',icon: svg('<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>') },
  { label: 'Empfehlungen',  href: '/places',         theme: 'places',   icon: svg('<circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>') },
  { label: 'Service',       href: '/service-items',  theme: 'service',  icon: svg('<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>') },
  { label: 'Self-Checkout', href: '/self-checkout',  theme: 'checkout', icon: svg('<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>') },
  { label: 'Marketing',     href: '/marketing',      theme: 'marketing',icon: svg('<path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/>') },
  { label: 'Team',          href: '/team',           theme: 'team',     icon: svg('<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>') },
  { label: 'Einstellungen', href: '/admin/settings', theme: 'general',  icon: svg('<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>') },
  { label: 'Abo',           href: '/subscription',   theme: 'plan',     icon: svg('<path d="m5 16-2.5-9 5.5 4L12 4l4 7 5.5-4L19 16z"/><line x1="5" y1="20" x2="19" y2="20"/>') },
];
---

<section class="qa">
  <div class="qa__head">
    <span class="qa__eyebrow">Schnellzugriff</span>
  </div>

  <div class="qa__grid">
    {apps.map((a) => (
      <a class:list={['qa__tile', `qa__tile--${a.theme}`]} href={a.href}>
        <span class="qa__icon" set:html={a.icon}></span>
        <span class="qa__label">{a.label}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .qa { max-width: 1400px; margin: 28px auto 0; padding: 0 32px; }
  @media (max-width: 768px) { .qa { padding: 0 20px; } }

  .qa__head { margin-bottom: 16px; }
  .qa__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--ink-muted, rgba(10,10,10,0.5));
  }

  .qa__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  @media (max-width: 1100px) { .qa__grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 760px)  { .qa__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 480px)  { .qa__grid { grid-template-columns: repeat(2, 1fr); } }

  /* App-Kachel: quadratisch, getönt, Icon oben, Name unten — Familie */
  .qa__tile {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    padding: 20px;
    display: flex; flex-direction: column; justify-content: space-between;
    text-decoration: none; color: #fff; overflow: hidden;
    box-shadow: 0 10px 26px rgba(10,10,10,0.10);
    transition: transform 0.18s cubic-bezier(0.16,1,0.3,1), box-shadow 0.18s ease;
  }
  /* dezenter Glanz von oben (App-Icon-Feeling) */
  .qa__tile::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(120% 80% at 20% -10%, rgba(255,255,255,0.28), transparent 60%);
    pointer-events: none;
  }
  .qa__tile:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(10,10,10,0.18); }

  .qa__icon {
    position: relative; z-index: 1;
    width: 50px; height: 50px; border-radius: 14px;
    display: grid; place-items: center;
    background: rgba(255,255,255,0.22);
    backdrop-filter: blur(2px);
  }
  .qa__icon :global(svg) { width: 26px; height: 26px; color: #fff; }

  .qa__label {
    position: relative; z-index: 1;
    font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 16px;
    letter-spacing: -0.01em; color: #fff;
    text-shadow: 0 1px 8px rgba(0,0,0,0.18);
  }

  /* ── Themen-Farbwelten — alle unterschiedlich, doch Familie ── */
  .qa__tile--branding  { background: linear-gradient(135deg, #F94EA0, #FF7A45 34%, #FFC83D 58%, #3FD17A 80%, #4D8DFF); }
  .qa__tile--eve       { background: linear-gradient(150deg, #0E3A44, #14616E 70%, #1E8B79); }
  .qa__tile--breakfast { background: linear-gradient(135deg, #FFB347, #FF6F61); }
  .qa__tile--places    { background: linear-gradient(135deg, #2BC48A, #149E8A); }
  .qa__tile--service   { background: linear-gradient(135deg, #4F8DF7, #6A5AE0); }
  .qa__tile--checkout  { background: linear-gradient(135deg, #9B7BFF, #C16BFF); }
  .qa__tile--marketing { background: linear-gradient(135deg, #FF5E9C, #FF8A5B); }
  .qa__tile--team      { background: linear-gradient(135deg, #12B5C9, #1B7BC9); }
  .qa__tile--general   { background: linear-gradient(135deg, #6B7686, #3C4654); }
  .qa__tile--plan      { background: linear-gradient(135deg, #E8C15A, #C9962A); }

  @media (prefers-reduced-motion: reduce) { .qa__tile { transition: none; } }
</style>
