---
// Dunkle „Toolkit"-Hero-Karte (à la Surfshark One): links Text, rechts ein
// verschachteltes weißes Karussell mit Feature-Highlights, Fortschrittsbalken und
// rundem Weiter-Pfeil. Karten-Stapel-Effekt dahinter.
import { bt, type LanguageCode } from '@retaha/i18n';

interface Props { lang: LanguageCode; }
const { lang } = Astro.props;

const slides = [
  { key: 'branding', title: bt('dash.tk.branding.title', lang), desc: bt('dash.tk.branding.desc', lang), href: '/branding' },
  { key: 'eve',      title: bt('dash.tk.eve.title', lang),      desc: bt('dash.tk.eve.desc', lang),      href: '/eve/knowledge' },
  { key: 'places',   title: bt('dash.tk.places.title', lang),   desc: bt('dash.tk.places.desc', lang),   href: '/places' },
];
---

<section class="dtk" data-tk-root>
  <div class="dtk__card">
    <div class="dtk__left">
      <span class="dtk__eyebrow">{bt('dash.tk.eyebrow', lang)}</span>
      <h2 class="dtk__title">{bt('dash.tk.title', lang)}</h2>
      <p class="dtk__desc">{bt('dash.tk.desc', lang)}</p>
    </div>

    <div class="dtk__right">
      <span class="dtk__stack dtk__stack--3" aria-hidden="true"></span>
      <span class="dtk__stack dtk__stack--2" aria-hidden="true"></span>

      <a class="dtk__slide" data-tk-link href={slides[0].href}>
        <div class="dtk__slide-row">
          <div class="dtk__slide-body">
            <h3 class="dtk__slide-title" data-tk-title>{slides[0].title}</h3>
            <p class="dtk__slide-desc" data-tk-desc>{slides[0].desc}</p>
          </div>
          <span class="dtk__slide-icon">
            <img
              class="dtk__slide-shot"
              data-tk-shot
              src={`/previews/${slides[0].key}.png`}
              alt=""
              loading="lazy"
              onload="this.classList.add('is-loaded')"
              onerror="this.classList.remove('is-loaded')"
            />
          </span>
        </div>
        <div class="dtk__bar"><span data-tk-bar style="width: 33%"></span></div>
      </a>

      <button class="dtk__next" type="button" data-tk-next aria-label="Nächstes Highlight">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<script is:inline define:vars={{ slides }}>
  (function () {
    var root = document.querySelector('[data-tk-root]');
    if (!root) return;
    var titleEl = root.querySelector('[data-tk-title]');
    var descEl  = root.querySelector('[data-tk-desc]');
    var shotEl  = root.querySelector('[data-tk-shot]');
    var linkEl  = root.querySelector('[data-tk-link]');
    var barEl   = root.querySelector('[data-tk-bar]');
    var nextBtn = root.querySelector('[data-tk-next]');
    var i = 0, n = slides.length;

    function render() {
      var s = slides[i];
      if (titleEl) titleEl.textContent = s.title;
      if (descEl)  descEl.textContent  = s.desc;
      if (shotEl) { shotEl.classList.remove('is-loaded'); shotEl.src = '/previews/' + s.key + '.png'; }
      if (linkEl)  linkEl.setAttribute('href', s.href);
      if (barEl)   barEl.style.width   = Math.round(((i + 1) / n) * 100) + '%';
    }
    function next() { i = (i + 1) % n; render(); }

    if (nextBtn) nextBtn.addEventListener('click', function (e) { e.preventDefault(); next(); });
    render();

    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      var timer = setInterval(next, 6500);
      root.addEventListener('mouseenter', function () { clearInterval(timer); });
    }
  })();
</script>

<style>
  .dtk {
    max-width: 1680px;
    margin: 28px auto 0;
    padding: 0 32px;
  }
  @media (max-width: 768px) { .dtk { padding: 0 20px; } }

  .dtk__card {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: 40px;
    align-items: center;
    background: #12262d;
    border-radius: 24px;
    padding: 36px 40px;
  }
  @media (max-width: 900px) {
    .dtk__card { grid-template-columns: 1fr; gap: 28px; padding: 28px 24px; }
  }

  .dtk__eyebrow {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.55);
  }
  .dtk__title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 500;
    font-size: 26px; letter-spacing: -0.01em; color: #fff; margin: 10px 0 12px;
  }
  .dtk__desc {
    font-family: 'Inter Tight', sans-serif; font-size: 15px; line-height: 1.6;
    color: rgba(255,255,255,0.72); margin: 0; max-width: 420px;
  }

  /* Rechte Seite: weißes Karussell + Stapel dahinter + Pfeil */
  .dtk__right { position: relative; padding-right: 24px; }

  .dtk__stack {
    position: absolute; top: 14px; bottom: 14px; right: 8px; left: 24px;
    background: rgba(255,255,255,0.55); border-radius: 16px; z-index: 0;
  }
  .dtk__stack--2 { right: 0; left: 32px; background: rgba(255,255,255,0.32); }
  .dtk__stack--3 { right: -8px; left: 40px; background: rgba(255,255,255,0.18); }

  .dtk__slide {
    position: relative; z-index: 1; display: block;
    background: #fff; border-radius: 16px; padding: 22px 22px 18px;
    text-decoration: none;
    box-shadow: 0 18px 44px rgba(0,0,0,0.28);
    transition: transform 0.16s ease;
  }
  .dtk__slide:hover { transform: translateY(-2px); }

  .dtk__slide-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .dtk__slide-body { min-width: 0; }
  .dtk__slide-title {
    font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 19px;
    color: var(--ink, #0a0a0a); margin: 0 0 8px;
  }
  .dtk__slide-desc {
    font-family: 'Inter Tight', sans-serif; font-size: 14px; line-height: 1.5;
    color: var(--ink-soft, rgba(10,10,10,0.6)); margin: 0; max-width: 32ch;
  }
  /* Screenshot-Slot (selbes Prinzip wie die Grids): neutraler Platzhalter, der
     durch /previews/<key>.png ersetzt wird, sobald vorhanden. Keine SVGs. */
  .dtk__slide-icon {
    position: relative; flex-shrink: 0;
    width: 40%; max-width: 220px; aspect-ratio: 3 / 2;
    border-radius: 14px; overflow: hidden;
    background: var(--bg-deep, #f0efea);
  }
  .dtk__slide-shot {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; opacity: 0; transition: opacity 0.2s ease;
  }
  .dtk__slide-shot.is-loaded { opacity: 1; }

  .dtk__bar {
    margin-top: 22px; height: 4px; border-radius: 999px;
    background: rgba(10,10,10,0.08); overflow: hidden;
  }
  .dtk__bar > span { display: block; height: 100%; border-radius: 999px; background: var(--petrol); transition: width 0.4s cubic-bezier(0.5,0,0.2,1); }

  .dtk__next {
    position: absolute; z-index: 2; right: -2px; bottom: -14px;
    width: 44px; height: 44px; border-radius: 50%;
    display: grid; place-items: center;
    background: #fff; color: var(--ink, #0a0a0a);
    border: 1px solid var(--border, rgba(10,10,10,0.08));
    box-shadow: 0 8px 22px rgba(0,0,0,0.18);
    cursor: pointer; transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .dtk__next:hover { background: var(--petrol); color: #fff; transform: scale(1.06); }
  .dtk__next svg { width: 18px; height: 18px; }
  @media (max-width: 900px) { .dtk__right { padding-right: 8px; } .dtk__next { right: -2px; } }
</style>
