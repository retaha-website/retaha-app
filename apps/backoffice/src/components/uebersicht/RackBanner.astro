---
import KeyHanger from './KeyHanger.astro';
import { APPS, type AppStatus } from '../../lib/uebersicht/apps-data';
import { getAppStatus, getDoneCount, type Stage } from '../../lib/uebersicht/setup-stage';

interface Props {
  stage: Stage;
}

const { stage } = Astro.props;
const done = getDoneCount(stage);
const doneStr = String(done).padStart(2, '0');

const delays = ['0s', '0.3s', '0.6s', '0.2s', '0.5s', '0.7s', '0.4s'];
---

<section class="rack-banner">
  <div class="rack-banner__inner">
    <span class="rack-banner__label">Dein Hausschlüsselbund</span>
    <span class="rack-banner__count">
      <strong>{doneStr}/07</strong> übergeben
    </span>
    <div class="rack-banner__keys">
      {APPS.map((app, i) => (
        <a href={`#app-${app.num}`} class="rack-key-link" aria-label={`Zur App: ${app.label}`}>
          <KeyHanger
            num={app.num}
            label={app.label}
            status={getAppStatus(app, stage)}
            delay={delays[i]}
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .rack-banner {
    max-width: 1400px;
    margin: 32px auto 0;
    padding: 0 32px;
  }
  @media (max-width: 768px) {
    .rack-banner { padding: 0 20px; margin-top: 24px; }
  }
  .rack-banner__inner {
    position: relative;
    padding: 28px 32px;
    background: var(--surface);
    border: 1px solid var(--ink);
    overflow: hidden;
    border-radius: var(--r);
  }
  .rack-banner__label {
    position: absolute;
    top: 16px;
    left: 32px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }
  .rack-banner__count {
    position: absolute;
    top: 16px;
    right: 32px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink);
  }
  .rack-banner__count strong {
    color: var(--te-yellow);
    background: #0A0A0A;
    padding: 2px 6px;
    border-radius: var(--r-sm);
  }
  .rack-banner__keys {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-top: 36px;
    position: relative;
  }
  @media (max-width: 768px) {
    .rack-banner__keys { grid-template-columns: repeat(4, 1fr); }
  }
  .rack-key-link {
    display: contents;
    text-decoration: none;
  }
  .rack-key-link:focus-visible .rack-key {
    outline: 2px solid var(--pink);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* Messing-Haken-Schiene */
  .rack-banner__keys::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 8px;
    right: 8px;
    height: 3px;
    background: linear-gradient(180deg, var(--brass) 0%, var(--brass-soft) 100%);
    border-radius: 1.5px;
  }
</style>
