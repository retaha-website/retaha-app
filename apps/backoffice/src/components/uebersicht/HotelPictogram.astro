---
interface Props {
  id: 1 | 2 | 3 | 4 | 5 | 6 | 7;
}
const { id } = Astro.props;
---

<svg class="hotel-picto" viewBox="0 0 100 100" aria-hidden="true">
  {id === 1 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="50,18 80,38 80,82 20,82 20,38"/>
      <rect x="42" y="58" width="16" height="24" fill="currentColor"/>
      <rect x="28" y="44" width="10" height="10" fill="currentColor"/>
      <rect x="62" y="44" width="10" height="10" fill="currentColor"/>
      <polygon points="50,8 53,16 47,16" fill="currentColor"/>
    </g>
  )}
  {id === 2 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <line x1="22" y1="78" x2="50" y2="50"/>
      <path d="M50 50 L66 34 L78 46 L62 62 Z" fill="currentColor"/>
      <circle cx="28" cy="62" r="5" fill="currentColor"/>
      <circle cx="18" cy="46" r="3" fill="currentColor"/>
    </g>
  )}
  {id === 3 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="18" y="18" width="64" height="64"/>
      <path d="M18 68 Q35 68 35 50" fill="none"/>
      <rect x="44" y="28" width="30" height="20" fill="currentColor" opacity="0.3"/>
      <line x1="44" y1="33" x2="74" y2="33"/>
      <rect x="28" y="30" width="8" height="14"/>
    </g>
  )}
  {id === 4 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="14" y="46" width="18" height="36"/>
      <rect x="68" y="46" width="18" height="36"/>
      <path d="M23 46 Q50 14 77 46" fill="none"/>
      <line x1="50" y1="22" x2="50" y2="32" stroke-dasharray="3,3"/>
    </g>
  )}
  {id === 5 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="22" y="46" width="56" height="38" rx="3"/>
      <path d="M34 46 L34 32 Q34 20 50 20 Q66 20 66 32 L66 46" fill="none"/>
      <circle cx="50" cy="60" r="6"/>
      <line x1="50" y1="66" x2="50" y2="74" stroke-width="5"/>
    </g>
  )}
  {id === 6 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="12" y="36" width="50" height="36" rx="3"/>
      <rect x="20" y="44" width="16" height="12" fill="currentColor"/>
      <line x1="20" y1="62" x2="54" y2="62" stroke-width="2" opacity="0.5"/>
      <path d="M74 46 Q82 56 74 66" fill="none"/>
      <path d="M82 38 Q92 56 82 74" fill="none" opacity="0.6"/>
    </g>
  )}
  {id === 7 && (
    <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="50" cy="36" r="11"/>
      <path d="M28 80 Q28 56 50 56 Q72 56 72 80"/>
      <circle cx="20" cy="42" r="8" stroke-width="3"/>
      <path d="M8 76 Q8 60 22 60" stroke-width="3" opacity="0.7"/>
      <circle cx="80" cy="42" r="8" stroke-width="3"/>
      <path d="M92 76 Q92 60 78 60" stroke-width="3" opacity="0.7"/>
    </g>
  )}
</svg>

<style>
  .hotel-picto {
    width: 52%;
    height: auto;
    max-width: 100px;
  }
</style>
