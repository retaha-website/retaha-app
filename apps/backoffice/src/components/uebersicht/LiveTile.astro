---
import type { LiveTileData } from '../../lib/uebersicht/live-data';

interface Props {
  tile: LiveTileData;
}
const { tile } = Astro.props;
---

<a href={tile.href} class="live-tile">
  <svg class="live-tile__icon" viewBox="0 0 32 32" aria-hidden="true">
    {tile.key === 'empfang' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="18" width="24" height="12"/>
        <line x1="4" y1="24" x2="28" y2="24"/>
        <ellipse cx="16" cy="12" rx="6" ry="2"/>
        <path d="M10 12c0-4 3-7 6-7s6 3 6 7" fill="currentColor" opacity="0.3"/>
        <circle cx="16" cy="7" r="1.5" fill="currentColor"/>
      </g>
    )}
    {tile.key === 'schluessel' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="5" y="5" width="22" height="22"/>
        <line x1="5" y1="11" x2="27" y2="11"/>
        <line x1="5" y1="19" x2="27" y2="19"/>
        <circle cx="11" cy="15" r="1.5" fill="currentColor"/>
        <circle cx="16" cy="15" r="1.5" fill="currentColor"/>
        <circle cx="21" cy="15" r="1.5" fill="currentColor"/>
        <circle cx="11" cy="23" r="1.5" fill="currentColor"/>
        <circle cx="16" cy="23" r="1.5" fill="currentColor"/>
        <circle cx="21" cy="23" r="1.5" fill="currentColor"/>
      </g>
    )}
    {tile.key === 'glocke' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 4v2"/>
        <path d="M8 22c0-5 3-11 8-11s8 6 8 11"/>
        <line x1="6" y1="22" x2="26" y2="22"/>
        <circle cx="16" cy="26" r="1.5" fill="currentColor"/>
      </g>
    )}
    {tile.key === 'gaeste' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="16" cy="12" r="5"/>
        <path d="M6 28 Q6 19 16 19 Q26 19 26 28"/>
        <circle cx="6"  cy="14" r="3" stroke-width="1.5" opacity="0.6"/>
        <circle cx="26" cy="14" r="3" stroke-width="1.5" opacity="0.6"/>
      </g>
    )}
    {tile.key === 'brief' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="8" width="24" height="16"/>
        <path d="M4 10 L16 18 L28 10"/>
        <circle cx="28" cy="8" r="2" fill="currentColor"/>
      </g>
    )}
  </svg>
  <div class="live-tile__num">{tile.num}</div>
  <div class="live-tile__label">{tile.label}</div>
  <div class="live-tile__sub">{tile.sub}</div>
</a>

<style>
  .live-tile {
    padding: 24px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    cursor: pointer;
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
  }
  .live-tile:hover {
    border-color: var(--ink);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(10,10,10,0.05);
  }
  .live-tile__icon {
    width: 32px;
    height: 32px;
    color: var(--ink);
    margin-bottom: 8px;
    transition: color 200ms ease;
  }
  .live-tile:hover .live-tile__icon { color: var(--pink); }

  .live-tile__num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 36px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .live-tile__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }
  .live-tile__sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    margin-top: 2px;
  }
</style>
