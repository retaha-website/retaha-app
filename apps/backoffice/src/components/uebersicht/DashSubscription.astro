---
// Dashboard-Kopf à la Surfshark: großer Titel + Abo-/Testphasen-Status mit
// „X Tage übrig" (Akzent) + Subtitle (stage-abhängig).
import { bt, type LanguageCode } from '@retaha/i18n';
import type { TrialStatus } from '../../lib/trial-status';

interface Props { trial: TrialStatus; stage: string | number; lang: LanguageCode; }
const { trial, stage, lang } = Astro.props;

const expired = trial.urgencyLevel === 'expired';
const dayWord = trial.daysRemaining === 1 ? 'Tag' : 'Tage';
---

<section class="dsub">
  <h1 class="dsub__title" set:html={bt(`hero.${stage}.title`, lang)}></h1>

  {trial.isInTrial && !expired && (
    <p class="dsub__status">
      Deine Testphase · <span class="dsub__accent">{trial.daysRemaining} {dayWord} übrig</span>
    </p>
  )}
  {trial.isInTrial && expired && (
    <p class="dsub__status">
      Deine Testphase · <span class="dsub__accent dsub__accent--warn">abgelaufen</span>
    </p>
  )}

  <p class="dsub__sub">{bt(`hero.${stage}.sub`, lang)}</p>
</section>

<style>
  .dsub {
    max-width: 1400px;
    margin: 0 auto;
    padding: 56px 32px 0;
  }
  @media (max-width: 768px) { .dsub { padding: 36px 20px 0; } }

  /* H1 = exakt die Flow-Karten-Größe (überall gleich). */
  .dsub__title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0;
  }
  .dsub__status {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 18px;
    color: var(--ink);
    margin: 14px 0 0;
  }
  .dsub__accent { color: var(--petrol); }
  .dsub__accent--warn { color: var(--burgund, #8E2A3A); }
  .dsub__sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.55;
    color: var(--ink-soft, rgba(10,10,10,0.6));
    margin: 8px 0 0; max-width: 720px;
  }
</style>

<style is:global>
  /* Begrüßungs-Titel (set:html): fette Teile + Petrol-Punkt statt Pink. */
  .dsub__title strong { font-weight: 500; }
  .dsub__title .dot-pink { color: var(--petrol); }
</style>
