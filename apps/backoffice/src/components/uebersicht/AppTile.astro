---
import HotelPictogram from './HotelPictogram.astro';
import type { SetupApp, AppStatus } from '../../lib/uebersicht/apps-data';

interface Props {
  app: SetupApp;
  status: AppStatus;
}

const { app, status } = Astro.props;
const sticker = app.sticker[status];
---

<a
  href={app.href}
  id={`app-${app.num}`}
  class:list={['app-tile', { 'is-active': status === 'active', 'is-done': status === 'done' }]}
>
  <div class="app-tile__icon-box">
    <span class="app-tile__num">{app.num}</span>
    <span class="app-tile__led" aria-hidden="true"></span>
    <HotelPictogram id={app.id} />
    <span class="app-tile__sticker">{sticker}</span>
  </div>
  <div class="app-tile__label">{app.label}</div>
  <div class="app-tile__sub">{app.sub}</div>
</a>

<style>
  .app-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 12px;
    cursor: pointer;
    text-decoration: none;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
  }
  .app-tile:hover { transform: translateY(-4px); }
  .app-tile:hover .app-tile__icon-box {
    box-shadow: 0 12px 28px rgba(10,10,10,0.12);
  }

  .app-tile__icon-box {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 200px;
    background: var(--ink);
    color: var(--surface);
    border-radius: var(--r-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }
  .app-tile.is-active .app-tile__icon-box {
    background: var(--te-yellow);
    color: #0A0A0A;
  }
  .app-tile.is-done .app-tile__icon-box {
    background: var(--sage);
    color: white;
  }

  .app-tile__num {
    position: absolute;
    top: 12px;
    left: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    opacity: 0.7;
  }

  .app-tile__led {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--led-off);
    border: 1px solid var(--ink-faint);
  }
  .app-tile.is-active .app-tile__led {
    background: #0A0A0A;
    border-color: #0A0A0A;
    box-shadow: 0 0 0 4px rgba(10,10,10,0.18);
    animation: led-pulse 1.5s ease-in-out infinite;
  }
  .app-tile.is-done .app-tile__led {
    background: white;
    border-color: white;
    box-shadow: 0 0 6px rgba(255,255,255,0.5);
  }

  .app-tile__sticker {
    position: absolute;
    bottom: 12px;
    right: 14px;
    padding: 4px 9px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(255,255,255,0.18);
    color: currentColor;
    border-radius: var(--r-sm);
  }
  .app-tile.is-active .app-tile__sticker {
    background: #0A0A0A;
    color: var(--te-yellow);
  }
  .app-tile.is-done .app-tile__sticker {
    background: rgba(255,255,255,0.22);
    color: white;
  }

  .app-tile__label {
    margin-top: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--ink);
    text-align: center;
  }
  .app-tile__sub {
    margin-top: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink-muted);
    text-align: center;
    letter-spacing: 0.04em;
  }
</style>
