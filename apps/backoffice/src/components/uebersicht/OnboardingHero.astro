---
// Onboarding-Hero · Screen 1 — „Eve kennt dein Hotel schon."
//
// Airbnb-Split: links Copy, rechts der ECHTE Eve-Concierge im Bauhaus-Branding
// (gelb) — 1:1 übernommen aus der Gäste-App / /branding-Vorschau
// (EveChatSheet [data-theme="bauhaus"] + BauhausPreview-Tokens). Eve-Avatar-SVG
// inline aus apps/guest/src/assets/eve-avatar.svg. Tokens lokal gescopt → kein
// Backoffice-Leak, identischer Look.
//
// Demo-Konversation (kein echtes Eve-Backend). Copy bewusst noch DE-only — i18n
// folgt erst nach finaler Freigabe von Screen 1.

interface Props {
  hotelName?: string;
}
const { hotelName: _hotelName } = Astro.props;

// Echte Sprachzahl aus der i18n-Config (LANGUAGES in @retaha/i18n) — nicht raten.
const LANG_COUNT = 11; // de en fr es it pt nl ru ar zh tr
---

<section class="onb-hero" data-onb-hero>
  <div class="onb-grid">

    <!-- ── Links: Copy ─────────────────────────────────────────────── -->
    <div class="onb-copy">
      <p class="onb-eyebrow onb-reveal" data-r="0">Schritt 1 · Dein Gast-Concierge</p>
      <h1 class="onb-headline onb-reveal" data-r="1">Eve kennt dein Hotel schon<span class="onb-dot"></span></h1>
      <p class="onb-sub onb-reveal" data-r="2">
        Aufgebaut aus eurer Website — ohne dass du etwas eingestellt hast. So
        beantwortet Eve ab jetzt jede Gästefrage, rund um die Uhr, in
        <strong>{LANG_COUNT} Sprachen</strong>.
      </p>
      <div class="onb-cta-row onb-reveal" data-r="3">
        <button type="button" class="onb-cta">Weiter →</button>
      </div>
    </div>

    <!-- ── Rechts: Eve-Concierge (Bauhaus-Branding) ────────────────── -->
    <div class="onb-eve onb-reveal" data-r="2" data-onb-eve>
      <header class="eve-sheet-header">
        <div class="eve-sheet-avatar" role="img" aria-label="Eve, Concierge">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <defs><clipPath id="onb-eve-fr"><circle cx="24" cy="24" r="21.5"/></clipPath></defs>
            <circle cx="24" cy="24" r="21.5" stroke-width="2"/>
            <circle cx="24" cy="10.8" r="2.6"/>
            <circle cx="24" cy="20" r="7"/>
            <path d="M19.9 19 C20.6 17.7 22.2 17.7 22.9 19" stroke-width="1.8"/>
            <path d="M25.1 19 C25.8 17.7 27.4 17.7 28.1 19" stroke-width="1.8"/>
            <path d="M21.3 22 C22.5 24 25.5 24 26.7 22" stroke-width="1.9"/>
            <g clip-path="url(#onb-eve-fr)"><path d="M8.5 40 C10 32.5 16.5 29.5 24 29.5 C31.5 29.5 38 32.5 39.5 40"/></g>
            <path d="M19.5 30.5 L24 36.5 L28.5 30.5"/>
          </svg>
        </div>
        <div class="eve-sheet-header-info">
          <span class="eve-sheet-header-eyebrow">concierge</span>
          <h2 class="eve-sheet-header-name">Eve<span class="eve-name-dot">.</span></h2>
        </div>
        <span class="eve-online" aria-hidden="true"><span class="eve-online-dot"></span></span>
      </header>

      <div class="eve-sheet-messages" data-eve-messages>
        <div class="eve-message eve-message--assistant" data-step="0">
          <div class="eve-message-bubble" data-sender="EVE">Hallo! Ich bin Eve, euer digitaler Concierge — rund um die Uhr für eure Gäste da.</div>
        </div>
        <div class="eve-message eve-message--user" data-step="1">
          <div class="eve-message-bubble">Wann gibt es Frühstück?</div>
        </div>
        <div class="eve-typing-wrap" data-eve-typing hidden>
          <div class="eve-typing" aria-label="Eve schreibt …" role="status">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="eve-message eve-message--assistant" data-step="2">
          <div class="eve-message-bubble" data-sender="EVE">Täglich von 7:00–10:30 Uhr im Wintergarten — inklusive für alle Übernachtungsgäste. Soll ich sonst noch etwas vorbereiten?</div>
        </div>
      </div>

      <div class="eve-sheet-input-row">
        <input class="eve-sheet-input" type="text" placeholder="Frag Eve selbst etwas über dein Hotel" aria-label="Frag Eve etwas" />
        <button class="eve-sheet-send" type="button" aria-label="Senden">↑</button>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Bauhaus-Tokens (lokal gescopt — wie /branding-Vorschau) ────── */
  .onb-hero {
    --onb-bg: #FAFAF7;
    --onb-ink: #0A0A0A;
    --onb-ink-muted: #5C5C5C;
    --onb-ink-faint: #A3A3A3;
    --onb-pink: #FF4A82;
    --onb-yellow: #FFE600;
    --onb-border: #E5E4DF;
    --onb-border-card: #E3E1DA;
    --onb-card-bg: #FAFAF6;
    --onb-sage: #5C9070;

    /* Breite/Ausrichtung exakt wie der Inhalt darunter (1400px · 32px padding) */
    max-width: 1400px;
    margin: 8px auto 12px;
    padding: 32px 32px 48px;
    border-bottom: 1px solid var(--border);
  }
  .onb-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .onb-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 768px) {
    .onb-hero { padding: 24px 20px 36px; }
  }

  /* ── Links: Copy (Bauhaus) ─────────────────────────────────────── */
  .onb-copy { min-width: 0; }
  .onb-eyebrow {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--onb-ink);
    background: var(--onb-yellow);
    padding: 5px 11px;
    border-radius: 4px;
    margin: 0 0 18px;
  }
  .onb-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: clamp(30px, 4.4vw, 46px);
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: var(--onb-ink);
    margin: 0 0 18px;
  }
  .onb-dot {
    display: inline-block;
    width: 11px; height: 11px;
    background: var(--onb-pink);
    border-radius: 50%;
    vertical-align: baseline;
    margin-left: 3px;
  }
  .onb-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px;
    line-height: 1.62;
    color: var(--onb-ink-muted);
    max-width: 48ch;
    margin: 0 0 28px;
  }
  .onb-sub strong { color: var(--onb-ink); font-weight: 600; }

  .onb-cta-row { display: flex; gap: 12px; align-items: center; }
  .onb-cta {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--onb-bg);
    background: var(--onb-ink);
    border: none;
    border-radius: var(--r, 12px);
    padding: 13px 26px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, transform 0.1s ease;
  }
  .onb-cta:hover { background: var(--onb-yellow); color: var(--onb-ink); }
  .onb-cta:active { transform: translateY(1px); }

  /* ── Rechts: Eve-Panel (Bauhaus, 1:1 aus der Gäste-App) ────────── */
  .onb-eve {
    display: flex;
    flex-direction: column;
    height: 480px;
    background: var(--onb-card-bg);
    border: 1px solid var(--onb-border-card);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 18px 50px -24px rgba(10, 10, 10, 0.28);
  }
  @media (max-width: 880px) { .onb-eve { height: 440px; } }

  /* Header — grid avatar · info · status */
  .eve-sheet-header {
    flex-shrink: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 14px 16px;
    background: var(--onb-card-bg);
    border-bottom: 1px solid var(--onb-border-card);
  }
  .eve-sheet-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--onb-pink) 13%, var(--onb-card-bg));
    color: var(--onb-pink);
    display: grid; place-items: center;
    justify-self: start;
  }
  .eve-sheet-avatar svg { width: 38px; height: 38px; overflow: visible; }
  .eve-sheet-header-info { display: flex; flex-direction: column; gap: 2px; align-items: center; text-align: center; }
  .eve-sheet-header-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: #6E6B64;
  }
  .eve-sheet-header-eyebrow::before {
    content: '● '; font-size: 6px; vertical-align: middle; color: var(--onb-pink);
  }
  .eve-sheet-header-name {
    margin: 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 700; letter-spacing: -0.01em;
    color: var(--onb-ink);
  }
  .eve-name-dot { color: var(--onb-pink); font-style: normal; }
  .eve-online { justify-self: end; display: inline-flex; }
  .eve-online-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--onb-sage);
    box-shadow: 0 0 0 3px rgba(92, 144, 112, 0.22);
    animation: onb-led-pulse 2s ease-in-out infinite;
  }
  @keyframes onb-led-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(1.15); }
  }

  /* Messages */
  .eve-sheet-messages { flex: 1; overflow-y: auto; padding: 18px 18px; scroll-behavior: smooth; }
  .eve-message { display: flex; margin-bottom: 16px; max-width: 100%; align-items: flex-end; }
  .eve-message--user { justify-content: flex-end; }
  .eve-message--assistant { justify-content: flex-start; }
  .eve-message-bubble {
    max-width: 88%;
    padding: 16px 18px;
    font-family: 'Inter Tight', system-ui, sans-serif;
    font-size: 15px; line-height: 1.55;
    white-space: pre-wrap; word-wrap: break-word;
  }
  .eve-message--user .eve-message-bubble {
    background: #0A0A0A; color: #FAFAF6; border-radius: 12px;
  }
  .eve-message--assistant .eve-message-bubble {
    background: #FFFFFF; color: #0A0A0A;
    border: 1px solid var(--onb-border-card); border-radius: 12px;
  }
  .eve-message--assistant .eve-message-bubble::before {
    content: attr(data-sender);
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5px; font-weight: 600; letter-spacing: 0.2em;
    color: var(--onb-pink); margin-bottom: 6px;
  }

  /* Typing */
  .eve-typing-wrap { display: flex; margin-bottom: 16px; }
  .eve-typing {
    display: inline-flex; gap: 4px; align-items: center;
    padding: 14px 18px;
    background: #FFFFFF; border: 1px solid var(--onb-border-card);
    border-radius: 12px; width: fit-content;
  }
  .eve-typing span {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--onb-pink);
    animation: onb-typing-bounce 1.2s infinite ease-in-out;
  }
  .eve-typing span:nth-child(2) { animation-delay: 0.15s; }
  .eve-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes onb-typing-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  /* Input */
  .eve-sheet-input-row {
    flex-shrink: 0;
    display: flex; gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--onb-border-card);
    background: #FFFFFF;
  }
  .eve-sheet-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--onb-border-card);
    border-radius: 12px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: var(--onb-ink);
    background: var(--onb-bg);
    outline: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .eve-sheet-input:focus { border-color: var(--onb-pink); background: #FFFFFF; }
  .eve-sheet-input::placeholder { color: var(--onb-ink-faint); }
  .eve-sheet-send {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border: none; border-radius: 12px;
    background: #0A0A0A; color: #FAFAF6;
    font-size: 22px; line-height: 1;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .eve-sheet-send:hover { background: var(--onb-pink); }

  /* ── Entrance-Animation ────────────────────────────────────────── */
  .onb-reveal { opacity: 0; transform: translateY(12px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .onb-reveal.is-in { opacity: 1; transform: none; }
  .eve-message, .eve-typing-wrap { opacity: 0; transform: translateY(6px); transition: opacity 0.35s ease, transform 0.35s ease; }
  .eve-message.is-in, .eve-typing-wrap.is-in { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .onb-reveal, .eve-message { opacity: 1 !important; transform: none !important; transition: none; }
    .eve-typing-wrap { display: none !important; }
  }
</style>

<noscript>
  <style>
    .onb-reveal, .eve-message { opacity: 1 !important; transform: none !important; }
    .eve-typing-wrap { display: none !important; }
  </style>
</noscript>

<script is:inline>
  (function () {
    var hero = document.querySelector('[data-onb-hero]');
    if (!hero) return;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var reveals = Array.prototype.slice.call(hero.querySelectorAll('.onb-reveal'));
    var msgs = Array.prototype.slice.call(hero.querySelectorAll('[data-step]'));
    var typing = hero.querySelector('[data-eve-typing]');
    var msgArea = hero.querySelector('[data-eve-messages]');

    function scrollDown() { if (msgArea) msgArea.scrollTop = msgArea.scrollHeight; }

    if (reduce) {
      reveals.forEach(function (el) { el.classList.add('is-in'); });
      msgs.forEach(function (el) { el.classList.add('is-in'); });
      return;
    }

    function start() {
      reveals.forEach(function (el) {
        var r = parseInt(el.getAttribute('data-r') || '0', 10);
        setTimeout(function () { el.classList.add('is-in'); }, r * 90);
      });

      var t = 750;
      setTimeout(function () { msgs[0].classList.add('is-in'); scrollDown(); }, t);
      t += 850;
      setTimeout(function () { msgs[1].classList.add('is-in'); scrollDown(); }, t);
      t += 550;
      setTimeout(function () {
        if (typing) { typing.hidden = false; void typing.offsetWidth; typing.classList.add('is-in'); scrollDown(); }
      }, t);
      t += 1400;
      setTimeout(function () {
        if (typing) typing.hidden = true;
        msgs[2].classList.add('is-in');
        scrollDown();
      }, t);
    }

    if ('requestAnimationFrame' in window) requestAnimationFrame(function () { setTimeout(start, 120); });
    else setTimeout(start, 200);
  })();
</script>
