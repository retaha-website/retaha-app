---
// Onboarding-Hero · Screen 1 — „Eve kennt dein Hotel schon."
//
// Airbnb-Split: links Copy, rechts der ECHTE Eve-Concierge im Bauhaus-Look
// (Eve-Avatar-SVG inline aus apps/guest/src/assets/eve-avatar.svg). Akzentfarbe
// Petrol (#14616E). Eve ist INTERAKTIV: man kann tippen und Eve antwortet wie in
// der Gäste-App (Demo — Stichwort-basierte Antworten, kein Backend). Unten ein
// cleaner Schritt-Balken. Copy DE-only.

interface Props {
  hotelName?: string;
}
const { hotelName: _hotelName } = Astro.props;

const LANG_COUNT = 11; // de en fr es it pt nl ru ar zh tr
const STEPS = 5;       // 1 Eve · 2 Look+Reveal · 3 Ausblick · 4 Komplett · 5 Live
---

<section class="onb-hero" data-onb-hero data-onb-step="1">
  <div class="onb-grid">

    <!-- ── Links: Copy ─────────────────────────────────────────────── -->
    <div class="onb-copy">
      <h1 class="onb-headline onb-reveal" data-r="0">Eve kennt dein Hotel <span class="onb-nb">schon<span class="onb-dot"></span></span></h1>
      <p class="onb-sub onb-reveal" data-r="1">
        Aufgebaut aus eurer Website — ohne dass du etwas eingestellt hast. So
        beantwortet Eve ab jetzt jede Gästefrage, rund um die Uhr, in
        <strong>{LANG_COUNT} verfügbaren Sprachen</strong>.
      </p>
      <div class="onb-cta-row onb-reveal" data-r="2">
        <button type="button" class="onb-cta" data-onb-goto="2">Weiter →</button>
        <button type="button" class="onb-skip" data-onb-action="skip">Setup überspringen</button>
      </div>
    </div>

    <!-- ── Rechts: Eve-Concierge (interaktiv) ───────────────────────── -->
    <div class="onb-eve onb-reveal" data-r="1" data-onb-eve>
      <header class="eve-sheet-header">
        <div class="eve-sheet-avatar" data-eve-avatar role="img" aria-label="Eve, Concierge">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <defs><clipPath id="onb-eve-fr"><circle cx="24" cy="24" r="21.5"/></clipPath></defs>
            <circle class="ring-closed" cx="24" cy="24" r="21.5" stroke-width="2"/>
            <path class="ring-open" d="M42.8 13.6 A21.5 21.5 0 1 1 36.6 6.6" stroke-width="2"/>
            <circle cx="24" cy="10.8" r="2.6"/>
            <circle cx="24" cy="20" r="7"/>
            <path d="M19.9 19 C20.6 17.7 22.2 17.7 22.9 19" stroke-width="1.8"/>
            <path d="M25.1 19 C25.8 17.7 27.4 17.7 28.1 19" stroke-width="1.8"/>
            <path d="M21.3 22 C22.5 24 25.5 24 26.7 22" stroke-width="1.9"/>
            <g clip-path="url(#onb-eve-fr)"><path d="M8.5 40 C10 32.5 16.5 29.5 24 29.5 C31.5 29.5 38 32.5 39.5 40"/></g>
            <path d="M19.5 30.5 L24 36.5 L28.5 30.5"/>
            <path class="arm" d="M31.2 30.3 C34.8 27.4 36.9 23 38 13.8"/>
            <g class="wave-hand"><g class="swing"><g transform="translate(38 13) rotate(32)">
              <path d="M-4.2 -0.2 L-4.2 -2.0 C-6.2 -2.5 -7.0 -4.2 -6.0 -5.2 C-5.3 -5.9 -4.4 -5.5 -4.2 -4.4 L-4.2 -6.8 A1.4 1.4 0 0 1 -1.4 -6.8 L-1.4 -5.2 L-1.4 -7.8 A1.4 1.4 0 0 1 1.4 -7.8 L1.4 -5.2 L1.4 -6.4 A1.4 1.4 0 0 1 4.2 -6.4 L4.2 -0.2 Z" stroke-width="1.9"/>
            </g></g></g>
          </svg>
        </div>
        <div class="eve-sheet-header-info">
          <span class="eve-sheet-header-eyebrow">concierge</span>
          <h2 class="eve-sheet-header-name">Eve<span class="eve-name-dot">.</span></h2>
        </div>
      </header>

      <div class="eve-sheet-messages" data-eve-messages>
        <div class="eve-message eve-message--assistant" data-step="0">
          <div class="eve-message-bubble" data-sender="EVE">Hallo! Ich bin Eve, euer digitaler Concierge — rund um die Uhr für eure Gäste da.</div>
        </div>
        <div class="eve-message eve-message--user" data-step="1">
          <div class="eve-message-bubble">Wann gibt es Frühstück?</div>
        </div>
        <div class="eve-typing-wrap" data-eve-typing hidden>
          <div class="eve-typing" aria-label="Eve schreibt …" role="status">
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="eve-message eve-message--assistant" data-step="2">
          <div class="eve-message-bubble" data-sender="EVE">Frühstück gibt’s täglich von 7:00 bis 10:30 Uhr im Wintergarten — frisch gebacken, mit Blick in den Garten. 🌿</div>
        </div>
        <div class="eve-message eve-message--user" data-step="3">
          <div class="eve-message-bubble">Was gibt es in der Nähe?</div>
        </div>
        <div class="eve-message eve-message--assistant" data-step="4">
          <div class="eve-message-bubble" data-sender="EVE">Ganz in der Nähe, etwa 10 Minuten zu Fuß: das Museum für Naturkunde und der Hamburger Bahnhof – Museum der Gegenwart. Soll ich euch die Route schicken?</div>
        </div>
      </div>

      <div class="eve-sheet-input-row">
        <input class="eve-sheet-input" data-eve-input type="text" placeholder="Frag Eve etwas über dein Hotel …" aria-label="Frag Eve etwas" readonly tabindex="-1" />
        <button class="eve-sheet-send" data-eve-send type="button" aria-label="Senden" tabindex="-1">↑</button>
      </div>
    </div>

  </div>

  <!-- ── Schritt-Balken (clean, klickbar — vor/zurück) ─────────────── -->
  <div class="onb-steps" role="group" aria-label="Onboarding-Schritte">
    {Array.from({ length: STEPS }, (_, i) => (
      <button
        type="button"
        class:list={['onb-step', { 'is-active': i === 0 }]}
        data-onb-goto={i + 1}
        aria-label={`Schritt ${i + 1}`}
      ></button>
    ))}
  </div>
</section>

<style>
  /* ── Tokens (lokal gescopt) ────────────────────────────────────── */
  .onb-hero {
    --onb-bg: #FAFAF7;
    --onb-ink: #0A0A0A;
    --onb-ink-muted: #5C5C5C;
    --onb-ink-faint: #A3A3A3;
    --onb-petrol: #14616E;
    --onb-petrol-soft: rgba(20, 97, 110, 0.10);
    --onb-border: #E5E4DF;
    --onb-border-card: #E3E1DA;
    --onb-card-bg: #FAFAF6;

    max-width: 1280px; width: calc(100% - 64px);   /* = Step 2 (.lr) */
    margin: 32px auto 32px;
    padding: 32px 32px 40px;
    /* Setup-Screen füllt die volle Bildschirmhöhe; JS verfeinert pro Header-Höhe. */
    display: flex;
    flex-direction: column;
    min-height: calc(100svh - var(--onb-chrome, 190px));
    box-sizing: border-box;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: 24px;
    box-shadow: 0 12px 26px rgba(0,0,0,.06);
  }
  .onb-grid {
    display: grid;
    grid-template-columns: minmax(0, 720px) minmax(0, 380px);
    gap: 56px;
    align-items: center;
    justify-content: center;   /* Gruppe mittig — Luft links/rechts wie Step 2 (statt 1fr randvoll) */
    width: 100%;
    flex: 1 1 auto;   /* wächst → Inhalt mittig, Step-Balken sinkt nach unten */
  }
  @media (max-width: 1280px) {
    .onb-grid { grid-template-columns: 1fr; gap: 36px; justify-items: center; }
    .onb-copy { text-align: center; max-width: 600px; }
    .onb-sub { margin-left: auto; margin-right: auto; }
    .onb-cta-row { justify-content: center; }
  }
  @media (max-width: 768px) {
    .onb-hero { padding: 24px 20px 32px; }
  }

  /* ── Links: Copy ───────────────────────────────────────────────── */
  .onb-copy { min-width: 0; }
  .onb-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: var(--onb-ink);
    margin: 0 0 24px;
  }
  .onb-nb { white-space: nowrap; }
  .onb-dot {
    display: inline-block;
    width: 14px; height: 14px;
    background: var(--onb-petrol);
    border-radius: 50%;
    vertical-align: baseline;
    margin-left: 4px;
  }
  .onb-sub {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 16px; line-height: 1.62;
    color: var(--onb-ink-muted);
    max-width: 48ch;
    margin: 0 0 28px;
  }
  .onb-sub strong { color: var(--onb-ink); font-weight: 600; }

  .onb-cta-row { display: flex; gap: 12px; align-items: center; }
  .onb-cta {
    display: inline-block; text-decoration: none;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 500;
    color: var(--onb-bg); background: var(--onb-ink);
    border: none; border-radius: var(--r, 12px);
    padding: 13px 26px; cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, transform 0.1s ease;
  }
  .onb-cta:hover { background: var(--onb-petrol); color: #fff; }
  .onb-cta:active { transform: translateY(1px); }
  .onb-skip {
    font-family: 'Inter Tight', -apple-system, sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--onb-ink-muted);
    background: transparent; border: none;
    padding: 13px 8px; cursor: pointer;
    transition: color 0.15s ease;
  }
  .onb-skip:hover { color: var(--onb-ink); }

  /* ── Rechts: Eve-Panel ─────────────────────────────────────────── */
  .onb-eve {
    width: 100%; max-width: 380px; margin: 0 auto;
    display: flex; flex-direction: column;
    height: 560px;
    background: var(--onb-card-bg);
    border: 1px solid var(--onb-border-card);
    border-radius: 20px; overflow: hidden;
    box-shadow: 0 22px 60px -26px rgba(10, 10, 10, 0.32);
  }
  @media (max-width: 880px) { .onb-eve { height: 500px; } }

  .eve-sheet-header {
    flex-shrink: 0;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding: 14px 16px;
    background: var(--onb-card-bg);
    border-bottom: 1px solid var(--onb-border-card);
  }
  .eve-sheet-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: color-mix(in srgb, var(--onb-petrol) 13%, var(--onb-card-bg));
    color: var(--onb-petrol);
    display: grid; place-items: center;
    justify-self: start; overflow: visible;
  }
  .eve-sheet-avatar svg { width: 38px; height: 38px; overflow: visible; }

  /* Avatar: Wink-Sequenz (1×, beim Start) + Tipp-Puls */
  .onb-eve { --onb-wave-total: 5900ms; }
  .onb-eve .ring-closed { opacity: 1; }
  .onb-eve .ring-open { opacity: 0; }
  .onb-eve .arm { opacity: 0; }
  .onb-eve .wave-hand { opacity: 0; }
  .onb-eve .wave-hand .swing { transform-box: fill-box; transform-origin: 50% 100%; }
  @media (prefers-reduced-motion: no-preference) {
    .eve-sheet-avatar .ring-closed { animation: onb-ring-closed-vis var(--onb-wave-total) linear forwards; }
    .eve-sheet-avatar .ring-open   { animation: onb-ring-open-vis   var(--onb-wave-total) linear forwards; }
    .eve-sheet-avatar .arm         { animation: onb-arm-vis         var(--onb-wave-total) linear forwards; }
    .eve-sheet-avatar .wave-hand   { animation: onb-hand-vis        var(--onb-wave-total) linear forwards; }
    .eve-sheet-avatar .wave-hand .swing { animation: onb-hand-swing var(--onb-wave-total) ease-in-out forwards; }
    .eve-sheet-avatar.is-typing svg { animation: onb-eve-typing-pulse 1.2s ease-in-out infinite; }
  }
  @keyframes onb-ring-closed-vis { 0%,48%{opacity:1} 52%,86%{opacity:0} 90%,100%{opacity:1} }
  @keyframes onb-ring-open-vis   { 0%,48%{opacity:0} 52%,86%{opacity:1} 90%,100%{opacity:0} }
  @keyframes onb-arm-vis         { 0%,48%{opacity:0} 53%,86%{opacity:1} 90%,100%{opacity:0} }
  @keyframes onb-hand-vis        { 0%,49%{opacity:0} 54%,86%{opacity:1} 90%,100%{opacity:0} }
  @keyframes onb-hand-swing {
    0%,50%{transform:rotate(0deg)} 58%{transform:rotate(16deg)} 66%{transform:rotate(-13deg)}
    74%{transform:rotate(11deg)} 82%{transform:rotate(-7deg)} 86%,100%{transform:rotate(0deg)}
  }
  @keyframes onb-eve-typing-pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.04);opacity:0.8} }

  .eve-sheet-header-info { display: flex; flex-direction: column; gap: 2px; align-items: center; text-align: center; }
  .eve-sheet-header-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase; color: #6E6B64;
  }
  .eve-sheet-header-eyebrow::before { content: '● '; font-size: 6px; vertical-align: middle; color: var(--onb-petrol); }
  .eve-sheet-header-name {
    margin: 0; font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 700; letter-spacing: -0.01em; color: var(--onb-ink);
  }
  .eve-name-dot { color: var(--onb-petrol); font-style: normal; }

  /* Messages */
  .eve-sheet-messages { flex: 1; overflow-y: auto; padding: 18px 18px; scroll-behavior: smooth; }
  /* flex-wrap explizit: GuestPhoneView (Step 2) lädt global guest-preview.css,
     deren .eve-message flex-wrap:wrap setzt — hier neutralisiert. */
  .eve-message { display: flex; flex-wrap: nowrap; margin-bottom: 16px; max-width: 100%; align-items: flex-end; }
  .eve-message--user { justify-content: flex-end; }
  .eve-message--assistant { justify-content: flex-start; }
  .eve-message-bubble {
    max-width: 88%; padding: 16px 18px;
    font-family: 'Inter Tight', system-ui, sans-serif;
    font-size: 15px; line-height: 1.55;
    white-space: pre-wrap; word-wrap: break-word;
  }
  .eve-message--user .eve-message-bubble { background: #0A0A0A; color: #FAFAF6; border-radius: 12px; }
  .eve-message--assistant .eve-message-bubble {
    background: #FFFFFF; color: #0A0A0A;
    border: 1px solid var(--onb-border-card); border-radius: 12px;
  }
  .eve-message--assistant .eve-message-bubble::before {
    content: attr(data-sender); display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 7.5px; font-weight: 600; letter-spacing: 0.2em;
    color: var(--onb-petrol); margin-bottom: 6px;
  }

  /* Typing */
  .eve-typing-wrap { display: flex; margin-bottom: 16px; }
  .eve-typing {
    display: inline-flex; gap: 4px; align-items: center; padding: 14px 18px;
    background: #FFFFFF; border: 1px solid var(--onb-border-card);
    border-radius: 12px; width: fit-content;
  }
  .eve-typing span {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--onb-petrol);
    animation: onb-typing-bounce 1.2s infinite ease-in-out;
  }
  .eve-typing span:nth-child(2) { animation-delay: 0.15s; }
  .eve-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes onb-typing-bounce { 0%,60%,100%{transform:translateY(0);opacity:0.4} 30%{transform:translateY(-4px);opacity:1} }

  /* Input (dekorativ — kein interaktiver Chat) */
  .eve-sheet-input-row {
    flex-shrink: 0; display: flex; gap: 8px; margin: 0;
    padding: 12px 16px;
    border-top: 1px solid var(--onb-border-card); background: #FFFFFF;
  }
  .eve-sheet-input {
    flex: 1; padding: 12px 16px;
    border: 1px solid var(--onb-border-card); border-radius: 12px;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    color: var(--onb-ink); background: var(--onb-bg);
    outline: none; transition: border-color 0.15s ease, background 0.15s ease;
  }
  .eve-sheet-input:focus,
  .eve-sheet-input.is-active { border-color: var(--onb-petrol); background: #FFFFFF; }
  .eve-sheet-input.is-active { caret-color: var(--onb-petrol); }
  .eve-sheet-send.is-active { background: var(--onb-petrol); }
  .eve-sheet-send {
    flex-shrink: 0; width: 44px; height: 44px;
    border: none; border-radius: 12px;
    background: #0A0A0A; color: #FAFAF6;
    font-size: 22px; line-height: 1; cursor: pointer;
    transition: background 0.15s ease;
  }
  .eve-sheet-send:hover { background: var(--onb-petrol); }

  /* ── Schritt-Balken ────────────────────────────────────────────── */
  .onb-steps {
    display: flex; justify-content: center; align-items: center; gap: 8px;
    margin: 28px auto 0;
  }
  .onb-step {
    appearance: none; -webkit-appearance: none; padding: 0; border: none;
    flex: 0 0 auto; width: 20px; height: 5px; border-radius: 999px;
    background: var(--border-medium, rgba(10,10,10,0.14));
    cursor: pointer;
    transition: width 0.3s ease, background 0.2s ease, opacity 0.2s ease;
  }
  .onb-step.is-active { width: 46px; background: var(--onb-petrol); }
  .onb-step:not(.is-active):not(:disabled):hover { background: var(--onb-petrol); opacity: 0.45; }
  .onb-step:disabled { cursor: default; }

  /* ── Entrance-Animation ────────────────────────────────────────── */
  .onb-reveal { opacity: 0; transform: translateY(12px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .onb-reveal.is-in { opacity: 1; transform: none; }

  /* Chat-Bubbles: verborgen reservieren KEINEN Platz — sonst scrollt die App
     sofort an der Begrüßung vorbei. Erscheinen einzeln mit sanftem Fade. */
  .eve-message:not(.is-in), .eve-typing-wrap:not(.is-in) { display: none; }
  .eve-message.is-in, .eve-typing-wrap.is-in { animation: onb-msg-in 0.4s ease both; }
  @keyframes onb-msg-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  @media (prefers-reduced-motion: reduce) {
    .onb-reveal { opacity: 1 !important; transform: none !important; transition: none; }
    .eve-message { display: flex !important; }
    .eve-message.is-in { animation: none !important; }
    .eve-typing-wrap { display: none !important; }
  }
</style>

<noscript>
  <style>
    .onb-reveal { opacity: 1 !important; transform: none !important; }
    .eve-message { display: flex !important; }
    .eve-typing-wrap { display: none !important; }
  </style>
</noscript>

<script is:inline>
  (function () {
    var hero = document.querySelector('[data-onb-hero]');
    if (!hero) return;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var reveals = Array.prototype.slice.call(hero.querySelectorAll('.onb-reveal'));
    var msgs = Array.prototype.slice.call(hero.querySelectorAll('[data-step]'));
    var typing = hero.querySelector('[data-eve-typing]');
    var avatar = hero.querySelector('[data-eve-avatar]');
    var msgArea = hero.querySelector('[data-eve-messages]');
    var input = hero.querySelector('[data-eve-input]');
    var sendBtn = hero.querySelector('[data-eve-send]');

    function scrollDown() {
      if (!msgArea) return;
      // erst nach Layout scrollen (smooth via CSS scroll-behavior)
      requestAnimationFrame(function () {
        if (typeof msgArea.scrollTo === 'function') msgArea.scrollTo({ top: msgArea.scrollHeight, behavior: 'smooth' });
        else msgArea.scrollTop = msgArea.scrollHeight;
      });
    }
    function pulseOn()  { if (avatar) avatar.classList.add('is-typing'); }
    function pulseOff() { if (avatar) avatar.classList.remove('is-typing'); }
    function showTyping(beforeEl) {
      if (!typing) return;
      if (beforeEl && beforeEl.parentNode) beforeEl.parentNode.insertBefore(typing, beforeEl);
      typing.hidden = false; void typing.offsetWidth; typing.classList.add('is-in');
      pulseOn(); scrollDown();
    }
    function hideTyping() {
      if (!typing) return;
      typing.hidden = true; typing.classList.remove('is-in'); pulseOff();
    }
    function showMsg(i) { if (msgs[i]) { msgs[i].classList.add('is-in'); scrollDown(); } }

    // Gast „tippt" die Frage Zeichen für Zeichen ins Feld (wirkt wie echtes Chatten)
    function typeInto(text, done) {
      if (!input) { done && done(); return; }
      input.classList.add('is-active'); if (sendBtn) sendBtn.classList.add('is-active');
      var i = 0;
      (function tick() {
        input.value = text.slice(0, i);
        if (i++ < text.length) setTimeout(tick, 42 + Math.random() * 55);
        else setTimeout(function () { done && done(); }, 380);
      })();
    }
    // „Senden": Feld leeren + zugehörige Gast-Bubble einblenden
    function sendUser(i) {
      if (input) { input.value = ''; input.classList.remove('is-active'); }
      if (sendBtn) sendBtn.classList.remove('is-active');
      showMsg(i);
    }

    // Höhe + Step-Wechsel + „Setup überspringen" steuert der Flow-Controller
    // in uebersicht.astro (gemeinsam für beide Steps).

    if (reduce) {
      reveals.forEach(function (el) { el.classList.add('is-in'); });
      msgs.forEach(function (el) { el.classList.add('is-in'); });
      return;
    }

    function start() {
      reveals.forEach(function (el) {
        var r = parseInt(el.getAttribute('data-r') || '0', 10);
        setTimeout(function () { el.classList.add('is-in'); }, r * 90);
      });

      // Demo-Chat — wirkt wie echtes Chatten: Gast tippt, Eve tippt + antwortet.
      // Beat 1 (Erleichterung): „Wann gibt es Frühstück?" → Wintergarten, 7–10:30.
      // Beat 2 (Überraschung): „Was gibt es in der Nähe?" → Museum für Naturkunde
      //                         + Hamburger Bahnhof, ~10 Min.
      setTimeout(function () { showMsg(0); }, 700);                       // Eve-Greeting

      setTimeout(function () {
        typeInto('Wann gibt es Frühstück?', function () {
          sendUser(1);
          setTimeout(function () { showTyping(msgs[2]); }, 450);
          setTimeout(function () {
            hideTyping(); showMsg(2);
            setTimeout(function () {
              typeInto('Was gibt es in der Nähe?', function () {
                sendUser(3);
                setTimeout(function () { showTyping(msgs[4]); }, 450);
                setTimeout(function () { hideTyping(); showMsg(4); }, 1850);
              });
            }, 1000);
          }, 1300);
        });
      }, 1600);
    }

    if ('requestAnimationFrame' in window) requestAnimationFrame(function () { setTimeout(start, 120); });
    else setTimeout(start, 200);
  })();
</script>
