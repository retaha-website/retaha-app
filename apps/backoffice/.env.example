# @retaha/backoffice-app — backoffice.retaha.de
#
# Hotelier-Config: Settings, Marketing-Editor, Themes, NFC-Tags, Showcase,
# Team, Cron-Jobs (Auto-Delete, Marketing-Drips, Places-Refresh).
#
# Setup: cp .env.example .env  →  Werte fuellen.

# ─── Supabase ────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── SSO-Cross-Subdomain-Cookie ──────────────────────────────
COOKIE_DOMAIN=.retaha.local
AUTH_APP_URL=http://auth.retaha.local:4321

# ─── Anthropic (Eve-Knowledge-Translator + Marketing-Translate) ──
ANTHROPIC_API_KEY=

# ─── DeepL (Backoffice-Uebersetzungs-Pipeline) ───────────────
DEEPL_API_KEY=

# ─── Mews-Token-Encryption ───────────────────────────────────
ENCRYPTION_KEY=

# ─── MFA Secret-Encryption (Sprint-I 2FA) ────────────────────
# AES-256-GCM Key fuer TOTP-Secrets in user_mfa.secret_encrypted.
# Separater Key, NICHT ENCRYPTION_KEY oben wiederverwenden.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MFA_ENCRYPTION_KEY=<32-bytes-base64>

# ─── Mews Connector API (fuer Admin-PMS-Setup) ───────────────
MEWS_API_BASE_URL=https://api.mews-demo.com
MEWS_CLIENT_NAME=retaha 1.0.0

# ─── Google Wallet (Pass-Class-Management + Marketing-Push) ──
WALLET_GOOGLE_ISSUER_ID=
WALLET_GOOGLE_SERVICE_ACCOUNT_JSON=
WALLET_DEEP_LINK_SECRET=
WALLET_OPT_OUT_SECRET=

# ─── Email-Provider (Marketing-Campaigns + Team-Invites) ─────
MICROSOFT_SMTP_HOST=smtp.office365.com
MICROSOFT_SMTP_PORT=587
MICROSOFT_SMTP_USER=noreply@retaha.de
MICROSOFT_SMTP_PASSWORD=

# Optional: Resend als Fallback fuer Marketing-Emails (Sprint G)
RESEND_API_KEY=

# ─── Cron-Auth ───────────────────────────────────────────────
CRON_SECRET=

# ─── Auto-Delete Kill-Switch ────────────────────────────────
# DSGVO-Auto-Delete von alten Stays. Bleibt OFF bis Anwalt-Freigabe.
AUTO_DELETE_ENABLED=false

# ─── Google Places (Admin-Side-Setup fuer Empfehlungen) ──────
GOOGLE_PLACES_API_KEY=

# ─── Stay-Session JWT (fuer admin-seitige Stay-Lookups) ─────
STAY_SESSION_SECRET=
