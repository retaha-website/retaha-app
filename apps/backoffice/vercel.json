{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @retaha/backoffice-app build",
  "outputDirectory": ".vercel/output",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/marketing-scheduler",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/marketing-drips",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/auto-delete-stays",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/eve-chat-cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/places-refresh",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/places-nearby-refresh",
      "schedule": "0 6 * * 0"
    }
  ]
}
