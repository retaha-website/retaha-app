# @retaha/auth-app — auth.retaha.de
#
# Magic-Link-Empfaenger + SSO-Cookie-Setter.
#
# Setup: cp .env.example .env  →  Werte fuellen.

# ─── Supabase ────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# Service-Role nur fuer rate-limit-Table (Sprint G Backlog), aktuell nicht genutzt
SUPABASE_SERVICE_ROLE_KEY=

# ─── SSO-Cross-Subdomain-Cookie ──────────────────────────────
# Production: .retaha.de  ·  Dev: .retaha.local
COOKIE_DOMAIN=.retaha.local

# Auth-App-URL (verwendet in Email-Redirect-URLs)
# Production: https://auth.retaha.de  ·  Dev: http://auth.retaha.local:4321
AUTH_APP_URL=http://auth.retaha.local:4321

# Allowed Redirect Targets — Komma-getrennt, Open-Redirect-Protection
# Default-Liste in src/lib/redirect-whitelist.ts wird verwendet wenn leer.
ALLOWED_REDIRECT_DOMAINS=app.retaha.local,dashboard.retaha.local,backoffice.retaha.local

# Default-Redirect wenn return_to nicht whitelisted
DEFAULT_REDIRECT_TARGET=http://backoffice.retaha.local:4324/

# ─── Email-Provider (Supabase Auth ruft Resend automatisch) ─
# Konfiguration in Supabase-Dashboard:
# Authentication → Providers → Email → SMTP-Settings mit Resend-Credentials.
# Kein direktes RESEND_API_KEY hier — geht ueber Supabase.

# ─── MFA Secret-Encryption (Sprint-I 2FA) ────────────────────
# AES-256-GCM Key fuer TOTP-Secrets in user_mfa.secret_encrypted.
# Separater Key, NICHT ENCRYPTION_KEY (Mews-Tokens) wiederverwenden.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MFA_ENCRYPTION_KEY=<32-bytes-base64>
