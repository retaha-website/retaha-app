---
// apps/auth — Shared Layout für Login/Callback/Logout/Error.
// Bauhaus-Marken-Signaturen via @retaha/ui Styles.
import '@retaha/ui/styles/themes.css';
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';

interface Props {
  title: string;
  eyebrow?: string;
}
const { title, eyebrow } = Astro.props;
---
<!DOCTYPE html>
<html lang="de" data-theme="bauhaus_manufaktur">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · auth.retaha</title>
  </head>
  <body class="auth-body">
    <main class="auth-shell">
      {eyebrow && <p class="auth-eyebrow themed-eyebrow-flank">{eyebrow}</p>}
      <slot />
    </main>
    <footer class="auth-foot">
      <span class="auth-foot-shapes" aria-hidden="true">
        <span class="circle"></span>
        <span class="square"></span>
        <span class="triangle"></span>
      </span>
      <span>retaha hospitality</span>
    </footer>

    <style>
      .auth-body {
        margin: 0;
        font-family: var(--theme-font-sans);
        background: var(--theme-bg-primary);
        color: var(--theme-text-primary);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 24px;
      }
      .auth-shell {
        width: 100%;
        max-width: 420px;
      }
      .auth-eyebrow {
        font-family: var(--theme-font-mono);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--theme-accent);
        margin: 0 0 24px;
        text-align: center;
      }
      .auth-foot {
        margin-top: 48px;
        font-family: var(--theme-font-mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--theme-text-muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .auth-foot-shapes { display: inline-flex; gap: 4px; align-items: center; }
      .auth-foot-shapes .circle,
      .auth-foot-shapes .square,
      .auth-foot-shapes .triangle {
        width: 6px; height: 6px; display: block;
      }
      .auth-foot-shapes .circle   {
        background: var(--theme-accent);
        border-radius: var(--theme-radius-pill);
      }
      .auth-foot-shapes .square   { background: var(--theme-text-primary); }
      .auth-foot-shapes .triangle {
        width: 0; height: 0;
        border-left: 3px solid transparent;
        border-right: 3px solid transparent;
        border-bottom: 6px solid var(--theme-accent);
        background: transparent;
      }
    </style>
  </body>
</html>
