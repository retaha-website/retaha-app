---
import AuthLayout from '../layouts/AuthLayout.astro';
import { clearSessionCookie } from '@retaha/auth';
import { clearMfaMarkerCookie } from '@retaha/auth/mfa';

// Logout via GET ist OK weil Idempotent (Cookie löschen).
// Für CSRF-strikten Flow gibt es zusätzlich /api/auth/logout POST.
clearSessionCookie(Astro.cookies);
clearMfaMarkerCookie(Astro.cookies);
---

<AuthLayout title="abgemeldet" eyebrow="bis bald">
  <h1 class="lo-headline">
    Abgemeldet<span class="h-dot">.</span>
  </h1>
  <p class="lo-sub">
    Dein Cookie ist gelöscht. Willst du dich erneut anmelden?
  </p>
  <a href="/login" class="lo-link">→ Zur Anmeldung</a>

  <style>
    .lo-headline {
      font-family: var(--theme-font-headline);
      font-size: 32px;
      font-weight: 300;
      letter-spacing: -0.02em;
      margin: 0 0 12px;
      text-align: center;
    }
    .lo-sub {
      text-align: center;
      color: var(--theme-text-secondary);
      margin: 0 0 24px;
    }
    .lo-link {
      display: block;
      text-align: center;
      color: var(--theme-accent);
      font-size: 14px;
      text-decoration: none;
      padding: 12px;
      border: 1px solid var(--theme-border);
      border-radius: var(--theme-radius-button);
      transition: background 0.15s ease, color 0.15s ease;
    }
    .lo-link:hover {
      background: var(--theme-accent);
      color: var(--theme-text-on-accent);
    }
  </style>
</AuthLayout>
