---
import AuthLayout from '../layouts/AuthLayout.astro';
import { clearSessionCookie } from '@retaha/auth';
import { clearMfaMarkerCookie } from '@retaha/auth/mfa';

// Logout via GET ist OK weil idempotent (Cookie löschen).
// Für CSRF-strikten Flow gibt es zusätzlich /api/auth/logout POST.
clearSessionCookie(Astro.cookies);
clearMfaMarkerCookie(Astro.cookies);
---

<AuthLayout title="abgemeldet" eyebrow="bis bald" eyebrowFlank={false}>
  <h1 class="lo-headline">
    Abgemeldet<span class="h-dot">.</span>
  </h1>
  <p class="lo-sub">
    Ihr Cookie ist gelöscht. Möchten Sie sich erneut anmelden?
  </p>
  <a href="/login" class="lo-link">Zur Anmeldung</a>

  <!-- Pink-Akzent (Theme-Default) auf der Logout-Seite durch Petrol ersetzen —
       wirkt auf Eyebrow, Satzpunkt und die Bauhaus-Fußformen. -->
  <style is:global>
    html[data-theme="bauhaus_manufaktur"] body { --theme-accent: #14616E; }
  </style>

  <style>
    /* „Abgemeldet" im selben Font wie „Anmelden" auf der Hauptseite (Space Grotesk 500 / 28px). */
    .lo-headline {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      font-size: 28px;
      font-weight: 500;
      letter-spacing: -0.018em;
      line-height: 1.2;
      margin: 0 0 12px;
      text-align: center;
    }
    .lo-headline .h-dot { color: #14616E; }
    .lo-sub {
      text-align: center;
      color: var(--theme-text-secondary);
      font-size: 14px;
      line-height: 1.55;
      margin: 0 0 28px;
    }
    /* Button wie der Primary-Button der Hauptseite: anthrazit gefüllt, 3px Radius. */
    .lo-link {
      display: block;
      text-align: center;
      background: #1A1A1A;
      color: #FFFFFF;
      font-family: 'Space Grotesk', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      padding: 15px 24px;
      border: none;
      border-radius: 3px;
      transition: background 0.2s ease, transform 0.12s ease;
    }
    .lo-link:hover { background: #2A2A2A; transform: translateY(-2px); }
    .lo-link:active { transform: translateY(0); }
  </style>
</AuthLayout>
