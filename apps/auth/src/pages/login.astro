<!DOCTYPE html>
<html lang={initialLang} data-theme="bauhaus_manufaktur">
  <head>
    <meta charset="utf-8" />
    <!-- viewport-fit=cover = KRITISCH fuer iOS-Status-Bar:
         ohne diesen Flag rendert Safari die Status-Bar-Area AUSSERHALB
         des Page-Viewports -> Status-Bar zeigt Default-Weiss.
         Mit cover: Page extendet UNTER die Status-Bar -> Status-Bar
         nimmt die Farbe des darunter liegenden Page-Inhalts an. -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex,nofollow" />
    <!-- Explizites color-scheme zwingt iOS zur theme-color-Anwendung -->
    <meta name="color-scheme" content="light dark" />
    <!-- theme-color media-getrennt fuer beide System-Modi (iOS 16+ Behandlung) -->
    <meta name="theme-color" content="#1A1A1A" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1A1A1A" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#1A1A1A" />
    <!-- PWA-Standalone-Mode (Add to Home Screen): Status-Bar transparent over content -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Anmelden · retaha</title>
  </head>
  <body>

    <main
      class="auth-layout"
      x-data={`{
        passwordExpanded: false,
        email: '',
        password: '',
        emailError: '',
        passwordError: '',
        errorMessage: '',
        isSubmitting: false,
        successShown: false,
        sentEmail: '',
        resendCooldown: 0,
        _resendTimer: null,
        returnTo: ${JSON.stringify(returnTo)},
        currentLang: ${JSON.stringify(initialLang)},
        translations: ${JSON.stringify(t)},

        init() {
          const allowed = ['de', 'en', 'fr', 'es', 'tr'];
          // Cookie (cross-subdomain) hat Vorrang vor localStorage,
          // localStorage faellt zurueck auf Browser-Sprache.
          const cookieMatch = document.cookie.match(/(?:^|;\\s*)retaha_lang=([^;]+)/);
          const fromCookie = cookieMatch ? decodeURIComponent(cookieMatch[1]) : '';
          const fromStorage = (typeof localStorage !== 'undefined' && localStorage.getItem('retaha_lang')) || '';
          const stored = fromCookie || fromStorage;
          if (allowed.indexOf(stored) >= 0) {
            this.currentLang = stored;
          } else if (typeof navigator !== 'undefined') {
            const browser = (navigator.language || 'de').slice(0, 2).toLowerCase();
            if (allowed.indexOf(browser) >= 0) this.currentLang = browser;
          }
          document.documentElement.lang = this.currentLang;
          // Cookie sync: falls Sprache aus localStorage/Browser kommt aber Cookie fehlt,
          // jetzt Cookie setzen damit Folge-Apps (dashboard, backoffice) gleiche Sprache haben.
          if (!fromCookie) this._writeLangCookie(this.currentLang);
        },

        _writeLangCookie(lang) {
          // Cross-Subdomain Cookie: gilt fuer alle *.retaha.de Apps.
          const host = window.location.hostname;
          const isProd = host.endsWith('.retaha.de') || host === 'retaha.de';
          const domain = isProd ? '; domain=.retaha.de' : '';
          const maxAge = 365 * 24 * 3600; // 1 Jahr
          document.cookie = 'retaha_lang=' + encodeURIComponent(lang) + '; path=/' + domain + '; max-age=' + maxAge + '; SameSite=Lax';
        },

        t(key, vars) {
          const dict = this.translations[this.currentLang] || this.translations.de;
          let s = dict[key] || key;
          if (vars) Object.keys(vars).forEach(k => { s = s.replace('{' + k + '}', vars[k]); });
          return s;
        },

        setLang(lang) {
          this.currentLang = lang;
          try { localStorage.setItem('retaha_lang', lang); } catch (e) {}
          this._writeLangCookie(lang);
          document.documentElement.lang = lang;
        },

          togglePassword() {
            this.passwordExpanded = !this.passwordExpanded;
            this.errorMessage = '';
            this.passwordError = '';
            if (this.passwordExpanded) {
              this.$nextTick(() => {
                setTimeout(() => this.$refs.passwordInput?.focus(), 700);
              });
            } else {
              this.password = '';
            }
          },

          validateEmail() {
            if (!this.email) { this.emailError = this.t('err_email_empty'); return false; }
            const re = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;
            if (!re.test(this.email)) {
              this.emailError = this.t('err_email_invalid');
              return false;
            }
            this.emailError = '';
            return true;
          },

          validatePassword() {
            if (!this.password) { this.passwordError = this.t('err_password_empty'); return false; }
            if (this.password.length < 8) {
              this.passwordError = this.t('err_password_short');
              return false;
            }
            this.passwordError = '';
            return true;
          },

          startResendCooldown() {
            this.resendCooldown = 60;
            if (this._resendTimer) clearInterval(this._resendTimer);
            this._resendTimer = setInterval(() => {
              this.resendCooldown--;
              if (this.resendCooldown <= 0) { clearInterval(this._resendTimer); this._resendTimer = null; }
            }, 1000);
          },

          async submit(e) {
            e?.preventDefault?.();
            this.errorMessage = '';
            if (!this.validateEmail()) { this.$refs.emailInput?.focus(); return; }
            if (this.passwordExpanded && !this.validatePassword()) { this.$refs.passwordInput?.focus(); return; }
            this.isSubmitting = true;
            try {
              if (this.passwordExpanded) {
                const res = await fetch('/api/auth/login-password', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: this.email, password: this.password, return_to: this.returnTo }),
                });
                const data = await res.json().catch(() => ({}));
                if (data.ok && data.redirect) { window.location.href = data.redirect; return; }
                this.errorMessage = this.t('err_credentials');
              } else {
                const res = await fetch('/api/auth/send-magic-link', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: this.email, return_to: this.returnTo }),
                });
                const data = await res.json().catch(() => ({}));
                if (data.ok) {
                  this.sentEmail = this.email;
                  this.successShown = true;
                  this.startResendCooldown();
                  return;
                }
                this.errorMessage = data.error === 'unknown-email'
                  ? this.t('err_unknown_email')
                  : data.error === 'rate-limited'
                  ? this.t('err_rate_limit')
                  : this.t('err_send_failed');
              }
            } catch (err) {
              this.errorMessage = this.t('err_network');
            } finally {
              this.isSubmitting = false;
            }
          },

          async resend() {
            if (this.resendCooldown > 0 || this.isSubmitting) return;
            this.isSubmitting = true;
            try {
              const res = await fetch('/api/auth/send-magic-link', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: this.sentEmail, return_to: this.returnTo }),
              });
              const data = await res.json().catch(() => ({}));
              if (data.ok) this.startResendCooldown();
            } catch (err) { /* silent */ } finally { this.isSubmitting = false; }
          },

          resetToForm() {
            this.successShown = false;
            this.email = '';
            this.sentEmail = '';
            this.errorMessage = '';
            this.emailError = '';
            this.passwordExpanded = false;
          },
        }`}
        x-init="init()"
      >

      <!-- ═══════════ HERO LINKS 45% ═══════════ -->
      <aside class="auth-hero">
        <!-- hero-top: auf Desktop "display: contents" (transparent), auf Tablet/Mobile flex zwischen Logo + Mobile-Switcher -->
        <div class="hero-top">
          <Logo
            variant="light"
            size="md"
            href="https://retaha.de"
            ariaLabel="retaha · zur Startseite"
            class="brand-logo"
          />

          <!-- Mobile/Tablet Switcher — native <select>, zeigt System-Picker auf iOS/Android -->
          <div class="lang-switcher-mobile-wrap" x-cloak>
            <select
              class="lang-select-mobile"
              aria-label="Sprache"
              :value="currentLang"
              @change="setLang($event.target.value)"
