<!DOCTYPE html>
<html lang={initialLang} dir={isRTL ? 'rtl' : 'ltr'} data-theme="bauhaus_manufaktur">
  <head>
    <meta charset="utf-8" />
    <!-- iOS Safari Status-Bar Setup (Versuche #1-11 dokumentiert in
         docs/debug-reports/IOS_STATUS_BAR_INVESTIGATION.md).
         Finale Strategie: viewport-fit=cover + black-translucent + manifest
         + body-bg anthrazit (Safari 26 Live-Observer samplet body). -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Anmelden · retaha</title>
  </head>
  <body>

    <main
      class="auth-layout"
      x-data={`{
        passwordExpanded: true,
        email: '',
        password: '',
        emailError: '',
        passwordError: '',
        errorMessage: '',
        isSubmitting: false,
        successShown: false,
        sentEmail: '',
        resendCooldown: 0,
        _resendTimer: null,
        returnTo: ${JSON.stringify(returnTo)},
        currentLang: ${JSON.stringify(initialLang)},
        translations: ${JSON.stringify(t)},
        langOverlayOpen: false,

        init() {
          // Middleware liefert Sprache via Astro.locals.currentLang als initialLang.
          // Hier nur Cookie sync falls noch nicht gesetzt + dir-Attribut fuer RTL.
          const allowed = ['de', 'en', 'tr', 'fr', 'es', 'it', 'pt', 'nl', 'ru', 'ar', 'zh'];
          const cookieMatch = document.cookie.match(/(?:^|;\\s*)retaha_lang=([^;]+)/);
          const fromCookie = cookieMatch ? decodeURIComponent(cookieMatch[1]) : '';
          if (!fromCookie) this._writeLangCookie(this.currentLang);
          document.documentElement.lang = this.currentLang;
          document.documentElement.dir = this.currentLang === 'ar' ? 'rtl' : 'ltr';
        },

        _writeLangCookie(lang) {
          // Cross-Subdomain Cookie: gilt fuer alle *.retaha.de Apps.
          const host = window.location.hostname;
          const isProd = host.endsWith('.retaha.de') || host === 'retaha.de';
          const domain = isProd ? '; domain=.retaha.de' : '';
          const maxAge = 365 * 24 * 3600; // 1 Jahr
          document.cookie = 'retaha_lang=' + encodeURIComponent(lang) + '; path=/' + domain + '; max-age=' + maxAge + '; SameSite=Lax';
        },

        t(key, vars) {
          const dict = this.translations[this.currentLang] || this.translations.de;
          let s = dict[key] || key;
          if (vars) Object.keys(vars).forEach(k => { s = s.replace('{' + k + '}', vars[k]); });
          return s;
        },

        setLang(lang) {
          // 1. Cookie + localStorage persistieren (cross-subdomain fuer Dashboard/Backoffice)
          try { localStorage.setItem('retaha_lang', lang); } catch (e) {}
          this._writeLangCookie(lang);
          // 2. URL umbauen + reload damit Astro i18n routing greift (z.B. /en/login).
          //    DE bleibt ohne Prefix (prefixDefaultLocale: false).
          const langPrefixRegex = /^\\/(de|en|tr|fr|es|it|pt|nl|ru|ar|zh)(?=\\/|$)/;
          const cleanPath = window.location.pathname.replace(langPrefixRegex, '') || '/';
          const newPath = lang === 'de' ? cleanPath : '/' + lang + (cleanPath === '/' ? '' : cleanPath);
          window.location.href = newPath + window.location.search;
        },

          togglePassword() {
            this.passwordExpanded = !this.passwordExpanded;
            this.errorMessage = '';
            this.passwordError = '';
            if (this.passwordExpanded) {
              this.$nextTick(() => {
                setTimeout(() => this.$refs.passwordInput?.focus(), 700);
              });
            } else {
              this.password = '';
            }
          },

          validateEmail() {
            if (!this.email) { this.emailError = this.t('err_email_empty'); return false; }
            const re = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;
            if (!re.test(this.email)) {
              this.emailError = this.t('err_email_invalid');
              return false;
            }
            this.emailError = '';
            return true;
          },

          validatePassword() {
            if (!this.password) { this.passwordError = this.t('err_password_empty'); return false; }
            if (this.password.length < 8) {
              this.passwordError = this.t('err_password_short');
              return false;
            }
            this.passwordError = '';
            return true;
          },

          startResendCooldown() {
            this.resendCooldown = 60;
            if (this._resendTimer) clearInterval(this._resendTimer);
            this._resendTimer = setInterval(() => {
              this.resendCooldown--;
              if (this.resendCooldown <= 0) { clearInterval(this._resendTimer); this._resendTimer = null; }
            }, 1000);
          },

          async submit(e) {
            e?.preventDefault?.();
            this.errorMessage = '';
            if (!this.validateEmail()) { this.$refs.emailInput?.focus(); return; }
            if (this.passwordExpanded && !this.validatePassword()) { this.$refs.passwordInput?.focus(); return; }
            this.isSubmitting = true;
            try {
              if (this.passwordExpanded) {
                const res = await fetch('/api/auth/login-password', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: this.email, password: this.password, return_to: this.returnTo }),
                });
                const data = await res.json().catch(() => ({}));
                if (data.ok && data.redirect) { window.location.href = data.redirect; return; }
                this.errorMessage = this.t('err_credentials');
              } else {
                const res = await fetch('/api/auth/send-magic-link', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ email: this.email, return_to: this.returnTo }),
                });
                const data = await res.json().catch(() => ({}));
                if (data.ok) {
                  this.sentEmail = this.email;
                  this.successShown = true;
                  this.startResendCooldown();
                  return;
                }
                this.errorMessage = data.error === 'unknown-email'
                  ? this.t('err_unknown_email')
                  : data.error === 'rate-limited'
                  ? this.t('err_rate_limit')
                  : this.t('err_send_failed');
              }
            } catch (err) {
              this.errorMessage = this.t('err_network');
            } finally {
              this.isSubmitting = false;
            }
          },

          async resend() {
            if (this.resendCooldown > 0 || this.isSubmitting) return;
            this.isSubmitting = true;
            try {
              const res = await fetch('/api/auth/send-magic-link', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: this.sentEmail, return_to: this.returnTo }),
