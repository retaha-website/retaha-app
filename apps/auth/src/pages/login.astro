---
import AuthLayout from '../layouts/AuthLayout.astro';
import { sanitizeReturnTo } from '../lib/redirect-whitelist';

const url = new URL(Astro.request.url);
const rawReturnTo = url.searchParams.get('return_to');
// Whitelist-Check schon hier, damit return_to in form-action sicher ist.
const returnTo = sanitizeReturnTo(rawReturnTo);
const flashSent = url.searchParams.get('sent') === '1';
const flashError = url.searchParams.get('error');
---

<AuthLayout title="anmeldung" eyebrow="hotelier anmeldung">
  <h1 class="login-headline">
    {flashSent ? 'Check deine Mailbox' : 'Willkommen zurück'}<span class="h-dot">.</span>
  </h1>

  {flashSent ? (
    <p class="login-sub">
      Wir haben dir einen Magic-Link an deine E-Mail-Adresse gesendet.
      <br />Öffne ihn auf diesem Gerät — dann bist du eingeloggt.
    </p>
  ) : (
    <p class="login-sub">
      Gib deine E-Mail ein. Wir senden dir einen Einmal-Link für die Anmeldung.
    </p>
  )}

  {flashError && (
    <p class="login-error">{flashError}</p>
  )}

  {!flashSent && (
    <>
      <form
        class="login-form"
        method="POST"
        action="/api/auth/send-magic-link"
        autocomplete="off"
        data-form="magic-link"
      >
        <input type="hidden" name="return_to" value={returnTo} />
        <label class="login-label" for="email">E-Mail</label>
        <input
          id="email"
          type="email"
          name="email"
          required
          autocomplete="email"
          inputmode="email"
          placeholder="hotelier@example.com"
          class="login-input"
        />
        <button type="submit" class="login-submit">
          magic-link senden
        </button>
      </form>

      <form
        class="login-form login-form--password"
        method="POST"
        action="/api/auth/login-password"
        autocomplete="on"
        data-form="password"
        hidden
      >
        <input type="hidden" name="return_to" value={returnTo} />
        <label class="login-label" for="email-pw">E-Mail</label>
        <input
          id="email-pw"
          type="email"
          name="email"
          required
          autocomplete="email"
          inputmode="email"
          placeholder="hotelier@example.com"
          class="login-input"
        />
        <label class="login-label" for="password">Passwort</label>
        <input
          id="password"
          type="password"
          name="password"
          required
          autocomplete="current-password"
          minlength="8"
          placeholder="dein passwort"
          class="login-input"
        />
        <button type="submit" class="login-submit">
          anmelden
        </button>
      </form>

      <button type="button" class="login-toggle" data-toggle="auth-method">
        <span data-show="magic-link">→ Mit Passwort anmelden</span>
        <span data-show="password" hidden>→ Mit Magic-Link anmelden</span>
      </button>
    </>
  )}

  <p class="login-foot">
    Kein Zugang? Frag deinen Team-Owner um eine Einladung.
  </p>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const toggleBtn = document.querySelector('[data-toggle="auth-method"]');
      const magicForm = document.querySelector('[data-form="magic-link"]');
      const passwordForm = document.querySelector('[data-form="password"]');
      const labelMagic = document.querySelector('[data-show="magic-link"]');
      const labelPassword = document.querySelector('[data-show="password"]');

      if (!toggleBtn || !magicForm || !passwordForm) return;

      let usingPassword = false;
      toggleBtn.addEventListener('click', () => {
        usingPassword = !usingPassword;
        magicForm.hidden = usingPassword;
        passwordForm.hidden = !usingPassword;
        if (labelMagic) labelMagic.hidden = usingPassword;
        if (labelPassword) labelPassword.hidden = !usingPassword;
      });
    });
  </script>

  <style>
    .login-headline {
      font-family: var(--theme-font-headline);
      font-size: 32px;
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin: 0 0 16px;
      text-align: center;
    }
    .login-sub {
      font-size: 15px;
      line-height: 1.55;
      color: var(--theme-text-secondary);
      text-align: center;
      margin: 0 0 28px;
    }
    .login-error {
      padding: 12px 14px;
      background: rgba(var(--theme-accent-rgb), 0.08);
      border-left: 3px solid var(--theme-accent);
      font-size: 13px;
      color: var(--theme-accent);
      margin: 0 0 20px;
      border-radius: var(--theme-radius);
    }
    .login-form {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 24px;
    }
    .login-label {
      font-family: var(--theme-font-mono);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--theme-text-tertiary);
    }
    .login-input {
      padding: 12px 14px;
      font-family: var(--theme-font-sans);
      font-size: 15px;
      border: 1px solid var(--theme-border);
      background: var(--theme-bg-primary);
      color: var(--theme-text-primary);
      border-radius: var(--theme-radius-input);
      transition: border-color 0.15s ease;
    }
    .login-input:focus {
      outline: none;
      border-color: var(--theme-accent);
      /* Marken-DNA: Pink-Glow auf Input-Focus */
      box-shadow: 0 0 0 3px rgba(var(--theme-accent-rgb), 0.1);
    }
    .login-submit {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 16px;
      padding: 14px 22px;
      background: var(--theme-text-primary);
      color: var(--theme-bg-primary);
      border: none;
      border-radius: var(--theme-radius-button);
      font-family: var(--theme-font-sans);
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 0.02em;
      text-transform: lowercase;
      cursor: pointer;
      transition: background 0.18s ease, color 0.18s ease;
    }
    /* Marken-Signatur: Pink-Punkt-Bullet links vor Button-Text. */
    .login-submit::before {
      content: '';
      display: block;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--theme-accent);
      flex-shrink: 0;
    }
    .login-submit:hover,
    .login-submit:focus-visible {
      background: var(--theme-accent);
      color: var(--theme-text-on-accent);
      outline: none;
    }
    .login-foot {
      text-align: center;
      font-size: 12px;
      color: var(--theme-text-muted);
      margin: 16px 0 0;
    }
    .login-toggle {
      display: block;
      width: 100%;
      padding: 10px 14px;
      margin: 8px 0 0;
      background: transparent;
      border: none;
      font-family: var(--theme-font-sans);
      font-size: 13px;
      color: var(--theme-accent);
      cursor: pointer;
      text-align: center;
      text-transform: lowercase;
      letter-spacing: 0.02em;
      transition: color 0.15s ease;
    }
    .login-toggle:hover,
    .login-toggle:focus-visible {
      color: var(--theme-text-primary);
      outline: none;
    }
  </style>
</AuthLayout>
