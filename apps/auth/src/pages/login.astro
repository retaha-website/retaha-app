    <!-- Dynamic Theme-Color (Status-Bar iOS/Android):
         Hero sichtbar oben -> #1A1A1A anthrazit,
         Form-Section gescrollt nach oben -> #FFFFFF weiss.
         Desktop ignoriert (kein Status-Bar Effekt).
         Uses rAF-throttled scroll listener — perf-OK.
         iOS Safari 15+ + Android Chrome unterstuetzen dynamische Updates. -->
    <script is:inline>
      (function () {
        var meta = document.querySelector('meta[name="theme-color"]');
        if (!meta) return;

        function update() {
          // Desktop (>= 1024px): kein Mobile-Status-Bar, statisch anthrazit fuer Safari-Tab-Color
          if (window.innerWidth >= 1024) {
            meta.setAttribute('content', '#1A1A1A');
            return;
          }
          var hero = document.querySelector('.auth-hero');
          if (!hero) return;
          // Wenn Hero-Bottom hoeher als 60px im Viewport -> User scrollt in weiss-Bereich -> Status-Bar weiss
          var heroBottom = hero.getBoundingClientRect().bottom;
          var newColor = heroBottom > 60 ? '#1A1A1A' : '#FFFFFF';
          if (meta.getAttribute('content') !== newColor) {
            meta.setAttribute('content', newColor);
          }
        }

        // rAF-Throttle damit Scroll-Listener nicht jeden Pixel berechnet
        var scheduled = false;
        function onScroll() {
          if (scheduled) return;
          scheduled = true;
          requestAnimationFrame(function () {
            scheduled = false;
            update();
          });
        }

        // Initial + Listener
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', update);
        } else {
          update();
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
      })();
    </script>

