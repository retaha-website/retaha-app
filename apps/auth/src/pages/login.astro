const middlewareLang = Astro.locals.currentLang;
const initialLang: typeof ALLOWED_LANGS[number] =
  middlewareLang && (ALLOWED_LANGS as readonly string[]).includes(middlewareLang)
    ? (middlewareLang as typeof ALLOWED_LANGS[number])
    : 'de';
const isRTL = initialLang === 'ar';

