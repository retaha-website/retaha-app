---
/**
 * apps/auth/src/pages/login.astro — v2.1
 *
 * Sprint-I-Findings-Fix-Run Round 2 (8-Bug-Fix):
 * - Bug 1: Layout 100vh ohne Scroll (Desktop)
 * - Bug 2: "Anmeldung." Grossschreibung
 * - Bug 3: H1 Editorial-Magazine-Groesse (32/48/56px)
 * - Bug 4: Eyebrow Pink-Shock auch auf dunklem BG
 * - Bug 5: Meta UPPERCASE via CSS
 * - Bug 6: Form-Toggle via Alpine x-data (exklusiv)
 * - Bug 7: Footer-Legal auf app.retaha.de
 * - Bug 8: Logo via <Logo /> Komponente aus @retaha/ui
 */

import { sanitizeReturnTo } from '../lib/redirect-whitelist';
import Logo from '@retaha/ui/components/brand/Logo.astro';
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/components/login.css';
import '@retaha/ui/styles/components/bauhaus-stamp.css';
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';

const url = new URL(Astro.request.url);
const rawReturnTo = url.searchParams.get('return_to');
const returnTo = sanitizeReturnTo(rawReturnTo);
const flashSent = url.searchParams.get('sent') === '1';
const flashError = url.searchParams.get('error');
---

<!DOCTYPE html>
<html lang="de" data-theme="bauhaus_manufaktur">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Anmeldung · retaha</title>
  </head>
  <body class="login-page">
    <!-- ═══════════ HERO 40% (links, Anthrazit) ═══════════ -->
    <aside class="login-hero">
      <Logo
        variant="light"
        size="md"
        href="https://retaha.de"
        ariaLabel="retaha · zur startseite"
        class="login-hero-brand"
      />

      <div class="login-hero-stack">
        <p class="login-hero-eyebrow">— manufaktur —</p>
        <h1 class="login-hero-headline">
          Willkommen zurück<span class="login-hero-dot">.</span>
        </h1>
        <p class="login-hero-tagline">Premium-Handwerk für Hotels.</p>
      </div>

      <div class="login-hero-meta">
        <span class="bauhaus-stamp bauhaus-stamp--md bauhaus-stamp--on-dark" aria-hidden="true">●  ■  ▲</span>
        <span>retaha hospitality · niedernhall</span>
      </div>
    </aside>

    <!-- ═══════════ FORM-SIDE 60% (rechts, weiß) ═══════════ -->
    <section class="login-form-side" x-data="{ mode: 'magic' }">
      <div class="login-form-container">

        {flashSent ? (
          <header class="login-form-header">
            <h2 class="login-form-title">
              Check deine Mailbox<span class="h-dot">.</span>
            </h2>
            <p class="login-form-sub">
              Wir haben dir einen Magic-Link an deine E-Mail-Adresse gesendet.
              Öffne ihn auf diesem Gerät — dann bist du eingeloggt.
            </p>
          </header>
        ) : (
          <>
            <!-- MAGIC-LINK STATE (default) -->
            <div x-show="mode === 'magic'" x-cloak>
              <header class="login-form-header">
                <h2 class="login-form-title">
                  Anmeldung<span class="h-dot">.</span>
                </h2>
                <p class="login-form-sub">
                  Gib deine E-Mail-Adresse ein. Wir senden dir einen Einmal-Link.
                </p>
              </header>

              {flashError && (
                <p class="login-error">{flashError}</p>
              )}

              <form
                class="login-form"
                method="POST"
                action="/api/auth/send-magic-link"
                autocomplete="off"
              >
                <input type="hidden" name="return_to" value={returnTo} />
                <label class="login-label" for="ml-email">E-Mail</label>
                <input
                  id="ml-email"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  inputmode="email"
                  placeholder="hotelier@example.com"
                  class="login-input"
                />
                <button type="submit" class="login-submit">
                  magic-link senden
                </button>
              </form>

              <button
                type="button"
                class="login-toggle"
                @click="mode = 'password'"
              >
                → stattdessen mit passwort anmelden
              </button>
            </div>

            <!-- PASSWORD STATE (hinter Toggle) -->
            <div x-show="mode === 'password'" x-cloak>
              <header class="login-form-header">
                <h2 class="login-form-title">
                  Mit Passwort anmelden<span class="h-dot">.</span>
                </h2>
                <p class="login-form-sub">
                  Wenn du lieber dein Passwort verwendest.
                </p>
              </header>

              {flashError && (
                <p class="login-error">{flashError}</p>
              )}

              <form
                class="login-form"
                method="POST"
                action="/api/auth/login-password"
                autocomplete="on"
              >
                <input type="hidden" name="return_to" value={returnTo} />
                <label class="login-label" for="pw-email">E-Mail</label>
                <input
                  id="pw-email"
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  inputmode="email"
                  placeholder="hotelier@example.com"
                  class="login-input"
                />
                <label class="login-label" for="pw-pass">Passwort</label>
                <input
                  id="pw-pass"
                  type="password"
                  name="password"
                  required
                  autocomplete="current-password"
                  minlength="8"
                  placeholder="dein passwort"
                  class="login-input"
                />
                <button type="submit" class="login-submit">
                  anmelden
                </button>
              </form>

              <button
                type="button"
                class="login-toggle"
                @click="mode = 'magic'"
              >
                ← stattdessen magic-link senden
              </button>
            </div>
          </>
        )}

        <p class="login-support">
          Kein Zugang? Kontaktiere den retaha-Support unter
          <a href="mailto:support@retaha.de">support@retaha.de</a>
          oder bitte deinen Admin um eine Einladung.
        </p>

        <footer class="login-form-footer">
          <a href="https://app.retaha.de/impressum" target="_blank" rel="noopener">impressum</a>
          <span class="login-form-footer-sep" aria-hidden="true">·</span>
          <a href="https://app.retaha.de/datenschutz" target="_blank" rel="noopener">datenschutz</a>
          <span class="login-form-footer-sep" aria-hidden="true">·</span>
          <a href="https://app.retaha.de/agb" target="_blank" rel="noopener">agb</a>
        </footer>
      </div>
    </section>

    <script>
      import Alpine from 'alpinejs';
      // @ts-expect-error - Alpine types
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
