        --color-anthrazit-soft: #2A2A2A;
        --color-anthrazit-card: #242424;
        --color-anthrazit-card-soft: #1E1E1E;
        --color-sage: #5C9070;
        --color-white: #FFFFFF;
        --radius: 3px;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-out-quint: cubic-bezier(0.22, 1, 0.36, 1);
        --ease-in-out-back: cubic-bezier(0.68, -0.55, 0.265, 1.55);
        --duration-fast: 250ms;
        --duration-base: 450ms;
        --duration-slow: 700ms;
        --duration-very-slow: 900ms;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { background-color: var(--color-anthrazit); }
      html, body { min-height: 100%; }
      /* Body-Default-Style mit erhoehter Specificity (0,1,2) via html[data-theme] body
         um packages/ui/src/styles/themes.css globalen body{background} Override
         (Specificity 0,0,1) deterministisch zu schlagen. themes.css wird im
         Astro-Build NACH login-CSS geladen, sonst gewinnt es per Cascade.
         Sprint-J-Folge: themes.css selbst auf [data-theme] body umstellen — dann
         koennte hier wieder einfaches body{} reichen. */
      html[data-theme="bauhaus_manufaktur"] body {
        font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 14px; line-height: 1.5;
        color: var(--color-anthrazit);
        background: var(--color-white);
        -webkit-font-smoothing: antialiased;
        -webkit-overflow-scrolling: touch;
      }
      /* Mobile/Tablet: body-bg anthrazit damit Safari 26 WebKit-Live-Observer
         body.background-color samplet -> Status-Bar wird anthrazit.
         Refs: https://github.com/andesco/safari-color-tinting */
      @media (max-width: 1023px) {
        html[data-theme="bauhaus_manufaktur"] body {
          background: var(--color-anthrazit);
        }
      }
      [x-cloak] { display: none !important; }

      .auth-layout {
        display: grid;
        grid-template-columns: 1fr;
        min-height: 100vh;
        /* dvh = dynamic viewport height (modern Safari/Chrome, iOS-fix fuer Address-Bar) */
        min-height: 100dvh;
      }
      /* Mobile/Tablet: auth-layout weiss-bg ueberdeckt Body unter dem Brand-Footer.
         Body-bg bleibt anthrazit (Status-Bar Sampling Source), aber User sieht
         in der Leer-Area zwischen letztem Content und Bottom des Grids
         WEISS — passt zu Form/Brand-Footer die ebenfalls weiss sind.
         Hero hat eigene anthrazit-bg, daher kein Konflikt am Top. */
      @media (max-width: 1023px) {
        .auth-layout { background-color: var(--color-white); }
      }
      /* Ab 1024px (echte Desktops) 45/55 split */
      @media (min-width: 1024px) { .auth-layout { grid-template-columns: 45% 55%; } }
      /* iPad-Tablet-Bereich (768-1023): Stack-Layout damit Inhalt scrollbar bleibt */

      /* HERO */
      .auth-hero {
        background: var(--color-anthrazit); color: var(--color-white);
        padding: 48px 32px; display: flex; flex-direction: column;
        min-height: 380px; position: relative;
        /* overflow: hidden entfernt — DashboardShowcase managed eigene Animation-Cards */
      }
      @media (min-width: 1024px) {
        .auth-hero {
          padding: 56px 64px;
          /* Auf echtem Desktop volle Viewport-Hoehe damit Logo+Headline+Hero-Bottom passen */
          min-height: 100vh;
          min-height: 100dvh;
        }
      }
      @media (max-width: 767px) { .auth-hero { padding: 32px 24px; min-height: auto; } }

      /* hero-top: Desktop "display: contents" -> wrapper unsichtbar im Layout.
         Tablet/Mobile -> flex row mit Logo links + Switcher rechts. */
      .hero-top { display: contents; }

      /* Logo Hover: leichte Transparenz wie auf retaha.de / hospitality.retaha.de */
      .auth-hero :global(.brand-logo) {
        margin-bottom: 48px;
