const url = new URL(Astro.request.url);
const rawReturnTo = url.searchParams.get('return_to');
const returnTo = sanitizeReturnTo(rawReturnTo);

/* 11 Sprachen (Sprint-I final). Middleware liefert initiale Sprache via
   Astro.locals.currentLang (URL > Cookie > Browser > 'de'). */
const ALLOWED_LANGS = ['de', 'en', 'tr', 'fr', 'es', 'it', 'pt', 'nl', 'ru', 'ar', 'zh'] as const;
const middlewareLang = Astro.locals.currentLang;
const initialLang: typeof ALLOWED_LANGS[number] =
  middlewareLang && (ALLOWED_LANGS as readonly string[]).includes(middlewareLang)
    ? (middlewareLang as typeof ALLOWED_LANGS[number])
    : 'de';
const isRTL = initialLang === 'ar';

