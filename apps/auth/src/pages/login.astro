        <nav class="brand-legal" aria-label="Rechtliches">
          <a href="https://app.retaha.de/impressum" target="_blank" rel="noopener" x-text="t('legal_impressum')"></a>
          <a href="https://app.retaha.de/datenschutz" target="_blank" rel="noopener" x-text="t('legal_datenschutz')"></a>
          <a href="https://app.retaha.de/agb" target="_blank" rel="noopener" x-text="t('legal_agb')"></a>
