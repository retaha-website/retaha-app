        display: inline-block;
        min-width: 160px;
        height: 20px;
        line-height: 20px;
      }
      .btn-text {
        position: absolute;
        top: 0; left: 0; right: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--duration-base) var(--ease-out-expo);
      }
      .btn-text.is-visible {
        opacity: 1;
        pointer-events: auto;
      }

      /* Pink-Dot INSIDE jeden btn-text — bleibt zentriert mit Text */
      .btn-dot {
        width: 5px; height: 5px;
        background: var(--color-pink-shock);
        border-radius: 50%;
        flex-shrink: 0;
      }

      .btn-spinner {
        display: inline-block;
        width: 12px; height: 12px;
        border: 2px solid rgba(255, 255, 255, 0.25);
        border-top-color: var(--color-pink-shock);
        border-radius: 50%;
        animation: spin 700ms linear infinite;
        flex-shrink: 0;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      .form-toggle {
        margin-top: 24px; text-align: center;
        transition:
          opacity var(--duration-base) var(--ease-out-expo),
          max-height var(--duration-slow) var(--ease-out-expo),
          margin-top var(--duration-slow) var(--ease-out-expo);
        overflow: hidden;
        max-height: 60px;
      }
      .form-toggle[data-hidden="true"] {
        opacity: 0; max-height: 0; margin-top: 0; pointer-events: none;
      }
      .toggle-link {
        background: transparent; border: none; font-family: inherit;
        font-size: 13px; color: var(--color-pink-shock); cursor: pointer;
        padding: 6px 12px; border-radius: var(--radius);
        transition: background 250ms ease;
      }
      .toggle-link:hover { background: var(--color-pink-soft); }

      .password-section {
        overflow: hidden;
        max-height: 0; opacity: 0;
        transition:
          max-height var(--duration-very-slow) var(--ease-out-expo),
          opacity var(--duration-slow) var(--ease-out-expo);
      }
      .password-section[data-visible="true"] { max-height: 240px; opacity: 1; }
      .password-section .field {
        transform: translateY(12px); opacity: 0;
        transition:
          transform var(--duration-slow) var(--ease-out-expo) 350ms,
          opacity var(--duration-slow) var(--ease-out-expo) 350ms;
      }
      .password-section[data-visible="true"] .field { transform: translateY(0); opacity: 1; }

      .form-footer { margin-top: 48px; padding-top: 24px; border-top: 1px solid rgba(26, 26, 26, 0.08); }
      .footer-support { font-size: 12px; color: rgba(26, 26, 26, 0.5); line-height: 1.6; }
      .footer-support a {
        color: var(--color-anthrazit);
        border-bottom: 1px solid rgba(26, 26, 26, 0.2);
        text-decoration: none;
        transition: all 200ms ease;
      }
      .footer-support a:hover {
        color: var(--color-pink-shock);
        border-bottom-color: var(--color-pink-shock);
      }

      /* SUCCESS-STATE */
      .success-wrap { text-align: center; animation: successEnter 800ms var(--ease-out-expo); }
      @keyframes successEnter {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .success-triangle {
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 32px; width: 72px; height: 72px;
        animation: triangleEntrance 1000ms var(--ease-in-out-back);
      }
      .success-triangle::before {
        content: "▲";
        font-family: 'JetBrains Mono', monospace;
        font-size: 64px; color: var(--color-pink-shock);
        line-height: 1; display: block;
        animation: trianglePulse 2400ms var(--ease-out-expo) 1000ms infinite;
      }
      @keyframes triangleEntrance {
        0% { opacity: 0; transform: scale(0.4) rotate(-15deg); }
        60% { opacity: 1; transform: scale(1.15) rotate(0deg); }
        100% { opacity: 1; transform: scale(1) rotate(0deg); }
      }
      @keyframes trianglePulse {
        0%, 100% { transform: scale(1); filter: drop-shadow(0 0 0 transparent); }
        50% { transform: scale(1.08); filter: drop-shadow(0 0 20px var(--color-pink-glow)); }
      }
      .success-eyebrow {
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--color-pink-shock); margin-bottom: 16px;
        animation: fadeUp 600ms var(--ease-out-expo) 300ms backwards;
      }
      /* h1 = Styleguide Sektion 2.2: 36/500/-0.02em/1.15 */
      .success-title {
        font-size: 36px; font-weight: 500;
        letter-spacing: -0.02em; line-height: 1.15;
        color: var(--color-anthrazit); margin-bottom: 16px;
        animation: fadeUp 700ms var(--ease-out-expo) 450ms backwards;
      }
      .success-title .h-dot { color: var(--color-pink-shock); }
      .success-message {
        font-size: 15px; color: rgba(26, 26, 26, 0.65); line-height: 1.6;
        margin-bottom: 8px;
        animation: fadeUp 700ms var(--ease-out-expo) 600ms backwards;
      }
      .success-email {
        font-family: 'JetBrains Mono', monospace; font-size: 13px;
        color: var(--color-anthrazit);
        padding: 8px 14px;
        background: rgba(26, 26, 26, 0.04);
        border-radius: var(--radius);
        display: inline-block;
        margin: 8px 0 24px;
        letter-spacing: 0.02em;
        animation: fadeUp 700ms var(--ease-out-expo) 750ms backwards;
      }
      .success-validity {
        font-size: 13px; color: rgba(26, 26, 26, 0.5); margin-bottom: 40px;
        animation: fadeUp 700ms var(--ease-out-expo) 900ms backwards;
      }
      .success-actions {
        display: flex; flex-direction: column; gap: 12px;
        animation: fadeUp 700ms var(--ease-out-expo) 1050ms backwards;
      }
      .btn-secondary {
        background: transparent;
        border: 1px solid rgba(26, 26, 26, 0.2);
        color: var(--color-anthrazit);
        padding: 12px 24px; border-radius: var(--radius);
        font-family: inherit; font-size: 13px; cursor: pointer;
        transition: all 250ms var(--ease-out-expo);
      }
      .btn-secondary:hover {
        border-color: var(--color-pink-shock);
        color: var(--color-pink-shock);
        background: var(--color-pink-soft);
      }
      .resend-link {
        font-size: 12px; color: rgba(26, 26, 26, 0.5); margin-top: 16px;
        animation: fadeUp 700ms var(--ease-out-expo) 1200ms backwards;
      }
      .resend-link button {
        background: transparent; border: none;
        color: var(--color-pink-shock); cursor: pointer;
        font-family: inherit; font-size: 12px;
        padding: 4px 8px; border-radius: var(--radius);
        transition: background 200ms ease;
      }
      .resend-link button:hover:not(:disabled) { background: var(--color-pink-soft); }
      .resend-link button:disabled {
        color: rgba(26, 26, 26, 0.3); cursor: not-allowed;
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* ═══════════════════════════════════════════════════════════════════
         BRAND-FOOTER (mobile-only)  —  Default hidden, mobile <768 visible
         Inhalte gespiegelt aus Hero-Bottom. Auf Mobile wird hero-bottom
         versteckt und stattdessen dieser Brand-Footer angezeigt.
         ═══════════════════════════════════════════════════════════════════ */
      .brand-footer { display: none; }
      .brand-bauhaus,
      .brand-meta,
      .brand-legal,
      .brand-trademark { margin: 0; }

      /* ═══════════════════════════════════════════════════════════════════
         TABLET + MOBILE (<1024px) — Switcher wandert von Form-Side in Hero-Top
         ═══════════════════════════════════════════════════════════════════ */
      @media (max-width: 1023px) {
        .hero-top {
          display: flex;
          align-items: center;
          justify-content: space-between;
          margin-bottom: 20px;
          gap: 16px;
        }
        .auth-hero :global(.brand-logo) { margin-bottom: 0; }

        /* Mobile-Select-Dropdown zeigen; Form-Side-Switcher ausblenden */
        .lang-switcher-mobile-wrap { display: inline-block; }
        .auth-form-side > .lang-switcher { display: none; }
      }

      /* ═══════════════════════════════════════════════════════════════════
         MOBILE (<768px)  —  v6a Layout (kompakt, Brand-Footer, iOS-Fixes)
         ═══════════════════════════════════════════════════════════════════ */
      @media (max-width: 767px) {
        /* HERO: kompakter */
        .auth-hero {
          padding: 20px 24px 28px;
          min-height: auto;
        }

        /* Hero-Bottom (Bauhaus + Meta + Legal + Trademark) auf Mobile ausblenden
           — wird im Brand-Footer dupliziert. */
        .hero-bottom { display: none; }

        /* Showcase kompakt: 160px (statt 240px) */
        :global(.dashboard-showcase) {
          min-height: 160px !important;
          margin: 0 0 20px;
        }
        :global(.showcase-card) { padding: 14px !important; }
        :global(.stat-cell) { padding: 8px !important; }
        :global(.stat-value) { font-size: 18px !important; }

        /* Headline + Tagline mobile-kompakt — h1 bleibt semantisch,
           Size reduziert auf 28px (= Styleguide-h2-Skala) damit Hero auf
           375px-iPhones nicht doppelt umbricht. line-height/letter-spacing
           bleiben Styleguide-h1. */
        .hero-center { margin-top: 0; margin-bottom: 0; }
        .hero-headline {
          font-size: 28px;
          line-height: 1.15;
          letter-spacing: -0.02em;
          margin-top: 16px;
          margin-bottom: 10px;
        }
        .hero-tagline { font-size: 14px; line-height: 1.55; }

        /* FORM-SIDE: kompakter padding, iOS-fixes */
        .auth-form-side {
          min-height: auto;
          padding: 32px 24px 24px;
        }
        /* form-state-title = Styleguide-h2 28px — kein Mobile-Override mehr */

        /* iOS-Auto-Zoom verhindern: Input mind. 16px Font */
        .field-input {
          font-size: 16px;
          padding: 14px 16px;
          min-height: 48px;
        }

        /* Touch-Targets ≥ 44px (Apple HIG) */
        .btn-primary {
          min-height: 52px;
          padding: 16px 24px;
          font-size: 15px;
        }
        .toggle-link { padding: 12px 16px; }
        .field-close { width: 36px; height: 36px; }

        /* BRAND-FOOTER zeigen — alle Marken-Infos in weiß-Sektion unten */
        .brand-footer {
          display: block;
          background: var(--color-white);
          padding: 36px 24px 32px;
          border-top: 1px solid rgba(26, 26, 26, 0.08);
        }
        .brand-bauhaus {
          font-family: 'JetBrains Mono', monospace;
          letter-spacing: 0.5em;
          font-size: 14px;
          color: rgba(26, 26, 26, 0.35);
          margin-bottom: 16px;
        }
        .brand-meta {
          font-family: 'JetBrains Mono', monospace;
          font-size: 10px;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: rgba(26, 26, 26, 0.55);
          margin-bottom: 16px;
        }
        .brand-legal {
          display: flex;
          gap: 16px;
          flex-wrap: wrap;
          margin-bottom: 20px;
          font-family: 'JetBrains Mono', monospace;
          font-size: 10px;
          letter-spacing: 0.12em;
          text-transform: uppercase;
        }
        .brand-legal a {
          color: rgba(26, 26, 26, 0.5);
          text-decoration: none;
          transition: color 200ms ease;
          padding: 6px 0;  /* groessere Touch-Targets */
        }
        .brand-legal a:hover,
        .brand-legal a:focus-visible {
          color: var(--color-pink-shock);
        }
        .brand-trademark {
          font-family: 'Space Grotesk', sans-serif;
          font-size: 10px;
          line-height: 1.5;
          color: rgba(26, 26, 26, 0.4);
        }

        /* iOS Safe-Area respektieren (Notch + Home-Indicator) */
        @supports (padding: max(0px)) {
          .auth-hero { padding-top: max(20px, env(safe-area-inset-top)); }
          .brand-footer { padding-bottom: max(32px, env(safe-area-inset-bottom)); }
        }
      }
    </style>
  </body>
</html>
