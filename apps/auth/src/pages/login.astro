                    <span class="btn-spinner" aria-hidden="true"></span>
                    <span x-text="passwordExpanded ? t('btn_loading_password') : t('btn_loading_magic')"></span>
                  </span>
                </span>
              </button>

              <div class="form-toggle">
                <button type="button" class="toggle-link" @click="togglePassword()" x-text="passwordExpanded ? t('toggle_to_magic') : t('toggle_to_password')"></button>
