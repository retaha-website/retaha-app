/**
 * apps/auth/src/pages/login.astro — v4g Round 5
 *
 * Aenderungen ggue. Round 4:
 *   - "Anmeldung" -> "Anmelden" (Verb-Form, matched Button-Lowercase)
 *   - Sprachwechsler (4 Sprachen: de/en/fr/es) mit localStorage
 *   - Alle UI-Texte i18n via t(key) Funktion
 *   - Pink-Dot Button-Fix: Dot wandert INNERHALB jeden btn-text-Span
 *     statt globalen ::before (so bleibt Dot+Text immer mittig zusammen)
 */

import { sanitizeReturnTo } from '../lib/redirect-whitelist';
import Logo from '@retaha/ui/components/brand/Logo.astro';
