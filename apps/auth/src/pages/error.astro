---
import AuthLayout from '../layouts/AuthLayout.astro';

const url = new URL(Astro.request.url);
const reason = url.searchParams.get('reason') ?? 'Unbekannter Fehler';
---

<AuthLayout title="fehler" eyebrow="da haben wir uns wohl vertan">
  <h1 class="err-headline">
    Da lief was schief<span class="h-dot">.</span>
  </h1>
  <p class="err-sub">{reason}</p>
  <a href="/login" class="err-link">→ Zurück zur Anmeldung</a>

  <style>
    .err-headline {
      font-family: var(--theme-font-headline);
      font-size: 32px;
      font-weight: 300;
      letter-spacing: -0.02em;
      margin: 0 0 12px;
      text-align: center;
    }
    .err-sub {
      text-align: center;
      color: var(--theme-text-secondary);
      margin: 0 0 24px;
      padding: 12px 14px;
      background: rgba(var(--theme-accent-rgb), 0.06);
      border-left: 3px solid var(--theme-accent);
      border-radius: var(--theme-radius);
      font-size: 14px;
    }
    .err-link {
      display: block;
      text-align: center;
      color: var(--theme-accent);
      text-decoration: none;
      padding: 12px;
      border: 1px solid var(--theme-border);
      border-radius: var(--theme-radius-button);
    }
    .err-link:hover {
      background: var(--theme-accent);
      color: var(--theme-text-on-accent);
    }
  </style>
</AuthLayout>
