# @retaha/guest-app — app.retaha.de
#
# Gast-Frontend: Hub + 8 Sheets + Eve-Chat + NFC-Routes + Wallet.
#
# Setup: cp .env.example .env  →  Werte fuellen.

# ─── Supabase ────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stay-Session JWT (HS256) ────────────────────────────────
# Cookie retaha_stay fuer Gast-Auth via /g/[token].
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Min 32 Zeichen — sonst signing failed.
STAY_SESSION_SECRET=

# ─── Mews-Token-Encryption (AES-256-GCM) ─────────────────────
# Fuer Mews-Token-Storage (encrypted in mews_integrations-Tabelle).
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ─── Anthropic (Eve-Chat) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google Places API (Empfehlungen) ────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Google Wallet (Pass-Creation) ───────────────────────────
# Issuer ID aus Google Pay Console (Hotelier-Account)
WALLET_GOOGLE_ISSUER_ID=
# Service-Account-JSON (base64-encoded oder als Pfad — siehe wallet/config.ts)
WALLET_GOOGLE_SERVICE_ACCOUNT_JSON=
# JWT-Secret fuer Deep-Link-Tokens (pass-open-tracking)
WALLET_DEEP_LINK_SECRET=
# JWT-Secret fuer Opt-Out-Links in Marketing-Emails
WALLET_OPT_OUT_SECRET=

# ─── Web-Push (Browser-Notifications) ────────────────────────
# VAPID-Keys generieren: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@retaha.de

# ─── Mews Connector API ──────────────────────────────────────
MEWS_API_BASE_URL=https://api.mews-demo.com
MEWS_CLIENT_NAME=retaha 1.0.0
