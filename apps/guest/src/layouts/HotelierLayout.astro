---
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/v9-colors.css';
import '@retaha/ui/styles/tokens.css';
import '@retaha/ui/styles/global.css';
import '@retaha/ui/styles/retaha.css';
import '@retaha/ui/styles/icons.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/pills.css';
import '@retaha/ui/styles/components/menu.css';
import '@retaha/ui/styles/components/settings.css';
import '@retaha/ui/styles/components/status-markers.css';

import Header from '@retaha/ui/components/header/Header.astro';
import Footer from '@retaha/ui/components/shared/Footer.astro';
import Toast from '@retaha/ui/components/shared/Toast.astro';
import { getHeaderUser } from '@retaha/auth';
import { normalizeLanguage } from '@retaha/i18n';

interface Props {
  title: string;
  activeTab: 'gast' | 'backoffice' | 'admin';
  hotelName?: string;
  hotelLogoUrl?: string | null;
}

const { title, activeTab, hotelName, hotelLogoUrl } = Astro.props;

const BACKOFFICE = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
const DASHBOARD  = import.meta.env.DASHBOARD_URL  ?? 'https://dashboard.retaha.de';

// Sprach-Auflösung — identische Kette wie das Backoffice (getLang): ?lang → Cookie
// `retaha_lang` → Accept-Language → 'de'. Cookie ist auf .retaha.de domainweit gesetzt.
function resolveLang(): string {
  try {
    const urlLang = new URL(Astro.request.url).searchParams.get('lang');
    if (urlLang) return normalizeLanguage(urlLang);
  } catch { /* relative URL — ignorieren */ }
  const cookieLang = Astro.cookies.get('retaha_lang')?.value;
  if (cookieLang) return normalizeLanguage(cookieLang);
  const accept = Astro.request.headers.get('accept-language') ?? '';
  return normalizeLanguage(accept.split(',')[0]?.trim());
}

// Volles Header-Profil laden — dieselben Hotel-/User-Daten wie im Backoffice.
const headerUser = await getHeaderUser(Astro.cookies, Astro.request, resolveLang());
if (!headerUser) return Astro.redirect(`${BACKOFFICE}/admin/login`);
if (!headerUser.hotel_id) return Astro.redirect(`${BACKOFFICE}/admin/login?error=no_hotel`);

// Optionale Overrides aus den Layout-Props (sonst aus dem geladenen Profil).
const displayName    = hotelName    ?? headerUser.hotel_name;
const displayLogoUrl = hotelLogoUrl !== undefined ? hotelLogoUrl : headerUser.hotel_logo_url;
---

<!DOCTYPE html>
<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FAFAF8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/apple-touch-icon-167x167.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon-precomposed.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title} · retaha</title>
  </head>
  <body>
    <Header
      activeTab={activeTab}
      user={headerUser}
      hotelName={displayName}
      hotelLogoUrl={displayLogoUrl}
      bo={BACKOFFICE}
      guestBase=""
      dashboardBase={DASHBOARD}
    />
    <main>
      <slot />
    </main>

    <Footer />

    <Toast />

    <script>
      import Alpine from 'alpinejs';
      import collapse from '@alpinejs/collapse';
      Alpine.plugin(collapse);
      // @ts-expect-error
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
