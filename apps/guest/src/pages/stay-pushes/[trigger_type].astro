---
import HotelierLayout from '../../layouts/HotelierLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';
import {
  STAY_PUSH_TRIGGER_LABELS, STAY_PUSH_TRIGGER_DESCRIPTIONS, STAY_PUSH_TRIGGER_VARIABLES,
} from '@retaha/marketing';
import { VARIABLE_UI_DEFS } from '@retaha/marketing';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) {
  const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
  return Astro.redirect(`${b}/admin/login`);
}
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) {
  const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
  return Astro.redirect(`${b}/admin/login?error=no_hotel`);
}
const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'content.write')) return new Response('Forbidden', { status: 403 });

const triggerType = Astro.params.trigger_type;
if (!triggerType || !(triggerType in STAY_PUSH_TRIGGER_LABELS)) {
  return Astro.redirect('/stay-pushes');
}

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: existing } = await client
  .from('stay_push_templates')
  .select('id, title_i18n, body_i18n, is_active')
  .eq('hotel_id', hotel.id)
  .eq('trigger_type', triggerType)
  .maybeSingle();

const hotelDefaultLang = (hotel as any).default_language || 'de';
function pickI18n(jsonb: any): string {
  if (!jsonb) return '';
  return jsonb[hotelDefaultLang]?.value ?? '';
}
const initialTitle = pickI18n(existing?.title_i18n);
const initialBody  = pickI18n(existing?.body_i18n);
const initialActive = existing?.is_active !== false;

const allowedVars = STAY_PUSH_TRIGGER_VARIABLES[triggerType] ?? [];
const STAY_VAR_LABELS: Record<string, string> = {
  ...Object.fromEntries(VARIABLE_UI_DEFS.map(v => [v.key, v.label])),
  checkout_time: 'Check-out-Zeit',
  room_number:   'Zimmer-Nummer',
  guest_count:   'Gäste-Anzahl',
  date:          'Datum',
  time:          'Uhrzeit',
};
const STAY_VAR_EXAMPLES: Record<string, string> = {
  ...Object.fromEntries(VARIABLE_UI_DEFS.map(v => [v.key, v.example])),
  checkout_time: '11:00',
  room_number:   '204',
  guest_count:   '4',
  date:          '14. Juli 2026',
  time:          '19:30',
};

const DEMO_VARS = {
  first_name: 'Anna',
  last_name: 'Schmidt',
  hotel_name: hotel.name,
  visit_count: 3,
  last_visit_date: '24.12.2025',
  first_visit_date: '15.07.2024',
  checkout_time: '11:00',
  room_number: '204',
  guest_count: '4',
  date: '14. Juli 2026',
  time: '19:30',
};
---

<HotelierLayout title={`Stay-Push · ${STAY_PUSH_TRIGGER_LABELS[triggerType]}`} activeTab="gast" hotelName={hotel.name}>
  <div class="se-page">
    <div class="se-breadcrumb"><a href="/stay-pushes">← Alle Stay-Pushes</a></div>

    <header class="se-header">
      <p class="se-eyebrow">Stay-Push · {STAY_PUSH_TRIGGER_LABELS[triggerType]}</p>
      <h1 class="se-title">{STAY_PUSH_TRIGGER_LABELS[triggerType]}<span class="h-dot">.</span></h1>
      <p class="se-sub">{STAY_PUSH_TRIGGER_DESCRIPTIONS[triggerType]}</p>
    </header>

    <div class="se-grid" x-data="stayPushEditor()" x-init="init()">

      <div class="se-col se-col-form">
        <h3 class="se-section-title">Text ({hotelDefaultLang.toUpperCase()})</h3>
        <p class="se-hint">Beim Speichern wird in alle aktivierten Sprachen automatisch übersetzt. Variablen wie <code>{`{{first_name}}`}</code> werden beim Versand mit echten Werten ersetzt.</p>

        <label class="se-field">
          <span class="se-label">Aktiv</span>
          <div class="se-toggle">
            <input type="checkbox" x-model="form.is_active" id="se-active-toggle" />
            <label for="se-active-toggle"></label>
          </div>
          <span class="se-toggle-text" x-text="form.is_active ? 'Push wird bei Trigger versandt' : 'Push deaktiviert — Trigger feuert ins Leere'"></span>
        </label>

        <label class="se-field">
          <span class="se-label">Titel</span>
          <input type="text" x-model="form.title" placeholder="z.B. Willkommen im {{hotel_name}}!" class="se-input" maxlength="60" />
          <span class="se-hint">Max 60 Zeichen (Google-Wallet-Limit)</span>
        </label>

        <label class="se-field">
          <span class="se-label">Body</span>
          <textarea x-model="form.body" rows="4" placeholder="z.B. Schön dass du da bist, {{first_name}}." class="se-input se-textarea" maxlength="1024"></textarea>
        </label>

        <div class="se-field">
          <span class="se-label">Verfügbare Variablen</span>
          <div class="se-var-chips">
            {allowedVars.map(v => (
              <button type="button" class="se-var-chip" @click={`insertVar('${v}')`}>
                <strong>{STAY_VAR_LABELS[v]}</strong>
                <code>{`{{${v}}}`}</code>
              </button>
            ))}
          </div>
        </div>

        <template x-if="errorMsg">
          <div class="se-error" x-text="errorMsg"></div>
        </template>

        <div class="se-actions">
          <a href="/stay-pushes" class="se-btn-ghost">Abbrechen</a>
          <button type="button" class="se-btn-primary" :disabled="submitting" @click="save()" x-text="submitting ? 'Wird gespeichert (übersetzt …)' : 'Speichern'"></button>
        </div>
      </div>

      <div class="se-col se-col-preview">
        <h3 class="se-section-title">Vorschau</h3>
        <p class="se-hint">So sieht der Push aus. Demo-Daten ersetzen die Variablen.</p>
        <div class="se-mockup">
          <div class="se-mockup-frame">
            <div class="se-mockup-status">retaha · Wallet-Push</div>
            <div class="se-mockup-card">
              <div class="se-mockup-brand">
                <span class="se-mockup-logo">{hotel.name.slice(0, 1).toUpperCase()}</span>
                <div>
                  <div class="se-mockup-hotel">{hotel.name}</div>
                  <div class="se-mockup-now">jetzt</div>
                </div>
              </div>
              <div class="se-mockup-title" x-text="previewTitle"></div>
              <div class="se-mockup-body" x-text="previewBody"></div>
            </div>
            <div class="se-mockup-note">Service-Push · Vertragserfüllung</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{
    INITIAL: { title: initialTitle, body: initialBody, is_active: initialActive },
    TRIGGER: triggerType,
    DEMO: DEMO_VARS,
  }}>
    window.__RETAHA_SE__ = { INITIAL, TRIGGER, DEMO };
  </script>

  <script>
    function renderVars(text, ctx) {
      const re = /\{\{\s*([a-z_][a-z0-9_]*)\s*\}\}/gi;
      return text.replace(re, (full, name) => {
        const key = String(name).toLowerCase();
        if (key in ctx) {
          const v = ctx[key];
          return v == null ? '' : String(v);
        }
        return full;
      });
    }

    document.addEventListener('alpine:init', () => {
      // @ts-expect-error - Alpine global
      window.Alpine.data('stayPushEditor', () => ({
        cfg: (window as any).__RETAHA_SE__,
        submitting: false,
        errorMsg: '' as string,
        form: { title: '', body: '', is_active: true },

        init() {
          this.form.title = this.cfg.INITIAL.title;
          this.form.body  = this.cfg.INITIAL.body;
          this.form.is_active = this.cfg.INITIAL.is_active;
        },

        insertVar(key: string) {
          this.form.body += this.form.body && !this.form.body.endsWith(' ') ? ` {{${key}}}` : `{{${key}}}`;
        },

        get previewTitle() {
          return renderVars(this.form.title || '(kein Titel)', this.cfg.DEMO);
        },
        get previewBody() {
          return renderVars(this.form.body || '(kein Text)', this.cfg.DEMO);
        },

        async save() {
          if (this.submitting) return;
          this.errorMsg = '';
          if (!this.form.title?.trim()) { this.errorMsg = 'Bitte gib einen Titel an.'; return; }
          if (!this.form.body?.trim())  { this.errorMsg = 'Bitte gib einen Text an.'; return; }

          this.submitting = true;
          try {
            const res = await fetch(`/api/stay-push/${this.cfg.TRIGGER}`, {
              method: 'PUT', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                title_default: this.form.title.trim(),
                body_default:  this.form.body.trim(),
                is_active: this.form.is_active,
              }),
            });
            const data = await res.json();
            if (!data.ok) {
              if (data.error === 'invalid_variables') {
                const parts: string[] = [];
                if (data.unknown?.length)   parts.push('Unbekannte Variablen: ' + data.unknown.map((v: string) => `{{${v}}}`).join(', '));
                if (data.forbidden?.length) parts.push('Verbotene Variablen: ' + data.forbidden.map((v: string) => `{{${v}}}`).join(', '));
                this.errorMsg = parts.join(' · ');
              } else {
                this.errorMsg = data.error || 'Speichern fehlgeschlagen.';
              }
              return;
            }
            window.location.href = '/stay-pushes';
          } catch (err: any) {
            this.errorMsg = 'Netzwerk-Fehler: ' + (err.message || 'unbekannt');
          } finally {
            this.submitting = false;
          }
        },
      }));
    });
  </script>

  <style>
    .se-page { max-width: 1100px; margin: 0 auto; padding: 0 24px 60px; }
    .se-breadcrumb { margin: 16px 0 8px; }
    .se-breadcrumb a { font-size: 13px; color: var(--ink-muted); text-decoration: none; }
    .se-breadcrumb a:hover { color: var(--te-pink, #FF4A82); }

    .se-header { margin: 20px 0 28px; }
    .se-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--te-pink, #FF4A82); margin: 0 0 6px; }
    .se-title { margin: 0 0 8px; font-size: 26px; font-weight: 300; }
    .se-sub { margin: 0; font-size: 14px; color: var(--ink-soft); max-width: 720px; line-height: 1.5; }

    .se-grid { display: grid; grid-template-columns: 1fr 360px; gap: 16px; align-items: flex-start; }
    @media (max-width: 1000px) { .se-grid { grid-template-columns: 1fr; } }
    .se-col { background: var(--surface); border: 1px solid var(--border); padding: 20px; }
    .se-col-preview { background: var(--surface-raised); }

    .se-section-title { font-size: 13px; font-weight: 500; margin: 0 0 8px; color: var(--ink); letter-spacing: 0.02em; }
    .se-label { display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 6px; }
    .se-hint { font-size: 12px; color: var(--ink-muted); font-style: italic; margin: 4px 0 12px; }
    .se-hint code { background: var(--surface-raised); padding: 1px 5px; font-family: 'JetBrains Mono', monospace; color: var(--te-pink, #FF4A82); font-style: normal; }
    .se-field { display: block; margin-bottom: 16px; }
    .se-input { width: 100%; box-sizing: border-box; padding: 10px 12px; font-family: inherit; font-size: 14px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); }
    .se-input:focus { outline: none; border-color: var(--ink); }
    .se-textarea { resize: vertical; min-height: 90px; line-height: 1.5; }

    .se-toggle { display: inline-block; vertical-align: middle; position: relative; width: 44px; height: 24px; margin-right: 12px; }
    .se-toggle input { opacity: 0; width: 0; height: 0; }
    .se-toggle label { position: absolute; cursor: pointer; inset: 0; background: var(--border); transition: background .15s; }
    .se-toggle label::before { content: ''; position: absolute; left: 2px; top: 2px; width: 20px; height: 20px; background: var(--surface); transition: transform .15s; }
    .se-toggle input:checked + label { background: var(--te-pink, #FF4A82); }
    .se-toggle input:checked + label::before { transform: translateX(20px); }
    .se-toggle-text { font-size: 12px; color: var(--ink-muted); }

    .se-var-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
    .se-var-chip { display: inline-flex; gap: 8px; align-items: center; padding: 6px 10px; background: transparent; border: 1px dashed var(--ink); color: var(--ink); cursor: pointer; font-family: inherit; font-size: 12px; }
    .se-var-chip:hover { background: var(--te-pink, #FF4A82); color: var(--surface); border-color: var(--te-pink, #FF4A82); }
    .se-var-chip code { color: inherit; font-family: 'JetBrains Mono', monospace; opacity: .85; }
    .se-var-chip:hover code { opacity: 1; }

    .se-error { padding: 12px; background: rgba(255,74,130, 0.08); color: var(--te-pink, #FF4A82); font-size: 13px; border-left: 3px solid var(--te-pink, #FF4A82); margin: 12px 0; }
    .se-actions { display: flex; gap: 12px; justify-content: flex-end; padding-top: 12px; border-top: 1px solid var(--border); }
    .se-btn-ghost { padding: 10px 18px; background: transparent; color: var(--ink-soft); border: 1px solid var(--border); text-decoration: none; font-size: 13px; }
    .se-btn-ghost:hover { color: var(--ink); border-color: var(--ink); }
    .se-btn-primary { padding: 10px 22px; background: var(--ink); color: var(--surface); border: none; cursor: pointer; font-size: 13px; font-weight: 500; }
    .se-btn-primary:hover:not(:disabled) { background: var(--te-pink, #FF4A82); }
    .se-btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    .se-mockup { padding: 16px 0; display: flex; justify-content: center; }
    .se-mockup-frame { width: 100%; max-width: 300px; background: var(--ink); padding: 12px 8px 20px; border-radius: 24px; box-shadow: 0 20px 40px -16px rgba(0,0,0,.25); }
    .se-mockup-status { color: rgba(255,255,255,.6); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; text-align: center; padding: 4px 0 10px; }
    .se-mockup-card { background: var(--surface); padding: 12px; border-radius: 10px; margin: 0 8px; }
    .se-mockup-brand { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .se-mockup-logo { width: 26px; height: 26px; background: var(--te-pink, #FF4A82); color: white; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; border-radius: 4px; }
    .se-mockup-hotel { font-size: 12px; font-weight: 500; }
    .se-mockup-now { font-size: 10px; color: var(--ink-muted); }
    .se-mockup-title { font-size: 14px; font-weight: 500; color: var(--ink); margin: 6px 0 4px; line-height: 1.3; }
    .se-mockup-body { font-size: 12px; line-height: 1.5; color: var(--ink-soft); white-space: pre-wrap; }
    .se-mockup-note { color: rgba(255,255,255,.4); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; text-align: center; padding-top: 10px; }
  </style>
</HotelierLayout>
