---
// Pre-Checkin Wizard — Eingangs-Router
// Liest stay_pre_checkin und leitet zum richtigen Schritt weiter.

import { loadStayByToken } from '@retaha/db';
import { setStaySessionCookie, getStaySession, createSupabaseServiceRoleInstance } from '@retaha/auth';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return Astro.redirect(`/g/${token ?? ''}`);

const { stay, guest, hotel, settings } = ctx;
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_checkin === false) return Astro.redirect(`/g/${token}`);

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id,
    hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out,
    is_showcase: false,
  });
}

const sbSr = createSupabaseServiceRoleInstance();
const { data: rec } = await sbSr
  .from('stay_pre_checkin')
  .select('path, status, arrival_eta, address_city, doc_number, signed_at')
  .eq('stay_id', stay.id)
  .maybeSingle();

if (rec?.status === 'completed') {
  return Astro.redirect(`/g/${token}/pre-checkin/done`);
}

const path = rec?.path ?? 'pending';

if (path === 'pending' || !rec) {
  return Astro.redirect(`/g/${token}/pre-checkin/path`);
}

if (path === 'domestic') {
  return rec.arrival_eta
    ? Astro.redirect(`/g/${token}/pre-checkin/done`)
    : Astro.redirect(`/g/${token}/pre-checkin/arrival`);
}

// foreign path
if (!rec.address_city) return Astro.redirect(`/g/${token}/pre-checkin/address`);
if (!rec.doc_number)   return Astro.redirect(`/g/${token}/pre-checkin/document`);
if (!rec.signed_at)    return Astro.redirect(`/g/${token}/pre-checkin/signature`);
return Astro.redirect(`/g/${token}/pre-checkin/done`);
---
