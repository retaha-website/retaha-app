---
// Pre-Checkin — Schritt 1: Pfad-Auswahl (Glas-UI auf Foto-Hintergrund)

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@retaha/ui-guest/base';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return Astro.redirect(`/g/${token ?? ''}`);

const { stay, guest, hotel, settings } = ctx;
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_checkin === false) return Astro.redirect(`/g/${token}`);

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id, hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out, is_showcase: false,
  });
}

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary = (hotel as any).brand_primary ?? '#0A0A0A';
const brandPalette = computeBrandPalette(brandPrimary);

const sbSr = createSupabaseServiceRoleInstance();
const { data: splashRow } = await sbSr
  .from('hotels').select('splash_background').eq('id', (hotel as any).id).maybeSingle();
const splashBg = (splashRow?.splash_background as string | null) ?? null;

const guestName = guest?.first_name ?? null;

type Labels = { title: string; sub: string; card1: string; card1sub: string; card2: string; card2sub: string; next: string };
const labels: Record<Lang, Labels> = {
  de: {
    title: guestName ? `Kurz vorab, ${guestName}.` : 'Kurz vorab.',
    sub: 'Damit dein Check-in schneller geht. Dauert 2 Minuten.',
    card1: 'Deutscher Ausweis', card1sub: 'Schnelle Anmeldung, ohne Unterschrift',
    card2: 'Anderer Pass · international', card2sub: 'Kurzer Meldeschein nach §30 BMG',
    next: 'Weiter',
  },
  en: {
    title: guestName ? `Quick heads-up, ${guestName}.` : 'Quick heads-up.',
    sub: 'Helps us check you in faster. Takes 2 minutes.',
    card1: 'German ID card', card1sub: 'Fast registration, no signature needed',
    card2: 'Other passport · international', card2sub: 'Short registration form',
    next: 'Continue',
  },
  fr: {
    title: guestName ? `Un instant, ${guestName}.` : 'Un instant.',
    sub: 'Pour accélérer votre enregistrement. 2 minutes.',
    card1: 'Carte d\'identité allemande', card1sub: 'Enregistrement rapide, sans signature',
    card2: 'Autre passeport · international', card2sub: 'Formulaire d\'inscription §30 BMG',
    next: 'Continuer',
  },
  es: {
    title: guestName ? `Un momento, ${guestName}.` : 'Un momento.',
    sub: 'Para agilizar tu check-in. 2 minutos.',
    card1: 'DNI alemán', card1sub: 'Registro rápido, sin firma',
    card2: 'Otro pasaporte · internacional', card2sub: 'Formulario de registro §30 BMG',
    next: 'Continuar',
  },
};
const L = labels[lang];
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPalette.accent};--accent-soft:${brandPalette.soft};--accent-on:${brandPalette.on};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Voranmeldung</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #0a0a0a; min-height: 100dvh; overflow-x: hidden; }

    .wiz-bg {
      position: fixed; inset: 0;
      background-image: var(--splash-url, none);
      background-size: cover; background-position: center;
    }
    .wiz-bg-overlay {
      position: fixed; inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.65) 60%, rgba(0,0,0,0.8) 100%);
    }

    .wiz-layout {
      position: relative; z-index: 10;
      min-height: 100dvh;
      display: flex; flex-direction: column;
      padding: env(safe-area-inset-top, 0) 0 calc(env(safe-area-inset-bottom, 0) + 24px);
    }

    .wiz-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px;
    }
    .wiz-back {
      width: 38px; height: 38px; border-radius: 50%;
      background: rgba(255,255,255,0.12); border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #fff; cursor: pointer; text-decoration: none;
      flex-shrink: 0;
    }
    .wiz-dots { display: flex; gap: 6px; align-items: center; }
    .wiz-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.28); }
    .wiz-dot.active { width: 18px; border-radius: 3px; background: #fff; }

    .wiz-content {
      flex: 1; display: flex; flex-direction: column;
      justify-content: flex-end; padding: 0 20px 8px;
    }
    .wiz-title {
      font-size: 30px; font-weight: 700; color: #fff;
      line-height: 1.2; margin-bottom: 10px;
    }
    .wiz-sub {
      font-size: 15px; color: rgba(255,255,255,0.65);
      line-height: 1.5; margin-bottom: 28px;
    }

    .path-cards { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
    .path-card {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(24px) saturate(160%);
      -webkit-backdrop-filter: blur(24px) saturate(160%);
      border: 1.5px solid rgba(255,255,255,0.14);
      border-radius: 18px; padding: 18px 18px;
      cursor: pointer; display: flex; align-items: center; gap: 14px;
      transition: border-color 0.15s, background 0.15s;
      user-select: none;
    }
    .path-card.selected {
      border-color: rgba(255,255,255,0.55);
      background: rgba(255,255,255,0.13);
    }
    .path-card-icon {
      width: 46px; height: 46px; border-radius: 12px;
      background: rgba(255,255,255,0.1);
      display: flex; align-items: center; justify-content: center;
      color: #fff; flex-shrink: 0;
    }
    .path-card-body { flex: 1; min-width: 0; }
    .path-card-title { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 3px; }
    .path-card-sub { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.4; }
    .path-check {
      width: 22px; height: 22px; border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,0.28);
      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
      transition: all 0.15s;
    }
    .path-card.selected .path-check {
      background: #fff; border-color: #fff;
    }

    .btn-wiz {
      width: 100%; border: 0; padding: 16px;
      border-radius: 16px; font-size: 16px; font-weight: 600;
      cursor: pointer; transition: opacity 0.15s;
      font-family: inherit;
    }
    .btn-wiz-primary { background: #fff; color: #0a0a0a; }
    .btn-wiz-primary:disabled { opacity: 0.35; cursor: default; }
  </style>
</head>
<body>
  {splashBg && (
    <div class="wiz-bg" style={`background-image: url('${splashBg}')`}></div>
  )}
  {!splashBg && <div class="wiz-bg" style="background: linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)"></div>}
  <div class="wiz-bg-overlay"></div>

  <div class="wiz-layout" x-data="wizPath()" x-init="init()">
    <header class="wiz-header">
      <a class="wiz-back" href={`/g/${token}`} data-astro-reload aria-label="Zurück">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </a>
      <div class="wiz-dots">
        <div class="wiz-dot active"></div>
        <div class="wiz-dot"></div>
        <div class="wiz-dot"></div>
        <div class="wiz-dot"></div>
      </div>
    </header>

    <main class="wiz-content">
      <h1 class="wiz-title">{L.title}</h1>
      <p class="wiz-sub">{L.sub}</p>

      <div class="path-cards">
        <div class="path-card" :class="{ selected: chosen === 'domestic' }" @click="chosen = 'domestic'">
          <div class="path-card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <circle cx="9" cy="11" r="2"/>
              <path d="M7 15c0-1.1.9-2 2-2h4a2 2 0 0 1 2 2"/>
              <path d="M14 9h3M14 12h3"/>
            </svg>
          </div>
          <div class="path-card-body">
            <div class="path-card-title">{L.card1}</div>
            <div class="path-card-sub">{L.card1sub}</div>
          </div>
          <div class="path-check">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="2 7 6 11 12 3"/>
            </svg>
          </div>
        </div>

        <div class="path-card" :class="{ selected: chosen === 'foreign' }" @click="chosen = 'foreign'">
          <div class="path-card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <rect x="3" y="4" width="18" height="16" rx="2"/>
              <path d="M3 9h18M7 4v5"/>
              <circle cx="14" cy="15" r="2"/>
              <path d="M12 19h4"/>
            </svg>
          </div>
          <div class="path-card-body">
            <div class="path-card-title">{L.card2}</div>
            <div class="path-card-sub">{L.card2sub}</div>
          </div>
          <div class="path-check">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="2 7 6 11 12 3"/>
            </svg>
          </div>
        </div>
      </div>

      <button class="btn-wiz btn-wiz-primary" :disabled="!chosen || submitting" @click="submit()" x-text="submitting ? '…' : '{L.next}'">{L.next}</button>
    </main>
  </div>

  <script is:inline define:vars={{ token }}>
    document.addEventListener('alpine:init', () => {
      const Alpine = window['Alpine'];
      Alpine.data('wizPath', () => ({
        chosen: null,
        submitting: false,
        init() {},
        async submit() {
          if (!this.chosen || this.submitting) return;
          this.submitting = true;
          try {
            const res = await fetch('/api/g/pre-checkin/save-path', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ path: this.chosen }),
            });
            const data = await res.json().catch(() => ({}));
            if (!data.ok) { this.submitting = false; return; }
            const next = this.chosen === 'domestic'
              ? `/g/${token}/pre-checkin/arrival`
              : `/g/${token}/pre-checkin/address`;
            window.location.href = next;
          } catch { this.submitting = false; }
        },
      }));
    });
  </script>
</body>
</html>
