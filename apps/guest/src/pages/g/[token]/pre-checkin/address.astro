---
// Pre-Checkin — Schritt 2 (Foreign): Adresse

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@retaha/ui-guest/base';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return Astro.redirect(`/g/${token ?? ''}`);

const { stay, guest, hotel, settings } = ctx;
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_checkin === false) return Astro.redirect(`/g/${token}`);

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id, hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out, is_showcase: false,
  });
}

const sbSr = createSupabaseServiceRoleInstance();
const { data: rec } = await sbSr
  .from('stay_pre_checkin')
  .select('path, status, address_street, address_zip, address_city, address_country')
  .eq('stay_id', stay.id)
  .maybeSingle();

if (rec?.path !== 'foreign') return Astro.redirect(`/g/${token}/pre-checkin`);
if (rec?.status === 'completed') return Astro.redirect(`/g/${token}/pre-checkin/done`);

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary = (hotel as any).brand_primary ?? '#0A0A0A';
const brandPalette = computeBrandPalette(brandPrimary);

type Labels = { title: string; sub: string; street: string; zip: string; city: string; country: string; next: string };
const labels: Record<Lang, Labels> = {
  de: { title: 'Deine Adresse', sub: 'Damit dein Check-in schneller geht.', street: 'Straße & Hausnummer', zip: 'Postleitzahl', city: 'Ort', country: 'Land', next: 'Weiter' },
  en: { title: 'Your address', sub: 'Helps us check you in faster.', street: 'Street & house number', zip: 'Postal code', city: 'City', country: 'Country', next: 'Continue' },
  fr: { title: 'Votre adresse', sub: 'Pour accélérer votre enregistrement.', street: 'Rue & numéro', zip: 'Code postal', city: 'Ville', country: 'Pays', next: 'Continuer' },
  es: { title: 'Tu dirección', sub: 'Para agilizar tu check-in.', street: 'Calle y número', zip: 'Código postal', city: 'Ciudad', country: 'País', next: 'Continuar' },
  it: { title: 'Il tuo indirizzo', sub: 'Per velocizzare il check-in.', street: 'Via & numero civico', zip: 'Codice postale', city: 'Città', country: 'Paese', next: 'Avanti' },
  pt: { title: 'O teu endereço', sub: 'Para agilizar o check-in.', street: 'Rua & número', zip: 'Código postal', city: 'Cidade', country: 'País', next: 'Continuar' },
  nl: { title: 'Jouw adres', sub: 'Om de check-in te versnellen.', street: 'Straat & huisnummer', zip: 'Postcode', city: 'Stad', country: 'Land', next: 'Verder' },
  ru: { title: 'Ваш адрес', sub: 'Для ускорения заезда.', street: 'Улица и номер дома', zip: 'Почтовый индекс', city: 'Город', country: 'Страна', next: 'Далее' },
  ar: { title: 'عنوانك', sub: 'لتسريع تسجيل الوصول.', street: 'الشارع والرقم', zip: 'الرمز البريدي', city: 'المدينة', country: 'البلد', next: 'التالي' },
  zh: { title: '您的地址', sub: '加快入住手续。', street: '街道和门牌号', zip: '邮政编码', city: '城市', country: '国家', next: '继续' },
};
const L = labels[lang];

// Pre-fill from existing record
const prefill = {
  street: rec?.address_street ?? '',
  zip: rec?.address_zip ?? '',
  city: rec?.address_city ?? '',
  country: rec?.address_country ?? 'DE',
};
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPrimary};--accent-soft:${brandPalette.soft};--accent-on:${brandPalette.onAccent};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Adresse</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #F8F7F4; min-height: 100dvh; padding-bottom: 120px; }

    .wiz-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: calc(env(safe-area-inset-top, 0px) + 16px) 20px 16px;
    }
    .wiz-back {
      width: 38px; height: 38px; border-radius: 50%;
      background: #EDEBE7; border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #3A3A36; cursor: pointer; text-decoration: none;
    }
    .wiz-dots { display: flex; gap: 6px; align-items: center; }
    .wiz-dot { width: 6px; height: 6px; border-radius: 50%; background: #D4D1CA; }
    .wiz-dot.active { width: 18px; border-radius: 3px; background: var(--accent, #0A0A0A); }

    .wiz-body { padding: 24px 20px 0; }
    .wiz-title { font-size: 28px; font-weight: 700; color: #0F0F0D; line-height: 1.2; margin-bottom: 8px; }
    .wiz-sub { font-size: 15px; color: #6B6B63; line-height: 1.5; margin-bottom: 32px; }

    .form-group { margin-bottom: 16px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    .form-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.12em; color: #888;
      text-transform: uppercase; margin-bottom: 6px; display: block;
    }
    .form-input, .form-select {
      width: 100%; padding: 14px 16px;
      border: 1.5px solid #E0DDD6; border-radius: 12px;
      background: #fff; font-size: 16px; color: #0F0F0D;
      font-family: 'Space Grotesk', sans-serif;
      outline: none; transition: border-color 0.15s;
    }
    .form-input:focus, .form-select:focus {
      border-color: var(--accent, #0A0A0A);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent, #0A0A0A) 10%, transparent);
    }
    .form-select { appearance: none; }

    .wiz-footer {
      position: fixed; bottom: 0; left: 0; right: 0;
      padding: 16px 20px calc(env(safe-area-inset-bottom, 0px) + 16px);
      background: linear-gradient(to bottom, transparent 0%, #F8F7F4 30%);
    }
    .btn-wiz {
      width: 100%; border: 0; padding: 16px;
      border-radius: 14px; font-size: 16px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: opacity 0.15s;
    }
    .btn-dark { background: #0F0F0D; color: #fff; }
    .btn-dark:disabled { opacity: 0.35; cursor: default; }

    .err-msg { font-size: 13px; color: #E53E3E; margin-top: 8px; }
  </style>
</head>
<body>
  <div x-data="wizAddress()">
    <header class="wiz-header">
      <a class="wiz-back" href={`/g/${token}/pre-checkin/path`} aria-label="Zurück">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </a>
      <div class="wiz-dots">
        <div class="wiz-dot"></div>
        <div class="wiz-dot active"></div>
        <div class="wiz-dot"></div>
        <div class="wiz-dot"></div>
      </div>
    </header>

    <div class="wiz-body">
      <h1 class="wiz-title">{L.title}</h1>
      <p class="wiz-sub">{L.sub}</p>

      <div class="form-group">
        <label class="form-label" for="street">{L.street}</label>
        <input id="street" type="text" class="form-input" x-model="street" autocomplete="street-address" inputmode="text" />
      </div>

      <div class="form-row">
        <div>
          <label class="form-label" for="zip">{L.zip}</label>
          <input id="zip" type="text" class="form-input" x-model="zip" autocomplete="postal-code" inputmode="numeric" />
        </div>
        <div>
          <label class="form-label" for="city">{L.city}</label>
          <input id="city" type="text" class="form-input" x-model="city" autocomplete="address-level2" />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="country">{L.country}</label>
        <select id="country" class="form-select" x-model="country">
          <option value="DE">Deutschland</option>
          <option value="AT">Österreich</option>
          <option value="CH">Schweiz</option>
          <option value="FR">Frankreich</option>
          <option value="IT">Italien</option>
          <option value="ES">Spanien</option>
          <option value="NL">Niederlande</option>
          <option value="BE">Belgien</option>
          <option value="PL">Polen</option>
          <option value="CZ">Tschechien</option>
          <option value="HU">Ungarn</option>
          <option value="RO">Rumänien</option>
          <option value="HR">Kroatien</option>
          <option value="TR">Türkei</option>
          <option value="GB">Großbritannien</option>
          <option value="IE">Irland</option>
          <option value="SE">Schweden</option>
          <option value="NO">Norwegen</option>
          <option value="DK">Dänemark</option>
          <option value="FI">Finnland</option>
          <option value="PT">Portugal</option>
          <option value="GR">Griechenland</option>
          <option value="US">USA</option>
          <option value="CA">Kanada</option>
          <option value="AU">Australien</option>
          <option value="JP">Japan</option>
          <option value="CN">China</option>
          <option value="IN">Indien</option>
          <option value="BR">Brasilien</option>
          <option value="AE">Vereinigte Arabische Emirate</option>
          <option value="OTHER">Anderes Land</option>
        </select>
      </div>

      <p class="err-msg" x-show="error" x-text="error"></p>
    </div>

    <footer class="wiz-footer">
      <button class="btn-wiz btn-dark" :disabled="!canSubmit || submitting" @click="submit()" x-text="submitting ? '…' : '{L.next}'">{L.next}</button>
    </footer>
  </div>

  <script is:inline define:vars={{ token, prefill }}>
    document.addEventListener('alpine:init', () => {
      const Alpine = window['Alpine'];
      Alpine.data('wizAddress', () => ({
        street: prefill.street,
        zip: prefill.zip,
        city: prefill.city,
        country: prefill.country,
        submitting: false,
        error: '',
        get canSubmit() {
          return this.street.trim() && this.zip.trim() && this.city.trim() && this.country;
        },
        async submit() {
          if (!this.canSubmit || this.submitting) return;
          this.submitting = true;
          this.error = '';
          try {
            const res = await fetch('/api/g/pre-checkin/save-address', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                address_street: this.street.trim(),
                address_zip: this.zip.trim(),
                address_city: this.city.trim(),
                address_country: this.country,
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (!data.ok) { this.error = data.error || 'Fehler'; this.submitting = false; return; }
            window.location.href = `/g/${token}/pre-checkin/document`;
          } catch { this.error = 'Netzwerkfehler'; this.submitting = false; }
        },
      }));
    });
  </script>
</body>
</html>
