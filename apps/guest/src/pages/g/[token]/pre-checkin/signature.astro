---
// Pre-Checkin — Schritt 4 (Foreign): Unterschrift + Consent

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@retaha/ui-guest/base';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return Astro.redirect(`/g/${token ?? ''}`);

const { stay, guest, hotel, settings } = ctx;
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_checkin === false) return Astro.redirect(`/g/${token}`);

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id, hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out, is_showcase: false,
  });
}

const sbSr = createSupabaseServiceRoleInstance();
const { data: rec } = await sbSr
  .from('stay_pre_checkin')
  .select('path, status, doc_number, address_city')
  .eq('stay_id', stay.id)
  .maybeSingle();

if (rec?.path !== 'foreign') return Astro.redirect(`/g/${token}/pre-checkin`);
if (rec?.status === 'completed') return Astro.redirect(`/g/${token}/pre-checkin/done`);
if (!rec?.address_city) return Astro.redirect(`/g/${token}/pre-checkin/address`);
if (!rec?.doc_number) return Astro.redirect(`/g/${token}/pre-checkin/document`);

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary = (hotel as any).brand_primary ?? '#0A0A0A';
const brandPalette = computeBrandPalette(brandPrimary);

type Labels = {
  title: string; sub: string;
  clear: string; consent: string; consentSub: string;
  cta: string; ctaSubmitting: string;
  errEmpty: string; errConsent: string;
};
const labels: Record<Lang, Labels> = {
  de: {
    title: 'Unterschrift', sub: 'Mit dem Finger — wie auf Papier, nur schöner.',
    clear: 'Löschen',
    consent: 'Meine Angaben sind korrekt.',
    consentSub: 'Deine Daten werden gemäß §30 BMG gespeichert und nach 12 Monaten gelöscht. Keine Weitergabe ohne richterliche Anordnung.',
    cta: 'Anmeldung abschließen', ctaSubmitting: 'Wird gespeichert …',
    errEmpty: 'Bitte unterschreibe zuerst.',
    errConsent: 'Bitte bestätige deine Angaben.',
  },
  en: {
    title: 'Signature', sub: 'Use your finger — like on paper, just better.',
    clear: 'Clear',
    consent: 'My details are correct.',
    consentSub: 'Your data is stored according to §30 BMG and deleted after 12 months. Not shared without court order.',
    cta: 'Complete registration', ctaSubmitting: 'Saving …',
    errEmpty: 'Please sign first.',
    errConsent: 'Please confirm your details.',
  },
  fr: {
    title: 'Signature', sub: 'Utilisez votre doigt — comme sur papier, en mieux.',
    clear: 'Effacer',
    consent: 'Mes informations sont exactes.',
    consentSub: 'Vos données sont conservées conformément au §30 BMG et supprimées après 12 mois.',
    cta: 'Finaliser l\'inscription', ctaSubmitting: 'Enregistrement …',
    errEmpty: 'Veuillez signer d\'abord.',
    errConsent: 'Veuillez confirmer vos informations.',
  },
  es: {
    title: 'Firma', sub: 'Con el dedo — como en papel, pero mejor.',
    clear: 'Borrar',
    consent: 'Mis datos son correctos.',
    consentSub: 'Tus datos se almacenan conforme al §30 BMG y se eliminan tras 12 meses.',
    cta: 'Completar registro', ctaSubmitting: 'Guardando …',
    errEmpty: 'Por favor firma primero.',
    errConsent: 'Por favor confirma tus datos.',
  },
};
const L = labels[lang];
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPalette.accent};--accent-soft:${brandPalette.soft};--accent-on:${brandPalette.on};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Unterschrift</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #F8F7F4; min-height: 100dvh; display: flex; flex-direction: column; padding-bottom: 0; }

    .wiz-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: calc(env(safe-area-inset-top, 0px) + 16px) 20px 16px;
    }
    .wiz-back {
      width: 38px; height: 38px; border-radius: 50%;
      background: #EDEBE7; border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #3A3A36; cursor: pointer; text-decoration: none;
    }
    .wiz-dots { display: flex; gap: 6px; align-items: center; }
    .wiz-dot { width: 6px; height: 6px; border-radius: 50%; background: #D4D1CA; }
    .wiz-dot.active { width: 18px; border-radius: 3px; background: var(--accent, #0A0A0A); }

    .wiz-body { padding: 24px 20px 0; flex: 1; }
    .wiz-title { font-size: 28px; font-weight: 700; color: #0F0F0D; line-height: 1.2; margin-bottom: 8px; }
    .wiz-sub { font-size: 15px; color: #6B6B63; line-height: 1.5; margin-bottom: 24px; }

    .canvas-wrap {
      position: relative;
      background: #fff; border: 1.5px solid #E0DDD6; border-radius: 16px;
      overflow: hidden; touch-action: none;
      margin-bottom: 12px;
    }
    .sig-canvas { display: block; width: 100%; cursor: crosshair; }
    .sig-line {
      position: absolute; bottom: 28px; left: 20px; right: 20px;
      height: 1px; background: #E0DDD6; pointer-events: none;
    }
    .sig-clear {
      position: absolute; top: 10px; right: 12px;
      background: #F8F7F4; border: 1.5px solid #E0DDD6; border-radius: 8px;
      padding: 5px 10px; font-size: 12px; font-family: inherit; color: #888;
      cursor: pointer;
    }
    .canvas-hint {
      text-align: center; font-size: 12px; color: #B0ADA6;
      margin-bottom: 24px; font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.08em; text-transform: uppercase;
    }

    .consent-block {
      background: #fff; border: 1.5px solid #E0DDD6; border-radius: 14px;
      padding: 16px; margin-bottom: 16px; cursor: pointer;
      display: flex; gap: 12px; align-items: flex-start;
      transition: border-color 0.15s;
    }
    .consent-block.checked { border-color: var(--accent, #0A0A0A); }
    .consent-checkbox {
      width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0; margin-top: 1px;
      border: 1.5px solid #D4D1CA; background: #fff;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.15s;
    }
    .consent-block.checked .consent-checkbox {
      background: var(--accent, #0A0A0A); border-color: var(--accent, #0A0A0A);
    }
    .consent-text { flex: 1; }
    .consent-label { font-size: 15px; font-weight: 600; color: #0F0F0D; margin-bottom: 4px; }
    .consent-sub { font-size: 12px; color: #888; line-height: 1.5; }

    .err-msg { font-size: 13px; color: #E53E3E; margin-bottom: 12px; }

    .wiz-footer {
      padding: 8px 20px calc(env(safe-area-inset-bottom, 0px) + 20px);
      background: #F8F7F4;
    }
    .btn-wiz {
      width: 100%; border: 0; padding: 16px;
      border-radius: 14px; font-size: 16px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: opacity 0.15s;
    }
    .btn-dark { background: #0F0F0D; color: #fff; }
    .btn-dark:disabled { opacity: 0.35; cursor: default; }
  </style>
</head>
<body>
  <div x-data="wizSignature()" style="display:flex;flex-direction:column;min-height:100dvh">
    <header class="wiz-header">
      <a class="wiz-back" href={`/g/${token}/pre-checkin/document`} aria-label="Zurück">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </a>
      <div class="wiz-dots">
        <div class="wiz-dot"></div>
        <div class="wiz-dot"></div>
        <div class="wiz-dot"></div>
        <div class="wiz-dot active"></div>
      </div>
    </header>

    <div class="wiz-body">
      <h1 class="wiz-title">{L.title}</h1>
      <p class="wiz-sub">{L.sub}</p>

      <div class="canvas-wrap">
        <canvas id="sig-canvas" class="sig-canvas" height="200"></canvas>
        <div class="sig-line"></div>
        <button type="button" class="sig-clear" @click="clearCanvas()">{L.clear}</button>
      </div>
      <p class="canvas-hint" x-show="!hasStrokes">✍</p>

      <div class="consent-block" :class="{ checked: consent }" @click="consent = !consent">
        <div class="consent-checkbox">
          <svg x-show="consent" width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="2 7 6 11 12 3"/>
          </svg>
        </div>
        <div class="consent-text">
          <div class="consent-label">{L.consent}</div>
          <div class="consent-sub">{L.consentSub}</div>
        </div>
      </div>

      <p class="err-msg" x-show="error" x-text="error"></p>
    </div>

    <footer class="wiz-footer">
      <button class="btn-wiz btn-dark" :disabled="submitting" @click="submit()">
        <span x-text="submitting ? '{L.ctaSubmitting}' : '{L.cta}'">{L.cta}</span>
      </button>
    </footer>
  </div>

  <script is:inline define:vars={{ token, errEmpty: L.errEmpty, errConsent: L.errConsent }}>
    document.addEventListener('alpine:init', () => {
      const Alpine = window['Alpine'];
      Alpine.data('wizSignature', () => ({
        consent: false,
        hasStrokes: false,
        submitting: false,
        error: '',
        _canvas: null,
        _ctx: null,
        _drawing: false,
        _lastX: 0,
        _lastY: 0,

        init() {
          const canvas = document.getElementById('sig-canvas');
          if (!canvas) return;
          this._canvas = canvas;
          // Size canvas to parent width
          const resize = () => {
            const w = canvas.parentElement.clientWidth;
            canvas.width = w;
            canvas.height = 200;
            this._ctx = canvas.getContext('2d');
            this._ctx.strokeStyle = '#0F0F0D';
            this._ctx.lineWidth = 2.2;
            this._ctx.lineCap = 'round';
            this._ctx.lineJoin = 'round';
          };
          resize();

          const getPos = (e) => {
            const r = canvas.getBoundingClientRect();
            const src = e.touches ? e.touches[0] : e;
            return { x: (src.clientX - r.left) * (canvas.width / r.width), y: (src.clientY - r.top) * (canvas.height / r.height) };
          };

          const start = (e) => { e.preventDefault(); this._drawing = true; const p = getPos(e); this._lastX = p.x; this._lastY = p.y; this._ctx.beginPath(); this._ctx.moveTo(p.x, p.y); };
          const move = (e) => { e.preventDefault(); if (!this._drawing) return; const p = getPos(e); this._ctx.lineTo(p.x, p.y); this._ctx.stroke(); this._lastX = p.x; this._lastY = p.y; this.hasStrokes = true; };
          const end = (e) => { e.preventDefault(); this._drawing = false; };

          canvas.addEventListener('mousedown', start);
          canvas.addEventListener('mousemove', move);
          canvas.addEventListener('mouseup', end);
          canvas.addEventListener('touchstart', start, { passive: false });
          canvas.addEventListener('touchmove', move, { passive: false });
          canvas.addEventListener('touchend', end);
        },

        clearCanvas() {
          if (!this._canvas || !this._ctx) return;
          this._ctx.clearRect(0, 0, this._canvas.width, this._canvas.height);
          this.hasStrokes = false;
        },

        async submit() {
          if (this.submitting) return;
          if (!this.hasStrokes) { this.error = errEmpty; return; }
          if (!this.consent) { this.error = errConsent; return; }
          this.submitting = true;
          this.error = '';
          try {
            const dataUrl = this._canvas.toDataURL('image/png');
            const res = await fetch('/api/g/pre-checkin/save-signature', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ signature_image: dataUrl }),
            });
            const data = await res.json().catch(() => ({}));
            if (!data.ok) { this.error = data.error || 'Fehler'; this.submitting = false; return; }
            window.location.href = `/g/${token}/pre-checkin/done`;
          } catch { this.error = 'Netzwerkfehler'; this.submitting = false; }
        },
      }));
    });
  </script>
</body>
</html>
