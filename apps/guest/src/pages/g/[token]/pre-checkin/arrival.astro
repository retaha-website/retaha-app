---
// Pre-Checkin — Schritt 2 (Domestic): Ankunftszeit (optional)

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@retaha/ui-guest/base';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return Astro.redirect(`/g/${token ?? ''}`);

const { stay, guest, hotel, settings } = ctx;
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_checkin === false) return Astro.redirect(`/g/${token}`);

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id, hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out, is_showcase: false,
  });
}

const sbSr = createSupabaseServiceRoleInstance();
const { data: rec } = await sbSr
  .from('stay_pre_checkin')
  .select('path, status')
  .eq('stay_id', stay.id)
  .maybeSingle();

// Nur domestic path darf hierher
if (rec?.path !== 'domestic') return Astro.redirect(`/g/${token}/pre-checkin`);
if (rec?.status === 'completed') return Astro.redirect(`/g/${token}/pre-checkin/done`);

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary = (hotel as any).brand_primary ?? '#0A0A0A';
const brandPalette = computeBrandPalette(brandPrimary);
const guestName = guest?.first_name ?? null;

type Labels = { title: string; sub: string; etaLabel: string; optional: string; skip: string; next: string };
const labels: Record<Lang, Labels> = {
  de: {
    title: guestName ? `Wann kommst du an, ${guestName}?` : 'Wann kommst du an?',
    sub: 'Das hilft uns, alles für dich bereitzuhalten.',
    etaLabel: 'Geplante Ankunftszeit',
    optional: 'optional',
    skip: 'Überspringen',
    next: 'Fertig',
  },
  en: {
    title: guestName ? `When do you arrive, ${guestName}?` : 'When do you arrive?',
    sub: 'Helps us have everything ready for you.',
    etaLabel: 'Estimated arrival time',
    optional: 'optional',
    skip: 'Skip',
    next: 'Done',
  },
  fr: {
    title: guestName ? `À quelle heure arrivez-vous, ${guestName} ?` : 'À quelle heure arrivez-vous ?',
    sub: 'Cela nous aide à tout préparer pour vous.',
    etaLabel: 'Heure d\'arrivée prévue',
    optional: 'optionnel',
    skip: 'Passer',
    next: 'Terminer',
  },
  es: {
    title: guestName ? `¿Cuándo llegas, ${guestName}?` : '¿Cuándo llegas?',
    sub: 'Nos ayuda a tener todo listo para ti.',
    etaLabel: 'Hora de llegada estimada',
    optional: 'opcional',
    skip: 'Omitir',
    next: 'Finalizar',
  },
};
const L = labels[lang];
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPalette.accent};--accent-soft:${brandPalette.soft};--accent-on:${brandPalette.on};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Ankunftszeit</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #F8F7F4; min-height: 100dvh; }

    .wiz-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: calc(env(safe-area-inset-top, 0px) + 16px) 20px 16px;
    }
    .wiz-back {
      width: 38px; height: 38px; border-radius: 50%;
      background: #EDEBE7; border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #3A3A36; cursor: pointer; text-decoration: none;
    }
    .wiz-dots { display: flex; gap: 6px; align-items: center; }
    .wiz-dot { width: 6px; height: 6px; border-radius: 50%; background: #D4D1CA; }
    .wiz-dot.active { width: 18px; border-radius: 3px; background: var(--accent, #0A0A0A); }

    .wiz-body { padding: 24px 20px 0; }
    .wiz-title { font-size: 28px; font-weight: 700; color: #0F0F0D; line-height: 1.2; margin-bottom: 8px; }
    .wiz-sub { font-size: 15px; color: #6B6B63; line-height: 1.5; margin-bottom: 32px; }

    .form-group { margin-bottom: 20px; }
    .form-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.12em; color: #888;
      text-transform: uppercase; margin-bottom: 6px; display: flex; align-items: center; gap: 6px;
    }
    .form-label-opt {
      background: #EDEBE7; color: #888; border-radius: 4px;
      padding: 2px 6px; font-size: 9px; letter-spacing: 0.08em;
    }
    .form-input {
      width: 100%; padding: 14px 16px;
      border: 1.5px solid #E0DDD6; border-radius: 12px;
      background: #fff; font-size: 18px; color: #0F0F0D;
      font-family: 'Space Grotesk', sans-serif;
      outline: none; transition: border-color 0.15s;
    }
    .form-input:focus {
      border-color: var(--accent, #0A0A0A);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent, #0A0A0A) 10%, transparent);
    }

    .wiz-footer {
      position: fixed; bottom: 0; left: 0; right: 0;
      padding: 16px 20px calc(env(safe-area-inset-bottom, 0px) + 16px);
      background: linear-gradient(to bottom, transparent 0%, #F8F7F4 30%);
      display: flex; flex-direction: column; gap: 10px;
    }
    .btn-wiz {
      width: 100%; border: 0; padding: 16px;
      border-radius: 14px; font-size: 16px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: opacity 0.15s;
    }
    .btn-dark { background: #0F0F0D; color: #fff; }
    .btn-dark:disabled { opacity: 0.35; cursor: default; }
    .btn-ghost { background: transparent; color: #888; font-weight: 500; }
  </style>
</head>
<body>
  <div x-data="wizArrival()">
    <header class="wiz-header">
      <a class="wiz-back" href={`/g/${token}/pre-checkin/path`} aria-label="Zurück">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </a>
      <div class="wiz-dots">
        <div class="wiz-dot"></div>
        <div class="wiz-dot active"></div>
      </div>
    </header>

    <div class="wiz-body">
      <h1 class="wiz-title">{L.title}</h1>
      <p class="wiz-sub">{L.sub}</p>

      <div class="form-group">
        <label class="form-label" for="arrival_eta">
          {L.etaLabel}
          <span class="form-label-opt">{L.optional}</span>
        </label>
        <input
          id="arrival_eta"
          type="time"
          class="form-input"
          x-model="eta"
          min="00:00" max="23:59"
        />
      </div>
    </div>

    <footer class="wiz-footer">
      <button class="btn-wiz btn-dark" :disabled="submitting" @click="submit(false)" x-text="submitting ? '…' : '{L.next}'">{L.next}</button>
      <button class="btn-wiz btn-ghost" :disabled="submitting" @click="submit(true)">{L.skip}</button>
    </footer>
  </div>

  <script is:inline define:vars={{ token }}>
    document.addEventListener('alpine:init', () => {
      const Alpine = window['Alpine'];
      Alpine.data('wizArrival', () => ({
        eta: '',
        submitting: false,
        async submit(skip) {
          if (this.submitting) return;
          this.submitting = true;
          try {
            const res = await fetch('/api/g/pre-checkin/save-arrival', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ arrival_eta: skip ? null : (this.eta || null) }),
            });
            const data = await res.json().catch(() => ({}));
            if (!data.ok) { this.submitting = false; return; }
            window.location.href = `/g/${token}/pre-checkin/done`;
          } catch { this.submitting = false; }
        },
      }));
    });
  </script>
</body>
</html>
