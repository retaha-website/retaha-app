---
// Pre-Checkin — Schritt 3 (Foreign): Ausweisdaten + Mitreisende

import { loadGuestCtx } from '../../../../lib/showcase/guest-ctx';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@retaha/ui-guest/base';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctxResult = await loadGuestCtx(token);
if (!ctxResult) return Astro.redirect(`/g/${token ?? ''}`);
const { ctx, isShowcase } = ctxResult;
const { stay, guest, hotel, settings } = ctx;
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_checkin === false) return Astro.redirect(`/g/${token}`);

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id, hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out, is_showcase: isShowcase,
  });
}

const sbSr = createSupabaseServiceRoleInstance();
let rec: any = null;
if (!isShowcase) {
  const { data } = await sbSr.from('stay_pre_checkin').select('path, status, nationality, doc_type, doc_number, accompanying, address_city').eq('stay_id', stay.id).maybeSingle();
  rec = data;
  if (rec?.path !== 'foreign') return Astro.redirect(`/g/${token}/pre-checkin`);
  if (rec?.status === 'completed') return Astro.redirect(`/g/${token}/pre-checkin/done`);
  if (!rec?.address_city) return Astro.redirect(`/g/${token}/pre-checkin/address`);
}

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary = (hotel as any).brand_primary ?? '#0A0A0A';
const brandPalette = computeBrandPalette(brandPrimary);

type Labels = { title: string; sub: string; nationality: string; docType: string; docNumber: string; passport: string; idCard: string; accompanying: string; accompanyingAdd: string; accompanyingRemove: string; accompanyingFn: string; accompanyingLn: string; accompanyingNat: string; next: string };
const labels: Record<Lang, Labels> = {
  de: { title: 'Dein Ausweis', sub: 'Kurz für den Meldeschein — bleibt streng vertraulich.', nationality: 'Nationalität', docType: 'Reisedokument', docNumber: 'Dokumentnummer', passport: 'Reisepass', idCard: 'Personalausweis', accompanying: 'Mitreisende', accompanyingAdd: '+ Person hinzufügen', accompanyingRemove: 'Entfernen', accompanyingFn: 'Vorname', accompanyingLn: 'Nachname', accompanyingNat: 'Nationalität', next: 'Weiter' },
  en: { title: 'Your ID', sub: 'For the registration form — kept strictly confidential.', nationality: 'Nationality', docType: 'Travel document', docNumber: 'Document number', passport: 'Passport', idCard: 'ID card', accompanying: 'Accompanying guests', accompanyingAdd: '+ Add person', accompanyingRemove: 'Remove', accompanyingFn: 'First name', accompanyingLn: 'Last name', accompanyingNat: 'Nationality', next: 'Continue' },
  fr: { title: "Votre pièce d'identité", sub: 'Pour le formulaire — strictement confidentiel.', nationality: 'Nationalité', docType: 'Document de voyage', docNumber: 'Numéro de document', passport: 'Passeport', idCard: "Carte d'identité", accompanying: 'Accompagnateurs', accompanyingAdd: '+ Ajouter une personne', accompanyingRemove: 'Supprimer', accompanyingFn: 'Prénom', accompanyingLn: 'Nom', accompanyingNat: 'Nationalité', next: 'Continuer' },
  es: { title: 'Tu documento', sub: 'Para el formulario de registro — estrictamente confidencial.', nationality: 'Nacionalidad', docType: 'Documento de viaje', docNumber: 'Número de documento', passport: 'Pasaporte', idCard: 'DNI / Tarjeta de identidad', accompanying: 'Acompañantes', accompanyingAdd: '+ Añadir persona', accompanyingRemove: 'Eliminar', accompanyingFn: 'Nombre', accompanyingLn: 'Apellido', accompanyingNat: 'Nacionalidad', next: 'Continuar' },
  it: { title: 'Il tuo documento', sub: 'Per il modulo di registrazione — strettamente riservato.', nationality: 'Nazionalità', docType: 'Documento di viaggio', docNumber: 'Numero documento', passport: 'Passaporto', idCard: "Carta d'identità", accompanying: 'Accompagnatori', accompanyingAdd: '+ Aggiungi persona', accompanyingRemove: 'Rimuovi', accompanyingFn: 'Nome', accompanyingLn: 'Cognome', accompanyingNat: 'Nazionalità', next: 'Avanti' },
  pt: { title: 'O teu documento', sub: 'Para o formulário de registo — estritamente confidencial.', nationality: 'Nacionalidade', docType: 'Documento de viagem', docNumber: 'Número do documento', passport: 'Passaporte', idCard: 'Bilhete de identidade', accompanying: 'Acompanhantes', accompanyingAdd: '+ Adicionar pessoa', accompanyingRemove: 'Remover', accompanyingFn: 'Primeiro nome', accompanyingLn: 'Apelido', accompanyingNat: 'Nacionalidade', next: 'Continuar' },
  nl: { title: 'Jouw identiteitsbewijs', sub: 'Voor het registratieformulier — strikt vertrouwelijk.', nationality: 'Nationaliteit', docType: 'Reisdocument', docNumber: 'Documentnummer', passport: 'Paspoort', idCard: 'Identiteitskaart', accompanying: 'Reisgezelschap', accompanyingAdd: '+ Persoon toevoegen', accompanyingRemove: 'Verwijderen', accompanyingFn: 'Voornaam', accompanyingLn: 'Achternaam', accompanyingNat: 'Nationaliteit', next: 'Verder' },
  ru: { title: 'Ваш документ', sub: 'Для регистрационной формы — строго конфиденциально.', nationality: 'Гражданство', docType: 'Документ для путешествий', docNumber: 'Номер документа', passport: 'Паспорт', idCard: 'Удостоверение личности', accompanying: 'Сопровождающие', accompanyingAdd: '+ Добавить человека', accompanyingRemove: 'Удалить', accompanyingFn: 'Имя', accompanyingLn: 'Фамилия', accompanyingNat: 'Гражданство', next: 'Далее' },
  ar: { title: 'وثيقتك', sub: 'لنموذج التسجيل — سري للغاية.', nationality: 'الجنسية', docType: 'وثيقة السفر', docNumber: 'رقم الوثيقة', passport: 'جواز السفر', idCard: 'بطاقة الهوية', accompanying: 'المرافقون', accompanyingAdd: '+ إضافة شخص', accompanyingRemove: 'إزالة', accompanyingFn: 'الاسم الأول', accompanyingLn: 'اسم العائلة', accompanyingNat: 'الجنسية', next: 'التالي' },
  zh: { title: '您的证件', sub: '用于登记表格 — 严格保密。', nationality: '国籍', docType: '旅行证件', docNumber: '证件号码', passport: '护照', idCard: '身份证', accompanying: '同行人员', accompanyingAdd: '+ 添加人员', accompanyingRemove: '删除', accompanyingFn: '名', accompanyingLn: '姓', accompanyingNat: '国籍', next: '继续' },
};
const L = labels[lang];

const prefill = {
  nationality: rec?.nationality ?? '',
  doc_type: rec?.doc_type ?? 'passport',
  doc_number: rec?.doc_number ?? '',
  accompanying: rec?.accompanying ?? [],
};
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPrimary};--accent-soft:${brandPalette.soft};--accent-on:${brandPalette.onAccent};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Ausweis</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #F8F7F4; min-height: 100dvh; padding-bottom: 120px; }

    .wiz-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: calc(env(safe-area-inset-top, 0px) + 16px) 20px 16px;
    }
    .wiz-back {
      width: 38px; height: 38px; border-radius: 50%;
      background: #EDEBE7; border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #3A3A36; cursor: pointer; text-decoration: none;
    }
    .wiz-dots { display: flex; gap: 6px; align-items: center; }
    .wiz-dot { width: 6px; height: 6px; border-radius: 50%; background: #D4D1CA; }
    .wiz-dot.active { width: 18px; border-radius: 3px; background: var(--accent, #0A0A0A); }

    .wiz-body { padding: 24px 20px 0; }
    .wiz-title { font-size: 28px; font-weight: 700; color: #0F0F0D; line-height: 1.2; margin-bottom: 8px; }
    .wiz-sub { font-size: 15px; color: #6B6B63; line-height: 1.5; margin-bottom: 32px; }

    .form-group { margin-bottom: 16px; }
    .form-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.12em; color: #888;
      text-transform: uppercase; margin-bottom: 6px; display: block;
    }
    .form-input, .form-select {
      width: 100%; padding: 14px 16px;
      border: 1.5px solid #E0DDD6; border-radius: 12px;
      background: #fff; font-size: 16px; color: #0F0F0D;
      font-family: 'Space Grotesk', sans-serif;
      outline: none; transition: border-color 0.15s; appearance: none;
    }
    .form-input:focus, .form-select:focus {
      border-color: var(--accent, #0A0A0A);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent, #0A0A0A) 10%, transparent);
    }

    .doctype-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .doctype-btn {
      padding: 12px; border: 1.5px solid #E0DDD6; border-radius: 12px;
      background: #fff; font-size: 14px; font-weight: 500; color: #6B6B63;
      cursor: pointer; font-family: inherit; transition: all 0.15s; text-align: center;
    }
    .doctype-btn.active {
      border-color: var(--accent, #0A0A0A); color: var(--accent, #0A0A0A);
      background: color-mix(in srgb, var(--accent, #0A0A0A) 6%, #fff);
    }

    .section-divider {
      margin: 24px 0 16px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.12em; color: #888; text-transform: uppercase;
    }
    .acc-person {
      background: #fff; border: 1.5px solid #E0DDD6; border-radius: 14px;
      padding: 14px; margin-bottom: 10px;
    }
    .acc-person-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .acc-remove {
      background: none; border: 0; font-size: 13px; color: #888; cursor: pointer;
      font-family: inherit; padding: 0;
    }
    .btn-add-person {
      width: 100%; padding: 12px; border: 1.5px dashed #D4D1CA;
      border-radius: 12px; background: transparent; font-size: 14px;
      font-weight: 500; color: #888; cursor: pointer; font-family: inherit;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn-add-person:hover { border-color: var(--accent, #0A0A0A); color: var(--accent, #0A0A0A); }

    .wiz-footer {
      position: fixed; bottom: 0; left: 0; right: 0;
      padding: 16px 20px calc(env(safe-area-inset-bottom, 0px) + 16px);
      background: linear-gradient(to bottom, transparent 0%, #F8F7F4 30%);
    }
    .btn-wiz {
      width: 100%; border: 0; padding: 16px;
      border-radius: 14px; font-size: 16px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: opacity 0.15s;
    }
    .btn-dark { background: #0F0F0D; color: #fff; }
    .btn-dark:disabled { opacity: 0.35; cursor: default; }
    .err-msg { font-size: 13px; color: #E53E3E; margin-top: 8px; }
  </style>
</head>
<body>
  <div x-data="wizDocument()">
    <header class="wiz-header">
      <a class="wiz-back" href={`/g/${token}/pre-checkin/address`} aria-label="Zurück">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </a>
      <div class="wiz-dots">
        <div class="wiz-dot"></div>
        <div class="wiz-dot"></div>
        <div class="wiz-dot active"></div>
        <div class="wiz-dot"></div>
      </div>
    </header>

    <div class="wiz-body">
      <h1 class="wiz-title">{L.title}</h1>
      <p class="wiz-sub">{L.sub}</p>

      <div class="form-group">
        <label class="form-label" for="nationality">{L.nationality}</label>
        <select id="nationality" class="form-select" x-model="nationality">
          <option value="">—</option>
          <option value="DE">Deutsch</option>
          <option value="AT">Österreichisch</option>
          <option value="CH">Schweizerisch</option>
          <option value="FR">Französisch</option>
          <option value="IT">Italienisch</option>
          <option value="ES">Spanisch</option>
          <option value="NL">Niederländisch</option>
          <option value="PL">Polnisch</option>
          <option value="TR">Türkisch</option>
          <option value="GB">Britisch</option>
          <option value="US">Amerikanisch</option>
          <option value="RU">Russisch</option>
          <option value="CN">Chinesisch</option>
          <option value="JP">Japanisch</option>
          <option value="IN">Indisch</option>
          <option value="BR">Brasilianisch</option>
          <option value="AE">Emiratisch</option>
          <option value="OTHER">Sonstige</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">{L.docType}</label>
        <div class="doctype-row">
          <button type="button" class="doctype-btn" :class="{ active: docType === 'passport' }" @click="docType = 'passport'">{L.passport}</button>
          <button type="button" class="doctype-btn" :class="{ active: docType === 'id_card' }" @click="docType = 'id_card'">{L.idCard}</button>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="docnumber">{L.docNumber}</label>
        <input id="docnumber" type="text" class="form-input" x-model="docNumber" autocomplete="off" autocorrect="off" spellcheck="false" />
      </div>

      <div class="section-divider">{L.accompanying}</div>

      <template x-for="(person, idx) in accompanying" :key="idx">
        <div class="acc-person">
          <div class="acc-person-fields">
            <div>
              <label class="form-label">{L.accompanyingFn}</label>
              <input type="text" class="form-input" x-model="person.first_name" />
            </div>
            <div>
              <label class="form-label">{L.accompanyingLn}</label>
              <input type="text" class="form-input" x-model="person.last_name" />
            </div>
          </div>
          <div class="form-group" style="margin-bottom:8px">
            <label class="form-label">{L.accompanyingNat}</label>
            <input type="text" class="form-input" x-model="person.nationality" />
          </div>
          <button type="button" class="acc-remove" @click="accompanying.splice(idx,1)">{L.accompanyingRemove}</button>
        </div>
      </template>

      <button type="button" class="btn-add-person" @click="accompanying.push({first_name:'',last_name:'',nationality:''})">{L.accompanyingAdd}</button>

      <p class="err-msg" x-show="error" x-text="error" style="margin-top:12px"></p>
    </div>

    <footer class="wiz-footer">
      <button class="btn-wiz btn-dark" :disabled="!canSubmit || submitting" @click="submit()" x-text="submitting ? '…' : '{L.next}'">{L.next}</button>
    </footer>
  </div>

  <script is:inline define:vars={{ token, prefill }}>
    document.addEventListener('alpine:init', () => {
      const Alpine = window['Alpine'];
      Alpine.data('wizDocument', () => ({
        nationality: prefill.nationality,
        docType: prefill.doc_type || 'passport',
        docNumber: prefill.doc_number,
        accompanying: prefill.accompanying ? [...prefill.accompanying] : [],
        submitting: false,
        error: '',
        get canSubmit() {
          return this.nationality && this.docNumber.trim();
        },
        async submit() {
          if (!this.canSubmit || this.submitting) return;
          this.submitting = true;
          this.error = '';
          try {
            const res = await fetch('/api/g/pre-checkin/save-document', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                nationality: this.nationality,
                doc_type: this.docType,
                doc_number: this.docNumber.trim(),
                accompanying: this.accompanying.filter(p => p.first_name || p.last_name),
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (!data.ok) { this.error = data.error || 'Fehler'; this.submitting = false; return; }
            window.location.href = `/g/${token}/pre-checkin/signature`;
          } catch { this.error = 'Netzwerkfehler'; this.submitting = false; }
        },
      }));
    });
  </script>
</body>
</html>
