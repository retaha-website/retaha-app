---
// Self-Checkout-Sheet
// Feature-Gate: features.self_checkout
//
// Billing-Logik:
//   Test (jetzt): stays.raw_mews_data._retaha_sim  →  { currency, balance_cents, total_cents, items }
//   TODO Mews live: Saldo + Posten aus Mews-API lesen; _retaha_sim-Block entfernen/ignorieren.
//
// Pfade:
//   balance_cents === 0  →  Zustand A: Self-Checkout erlaubt
//   balance_cents  > 0  →  Zustand B: gesperrt, Rezeption aufsuchen

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { getStaySession, setStaySessionCookie, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';

const { token } = Astro.params;
if (!token) return new Response('Token fehlt', { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return new Response('Aufenthalt nicht gefunden', { status: 404 });

const { stay, guest, hotel, settings } = ctx;

// Feature-Gate
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.self_checkout === false) {
  return Astro.redirect(`/g/${token}`);
}

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);

// Stay-Session sicherstellen
const existingSession = await getStaySession(Astro.cookies);
if (!existingSession || existingSession.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id,
    hotel_id: hotel.id,
    check_out_utc: stay.check_out,
    is_showcase: false,
  });
}

// Checkout-Datum formatieren
const localeMap = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES' } as Record<Lang, string>;
const checkoutDate = new Date(stay.check_out);
const checkoutDateLabel = checkoutDate.toLocaleDateString(localeMap[lang], {
  weekday: 'long', day: '2-digit', month: 'long',
});
const checkoutTime = checkoutDate.toLocaleTimeString(localeMap[lang], {
  hour: '2-digit', minute: '2-digit',
});

const guestName = guest?.first_name ?? null;
const isCheckoutDay = new Date().toDateString() === checkoutDate.toDateString();
const alreadyPast = Date.parse(stay.check_out) < Date.now();

// Stay-Daten + Billing in einem Query
const sbSr = createSupabaseServiceRoleInstance();
const { data: stayRow } = await sbSr
  .from('stays')
  .select('checked_out_at, raw_mews_data')
  .eq('id', stay.id)
  .maybeSingle();

const alreadyCheckedOut = !!(stayRow as any)?.checked_out_at;

// --- Billing ---------------------------------------------------------------
// TODO: Mews live-Anbindung hier — dann _retaha_sim-Block ersetzen.
interface SimItem    { label: string; amount_cents: number; }
interface SimBilling { currency: string; balance_cents: number; total_cents: number; items: SimItem[]; }

const simBilling: SimBilling | null = (stayRow as any)?.raw_mews_data?._retaha_sim ?? null;
const balanceCents  = simBilling?.balance_cents ?? 0;
const totalCents    = simBilling?.total_cents   ?? 0;
const billItems     = simBilling?.items         ?? [];
const billCurrency  = simBilling?.currency      ?? (hotel as any).currency ?? 'EUR';
const isBalanceOpen = balanceCents > 0;

function fmtMoney(cents: number): string {
  return new Intl.NumberFormat('de-DE', {
    style: 'currency', currency: billCurrency, minimumFractionDigits: 2,
  }).format(cents / 100);
}
// ---------------------------------------------------------------------------

const hotelPhone: string | null = (hotel as any).phone ?? null;
const backHref = `/g/${token}`;

type LabelSet = {
  eyebrow: string;
  title: string; titleOpen: string;
  sub: string; subOpen: string;
  step1BillTitle: string;
  billPaidLabel: string; billOpenLabel: string;
  billTotal: string; billOpenTotal: string;
  billNote: string; billNoteOpen: string;
  attnLabel: string; attnMsg: string;
  step2Title: string; step2Sub: string;
  step3Title: string; step3Sub: string;
  btnLabel: string; hintLabel: string;
  btnCallLabel: string; callHint: string;
  doneTitle: string; doneSub: string;
  notYetTitle: string; notYetSub: string;
  back: string;
};

const labels = {
  de: {
    eyebrow:       `Abreise · ${checkoutDateLabel} · ${checkoutTime} Uhr`,
    title:         `Auf Wiedersehen${guestName ? `, ${guestName}` : ''}`,
    titleOpen:     `Fast geschafft${guestName ? `, ${guestName}` : ''}`,
    sub:           'Danke für deinen Aufenthalt — wir hoffen, es hat dir gefallen.',
    subOpen:       'Vor der Abreise ist noch ein offener Betrag zu begleichen.',
    step1BillTitle: 'Rechnung',
    billPaidLabel:  'Beglichen',
    billOpenLabel:  'Offen',
    billTotal:      'Gesamt',
    billOpenTotal:  'Offener Betrag',
    billNote:       'Die offizielle Rechnung erhältst du per E-Mail.',
    billNoteOpen:   'Die offizielle Rechnung erhältst du an der Rezeption oder per E-Mail.',
    attnLabel:      'Noch offen',
    attnMsg:        'Self-Checkout ist erst möglich, wenn die Rechnung beglichen ist. Bitte checke an der Rezeption aus — unser Team hilft dir gern.',
    step2Title:    'Schlüsselkarte',
    step2Sub:      'Einfach im Zimmer lassen oder an der Rezeption abgeben.',
    step3Title:    'Auschecken bestätigen',
    step3Sub:      'Ein Klick — du erhältst eine Bestätigungs-E-Mail.',
    btnLabel:      'Jetzt auschecken',
    hintLabel:     'Du erhältst eine kurze Bestätigung per E-Mail.',
    btnCallLabel:  'Rezeption anrufen',
    callHint:      'Self-Checkout wird nach Begleichung wieder freigeschaltet.',
    doneTitle:     'Erfolgreich ausgecheckt.',
    doneSub:       'Gute Reise — wir hoffen, dich bald wieder begrüßen zu dürfen.',
    notYetTitle:   'Checkout noch nicht möglich.',
    notYetSub:     `Dein Abreise-Tag ist ${checkoutDateLabel}. Bis dahin — genieß deinen Aufenthalt!`,
    back:          '← zurück',
  },
  en: {
    eyebrow:       `Check-out · ${checkoutDateLabel} · ${checkoutTime}`,
    title:         `Goodbye${guestName ? `, ${guestName}` : ''}`,
    titleOpen:     `Almost there${guestName ? `, ${guestName}` : ''}`,
    sub:           'Thank you for your stay — we hope you enjoyed it.',
    subOpen:       'There is an outstanding balance to settle before departure.',
    step1BillTitle: 'Invoice',
    billPaidLabel:  'Settled',
    billOpenLabel:  'Open',
    billTotal:      'Total',
    billOpenTotal:  'Outstanding',
    billNote:       'Your official receipt will be sent by e-mail.',
    billNoteOpen:   'Your official receipt is available at reception or by e-mail.',
    attnLabel:      'Outstanding',
    attnMsg:        'Self-checkout is only available once the balance is settled. Please check out at reception — our team is happy to help.',
    step2Title:    'Key card',
    step2Sub:      'Leave it in the room or hand it to reception.',
    step3Title:    'Confirm check-out',
    step3Sub:      "One click — you'll receive a confirmation email.",
    btnLabel:      'Check out now',
    hintLabel:     "You'll receive a short confirmation by email.",
    btnCallLabel:  'Call reception',
    callHint:      'Self-checkout will be available once the balance is settled.',
    doneTitle:     'Successfully checked out.',
    doneSub:       'Safe travels — we hope to welcome you back soon.',
    notYetTitle:   'Check-out not yet available.',
    notYetSub:     `Your check-out date is ${checkoutDateLabel}. Until then — enjoy your stay!`,
    back:          '← back',
  },
  fr: {
    eyebrow:       `Départ · ${checkoutDateLabel} · ${checkoutTime}`,
    title:         `Au revoir${guestName ? `, ${guestName}` : ''}`,
    titleOpen:     `Presque là${guestName ? `, ${guestName}` : ''}`,
    sub:           'Merci pour votre séjour — nous espérons vous revoir bientôt.',
    subOpen:       'Un solde est encore à régler avant votre départ.',
    step1BillTitle: 'Facture',
    billPaidLabel:  'Réglée',
    billOpenLabel:  'Ouverte',
    billTotal:      'Total',
    billOpenTotal:  'Solde dû',
    billNote:       'Votre reçu officiel vous sera envoyé par e-mail.',
    billNoteOpen:   'Votre reçu officiel est disponible à la réception ou par e-mail.',
    attnLabel:      'Solde dû',
    attnMsg:        'Le départ autonome est disponible une fois le solde réglé. Veuillez vous adresser à la réception.',
    step2Title:    'Carte-clé',
    step2Sub:      'Laissez-la dans la chambre ou remettez-la à la réception.',
    step3Title:    'Confirmer le départ',
    step3Sub:      'Un clic — vous recevrez un e-mail de confirmation.',
    btnLabel:      'Partir maintenant',
    hintLabel:     'Vous recevrez une confirmation par e-mail.',
    btnCallLabel:  'Appeler la réception',
    callHint:      'Le départ autonome sera disponible après règlement.',
    doneTitle:     'Départ confirmé.',
    doneSub:       'Bon voyage — à bientôt !',
    notYetTitle:   'Départ pas encore disponible.',
    notYetSub:     `Votre date de départ est le ${checkoutDateLabel}.`,
    back:          '← retour',
  },
  es: {
    eyebrow:       `Salida · ${checkoutDateLabel} · ${checkoutTime}`,
    title:         `Hasta pronto${guestName ? `, ${guestName}` : ''}`,
    titleOpen:     `Ya casi${guestName ? `, ${guestName}` : ''}`,
    sub:           'Gracias por tu estancia — esperamos verte pronto.',
    subOpen:       'Hay un saldo pendiente por liquidar antes de la salida.',
    step1BillTitle: 'Factura',
    billPaidLabel:  'Pagada',
    billOpenLabel:  'Pendiente',
    billTotal:      'Total',
    billOpenTotal:  'Importe pendiente',
    billNote:       'Tu recibo oficial se enviará por correo electrónico.',
    billNoteOpen:   'Tu recibo oficial está disponible en recepción o por correo electrónico.',
    attnLabel:      'Pendiente',
    attnMsg:        'El auto-checkout solo está disponible cuando el saldo esté liquidado. Por favor dirígete a recepción.',
    step2Title:    'Tarjeta-llave',
    step2Sub:      'Déjala en la habitación o entrégala en recepción.',
    step3Title:    'Confirmar la salida',
    step3Sub:      'Un clic — recibirás un correo de confirmación.',
    btnLabel:      'Salir ahora',
    hintLabel:     'Recibirás una confirmación breve por e-mail.',
    btnCallLabel:  'Llamar a recepción',
    callHint:      'El auto-checkout estará disponible tras el pago.',
    doneTitle:     'Salida confirmada.',
    doneSub:       '¡Buen viaje — esperamos verte pronto!',
    notYetTitle:   'Salida aún no disponible.',
    notYetSub:     `Tu fecha de salida es el ${checkoutDateLabel}.`,
    back:          '← volver',
  },
};

const L = (labels as Record<Lang, LabelSet>)[lang] ?? (labels as Record<Lang, LabelSet>)['de'];
const effectiveTitle = isBalanceOpen ? L.titleOpen : L.title;
const effectiveSub   = isBalanceOpen ? L.subOpen   : L.sub;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0A" />
    <title>{hotel.name} · {lang === 'de' ? 'Auschecken' : 'Check-out'}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0; padding: 0;
        background: #FAFAF8; color: #0A0A0A;
        font-family: 'Space Grotesk', system-ui, sans-serif; min-height: 100vh;
      }
      .page { max-width: 520px; margin: 0 auto; padding: 0 20px 60px; }

      .back-link {
        display: inline-block; padding: 16px 0 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
        color: #888; text-decoration: none;
      }
      .back-link:hover { color: #0A0A0A; }

      .hero { padding: 32px 0 28px; border-bottom: 1px solid #E0DDD8; margin-bottom: 28px; }
      .hero__eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.14em; font-weight: 500;
        color: #888; display: block; margin-bottom: 12px;
      }
      .hero__title {
        font-size: clamp(26px, 6vw, 42px); font-weight: 400; letter-spacing: -0.025em;
        line-height: 1.05; margin: 0 0 10px; color: #0A0A0A;
      }
      .hero__title .dot { color: var(--guest-accent); }
      .hero__sub { font-size: 15px; color: #666; line-height: 1.5; margin: 0; }

      /* Steps */
      .steps { display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; }
      .step {
        display: flex; align-items: flex-start; gap: 14px;
        padding: 16px;
        background: #fff; border: 1px solid #E0DDD8; border-radius: 14px;
      }
      .step--highlight { border: 1.5px solid var(--guest-accent); }
      .step__num {
        width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0;
        background: #E0DDD8; color: #555;
        display: flex; align-items: center; justify-content: center;
        font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600;
        margin-top: 1px;
      }
      .step--highlight .step__num { background: var(--guest-accent); color: #fff; }
      .step--done .step__num      { background: var(--guest-accent); color: #fff; }
      .step__body { flex: 1; min-width: 0; }
      .step__title-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
      .step__title { font-size: 15px; font-weight: 600; color: #0A0A0A; line-height: 1.2; }
      .step__sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #888; line-height: 1.4; margin-top: 4px; }
      .step__check { margin-left: auto; flex-shrink: 0; color: var(--guest-accent); margin-top: 4px; }

      /* Bill chips */
      .bill-chip {
        font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.06em;
        text-transform: uppercase; font-weight: 600; padding: 3px 8px; border-radius: 7px;
        white-space: nowrap; flex-shrink: 0;
      }
      .bill-chip--paid { background: var(--guest-accent); color: #fff; }
      .bill-chip--open { background: #0A0A0A; color: #FFE600; }

      /* Billing breakdown */
      .bill { margin-top: 11px; padding-top: 11px; border-top: 1px solid #E0DDD8; }
      .bill__li { display: flex; justify-content: space-between; font-size: 13px; color: #555; padding: 3px 0; }
      .bill__lbl { color: #666; }
      .bill__total {
        display: flex; justify-content: space-between;
        font-size: 15px; font-weight: 600; color: #0A0A0A;
        margin-top: 8px; padding-top: 8px; border-top: 1px solid #E0DDD8;
      }
      .bill__note {
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        color: #AAA; margin-top: 9px; line-height: 1.4;
      }

      /* Attention card (open balance) — warmer Gelb-Tint, kein Rot */
      .attn {
        background: #FFFBEA; border: 1px solid #F0E2A8; border-radius: 14px;
        padding: 18px; margin-bottom: 0;
      }
      .attn__label {
        font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em;
        text-transform: uppercase; color: #8A7A3A;
      }
      .attn__amount {
        font-size: 30px; font-weight: 700; font-family: 'Space Grotesk', sans-serif;
        margin-top: 4px; color: #0A0A0A;
      }
      .attn__msg { font-size: 13px; color: #5B5536; margin-top: 10px; line-height: 1.5; }

      /* CTA */
      .cta-area { display: flex; flex-direction: column; gap: 10px; align-items: center; }
      .cta-btn {
        width: 100%; padding: 16px;
        background: #0A0A0A; color: #FAFAF8;
        border: none; border-radius: 14px;
        font-size: 15px; font-weight: 600; cursor: pointer; font-family: inherit;
        transition: background 150ms, color 150ms;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        text-decoration: none;
      }
      .cta-btn:hover { background: #FFE600; color: #0A0A0A; }
      .cta-btn:hover .btn-icon { stroke: #0A0A0A; }
      .cta-btn:disabled { opacity: 0.5; cursor: wait; }
      .btn-icon { flex-shrink: 0; stroke: #FAFAF8; fill: none; stroke-width: 2.4; stroke-linecap: square; stroke-linejoin: miter; }
      .cta-hint {
        font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #AAA;
        text-align: center; margin: 0; letter-spacing: 0.04em;
      }

      /* Done state */
      .done-state {
        background: #0A0A0A; color: #FAFAF8;
        border-radius: 12px; padding: 28px 24px; text-align: center;
        margin-bottom: 20px;
      }
      .done-state__icon { font-size: 36px; margin-bottom: 16px; }
      .done-state__title { font-size: 20px; font-weight: 400; margin: 0 0 8px; }
      .done-state__sub { font-size: 13px; opacity: 0.65; line-height: 1.4; margin: 0; }

      /* Not-yet state */
      .notyet-state {
        background: #F5F5F3; border: 1px solid #E0DDD8;
        border-radius: 12px; padding: 24px; text-align: center;
      }
      .notyet-state__title { font-size: 18px; font-weight: 400; margin: 0 0 8px; }
      .notyet-state__sub { font-size: 13px; color: #666; line-height: 1.4; margin: 0; }

      /* Flash */
      .flash { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
      .flash--ok  { background: #EDF7ED; color: #2D6B2D; border: 1px solid #B5D9B5; }
      .flash--err { background: #FEF2F2; color: #8C2128; border: 1px solid #F5C6C6; }
      .flash[hidden] { display: none; }

      .made-by {
        margin-top: 48px; padding-top: 20px;
        border-top: 1px solid #E0DDD8;
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        color: #BBB; text-align: center; letter-spacing: 0.06em;
      }
      .made-by a { color: #888; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="page">
      <a href={backHref} class="back-link">{L.back}</a>

      <div class="hero">
        <span class="hero__eyebrow">{L.eyebrow}</span>
        <h1 class="hero__title">{effectiveTitle}<span class="dot">.</span></h1>
        <p class="hero__sub">{effectiveSub}</p>
      </div>

      {alreadyCheckedOut ? (
        <div class="done-state">
          <div class="done-state__icon">✓</div>
          <h2 class="done-state__title">{L.doneTitle}</h2>
          <p class="done-state__sub">{L.doneSub}</p>
        </div>
      ) : !isCheckoutDay && !alreadyPast ? (
        <div class="notyet-state">
          <h2 class="notyet-state__title">{L.notYetTitle}</h2>
          <p class="notyet-state__sub">{L.notYetSub}</p>
        </div>
      ) : isBalanceOpen ? (
        /* ── Zustand B: offener Saldo ── */
        <>
          <div class="attn">
            <div class="attn__label">{L.attnLabel}</div>
            <div class="attn__amount">{fmtMoney(balanceCents)}</div>
            <p class="attn__msg">{L.attnMsg}</p>
          </div>

          <div class="steps" style="margin-top: 14px;">
            <div class="step">
              <div class="step__num" style="font-style:italic;font-family:'Space Grotesk',sans-serif;font-size:13px;">i</div>
              <div class="step__body">
                <div class="step__title-row">
                  <span class="step__title">{L.step1BillTitle}</span>
                  <span class="bill-chip bill-chip--open">{L.billOpenLabel}</span>
                </div>
                {billItems.length > 0 && (
                  <div class="bill">
                    {billItems.map((item: SimItem) => (
                      <div class="bill__li">
                        <span class="bill__lbl">{item.label}</span>
                        <span>{fmtMoney(item.amount_cents)}</span>
                      </div>
                    ))}
                    <div class="bill__total">
                      <span>{L.billOpenTotal}</span>
                      <span>{fmtMoney(balanceCents)}</span>
                    </div>
                    <div class="bill__note">{L.billNoteOpen}</div>
                  </div>
                )}
              </div>
            </div>
          </div>

          <div class="cta-area">
            {hotelPhone ? (
              <a href={`tel:${hotelPhone}`} class="cta-btn">
                {L.btnCallLabel}
                <svg class="btn-icon" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true" stroke-linejoin="round">
                  <path d="M5 4h3l2 5-2 1.5a11 11 0 005 5L20 13l1 3v3a1 1 0 01-1 1A16 16 0 014 5a1 1 0 011-1z"/>
                </svg>
              </a>
            ) : (
              <div class="cta-btn" style="cursor:default;">
                {L.btnCallLabel}
                <svg class="btn-icon" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true" stroke-linejoin="round">
                  <path d="M5 4h3l2 5-2 1.5a11 11 0 005 5L20 13l1 3v3a1 1 0 01-1 1A16 16 0 014 5a1 1 0 011-1z"/>
                </svg>
              </div>
            )}
            <p class="cta-hint">{L.callHint}</p>
          </div>
        </>
      ) : (
        /* ── Zustand A: beglichen → Self-Checkout ── */
        <>
          <div id="flash-ok" class="flash flash--ok" hidden></div>
          <div id="flash-err" class="flash flash--err" hidden></div>

          <div class="steps">
            {/* Step 1: Rechnung — done */}
            <div class="step step--done">
              <div class="step__num">1</div>
              <div class="step__body">
                <div class="step__title-row">
                  <span class="step__title">{L.step1BillTitle}</span>
                  <span class="bill-chip bill-chip--paid">{L.billPaidLabel}</span>
                </div>
                {billItems.length > 0 && (
                  <div class="bill">
                    {billItems.map((item: SimItem) => (
                      <div class="bill__li">
                        <span class="bill__lbl">{item.label}</span>
                        <span>{fmtMoney(item.amount_cents)}</span>
                      </div>
                    ))}
                    <div class="bill__total">
                      <span>{L.billTotal}</span>
                      <span>{fmtMoney(totalCents)}</span>
                    </div>
                    <div class="bill__note">{L.billNote}</div>
                  </div>
                )}
              </div>
              <svg class="step__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" width="16" height="16" aria-hidden="true">
                <path d="M4 12.5 L10 18 L20 6"/>
              </svg>
            </div>

            {/* Step 2: Schlüsselkarte — done */}
            <div class="step step--done">
              <div class="step__num">2</div>
              <div class="step__body">
                <div class="step__title">{L.step2Title}</div>
                <div class="step__sub">{L.step2Sub}</div>
              </div>
              <svg class="step__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" width="16" height="16" aria-hidden="true">
                <path d="M4 12.5 L10 18 L20 6"/>
              </svg>
            </div>

            {/* Step 3: Auschecken bestätigen — active */}
            <div class="step step--highlight">
              <div class="step__num">3</div>
              <div class="step__body">
                <div class="step__title">{L.step3Title}</div>
                <div class="step__sub">{L.step3Sub}</div>
              </div>
            </div>
          </div>

          <div class="cta-area">
            <button class="cta-btn" id="checkout-btn" type="button">
              {L.btnLabel}
              <svg class="btn-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <path d="M4 12.5 L10 18 L20 6"/>
              </svg>
            </button>
            <p class="cta-hint">{L.hintLabel}</p>
          </div>
        </>
      )}

      <div class="made-by">
        powered by <a href="https://retaha.de" target="_blank" rel="noopener">retaha</a>
      </div>
    </div>

    <script is:inline define:vars={{ token, doneTitle: L.doneTitle, doneSub: L.doneSub }}>
      const btn = document.getElementById('checkout-btn');
      const flashOk  = document.getElementById('flash-ok');
      const flashErr = document.getElementById('flash-err');
      if (btn) {
        btn.addEventListener('click', async () => {
          btn.disabled = true;
          if (flashOk)  flashOk.hidden  = true;
          if (flashErr) flashErr.hidden = true;
          try {
            const res  = await fetch('/api/checkout/complete', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ stay_token: token }),
            });
            const data = await res.json().catch(() => ({}));
            if (res.ok && data.ok) {
              if (flashOk) { flashOk.textContent = '✓ ' + doneTitle; flashOk.hidden = false; }
              setTimeout(() => { window.location.href = '/g/' + token; }, 1800);
            } else {
              throw new Error(data.error || 'checkout failed');
            }
          } catch (err) {
            if (flashErr) { flashErr.textContent = 'Fehler: ' + (err.message || 'Bitte nochmal versuchen.'); flashErr.hidden = false; }
            btn.disabled = false;
          }
        });
      }
    </script>
  </body>
</html>
