---
// Wünsche vorab — Bestätigung

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return Astro.redirect(`/g/${token ?? ''}`);

const { stay, guest, hotel, settings } = ctx;
const features = (settings as any)?.features ?? {};
if (features.special_requests === false) return Astro.redirect(`/g/${token}`);

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary: string = (hotel as any).brand_primary ?? '#0A0A0A';
const guestName = guest?.first_name ?? null;

type Labels = { title: string; sub: string; cta: string };
const n = guestName;
const labels: Record<Lang, Labels> = {
  de: { title: n ? `Notiert, ${n}.` : 'Notiert.', sub: 'Wir bereiten alles vor, so gut es geht. Wir freuen uns auf dich!', cta: 'Fertig' },
  en: { title: n ? `Noted, ${n}.` : 'Noted.', sub: "We'll do our best to make it happen. Looking forward to your arrival!", cta: 'Done' },
  fr: { title: n ? `Noté, ${n}.` : 'Noté.', sub: 'Nous ferons de notre mieux. Nous avons hâte de vous accueillir !', cta: 'Terminer' },
  es: { title: n ? `Anotado, ${n}.` : 'Anotado.', sub: 'Haremos todo lo posible. ¡Esperamos su llegada!', cta: 'Listo' },
  it: { title: n ? `Annotato, ${n}.` : 'Annotato.', sub: "Faremo del nostro meglio. Non vediamo l'ora di accogliervi!", cta: 'Fatto' },
  pt: { title: n ? `Anotado, ${n}.` : 'Anotado.', sub: 'Faremos o nosso melhor. Esperamos a vossa chegada!', cta: 'Pronto' },
  nl: { title: n ? `Genoteerd, ${n}.` : 'Genoteerd.', sub: 'We doen ons best. We kijken uit naar uw komst!', cta: 'Klaar' },
  ru: { title: n ? `Отмечено, ${n}.` : 'Отмечено.', sub: 'Мы постараемся всё устроить. С нетерпением ждём вас!', cta: 'Готово' },
  ar: { title: n ? `تم التسجيل، ${n}.` : 'تم التسجيل.', sub: 'سنبذل قصارى جهدنا. نتطلع إلى استقبالكم!', cta: 'تم' },
  zh: { title: n ? `已记录，${n}。` : '已记录。', sub: '我们会尽力安排。期待您的到来！', cta: '完成' },
};
const L = labels[lang];
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPrimary};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>{L.title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #F8F7F4; min-height: 100dvh; display: flex; flex-direction: column; }

    .done-header {
      display: flex; justify-content: flex-end;
      padding: calc(env(safe-area-inset-top, 0px) + 16px) 20px 0;
    }
    .done-close {
      width: 38px; height: 38px; border-radius: 50%;
      background: #EDEBE7; border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #3A3A36; cursor: pointer; text-decoration: none;
    }

    .done-body {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 40px 32px; text-align: center;
    }

    .check-wrap { position: relative; width: 96px; height: 96px; margin-bottom: 36px; }
    .check-glow {
      position: absolute; inset: -20px; border-radius: 50%;
      background: radial-gradient(circle,
        color-mix(in srgb, var(--accent, #7B83D0) 22%, transparent) 0%,
        color-mix(in srgb, var(--accent, #7B83D0) 6%, transparent) 60%,
        transparent 80%);
      animation: pulse-glow 2.4s ease-in-out infinite;
    }
    @keyframes pulse-glow {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.7; }
    }
    .check-circle {
      position: relative; width: 96px; height: 96px; border-radius: 50%;
      background: var(--accent, #7B83D0);
      display: flex; align-items: center; justify-content: center;
    }

    .done-title { font-size: 26px; font-weight: 700; color: #0F0F0D; line-height: 1.2; margin-bottom: 12px; }
    .done-sub { font-size: 15px; color: #6B6B63; line-height: 1.6; max-width: 280px; }

    .done-footer { padding: 24px 20px calc(env(safe-area-inset-bottom, 0px) + 24px); }
    .btn-done {
      width: 100%; border: 0; padding: 16px;
      border-radius: 14px; font-size: 16px; font-weight: 600;
      background: #0F0F0D; color: #fff;
      cursor: pointer; font-family: inherit;
    }
  </style>
</head>
<body>
  <header class="done-header">
    <a class="done-close" href={`/g/${token}`} data-astro-reload aria-label="Schließen">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </a>
  </header>

  <div class="done-body">
    <div class="check-wrap">
      <div class="check-glow"></div>
      <div class="check-circle">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
          <polyline points="9 20 17 28 31 12" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <h1 class="done-title">{L.title}</h1>
    <p class="done-sub">{L.sub}</p>
  </div>

  <footer class="done-footer">
    <a class="btn-done" href={`/g/${token}`} data-astro-reload style="text-decoration:none;display:block;text-align:center">{L.cta}</a>
  </footer>
</body>
</html>
