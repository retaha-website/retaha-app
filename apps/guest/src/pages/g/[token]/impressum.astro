---
// Sprint Legal/DSGVO Phase 5 — Impressum Gast-App
//
// VORLAGE — anwaltlich prüfen vor Production-Pilot.
// Inhalt identisch zu /admin/impressum (§ 5 TMG verlangt das Impressum
// überall wo retaha-Dienste angeboten werden).

import { loadStayByToken } from '@retaha/db';

const { token } = Astro.params;
if (!token) return new Response('Token fehlt', { status: 400 });
const ctx = await loadStayByToken(token);
if (!ctx) return new Response('Aufenthalt nicht gefunden', { status: 404 });
const backHref = `/g/${token}`;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Impressum · retaha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      @import '@retaha/ui/styles/global.css';
      @import '@retaha/ui/styles/components/legal.css';
    </style>
  </head>
  <body class="font-sans antialiased text-anthrazit bg-white min-h-screen">
    <main class="legal-page">
      <a href={backHref} class="legal-page-back">← zurück zu Ihrem Aufenthalt</a>

      <p class="legal-page-eyebrow themed-eyebrow-flank">Impressum</p>
      <h1 class="legal-page-headline">
        Angaben gemäß<br />
        <span class="legal-page-headline-bold">§ 5 TMG<span class="legal-page-headline-punkt">.</span></span>
      </h1>

      <div class="legal-page-content">
        <h2>Anbieter</h2>
        <p>
          <strong>retaha GmbH</strong><br />
          Weinsteige 31<br />
          74676 Niedernhall<br />
          Deutschland
        </p>

        <h2>Vertretungsberechtigter Geschäftsführer</h2>
        <p>Taha Mustafa Ünal</p>

        <h2>Kontakt</h2>
        <p>
          Tel: +49 7131 3824635<br />
          E-Mail: <a href="mailto:hallo@retaha.de">hallo@retaha.de</a>
        </p>

        <h2>Registereintrag</h2>
        <p>
          Eintragung im Handelsregister<br />
          Registergericht: Amtsgericht Stuttgart<br />
          Registernummer: HRB 786739
        </p>

        <h2>Umsatzsteuer-ID</h2>
        <p>gemäß § 27a UStG: <strong>DE356391706</strong></p>

        <h2>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
        <p>
          Taha Mustafa Ünal<br />
          Anschrift wie oben
        </p>

        <h2>Online-Streitbeilegung (OS)</h2>
        <p>
          Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
          <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener">https://ec.europa.eu/consumers/odr</a>
        </p>
        <p>
          Die retaha GmbH ist nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
          Verbraucherschlichtungsstelle teilzunehmen.
        </p>

        <p style="margin-top: 40px; font-size: 13px;">
          <a href={`/g/${token}/datenschutz`}>→ Datenschutzerklärung</a>
        </p>
      </div>
    </main>
  </body>
</html>
