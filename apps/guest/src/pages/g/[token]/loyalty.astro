---
// Loyalty-Gast-Screen — verdrahtet an echte Daten (loyalty_points + loyalty_transactions
// + computed Tier/Benefits/Progress aus loyalty_config). Showcase-Tokens: Punkte werden
// am Display simuliert (kein echter guests-Row). Gate: features.loyalty === true.
import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { getStaySession, setStaySessionCookie, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { isShowcaseToken, findShowcaseSessionByToken, resolveDemoCheckDates } from '../../../lib/showcase/session';
import { computeTierProgress, nightsBetween, pointsForNights, DEFAULT_LOYALTY_CONFIG, type LoyaltyTier, type LoyaltyReward } from '@retaha/loyalty';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';

const { token } = Astro.params;
if (!token) return new Response('Token fehlt', { status: 400 });

const sbSr = createSupabaseServiceRoleInstance();

// ── Context: echter Stay oder Showcase ──────────────────────────────────────
let hotel: any = null;
let guest: any = null;
let hotelId: string | null = null;
let guestId: string | null = null;
let settings: any = { features: {} };
let isShowcase = false;
let demoData: any = null;

if (isShowcaseToken(token)) {
  const sc = await findShowcaseSessionByToken(token);
  if (!sc) return new Response('Aufenthalt nicht gefunden', { status: 404 });
  const [{ data: h }, { data: hs }] = await Promise.all([
    sbSr.from('hotels').select('id, name, default_language').eq('id', sc.hotel_id).maybeSingle(),
    sbSr.from('hotel_settings').select('features').eq('hotel_id', sc.hotel_id).maybeSingle(),
  ]);
  if (!h) return new Response('Aufenthalt nicht gefunden', { status: 404 });
  isShowcase = true;
  demoData = (sc.demo_data ?? {}) as any;
  hotel = h;
  guest = { first_name: demoData.guest_first_name ?? 'Anna', language: h.default_language };
  hotelId = h.id;
  settings = { features: hs?.features ?? {} };
  // Stay-Session (showcase) sicherstellen, damit Redeem auch bei Direkt-Aufruf greift
  const { checkOut } = resolveDemoCheckDates(demoData?.preset);
  await setStaySessionCookie(Astro.cookies, {
    stay_id: sc.id, hotel_id: h.id, check_out_utc: checkOut.toISOString(), is_showcase: true,
  });
} else {
  const ctx = await loadStayByToken(token);
  if (!ctx) return new Response('Aufenthalt nicht gefunden', { status: 404 });
  hotel = ctx.hotel; guest = ctx.guest; settings = ctx.settings;
  hotelId = ctx.hotel.id; guestId = ctx.guest?.id ?? null;
  const existing = await getStaySession(Astro.cookies);
  if (!existing || existing.stay_id !== ctx.stay.id) {
    await setStaySessionCookie(Astro.cookies, {
      stay_id: ctx.stay.id, hotel_id: ctx.hotel.id, check_out_utc: ctx.stay.check_out, is_showcase: false,
    });
  }
}

// Feature-Gate (loyalty ist opt-in → nur bei explizit true)
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.loyalty !== true) return Astro.redirect(`/g/${token}`);

const langRaw = normalizeLang(guest?.language || hotel.default_language);
type LK = 'de' | 'en' | 'fr' | 'es';
const lk: LK = (['de', 'en', 'fr', 'es'].includes(langRaw) ? langRaw : 'de') as LK;
const lang: Lang = langRaw;

// ── Config ──────────────────────────────────────────────────────────────────
const { data: cfgRow } = await sbSr.from('loyalty_config')
  .select('points_per_night, tiers, rewards').eq('hotel_id', hotelId).maybeSingle();
const tiers = (cfgRow?.tiers ?? DEFAULT_LOYALTY_CONFIG.tiers) as LoyaltyTier[];
const pointsPerNight = (cfgRow?.points_per_night ?? DEFAULT_LOYALTY_CONFIG.points_per_night) as number;
const activeRewards = ((cfgRow?.rewards ?? DEFAULT_LOYALTY_CONFIG.rewards) as LoyaltyReward[])
  .filter(r => r.active !== false && r.title)
  .sort((a, b) => (a.cost_points || 0) - (b.cost_points || 0));

// ── Saldo + History: echt oder Demo-Simulation ──────────────────────────────
const locale = ({ de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES' } as Record<string, string>)[lk] ?? 'de-DE';
const fmtDate = (iso: string) => { try { return new Date(iso).toLocaleDateString(locale, { day: '2-digit', month: 'short', year: 'numeric' }); } catch { return ''; } };
const nightWord = (n: number) => lk === 'de' ? (n === 1 ? 'Nacht' : 'Nächte') : (n === 1 ? 'night' : 'nights');

let balance = 0;
let lifetime = 0;
let history: Array<{ label: string; pts: number; date: string }> = [];

if (isShowcase) {
  // Demo: glaubwürdiger Stammgast — mittlere Stufe + Fortschritt, fabrizierte Historie.
  // Demo-Daten immer aus dem Preset ableiten (gespeicherte Absolut-Daten driften).
  const { checkIn, checkOut } = resolveDemoCheckDates(demoData?.preset);
  const nights = nightsBetween(checkIn, checkOut);
  const stayPts = pointsForNights(nights, pointsPerNight);
  const sorted = [...tiers].sort((a, b) => a.threshold_points - b.threshold_points);
  const midIdx = Math.min(1, sorted.length - 1);
  const base = sorted[midIdx]?.threshold_points ?? 0;
  const next = sorted[midIdx + 1]?.threshold_points;
  lifetime = next != null ? base + Math.round((next - base) * 0.55) : base + Math.max(stayPts, 80);
  balance = lifetime;
  const today = new Date();
  const rest = Math.max(0, lifetime - stayPts);
  history = [
    { label: `${lk === 'de' ? 'Aktueller Aufenthalt' : 'Current stay'} · ${nights} ${nightWord(nights)}`, pts: stayPts, date: fmtDate(today.toISOString()) },
    { label: lk === 'de' ? 'Aufenthalt' : 'Stay', pts: Math.round(rest * 0.6), date: fmtDate(new Date(today.getTime() - 40 * 86400000).toISOString()) },
    { label: lk === 'de' ? 'Aufenthalt' : 'Stay', pts: rest - Math.round(rest * 0.6), date: fmtDate(new Date(today.getTime() - 120 * 86400000).toISOString()) },
  ].filter(h => h.pts > 0);
} else if (guestId) {
  const [{ data: lp }, { data: txs }] = await Promise.all([
    sbSr.from('loyalty_points').select('points_balance, points_lifetime').eq('hotel_id', hotelId).eq('guest_id', guestId).maybeSingle(),
    sbSr.from('loyalty_transactions').select('type, points, nights, note, created_at').eq('hotel_id', hotelId).eq('guest_id', guestId).order('created_at', { ascending: false }).limit(20),
  ]);
  balance = lp?.points_balance ?? 0;
  lifetime = lp?.points_lifetime ?? 0;
  history = ((txs ?? []) as any[]).map(t => ({
    label: t.type === 'earn'
      ? (t.nights ? `${lk === 'de' ? 'Aufenthalt' : 'Stay'} · ${t.nights} ${nightWord(t.nights)}` : (lk === 'de' ? 'Aufenthalt' : 'Stay'))
      : (t.note || (t.type === 'redeem' ? (lk === 'de' ? 'Prämie eingelöst' : 'Reward redeemed') : (lk === 'de' ? 'Anpassung' : 'Adjustment'))),
    pts: t.points,
    date: fmtDate(t.created_at),
  }));
}

// ── Aktive Gutscheine (nur echter Gast; Demo-Voucher entstehen client-seitig) ──
let vouchers: Array<{ voucher_code: string; reward_title: string; status: string; expires_at: string | null }> = [];
if (!isShowcase && guestId) {
  const { data: reds } = await sbSr.from('loyalty_redemptions')
    .select('voucher_code, reward_title, status, expires_at, created_at')
    .eq('hotel_id', hotelId).eq('guest_id', guestId)
    .in('status', ['issued', 'validated'])
    .order('created_at', { ascending: false }).limit(10);
  vouchers = ((reds ?? []) as any[]).map(v => {
    const expired = !!v.expires_at && new Date(v.expires_at).getTime() < Date.now();
    return {
      voucher_code: v.voucher_code,
      reward_title: v.reward_title,
      status: expired && v.status === 'issued' ? 'expired' : v.status,
      expires_at: v.expires_at,
    };
  });
}

// ── Tier + Progress (computed aus Config) ───────────────────────────────────
const progress = computeTierProgress(lifetime, tiers);
const tierName = progress.tier.name;
const nextTierName = progress.nextTier?.name ?? '';
const progressPct = progress.progressPct;
const pointsToNext = progress.pointsToNext;
const benefitsList = (progress.tier.benefits ?? []).map(b => b.title).filter(Boolean);
const hasActivity = lifetime > 0;
const backHref = `/g/${token}`;

const L = {
  de: { status: 'Dein Status', points: 'Punkte', benefits: 'Deine Vorteile', history: 'Punkte-Verlauf', empty: 'Noch keine Punkte', emptySub: 'Du sammelst Punkte automatisch bei jedem Aufenthalt.', back: '← zurück', rewards: 'Prämien einlösen', redeem: 'Einlösen', vouchers: 'Deine Gutscheine', validAt: 'Gültig bis', validReception: 'Diesen Code an der Rezeption vorzeigen.', stIssued: 'Offen', stValidated: 'Eingelöst', stExpired: 'Abgelaufen', okMsg: 'Prämie eingelöst', errInsufficient: 'Nicht genug Punkte', errGeneric: 'Etwas ist schiefgelaufen' },
  en: { status: 'Your Status', points: 'Points', benefits: 'Your Benefits', history: 'Points History', empty: 'No points yet', emptySub: 'You earn points automatically with every stay.', back: '← back', rewards: 'Redeem Rewards', redeem: 'Redeem', vouchers: 'Your Vouchers', validAt: 'Valid until', validReception: 'Show this code at the reception.', stIssued: 'Open', stValidated: 'Redeemed', stExpired: 'Expired', okMsg: 'Reward redeemed', errInsufficient: 'Not enough points', errGeneric: 'Something went wrong' },
  fr: { status: 'Votre Statut', points: 'Points', benefits: 'Vos Avantages', history: 'Historique', empty: 'Pas encore de points', emptySub: 'Vous gagnez des points à chaque séjour.', back: '← retour', rewards: 'Utiliser les récompenses', redeem: 'Utiliser', vouchers: 'Vos bons', validAt: 'Valable jusqu\'au', validReception: 'Présentez ce code à la réception.', stIssued: 'Ouvert', stValidated: 'Utilisé', stExpired: 'Expiré', okMsg: 'Récompense utilisée', errInsufficient: 'Points insuffisants', errGeneric: 'Une erreur est survenue' },
  es: { status: 'Tu Estado', points: 'Puntos', benefits: 'Tus Ventajas', history: 'Historial', empty: 'Aún sin puntos', emptySub: 'Ganas puntos con cada estancia.', back: '← volver', rewards: 'Canjear recompensas', redeem: 'Canjear', vouchers: 'Tus vales', validAt: 'Válido hasta', validReception: 'Muestra este código en recepción.', stIssued: 'Abierto', stValidated: 'Canjeado', stExpired: 'Caducado', okMsg: 'Recompensa canjeada', errInsufficient: 'Puntos insuficientes', errGeneric: 'Algo salió mal' },
}[lk];

const statusLabel = (st: string) => st === 'validated' ? L.stValidated : st === 'expired' ? L.stExpired : L.stIssued;

const progressLabel = !nextTierName ? '' :
  lk === 'de' ? `Noch ${pointsToNext} Punkte bis ${nextTierName}` :
  lk === 'en' ? `${pointsToNext} more points until ${nextTierName}` :
  lk === 'fr' ? `Encore ${pointsToNext} points jusqu'à ${nextTierName}` :
  `${pointsToNext} puntos más hasta ${nextTierName}`;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0A" />
    <title>{hotel.name} · {tierName}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0; padding: 0;
        background: #FAFAF8; color: #0A0A0A;
        font-family: 'Space Grotesk', system-ui, sans-serif; min-height: 100vh;
      }
      .page { max-width: 520px; margin: 0 auto; padding-bottom: 60px; }

      .back-link {
        display: inline-block; padding: 16px 20px 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
        color: #888; text-decoration: none;
      }
      .back-link:hover { color: #0A0A0A; }

      .hero {
        background: #0A0A0A; color: #FAFAF8;
        padding: 32px 20px 28px; margin-bottom: 24px;
      }
      .hero__eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
        opacity: 0.45; margin-bottom: 12px; display: block;
      }
      .hero__tier {
        font-size: clamp(36px, 9vw, 60px); font-weight: 400; letter-spacing: -0.03em;
        line-height: 1; margin: 0 0 8px;
      }
      .hero__tier .dot { color: var(--guest-accent, #FF4A82); }
      .hero__pts {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px; opacity: 0.6; letter-spacing: 0.08em;
      }

      .progress { padding: 0 20px 24px; }
      .progress__bar-wrap {
        height: 6px; background: #E0DDD8; border-radius: 3px; overflow: hidden; margin-bottom: 8px;
      }
      .progress__bar { height: 100%; background: var(--guest-accent, #FF4A82); border-radius: 3px; transition: width 0.5s ease; }
      .progress__label {
        font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #888; letter-spacing: 0.04em;
      }

      .section { padding: 0 20px 24px; }
      .section__head {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
        color: #888; padding-bottom: 10px; margin-bottom: 12px;
        border-bottom: 1px solid #E0DDD8;
      }

      .benefits { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
      .benefit {
        display: flex; align-items: center; gap: 10px;
        font-size: 14px; color: #0A0A0A;
      }
      .benefit svg { color: #5C9070; flex-shrink: 0; }

      .history { display: flex; flex-direction: column; }
      .history__item {
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 0; border-bottom: 1px solid #F0EDE8;
        font-size: 13px; color: #0A0A0A;
      }
      .history__item:last-child { border-bottom: none; }
      .history__item-date {
        font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #AAA;
        margin-top: 2px; display: block;
      }
      .history__pts {
        font-family: 'JetBrains Mono', monospace; font-size: 13px;
        font-weight: 500; color: var(--guest-accent, #FF4A82);
      }
      .history__pts--neg { color: #888; }

      .empty {
        background: #F5F5F3; border: 1px solid #E0DDD8; border-radius: 10px;
        padding: 24px; text-align: center; margin: 0 20px;
      }
      .empty__title { font-size: 16px; font-weight: 400; margin: 0 0 6px; }
      .empty__sub { font-size: 13px; color: #888; margin: 0; line-height: 1.4; }

      /* Rewards */
      .rewards { display: flex; flex-direction: column; gap: 10px; }
      .reward {
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        padding: 14px; background: #fff; border: 1px solid #E0DDD8; border-radius: 10px;
      }
      .reward__info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
      .reward__title { font-size: 14px; font-weight: 500; }
      .reward__desc { font-size: 12px; color: #888; line-height: 1.35; }
      .reward__btn {
        flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 1px;
        padding: 8px 14px; border: none; border-radius: 8px; cursor: pointer;
        background: #0A0A0A; color: #FAFAF8; font-family: inherit; min-width: 84px;
      }
      .reward__cost { font-family: 'JetBrains Mono', monospace; font-size: 11px; opacity: 0.7; }
      .reward__cta { font-size: 13px; font-weight: 500; }
      .reward__btn:disabled { background: #EDEAE5; color: #B5B0A8; cursor: not-allowed; }

      /* Vouchers */
      .vouchers { display: flex; flex-direction: column; gap: 10px; }
      .voucher { border: 1px dashed #0A0A0A; border-radius: 10px; padding: 14px; background: #FFFDF5; }
      .voucher--validated, .voucher--expired {
        opacity: 0.55; border-style: solid; border-color: #E0DDD8; background: #F5F5F3;
      }
      .voucher__top { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 8px; }
      .voucher__reward { font-size: 13px; font-weight: 500; }
      .voucher__status {
        flex-shrink: 0; font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em;
        text-transform: uppercase; padding: 3px 7px; border-radius: 999px; background: #0A0A0A; color: #FAFAF8;
      }
      .voucher--validated .voucher__status, .voucher--expired .voucher__status { background: #C9C4BC; color: #fff; }
      .voucher__code {
        font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 500; letter-spacing: 0.12em;
        text-align: center; padding: 6px 0;
      }
      .voucher__meta { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #888; text-align: center; }
      .vouchers__hint { font-size: 11px; color: #AAA; text-align: center; margin: 10px 0 0; }

      /* Redeem-Toast */
      .redeem-toast {
        position: fixed; left: 50%; bottom: 24px; transform: translate(-50%, 20px);
        padding: 12px 18px; border-radius: 10px; font-size: 13px; font-weight: 500;
        opacity: 0; pointer-events: none; transition: opacity .25s ease, transform .25s ease;
        z-index: 50; max-width: calc(100% - 40px); text-align: center;
      }
      .redeem-toast.is-show { opacity: 1; transform: translate(-50%, 0); }
      .redeem-toast--ok { background: var(--guest-accent, #FF4A82); color: #0A0A0A; }
      .redeem-toast--err { background: #0A0A0A; color: #FAFAF8; }
      @media (prefers-reduced-motion: reduce) { .redeem-toast { transition: none; } }

      .made-by {
        margin-top: 48px; padding-top: 20px;
        border-top: 1px solid #E0DDD8;
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        color: #BBB; text-align: center; letter-spacing: 0.06em;
      }
      .made-by a { color: #888; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="page">
      <a href={backHref} class="back-link">{L.back}</a>

      <div class="hero">
        <span class="hero__eyebrow">{L.status}</span>
        <h1 class="hero__tier">{tierName}<span class="dot">.</span></h1>
        <p class="hero__pts"><span id="hero-balance">{balance}</span> {L.points}</p>
      </div>

      {!hasActivity ? (
        <div class="empty">
          <h2 class="empty__title">{L.empty}</h2>
          <p class="empty__sub">{L.emptySub}</p>
        </div>
      ) : (
        <>
          {nextTierName && (
            <div class="progress">
              <div class="progress__bar-wrap">
                <div class="progress__bar" style={`width:${progressPct}%`}></div>
              </div>
              <p class="progress__label">{progressLabel}</p>
            </div>
          )}

          {benefitsList.length > 0 && (
            <div class="section">
              <div class="section__head">{L.benefits}</div>
              <ul class="benefits">
                {benefitsList.map((b: string) => (
                  <li class="benefit">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14" aria-hidden="true">
                      <path d="M5 12 L10 17 L19 7"/>
                    </svg>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {activeRewards.length > 0 && (
            <div class="section" id="rewards-section" data-balance={balance} data-demo={isShowcase ? '1' : '0'}>
              <div class="section__head">{L.rewards}</div>
              <div class="rewards">
                {activeRewards.map((r) => (
                  <div class="reward" data-reward-id={r.id} data-cost={r.cost_points}>
                    <div class="reward__info">
                      <span class="reward__title">{r.title}</span>
                      {r.desc && <span class="reward__desc">{r.desc}</span>}
                    </div>
                    <button class="reward__btn" type="button" data-redeem disabled={balance < (r.cost_points || 0)}>
                      <span class="reward__cost">{r.cost_points} P</span>
                      <span class="reward__cta">{L.redeem}</span>
                    </button>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="section" id="vouchers-section" style={vouchers.length ? '' : 'display:none'}>
            <div class="section__head">{L.vouchers}</div>
            <div class="vouchers" id="vouchers-list">
              {vouchers.map((v) => (
                <div class:list={['voucher', `voucher--${v.status}`]}>
                  <div class="voucher__top">
                    <span class="voucher__reward">{v.reward_title}</span>
                    <span class="voucher__status">{statusLabel(v.status)}</span>
                  </div>
                  <div class="voucher__code">{v.voucher_code}</div>
                  <div class="voucher__meta">{v.status === 'issued' && v.expires_at ? `${L.validAt} ${fmtDate(v.expires_at)}` : ''}</div>
                </div>
              ))}
            </div>
            <p class="vouchers__hint">{L.validReception}</p>
          </div>

          {history.length > 0 && (
            <div class="section">
              <div class="section__head">{L.history}</div>
              <div class="history">
                {history.slice(0, 10).map((h) => (
                  <div class="history__item">
                    <div>
                      <span>{h.label}</span>
                      {h.date && <span class="history__item-date">{h.date}</span>}
                    </div>
                    <span class:list={['history__pts', { 'history__pts--neg': h.pts < 0 }]}>
                      {h.pts > 0 ? `+${h.pts}` : h.pts}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </>
      )}

      <div class="made-by" style="padding: 20px 20px 0">
        powered by <a href="https://retaha.de" target="_blank" rel="noopener">retaha</a>
      </div>
    </div>

    <script is:inline define:vars={{ labels: { okMsg: L.okMsg, errInsufficient: L.errInsufficient, errGeneric: L.errGeneric, validAt: L.validAt, stIssued: L.stIssued }, jsLocale: locale }}>
      (() => {
        const section = document.getElementById('rewards-section');
        if (!section) return;
        let balance = Number(section.dataset.balance || 0);
        const vouchersSection = document.getElementById('vouchers-section');
        const vouchersList = document.getElementById('vouchers-list');
        const heroBalance = document.getElementById('hero-balance');

        const fmtDate = (iso) => { try { return new Date(iso).toLocaleDateString(jsLocale, { day: '2-digit', month: 'short', year: 'numeric' }); } catch { return ''; } };

        function refresh() {
          if (heroBalance) heroBalance.textContent = String(balance);
          document.querySelectorAll('.reward').forEach((card) => {
            const cost = Number(card.dataset.cost || 0);
            const btn = card.querySelector('[data-redeem]');
            if (btn && btn.dataset.busy !== '1') btn.disabled = balance < cost;
          });
        }

        let toastEl = null, toastTimer = null;
        function toast(msg, type) {
          if (!toastEl) { toastEl = document.createElement('div'); document.body.appendChild(toastEl); }
          toastEl.textContent = msg;
          toastEl.className = 'redeem-toast redeem-toast--' + (type || 'ok') + ' is-show';
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => toastEl && toastEl.classList.remove('is-show'), 3200);
        }

        function addVoucher(d) {
          if (!vouchersList) return;
          const el = document.createElement('div');
          el.className = 'voucher voucher--issued';
          el.innerHTML = '<div class="voucher__top"><span class="voucher__reward"></span><span class="voucher__status"></span></div>'
            + '<div class="voucher__code"></div><div class="voucher__meta"></div>';
          el.querySelector('.voucher__reward').textContent = d.reward_title || '';
          el.querySelector('.voucher__status').textContent = labels.stIssued;
          el.querySelector('.voucher__code').textContent = d.voucher_code || '';
          el.querySelector('.voucher__meta').textContent = d.expires_at ? (labels.validAt + ' ' + fmtDate(d.expires_at)) : '';
          vouchersList.prepend(el);
          if (vouchersSection) vouchersSection.style.display = '';
        }

        section.addEventListener('click', async (e) => {
          const btn = e.target.closest('[data-redeem]');
          if (!btn || btn.disabled || btn.dataset.busy === '1') return;
          const card = btn.closest('.reward');
          const rewardId = card && card.dataset.rewardId;
          const cost = Number((card && card.dataset.cost) || 0);
          if (!rewardId) return;
          const cta = btn.querySelector('.reward__cta');
          const prev = cta ? cta.textContent : '';
          btn.dataset.busy = '1'; btn.disabled = true;
          if (cta) cta.textContent = '…';
          const done = () => { btn.dataset.busy = ''; if (cta) cta.textContent = prev; refresh(); };
          try {
            const res = await fetch('/api/loyalty/redeem', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reward_id: rewardId }),
            });
            const data = await res.json();
            if (!data || !data.ok) {
              toast((data && data.error === 'insufficient_points') ? labels.errInsufficient : labels.errGeneric, 'err');
              done(); return;
            }
            addVoucher(data);
            balance = (typeof data.balance === 'number') ? data.balance : Math.max(0, balance - cost);
            toast(labels.okMsg, 'ok');
            done();
          } catch (_) {
            toast(labels.errGeneric, 'err');
            done();
          }
        });

        refresh();
      })();
    </script>
  </body>
</html>
