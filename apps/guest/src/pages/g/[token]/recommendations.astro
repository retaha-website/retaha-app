---
import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { isShowcaseToken, findShowcaseSessionByToken } from '../../../lib/showcase/session';
import { buildPhotoUrl, type PickCategory } from '../../../lib/places/google-client';
import { haversineMeters, walkingMinutes } from '../../../lib/places/distance';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@retaha/ui-guest/base';

const { token } = Astro.params;
if (!token) return new Response('Token fehlt', { status: 400 });

const url = new URL(Astro.request.url);
const persona  = url.searchParams.get('persona') ?? 'in_house';
const langParam = url.searchParams.get('lang');

// ── Auth ──────────────────────────────────────────────────────────────────────
let ctx: any = null;
if (isShowcaseToken(token)) {
  const showcase = await findShowcaseSessionByToken(token);
  if (showcase) {
    const sbSr = createSupabaseServiceRoleInstance();
    const [{ data: hotelRow }, { data: settingsRow }] = await Promise.all([
      sbSr.from('hotels').select('id, name, default_language, enabled_languages, brand_primary').eq('id', showcase.hotel_id).single(),
      sbSr.from('hotel_settings').select('features').eq('hotel_id', showcase.hotel_id).single(),
    ]);
    if (hotelRow) ctx = { hotel: hotelRow, guest: { language: hotelRow.default_language ?? 'de' }, settings: settingsRow ?? {} };
  }
} else {
  const loaded = token ? await loadStayByToken(token) : null;
  if (loaded) {
    const existing = await getStaySession(Astro.cookies);
    if (!existing || existing.stay_id !== loaded.stay.id) {
      await setStaySessionCookie(Astro.cookies, { stay_id: loaded.stay.id, hotel_id: loaded.hotel.id, check_out_utc: loaded.stay.check_out, is_showcase: false });
    }
    ctx = loaded;
  }
}
if (!ctx) return Astro.redirect(`/g/${token}`);

const { hotel, settings } = ctx;
const features = (settings as any).features ?? {};
if (features.recommendations === false) return Astro.redirect(`/g/${token}?persona=${persona}`);

const lk = normalizeLang(langParam ?? (ctx.guest as any)?.language ?? (hotel as any).default_language ?? 'de') as Lang;

// ── Brand ────────────────────────────────────────────────────────────────────
const brandPrimary: string | null = (hotel as any).brand_primary ?? null;
const brandStyle = brandPrimary
  ? (() => { const p = computeBrandPalette(brandPrimary); return `--accent:${brandPrimary};--accent-soft:${p.soft};--accent-on:${p.onAccent}`; })()
  : undefined;

// ── Data ─────────────────────────────────────────────────────────────────────
const sbSr = createSupabaseServiceRoleInstance();
const [{ data: hotelGeo }, { data: picksRows }, { data: nearbyRows }] = await Promise.all([
  sbSr.from('hotels').select('latitude, longitude').eq('id', hotel.id).maybeSingle(),
  sbSr.from('hotel_place_picks')
    .select('id, place_id, category, hotel_note, hotel_note_en, hotel_note_fr, hotel_note_es, hotel_note_i18n, cached_data, photo_references, sort_order')
    .eq('hotel_id', hotel.id).eq('is_published', true)
    .order('sort_order', { ascending: true }).order('created_at', { ascending: false }),
  sbSr.from('hotel_place_nearby_cache').select('category, cached_places').eq('hotel_id', hotel.id),
]);

const hotelLat = (hotelGeo?.latitude as number | null) ?? null;
const hotelLng = (hotelGeo?.longitude as number | null) ?? null;
const picks    = (picksRows  ?? []) as any[];
const nearby   = (nearbyRows ?? []) as any[];

function noteForLang(p: any): string | undefined {
  const i18n = p.hotel_note_i18n;
  if (i18n?.[lk]?.value)  return i18n[lk].value.trim() || undefined;
  if (i18n?.de?.value)    return i18n.de.value.trim()   || undefined;
  const f = lk === 'de' ? p.hotel_note
    : lk === 'en' ? (p.hotel_note_en ?? p.hotel_note)
    : lk === 'fr' ? (p.hotel_note_fr ?? p.hotel_note)
    : lk === 'es' ? (p.hotel_note_es ?? p.hotel_note)
    : p.hotel_note;
  return f?.trim() || undefined;
}

// Logical tabs (user-facing) → DB category mapping
// 'explore' merges sight + activity since they are sparsely populated separately
type TabKey = 'restaurant' | 'cafe' | 'bar' | 'explore';
const LOGICAL_TABS: TabKey[] = ['restaurant', 'cafe', 'bar', 'explore'];
const TAB_DB_CATS: Record<TabKey, PickCategory[]> = {
  restaurant: ['restaurant'],
  cafe:       ['cafe'],
  bar:        ['bar'],
  explore:    ['sight', 'activity'],
};

interface CatData {
  picks: { id: string; place_id: string; name: string; rating?: number; userRatingCount?: number;
           priceLevel?: string; address?: string; photoUrl?: string; hotelNote?: string; walkingMin?: number }[];
  auto:  { place_id: string; name: string; rating?: number; userRatingCount?: number;
           address?: string; photoUrl?: string; walkingMin?: number; openNow?: boolean | null }[];
}

const PRICE: Record<string, string> = {
  PRICE_LEVEL_FREE: '', PRICE_LEVEL_INEXPENSIVE: '€', PRICE_LEVEL_MODERATE: '€€',
  PRICE_LEVEL_EXPENSIVE: '€€€', PRICE_LEVEL_VERY_EXPENSIVE: '€€€€',
};

const dataByCategory: Record<string, CatData> = {};
for (const tab of LOGICAL_TABS) {
  const dbCats = TAB_DB_CATS[tab];

  const catPicks = dbCats.flatMap(cat =>
    picks.filter(p => p.category === cat).map(p => {
      const cd = p.cached_data ?? {};
      const photo = p.photo_references?.[0] ? buildPhotoUrl(p.photo_references[0], 800) : undefined;
      const loc = cd.location;
      let wm: number | undefined;
      if (hotelLat != null && hotelLng != null && loc?.lat && loc?.lng)
        wm = walkingMinutes(haversineMeters({ lat: hotelLat, lng: hotelLng }, loc));
      return { id: p.id, place_id: p.place_id, name: cd.name ?? '(no name)', rating: cd.rating,
               userRatingCount: cd.user_ratings_total, priceLevel: cd.price_level,
               address: cd.formatted_address, photoUrl: photo, hotelNote: noteForLang(p), walkingMin: wm };
    })
  );

  const pickIds = new Set(catPicks.map((p: any) => p.place_id));
  const autoPlaces = dbCats.flatMap(cat => {
    const cacheRow = nearby.find((n: any) => n.category === cat);
    return ((cacheRow?.cached_places ?? []) as any[])
      .filter(p => !pickIds.has(p.placeId))
      .map(p => {
        const photo = p.photoNames?.[0] ? buildPhotoUrl(p.photoNames[0], 680) : undefined;
        let wm: number | undefined;
        if (hotelLat != null && hotelLng != null && p.location?.lat && p.location?.lng)
          wm = walkingMinutes(haversineMeters({ lat: hotelLat, lng: hotelLng }, p.location));
        return { place_id: p.placeId, name: p.name, rating: p.rating,
                 userRatingCount: p.userRatingCount, address: p.formattedAddress, photoUrl: photo,
                 walkingMin: wm, openNow: (p.openNow as boolean | undefined) ?? null };
      });
  }).sort((a, b) => {
    const r = (b.rating ?? 0) - (a.rating ?? 0);
    return r !== 0 ? r : (b.userRatingCount ?? 0) - (a.userRatingCount ?? 0);
  });

  dataByCategory[tab] = { picks: catPicks, auto: autoPlaces };
}

// Only show tabs that have at least one place
const visibleTabs = LOGICAL_TABS.filter(t =>
  dataByCategory[t].picks.length > 0 || dataByCategory[t].auto.length > 0
);

// Default: restaurant if it has data, else first non-empty tab
const initialTab: TabKey = visibleTabs.includes('restaurant') ? 'restaurant' : (visibleTabs[0] ?? 'restaurant');

// Pre-load pick detail cache
const placeDetailCache: Record<string, any> = {};
for (const p of picks) {
  const cd = p.cached_data ?? {};
  placeDetailCache[p.place_id] = {
    name: cd.name, rating: cd.rating, userRatingCount: cd.user_ratings_total,
    priceSymbol: PRICE[cd.price_level] ?? '', hotelNote: noteForLang(p) ?? null,
    formattedAddress: cd.formatted_address, phone: cd.international_phone_number,
    website: cd.website_uri, googleMapsUri: cd.google_maps_uri,
    openNow: cd.opening_hours?.openNow ?? null,
    weekdayDescriptions: cd.opening_hours?.weekdayDescriptions ?? [],
    reviews: (cd.reviews ?? []).slice(0, 3),
    photoUrls: (p.photo_references ?? []).slice(0, 8).map((n: string) => buildPhotoUrl(n, 1200)),
  };
}

// ── i18n ──────────────────────────────────────────────────────────────────────
const _l = (d: Record<string, string>) => d[lk] || d.en || '';
const labels = {
  pageTitle:   `${hotel.name} · ${_l({ de: 'Empfehlungen', en: 'Recommendations', fr: 'Recommandations', es: 'Recomendaciones', it: 'Consigli', pt: 'Recomendações', nl: 'Aanbevelingen', ru: 'Рекомендации', ar: 'التوصيات', zh: '推荐' })}`,
  eyebrow:     _l({ de: '— Tipps & Empfehlungen —', en: '— Tips & Recommendations —', fr: '— Conseils & Recommandations —', es: '— Consejos y Recomendaciones —', it: '— Consigli e Raccomandazioni —', pt: '— Dicas & Recomendações —', nl: '— Tips & Aanbevelingen —', ru: '— Советы и Рекомендации —', ar: '— نصائح وتوصيات —', zh: '— 推荐与建议 —' }),
  title:       _l({ de: 'Entdeckungen', en: 'Discoveries', fr: 'Découvertes', es: 'Descubrimientos', it: 'Scoperte', pt: 'Descobertas', nl: 'Ontdekkingen', ru: 'Открытия', ar: 'اكتشافات', zh: '探索' }),
  titleAccent: '.',
  subtitle:    `${_l({ de: 'Ganz in der Nähe von', en: 'Right near', fr: 'À deux pas de', es: 'Muy cerca de', it: 'A due passi da', pt: 'Perto de', nl: 'Vlak bij', ru: 'Рядом с', ar: 'بالقرب من', zh: '在附近' })} ${hotel.name}`,
  tabRestaurant: _l({ de: 'Essen', en: 'Food', fr: 'Restauration', es: 'Comida', it: 'Ristoranti', pt: 'Restaurantes', nl: 'Eten', ru: 'Рестораны', ar: 'مطاعم', zh: '美食' }),
  tabCafe:       _l({ de: 'Café', en: 'Café', fr: 'Café', es: 'Café', it: 'Caffè', pt: 'Café', nl: 'Café', ru: 'Кафе', ar: 'مقهى', zh: '咖啡' }),
  tabBar:        _l({ de: 'Bar', en: 'Bar', fr: 'Bar', es: 'Bar', it: 'Bar', pt: 'Bar', nl: 'Bar', ru: 'Бар', ar: 'بار', zh: '酒吧' }),
  tabExplore:    _l({ de: 'Sehenswertes', en: 'Explore', fr: 'Explorer', es: 'Explorar', it: 'Esplorare', pt: 'Explorar', nl: 'Ontdekken', ru: 'Открытия', ar: 'استكشاف', zh: '探索' }),
  sectionPicks:  _l({ de: '— Hotel-Tipps —', en: '— Hotel Tips —', fr: '— Coups de cœur —', es: '— Favoritos del hotel —', it: '— Consigli dell\'hotel —', pt: '— Dicas do hotel —', nl: '— Hoteltips —', ru: '— Советы отеля —', ar: '— نصائح الفندق —', zh: '— 酒店推荐 —' }),
  sectionNearby: _l({ de: '— In der Nähe —', en: '— Nearby —', fr: '— À proximité —', es: '— Cerca —', it: '— Nelle vicinanze —', pt: '— Perto daqui —', nl: '— In de buurt —', ru: '— Поблизости —', ar: '— بالقرب منك —', zh: '— 附近 —' }),
  walkMin:       _l({ de: '{n} Min.', en: '{n} min', fr: '{n} min', es: '{n} min', it: '{n} min', pt: '{n} min', nl: '{n} min', ru: '{n} мин', ar: '{n} دق', zh: '{n} 分钟' }),
  noPicks:       _l({ de: 'Noch keine Hotel-Empfehlungen.', en: 'No hotel picks yet.', fr: 'Pas encore de coups de cœur.', es: 'Aún sin favoritos del hotel.', it: 'Ancora nessun consiglio dell\'hotel.', pt: 'Ainda sem dicas do hotel.', nl: 'Nog geen hoteltips.', ru: 'Пока нет советов от отеля.', ar: 'لا توصيات من الفندق بعد.', zh: '暂无酒店推荐。' }),
  noNearby:      _l({ de: 'Keine weiteren Orte gefunden.', en: 'No other places found.', fr: 'Aucun autre lieu trouvé.', es: 'No se encontraron otros lugares.', it: 'Nessun altro posto trovato.', pt: 'Nenhum outro lugar encontrado.', nl: 'Geen andere plaatsen gevonden.', ru: 'Других мест не найдено.', ar: 'لم يتم العثور على أماكن أخرى.', zh: '未找到其他地方。' }),
  showMore:      _l({ de: 'Weitere anzeigen', en: 'Show more', fr: 'Voir plus', es: 'Ver más', it: 'Mostra altro', pt: 'Ver mais', nl: 'Meer tonen', ru: 'Показать ещё', ar: 'عرض المزيد', zh: '显示更多' }),
  open:          _l({ de: 'Geöffnet', en: 'Open', fr: 'Ouvert', es: 'Abierto', it: 'Aperto', pt: 'Aberto', nl: 'Geopend', ru: 'Открыто', ar: 'مفتوح', zh: '营业中' }),
  closed:        _l({ de: 'Geschlossen', en: 'Closed', fr: 'Fermé', es: 'Cerrado', it: 'Chiuso', pt: 'Fechado', nl: 'Gesloten', ru: 'Закрыто', ar: 'مغلق', zh: '已关闭' }),
};

const TAB_LABELS: Record<TabKey, string> = {
  restaurant: labels.tabRestaurant,
  cafe:       labels.tabCafe,
  bar:        labels.tabBar,
  explore:    labels.tabExplore,
};

const backHref = `/g/${token}?persona=${persona}${langParam ? `&lang=${langParam}` : ''}`;

function walkLabel(min: number | undefined): string {
  if (min == null) return '';
  return labels.walkMin.replace('{n}', String(min));
}
---

<!DOCTYPE html>
<html lang={lk} style={brandStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{labels.pageTitle}</title>
    <script is:inline set:html={`window.__PLACE_DETAILS__ = ${JSON.stringify({ cache: placeDetailCache, lang: lk, initialTab })};`}></script>
    <style>
      [x-cloak] { display: none !important; }
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --accent:        #0A0A0A;
        --accent-soft:   rgba(10,10,10,0.08);
        --ink:           #0F0F0D;
        --ink-muted:     #6B6B63;
        --ink-faint:     #A8A8A0;
        --border:        #E7E4DD;
        --border-strong: #C8C4BB;
        --bg:            #FBFAF7;
        --surface:       #FFFFFF;
        --success:       #3D8C5C;
        --radius:        12px;
        --mono:    'JetBrains Mono', 'Courier New', monospace;
        --display: 'Space Grotesk', system-ui, sans-serif;
      }

      body {
        margin: 0; padding: 0;
        background: var(--bg); color: var(--ink);
        font-family: var(--display);
        min-height: 100dvh;
        -webkit-font-smoothing: antialiased;
        position: relative;
      }

      /* ── Page layout ──────────────────────────────────────────────────── */
      .page {
        max-width: 480px; margin: 0 auto;
        padding: calc(env(safe-area-inset-top, 0px) + 72px) 22px calc(env(safe-area-inset-bottom, 20px) + 48px);
        animation: page-in 280ms cubic-bezier(0.22,1,0.36,1) both;
      }
      @keyframes page-in {
        from { transform: translateY(-12px); opacity: 0; }
        to   { transform: translateY(0);     opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) { .page { animation: none; } }

      /* ── Close button ─────────────────────────────────────────────────── */
      .close-btn {
        position: absolute;
        top: calc(env(safe-area-inset-top, 0px) + 16px);
        right: 20px;
        width: 36px; height: 36px; border-radius: 50%;
        background: #EFEDE8;
        display: grid; place-items: center;
        text-decoration: none; color: var(--ink);
        transition: background 0.14s ease;
        z-index: 10;
      }
      .close-btn:hover  { background: #E0DDD7; }
      .close-btn:active { transform: none !important; }
      .close-btn svg    { width: 16px; height: 16px; }

      /* ── Hero ─────────────────────────────────────────────────────────── */
      .hero {
        padding: 28px 0 24px;
        border-bottom: 2px solid var(--ink);
        margin-bottom: 28px;
      }
      .eyebrow {
        font-family: var(--mono); font-size: 10px;
        letter-spacing: 0.16em; font-weight: 500;
        color: var(--accent); margin: 0 0 14px; display: block;
      }
      .title {
        font-size: clamp(28px, 7vw, 38px); font-weight: 700;
        letter-spacing: -0.025em; line-height: 1.05;
        margin: 0 0 8px; color: var(--ink);
      }
      .title .accent { color: var(--accent); }
      .subtitle { font-size: 14px; color: var(--ink-muted); margin: 0; line-height: 1.45; }

      /* ── Tabs ─────────────────────────────────────────────────────────── */
      .tabs {
        display: flex; gap: 6px; margin-bottom: 24px;
        overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none;
      }
      .tabs::-webkit-scrollbar { display: none; }
      .tab-btn {
        flex-shrink: 0; min-height: 40px; padding: 7px 13px;
        background: white; border: 1px solid #D0CCC5; border-radius: 8px;
        font-family: var(--display); font-size: 13px; font-weight: 500;
        color: var(--ink); cursor: pointer; white-space: nowrap;
        -webkit-tap-highlight-color: transparent;
        transition: background 80ms, color 80ms, border-color 80ms;
      }
      .tab-btn[data-active="true"] { background: #0A0A0A; border-color: #0A0A0A; color: #fff; }
      .tab-btn:hover:not([data-active="true"]) { border-color: #C0BCB5; }

      /* ── Category section title ───────────────────────────────────────── */
      .cat-title {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.16em;
        text-transform: uppercase; color: var(--ink-faint);
        padding-bottom: 8px; border-bottom: 1px solid var(--border); margin-bottom: 12px;
      }
      .cat-section { margin-bottom: 28px; }

      /* ── Pick card (hotel recommendations) ───────────────────────────── */
      .place-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); overflow: hidden;
        margin-bottom: 12px; cursor: pointer;
        transition: border-color 0.12s;
      }
      .place-card:hover { border-color: var(--border-strong); }
      .place-card:active { transform: scale(0.99); }
      .place-card-photo { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: #F0EDE6; }
      .place-card-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .place-card-body { padding: 14px 16px; }
      .place-card-name {
        font-size: 16px; font-weight: 600; margin: 0 0 5px; color: var(--ink);
        letter-spacing: -0.01em;
      }
      .place-card-meta {
        font-size: 13px; color: var(--ink-muted); margin: 0 0 0;
        display: flex; gap: 6px; flex-wrap: wrap; align-items: center;
      }
      .place-card-meta-sep { color: var(--border-strong); }
      .place-note {
        margin: 10px 0 0; padding: 8px 12px;
        background: var(--accent-soft);
        border-left: 2px solid var(--accent);
        font-size: 13px; font-style: italic;
        color: var(--ink-muted); border-radius: 0 4px 4px 0;
        line-height: 1.45;
      }

      /* ── Cinematic nearby cards ───────────────────────────────────────── */
      .nearby-list { display: flex; flex-direction: column; gap: 18px; margin: 0; padding: 0; }
      .nearby-card {
        position: relative; height: 212px; border-radius: 18px; overflow: hidden;
        background-color: #0A0A0A; background-size: cover; background-position: center;
        cursor: pointer; -webkit-tap-highlight-color: transparent;
      }
      /* Dimming overlay: ~32% top → ~88% bottom — name legible on any photo */
      .nearby-card::after {
        content: ''; position: absolute; inset: 0; z-index: 1;
        background: linear-gradient(to top, rgba(8,8,8,.88) 0%, rgba(8,8,8,.55) 38%, rgba(8,8,8,.34) 70%, rgba(8,8,8,.34) 100%);
      }
      /* Fallback: solid dark gradient when no photo available */
      .nearby-card[data-photo="false"] {
        background: radial-gradient(120% 120% at 80% 0%, #2a3344 0%, #0A0A0A 60%);
      }
      .nearby-card[data-photo="false"]::after { display: none; }
      /* Status chip — top left */
      .nearby-ribbon {
        position: absolute; top: 14px; left: 14px; z-index: 3;
        font-family: var(--mono); font-size: 11px; letter-spacing: .08em;
        text-transform: uppercase; font-weight: 600; padding: 6px 11px; border-radius: 9px;
      }
      /* Open = hotel accent fill; closed = frosted glass (always distinct from any accent) */
      .nearby-ribbon-open { background: var(--accent); color: var(--accent-on, #fff); }
      .nearby-ribbon-closed {
        background: rgba(255,255,255,.15); color: #fff;
        border: 1px solid rgba(255,255,255,.30); backdrop-filter: blur(6px);
      }
      /* Rating chip — top right, kanonisch = /places .nb-rating */
      .nearby-rate {
        position: absolute; top: 14px; right: 14px; z-index: 3;
        font-family: var(--mono); font-size: 9.5px; font-weight: 600;
        background: rgba(10,10,10,.6); backdrop-filter: blur(5px);
        color: #fff; padding: 2px 7px; border-radius: 5px;
        display: flex; align-items: center; gap: 4px;
      }
      .nearby-rate-star { color: #FFE600; display: inline-flex; align-items: center; }
      .nearby-rate-star svg { width: 11px; height: 11px; display: block; }
      /* Caption — bottom overlay area */
      .nearby-cap { position: absolute; left: 17px; right: 17px; bottom: 16px; z-index: 3; }
      .nearby-name {
        font-family: var(--display); font-weight: 600; font-size: 23px; line-height: 1.08;
        color: #fff; margin: 0; text-shadow: 0 1px 10px rgba(0,0,0,.55);
      }
      .nearby-meta {
        font-family: var(--mono); font-size: 13px; margin: 7px 0 0;
        color: #fff; opacity: .96; text-shadow: 0 1px 8px rgba(0,0,0,.6);
      }

      /* ── Empty state ──────────────────────────────────────────────────── */
      .place-empty {
        padding: 20px 0; font-size: 14px; color: var(--ink-muted); font-style: italic;
      }

      /* ── Show-more button ─────────────────────────────────────────────── */
      .show-more-btn {
        background: none; border: none; padding: 10px 2px;
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.10em;
        text-transform: uppercase; color: var(--accent); cursor: pointer;
      }
      .show-more-btn:hover { opacity: 0.75; }

      /* ── Stars ───────────────────────────────────────────────────────── */
      /* Exception: #FFE600 (V9-yellow) is the ONLY permitted use of yellow in the guest app.
         Rating stars are a cultural data symbol, not a UI interaction element.
         NO yellow for buttons, hover, accents, or active states in the guest app. */
      .star {
        color: #FFE600; font-size: 11px; line-height: 1;
        vertical-align: middle;
      }

      /* ── Place detail overlay ─────────────────────────────────────────── */
      .detail-backdrop {
        position: fixed;
        /* starts BELOW safe-area so statusbar stays light */
        top: env(safe-area-inset-top, 50px);
        left: 0; right: 0; bottom: 0;
        background: rgba(10,10,10,0.18);
        z-index: 40;
      }
      .detail-sheet {
        position: fixed; bottom: 0;
        /* centering without transform so translateY animation is pure */
        left: 0; right: 0;
        margin-inline: auto;
        width: min(100%, 480px);
        max-height: 88vh; overflow-y: auto;
        background: var(--bg); border-radius: 16px 16px 0 0;
        z-index: 41;
        padding-bottom: env(safe-area-inset-bottom, 20px);
        box-shadow: 0 -4px 24px rgba(10,10,10,0.10);
      }
      .detail-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 18px 14px; border-bottom: 1px solid var(--border);
        position: sticky; top: 0; background: var(--bg); z-index: 1;
      }
      .detail-title { font-size: 17px; font-weight: 600; margin: 0; flex: 1; color: var(--ink); }
      .detail-close {
        width: 30px; height: 30px; border-radius: 50%; border: none;
        background: #EFEDE8; color: var(--ink);
        display: grid; place-items: center; cursor: pointer; flex-shrink: 0;
        font-size: 16px; line-height: 1;
      }
      .detail-body { padding: 0 18px 20px; }
      .detail-loading { padding: 32px 18px; text-align: center; color: var(--ink-muted); font-size: 14px; }

      .detail-photos { width: 100%; aspect-ratio: 4/3; background: #F0EDE6; overflow: hidden; }
      .detail-photo-frame { width: 100%; height: 100%; position: relative; }
      .detail-photo-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.3s; }
      .detail-photo-img.is-active { opacity: 1; }
      .detail-photo-prev, .detail-photo-next {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 30px; height: 30px; border-radius: 50%; border: none;
        background: rgba(255,255,255,0.85); cursor: pointer;
        display: grid; place-items: center; font-size: 16px;
      }
      .detail-photo-prev { left: 10px; }
      .detail-photo-next { right: 10px; }

      .detail-meta {
        display: flex; gap: 14px; flex-wrap: wrap;
        padding: 14px 0 12px; border-bottom: 1px solid var(--border); margin-bottom: 12px;
      }
      .detail-meta-item { font-size: 13px; color: var(--ink-muted); }
      .detail-note {
        padding: 10px 12px; background: var(--accent-soft); border-left: 2px solid var(--accent);
        font-size: 13px; font-style: italic; color: var(--ink-muted);
        border-radius: 0 4px 4px 0; margin-bottom: 14px; line-height: 1.45;
      }
      .detail-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
      .detail-action {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 12px; border: 1px solid var(--border); border-radius: 8px;
        background: var(--surface); color: var(--ink); font-size: 13px;
        text-decoration: none; transition: border-color 0.12s;
      }
      .detail-action:hover { border-color: var(--border-strong); }

      .detail-hours-title, .detail-reviews-title {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.13em;
        text-transform: uppercase; color: var(--ink-faint); margin: 14px 0 8px;
      }
      .detail-hours { list-style: none; margin: 0; padding: 0; }
      .detail-hours li { font-size: 13px; color: var(--ink-muted); padding: 2px 0; }
      .detail-review { padding: 10px 0; border-bottom: 1px solid var(--border); }
      .detail-review:last-child { border-bottom: none; }
      .detail-review-author { font-size: 13px; font-weight: 500; margin: 0 0 3px; color: var(--ink); }
      .detail-review-text { font-size: 13px; color: var(--ink-muted); margin: 0; line-height: 1.45; }

      /* ── Detail slide transitions ─────────────────────────────────────── */
      .d-enter        { transition: transform 0.32s cubic-bezier(.32,.72,0,1); }
      .d-enter-start  { transform: translateY(100%); }
      .d-enter-end    { transform: translateY(0); }
      .d-leave        { transition: transform 0.24s ease-in; }
      .d-leave-start  { transform: translateY(0); }
      .d-leave-end    { transform: translateY(100%); }
      .d-fade-enter   { transition: opacity 0.18s; }
      .d-fade-start   { opacity: 0; }
      .d-fade-end     { opacity: 1; }
      .d-fade-leave   { transition: opacity 0.18s; }
      .d-fade-l-start { opacity: 1; }
      .d-fade-l-end   { opacity: 0; }

      @media (prefers-reduced-motion: reduce) {
        .d-enter, .d-leave { transition: none; }
        .tab-btn { transition: none; }
        .place-card { transition: none; }
      }
    </style>
  </head>

  <body x-data="places()" x-init="init()">

    <a class="close-btn" href={backHref} data-astro-reload aria-label="Schließen">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </a>

    <div class="page">

      <!-- Hero -->
      <div class="hero g-hero-dot">
        <span class="eyebrow">{labels.eyebrow}</span>
        <h1 class="title">{labels.title}<span class="accent">{labels.titleAccent}</span></h1>
        <p class="subtitle">{labels.subtitle}</p>
      </div>

      <!-- Category tabs -->
      <div class="tabs" role="tablist">
        {visibleTabs.map(cat => (
          <button
            type="button"
            class="tab-btn"
            :data-active={`activeTab === '${cat}'`}
            @click={`activeTab = '${cat}'; showAllExpanded['${cat}'] = false`}
            role="tab"
          >
            {TAB_LABELS[cat]}
            {dataByCategory[cat].picks.length > 0 && (
              <sup style="font-size:9px;opacity:0.6;margin-left:3px">{dataByCategory[cat].picks.length}</sup>
            )}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {visibleTabs.map(cat => {
        const d = dataByCategory[cat];
        const AUTO_INITIAL = 8;
        return (
          <div x-show={`activeTab === '${cat}'`} x-cloak role="tabpanel">

            <!-- Hotel picks — hidden entirely when no picks exist -->
            {d.picks.length > 0 && (
            <section class="cat-section">
              <p class="cat-title">{labels.sectionPicks}</p>
              {d.picks.map(p => (
                <article
                  class="place-card"
                  tabindex="0"
                  @click={`openDetail('${p.place_id}')`}
                  @keydown.enter={`openDetail('${p.place_id}')`}
                >
                  {p.photoUrl && (
                    <div class="place-card-photo">
                      <img src={p.photoUrl} alt={p.name} loading="lazy" />
                    </div>
                  )}
                  <div class="place-card-body">
                    <p class="place-card-name">{p.name}</p>
                    <p class="place-card-meta">
                      {p.rating != null && <span><span class="star" aria-hidden="true">★</span> {p.rating}</span>}
                      {p.rating != null && (p.priceLevel || p.walkingMin != null) && <span class="place-card-meta-sep">·</span>}
                      {p.priceLevel && <span>{PRICE[p.priceLevel]}</span>}
                      {p.priceLevel && p.walkingMin != null && <span class="place-card-meta-sep">·</span>}
                      {p.walkingMin != null && <span>{walkLabel(p.walkingMin)}</span>}
                    </p>
                    {p.hotelNote && <p class="place-note">{p.hotelNote}</p>}
                  </div>
                </article>
              ))}
            </section>
            )}

            <!-- Auto / nearby -->
            <section class="cat-section">
              <p class="cat-title">{labels.sectionNearby}</p>
              {d.auto.length === 0 && <p class="place-empty">{labels.noNearby}</p>}
              <div class="nearby-list">
                {d.auto.slice(0, AUTO_INITIAL).map(a => (
                  <div
                    class="nearby-card"
                    data-photo={a.photoUrl ? 'true' : 'false'}
                    style={a.photoUrl ? `background-image:url('${a.photoUrl}')` : undefined}
                    tabindex="0"
                    @click={`openDetail('${a.place_id}')`}
                    @keydown.enter={`openDetail('${a.place_id}')`}
                  >
                    {a.openNow !== null && a.openNow !== undefined && (
                      <span class={`nearby-ribbon ${a.openNow ? 'nearby-ribbon-open' : 'nearby-ribbon-closed'}`}>
                        {a.openNow ? labels.open : labels.closed}
                      </span>
                    )}
                    {a.rating != null && (
                      <span class="nearby-rate">
                        <span class="nearby-rate-star" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11"><path d="M12 2l2.9 6.3 6.8.6-5.1 4.5 1.5 6.7L12 17l-6 3.6 1.5-6.7L2.4 9.4l6.8-.6z"/></svg>
                        </span>
                        {a.rating} · {a.userRatingCount ?? 0}
                      </span>
                    )}
                    <div class="nearby-cap">
                      <p class="nearby-name">{a.name}</p>
                      {a.walkingMin != null && <p class="nearby-meta">{walkLabel(a.walkingMin)}</p>}
                    </div>
                  </div>
                ))}

                {d.auto.length > AUTO_INITIAL && (
                  <div x-show={`!showAllExpanded['${cat}']`}>
                    <button
                      type="button"
                      class="show-more-btn"
                      @click={`showAllExpanded['${cat}'] = true`}
                    >
                      {labels.showMore} ({d.auto.length - AUTO_INITIAL})
                    </button>
                  </div>
                )}

                {d.auto.length > AUTO_INITIAL && d.auto.slice(AUTO_INITIAL).map(a => (
                  <div
                    class="nearby-card"
                    data-photo={a.photoUrl ? 'true' : 'false'}
                    style={a.photoUrl ? `background-image:url('${a.photoUrl}')` : undefined}
                    tabindex="0"
                    x-show={`showAllExpanded['${cat}']`}
                    x-cloak
                    @click={`openDetail('${a.place_id}')`}
                    @keydown.enter={`openDetail('${a.place_id}')`}
                  >
                    {a.openNow !== null && a.openNow !== undefined && (
                      <span class={`nearby-ribbon ${a.openNow ? 'nearby-ribbon-open' : 'nearby-ribbon-closed'}`}>
                        {a.openNow ? labels.open : labels.closed}
                      </span>
                    )}
                    {a.rating != null && (
                      <span class="nearby-rate">
                        <span class="nearby-rate-star" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11"><path d="M12 2l2.9 6.3 6.8.6-5.1 4.5 1.5 6.7L12 17l-6 3.6 1.5-6.7L2.4 9.4l6.8-.6z"/></svg>
                        </span>
                        {a.rating} · {a.userRatingCount ?? 0}
                      </span>
                    )}
                    <div class="nearby-cap">
                      <p class="nearby-name">{a.name}</p>
                      {a.walkingMin != null && <p class="nearby-meta">{walkLabel(a.walkingMin)}</p>}
                    </div>
                  </div>
                ))}
              </div>
            </section>

          </div>
        );
      })}
    </div>

    <!-- Place detail overlay -->
    <div
      class="detail-backdrop"
      x-show="activeId"
      x-cloak
      @click="closeDetail()"
      x-transition:enter="d-fade-enter"
      x-transition:enter-start="d-fade-start"
      x-transition:enter-end="d-fade-end"
      x-transition:leave="d-fade-leave"
      x-transition:leave-start="d-fade-l-start"
      x-transition:leave-end="d-fade-l-end"
    ></div>

    <aside
      class="detail-sheet"
      x-show="activeId"
      x-cloak
      role="dialog"
      aria-modal="true"
      x-transition:enter="d-enter"
      x-transition:enter-start="d-enter-start"
      x-transition:enter-end="d-enter-end"
      x-transition:leave="d-leave"
      x-transition:leave-start="d-leave-start"
      x-transition:leave-end="d-leave-end"
    >
      <header class="detail-header">
        <h2 class="detail-title" x-text="data?.name || '…'"></h2>
        <button type="button" class="detail-close" @click="closeDetail()" aria-label="Schließen">×</button>
      </header>

      <div x-show="loading && !data" class="detail-loading" x-cloak>
        <p>…</p>
      </div>

      <div x-show="data" x-cloak>
        <!-- Carousel -->
        <div class="detail-photos" x-data="{ idx: 0 }" x-show="(data?.photoUrls?.length || 0) > 0">
          <div class="detail-photo-frame">
            <template x-for="(u, i) in (data?.photoUrls || [])" :key="u">
              <img :src="u" :alt="data?.name" class="detail-photo-img" :class="{ 'is-active': i === idx }" loading="lazy" />
            </template>
          </div>
          <button type="button" class="detail-photo-prev" @click="idx = Math.max(0, idx - 1)" :disabled="idx === 0" x-show="(data?.photoUrls?.length || 0) > 1">‹</button>
          <button type="button" class="detail-photo-next" @click="idx = Math.min(idx + 1, (data?.photoUrls?.length || 1) - 1)" :disabled="idx >= (data?.photoUrls?.length || 1) - 1" x-show="(data?.photoUrls?.length || 0) > 1">›</button>
        </div>

        <div class="detail-body">
          <!-- Meta row -->
          <div class="detail-meta">
            <span class="detail-meta-item" x-show="data?.rating" style="display:inline-flex;align-items:center;gap:3px">
              <span class="star" aria-hidden="true">★</span>
              <span x-text="data?.rating"></span>
              <span x-show="data?.userRatingCount">(<span x-text="data?.userRatingCount"></span>)</span>
            </span>
            <span class="detail-meta-item" x-show="data?.priceSymbol" x-text="data?.priceSymbol"></span>
            <span class="detail-meta-item"
              x-show="data?.openNow !== null && data?.openNow !== undefined"
              :style="data?.openNow ? 'color:var(--success)' : 'color:var(--ink-muted)'"
              x-text="data?.openNow ? 'Geöffnet' : 'Geschlossen'">
            </span>
          </div>

          <!-- Hotel note -->
          <div x-show="data?.hotelNote" class="detail-note" x-text="data?.hotelNote"></div>

          <!-- Action links -->
          <div class="detail-actions">
            <a x-show="data?.googleMapsUri" :href="data?.googleMapsUri" target="_blank" rel="noopener" class="detail-action">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="11" r="3"/><path d="M17.657 16.657L13.414 20.9a2 2 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0z"/></svg>
              Maps
            </a>
            <a x-show="data?.phone" :href="`tel:${data?.phone}`" class="detail-action">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.89 8.19a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.8 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Anrufen
            </a>
            <a x-show="data?.website" :href="data?.website" target="_blank" rel="noopener" class="detail-action">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              Website
            </a>
          </div>

          <!-- Address -->
          <p x-show="data?.formattedAddress" class="detail-meta-item" x-text="data?.formattedAddress" style="font-size:13px;color:var(--ink-muted);margin:0 0 4px"></p>

          <!-- Hours -->
          <div x-show="(data?.weekdayDescriptions?.length || 0) > 0">
            <p class="detail-hours-title">Öffnungszeiten</p>
            <ul class="detail-hours">
              <template x-for="d in (data?.weekdayDescriptions || [])" :key="d">
                <li x-text="d"></li>
              </template>
            </ul>
          </div>

          <!-- Reviews -->
          <div x-show="(data?.reviews?.length || 0) > 0">
            <p class="detail-reviews-title">Bewertungen</p>
            <template x-for="r in (data?.reviews || [])" :key="r.author">
              <div class="detail-review">
                <p class="detail-review-author">
                  <span x-text="r.author"></span>
                  <span class="star" x-show="r.rating" x-text="r.rating ? ' · ' + '★'.repeat(r.rating) : ''" style="font-size:10px;margin-left:4px"></span>
                </p>
                <p class="detail-review-text" x-text="r.text"></p>
              </div>
            </template>
          </div>
        </div>
      </div>
    </aside>

    <script>
      import Alpine from 'alpinejs';

      Alpine.data('places', () => ({
          activeTab: (window as any).__PLACE_DETAILS__?.initialTab ?? 'restaurant',
          showAllExpanded: {} as Record<string, boolean>,
          activeId: null as string | null,
          data: null as any,
          loading: false,
          error: null as string | null,

          init() {
            this.activeTab = (window as any).__PLACE_DETAILS__?.initialTab ?? 'restaurant';
          },

          async openDetail(placeId: string) {
            this.error = null;
            this.activeId = placeId;

            const cache = (window as any).__PLACE_DETAILS__?.cache ?? {};
            if (cache[placeId]) {
              this.data = cache[placeId];
              this.loading = false;
              return;
            }

            this.data = null;
            this.loading = true;
            try {
              const lang = (window as any).__PLACE_DETAILS__?.lang || 'de';
              const res = await fetch(`/api/places/details?placeId=${encodeURIComponent(placeId)}&lang=${lang}`);
              if (!res.ok) throw new Error(`HTTP ${res.status}`);
              const body = await res.json() as any;
              if (!body.ok) throw new Error(body.error || 'Unknown');
              const d = body.details as any;
              const P: Record<string,string> = { PRICE_LEVEL_FREE: '', PRICE_LEVEL_INEXPENSIVE: '€', PRICE_LEVEL_MODERATE: '€€', PRICE_LEVEL_EXPENSIVE: '€€€', PRICE_LEVEL_VERY_EXPENSIVE: '€€€€' };
              this.data = {
                name: d.name, rating: d.rating, userRatingCount: d.userRatingCount,
                priceSymbol: P[d.priceLevel ?? ''] ?? '', hotelNote: null,
                formattedAddress: d.formattedAddress, phone: d.internationalPhoneNumber,
                website: d.websiteUri, googleMapsUri: d.googleMapsUri,
                openNow: d.openingHours?.openNow ?? null,
                weekdayDescriptions: d.openingHours?.weekdayDescriptions ?? [],
                reviews: (d.reviews ?? []).slice(0, 3).map((r: any) => ({
                  author: r.authorAttribution?.displayName ?? 'Gast',
                  text: r.text?.text ?? '',
                  rating: r.rating,
                })),
                photoUrls: (d.photos ?? []).slice(0, 8).map((ph: any) =>
                  `/api/places/photo?name=${encodeURIComponent(ph.name ?? ph)}&maxWidth=1200`
                ),
              };
            } catch (e) {
              this.error = (e as Error).message;
            } finally {
              this.loading = false;
            }
          },

          closeDetail() {
            this.activeId = null;
            this.data = null;
            this.error = null;
          },
        }));

      Alpine.start();
    </script>

  </body>
</html>
