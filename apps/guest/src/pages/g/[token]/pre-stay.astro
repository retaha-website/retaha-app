---
// Pre-Stay-Welcome-Sheet
// Zugängig via E-Mail-Link vor Anreise: /g/[token]/pre-stay
// Feature-Gate: features.pre_stay

import { loadStayByToken } from '@retaha/db';
import { normalizeLang, type Lang } from '@retaha/i18n';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/jetbrains-mono/400.css';

const { token } = Astro.params;
if (!token) return new Response('Token fehlt', { status: 400 });

const ctx = await loadStayByToken(token);
if (!ctx) return new Response('Aufenthalt nicht gefunden', { status: 404 });

const { stay, guest, hotel, settings } = ctx;

// Feature-Gate
const features = (settings?.features ?? {}) as Record<string, boolean>;
if (features.pre_stay === false) {
  return Astro.redirect(`/g/${token}`);
}

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);

// Countdown-Berechnung
const now = new Date();
const checkIn = new Date(stay.check_in);
const msPerDay = 1000 * 60 * 60 * 24;
const daysUntil = Math.max(0, Math.ceil((checkIn.getTime() - now.getTime()) / msPerDay));

const localeMap: Record<Lang, string> = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES' };
const arrivalLabel = checkIn.toLocaleDateString(localeMap[lang], {
  weekday: 'short', day: '2-digit', month: 'short',
});

const guestName = guest?.first_name ?? null;
const breakfastStart = settings?.breakfast_start_time?.slice(0, 5) ?? '07:00';
const breakfastEnd   = settings?.breakfast_end_time?.slice(0, 5) ?? '10:30';
const wifiSsid = settings?.wifi_ssid ?? null;

const backHref = `/g/${token}`;

const labels: Record<Lang, {
  eyebrow: string; greeting: string; sub: string; prepTitle: string;
  wifiCard: string; wifiSub: string; brkCard: string; brkSub: string;
  serviceCard: string; serviceSub: string;
  walletTeaser: string; walletSub: string; walletBtn: string;
  back: string; daysUnit: (n: number) => string;
}> = {
  de: {
    eyebrow: `In ${daysUntil} ${daysUntil === 1 ? 'Tag' : 'Tagen'}`,
    greeting: `Hallo${guestName ? `, ${guestName}` : ''}`,
    sub: `Wir freuen uns auf dich am ${arrivalLabel}.`,
    prepTitle: 'Was dich erwartet',
    wifiCard: 'WLAN inklusive', wifiSub: 'Im ganzen Haus kostenlos — schon beim Einzug verfügbar',
    brkCard: `Frühstück ${breakfastStart}–${breakfastEnd}`, brkSub: 'In der App reservierbar',
    serviceCard: 'Service auf Abruf', serviceSub: 'Handtücher, Wasser, Zimmerservice',
    walletTeaser: 'Bereit für die Anreise?',
    walletSub: 'Hol dir schon jetzt deinen digitalen Willkommenspass.',
    walletBtn: 'Zur Google Wallet hinzufügen',
    back: '← Zurück zur App',
    daysUnit: (n) => n === 1 ? 'Tag' : 'Tage',
  },
  en: {
    eyebrow: `In ${daysUntil} ${daysUntil === 1 ? 'day' : 'days'}`,
    greeting: `Hello${guestName ? `, ${guestName}` : ''}`,
    sub: `We're looking forward to welcoming you on ${arrivalLabel}.`,
    prepTitle: "What's waiting for you",
    wifiCard: 'Free WiFi', wifiSub: 'Throughout the hotel — available from check-in',
    brkCard: `Breakfast ${breakfastStart}–${breakfastEnd}`, brkSub: 'Reservable in the app',
    serviceCard: 'Room Service', serviceSub: 'Towels, water and more on request',
    walletTeaser: 'Ready for your stay?',
    walletSub: 'Get your digital welcome pass now.',
    walletBtn: 'Add to Google Wallet',
    back: '← Back to app',
    daysUnit: (n) => n === 1 ? 'day' : 'days',
  },
  fr: {
    eyebrow: `Dans ${daysUntil} ${daysUntil === 1 ? 'jour' : 'jours'}`,
    greeting: `Bonjour${guestName ? `, ${guestName}` : ''}`,
    sub: `Nous avons hâte de vous accueillir le ${arrivalLabel}.`,
    prepTitle: 'Ce qui vous attend',
    wifiCard: 'WiFi gratuit', wifiSub: "Dans tout l'hôtel",
    brkCard: `Petit-déjeuner ${breakfastStart}–${breakfastEnd}`, brkSub: "Réservable dans l'application",
    serviceCard: 'Service en chambre', serviceSub: 'Serviettes, eau et plus',
    walletTeaser: 'Prêt pour votre séjour?',
    walletSub: 'Obtenez votre pass numérique dès maintenant.',
    walletBtn: 'Ajouter au Wallet',
    back: '← Retour',
    daysUnit: (n) => n === 1 ? 'jour' : 'jours',
  },
  es: {
    eyebrow: `En ${daysUntil} ${daysUntil === 1 ? 'día' : 'días'}`,
    greeting: `Hola${guestName ? `, ${guestName}` : ''}`,
    sub: `Estamos deseando recibirte el ${arrivalLabel}.`,
    prepTitle: 'Lo que te espera',
    wifiCard: 'WiFi gratuito', wifiSub: 'En todo el hotel',
    brkCard: `Desayuno ${breakfastStart}–${breakfastEnd}`, brkSub: 'Reservable en la app',
    serviceCard: 'Servicio de habitaciones', serviceSub: 'Toallas, agua y más',
    walletTeaser: '¿Listo para tu estancia?',
    walletSub: 'Obtén tu pase de bienvenida digital ahora.',
    walletBtn: 'Añadir a Google Wallet',
    back: '← Volver',
    daysUnit: (n) => n === 1 ? 'día' : 'días',
  },
};

const L = labels[lang];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0A" />
    <title>{hotel.name} — {lang === 'de' ? 'Willkommen' : 'Welcome'}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0; padding: 0;
        background: #FAFAF8; color: #0A0A0A;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        min-height: 100vh;
      }
      .page { max-width: 520px; margin: 0 auto; padding: 0 20px 60px; }

      .back-link {
        display: inline-block; padding: 16px 0 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
        color: #888; text-decoration: none;
      }
      .back-link:hover { color: #0A0A0A; }

      .hero { padding: 32px 0 28px; border-bottom: 1px solid #E0DDD8; margin-bottom: 28px; }
      .hero__logo { height: 32px; max-width: 120px; object-fit: contain; margin-bottom: 16px; display: block; }
      .hero__eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px; letter-spacing: 0.18em; font-weight: 500;
        color: #0A0A0A; background: #FFE600;
        padding: 4px 10px; display: inline-block; border-radius: 3px;
        margin-bottom: 16px;
      }
      .hero__title {
        font-size: clamp(28px, 7vw, 48px); font-weight: 400; letter-spacing: -0.025em;
        line-height: 1.05; margin: 0 0 10px; color: #0A0A0A;
      }
      .hero__title .dot { color: #FF4A82; }
      .hero__sub { font-size: 15px; color: #666; line-height: 1.5; margin: 0; }

      .cards { display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
      .card {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 16px;
        background: #fff; border: 1px solid #E0DDD8; border-radius: 10px;
        transition: border-color 150ms;
      }
      .card:hover { border-color: #FFE600; }
      .card__icon {
        width: 36px; height: 36px; border-radius: 8px;
        background: #F5F5F3; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        color: #555;
      }
      .card__title { font-size: 14px; font-weight: 500; color: #0A0A0A; line-height: 1.2; }
      .card__sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #888; margin-top: 3px; }

      .wallet-cta {
        background: #0A0A0A; color: #FAFAF8;
        border-radius: 12px; padding: 20px;
        display: flex; flex-direction: column; gap: 14px;
      }
      .wallet-cta__title { font-size: 16px; font-weight: 500; margin: 0 0 4px; }
      .wallet-cta__sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; opacity: 0.6; margin: 0; }
      .wallet-cta__btn {
        background: #FFE600; color: #0A0A0A;
        border: none; border-radius: 8px; padding: 14px;
        font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500;
        letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer;
        transition: background 150ms; width: 100%;
      }
      .wallet-cta__btn:hover { background: #FF4A82; color: #fff; }

      .made-by {
        margin-top: 48px; padding-top: 20px;
        border-top: 1px solid #E0DDD8;
        font-family: 'JetBrains Mono', monospace; font-size: 10px;
        color: #BBB; text-align: center; letter-spacing: 0.06em;
      }
      .made-by a { color: #888; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="page">
      <a href={backHref} class="back-link">{L.back}</a>

      <div class="hero">
        {hotel.logo_url && (
          <img class="hero__logo" src={hotel.logo_url} alt={hotel.name} />
        )}
        <div class="hero__eyebrow">{L.eyebrow}</div>
        <h1 class="hero__title">{L.greeting}<span class="dot">.</span></h1>
        <p class="hero__sub">{L.sub}</p>
      </div>

      <div class="cards">
        <!-- WLAN -->
        {wifiSsid && (
          <div class="card">
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
                <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
                <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
                <circle cx="12" cy="20" r="1" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <div class="card__title">{L.wifiCard}</div>
              <div class="card__sub">{wifiSsid} · {L.wifiSub}</div>
            </div>
          </div>
        )}

        <!-- Frühstück -->
        {features.breakfast !== false && (
          <div class="card">
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
                <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
                <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                <line x1="6" y1="1" x2="6" y2="4"/>
                <line x1="10" y1="1" x2="10" y2="4"/>
                <line x1="14" y1="1" x2="14" y2="4"/>
              </svg>
            </div>
            <div>
              <div class="card__title">{L.brkCard}</div>
              <div class="card__sub">{L.brkSub}</div>
            </div>
          </div>
        )}

        <!-- Service -->
        {features.service !== false && (
          <div class="card">
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
                <path d="M18 20V10"/>
                <path d="M12 20V4"/>
                <path d="M6 20v-6"/>
              </svg>
            </div>
            <div>
              <div class="card__title">{L.serviceCard}</div>
              <div class="card__sub">{L.serviceSub}</div>
            </div>
          </div>
        )}
      </div>

      <!-- Wallet CTA -->
      <div class="wallet-cta">
        <div>
          <p class="wallet-cta__title">{L.walletTeaser}</p>
          <p class="wallet-cta__sub">{L.walletSub}</p>
        </div>
        <button class="wallet-cta__btn" type="button">{L.walletBtn}</button>
      </div>

      <div class="made-by">
        powered by <a href="https://retaha.de" target="_blank" rel="noopener">retaha</a>
      </div>
    </div>
  </body>
</html>
