<!DOCTYPE html>
<html lang={lang} style={brandStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{l.pageTitle}</title>
    <style>
      [x-cloak] { display: none !important; }
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --accent:      #0A0A0A;
        --accent-soft: rgba(10,10,10,0.08);
        --ink:         #0F0F0D;
        --ink-muted:   #6B6B63;
        --ink-faint:   #A8A8A0;
        --border:      #E7E4DD;
        --border-strong: #C8C4BB;
        --bg:          #FBFAF7;
        --surface:     #FFFFFF;
        --success:     #3D8C5C;
        --radius:      12px;
        --mono: 'JetBrains Mono', 'Courier New', monospace;
        --display: 'Space Grotesk', system-ui, sans-serif;
        /* Choreografie-Timing — ein Wert justieren = alle Stufen passen */
        --bf-ease:     cubic-bezier(.32,.72,0,1);
        --bf-feedback: 200ms;   /* Pill aktiv sichtbar            */
        --bf-collapse: 300ms;   /* Sektion kollabiert             */
        --bf-open:     300ms;   /* Nächste Sektion öffnet sich    */
      }

      body {
        margin: 0; padding: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--display);
        min-height: 100dvh;
        -webkit-font-smoothing: antialiased;
        position: relative;
      }

      .page {
        max-width: 480px;
        margin: 0 auto;
        padding: calc(env(safe-area-inset-top, 0px) + 72px) 22px calc(env(safe-area-inset-bottom, 20px) + 48px);
        animation: page-in 280ms cubic-bezier(0.22,1,0.36,1) both;
      }
      @keyframes page-in {
        from { transform: translateY(-12px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        .page { animation: none; }
      }

      /* ── Close button ───────────────────────────────────────────────── */
      .close-btn {
        position: absolute;
        top: calc(env(safe-area-inset-top, 0px) + 16px);
        right: 20px;
        width: 36px; height: 36px;
        border-radius: 50%;
        background: #EFEDE8;
        display: grid; place-items: center;
        text-decoration: none;
        color: var(--ink);
        flex-shrink: 0;
        transition: background 0.14s ease;
        z-index: 10;
      }
      .close-btn:hover { background: #E0DDD7; }
      .close-btn:active { transform: none !important; }
      .close-btn svg { width: 16px; height: 16px; }

      /* ── Hero ───────────────────────────────────────────────────────── */
      .hero { padding: 28px 0 24px; border-bottom: 2px solid var(--ink); margin-bottom: 28px; }
      .eyebrow {
        font-family: var(--mono);
        font-size: 10px; letter-spacing: 0.16em; font-weight: 500;
        color: var(--accent); margin: 0 0 14px; display: block;
      }
      .title {
        font-size: clamp(28px, 7vw, 38px); font-weight: 700;
        letter-spacing: -0.025em; line-height: 1.05;
        margin: 0 0 8px; color: var(--ink);
      }
      .title .accent { color: var(--accent); }
      .subtitle { font-size: 14px; color: var(--ink-muted); margin: 0; line-height: 1.45; }

      /* ── Tabs ───────────────────────────────────────────────────────── */
      .tabs {
        display: flex; gap: 6px;
        margin-bottom: 24px;
      }
      .tab-btn {
        flex: 1; min-height: 40px; padding: 7px 13px;
        background: white; border: 1px solid #D0CCC5; border-radius: 8px;
        font-family: var(--display); font-size: 13px; font-weight: 500;
        color: var(--ink); cursor: pointer; text-align: center;
        -webkit-tap-highlight-color: transparent;
        transition: background 80ms, color 80ms, border-color 80ms;
      }
      .tab-btn[data-active="true"] { background: #0A0A0A; border-color: #0A0A0A; color: #fff; }
      .tab-btn:hover:not([data-active="true"]) { border-color: #C0BCB5; }

      /* ── Error ──────────────────────────────────────────────────────── */
      .booking-error {
        padding: 10px 14px; background: #FFF0F0; border: 1px solid #F5C6C6;
        border-radius: 6px; color: #8C2128; font-size: 13px;
      }

      /* ── Status card ────────────────────────────────────────────────── */
      .status-card { text-align: center; padding: 8px 0 24px; }
      .status-icon {
        width: 48px; height: 48px; border-radius: 50%;
        background: var(--accent); color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        margin-bottom: 16px;
      }
      .status-icon.confirmed { background: var(--success); }
      .status-icon.cancelled { background: var(--ink-muted); }
      .status-icon svg { width: 22px; height: 22px; }
      .status-title { font-size: 20px; font-weight: 600; margin: 0 0 6px; }
      .status-sub   { font-size: 14px; color: var(--ink-muted); margin: 0 0 24px; line-height: 1.4; }

      .summary-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); overflow: hidden; margin-bottom: 20px;
      }
      .summary-row {
        display: flex; justify-content: space-between; align-items: baseline;
        padding: 12px 16px; border-bottom: 1px solid var(--border);
      }
      .summary-row:last-child { border-bottom: none; }
      .summary-label {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--ink-faint);
      }
      .summary-value { font-size: 14px; font-weight: 500; color: var(--ink); }

      .rebook-btn {
        width: 100%; padding: 13px; border: 1px solid var(--border);
        border-radius: 8px; background: transparent; color: var(--ink-muted);
        font-family: var(--display); font-size: 14px; cursor: pointer;
        transition: border-color 0.12s, color 0.12s;
      }
      .rebook-btn:hover { border-color: var(--accent); color: var(--accent); }

      /* ── Info card ──────────────────────────────────────────────────── */
      .info-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); overflow: hidden;
      }
      .info-row {
        display: flex; flex-direction: column; gap: 4px;
        padding: 14px 18px; border-bottom: 1px solid var(--border);
      }
      .info-row:last-child { border-bottom: none; }
      .info-label {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.13em;
        text-transform: uppercase; color: var(--ink-faint);
      }
      .info-value { font-size: 15px; font-weight: 500; color: var(--ink); }
      .info-value--multi { white-space: pre-line; font-weight: 400; font-size: 14px; line-height: 1.55; }

      /* ── Menu tab ───────────────────────────────────────────────────── */
      .filter-section { margin-bottom: 20px; }
      .filter-title {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em;
        font-weight: 500; text-transform: uppercase; color: var(--ink-muted);
        margin-bottom: 8px;
      }
      .filter-hint { font-size: 12px; color: var(--ink-muted); margin: 0 0 12px; line-height: 1.4; }
      .filter-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
      .filter-chip {
        padding: 5px 11px; border-radius: 20px; border: 1px solid var(--border);
        background: var(--surface); font-size: 12px; color: var(--ink-muted);
        cursor: pointer; transition: background 0.12s, border-color 0.12s, color 0.12s;
      }
      .filter-chip.active {
        background: var(--accent); border-color: var(--accent); color: #fff;
      }
      .filter-reset {
        padding: 6px 0; background: none; border: none;
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.10em;
        text-transform: uppercase; color: var(--accent); cursor: pointer;
      }

      .menu-empty { padding: 24px; text-align: center; color: var(--ink-muted); font-size: 14px; }
      .menu-category { margin-bottom: 24px; }
      .menu-category-title {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.16em;
        text-transform: uppercase; color: var(--ink-faint);
        padding-bottom: 8px; border-bottom: 1px solid var(--border); margin-bottom: 12px;
      }
      .menu-item {
        padding: 12px 0; border-bottom: 1px solid var(--border);
      }
      .menu-item:last-child { border-bottom: none; }
      .menu-item-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 4px; }
      .menu-item-name { font-size: 15px; font-weight: 500; color: var(--ink); }
      .menu-item-flags { display: flex; gap: 4px; flex-shrink: 0; }
      .menu-flag {
        font-family: var(--mono); font-size: 8px; letter-spacing: 0.08em;
        text-transform: uppercase; padding: 2px 6px; border-radius: 3px;
        background: rgba(61,140,92,0.10); color: var(--success);
      }
      .menu-flag.organic { background: rgba(180,140,40,0.10); color: #8B6914; }
      .menu-item-desc { font-size: 13px; color: var(--ink-muted); line-height: 1.4; margin-bottom: 6px; }
      .menu-item-warning {
        display: flex; align-items: center; gap: 5px;
        font-size: 12px; color: #C05000; padding: 5px 8px;
        background: rgba(192,80,0,0.07); border-radius: 4px; margin-top: 6px;
      }
      .menu-item-warning svg { flex-shrink: 0; }
      .menu-item-allergens {
        font-size: 11px; color: var(--ink-faint); margin-top: 4px;
        font-family: var(--mono);
      }
      .menu-disclaimer {
        font-size: 11px; color: var(--ink-faint); font-style: italic;
        margin-top: 16px; line-height: 1.4;
      }

      /* ── Shared chips (Design D + legacy) ──────────────────────────── */
      .v2-chips { display: flex; flex-wrap: wrap; gap: 6px; }
      .v2-chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 13px; min-height: 40px;
        background: white; border: 1px solid #D0CCC5;
        border-radius: 8px; font-family: var(--display); font-size: 13px;
        font-weight: 500; color: var(--ink);
        cursor: pointer; white-space: nowrap;
        -webkit-tap-highlight-color: transparent;
        transition: border-color 80ms, background 80ms, color 80ms;
      }
      .v2-chip:active { transform: scale(0.96); }
      .v2-chip[data-active="true"] { background: #0A0A0A; border-color: #0A0A0A; color: #fff; }
      .chip-sub {
        font-family: var(--mono); font-size: 10px;
        letter-spacing: 0.06em; color: inherit; opacity: 0.65;
      }
      .v2-chip[data-active="true"] .chip-sub { opacity: 0.75; }
      .v2-textarea {
        width: 100%; padding: 2px 0; margin: 0;
        background: transparent; border: none;
        font-family: var(--display); font-size: 14px;
        color: var(--ink); resize: none; outline: none;
        min-height: 26px; overflow: hidden; field-sizing: content;
      }
      .v2-textarea::placeholder { color: var(--ink-faint); }

      /* ── Design D: Collapsing sections + Sticky bar ─────────────────── */
      .d-sections { display: grid; gap: 10px; padding-bottom: 130px; }
      .d-section-open {
        background: white; border: 1.5px solid var(--ink);
        border-radius: 12px; padding: 14px 14px 16px;
      }
      .d-section-label {
        display: flex; align-items: center; gap: 6px;
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.15em;
        font-weight: 600; text-transform: uppercase;
        color: var(--ink-faint); margin-bottom: 10px;
      }
      .d-section-label-opt { font-weight: 400; font-size: 8px; opacity: 0.8; }
      .d-row {
        width: 100%; display: flex; align-items: center; gap: 10px;
        text-align: left; background: white; border: 1px solid var(--border);
        border-radius: 12px; padding: 13px 14px;
        cursor: pointer; transition: border-color 0.12s;
        font-family: var(--display); color: var(--ink); font-size: 14px;
      }
      .d-row:hover { border-color: #C0BCB5; }
      .d-row-check { color: var(--accent); font-size: 13px; line-height: 1; flex-shrink: 0; }
      .d-row-spacer { width: 13px; flex-shrink: 0; }
      .d-row-value { font-weight: 600; flex: 1; }
      .d-row-empty { color: var(--ink-muted); flex: 1; display: flex; align-items: center; gap: 5px; }
      .d-row-opt { font-size: 11px; color: var(--ink-faint); }
      .d-row-action {
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.10em;
        text-transform: uppercase; color: var(--ink-faint); margin-left: auto; flex-shrink: 0;
      }
      .d-skip {
        background: none; border: none; padding: 10px 2px 0;
        font-family: var(--display); font-size: 13px; color: var(--ink-muted);
        cursor: pointer;
      }
      .d-skip:hover { color: var(--ink); }
      .d-done {
        background: none; border: none; padding: 10px 2px 0;
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.10em;
        text-transform: uppercase; color: var(--accent); cursor: pointer;
      }

      /* Sticky summary bar */
      .d-sticky {
        position: sticky; bottom: 0;
        background: white; border-top: 1px solid var(--border);
        padding: 12px 0 calc(env(safe-area-inset-bottom, 0px) + 8px);
        display: flex; align-items: center; gap: 12px;
        margin-top: 4px;
      }
      .d-sticky-price { flex-shrink: 0; min-width: 80px; }
      .d-sticky-label {
        font-family: var(--mono); font-size: 8.5px; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--ink-faint);
      }
      .d-sticky-total {
        font-family: var(--display); font-size: 20px; font-weight: 700;
        color: var(--ink); line-height: 1.1;
      }
      .d-sticky-sub { font-size: 10px; color: var(--ink-muted); margin-top: 1px; }
      .d-sticky-cta { flex: 1; display: flex; flex-direction: column; gap: 6px; }
      .d-cta-incomplete {
        width: 100%; padding: 13px 14px; background: transparent;
        color: var(--ink-muted); border: 1.5px dashed #CFCBC1;
        border-radius: 10px; font-family: var(--mono); font-size: 10px;
        letter-spacing: 0.12em; text-transform: uppercase;
        font-weight: 500; cursor: default; text-align: center;
      }
      .d-cta-complete {
        width: 100%; padding: 13px 14px; background: #0A0A0A; color: white;
        border: none; border-radius: 10px;
        font-family: var(--display); font-size: 14px; font-weight: 700;
        cursor: pointer; text-align: center;
        transition: background 0.14s; -webkit-tap-highlight-color: transparent;
      }
      .d-cta-complete:hover { background: #2A2A2A; }
      .d-cta-complete:active { background: var(--accent); }

      /* ── Chip selection pulse ────────────────────────────────────────── */
      @keyframes chip-active-pulse {
        0%   { transform: scale(1); }
        40%  { transform: scale(0.96); }
        100% { transform: scale(1); }
      }
      .v2-chip[data-active="true"] { animation: chip-active-pulse var(--bf-feedback) var(--bf-ease); }

      /* ── Section card enter / leave — max-height + opacity für ruckelfreie Höhen-Animation */
      .d-section-open { overflow: hidden; }

      .sect-enter {
        overflow: hidden;
        transition: opacity var(--bf-open) var(--bf-ease),
                    transform var(--bf-open) var(--bf-ease),
                    max-height var(--bf-open) var(--bf-ease);
      }
      .sect-enter-start { opacity: 0; transform: translateY(-4px); max-height: 0; }
      .sect-enter-end   { opacity: 1; transform: translateY(0);    max-height: 700px; }

      .sect-leave {
        overflow: hidden;
        transition: opacity var(--bf-collapse) var(--bf-ease),
                    max-height var(--bf-collapse) var(--bf-ease),
                    padding-top var(--bf-collapse) var(--bf-ease),
                    padding-bottom var(--bf-collapse) var(--bf-ease);
      }
      .sect-leave-start { opacity: 1; max-height: 700px; }
      .sect-leave-end   { opacity: 0; max-height: 0; padding-top: 0; padding-bottom: 0; }

      /* Collapsed confirmation row enter */
      .row-in       { transition: opacity 180ms var(--bf-ease); }
      .row-in-start { opacity: 0; }
      .row-in-end   { opacity: 1; }

      @media (prefers-reduced-motion: reduce) {
        .v2-chip, .d-cta-complete, .filter-chip, .tab-btn { transition: none; }
        .v2-chip[data-active="true"] { animation: none; }
        .sect-enter, .sect-leave, .row-in { transition: none; }
      }
    </style>
  </head>
  <body>
    <a class="close-btn" href={backHref} data-astro-reload aria-label="Schließen">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </a>

    <div class="page">
      <div class="hero g-hero-dot">
        <span class="eyebrow">{l.eyebrow}</span>
        <h1 class="title">{l.title}<span class="accent">{l.titleAccent}</span></h1>
        <p class="subtitle">{l.subtitle}</p>
      </div>

      <div x-data={`breakfast(${JSON.stringify(sheetData)})`} x-cloak>

        <!-- Tabs: nur wenn Menü-Einträge vorhanden -->
        <div class="tabs" x-show="menuItems.length > 0">
          <button type="button" class="tab-btn" :data-active="tab === 'main'" @click="tab = 'main'">
            <span x-text="reservationEnabled ? labels.menuTabReservation : labels.menuTabInfo"></span>
          </button>
          <button type="button" class="tab-btn" :data-active="tab === 'menu'" @click="tab = 'menu'">
            <span x-text="labels.menuTabMenu"></span>
          </button>
        </div>

        <!-- ── Haupt-Tab ──────────────────────────────────────────────── -->
        <div x-show="tab === 'main'">

          <!-- View: Status (existingBooking vorhanden) -->
          <template x-if="view === 'status'">
            <div class="status-card">
              <div class="status-icon" :class="statusInfo.iconClass">
                <template x-if="statusInfo.icon === 'check'">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </template>
                <template x-if="statusInfo.icon === 'clock'">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="9"/>
                    <polyline points="12 7 12 12 16 14"/>
                  </svg>
                </template>
                <template x-if="statusInfo.icon === 'cross'">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                  </svg>
                </template>
              </div>
              <p class="status-title" x-text="statusInfo.title"></p>
              <p class="status-sub"   x-text="statusInfo.sub"></p>
              <div class="summary-card">
                <div class="summary-row">
                  <span class="summary-label" x-text="labels.bookingDate"></span>
                  <span class="summary-value" x-text="formatDate(existingBooking.details.date)"></span>
                </div>
                <div class="summary-row">
                  <span class="summary-label" x-text="labels.bookingTime"></span>
                  <span class="summary-value" x-text="existingBooking.details.time"></span>
                </div>
                <div class="summary-row">
                  <span class="summary-label" x-text="labels.bookingPeople"></span>
                  <span class="summary-value" x-text="existingBooking.details.people"></span>
                </div>
                <div class="summary-row"
                  x-show="existingBooking.details.table_preference && existingBooking.details.table_preference !== 'any'">
                  <span class="summary-label" x-text="labels.bookingTable"></span>
                  <span class="summary-value" x-text="tableLabelFor(existingBooking.details.table_preference)"></span>
                </div>
                <div class="summary-row" x-show="existingBooking.details.delivery">
                  <span class="summary-label" x-text="labels.bookingDelivery"></span>
                  <span class="summary-value" x-text="existingBooking.details.delivery === 'room' ? (labels.deliveryRoom + (existingBooking.details.room_number ? ' ' + existingBooking.details.room_number : '')) : labels.deliveryTable"></span>
                </div>
              </div>
              <button type="button" class="rebook-btn"
                x-show="existingBooking.status === 'cancelled' || existingBooking.status === 'confirmed'"
                x-text="labels.rebookBtn"
                @click="startRebook()">
              </button>
            </div>
          </template>

          <!-- View: Formular (Design D) -->
          <template x-if="view === 'form'">
            <div>
              <template x-if="availableDates.length === 0">
                <div class="info-card">
                  <div class="info-row">
                    <div class="info-label" x-text="labels.infoTimeLabel"></div>
                    <div class="info-value" x-text="labels.noFutureDates"></div>
                  </div>
                  <div class="info-row" x-show="location">
                    <div class="info-label" x-text="labels.infoLocationLabel"></div>
                    <div class="info-value" x-text="location"></div>
                  </div>
                </div>
              </template>

              <!-- Design D: Collapsing Sections + Sticky Summary -->
              <div x-show="availableDates.length > 0">
                <div class="d-sections">

                  <!-- DATUM -->
                  <div data-dsection="datum">
                    <div class="d-section-open"
                      x-show="dOpen === 'datum'"
                      x-transition:enter="sect-enter"
                      x-transition:enter-start="sect-enter-start"
                      x-transition:enter-end="sect-enter-end"
                      x-transition:leave="sect-leave"
                      x-transition:leave-start="sect-leave-start"
                      x-transition:leave-end="sect-leave-end">
                      <div class="d-section-label" x-text="labels.labelDatum"></div>
                      <div class="v2-chips">
                        <template x-for="(date, i) in availableDates" :key="date.iso">
                          <button type="button" class="v2-chip"
                            :data-active="form.date === date.iso"
                            @click="setDate(date.iso); dNext('datum')">
                            <span x-text="dateLabels[i]"></span>
                            <span class="chip-sub" x-text="formatDateShort(date.iso)"></span>
                          </button>
                        </template>
                      </div>
                    </div>
                    <button type="button" class="d-row"
                      x-show="dOpen !== 'datum'"
                      x-transition:enter="row-in"
                      x-transition:enter-start="row-in-start"
                      x-transition:enter-end="row-in-end"
                      @click="dOpen = 'datum'">
                      <span class="d-row-check" x-show="form.date">✓</span>
                      <span class="d-row-spacer" x-show="!form.date"></span>
                      <span class="d-row-value" x-show="form.date" x-text="dSummaryDate"></span>
                      <span class="d-row-empty" x-show="!form.date" x-text="labels.ctaPickDate"></span>
                      <span class="d-row-action" x-text="form.date ? labels.sectionAendern : labels.sectionWaehlen"></span>
                    </button>
                  </div>

                  <!-- PERSONEN -->
                  <div data-dsection="personen">
                    <div class="d-section-open"
                      x-show="dOpen === 'personen'"
                      x-transition:enter="sect-enter"
                      x-transition:enter-start="sect-enter-start"
                      x-transition:enter-end="sect-enter-end"
                      x-transition:leave="sect-leave"
                      x-transition:leave-start="sect-leave-start"
                      x-transition:leave-end="sect-leave-end">
                      <div class="d-section-label" x-text="labels.labelPersonen"></div>
                      <div class="v2-chips">
                        <template x-for="n in peopleOptions" :key="n">
                          <button type="button" class="v2-chip"
                            :data-active="form.people === n"
                            @click="form.people = n; dNext('personen')">
                            <span x-text="n"></span>
                          </button>
                        </template>
                        <button type="button" class="v2-chip"
                          :data-active="form.people > 4"
                          @click="form.people = 5; dNext('personen')">5+</button>
                      </div>
                    </div>
                    <button type="button" class="d-row"
                      x-show="dOpen !== 'personen'"
                      x-transition:enter="row-in"
                      x-transition:enter-start="row-in-start"
                      x-transition:enter-end="row-in-end"
                      @click="dOpen = 'personen'">
                      <span class="d-row-check">✓</span>
                      <span class="d-row-value" x-text="dSummaryPeople"></span>
                      <span class="d-row-action" x-text="labels.sectionAendern"></span>
                    </button>
                  </div>

                  <!-- UHRZEIT -->
                  <div data-dsection="uhrzeit">
                    <div class="d-section-open"
                      x-show="dOpen === 'uhrzeit'"
                      x-transition:enter="sect-enter"
                      x-transition:enter-start="sect-enter-start"
                      x-transition:enter-end="sect-enter-end"
                      x-transition:leave="sect-leave"
                      x-transition:leave-start="sect-leave-start"
                      x-transition:leave-end="sect-leave-end">
                      <div class="d-section-label" x-text="labels.labelUhrzeit"></div>
                      <div class="v2-chips">
                        <template x-for="slot in slots" :key="slot">
                          <button type="button" class="v2-chip"
                            :data-active="form.time === slot"
                            @click="form.time = slot; dNext('uhrzeit')"
                            x-text="slot">
                          </button>
                        </template>
                        <span x-show="slots.length === 0" style="font-size:13px;color:var(--ink-muted)" x-text="labels.noFutureDates"></span>
                      </div>
                    </div>
                    <button type="button" class="d-row"
                      x-show="dOpen !== 'uhrzeit'"
                      x-transition:enter="row-in"
                      x-transition:enter-start="row-in-start"
                      x-transition:enter-end="row-in-end"
                      @click="dOpen = 'uhrzeit'">
                      <span class="d-row-check" x-show="form.time">✓</span>
                      <span class="d-row-spacer" x-show="!form.time"></span>
                      <span class="d-row-value" x-show="form.time" x-text="form.time"></span>
                      <span class="d-row-empty" x-show="!form.time" x-text="labels.ctaPickTime"></span>
                      <span class="d-row-action" x-text="form.time ? labels.sectionAendern : labels.sectionWaehlen"></span>
                    </button>
                  </div>

                  <!-- TISCH (optional) -->
                  <div data-dsection="tisch">
                    <div class="d-section-open"
                      x-show="dOpen === 'tisch'"
                      x-transition:enter="sect-enter"
                      x-transition:enter-start="sect-enter-start"
                      x-transition:enter-end="sect-enter-end"
                      x-transition:leave="sect-leave"
                      x-transition:leave-start="sect-leave-start"
                      x-transition:leave-end="sect-leave-end">
                      <div class="d-section-label">
                        <span x-text="labels.labelTisch"></span>
                        <span class="d-section-label-opt" x-text="'· ' + labels.labelOptional"></span>
                      </div>
                      <div class="v2-chips">
                        <template x-for="opt in tableOptions" :key="opt.value">
                          <button type="button" class="v2-chip"
                            :data-active="form.table_preference === opt.value"
                            @click="form.table_preference = opt.value; dNext('tisch')"
                            x-text="opt.label">
                          </button>
                        </template>
                      </div>
                    </div>
                    <button type="button" class="d-row"
                      x-show="dOpen !== 'tisch'"
                      x-transition:enter="row-in"
                      x-transition:enter-start="row-in-start"
                      x-transition:enter-end="row-in-end"
                      @click="dOpen = 'tisch'">
                      <span class="d-row-check" x-show="dVisited.includes('tisch')">✓</span>
                      <span class="d-row-spacer" x-show="!dVisited.includes('tisch')"></span>
                      <span class="d-row-value" x-show="dVisited.includes('tisch')" x-text="tableLabelFor(form.table_preference)"></span>
                      <span class="d-row-empty" x-show="!dVisited.includes('tisch')">
                        <span x-text="labels.labelTisch"></span>
                        <span class="d-row-opt" x-text="labels.labelOptional"></span>
                      </span>
                      <span class="d-row-action" x-text="dVisited.includes('tisch') ? labels.sectionAendern : labels.sectionWaehlen"></span>
                    </button>
                  </div>

                  <!-- ORT (nur wenn roomServiceEnabled) -->
                  <div x-show="roomServiceEnabled" data-dsection="ort">
                    <div class="d-section-open"
                      x-show="roomServiceEnabled && dOpen === 'ort'"
                      x-transition:enter="sect-enter"
                      x-transition:enter-start="sect-enter-start"
                      x-transition:enter-end="sect-enter-end"
                      x-transition:leave="sect-leave"
                      x-transition:leave-start="sect-leave-start"
                      x-transition:leave-end="sect-leave-end">
                      <div class="d-section-label" x-text="labels.labelOrt"></div>
                      <div class="v2-chips">
                        <button type="button" class="v2-chip"
                          :data-active="form.delivery === 'table'"
                          @click="form.delivery = 'table'; dNext('ort')"
                          x-text="labels.deliveryTable">
                        </button>
                        <button type="button" class="v2-chip"
                          :data-active="form.delivery === 'room'"
                          @click="form.delivery = 'room'; dNext('ort')"
                          x-text="labels.deliveryRoom">
                        </button>
                      </div>
                    </div>
                    <button type="button" class="d-row"
                      x-show="roomServiceEnabled && dOpen !== 'ort'"
                      x-transition:enter="row-in"
                      x-transition:enter-start="row-in-start"
                      x-transition:enter-end="row-in-end"
                      @click="dOpen = 'ort'">
                      <span class="d-row-check">✓</span>
                      <span class="d-row-value" x-text="form.delivery === 'room' ? labels.deliveryRoom : labels.deliveryTable"></span>
                      <span class="d-row-action" x-text="labels.sectionAendern"></span>
                    </button>
                  </div>

                  <!-- HINWEIS (optional) -->
                  <div data-dsection="hinweis">
                    <div class="d-section-open"
                      x-show="dOpen === 'hinweis'"
                      x-transition:enter="sect-enter"
                      x-transition:enter-start="sect-enter-start"
                      x-transition:enter-end="sect-enter-end"
                      x-transition:leave="sect-leave"
                      x-transition:leave-start="sect-leave-start"
                      x-transition:leave-end="sect-leave-end">
                      <div class="d-section-label">
                        <span x-text="labels.labelHinweis"></span>
                        <span class="d-section-label-opt" x-text="'· ' + labels.labelOptional"></span>
                      </div>
                      <textarea class="v2-textarea" rows="2"
                        :placeholder="labels.notesPlaceholder"
                        x-model="form.notes"
                        @input="$el.style.height='auto'; $el.style.height=$el.scrollHeight+'px'">
                      </textarea>
                      <button type="button" class="d-done" @click="dFinishHinweis()"
                        x-text="form.notes.trim() ? labels.sectionFertig : labels.sectionUeberspringen">
                      </button>
                    </div>
                    <button type="button" class="d-row"
                      x-show="dOpen !== 'hinweis'"
                      x-transition:enter="row-in"
                      x-transition:enter-start="row-in-start"
                      x-transition:enter-end="row-in-end"
                      @click="dOpen = 'hinweis'">
                      <span class="d-row-check" x-show="form.notes.trim() || dVisited.includes('hinweis')">✓</span>
                      <span class="d-row-spacer" x-show="!form.notes.trim() && !dVisited.includes('hinweis')"></span>
                      <span class="d-row-value" x-show="form.notes.trim() || dVisited.includes('hinweis')" x-text="dSummaryHinweis"></span>
                      <span class="d-row-empty" x-show="!form.notes.trim() && !dVisited.includes('hinweis')">
                        <span x-text="labels.labelHinweis"></span>
                        <span class="d-row-opt" x-text="labels.labelOptional"></span>
                      </span>
                      <span class="d-row-action" x-text="form.notes.trim() || dVisited.includes('hinweis') ? labels.sectionAendern : labels.sectionWaehlen"></span>
                    </button>
                  </div>

                </div>

                <div x-show="errorMsg" class="booking-error" x-text="errorMsg" style="margin-bottom:8px"></div>

                <!-- Sticky summary + CTA -->
                <div class="d-sticky">
                  <div class="d-sticky-price">
                    <template x-if="totalPrice !== null && priceCents > 0">
                      <div>
                        <div class="d-sticky-label" x-text="labels.labelGesamt"></div>
                        <div class="d-sticky-total" x-text="formatPrice(totalPrice)"></div>
                        <div class="d-sticky-sub" x-show="form.people > 0">
                          <span x-text="formatPrice(priceCents) + ' / ' + (form.people === 1 ? labels.bookingPeopleSingular : labels.bookingPeople)"></span>
                          <span x-show="roomServiceEnabled && form.delivery === 'room' && roomServiceFeeCents > 0" x-text="' · ' + labels.priceRoomFee"></span>
                        </div>
                      </div>
                    </template>
                    <template x-if="priceCents === 0">
                      <div class="d-sticky-label" x-text="labels.buffetIncluded"></div>
                    </template>
                  </div>
                  <div class="d-sticky-cta">
                    <button type="button" class="d-cta-incomplete"
                      x-show="!canSubmit && !submitting"
                      x-text="!form.date ? labels.ctaPickDate : (!form.time ? labels.ctaPickTime : labels.submit)">
                    </button>
                    <button type="button" class="d-cta-complete"
                      x-show="canSubmit && !submitting"
                      @click="submitBooking()"
                      x-text="roomServiceEnabled && form.delivery === 'room' ? labels.submitRoom : labels.submit">
                    </button>
                    <button type="button" class="d-cta-complete"
                      x-show="submitting"
                      disabled
                      style="opacity:0.6;cursor:not-allowed"
                      x-text="labels.submitting">
                    </button>
                  </div>
                </div>

              </div>
            </div>
          </template>

          <!-- View: Info (Reservierung deaktiviert) -->
          <template x-if="view === 'info'">
            <div class="info-card">
              <div class="info-row">
                <div class="info-label" x-text="labels.infoTimeLabel"></div>
                <div class="info-value" x-text="labels.infoTimeValue"></div>
              </div>
              <div class="info-row">
                <div class="info-label" x-text="labels.infoLocationLabel"></div>
                <div class="info-value" x-text="location"></div>
              </div>
              <div class="info-row" x-show="includedText">
                <div class="info-label" x-text="labels.infoIncludedLabel"></div>
                <div class="info-value info-value--multi" x-text="includedText"></div>
              </div>
            </div>
          </template>

        </div>

        <!-- ── Menü-Tab ───────────────────────────────────────────────── -->
        <div x-show="tab === 'menu'">
          <div class="filter-section">
            <div class="filter-title" x-text="labels.menuFilterTitle"></div>
            <p class="filter-hint" x-text="labels.menuFilterHint"></p>
            <div class="filter-chips">
              <template x-for="key in allergenKeys" :key="key">
                <button type="button" class="filter-chip"
                  :class="{ active: selectedAllergens.includes(key) }"
                  @click="toggleAllergen(key)"
                  x-text="allergenLabels[key]">
                </button>
              </template>
            </div>
            <button type="button" class="filter-reset"
              x-show="selectedAllergens.length > 0"
              x-text="labels.menuFilterHideShow"
              @click="clearAllergenFilter()">
            </button>
          </div>

          <template x-if="menuItems.length === 0">
            <div class="menu-empty" x-text="labels.menuEmpty"></div>
          </template>

          <template x-for="(items, category) in groupedMenuItems" :key="category">
            <div class="menu-category">
              <div class="menu-category-title" x-text="category"></div>
              <div>
                <template x-for="item in items" :key="item.id">
                  <div class="menu-item">
                    <div class="menu-item-header">
                      <div class="menu-item-name" x-text="item.name"></div>
                      <div class="menu-item-flags">
                        <template x-if="item.isVegan">
                          <span class="menu-flag" x-text="labels.menuFlagVegan"></span>
                        </template>
                        <template x-if="!item.isVegan && item.isVegetarian">
                          <span class="menu-flag" x-text="labels.menuFlagVegetarian"></span>
                        </template>
                        <template x-if="item.isOrganic">
                          <span class="menu-flag organic" x-text="labels.menuFlagOrganic"></span>
                        </template>
                      </div>
                    </div>
                    <div class="menu-item-desc" x-text="item.description" x-show="item.description"></div>
                    <template x-if="getMatchingAllergens(item).length > 0">
                      <div class="menu-item-warning">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M12 9v4m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.74-3l-6.93-12a2 2 0 0 0-3.48 0L3.34 16a2 2 0 0 0 1.73 3z"/>
                        </svg>
                        <span>
                          <span x-text="labels.menuWarningPrefix"></span>
                          <span x-text="getMatchingAllergens(item).map(k => allergenLabels[k]).join(', ')"></span>
                        </span>
                      </div>
                    </template>
                    <template x-if="item.allergens.length > 0 && selectedAllergens.length === 0">
                      <div class="menu-item-allergens">
                        <span x-text="labels.menuAllergensPrefix"></span>
                        <span x-text="item.allergens.map(k => allergenLabels[k]).join(', ')"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
            </div>
          </template>

          <div class="menu-disclaimer" x-text="labels.menuDisclaimer"></div>
        </div>

      </div>
    </div>

    <script>
      import Alpine from 'alpinejs';

      Alpine.data('breakfast', (initial: any) => ({
        view: initial.existingBooking
          ? 'status'
          : (initial.reservationEnabled === false ? 'info' : 'form'),
        reservationEnabled: initial.reservationEnabled !== false,
        roomServiceEnabled: initial.roomServiceEnabled === true,
        priceCents: initial.priceCents ?? null,
        roomServiceFeeCents: initial.roomServiceFeeCents ?? 0,
        hotelCurrency: initial.hotelCurrency ?? 'EUR',
        slotsPerWeekday: initial.slotsPerWeekday ?? null,
        dOpen: 'datum' as string | null,
        dVisited: [] as string[],
        includedText: initial.includedText || '',
        location: initial.location || '',

        menuItems: initial.menuItems || [],
        allergenLabels: initial.allergenLabels || {},
        allergenKeys: initial.allergenKeys || [],
        selectedAllergens: [] as string[],
        tab: 'main' as 'main' | 'menu',

        stayRangeDates: initial.stayRangeDates,
        allSlots: initial.allSlots,
        startTime: initial.startTime,
        endTime: initial.endTime,
        peopleOptions: initial.peopleOptions,
        tableOptions: initial.tableOptions,
        labels: initial.labels,
        accessToken: initial.accessToken,
        existingBooking: initial.existingBooking,
        lang: initial.lang,
        nowTick: 0,

        form: {
          date: '',
          people: 2,
          time: '',
          table_preference: 'any',
          delivery: 'table' as 'table' | 'room',
          room_number: String(initial.roomNumber ?? ''),
          notes: '',
        },
        submitting: false,
        errorMsg: '',

        init() {
          const firstAvail = this.availableDates[0];
          if (firstAvail) this.form.date = firstAvail.iso;
          setInterval(() => {
            this.nowTick = Date.now();
            if (!this.availableDates.find((d: any) => d.iso === this.form.date)) {
              const newFirst = this.availableDates[0];
              this.form.date = newFirst ? newFirst.iso : '';
              this.form.time = '';
            }
            if (this.form.time && !this.slots.includes(this.form.time)) {
              this.form.time = '';
            }
          }, 60000);
        },

        toggleAllergen(key: string) {
          if (this.selectedAllergens.includes(key)) {
            this.selectedAllergens = this.selectedAllergens.filter((k: string) => k !== key);
          } else {
            this.selectedAllergens = [...this.selectedAllergens, key];
          }
        },

        clearAllergenFilter() { this.selectedAllergens = []; },

        getMatchingAllergens(item: any) {
          return item.allergens.filter((a: string) => this.selectedAllergens.includes(a));
        },

        get groupedMenuItems() {
          const groups: Record<string, any[]> = {};
          this.menuItems.forEach((item: any) => {
            const cat = item.category || 'Allgemein';
            if (!groups[cat]) groups[cat] = [];
            groups[cat].push(item);
          });
          return groups;
        },

        get todayIso() {
          this.nowTick;
          const d = new Date();
          return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        },

        slotsForDate(dateIso: string) {
          const baseSlots: string[] = (() => {
            if (this.slotsPerWeekday) {
              // Use T12:00:00 to avoid DST edge cases when extracting weekday
              const wkIdx = new Date(dateIso + 'T12:00:00').getDay();
              const wkKey = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'][wkIdx];
              return this.slotsPerWeekday[wkKey] ?? [];
            }
            return this.allSlots;
          })();
          if (dateIso !== this.todayIso) return baseSlots;
          const now = new Date();
          const nowMin = now.getHours() * 60 + now.getMinutes();
          return baseSlots.filter((slot: string) => {
            const [h, m] = slot.split(':').map(Number);
            return h * 60 + m > nowMin;
          });
        },

        get availableDates() {
          const today = this.todayIso;
          return this.stayRangeDates
            .filter((d: any) => d.iso >= today)
            .filter((d: any) => this.slotsForDate(d.iso).length > 0)
            .slice(0, 5);
        },

        get slots() { return this.slotsForDate(this.form.date); },

        get dateLabels() {
          const today = new Date();
          const todayIso = this.todayIso;
          const tomorrow = new Date(today);
          tomorrow.setDate(tomorrow.getDate() + 1);
          const tomIso = `${tomorrow.getFullYear()}-${String(tomorrow.getMonth()+1).padStart(2,'0')}-${String(tomorrow.getDate()).padStart(2,'0')}`;
          const dayAfter = new Date(today);
          dayAfter.setDate(dayAfter.getDate() + 2);
          const dayAfterIso = `${dayAfter.getFullYear()}-${String(dayAfter.getMonth()+1).padStart(2,'0')}-${String(dayAfter.getDate()).padStart(2,'0')}`;
          const localeMap: any = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES', it: 'it-IT', pt: 'pt-PT', nl: 'nl-NL', ru: 'ru-RU', ar: 'ar-SA', zh: 'zh-CN' };
          return this.availableDates.map((d: any) => {
            if (d.iso === todayIso) return this.labels.today;
            if (d.iso === tomIso)   return this.labels.tomorrow;
            if (d.iso === dayAfterIso) return this.labels.dayAfter;
            return new Date(d.iso).toLocaleDateString(localeMap[this.lang] || 'de-DE', { weekday: 'long' });
          });
        },

        get totalPrice(): number | null {
          if (this.priceCents === null || this.priceCents === 0) return null;
          const base = this.priceCents * this.form.people;
          return this.roomServiceEnabled && this.form.delivery === 'room'
            ? base + this.roomServiceFeeCents
            : base;
        },

        formatPrice(cents: number | null): string {
          if (cents === null) return '';
          return (cents / 100).toLocaleString('de-DE', { style: 'currency', currency: this.hotelCurrency });
        },

        get canSubmit() {
          if (!this.form.date || !this.form.time || this.form.people <= 0) return false;
          return true;
        },

        get statusInfo() {
          if (!this.existingBooking) return { iconClass: '', icon: '', title: '', sub: '' };
          const status = (this.existingBooking.status || 'pending').toLowerCase();
          if (status === 'confirmed') return { iconClass: 'confirmed', icon: 'check', title: this.labels.confirmedTitle, sub: this.labels.confirmedSub };
          if (status === 'cancelled') return { iconClass: 'cancelled', icon: 'cross', title: this.labels.cancelledTitle, sub: this.labels.cancelledSub };
          return { iconClass: 'pending', icon: 'clock', title: this.labels.pendingTitle, sub: this.labels.pendingSub };
        },

        formatDate(iso: string) {
          const localeMap: any = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES', it: 'it-IT', pt: 'pt-PT', nl: 'nl-NL', ru: 'ru-RU', ar: 'ar-SA', zh: 'zh-CN' };
          return new Date(iso).toLocaleDateString(localeMap[this.lang] || 'de-DE', { weekday: 'long', day: 'numeric', month: 'long' });
        },

        formatDateShort(iso: string) {
          const localeMap: any = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES', it: 'it-IT', pt: 'pt-PT', nl: 'nl-NL', ru: 'ru-RU', ar: 'ar-SA', zh: 'zh-CN' };
          return new Date(iso).toLocaleDateString(localeMap[this.lang] || 'de-DE', { day: '2-digit', month: 'short' });
        },

        tableLabelFor(value: string) {
          const opt = this.tableOptions.find((o: any) => o.value === value);
          return opt ? opt.label : value;
        },

        dNext(current: string) {
          const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? false;
          const alreadyVisited = this.dVisited.includes(current);
          // Phase a (--bf-feedback 200ms) + Phase b (pause 150ms) = 350ms
          setTimeout(() => {
            if (!this.dVisited.includes(current)) {
              this.dVisited = [...this.dVisited, current];
            }
            if (alreadyVisited) {
              // Re-edit: nur kollabieren, nicht zur nächsten Sektion springen
              this.dOpen = null;
              return;
            }
            const order = ['datum', 'personen', 'uhrzeit', 'tisch', 'ort', 'hinweis'];
            const idx = order.indexOf(current);
            let next: string | null = null;
            for (let i = idx + 1; i < order.length; i++) {
              if (order[i] === 'ort' && !this.roomServiceEnabled) continue;
              next = order[i];
              break;
            }
            this.dOpen = next;
            if (next) {
              // Phase c (--bf-collapse 300ms) abwarten, dann zur neuen Sektion scrollen
              setTimeout(() => {
                this.$nextTick(() => {
                  document.querySelector(`[data-dsection="${next}"]`)?.scrollIntoView({
                    behavior: reduced ? 'auto' : 'smooth',
                    block: 'nearest',
                  });
                });
              }, reduced ? 0 : 300);
            }
          }, reduced ? 300 : 350);
        },

        dFinishHinweis() {
          if (!this.dVisited.includes('hinweis')) this.dVisited = [...this.dVisited, 'hinweis'];
          this.dOpen = null;
        },

        get dSummaryDate() {
          if (!this.form.date) return '';
          const idx = (this.availableDates as any[]).findIndex((d: any) => d.iso === this.form.date);
          const label = idx >= 0 ? (this.dateLabels as any[])[idx] : '';
          const short = this.formatDateShort(this.form.date);
          return label ? `${label} · ${short}` : short;
        },

        get dSummaryPeople() {
          const n = this.form.people;
          if (!n) return '';
          return `${n} ${n === 1 ? this.labels.bookingPeopleSingular : this.labels.bookingPeople}`;
        },

        get dSummaryHinweis() {
          const t = this.form.notes.trim();
          if (!t) return this.labels.noHinweis;
          return t.length > 40 ? t.slice(0, 40) + '…' : t;
        },

        startRebook() {
          this.form = { date: (this.availableDates as any[])[0]?.iso || '', people: 2, time: '', table_preference: 'any', delivery: 'table' as const, room_number: String(initial.roomNumber ?? ''), notes: '' };
          this.dOpen = 'datum';
          this.dVisited = [];
          this.existingBooking = null;
          this.view = 'form';
        },

        setDate(iso: string) {
          this.form.date = iso;
          if (this.form.time && !this.slots.includes(this.form.time)) this.form.time = '';
        },

        async submitBooking() {
          if (!this.canSubmit || this.submitting) return;
          this.submitting = true;
          this.errorMsg = '';
          try {
            const resp = await fetch('/api/bookings/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_token: this.accessToken,
                type: 'breakfast',
                details: {
                  date: this.form.date,
                  time: this.form.time,
                  people: this.form.people,
                  table_preference: this.form.table_preference,
                  delivery: this.roomServiceEnabled ? this.form.delivery : 'table',
                  room_number: this.form.delivery === 'room' ? this.form.room_number || null : null,
                  notes: this.form.notes || null,
                },
              }),
            });
            const data = await resp.json();
            if (!data.ok) {
              this.errorMsg = `${this.labels.errorPrefix}: ${data.error || 'unknown'}`;
              this.submitting = false;
              return;
            }
            this.existingBooking = {
              id: data.booking.id,
              status: 'pending',
              details: {
                date: this.form.date,
                time: this.form.time,
                people: this.form.people,
                table_preference: this.form.table_preference,
                delivery: this.roomServiceEnabled ? this.form.delivery : 'table',
                room_number: this.form.delivery === 'room' ? this.form.room_number || null : null,
                notes: this.form.notes,
              },
            };
            this.view = 'status';
            this.submitting = false;
          } catch (e: any) {
            this.errorMsg = `${this.labels.errorPrefix}: ${e.message || 'network error'}`;
            this.submitting = false;
          }
        },
      }));

      Alpine.start();
    </script>
  </body>
</html>
