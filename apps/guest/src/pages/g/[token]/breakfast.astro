    menuDisclaimer: 'Informations fournies par l\'hôtel — en cas de doute, parlez au service.',
  },
  es: {
    pageTitle: `${hotel.name} · Desayuno`,
    eyebrow: '— Desayuno —',
    title: reservationEnabled ? 'Reservar una ' : 'Desayuno ',
    titleAccent: reservationEnabled ? 'mesa.' : 'con nosotros.',
    subtitle: reservationEnabled ? `Encantados de recibirte — ${location}.` : 'Pásate — sin mesa, sin reserva.',
    whenLabel: '¿Cuándo?', today: 'Hoy', tomorrow: 'Mañana', dayAfter: 'Pasado mañana',
    peopleLabel: '¿Cuántas personas?', timeLabel: '¿A qué hora?', tableLabel: '¿Preferencia de mesa?',
    tableInside: 'Interior', tableOutside: 'Exterior', tableGarden: 'En el jardín', tableAny: 'Sin preferencia',
    notesLabel: '¿Algo que debamos saber?', notesPlaceholder: 'Ej. sin gluten, cumpleaños, …',
    submit: 'Reservar', submitting: 'Reservando…', errorPrefix: 'Error',
    pendingTitle: 'Tenemos tu solicitud.', pendingSub: `${conciergeName} confirma enseguida.`,
