import { loadStayByToken, loadBookingsForStay, loadActiveBreakfastItems } from '@retaha/db';
import { normalizeLang, pickI18n, asLanguageCode, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import { isShowcaseToken, findShowcaseSessionByToken } from '../../../lib/showcase/session';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';

const { token } = Astro.params;
if (!token) return new Response('Token fehlt', { status: 400 });

const url = new URL(Astro.request.url);
const persona = url.searchParams.get('persona') ?? 'in_house';
const langParam = url.searchParams.get('lang');

// Showcase- oder Echtdaten laden
let ctx: any = null;
let showcaseMode = false;
if (isShowcaseToken(token)) {
  showcaseMode = true;
  const showcase = await findShowcaseSessionByToken(token);
  if (showcase) {
    const sbSr = createSupabaseServiceRoleInstance();
    const [{ data: hotelRow }, { data: settingsRow }] = await Promise.all([
      sbSr.from('hotels').select('id, name, default_language, enabled_languages, brand_primary').eq('id', showcase.hotel_id).single(),
      sbSr.from('hotel_settings').select('*').eq('hotel_id', showcase.hotel_id).single(),
    ]);
    if (hotelRow) {
      const now = new Date();
      const checkIn = new Date(now);
      checkIn.setUTCHours(14, 0, 0, 0);
      const checkOut = new Date(checkIn);
      checkOut.setUTCDate(checkOut.getUTCDate() + 1);
      checkOut.setUTCHours(11, 0, 0, 0);
      ctx = {
        stay: {
          id: showcase.id,
          check_in: checkIn.toISOString(),
          check_out: checkOut.toISOString(),
        },
        guest: { language: hotelRow.default_language ?? 'de' },
        hotel: hotelRow,
        settings: settingsRow ?? {},
      };
    }
  }
} else {
  const loaded = token ? await loadStayByToken(token) : null;
  if (loaded) {
    const existingSession = await getStaySession(Astro.cookies);
    if (!existingSession || existingSession.stay_id !== loaded.stay.id) {
      await setStaySessionCookie(Astro.cookies, {
        stay_id: loaded.stay.id,
        hotel_id: loaded.hotel.id,
        check_out_utc: loaded.stay.check_out,
        is_showcase: false,
      });
    }
    ctx = loaded;
  }
}

if (!ctx) return Astro.redirect(`/g/${token}`);

const { stay, guest, hotel, settings } = ctx;

// Sprach-Resolution
const lang: Lang = normalizeLang(
  langParam ?? (guest as any)?.language ?? (hotel as any).default_language ?? 'de'
) as Lang;
const lk = lang;

// Breakfast-Einstellungen
const startTime: string = (settings as any).breakfast_start_time || '07:30:00';
const endTime: string   = (settings as any).breakfast_end_time   || '10:30:00';
const slotMinutes: number = (settings as any).breakfast_slot_minutes || 30;
const reservationEnabled: boolean = (settings as any).features?.breakfast !== false;
const roomServiceEnabled: boolean = (settings as any).breakfast_room_service_enabled === true;
const priceCents: number | null = (settings as any).breakfast_price_cents ?? null;
const roomServiceFeeCents: number = (settings as any).breakfast_room_service_fee_cents ?? 0;
const roomNumber: string | null = showcaseMode ? null : ((ctx as any).room?.room_number ?? null);

const hotelDefaultLang = asLanguageCode((hotel as any).default_language ?? 'de');
const location = pickI18n((settings as any).breakfast_location_i18n, hotelDefaultLang, lang) || '';
const includedText = pickI18n((settings as any).breakfast_included_i18n, hotelDefaultLang, lang) || '';
const conciergeName: string = (settings as any).eve_name || 'das Team';

// Menu-Items + existingBooking laden
const [menuItemsRaw, existingBookings] = await Promise.all([
  loadActiveBreakfastItems(hotel.id),
  showcaseMode ? Promise.resolve([]) : loadBookingsForStay(stay.id, 'breakfast'),
]);
const existingBooking = existingBookings[0] || null;

// Brand-Palette
const brandPrimary: string | null = (hotel as any).brand_primary ?? null;
const brandStyle = brandPrimary
  ? (() => { const p = computeBrandPalette(brandPrimary); return `--accent:${brandPrimary};--accent-soft:${p.soft};--accent-on:${p.onAccent}`; })()
  : undefined;

// Zurück-Link
const backHref = `/g/${token}?persona=${persona}${langParam ? `&lang=${langParam}` : ''}`;

// Helper: stay range dates (für Slot-Picker)
const toLocalIso = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

const stayRangeDates: { iso: string }[] = [];
{
  if (showcaseMode) {
    // Showcase: always 3 rolling days regardless of check-in/out times so evening demos work.
    for (let i = 0; i < 3; i++) {
      const d = new Date();
      d.setDate(d.getDate() + i);
      stayRangeDates.push({ iso: toLocalIso(d) });
    }
  } else {
    const cursor = new Date(stay.check_in);
    const stayEnd = new Date(stay.check_out);
    while (cursor <= stayEnd) {
      stayRangeDates.push({ iso: toLocalIso(cursor) });
      cursor.setDate(cursor.getDate() + 1);
    }
  }
}

function generateSlots(start: string, end: string, step: number): string[] {
  const slots: string[] = [];
  const [sH, sM] = start.substring(0,5).split(':').map(Number);
  const [eH, eM] = end.substring(0,5).split(':').map(Number);
  const startMin = sH * 60 + sM;
  const endMin   = eH * 60 + eM;
  for (let t = startMin; t <= endMin - step; t += step) {
    slots.push(`${String(Math.floor(t/60)).padStart(2,'0')}:${String(t%60).padStart(2,'0')}`);
  }
  return slots;
}
const allSlots = generateSlots(startTime, endTime, slotMinutes);

