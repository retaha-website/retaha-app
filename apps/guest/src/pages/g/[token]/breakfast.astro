    infoLocationLabel: 'Ort', infoIncludedLabel: 'Was dich erwartet',
    menuTabReservation: 'Reservieren', menuTabInfo: 'Frühstück', menuTabMenu: 'Karte',
    menuFilterTitle: '— Allergene anzeigen —',
    menuFilterHint: 'Wähle deine Allergene aus — Speisen mit diesen Zutaten werden markiert.',
    menuFilterHideShow: 'Filter zurücksetzen',
    menuWarningPrefix: 'Enthält',
    menuFlagVegetarian: 'vegetarisch', menuFlagVegan: 'vegan', menuFlagOrganic: 'bio',
    menuAllergensPrefix: 'Allergene:', menuEmpty: 'Noch keine Speisen im Angebot.',
