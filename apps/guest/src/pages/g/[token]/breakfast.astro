    confirmedTitle: 'Reservierung bestätigt.', confirmedSub: 'Wir freuen uns auf dich.',
    cancelledTitle: 'Reservierung abgelehnt.', cancelledSub: 'Bitte sprich mit dem Empfang.',
    bookingDate: 'Tag', bookingTime: 'Uhrzeit', bookingPeople: 'Personen', bookingTable: 'Tisch',
    cancelBtn: 'Zurücknehmen', rebookBtn: 'Neuen Tisch reservieren',
