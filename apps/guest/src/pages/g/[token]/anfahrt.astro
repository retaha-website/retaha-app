---
// Anfahrt & Check-in — Info-Karte (Anreise-Phase)

import { loadGuestCtx } from '../../../lib/showcase/guest-ctx';
import { normalizeLang, type Lang } from '@retaha/i18n';
import { setStaySessionCookie, getStaySession, computeBrandPalette, createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';

const { token } = Astro.params;
if (!token) return new Response(null, { status: 400 });

const ctxResult = await loadGuestCtx(token);
if (!ctxResult) return Astro.redirect(`/g/${token ?? ''}`);
const { ctx, isShowcase } = ctxResult;
const { stay, guest, hotel, settings } = ctx;

const session = await getStaySession(Astro.cookies);
if (!session || session.stay_id !== stay.id) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id, hotel_id: (hotel as any).id,
    check_out_utc: stay.check_out, is_showcase: isShowcase,
  });
}

const sbSr = createSupabaseServiceRoleInstance();
const { data: hotelDetails } = await sbSr
  .from('hotels')
  .select('latitude, longitude, phone, address_street, address_zip, address_city')
  .eq('id', (hotel as any).id)
  .maybeSingle();

const lat  = (hotelDetails?.latitude  as number | null) ?? null;
const lng  = (hotelDetails?.longitude as number | null) ?? null;
const phone = (hotelDetails?.phone as string | null) ?? null;

const f = (settings as any).features ?? {};
const checkInTime  = (f.check_in_time  as string | null) ?? null;
const parkingNote  = (f.parking_note   as string | null) ?? null;

const lang: Lang = normalizeLang(guest?.language || hotel.default_language);
const brandPrimary = (hotel as any).brand_primary ?? '#0A0A0A';
const brandPalette = computeBrandPalette(brandPrimary);

const mapsUrl = (lat && lng)
  ? `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`
  : null;

type Labels = {
  title: string; sub: string; routeBtn: string;
  rowCheckin: string; rowParken: string; rowKontakt: string;
  checkinFrom: string;
};
const labels: Record<Lang, Labels> = {
  de: { title: 'Anfahrt & Check-in', sub: 'So findest du uns.', routeBtn: 'Route öffnen', rowCheckin: 'Check-in', rowParken: 'Parken', rowKontakt: 'Kontakt', checkinFrom: 'ab' },
  en: { title: 'Directions & Check-in', sub: 'How to find us.', routeBtn: 'Open route', rowCheckin: 'Check-in', rowParken: 'Parking', rowKontakt: 'Contact', checkinFrom: 'from' },
  fr: { title: 'Accès & Check-in', sub: 'Comment nous trouver.', routeBtn: 'Ouvrir l\'itinéraire', rowCheckin: 'Check-in', rowParken: 'Parking', rowKontakt: 'Contact', checkinFrom: 'à partir de' },
  es: { title: 'Cómo llegar & Check-in', sub: 'Así nos encuentras.', routeBtn: 'Abrir ruta', rowCheckin: 'Check-in', rowParken: 'Aparcamiento', rowKontakt: 'Contacto', checkinFrom: 'desde las' },
  it: { title: 'Come arrivare & Check-in', sub: 'Come trovarci.', routeBtn: 'Apri percorso', rowCheckin: 'Check-in', rowParken: 'Parcheggio', rowKontakt: 'Contatto', checkinFrom: 'dalle' },
  pt: { title: 'Como chegar & Check-in', sub: 'Como nos encontrar.', routeBtn: 'Abrir rota', rowCheckin: 'Check-in', rowParken: 'Estacionamento', rowKontakt: 'Contacto', checkinFrom: 'a partir das' },
  nl: { title: 'Route & Check-in', sub: 'Zo vindt u ons.', routeBtn: 'Route openen', rowCheckin: 'Check-in', rowParken: 'Parkeren', rowKontakt: 'Contact', checkinFrom: 'vanaf' },
  ru: { title: 'Маршрут & Check-in', sub: 'Как нас найти.', routeBtn: 'Открыть маршрут', rowCheckin: 'Заезд', rowParken: 'Парковка', rowKontakt: 'Контакт', checkinFrom: 'с' },
  ar: { title: 'الاتجاهات & تسجيل الوصول', sub: 'كيف تجدنا.', routeBtn: 'فتح المسار', rowCheckin: 'تسجيل الوصول', rowParken: 'مواقف السيارات', rowKontakt: 'التواصل', checkinFrom: 'من الساعة' },
  zh: { title: '路线 & 入住', sub: '如何找到我们。', routeBtn: '打开路线', rowCheckin: '入住时间', rowParken: '停车', rowKontakt: '联系方式', checkinFrom: '从' },
};
const L = labels[lang];
---

<!DOCTYPE html>
<html lang={lang} style={`--accent:${brandPrimary};--accent-soft:${brandPalette.soft};`}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <title>{L.title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { font-family: 'Space Grotesk', sans-serif; }
    body { background: #F4EEE0; min-height: 100dvh; padding-bottom: 40px; }

    .page-header {
      display: flex; align-items: center;
      padding: calc(env(safe-area-inset-top, 0px) + 16px) 20px 16px;
    }
    .back-btn {
      width: 38px; height: 38px; border-radius: 50%;
      background: #EDEBE7; border: 0;
      display: flex; align-items: center; justify-content: center;
      color: #3A3A36; cursor: pointer; text-decoration: none; flex-shrink: 0;
    }

    .page-body { padding: 8px 20px 0; }
    .page-title { font-size: 30px; font-weight: 700; color: #0F0F0D; line-height: 1.2; margin-bottom: 8px; }
    .page-sub   { font-size: 15px; color: #6B6B63; line-height: 1.5; margin-bottom: 24px; }

    /* Map */
    .map-wrap {
      border-radius: 16px; overflow: hidden;
      margin-bottom: 14px; aspect-ratio: 16/9;
      background: #EAEAE4;
    }
    .map-wrap svg { width: 100%; height: 100%; display: block; }
    .map-route { stroke: var(--accent, #7B83D0); }
    .map-pin   { fill: var(--accent, #7B83D0); }
    .map-glow  { fill: var(--accent, #7B83D0); opacity: 0.18; }

    /* Route button */
    .btn-route {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      width: 100%; padding: 16px; border: 0; border-radius: 14px;
      background: #0F0F0D; color: #fff;
      font-size: 16px; font-weight: 600; font-family: inherit;
      text-decoration: none; margin-bottom: 24px;
      cursor: pointer;
    }

    /* Info rows */
    .info-card {
      background: #fff; border-radius: 16px;
      border: 1px solid #EAEAE4; overflow: hidden;
    }
    .info-row {
      display: flex; align-items: center; gap: 14px;
      padding: 16px 18px;
      border-bottom: 1px solid #F0EDE8;
    }
    .info-row:last-child { border-bottom: 0; }
    .info-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: #F0EDE8; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: #6B6B63;
    }
    .info-text { flex: 1; min-width: 0; }
    .info-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px; letter-spacing: 0.12em; color: #AEACA6;
      text-transform: uppercase; margin-bottom: 3px;
    }
    .info-value { font-size: 15px; font-weight: 500; color: #0F0F0D; line-height: 1.3; }
    .info-link  { color: inherit; text-decoration: none; }
    .info-link:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <header class="page-header">
    <a class="back-btn" href={`/g/${token}`} data-astro-reload aria-label="Zurück">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </a>
  </header>

  <div class="page-body">
    <h1 class="page-title">{L.title}</h1>
    <p class="page-sub">{L.sub}</p>

    <!-- Map illustration -->
    <div class="map-wrap">
      <svg viewBox="0 0 360 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="360" height="200" fill="#EAEAE4"/>
        <!-- Roads -->
        <rect x="0" y="72" width="360" height="14" fill="#D9D5CF"/>
        <rect x="0" y="136" width="360" height="12" fill="#D9D5CF"/>
        <rect x="88"  y="0" width="14" height="200" fill="#D9D5CF"/>
        <rect x="250" y="0" width="12" height="200" fill="#D9D5CF"/>
        <!-- Buildings -->
        <rect x="16"  y="16"  width="56" height="48" fill="#D3D0C9" rx="3"/>
        <rect x="16"  y="94"  width="44" height="34" fill="#D3D0C9" rx="3"/>
        <rect x="16"  y="154" width="56" height="38" fill="#D3D0C9" rx="3"/>
        <rect x="116" y="16"  width="118" height="48" fill="#D3D0C9" rx="3"/>
        <rect x="116" y="94"  width="56"  height="34" fill="#D3D0C9" rx="3"/>
        <rect x="116" y="154" width="118" height="38" fill="#D3D0C9" rx="3"/>
        <rect x="276" y="94"  width="70"  height="34" fill="#D3D0C9" rx="3"/>
        <rect x="276" y="154" width="70"  height="38" fill="#D3D0C9" rx="3"/>
        <!-- Dotted route -->
        <path d="M 30 188 Q 100 160 190 110 T 280 56"
          class="map-route"
          stroke-width="3" stroke-dasharray="5 7"
          stroke-linecap="round" fill="none"/>
        <!-- Pin glow -->
        <circle cx="280" cy="56" r="24" class="map-glow"/>
        <!-- Pin drop -->
        <path d="M280 36 C269 36 261 44 261 55 C261 68 280 84 280 84 C280 84 299 68 299 55 C299 44 291 36 280 36Z" class="map-pin"/>
        <circle cx="280" cy="54" r="6" fill="white"/>
      </svg>
    </div>

    <!-- Route button -->
    {mapsUrl ? (
      <a class="btn-route" href={mapsUrl} target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="3 11 22 2 13 21 11 13 3 11"/>
        </svg>
        {L.routeBtn}
      </a>
    ) : (
      <div style="height:14px"></div>
    )}

    <!-- Info rows -->
    <div class="info-card">
      {checkInTime && (
        <div class="info-row">
          <div class="info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <div class="info-text">
            <div class="info-label">{L.rowCheckin}</div>
            <div class="info-value">{L.checkinFrom} {checkInTime}</div>
          </div>
        </div>
      )}

      {parkingNote && (
        <div class="info-row">
          <div class="info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>
            </svg>
          </div>
          <div class="info-text">
            <div class="info-label">{L.rowParken}</div>
            <div class="info-value">{parkingNote}</div>
          </div>
        </div>
      )}

      {phone && (
        <div class="info-row">
          <div class="info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.65 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div class="info-text">
            <div class="info-label">{L.rowKontakt}</div>
            <div class="info-value">
              <a class="info-link" href={`tel:${phone}`}>{phone}</a>
            </div>
          </div>
        </div>
      )}

      {!checkInTime && !parkingNote && !phone && (
        <div class="info-row">
          <div class="info-text" style="padding: 8px 0">
            <div class="info-value" style="color:#6B6B63;font-weight:400">Weitere Informationen auf Anfrage.</div>
          </div>
        </div>
      )}
    </div>
  </div>
</body>
</html>
