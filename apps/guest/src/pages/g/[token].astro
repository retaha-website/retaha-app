        // Sprint E7 Phase 4 — Action-Card-Click dispatch (5 Typen)
        handleRecClick(el: HTMLElement) {
          if (!el) return;
          const cardType = el.dataset.cardType;
          const target = el.dataset.actionTarget || '';

          switch (cardType) {
            case 'internal_action': {
              if (!target) return;
              const sheetId = target.replace(/^open_/, '');
              if (sheetId === 'eve') {
                this.eveOpen = true;
                this.eveSeenBefore = true;
                try { localStorage.setItem('retaha_eve_seen', '1'); } catch (_) {}
                if (typeof (this as any).eveMaybeWelcome === 'function') (this as any).eveMaybeWelcome();
                return;
              }
              const KNOWN_SHEETS = new Set(['wifi', 'breakfast', 'conference', 'service', 'places']);
              if (KNOWN_SHEETS.has(sheetId)) {
                this.openSheet(sheetId);
              } else {
                this._showRecToast('Diese Funktion ist bald verfügbar.');
              }
              return;
            }
            case 'external_link':
              if (target) window.open(target, '_blank', 'noopener,noreferrer');
              return;
            case 'phone':
              if (target) window.location.href = `tel:${target.replace(/\s+/g, '')}`;
              return;
            case 'email':
              if (target) window.location.href = `mailto:${target}`;
              return;
            case 'info':
            default:
              return;
          }
        },

        _showRecToast(text: string) {
          let t = document.getElementById('rec-toast');
          if (!t) {
            t = document.createElement('div');
            t.id = 'rec-toast';
            t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);padding:12px 20px;background:color-mix(in srgb, var(--theme-text-primary) .92, transparent);color:var(--theme-bg-primary);font-size:14px;font-family:inherit;border-radius:0;z-index:1000;max-width:90vw;box-shadow:0 8px 24px rgba(0,0,0,.2);';
            document.body.appendChild(t);
          }
          t.textContent = text;
          t.style.opacity = '1';
          setTimeout(() => { if (t) t.style.opacity = '0'; t.style.transition = 'opacity .4s'; }, 2500);
        },

        closeSheet() {
          this.activeSheet = null;
          this.sheetDragOffset = 0;
          document.body.style.overflow = '';
        },

        copyText(text: string, event: Event) {
          // Find the button first — needed for visual feedback regardless of copy method
          let btn = event.target as HTMLElement;
          while (btn && !btn.classList.contains('wifi-copy')) {
            btn = btn.parentElement as HTMLElement;
          }

          const showFeedback = () => {
            if (!btn) return;
            btn.classList.add('copied');
            setTimeout(() => {
              btn.classList.remove('copied');
            }, 1500);
          };

          // Method 1: modern clipboard API (works on Chrome, Firefox, Safari macOS)
          // CRITICAL: must be called synchronously, no await — iOS loses gesture trust on await
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(() => {
              showFeedback();
            }).catch((err) => {
              console.warn('clipboard.writeText failed, trying fallback', err);
              fallbackCopy(text);
              showFeedback();
            });
          } else {
            // Method 2: fallback for old iOS / restricted contexts
            fallbackCopy(text);
            showFeedback();
          }

          function fallbackCopy(value: string) {
            try {
              const textarea = document.createElement('textarea');
              textarea.value = value;
              textarea.setAttribute('readonly', '');
              textarea.style.position = 'fixed';
              textarea.style.top = '0';
              textarea.style.left = '0';
              textarea.style.opacity = '0';
              textarea.style.pointerEvents = 'none';
              document.body.appendChild(textarea);

              // iOS Safari requires selecting via Range, not just .select()
              const range = document.createRange();
              range.selectNodeContents(textarea);
              const selection = window.getSelection();
              if (selection) {
                selection.removeAllRanges();
                selection.addRange(range);
              }
              textarea.setSelectionRange(0, value.length);

              document.execCommand('copy');
              document.body.removeChild(textarea);
            } catch (e) {
              console.error('Fallback copy failed:', e);
            }
          }
        },

        startSheetDrag(event: PointerEvent) {
          event.preventDefault();
          this._sheetDragStart = event.clientY;
          this.sheetIsDragging = true;
          this.sheetDragOffset = 0;

          const onMove = (e: PointerEvent) => {
            const delta = e.clientY - this._sheetDragStart;
            this.sheetDragOffset = Math.max(0, delta);
          };
          const onEnd = () => {
            document.removeEventListener('pointermove', onMove);
            document.removeEventListener('pointerup', onEnd);
            document.removeEventListener('pointercancel', onEnd);
            this.sheetIsDragging = false;
            if (this.sheetDragOffset > 120) {
              this.closeSheet();
            } else {
              this.sheetDragOffset = 0;
            }
          };
          document.addEventListener('pointermove', onMove);
          document.addEventListener('pointerup', onEnd);
          document.addEventListener('pointercancel', onEnd);
        },

        startSheetDragTouch(event: TouchEvent) {
          this._sheetDragStart = event.touches[0].clientY;
          this.sheetIsDragging = true;
          this.sheetDragOffset = 0;

          const onMove = (e: TouchEvent) => {
            const delta = e.touches[0].clientY - this._sheetDragStart;
            this.sheetDragOffset = Math.max(0, delta);
          };
          const onEnd = () => {
            document.removeEventListener('touchmove', onMove);
            document.removeEventListener('touchend', onEnd);
            document.removeEventListener('touchcancel', onEnd);
            this.sheetIsDragging = false;
            if (this.sheetDragOffset > 120) {
              this.closeSheet();
            } else {
              this.sheetDragOffset = 0;
            }
          };
          document.addEventListener('touchmove', onMove, { passive: true });
          document.addEventListener('touchend', onEnd);
          document.addEventListener('touchcancel', onEnd);
        },
      }));

      // Sprint E2 Phase 7 — PlacesSheet Alpine-Component
      // (im selben bundled Script wie guestPage, damit Timing mit Alpine.start() stimmt)
      // @ts-expect-error - Alpine types
      Alpine.data('placesSheet', (initialTab: string) => ({
        activeTab: initialTab,
        showAllAuto: false,
      }));

      // @ts-expect-error - Alpine types
      Alpine.data('breakfastForm', (initial: any) => ({
        view: initial.existingBooking
          ? 'status'
          : (initial.reservationEnabled === false ? 'info' : 'form'),
        reservationEnabled: initial.reservationEnabled !== false,
        includedText: initial.includedText || '',
        location: initial.location || '',

        // Menu state
        menuItems: initial.menuItems || [],
        allergenLabels: initial.allergenLabels || {},
        allergenKeys: initial.allergenKeys || [],
        selectedAllergens: [] as string[],
        activeTab: 'main' as 'main' | 'menu',
        filterCollapsed: false,

        toggleAllergen(key: string) {
          if (this.selectedAllergens.includes(key)) {
            this.selectedAllergens = this.selectedAllergens.filter((k: string) => k !== key);
          } else {
            this.selectedAllergens = [...this.selectedAllergens, key];
          }
        },

        clearAllergenFilter() {
          this.selectedAllergens = [];
        },

        getMatchingAllergens(item: any) {
          return item.allergens.filter((a: string) => this.selectedAllergens.includes(a));
        },

        get groupedMenuItems() {
          const groups: Record<string, any[]> = {};
          this.menuItems.forEach((item: any) => {
            const cat = item.category || 'Allgemein';
            if (!groups[cat]) groups[cat] = [];
            groups[cat].push(item);
          });
          return groups;
        },

        stayRangeDates: initial.stayRangeDates,
        allSlots: initial.allSlots,
        startTime: initial.startTime,
        endTime: initial.endTime,
        peopleOptions: initial.peopleOptions,
        tableOptions: initial.tableOptions,
        labels: initial.labels,
        accessToken: initial.accessToken,
        existingBooking: initial.existingBooking,
        lang: initial.lang,

        // Live-updating "now" — tick every 60s to handle slot expiration
        nowTick: 0,

        form: {
          date: '',
          people: 2,
          time: '',
          table_preference: 'any',
          notes: '',
        },

        submitting: false,
        errorMsg: '',

        init() {
          // Pre-select first available date
          const firstAvail = this.availableDates[0];
          if (firstAvail) this.form.date = firstAvail.iso;

          // Tick every 60s for slot expiry on "today"
          setInterval(() => {
            this.nowTick = Date.now();
            // If currently selected date or slot expired, reset
            if (!this.availableDates.find((d: any) => d.iso === this.form.date)) {
              const newFirst = this.availableDates[0];
              this.form.date = newFirst ? newFirst.iso : '';
              this.form.time = '';
            }
            if (this.form.time && !this.slots.includes(this.form.time)) {
              this.form.time = '';
            }
          }, 60000);
        },

        // Computed: today as local ISO (recomputes on tick)
        get todayIso() {
          // nowTick triggers reactivity
          this.nowTick;
          const d = new Date();
          return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        },

        // Filter slots for a given date based on current time
        slotsForDate(dateIso: string) {
          if (dateIso !== this.todayIso) return this.allSlots;
          const now = new Date();
          const nowMin = now.getHours() * 60 + now.getMinutes();
          return this.allSlots.filter((slot: string) => {
            const [h, m] = slot.split(':').map(Number);
            return h * 60 + m > nowMin;
          });
        },

        // Available dates: those in stay range, in the present or future, with slots
        get availableDates() {
          const today = this.todayIso;
          return this.stayRangeDates
            .filter((d: any) => d.iso >= today)
            .filter((d: any) => this.slotsForDate(d.iso).length > 0)
            .slice(0, 5);
