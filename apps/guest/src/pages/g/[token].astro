    </main>

    <ConsentModule stayToken={token} />

    <script>
      import Alpine from 'alpinejs';

      // @ts-expect-error - Alpine types
      Alpine.data('guestPage', () => ({
        init() {
          // Sprint Functional Modul C Phase 8 — Post-Stay-Sheet ggf. anzeigen
          if (typeof (this as any)._initPostStay === 'function') {
            (this as any)._initPostStay();
          }
          // Consent-Modul: zeigen wenn noch keine Entscheidung gespeichert
          const POLICY = '2026-06-01';
          const flagKey = `retaha_consent_v${POLICY}`;
          const _cs = this._isShowcase ? sessionStorage : localStorage;
          if (_cs.getItem(flagKey)) {
            this.consentGiven = true;
          } else {
            setTimeout(() => { this.consentOpen = true; }, 900);
          }
        },
        recSlideIndex: 0,

        setRecSlide(i: number) {
          const slider = document.querySelector<HTMLElement>('.rec-slider');
          if (slider) slider.scrollTo({ left: i * 332, behavior: 'smooth' });
          this.recSlideIndex = i;
        },

        // Consent state
        consentOpen: false,
        consentGiven: false,
        cmExpanded: false,
        cmStats: false,
        cmComfort: true,

        cmDecide(type: 'all' | 'necessary' | 'custom') {
          const POLICY = '2026-06-01';
          const flagKey = `retaha_consent_v${POLICY}`;
          const payload = {
            type: type === 'all' ? 'all' : (this.cmStats ? 'necessary' : 'rejected'),
            analytics: type === 'all' || (type === 'custom' && this.cmStats),
            comfort:   type === 'all' || (type === 'custom' && this.cmComfort),
            at: Date.now(),
          };
          const _cs = this._isShowcase ? sessionStorage : localStorage;
          try { _cs.setItem(flagKey, JSON.stringify(payload)); } catch (_) {}
          try {
            const blob = new Blob([JSON.stringify({ token: null, consent_type: type, consent_given: type !== 'necessary' })], { type: 'application/json' });
            navigator.sendBeacon('/api/g/consent', blob);
          } catch (_) {}
          this.consentOpen = false;
          this.consentGiven = true;
        },

        // Sheet state
        activeSheet: null as string | null,
        sheetDragOffset: 0,
        sheetIsDragging: false,
        _sheetDragStart: 0,
        _bgColor: '#ffffff',

        // Eve state (Sprint E4 Phase 9 + 10)
        eveOpen: false,
        eveAvatarGreeting: false,
        eveMessages: (typeof window !== 'undefined' && (window as any).__EVE_INITIAL__?.messages)
          ? [...(window as any).__EVE_INITIAL__.messages]
          : [] as Array<{ role: 'user' | 'assistant'; content: string; streaming?: boolean }>,
        eveTyping: false,
        evePendingAction: null as any,
        eveError: null as string | null,
        eveConfirming: false,
        eveSeenBefore: typeof window !== 'undefined' ? !!localStorage.getItem('retaha_eve_seen') : false,
        _eveLastConversation: '' as string,  // für Audit-Context
        _eveWelcomeTried: false,  // Phase 10: idempotenter Welcome-Trigger
        _eveLang: (typeof window !== 'undefined' && (window as any).__EVE_INITIAL__?.lang) || 'de',
        _isShowcase: typeof window !== 'undefined' ? !!(window as any).__RETAHA_META__?.isShowcase : false,

        // Sprint E2 Phase 8 — Place-Detail-Sheet (layered über PlacesSheet)
        activeDetailPlaceId: null as string | null,
        activeDetailData: null as any,
        detailLoading: false,
        detailError: null as string | null,

        async openPlaceDetail(placeId: string) {
          this.activeDetailError = null;
          this.detailError = null;
          this.activeDetailPlaceId = placeId;

          // 1. Cache-Lookup (Picks haben pre-loaded data im window-Global)
          const cache = (typeof window !== 'undefined' && (window as any).__PLACE_DETAILS__?.cache) || {};
          if (cache[placeId]) {
            this.activeDetailData = cache[placeId];
            this.detailLoading = false;
            return;
          }

          // 2. Auto-Place → on-demand fetch
          this.activeDetailData = null;
          this.detailLoading = true;
          try {
            const lang = (typeof window !== 'undefined' && (window as any).__PLACE_DETAILS__?.lang) || 'de';
            const res = await fetch(`/api/places/details?placeId=${encodeURIComponent(placeId)}&lang=${lang}`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const body = await res.json();
            if (!body.ok) throw new Error(body.error || 'Unknown error');
            const d = body.details as any;
            const PRICE_SYMBOLS: Record<string, string> = {
              PRICE_LEVEL_FREE: '', PRICE_LEVEL_INEXPENSIVE: '€', PRICE_LEVEL_MODERATE: '€€',
              PRICE_LEVEL_EXPENSIVE: '€€€', PRICE_LEVEL_VERY_EXPENSIVE: '€€€€',
            };
            this.activeDetailData = {
              name: d.name,
              rating: d.rating,
              userRatingCount: d.userRatingCount,
              priceSymbol: PRICE_SYMBOLS[d.priceLevel ?? ''] ?? '',
              hotelNote: null,  // Auto-Places haben keine Hotel-Notiz
              formattedAddress: d.formattedAddress,
              phone: d.internationalPhoneNumber,
              website: d.websiteUri,
              googleMapsUri: d.googleMapsUri,
              openNow: d.openingHours?.openNow ?? null,
              weekdayDescriptions: d.openingHours?.weekdayDescriptions ?? [],
              reviews: d.reviews ?? [],
              photoUrls: d.photoUrls ?? [],
            };
          } catch (err) {
            this.detailError = `Details konnten nicht geladen werden: ${(err as Error).message}`;
          } finally {
            this.detailLoading = false;
          }
        },

        closePlaceDetail() {
          this.activeDetailPlaceId = null;
          this.activeDetailData = null;
          this.detailError = null;
        },

        // Maps raw API/network errors to Eve-voice messages — never show raw JSON/HTTP codes.
        _friendlyEveError(raw: string): string {
          const s = (raw ?? '').toLowerCase();
          if (s.includes('403') || s.includes('nicht aktiviert') || s.includes('not activated')) {
            return 'Ich bin gerade leider nicht verfügbar. Bitte wende dich an die Rezeption.';
          }
          if (s.includes('429') || s.includes('rate limit') || s.includes('zu viele')) {
            return 'Ich beantworte gerade viele Anfragen — bitte kurz warten und nochmal versuchen.';
          }
          if (s.includes('failed to fetch') || s.includes('networkerror') || s.includes('network')) {
            return 'Keine Verbindung — bitte Netzwerk prüfen und nochmal versuchen.';
          }
          return 'Ich bin gerade nicht erreichbar — bitte versuch es gleich nochmal.';
        },

        _parseMarkdown(text: string): string {
          if (!text) return '';
          return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\*\*([\s\S]*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(?!\*)(.*?)\*/g, '<em>$1</em>')
            .replace(/`([^`\n]+)`/g, '<code>$1</code>')
            .replace(/\n/g, '<br>');
        },

        async eveSend(text: string) {
          const message = (text || '').trim();
          if (!message || this.eveTyping) return;

          this.eveError = null;
          this.evePendingAction = null;
          this.eveMessages.push({ role: 'user', content: message });
          this.eveTyping = true;
          this._scrollEveBottom();

          // Mark als seen für Pulse-Disable
          try { localStorage.setItem('retaha_eve_seen', '1'); } catch (_) {}
          this.eveSeenBefore = true;

          const MIN_TYPING_MS = 700;
          const startedAt = Date.now();

          try {
            const res = await fetch('/api/eve/chat', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ message, lang: this._eveLang }),
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);

            // Gesamten Stream im Hintergrund sammeln — UI zeigt erst die vollständige Antwort
            const reader = res.body!.getReader();
            const decoder = new TextDecoder();
            let buffer = '';
            let fullContent = '';
            let pendingAction: any = null;
            let streamError: string | null = null;

            while (true) {
              const { done, value } = await reader.read();
              if (done) break;
              buffer += decoder.decode(value, { stream: true });
              const blocks = buffer.split('\n\n');
              buffer = blocks.pop() ?? '';
              for (const block of blocks) {
                const line = block.trim();
                if (!line.startsWith('data:')) continue;
                try {
                  const ev = JSON.parse(line.slice(5).trim());
                  if (ev.type === 'text_delta') {
                    fullContent += ev.text;
                  } else if (ev.type === 'pending_action') {
                    pendingAction = ev.action;
                  } else if (ev.type === 'error') {
                    streamError = ev.message;
                  } else if (ev.type === 'escalating') {
                    fullContent = '';
                  }
                  // router_decision, tool_use_preview, message_complete: ignoriert im UI
                } catch (_) {}
              }
            }

            // Mindest-Typing-Dauer — natürliches Gefühl, kein sofortiger Textplumps
            const elapsed = Date.now() - startedAt;
            if (elapsed < MIN_TYPING_MS) {
              await new Promise(r => setTimeout(r, MIN_TYPING_MS - elapsed));
            }

            this.eveTyping = false;

            if (streamError) {
              this.eveError = this._friendlyEveError(streamError);
            } else {
              this.eveMessages.push({
                role: 'assistant',
                content: fullContent,
                html: this._parseMarkdown(fullContent),
                streaming: false,
              });
              if (pendingAction) this.evePendingAction = pendingAction;
              this._eveLastConversation = this._buildConversationContext();
            }
            this._scrollEveBottom();
          } catch (err) {
            // Mindest-Typing-Dauer auch bei Netzwerkfehler
            const elapsed = Date.now() - startedAt;
            if (elapsed < MIN_TYPING_MS) {
              await new Promise(r => setTimeout(r, MIN_TYPING_MS - elapsed));
            }
            this.eveTyping = false;
            const msg = (err as Error).message || '';
            this.eveError = this._friendlyEveError(msg);
            console.error('[eve] chat failed:', err);
          }
        },

        async eveConfirm() {
          if (!this.evePendingAction || this.eveConfirming) return;
          this.eveConfirming = true;
          this.eveError = null;
          const pending = this.evePendingAction;

          try {
            const res = await fetch('/api/eve/confirm-action', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                pending_action: pending,
                conversation_context: this._eveLastConversation,
              }),
            });
            const body = await res.json();
            if (body.ok) {
              this.eveMessages.push({ role: 'assistant', content: 'Erledigt — der Hotelier bekommt deine Anfrage gleich.', html: this._parseMarkdown('Erledigt — der Hotelier bekommt deine Anfrage gleich.') });
              this.evePendingAction = null;
            } else {
              this.eveError = body.error || 'Bestätigung fehlgeschlagen.';
            }
          } catch (err) {
            this.eveError = (err as Error).message || 'Bestätigung fehlgeschlagen.';
          } finally {
            this.eveConfirming = false;
            this._scrollEveBottom();
          }
        },

        eveCancel() {
          this.evePendingAction = null;
          this.eveMessages.push({ role: 'assistant', content: 'Kein Problem, sag Bescheid wenn ich helfen kann.', html: this._parseMarkdown('Kein Problem, sag Bescheid wenn ich helfen kann.') });
          this._scrollEveBottom();
        },

        eveClose() {
          this.eveOpen = false;
        },

        // Phase 10: Welcome-Trigger beim ersten Sheet-Open ohne History.
        // Idempotent: Server-Side checks chat_messages.count + Client-Side
        // checks _eveWelcomeTried (prevents Doppel-Calls beim raschen Reopen).
        async eveMaybeWelcome() {
          if (this._eveWelcomeTried) return;
          if (this.eveMessages.length > 0) return;
          this._eveWelcomeTried = true;
          this.eveTyping = true;
          await new Promise(r => setTimeout(r, 850));
          this.eveTyping = false;
          const init = typeof window !== 'undefined' ? (window as any).__EVE_INITIAL__ : null;
          const guestName: string | null = init?.guestName ?? null;
          const eveName: string = init?.eveName || 'Eve';
          const lang: string = init?.lang || 'de';
          const hour = typeof window !== 'undefined' ? new Date().getHours() : 12;
          const GREET: Record<string, { time: (h: number) => string; body: (n: string | null, e: string) => string }> = {
            de: {
              time: h => h < 12 ? 'Guten Morgen' : h < 18 ? 'Guten Tag' : 'Guten Abend',
              body: (n, e) => `${n ? `Schön, dass du hier bist, ${n}. ` : ''}Ich bin ${e}, dein persönlicher Concierge — frag mich nach Empfehlungen, WLAN, Reservierungen oder was auch immer deinen Aufenthalt besser macht.`,
            },
            en: {
              time: h => h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening',
              body: (n, e) => `${n ? `Great to have you, ${n}. ` : ''}I'm ${e}, your personal concierge — ask me about recommendations, Wi-Fi, reservations, or anything to make your stay better.`,
            },
            fr: {
              time: h => h < 12 ? 'Bonjour' : h < 18 ? 'Bon après-midi' : 'Bonsoir',
              body: (n, e) => `${n ? `Ravi de vous accueillir, ${n}. ` : ''}Je suis ${e}, votre concierge — n'hésitez pas à demander des recommandations, le Wi-Fi ou des réservations.`,
            },
            es: {
              time: h => h < 12 ? 'Buenos días' : h < 18 ? 'Buenas tardes' : 'Buenas noches',
              body: (n, e) => `${n ? `Encantado de tenerte aquí, ${n}. ` : ''}Soy ${e}, tu concierge personal — pregúntame recomendaciones, Wi-Fi o reservas.`,
            },
          };
          const g = GREET[lang] ?? GREET.de;
          const greetText = `${g.time(hour)}! ${g.body(guestName, eveName)}`;
          this.eveMessages.push({ role: 'assistant', content: greetText, html: this._parseMarkdown(greetText), streaming: false });
          this._scrollEveBottom();
        },

        _scrollEveBottom() {
          requestAnimationFrame(() => {
            const el = this.$refs.eveMessagesEl as HTMLElement | undefined;
            if (el) el.scrollTop = el.scrollHeight;
          });
        },

        _buildConversationContext(): string {
          return this.eveMessages.slice(-3).map((m: any) =>
            `${m.role === 'user' ? 'Gast' : 'Eve'}: ${m.content}`
          ).join('\n');
        },

        // Sprint Wallet · Phase 5 — Add-to-Google-Wallet State
        walletOpen: false,
        walletConsent: false,
        walletSubmitting: false,
        walletDone: false,
        walletError: '' as string,
        walletThanksMessage: '' as string,

        async walletSubmit() {
          if (this.walletSubmitting) return;
          this.walletSubmitting = true;
          this.walletError = '';
          try {
            const res = await fetch('/api/g/wallet/create', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ marketing_consent: this.walletConsent }),
            });
            const data = await res.json();
            if (!data.ok || !data.save_link_url) {
              this.walletError = data.error === 'wallet_not_configured'
                ? 'Wallet ist auf diesem System noch nicht aktiviert.'
                : (data.error || 'Unbekannter Fehler.');
              return;
            }
            // Erfolg: Save-Link in selbem Tab öffnen (Google Wallet entscheidet
            // basierend auf Plattform: Android-App, Web-Wallet, Fallback)
            this.walletDone = true;
            this.walletThanksMessage = data.pass_state?.is_returning
              ? `Willkommen zurück! Dein ${data.pass_state.visit_count}. Besuch.`
              : 'Pass wird gleich geöffnet …';
            // Kurzer Delay damit Thanks-View sichtbar wird, dann redirect
            setTimeout(() => { window.location.href = data.save_link_url; }, 500);
          } catch (err) {
            this.walletError = (err as Error).message || 'Netzwerk-Fehler.';
          } finally {
            this.walletSubmitting = false;
          }
        },

        // Sprint Functional Modul C Phase 8 — Post-Stay-Rating-State
        postStayOpen: false,
        postStayRating: 0,
        postStayHover: 0,
        postStayComment: '',
        postStaySubmitting: false,
        postStayDone: false,
        postStayError: '' as string,

        // Wird bei init() vom Alpine-Component aufgerufen (s. registerguestPageInit).
        _initPostStay() {
          const cfg = (window as any).__RETAHA_POSTSTAY__;
          if (!cfg || !cfg.shouldAutoOpen) return;
          // Sanfter Auto-Open: 1.6s damit Gast die Seite zuerst sieht.
          setTimeout(() => { this.postStayOpen = true; }, 1600);
        },

        postStayDismiss() {
          this.postStayOpen = false;
          const cfg = (window as any).__RETAHA_POSTSTAY__;
          if (!cfg) return;
          try {
            localStorage.setItem('retaha_poststay_dismissed_' + cfg.stayId, String(Date.now()));
          } catch (_) { /* localStorage blocked — egal */ }
        },

        async postStaySubmit() {
          if (!this.postStayRating || this.postStaySubmitting) return;
          this.postStaySubmitting = true;
          this.postStayError = '';
          try {
            const res = await fetch('/api/g/stay-feedback', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                rating: this.postStayRating,
                comment: this.postStayComment.trim() || undefined,
              }),
            });
            const data = await res.json();
            if (!data.ok) {
              this.postStayError = data.error || 'unknown';
              return;
            }
            this.postStayDone = true;
            // Cleanup Cooldown — Gast hat ja bewertet, soll nie wieder gefragt werden
            const cfg = (window as any).__RETAHA_POSTSTAY__;
            if (cfg) {
              try { localStorage.removeItem('retaha_poststay_dismissed_' + cfg.stayId); } catch(_){}
            }
          } catch (err) {
            this.postStayError = (err as Error).message || 'network';
          } finally {
            this.postStaySubmitting = false;
          }
        },

        // Sprint Functional Modul C Phase 7 — Eve-Feedback (Daumen)
        async sendEveFeedback(messageId: string, rating: 1 | -1) {
          if (!messageId) return;
          const idx = this.eveMessages.findIndex((m: any) => m.id === messageId);
          if (idx < 0) return;
          // Optimistic Update
          const prev = this.eveMessages[idx].feedback;
          (this.eveMessages[idx] as any).feedback = rating;
          try {
            const res = await fetch('/api/g/eve-feedback', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ message_id: messageId, rating }),
            });
            const data = await res.json();
            if (!data.ok) {
              (this.eveMessages[idx] as any).feedback = prev;
              this._showRecToast('Feedback fehlgeschlagen.');
              return;
            }
            this._showRecToast(rating === 1 ? 'Danke!' : 'Danke für dein Feedback.');
          } catch (_) {
            (this.eveMessages[idx] as any).feedback = prev;
            this._showRecToast('Netzwerk-Fehler.');
          }
        },

        openSheet(id: string) {
          this.activeSheet = id;
          this.sheetDragOffset = 0;
          document.body.style.overflow = 'hidden';
        },

        // Sprint E7 Phase 4 — Action-Card-Click dispatch (5 Typen)
        handleRecClick(el: HTMLElement) {
          if (!el) return;
          const cardType = el.dataset.cardType;
          const target = el.dataset.actionTarget || '';

          switch (cardType) {
            case 'internal_action': {
              if (!target) return;
              const sheetId = target.replace(/^open_/, '');
              if (sheetId === 'eve') {
                this.eveOpen = true;
                this.eveAvatarGreeting = true;
                setTimeout(() => { (this as any).eveAvatarGreeting = false; }, 700);
                this.eveSeenBefore = true;
                try { localStorage.setItem('retaha_eve_seen', '1'); } catch (_) {}
                if (typeof (this as any).eveMaybeWelcome === 'function') (this as any).eveMaybeWelcome();
                return;
              }
              if (sheetId === 'wifi' || sheetId === 'breakfast') {
                const _parts = window.location.pathname.split('/').filter(Boolean);
                const _tok = _parts[1] ?? '';
                const _pers = new URLSearchParams(window.location.search).get('persona') ?? 'in_house';
                window.location.href = `/g/${_tok}/${sheetId}?persona=${_pers}`;
                return;
              }
              const KNOWN_SHEETS = new Set(['conference', 'service', 'places']);
              if (KNOWN_SHEETS.has(sheetId)) {
                this.openSheet(sheetId);
              } else {
                this._showRecToast('Diese Funktion ist bald verfügbar.');
              }
              return;
            }
            case 'external_link':
              if (target) window.open(target, '_blank', 'noopener,noreferrer');
              return;
            case 'phone':
              if (target) window.location.href = `tel:${target.replace(/\s+/g, '')}`;
              return;
            case 'email':
              if (target) window.location.href = `mailto:${target}`;
              return;
            case 'info':
            default:
              return;
          }
        },

        _showRecToast(text: string) {
          let t = document.getElementById('rec-toast');
          if (!t) {
            t = document.createElement('div');
            t.id = 'rec-toast';
            t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);padding:12px 20px;background:color-mix(in srgb, var(--theme-text-primary) .92, transparent);color:var(--theme-bg-primary);font-size:14px;font-family:inherit;border-radius:0;z-index:1000;max-width:90vw;box-shadow:0 8px 24px rgba(0,0,0,.2);';
            document.body.appendChild(t);
          }
          t.textContent = text;
          t.style.opacity = '1';
          setTimeout(() => { if (t) t.style.opacity = '0'; t.style.transition = 'opacity .4s'; }, 2500);
        },

        closeSheet() {
          this.activeSheet = null;
          this.sheetDragOffset = 0;
          document.body.style.overflow = '';
        },

        startSheetDrag(event: PointerEvent) {
          event.preventDefault();
          this._sheetDragStart = event.clientY;
          this.sheetIsDragging = true;
          this.sheetDragOffset = 0;

          const onMove = (e: PointerEvent) => {
            const delta = e.clientY - this._sheetDragStart;
            this.sheetDragOffset = Math.max(0, delta);
          };
          const onEnd = () => {
            document.removeEventListener('pointermove', onMove);
            document.removeEventListener('pointerup', onEnd);
            document.removeEventListener('pointercancel', onEnd);
            this.sheetIsDragging = false;
            if (this.sheetDragOffset > 120) {
              this.closeSheet();
            } else {
              this.sheetDragOffset = 0;
            }
          };
          document.addEventListener('pointermove', onMove);
          document.addEventListener('pointerup', onEnd);
          document.addEventListener('pointercancel', onEnd);
        },

        startSheetDragTouch(event: TouchEvent) {
          this._sheetDragStart = event.touches[0].clientY;
          this.sheetIsDragging = true;
          this.sheetDragOffset = 0;

          const onMove = (e: TouchEvent) => {
            const delta = e.touches[0].clientY - this._sheetDragStart;
            this.sheetDragOffset = Math.max(0, delta);
          };
          const onEnd = () => {
            document.removeEventListener('touchmove', onMove);
            document.removeEventListener('touchend', onEnd);
            document.removeEventListener('touchcancel', onEnd);
            this.sheetIsDragging = false;
            if (this.sheetDragOffset > 120) {
              this.closeSheet();
            } else {
              this.sheetDragOffset = 0;
            }
          };
          document.addEventListener('touchmove', onMove, { passive: true });
          document.addEventListener('touchend', onEnd);
          document.addEventListener('touchcancel', onEnd);
        },
      }));

      // Sprint E2 Phase 7 — PlacesSheet Alpine-Component
      // (im selben bundled Script wie guestPage, damit Timing mit Alpine.start() stimmt)
      // @ts-expect-error - Alpine types
      Alpine.data('placesSheet', (initialTab: string) => ({
        activeTab: initialTab,
        showAllAuto: false,
      }));

      // @ts-expect-error - Alpine types
      Alpine.data('conferenceForm', (initial: any) => ({
        rooms: initial.rooms,
        stayRangeDates: initial.stayRangeDates,
        allSlots: initial.allSlots,
        durationOptions: initial.durationOptions,
        labels: initial.labels,
        accessToken: initial.accessToken,
        existingBooking: initial.existingBooking,
        lang: initial.lang,

        view: initial.existingBooking ? 'status' : 'form',
        submitting: false,

        form: {
          room_id: '',
          date: '',
          time: '',
          duration_hours: 0,
          people: 0,
          occasion: '',
          notes: '',
        },

        get currentRoomCapacity() {
          const r = this.rooms.find((r: any) => r.id === this.form.room_id);
          return r ? r.capacity : 12;
        },

        get peopleOptions() {
          const cap = this.currentRoomCapacity;
          return Array.from({ length: cap }, (_, i) => i + 1);
        },

        get canSubmit() {
          return this.form.room_id && this.form.date && this.form.time &&
                 this.form.duration_hours && this.form.people && this.form.occasion.trim();
        },

        get statusInfo() {
          const status = (this.existingBooking?.status || 'pending').toLowerCase();
          if (status === 'confirmed') return { title: this.labels.statusConfirmedTitle, sub: this.labels.statusConfirmedSub };
          if (status === 'cancelled') return { title: this.labels.statusCancelledTitle, sub: this.labels.statusCancelledSub };
          return { title: this.labels.statusPendingTitle, sub: this.labels.statusPendingSub };
        },

        startRebook() {
          this.form = {
            room_id: '',
            date: '',
            time: '',
            duration_hours: 0,
            people: 0,
            occasion: '',
            notes: '',
          };
          this.existingBooking = null;
          this.view = 'form';
        },

        async submit() {
          if (!this.canSubmit || this.submitting) return;
          this.submitting = true;

          const room = this.rooms.find((r: any) => r.id === this.form.room_id);

          try {
            const resp = await fetch('/api/bookings/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_token: this.accessToken,
                type: 'conference',
                details: {
                  room_id: this.form.room_id,
                  room_name: room?.name || '',
                  date: this.form.date,
                  time: this.form.time,
                  duration_hours: this.form.duration_hours,
                  people: this.form.people,
                  occasion: this.form.occasion.trim(),
                  notes: this.form.notes.trim() || null,
                },
              }),
            });

            const data = await resp.json();
            if (!data.ok) {
              alert('Fehler: ' + (data.error || 'unbekannt'));
              this.submitting = false;
              return;
            }

            this.existingBooking = data.booking;
            this.view = 'status';
          } catch (err: any) {
            alert('Netzwerk-Fehler: ' + (err.message || 'unbekannt'));
          } finally {
            this.submitting = false;
          }
        },
      }));

      // @ts-expect-error - Alpine types
      Alpine.data('serviceForm', (initial: any) => ({
        items: initial.items,
        allSlots: initial.allSlots,
        labels: initial.labels,
        accessToken: initial.accessToken,
        existingBooking: initial.existingBooking,
        lang: initial.lang,

        view: initial.existingBooking ? 'status' : 'form',
        submitting: false,

        form: {
          item_id: '',
          timing: '',
          time: '',
          notes: '',
        },

        get canSubmit() {
          if (!this.form.item_id || !this.form.timing) return false;
          if (this.form.timing === 'scheduled' && !this.form.time) return false;
          return true;
        },

        get statusInfo() {
          const status = (this.existingBooking?.status || 'pending').toLowerCase();
          if (status === 'confirmed') return { title: this.labels.statusConfirmedTitle, sub: this.labels.statusConfirmedSub };
          if (status === 'cancelled') return { title: this.labels.statusCancelledTitle, sub: this.labels.statusCancelledSub };
          return { title: this.labels.statusPendingTitle, sub: this.labels.statusPendingSub };
        },

        startRebook() {
          this.form = { item_id: '', timing: '', time: '', notes: '' };
          this.existingBooking = null;
          this.view = 'form';
        },

        async submit() {
          if (!this.canSubmit || this.submitting) return;
          this.submitting = true;

          const item = this.items.find((i: any) => i.id === this.form.item_id);

          try {
            const resp = await fetch('/api/bookings/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_token: this.accessToken,
                type: 'service',
                details: {
                  item_id: this.form.item_id,
                  item_name: item?.name || '',
                  timing: this.form.timing,
                  time: this.form.timing === 'scheduled' ? this.form.time : null,
                  notes: this.form.notes.trim() || null,
                },
              }),
            });

            const data = await resp.json();
            if (!data.ok) {
              alert('Fehler: ' + (data.error || 'unbekannt'));
              this.submitting = false;
              return;
            }

            this.existingBooking = data.booking;
            this.view = 'status';
          } catch (err: any) {
            alert('Netzwerk-Fehler: ' + (err.message || 'unbekannt'));
          } finally {
            this.submitting = false;
          }
        },
      }));

      Alpine.start();
    </script>

    {isShowcase && (
      <>
        <style is:inline>{`
          @keyframes tile-pulse-on {
            0%   { box-shadow: 0 0 0 0 rgba(255,230,0,0);       transform: scale(1); }
            30%  { box-shadow: 0 0 20px 8px rgba(255,230,0,0.8); transform: scale(1.05); }
            100% { box-shadow: 0 0 0 0 rgba(255,230,0,0);       transform: scale(1); }
          }
          @keyframes tile-pulse-off {
            0%   { box-shadow: 0 0 0 0 rgba(255,74,130,0);       opacity: 1; }
            30%  { box-shadow: 0 0 20px 8px rgba(255,74,130,0.8); opacity: 0.6; }
            100% { box-shadow: 0 0 0 0 rgba(255,74,130,0);       opacity: 1; }
          }
          .gate-tile.pulse-on  { animation: tile-pulse-on  800ms ease-out; }
          .gate-tile.pulse-off { animation: tile-pulse-off 800ms ease-out; }
        `}</style>
        <script is:inline>
          window.addEventListener('message', function(e) {
            if (e.origin !== window.location.origin) return;
            var d = e.data;
            if (!d || d.type !== 'highlight-module') return;
            var tile = document.querySelector('.gate-tile[data-tile="' + d.module + '"]');
            if (!tile) return;
            tile.classList.remove('pulse-on', 'pulse-off');
            void tile.offsetWidth;
            tile.classList.add(d.state === 'off' ? 'pulse-off' : 'pulse-on');
            clearTimeout(tile._pulseTimer);
            tile._pulseTimer = setTimeout(function() {
              tile.classList.remove('pulse-on', 'pulse-off');
            }, 800);
          });
        </script>
      </>
    )}

    <!-- Sprint i18n Phase 7 — Sprach-Wechsel-Persistenz via sendBeacon -->
    <script is:inline>
      document.querySelectorAll('.lang-switcher .lang-btn').forEach(btn => {
        btn.addEventListener('click', (ev) => {
          const lang = btn.dataset.lang;
          const switcher = btn.closest('.lang-switcher');
          const token = switcher && switcher.dataset.stayToken;
          if (!lang || !token) return;
          // sendBeacon damit Persistenz vor Navigation garantiert flusht
          try {
            const payload = JSON.stringify({ token, lang });
            const blob = new Blob([payload], { type: 'application/json' });
            navigator.sendBeacon('/api/g/set-language', blob);
          } catch (_) { /* non-fatal */ }
          // Navigation läuft normal weiter (href greift)
        });
      });
    </script>
  </body>
</html>
