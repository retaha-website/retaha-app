    {/* Sprint Legal Phase 2 — Cookie-Banner (zeigt sich nur beim ersten Besuch) */}
    <CookieBanner stayToken={token} />

    <script>
      import Alpine from 'alpinejs';

      // @ts-expect-error - Alpine types
      Alpine.data('guestPage', () => ({
        init() {
          // Sprint Functional Modul C Phase 8 — Post-Stay-Sheet ggf. anzeigen
          if (typeof (this as any)._initPostStay === 'function') {
            (this as any)._initPostStay();
          }
        },
        recSlideIndex: 0,
        recDragOffset: 0,
        recIsDragging: false,
        _swipeStart: 0,
        _swipeStartTime: 0,

        get slideCount() {
          return document.querySelectorAll('.rec-slide').length;
        },

        setRecSlide(i: number) {
          this.recSlideIndex = i;
        },

        startRecSwipe(event: PointerEvent) {
          const target = event.target as HTMLElement;
          if (target.closest('button')) return;
          event.preventDefault();
          this._swipeStart = event.clientX;
          this._swipeStartTime = Date.now();
          this.recIsDragging = true;
          this.recDragOffset = 0;

          const onMove = (e: PointerEvent) => {
            const delta = e.clientX - this._swipeStart;
            const max = this.slideCount - 1;
            if ((this.recSlideIndex === 0 && delta > 0) || (this.recSlideIndex === max && delta < 0)) {
              this.recDragOffset = delta * 0.3;
            } else {
              this.recDragOffset = delta;
            }
          };
          const onEnd = () => {
            document.removeEventListener('pointermove', onMove);
            document.removeEventListener('pointerup', onEnd);
            document.removeEventListener('pointercancel', onEnd);
            this.recIsDragging = false;
            const delta = this.recDragOffset;
            const elapsed = Date.now() - this._swipeStartTime;
            const velocity = Math.abs(delta) / elapsed;
            const threshold = 60;
            const fastSwipe = velocity > 0.4 && Math.abs(delta) > 20;
            const max = this.slideCount - 1;
            if ((delta < -threshold || (fastSwipe && delta < 0)) && this.recSlideIndex < max) {
              this.recSlideIndex++;
            } else if ((delta > threshold || (fastSwipe && delta > 0)) && this.recSlideIndex > 0) {
              this.recSlideIndex--;
            }
            this.recDragOffset = 0;
          };
          document.addEventListener('pointermove', onMove);
          document.addEventListener('pointerup', onEnd);
          document.addEventListener('pointercancel', onEnd);
        },

        startRecSwipeTouch(event: TouchEvent) {
          const target = event.target as HTMLElement;
          if (target.closest('button')) return;
          this._swipeStart = event.touches[0].clientX;
          this._swipeStartTime = Date.now();
          this.recIsDragging = true;
          this.recDragOffset = 0;

          const onMove = (e: TouchEvent) => {
            const delta = e.touches[0].clientX - this._swipeStart;
            const max = this.slideCount - 1;
            if ((this.recSlideIndex === 0 && delta > 0) || (this.recSlideIndex === max && delta < 0)) {
              this.recDragOffset = delta * 0.3;
            } else {
              this.recDragOffset = delta;
            }
          };
          const onEnd = () => {
            document.removeEventListener('touchmove', onMove);
            document.removeEventListener('touchend', onEnd);
            document.removeEventListener('touchcancel', onEnd);
            this.recIsDragging = false;
            const delta = this.recDragOffset;
            const elapsed = Date.now() - this._swipeStartTime;
            const velocity = Math.abs(delta) / elapsed;
            const threshold = 60;
            const fastSwipe = velocity > 0.4 && Math.abs(delta) > 20;
            const max = this.slideCount - 1;
            if ((delta < -threshold || (fastSwipe && delta < 0)) && this.recSlideIndex < max) {
              this.recSlideIndex++;
            } else if ((delta > threshold || (fastSwipe && delta > 0)) && this.recSlideIndex > 0) {
              this.recSlideIndex--;
            }
            this.recDragOffset = 0;
          };
          document.addEventListener('touchmove', onMove, { passive: true });
          document.addEventListener('touchend', onEnd);
          document.addEventListener('touchcancel', onEnd);
        },

        // Sheet state
        activeSheet: null as string | null,
        sheetDragOffset: 0,
        sheetIsDragging: false,
        _sheetDragStart: 0,

        // Eve state (Sprint E4 Phase 9 + 10)
        eveOpen: false,
        eveMessages: (typeof window !== 'undefined' && (window as any).__EVE_INITIAL__?.messages)
          ? [...(window as any).__EVE_INITIAL__.messages]
          : [] as Array<{ role: 'user' | 'assistant'; content: string; streaming?: boolean }>,
        eveTyping: false,
        evePendingAction: null as any,
        eveError: null as string | null,
        eveConfirming: false,
        eveSeenBefore: typeof window !== 'undefined' ? !!localStorage.getItem('retaha_eve_seen') : false,
        _eveLastConversation: '' as string,  // für Audit-Context
        _eveWelcomeTried: false,  // Phase 10: idempotenter Welcome-Trigger
        _eveLang: (typeof window !== 'undefined' && (window as any).__EVE_INITIAL__?.lang) || 'de',

        // Sprint E2 Phase 8 — Place-Detail-Sheet (layered über PlacesSheet)
        activeDetailPlaceId: null as string | null,
        activeDetailData: null as any,
        detailLoading: false,
        detailError: null as string | null,

        async openPlaceDetail(placeId: string) {
          this.activeDetailError = null;
          this.detailError = null;
          this.activeDetailPlaceId = placeId;

          // 1. Cache-Lookup (Picks haben pre-loaded data im window-Global)
          const cache = (typeof window !== 'undefined' && (window as any).__PLACE_DETAILS__?.cache) || {};
          if (cache[placeId]) {
            this.activeDetailData = cache[placeId];
            this.detailLoading = false;
            return;
          }

          // 2. Auto-Place → on-demand fetch
          this.activeDetailData = null;
          this.detailLoading = true;
          try {
            const lang = (typeof window !== 'undefined' && (window as any).__PLACE_DETAILS__?.lang) || 'de';
            const res = await fetch(`/api/places/details?placeId=${encodeURIComponent(placeId)}&lang=${lang}`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const body = await res.json();
            if (!body.ok) throw new Error(body.error || 'Unknown error');
            const d = body.details as any;
            const PRICE_SYMBOLS: Record<string, string> = {
              PRICE_LEVEL_FREE: '', PRICE_LEVEL_INEXPENSIVE: '€', PRICE_LEVEL_MODERATE: '€€',
              PRICE_LEVEL_EXPENSIVE: '€€€', PRICE_LEVEL_VERY_EXPENSIVE: '€€€€',
            };
            this.activeDetailData = {
              name: d.name,
              rating: d.rating,
              userRatingCount: d.userRatingCount,
              priceSymbol: PRICE_SYMBOLS[d.priceLevel ?? ''] ?? '',
              hotelNote: null,  // Auto-Places haben keine Hotel-Notiz
              formattedAddress: d.formattedAddress,
              phone: d.internationalPhoneNumber,
              website: d.websiteUri,
              googleMapsUri: d.googleMapsUri,
              openNow: d.openingHours?.openNow ?? null,
              weekdayDescriptions: d.openingHours?.weekdayDescriptions ?? [],
              reviews: d.reviews ?? [],
              photoUrls: d.photoUrls ?? [],
            };
          } catch (err) {
            this.detailError = `Details konnten nicht geladen werden: ${(err as Error).message}`;
          } finally {
            this.detailLoading = false;
          }
        },

        closePlaceDetail() {
          this.activeDetailPlaceId = null;
          this.activeDetailData = null;
          this.detailError = null;
        },

        async eveSend(text: string) {
          const message = (text || '').trim();
          if (!message || this.eveTyping) return;

          this.eveError = null;
          this.evePendingAction = null;
          this.eveMessages.push({ role: 'user', content: message });
          this.eveTyping = true;
          this._scrollEveBottom();

          // Mark als seen für Pulse-Disable
          try { localStorage.setItem('retaha_eve_seen', '1'); } catch (_) {}
          this.eveSeenBefore = true;

          try {
            const res = await fetch('/api/eve/chat', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ message, lang: this._eveLang }),
            });
            if (!res.ok) {
              const errBody = await res.text().catch(() => '');
              throw new Error(`HTTP ${res.status}: ${errBody.slice(0, 200)}`);
            }

            // Assistant-Bubble pushen + Index tracken. WICHTIG: nach push() greifen
            // wir IMMER via this.eveMessages[msgIdx] zu, damit Alpine den reaktiven
            // Proxy sieht (nicht die Original-Object-Reference).
            this.eveMessages.push({ role: 'assistant', content: '', streaming: true });
            const msgIdx = this.eveMessages.length - 1;
            this.eveTyping = false;

            const reader = res.body!.getReader();
            const decoder = new TextDecoder();
            let buffer = '';

            while (true) {
              const { done, value } = await reader.read();
              if (done) break;
              buffer += decoder.decode(value, { stream: true });
              const blocks = buffer.split('\n\n');
              buffer = blocks.pop() ?? '';
              for (const block of blocks) {
                const line = block.trim();
                if (!line.startsWith('data:')) continue;
                try {
                  const ev = JSON.parse(line.slice(5).trim());
                  if (ev.type === 'text_delta') {
                    this.eveMessages[msgIdx].content += ev.text;
                    this._scrollEveBottom();
                  } else if (ev.type === 'pending_action') {
                    this.evePendingAction = ev.action;
                    this._scrollEveBottom();
                  } else if (ev.type === 'error') {
                    this.eveError = ev.message;
                  } else if (ev.type === 'message_complete') {
                    this.eveMessages[msgIdx].streaming = false;
                  } else if (ev.type === 'escalating') {
                    this.eveMessages[msgIdx].content = '';
                  }
                  // router_decision + tool_use_preview ignorieren wir im UI
                } catch (_) {
                  // unbekannter chunk, weiter
                }
              }
            }
            this.eveMessages[msgIdx].streaming = false;
            this._eveLastConversation = this._buildConversationContext();
          } catch (err) {
            this.eveTyping = false;
            const msg = (err as Error).message || 'Unbekannter Fehler';
            this.eveError = msg;
            console.error('[eve] chat failed:', err);
          }
        },

        async eveConfirm() {
          if (!this.evePendingAction || this.eveConfirming) return;
          this.eveConfirming = true;
          this.eveError = null;
          const pending = this.evePendingAction;

          try {
            const res = await fetch('/api/eve/confirm-action', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                pending_action: pending,
                conversation_context: this._eveLastConversation,
              }),
            });
            const body = await res.json();
            if (body.ok) {
              this.eveMessages.push({ role: 'assistant', content: 'Erledigt — der Hotelier bekommt deine Anfrage gleich.' });
              this.evePendingAction = null;
            } else {
              this.eveError = body.error || 'Bestätigung fehlgeschlagen.';
            }
          } catch (err) {
            this.eveError = (err as Error).message || 'Bestätigung fehlgeschlagen.';
          } finally {
            this.eveConfirming = false;
            this._scrollEveBottom();
          }
