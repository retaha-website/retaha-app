---
import { loadStayByToken, loadBookingsForStay, loadActiveBreakfastItems } from '@retaha/db';
import { normalizeLang, t, dayPart, type Lang } from '@retaha/i18n';
import WeatherIcon from '../../components/WeatherIcon.astro';
import WelcomeScreen from '@retaha/ui-guest/WelcomeScreen';
import BauhausScreen from '../../components/screens/BauhausScreen.astro';
import EditorialScreen from '../../components/screens/EditorialScreen.astro';
import MaisonScreen from '../../components/screens/MaisonScreen.astro';
import WifiSheet from '../../components/sheets/WifiSheet.astro';
import BreakfastSheet from '../../components/sheets/BreakfastSheet.astro';
import ConferenceSheet from '../../components/sheets/ConferenceSheet.astro';
import ServiceSheet from '../../components/sheets/ServiceSheet.astro';
import EveChatSheet from '../../components/eve/EveChatSheet.astro';
import EveFloatingBubble from '../../components/eve/EveFloatingBubble.astro';
import CookieBanner from '../../components/CookieBanner.astro';
import PlacesSheet from '../../components/sheets/PlacesSheet.astro';
import PlaceDetailSheet from '../../components/sheets/PlaceDetailSheet.astro';
import PostStaySheet from '../../components/sheets/PostStaySheet.astro';
import WalletAddSheet from '../../components/sheets/WalletAddSheet.astro';
import { isWalletConfigured } from '@retaha/wallet';
import { buildPhotoUrl } from '../../lib/places/google-client';
import { setStaySessionCookie, getStaySession } from '@retaha/auth';
import { getEveSuggestions } from '@retaha/eve';
import { createSupabaseServiceRoleInstance } from '@retaha/auth';
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/retaha.css';
import '@retaha/ui/styles/components/buttons.css';
import '@retaha/ui/styles/components/inputs.css';
import '@retaha/ui/styles/components/pills.css';
// Theme-Fonts self-hosted (DSGVO-konform) — alle 3 Themes via @fontsource
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/bodoni-moda/400.css';
import '@fontsource/bodoni-moda/400-italic.css';
import '@fontsource/bodoni-moda/500.css';
import '@fontsource/dm-sans/300.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@retaha/ui-guest/themes/classic';
import '@retaha/ui-guest/themes/bauhaus';
import '@retaha/ui-guest/themes/editorial';
import '@retaha/ui-guest/themes/maison';
import { resolveTheme } from '@retaha/ui/theme';
import { isShowcaseToken, findShowcaseSessionByToken, type ShowcaseSession } from '../../lib/showcase/session';

const { token } = Astro.params;

// Sprint H · Group 2 — Showcase-Mode-Erkennung
//   Token mit Prefix 'showcase_' → Pseudo-Stay-Context aus showcase_sessions.
//   Normale Stay-Tokens laufen via loadStayByToken weiter.
let showcaseSession: ShowcaseSession | null = null;
let ctx: any = null;
if (token && isShowcaseToken(token)) {
  showcaseSession = await findShowcaseSessionByToken(token);
  if (showcaseSession) {
    // Pseudo-Context aus Demo-Daten + Hotel + Hotel-Settings
    const sbSrInit = createSupabaseServiceRoleInstance();
    const [{ data: hotelRow }, { data: settingsRow }] = await Promise.all([
      sbSrInit.from('hotels').select('id, slug, name, city, default_language, enabled_languages, logo_url, logo_dark, theme, design_identity, splash_background, brand_primary, brand_secondary').eq('id', showcaseSession.hotel_id).single(),
      sbSrInit.from('hotel_settings').select('*').eq('hotel_id', showcaseSession.hotel_id).single(),
    ]);
    if (hotelRow) {
      // Demo-Daten: check_in = heute, check_out = morgen 11:00
      const now = new Date();
      const todayStart = new Date(now); todayStart.setUTCHours(14, 0, 0, 0);
      const tomorrowCheckout = new Date(todayStart); tomorrowCheckout.setUTCDate(tomorrowCheckout.getUTCDate() + 1); tomorrowCheckout.setUTCHours(11, 0, 0, 0);
      ctx = {
        stay: {
          id: showcaseSession.id,
          check_in: todayStart.toISOString(),
          check_out: tomorrowCheckout.toISOString(),
          is_active: true,
        },
        guest: {
          id: showcaseSession.id,
          first_name: showcaseSession.demo_data?.guest_first_name ?? 'Anna',
          last_name: showcaseSession.demo_data?.guest_last_name ?? 'Demo',
          language: hotelRow.default_language ?? 'de',
          visit_count: 1,
        },
        room: {
          id: showcaseSession.id,
          room_number: showcaseSession.demo_data?.room_number ?? '101',
          room_name: showcaseSession.demo_data?.room_name ?? 'Demo-Suite',
        },
        hotel: hotelRow,
        settings: settingsRow ?? {},
      };
    }
  }
} else {
  ctx = token ? await loadStayByToken(token) : null;
}

if (!ctx) {
  // Fix 4: graceful Fallback statt 404. Gestalteter Showcase kommt im Design-Sprint.
  return new Response(
    `<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="var(--theme-bg-primary)" />
    <title>retaha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style>:root { --theme-accent: #FF4A82; --theme-bg-primary: #FFFFFF; --theme-text-primary: #1A1A1A; }</style>
  </head>
  <body style="margin:0;font-family:-apple-system,BlinkMacSystemFont,'Space Grotesk',system-ui,sans-serif;background:var(--theme-bg-primary);color:var(--theme-text-primary);display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px">
    <div style="text-align:center;max-width:420px">
      <p style="font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--theme-accent);margin:0 0 20px 0">— retaha</p>
      <h1 style="font-size:26px;font-weight:300;letter-spacing:-0.02em;line-height:1.2;margin:0 0 12px 0">diese einladung ist nicht (mehr) gültig<span style="color:var(--theme-accent)">.</span></h1>
      <p style="opacity:0.55;font-size:14px;line-height:1.5;margin:0">bitte frag an der rezeption nach einem neuen link.</p>
    </div>
  </body>
</html>`,
    { status: 200, headers: { 'Content-Type': 'text/html; charset=utf-8' } }
  );
}

const { stay, guest, room, hotel, settings } = ctx;

// Sprint E4 Phase 9 Fix — Auto-Pair: wer den access_token in der URL hat,
// kriegt automatisch eine Stay-Session-Cookie. Konsistent zum Sprint-D-Pair-
// Pattern (/api/pair?token=...). Eve-Chat (/api/eve/chat) braucht den Cookie.
const existingSession = await getStaySession(Astro.cookies);
const isShowcase = !!showcaseSession;
if (!existingSession || existingSession.stay_id !== stay.id || !!existingSession.is_showcase !== isShowcase) {
  await setStaySessionCookie(Astro.cookies, {
    stay_id: stay.id,
    hotel_id: hotel.id,
    check_out_utc: stay.check_out,
    is_showcase: isShowcase,
  });
}

const menuItems = await loadActiveBreakfastItems(hotel.id);

const existingBreakfastBookings = await loadBookingsForStay(stay.id, 'breakfast');
// Show the most recent booking regardless of status (pending/confirmed/cancelled)
// so the guest knows what happened. They can rebook if cancelled.
const activeBreakfastBooking = existingBreakfastBookings[0] || null;

const existingConferenceBookings = await loadBookingsForStay(stay.id, 'conference');
const activeConferenceBooking = existingConferenceBookings[0] || null;

const existingServiceBookings = await loadBookingsForStay(stay.id, 'service');
const activeServiceBooking = existingServiceBookings[0] || null;

// Sprint i18n Phase 7 — Sprach-Resolution erweitert um Browser-Locale + enabled_languages
// Hierarchie: ?lang= URL > guest.language > Accept-Language (gegen enabled) > hotel.default_language > 'de'
const langParam = new URL(Astro.request.url).searchParams.get('lang');
const acceptLangHeader = Astro.request.headers.get('accept-language') ?? '';
const hotelEnabledLangs: string[] = Array.isArray((hotel as any).enabled_languages)
  ? (hotel as any).enabled_languages : ['de','en','fr','es'];

function pickBrowserLang(acceptHeader: string, enabled: string[]): string | null {
  // "de-DE,de;q=0.9,en;q=0.8" → ['de-DE','de','en']
  const tags = acceptHeader.split(',').map(s => s.split(';')[0].trim().toLowerCase()).filter(Boolean);
  for (const tag of tags) {
    const stripped = tag.slice(0, 2);
    if (enabled.includes(stripped)) return stripped;
  }
  return null;
}

const browserLang = pickBrowserLang(acceptLangHeader, hotelEnabledLangs);
const resolvedRaw = langParam || guest?.language || browserLang || hotel.default_language;
const lang: Lang = normalizeLang(resolvedRaw);
const hotelDefaultLang: Lang = normalizeLang(hotel.default_language);

import { pickI18n as pickI18nHelper } from '@retaha/i18n';
import { LANGUAGE_LABELS as LANG_LABELS_FULL, isRTL as isRTLHelper } from '@retaha/i18n';
const isRTL = isRTLHelper(lang as any);
const htmlDir = isRTL ? 'rtl' : 'ltr';

// Sprint E4 Phase 10 — Tageszeit-Chips (hotel-timezone-aware) + History pre-load
const hotelTz = (hotel as any).timezone || 'Europe/Berlin';
let localHour = 9;
try {
  localHour = parseInt(
    new Intl.DateTimeFormat('en-US', { timeZone: hotelTz, hour: 'numeric', hourCycle: 'h23' }).format(new Date()),
    10,
  );
  if (!Number.isFinite(localHour)) localHour = 9;
} catch { localHour = 9; }
const eveSuggestions = getEveSuggestions(localHour, lang);

// Pre-load chat_messages für diesen Stay (letzte 20) — Frontend startet mit
// History statt leerem Sheet. Wenn 0 Messages: Welcome-Trigger im Frontend.
const sbSr = createSupabaseServiceRoleInstance();
const { data: initialChatRows } = (settings as any).eve_enabled
  ? await sbSr
      .from('chat_messages')
      .select('id, role, content, created_at, eve_message_feedback(rating)')
      .eq('stay_id', stay.id)
      .order('created_at', { ascending: true })
      .limit(20)
  : { data: [] };
// Sprint Functional Modul C Phase 7 — id + feedback-Rating für Daumen-UI mitladen
const initialEveMessages = (initialChatRows ?? [])
  .filter((m: any) => m.role === 'user' || m.role === 'assistant')
  .map((m: any) => ({
    id: m.id,
    role: m.role as 'user' | 'assistant',
    content: m.content,
    streaming: false,
    feedback: m.eve_message_feedback?.[0]?.rating ?? null,
  }));

// Sprint E2 Phase 7 — Places-Sheet-Daten: Picks + Nearby-Cache + hotel lat/lng
const [{ data: hotelGeoRow }, { data: placePicksRows }, { data: nearbyRows }] = await Promise.all([
  sbSr.from('hotels').select('latitude, longitude, logo_dark, splash_background').eq('id', hotel.id).maybeSingle(),
  sbSr.from('hotel_place_picks')
    .select('id, place_id, category, hotel_note, hotel_note_en, hotel_note_fr, hotel_note_es, cached_data, photo_references, sort_order')
    .eq('hotel_id', hotel.id)
    .eq('is_published', true)
    .order('sort_order', { ascending: true })
    .order('created_at', { ascending: false }),
  sbSr.from('hotel_place_nearby_cache')
    .select('category, cached_places')
    .eq('hotel_id', hotel.id),
]);
const placesHotelLat = (hotelGeoRow?.latitude as number | null) ?? null;
const placesHotelLng = (hotelGeoRow?.longitude as number | null) ?? null;
const hotelHeroBg   = (hotelGeoRow?.splash_background as string | null) ?? (hotel as any).splash_background ?? null;
const hotelLogoDark = (hotelGeoRow?.logo_dark as string | null) ?? (hotel as any).logo_dark ?? null;
const placesPicks = (placePicksRows ?? []) as any[];
const placesNearby = (nearbyRows ?? []) as any[];

// Sprint E2 Phase 8 — Pre-render Pick-Detail-Daten als window-Global damit
// PlaceDetailSheet sie sofort hat (kein fetch). Auto-Places werden on-demand
// via /api/places/details geholt — die haben hier KEINE Daten.
const PRICE_SYMBOLS: Record<string, string> = {
  PRICE_LEVEL_FREE: '', PRICE_LEVEL_INEXPENSIVE: '€', PRICE_LEVEL_MODERATE: '€€',
  PRICE_LEVEL_EXPENSIVE: '€€€', PRICE_LEVEL_VERY_EXPENSIVE: '€€€€',
};
const placeDetailCache: Record<string, any> = {};
for (const p of placesPicks) {
  const cd = p.cached_data ?? {};
  const note = lang === 'de' ? p.hotel_note
    : lang === 'en' ? (p.hotel_note_en ?? p.hotel_note)
    : lang === 'fr' ? (p.hotel_note_fr ?? p.hotel_note)
    : (p.hotel_note_es ?? p.hotel_note);
  placeDetailCache[p.place_id] = {
    name: cd.name,
    rating: cd.rating,
    userRatingCount: cd.user_ratings_total,
    priceSymbol: PRICE_SYMBOLS[cd.price_level] ?? '',
    hotelNote: note?.trim() || null,
    formattedAddress: cd.formatted_address,
    phone: cd.international_phone_number,
    website: cd.website_uri,
    googleMapsUri: cd.google_maps_uri,
    openNow: cd.opening_hours?.openNow ?? null,
    weekdayDescriptions: cd.opening_hours?.weekdayDescriptions ?? [],
    reviews: (cd.reviews ?? []).slice(0, 3),
    photoUrls: (p.photo_references ?? []).slice(0, 8).map((n: string) => buildPhotoUrl(n, 1200)),
  };
}

// Sprint i18n Phase 7 — pickI18n statt Hand-Mapping (mit Safety-Fallback auf alte _de-Spalte)
const welcomeMsg = pickI18nHelper((settings as any).welcome_message_i18n, hotelDefaultLang as any, lang as any)
  || settings.welcome_message_de;
const hotelEyebrow = pickI18nHelper((settings as any).hotel_eyebrow_i18n, hotelDefaultLang as any, lang as any)
  || settings.hotel_eyebrow_de || (hotel.city || '');

const greetingLabel = t('hero.greeting', lang);
const greetingFallback = t('hero.greetingFallback', lang);
const greetingName = guest?.first_name
  ? `${greetingLabel} ${guest.first_name}`
  : greetingFallback;

// Visit-Ordinals nur wenn guest existiert (sonst kein Besuch-Counter)
let visitText = '';
if (guest) {
  const visitOrdinals: Record<Lang, string> = {
    de: `dein ${guest.visit_count}. Besuch`,
    en: `your ${guest.visit_count}${guest.visit_count === 1 ? 'st' : guest.visit_count === 2 ? 'nd' : guest.visit_count === 3 ? 'rd' : 'th'} visit`,
    fr: `votre ${guest.visit_count}${guest.visit_count === 1 ? 'ère' : 'ème'} visite`,
    es: `tu ${guest.visit_count}ª visita`,
  };
  visitText = visitOrdinals[lang];
}

const checkInDate = new Date(stay.check_in);
const checkOutDate = new Date(stay.check_out);
const localeMap: Record<Lang, string> = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES' };

const fmtShort = (d: Date) => d.toLocaleDateString(localeMap[lang], {
  weekday: 'short', day: '2-digit', month: 'short',
});

const checkInLabel = fmtShort(checkInDate);
const checkOutLabel = fmtShort(checkOutDate);

// Calculate nights
const msPerDay = 1000 * 60 * 60 * 24;
const nightsCount = Math.max(1, Math.round((checkOutDate.getTime() - checkInDate.getTime()) / msPerDay));

// Stay range label
const stayLabels = {
  de: { range: 'Aufenthalt', nights: nightsCount === 1 ? 'Nacht' : 'Nächte' },
  en: { range: 'Stay', nights: nightsCount === 1 ? 'night' : 'nights' },
  fr: { range: 'Séjour', nights: nightsCount === 1 ? 'nuit' : 'nuits' },
  es: { range: 'Estancia', nights: nightsCount === 1 ? 'noche' : 'noches' },
};
const stayLabel = stayLabels[lang];
const stayRange = `${checkInLabel} – ${checkOutLabel} · ${nightsCount} ${stayLabel.nights}`;

const now = new Date();
const dayPartLabel = dayPart(lang, now.getHours());
const dateLabel = now.toLocaleDateString(localeMap[lang], { weekday: 'long', day: 'numeric', month: 'short' });

// Sprint E7 Phase 4/5 — Action-Cards aus relationaler Tabelle.
// Verifikation Phase 5: alle Hotels mit JSONB-Cards haben action_cards
// → JSONB-Fallback entfernt. Die Spalte hotel_settings.recommendations
// existiert noch (deprecated), wird in Sprint G nach Production-Verifikation
// gedroppt.
const { data: actionCardsRows } = await sbSr
  .from('hotel_action_cards')
  .select('id, card_type, action_target, title_de, title_i18n, subtitle_de, subtitle_i18n, eyebrow_de, eyebrow_i18n, cta_de, cta_i18n, image_url, card_class, sort_order')
  .eq('hotel_id', hotel.id)
  .eq('is_published', true)
  .order('sort_order', { ascending: true });

function defaultIconForType(card_type: string): 'sun' | 'square' | 'triangle' {
  switch (card_type) {
    case 'external_link': return 'square';
    case 'phone': case 'email': case 'info': return 'triangle';
    default: return 'sun';
  }
}

const recs = (actionCardsRows ?? []).map((card: any) => ({
  id: card.id,
  cardType: card.card_type,
  actionTarget: card.action_target,
  imageUrl: card.image_url,
  // Sprint i18n Phase 7 — pickI18n mit Safety-Fallback auf alte _de-Spalten
  eyebrow: pickI18nHelper(card.eyebrow_i18n,  hotelDefaultLang as any, lang as any) || card.eyebrow_de || '',
  title:   pickI18nHelper(card.title_i18n,    hotelDefaultLang as any, lang as any) || card.title_de    || '',
  sub:     pickI18nHelper(card.subtitle_i18n, hotelDefaultLang as any, lang as any) || card.subtitle_de || '',
  cta:     pickI18nHelper(card.cta_i18n,      hotelDefaultLang as any, lang as any) || card.cta_de      || '',
  cardClass: card.card_class || 'rec-anthrazit',
  icon: defaultIconForType(card.card_type),
}));

const weather = {
  temperature: 21,
  iconType: 'partly' as 'sun' | 'partly' | 'cloud' | 'rain' | 'night',
  labelKey: 'weather.partly' as const,
};

const f = (settings as any).features ?? {};

const switchUrl = (l: string) => `/g/${token}?lang=${l}`;

const breakfastLocationMap: Record<Lang, string | null> = {
  de: settings.breakfast_location_de,
  en: settings.breakfast_location_en,
  fr: settings.breakfast_location_fr,
  es: settings.breakfast_location_es,
};
const breakfastLocation = breakfastLocationMap[lang] || settings.breakfast_location_de || 'im Wintergarten';

const breakfastIncludedMap: Record<Lang, string | null> = {
  de: settings.breakfast_included_de,
  en: settings.breakfast_included_en,
  fr: settings.breakfast_included_fr,
  es: settings.breakfast_included_es,
};
const breakfastIncluded = breakfastIncludedMap[lang] || settings.breakfast_included_de || '';

const reservationEnabled = settings.features?.breakfast_reservation !== false;

// Theme kommt ausschließlich aus hotel.design_identity — einzige Source of Truth.
// Kein URL-Override, kein session.theme_override — hotel-level only.
const VALID_IDENTITIES = new Set(['bauhaus', 'editorial', 'maison']);
const hotelDesignIdentity = (hotel as any).design_identity ?? null;
const activeTheme = (hotelDesignIdentity && VALID_IDENTITIES.has(hotelDesignIdentity))
  ? hotelDesignIdentity
  : resolveTheme({ hotelTheme: (hotel as any).theme, requestUrl: Astro.url });

const brandPrimary: string | null = (hotel as any).brand_primary ?? null;
const brandSecondary: string | null = (hotel as any).brand_secondary ?? null;
const brandStyle = brandPrimary
  ? `--user-brand-primary:${brandPrimary}${brandSecondary ? `;--user-brand-secondary:${brandSecondary}` : ''}`
  : undefined;

// Sprint Functional Modul C Phase 8 — Post-Stay-Sheet-Gate
// Render-Bedingung: check_out liegt in der Vergangenheit + noch kein Feedback.
// Cooldown (24h via localStorage) entscheidet danach Client-seitig, ob das
// Sheet wirklich aufpoppt — Render-Aufwand sparen wir trotzdem schon hier.
// Sprint Wallet Phase 5 — Add-to-Wallet nur anzeigen wenn Wallet konfiguriert
// UND der Gast eine Email hat (Pass braucht guest_email).
const walletAvailable = isWalletConfigured() && !!guest?.email;

const stayEnded = Date.parse(stay.check_out) < Date.now();
let hasStayFeedback = false;
if (stayEnded) {
  const { data: existingFb } = await sbSr
    .from('stay_feedback')
    .select('id')
    .eq('stay_id', stay.id)
    .maybeSingle();
  hasStayFeedback = !!existingFb;
}
const showPostStay = stayEnded && !hasStayFeedback;
---

<!DOCTYPE html>
<html lang={lang} dir={htmlDir} data-theme={activeTheme} style={brandStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="var(--theme-text-primary)" />
    <title>{hotel.name} · {greetingName}</title>
  </head>
  <body class={`gate-guest gate-theme-${activeTheme}`}>
    {isShowcase && (
      <div class="demo-mode-badge" role="status" aria-label="Demo-Modus aktiv">
        DEMO-MODE
      </div>
    )}
    <main x-data="guestPage" x-cloak>

      {/* ── Themed Welcome (bauhaus | editorial | maison) — unified WelcomeScreen ── */}
      {(activeTheme === 'bauhaus' || activeTheme === 'editorial' || activeTheme === 'maison') && (
        <WelcomeScreen
          hotel={hotel}
          hotelLogoDark={hotelLogoDark}
          guest={guest}
          room={room}
          settings={settings}
          token={token!}
          lang={lang}
          hotelEnabledLangs={hotelEnabledLangs}
          greetingName={greetingName}
          checkInLabel={checkInLabel}
          checkOutLabel={checkOutLabel}
          nightsCount={nightsCount}
          recs={recs}
          f={f}
          walletAvailable={walletAvailable}
          roomLabel={t('hero.stay.room', lang as Lang)}
        />
      )}

      {/* ── Classic Design (Standard gate-* CSS) ── */}
      {(activeTheme === 'classic' || (activeTheme !== 'bauhaus' && activeTheme !== 'editorial' && activeTheme !== 'maison')) && (
      <Fragment>
      <!-- HERO -->
      <section class="gate-hero">
        <div class="gate-hero-bg" style={hotelHeroBg ? `background-image: url('${hotelHeroBg}')` : undefined}></div>
        <div class="gate-hero-overlay"></div>
        <div class="gate-hero-content">
          <div class="gate-hero-top">
            <div class="gate-hero-tag">
              <span class="gate-hero-tag-shapes">
                <span class="circle"></span>
                <span class="square"></span>
                <span class="triangle"></span>
              </span>
              <span>{hotelEyebrow}</span>
            </div>
            <div class="lang-switcher" data-stay-token={token}>
              {hotelEnabledLangs.map(l => (
                <a
                  href={switchUrl(l)}
                  class={`lang-btn ${lang === l ? 'active' : ''}`}
                  data-lang={l}
                  title={LANG_LABELS_FULL[l as keyof typeof LANG_LABELS_FULL] ?? l}
                >{l.toUpperCase()}</a>
              ))}
            </div>
          </div>

          {hotel.logo_url ? (
            hotelLogoDark
              ? <img class="gate-hero-logo" src={hotelLogoDark} alt={hotel.name} />
              : <img class="gate-hero-logo gate-hero-logo--invert" src={hotel.logo_url} alt={hotel.name} />
          ) : (
            <img class="gate-hero-logo" src="/specht-anthrazit.svg" alt={hotel.name} />
          )}

          <div class="gate-hero-welcome">
            <div class="gate-hero-kicker">{t('hero.kicker', lang)}</div>
            <h1 class="gate-hero-greeting">
              {greetingName}<span class="dot">.</span>
            </h1>
            <p class="gate-hero-sub">{welcomeMsg}{visitText && ` — ${visitText}`}.</p>
          </div>

          <div class="gate-hero-stay">
            {room && (
              <div class="gate-hero-stay-block">
                <div class="label">{t('hero.stay.room', lang)}</div>
