        eveCancel() {
          this.evePendingAction = null;
          this.eveMessages.push({ role: 'assistant', content: 'Kein Problem, sag Bescheid wenn ich helfen kann.' });
          this._scrollEveBottom();
        },

        eveClose() {
          this.eveOpen = false;
