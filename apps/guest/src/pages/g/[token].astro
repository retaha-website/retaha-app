        // Wird bei init() vom Alpine-Component aufgerufen (s. registerguestPageInit).
        _initPostStay() {
          const cfg = (window as any).__RETAHA_POSTSTAY__;
          if (!cfg || !cfg.shouldAutoOpen) return;
          // Sanfter Auto-Open: 1.6s damit Gast die Seite zuerst sieht.
