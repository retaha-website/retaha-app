        // Sprint Functional Modul C Phase 7 — Eve-Feedback (Daumen)
        async sendEveFeedback(messageId: string, rating: 1 | -1) {
          if (!messageId) return;
          const idx = this.eveMessages.findIndex((m: any) => m.id === messageId);
          if (idx < 0) return;
          // Optimistic Update
          const prev = this.eveMessages[idx].feedback;
          (this.eveMessages[idx] as any).feedback = rating;
          try {
            const res = await fetch('/api/g/eve-feedback', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ message_id: messageId, rating }),
            });
            const data = await res.json();
            if (!data.ok) {
              (this.eveMessages[idx] as any).feedback = prev;
              this._showRecToast('Feedback fehlgeschlagen.');
              return;
            }
            this._showRecToast(rating === 1 ? 'Danke!' : 'Danke für dein Feedback.');
          } catch (_) {
            (this.eveMessages[idx] as any).feedback = prev;
            this._showRecToast('Netzwerk-Fehler.');
