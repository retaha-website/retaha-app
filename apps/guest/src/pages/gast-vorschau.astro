---
import HotelierLayout from '../layouts/HotelierLayout.astro';
import PhonePreview from '../components/gast-vorschau/PhonePreview.astro';
import SettingsPanel from '../components/gast-vorschau/settings/SettingsPanel.astro';
import DemoQrCard from '@retaha/ui/components/shared/DemoQrCard.astro';
import { getUser, getUserHotels, getOrCreateShowcaseUrl, createSupabaseServerInstance } from '@retaha/auth';
import { demoTags } from '../lib/gast-vorschau/demo-data';

const BACKOFFICE = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect(`${BACKOFFICE}/admin/login`);

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect(`${BACKOFFICE}/admin/login?error=no_hotel`);

const demoUrl = await getOrCreateShowcaseUrl(hotel.id, user.id);

// Sprachdaten + hotel_settings parallel laden
const sb = createSupabaseServerInstance(Astro.cookies, Astro.request);
const [
  { data: hotelLang, error: hotelLangError },
  { data: hotelSettings },
] = await Promise.all([
  sb.from('hotels').select('default_language, enabled_languages').eq('id', hotel.id).maybeSingle(),
  sb.from('hotel_settings')
    .select('welcome_message_i18n, welcome_message_de, hotel_eyebrow_i18n, hotel_eyebrow_de, guest_address_form')
    .eq('hotel_id', hotel.id)
    .maybeSingle(),
]);
if (hotelLangError) console.error('[gast-vorschau] hotel lang fetch error', hotelLangError);
const hotelDefaultLang: string = hotelLang?.default_language ?? 'de';
const hotelEnabledLangs: string[] = Array.isArray(hotelLang?.enabled_languages)
  ? hotelLang.enabled_languages
  : ['de', 'en', 'fr', 'es'];

// Welcome/Eyebrow: Wert in Default-Sprache extrahieren
function pickSettingsText(i18n: unknown, fallbackDe: string | null | undefined, lang: string): string {
  if (i18n && typeof i18n === 'object') {
    const map = i18n as Record<string, { value?: string }>;
    return map[lang]?.value || map['de']?.value || fallbackDe || '';
  }
  return fallbackDe || '';
}
const welcomeText = pickSettingsText(hotelSettings?.welcome_message_i18n, hotelSettings?.welcome_message_de, hotelDefaultLang);
const eyebrowText = pickSettingsText(hotelSettings?.hotel_eyebrow_i18n,   hotelSettings?.hotel_eyebrow_de,   hotelDefaultLang);
const formality   = ((hotelSettings?.guest_address_form ?? 'du') === 'sie' ? 'sie' : 'du') as 'du' | 'sie';
---

<HotelierLayout
  title="Gast-Vorschau"
  activeTab="gast"
  hotelName={hotel.name}
  hotelLogoUrl={hotel.logo_primary ?? hotel.logo_dark}
>
  <section class="gast-hero">
    <span class="gast-hero__eyebrow">Gast-Vorschau · Live</span>
    <h1 class="gast-hero__title">
      So sehen es deine Gäste<span class="dot-pink">.</span>
    </h1>
    <p class="gast-hero__sub">
      Klicke durch verschiedene Szenen — Settings ändern, Handy aktualisiert live.
    </p>
    <button class="gast-preview-btn" id="open-live-preview" type="button">
      → In Gäste-App öffnen
      <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M6 3l5 5-5 5"/>
      </svg>
    </button>
  </section>

  <script>
    import { getState } from '../lib/gast-vorschau/state';

    document.getElementById('open-live-preview')?.addEventListener('click', async () => {
      const btn = document.getElementById('open-live-preview') as HTMLButtonElement;
      btn.disabled = true;
      const orig = btn.innerHTML;
      btn.textContent = '…';
      const win = window.open('', '_retaha_preview');
      try {
        const res = await fetch('/api/admin/preview-url');
        const data = await res.json();
        const base: string = data?.url ?? '/gast-vorschau';
        const persona = getState().persona;
        const sep = base.includes('?') ? '&' : '?';
        if (win) win.location.href = `${base}${sep}persona=${persona}`;
      } catch {
        if (win) win.location.href = '/gast-vorschau';
      } finally {
        btn.disabled = false;
        btn.innerHTML = orig;
      }
    });
  </script>

  <script>
    // ─── iframe-basierter Demo-Modus ──────────────────────────────────────

    const DEMO_MODULES = ['eve', 'breakfast', 'conference', 'service', 'empfehlungen', 'self_checkout'];

    const iframe        = document.getElementById('guestPreview') as HTMLIFrameElement | null;
    const phonePreview  = document.getElementById('phonePreview');
    const demoBar       = document.getElementById('demoBar');
    const interactiveBar = document.getElementById('interactiveBar');

    const baseUrl = iframe?.dataset.baseUrl ?? '';

    let isInteractive   = false;
    let demoModuleIndex = 0;
    let demoTimer:      ReturnType<typeof setTimeout> | null = null;

    // ── postMessage helper ────────────────────────────────────────────────

    function sendHighlight(module: string, state: 'on' | 'off' | 'demo') {
      if (!iframe?.contentWindow) return;
      iframe.contentWindow.postMessage(
        { type: 'highlight-module', module, state },
        window.location.origin,
      );
    }

    // ── Demo Loop ─────────────────────────────────────────────────────────

    function tickDemo() {
      if (isInteractive) return;
      const module = DEMO_MODULES[demoModuleIndex % DEMO_MODULES.length];
      sendHighlight(module, 'demo');
      demoTimer = setTimeout(() => {
        demoModuleIndex = (demoModuleIndex + 1) % DEMO_MODULES.length;
        if (!isInteractive) demoTimer = setTimeout(tickDemo, 400);
      }, 1200);
    }

    function stopDemo() {
      if (demoTimer) { clearTimeout(demoTimer); demoTimer = null; }
    }

    // ── Interactive Mode ──────────────────────────────────────────────────

    function setInteractive(on: boolean) {
      isInteractive = on;
      phonePreview?.classList.toggle('is-interactive', on);
      if (demoBar)        demoBar.hidden        = on;
      if (interactiveBar) interactiveBar.hidden = !on;
      if (on) stopDemo();
      else    { demoModuleIndex = 0; demoTimer = setTimeout(tickDemo, 300); }
    }

    document.getElementById('demoInteractiveBtn')?.addEventListener('click', () => setInteractive(true));
    document.getElementById('demoDemoBtn')?.addEventListener('click',        () => setInteractive(false));

    // ── Persona Switching ─────────────────────────────────────────────────

    document.querySelectorAll<HTMLButtonElement>('.persona-dot').forEach(dot => {
      dot.addEventListener('click', () => {
        const persona = dot.dataset.persona;
        if (!persona || !iframe || !baseUrl) return;
        stopDemo();
        const sep = baseUrl.includes('?') ? '&' : '?';
        iframe.src = `${baseUrl}${sep}persona=${persona}`;
        iframe.onload = () => {
          demoModuleIndex = 0;
          if (!isInteractive) demoTimer = setTimeout(tickDemo, 800);
          iframe.onload = null;
        };
      });
    });

    // ── Module Toggle → postMessage ───────────────────────────────────────

    document.addEventListener('click', e => {
      const toggle = (e.target as HTMLElement).closest<HTMLButtonElement>('.module-toggle');
      if (!toggle) return;
      const key = toggle.dataset.moduleKey;
      if (!key) return;
      setTimeout(() => {
        const isOn = toggle.getAttribute('aria-pressed') === 'true';
        sendHighlight(key, isOn ? 'on' : 'off');
      }, 20);
    }, true);

    // ── Init — warte bis iframe geladen ───────────────────────────────────

    if (iframe) {
      iframe.addEventListener('load', () => {
        if (!isInteractive && !demoTimer) {
          demoTimer = setTimeout(tickDemo, 600);
        }
      }, { once: true });
    }
  </script>

  <div class="gast-layout">
    <PhonePreview showcaseUrl={demoUrl ?? ''} />
    <div class="gast-sidebar">
      <SettingsPanel
        tags={demoTags}
        hotelName={hotel.name}
        hotelId={hotel.id}
        enabledLanguages={hotelEnabledLangs}
        defaultLanguage={hotelDefaultLang}
        welcomeText={welcomeText}
        eyebrowText={eyebrowText}
        formality={formality}
      />
      <DemoQrCard demoUrl={demoUrl} />
    </div>
  </div>
</HotelierLayout>

<style>
  .gast-hero {
    max-width: 1400px; margin: 0 auto;
    padding: 48px 32px 32px;
  }
  @media (max-width: 768px) { .gast-hero { padding: 32px 20px 24px; } }

  .gast-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: #0A0A0A; background: var(--te-yellow);
    padding: 5px 10px; display: inline-block;
    margin-bottom: 24px; font-weight: 500; border-radius: var(--r-sm);
  }
  .gast-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 400; line-height: 1; letter-spacing: -0.03em; margin-bottom: 16px;
  }
  .gast-hero__sub {
    font-size: 16px; color: var(--ink-soft); line-height: 1.5; max-width: 560px;
  }

  .gast-layout {
    max-width: 1400px; margin: 0 auto;
    padding: 0 32px 80px;
    display: grid; grid-template-columns: 5fr 7fr;
    gap: 48px; align-items: start;
  }
  @media (max-width: 1000px) {
    .gast-layout { grid-template-columns: 1fr; gap: 32px; padding: 0 20px 64px; }
  }
  .gast-sidebar { display: flex; flex-direction: column; gap: 16px; }

  .gast-preview-btn {
    margin-top: 20px;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); cursor: pointer;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .gast-preview-btn:hover:not(:disabled) { background: var(--te-yellow-soft); }
  .gast-preview-btn:disabled { opacity: 0.5; cursor: wait; }
</style>
