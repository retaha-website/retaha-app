---
import HotelierLayout from '../layouts/HotelierLayout.astro';
import PhonePreview from '../components/gast-vorschau/PhonePreview.astro';
import SettingsPanel from '../components/gast-vorschau/settings/SettingsPanel.astro';
import DemoQrCard from '@retaha/ui/components/shared/DemoQrCard.astro';
import { getUser, getUserHotels, getOrCreateShowcaseUrl } from '@retaha/auth';
import { demoTags } from '../lib/gast-vorschau/demo-data';

const BACKOFFICE = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect(`${BACKOFFICE}/admin/login`);

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect(`${BACKOFFICE}/admin/login?error=no_hotel`);

const demoUrl = await getOrCreateShowcaseUrl(hotel.id, user.id);
---

<HotelierLayout
  title="Gast-Vorschau"
  activeTab="gast"
  hotelName={hotel.name}
  hotelLogoUrl={hotel.logo_primary ?? hotel.logo_dark}
>
  <section class="gast-hero">
    <span class="gast-hero__eyebrow">Gast-Vorschau · Live</span>
    <h1 class="gast-hero__title">
      So sehen es deine Gäste<span class="dot-pink">.</span>
    </h1>
    <p class="gast-hero__sub">
      Klicke durch verschiedene Szenen — Settings ändern, Handy aktualisiert live.
    </p>
    <button class="gast-preview-btn" id="open-live-preview" type="button">
      → In Gäste-App öffnen
      <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M6 3l5 5-5 5"/>
      </svg>
    </button>
  </section>

  <script>
    document.getElementById('open-live-preview')?.addEventListener('click', async () => {
      const btn = document.getElementById('open-live-preview') as HTMLButtonElement;
      btn.disabled = true;
      const orig = btn.innerHTML;
      btn.textContent = '…';
      const win = window.open('', '_retaha_preview');
      try {
        const res = await fetch('/api/admin/preview-url');
        const data = await res.json();
        if (win) win.location.href = data?.url ?? '/gast-vorschau';
      } catch {
        if (win) win.location.href = '/gast-vorschau';
      } finally {
        btn.disabled = false;
        btn.innerHTML = orig;
      }
    });
  </script>

  <script>
    // ─── Demo-Loop + Zoom + Interaktiv-Modus — Clean State Machine ──────────

    const LABEL_TO_MODULE: Record<string, string> = {
      'eve': 'eve', 'frühstück': 'breakfast', 'service': 'service',
      'tipps': 'empfehlungen', 'konferenz': 'conference', 'wallet': 'wallet',
    };
    const MODULE_DISPLAY_NAME: Record<string, string> = {
      'eve': 'Eve Concierge', 'breakfast': 'Frühstück', 'service': 'Service',
      'empfehlungen': 'Tipps & Orte', 'conference': 'Konferenz', 'wallet': 'Wallet',
    };

    // ── DOM refs ──────────────────────────────────────────────────────────
    const phonePreview    = document.getElementById('phonePreview');
    const phoneContent    = document.getElementById('phoneContent') as HTMLElement | null;
    const zoomNotice      = document.getElementById('zoomNotice')   as HTMLElement | null;
    const zoomNoticeLabel = document.getElementById('zoomNoticeLabel');
    const demoBar         = document.getElementById('demoBar');
    const interactiveBar  = document.getElementById('interactiveBar');
    const interactiveBtn  = document.getElementById('demoInteractiveBtn');
    const demoBtn         = document.getElementById('demoDemoBtn');

    // ── State ─────────────────────────────────────────────────────────────
    let isInteractive = false;
    let demoTileIndex = 0;
    let demoActive    = false;
    let zoomTimer:    ReturnType<typeof setTimeout> | null = null;
    let demoTimer:    ReturnType<typeof setTimeout> | null = null;

    // ── Utilities ─────────────────────────────────────────────────────────

    function getActiveTiles(): HTMLElement[] {
      return Array.from(document.querySelectorAll<HTMLElement>('.gate-tile')).filter(t => {
        const op = parseFloat(t.style.opacity ?? '1');
        return !isNaN(op) ? op > 0.3 : true;
      });
    }

    function tileKey(tile: HTMLElement): string | undefined {
      const label = tile.querySelector('.gate-tile-label')?.textContent?.trim().toLowerCase() ?? '';
      return LABEL_TO_MODULE[label];
    }

    function clearPulse(tile: HTMLElement) {
      tile.classList.remove('demo-pulse', 'toggle-pulse-on', 'toggle-pulse-off');
    }

    function pulseTile(tile: HTMLElement, v: 'demo' | 'on' | 'off') {
      clearPulse(tile);
      tile.classList.add(v === 'demo' ? 'demo-pulse' : v === 'on' ? 'toggle-pulse-on' : 'toggle-pulse-off');
    }

    function cancelAll() {
      if (zoomTimer) { clearTimeout(zoomTimer); zoomTimer = null; }
      if (demoTimer) { clearTimeout(demoTimer); demoTimer = null; }
    }

    // ── Zoom helpers ─────────────────────────────────────────────────────

    function resetZoom() {
      if (!phoneContent) return;
      phoneContent.style.transition = '';        // re-enable CSS transition (smooth out)
      phoneContent.style.transform  = '';
      phoneContent.style.transformOrigin = '';
      zoomNotice?.setAttribute('data-active', 'false');
    }

    function applyZoom(tile: HTMLElement) {
      if (!phoneContent) return;

      // 1. Snap back instantly (no animation) so rects are accurate at scale=1
      phoneContent.style.transition = 'none';
      phoneContent.style.transform  = '';
      phoneContent.style.transformOrigin = '';

      // Force reflow — ensures getBoundingClientRect() returns unscaled values
      void phoneContent.offsetHeight;

      // 2. Compute positions while content is at scale=1
      const cr = phoneContent.getBoundingClientRect();
      const tr = tile.getBoundingClientRect();

      const ox = tr.left + tr.width  / 2 - cr.left;
      const oy = tr.top  + tr.height / 2 - cr.top;

      // 3. Position notice at tile (inside phoneContent, scaled along with content)
      if (zoomNotice && zoomNoticeLabel) {
        const key  = tileKey(tile);
        zoomNoticeLabel.textContent = MODULE_DISPLAY_NAME[key ?? ''] ?? '';

        const tileCX = ox;
        const tileTop = tr.top    - cr.top;
        const tileBot = tr.bottom - cr.top;

        zoomNotice.style.left = `${tileCX}px`;

        if (tileTop < 50) {
          // Tile near top — place notice below
          zoomNotice.style.top = `${tileBot}px`;
          zoomNotice.style.transform = 'translateX(-50%) translateY(8px)';
          zoomNotice.classList.add('is-below');
        } else {
          // Place notice above tile
          zoomNotice.style.top = `${tileTop}px`;
          zoomNotice.style.transform = 'translateX(-50%) translateY(calc(-100% - 8px))';
          zoomNotice.classList.remove('is-below');
        }
        zoomNotice.setAttribute('data-active', 'true');
      }

      // 4. Set origin and apply scale (no animation for zoom-in — avoids origin-jump spin)
      phoneContent.style.transformOrigin = `${ox}px ${oy}px`;
      phoneContent.style.transform = 'scale(1.5)';
    }

    // ── Demo Loop ─────────────────────────────────────────────────────────

    function tickDemo() {
      if (isInteractive) return;
      const tiles = getActiveTiles();
      if (!tiles.length) return;
      demoActive = true;

      demoTileIndex = demoTileIndex % tiles.length;
      const tile = tiles[demoTileIndex];

      pulseTile(tile, 'demo');
      applyZoom(tile);

      zoomTimer = setTimeout(() => {
        clearPulse(tile);
        resetZoom();
        zoomTimer = null;
        demoTileIndex = (demoTileIndex + 1) % tiles.length;
        if (!isInteractive && demoActive) {
          // Brief gap between tiles so zoom-out transition completes
          demoTimer = setTimeout(tickDemo, 450);
        }
      }, 2200);
    }

    function stopDemo() {
      cancelAll();
      demoActive = false;
      document.querySelectorAll<HTMLElement>('.gate-tile').forEach(clearPulse);
      resetZoom();
    }

    // ── Toggle Handler ────────────────────────────────────────────────────

    function onModuleToggle(moduleKey: string, isOn: boolean) {
      if (isInteractive) return;
      cancelAll();
      demoActive = false;

      let target: HTMLElement | null = null;
      document.querySelectorAll<HTMLElement>('.gate-tile').forEach(t => {
        if (tileKey(t) === moduleKey) target = t;
      });

      if (target) {
        pulseTile(target, isOn ? 'on' : 'off');
        applyZoom(target);
      }

      zoomTimer = setTimeout(() => {
        if (target) clearPulse(target);
        resetZoom();
        zoomTimer = null;
        demoTimer = setTimeout(tickDemo, 500);
      }, 1200);
    }

    // ── Interactive Mode ──────────────────────────────────────────────────

    function setInteractive(on: boolean) {
      isInteractive = on;
      phonePreview?.classList.toggle('is-interactive', on);
      if (demoBar)        demoBar.hidden        = on;
      if (interactiveBar) interactiveBar.hidden = !on;
      if (on) { stopDemo(); }
      else    { demoTileIndex = 0; demoTimer = setTimeout(tickDemo, 300); }
    }

    interactiveBtn?.addEventListener('click', () => setInteractive(true));
    demoBtn?.addEventListener('click',        () => setInteractive(false));

    // ── Module Toggle Listener ────────────────────────────────────────────

    document.addEventListener('click', e => {
      const toggle = (e.target as HTMLElement).closest<HTMLButtonElement>('.module-toggle');
      if (!toggle) return;
      const key = toggle.dataset.moduleKey;
      if (!key) return;
      setTimeout(() => {
        const isOn = toggle.getAttribute('aria-pressed') === 'true';
        onModuleToggle(key, isOn);
      }, 20);
    }, true);

    // ── Init: wait for React hydration ────────────────────────────────────

    function tryStart() {
      if (document.querySelectorAll('.gate-tile').length > 0) {
        demoTimer = setTimeout(tickDemo, 800);
      } else {
        setTimeout(tryStart, 300);
      }
    }
    setTimeout(tryStart, 800);
  </script>

  <div class="gast-layout">
    <PhonePreview />
    <div class="gast-sidebar">
      <SettingsPanel tags={demoTags} hotelName={hotel.name} />
      <DemoQrCard demoUrl={demoUrl} />
    </div>
  </div>
</HotelierLayout>

<style>
  .gast-hero {
    max-width: 1400px; margin: 0 auto;
    padding: 48px 32px 32px;
  }
  @media (max-width: 768px) { .gast-hero { padding: 32px 20px 24px; } }

  .gast-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: #0A0A0A; background: var(--te-yellow);
    padding: 5px 10px; display: inline-block;
    margin-bottom: 24px; font-weight: 500; border-radius: var(--r-sm);
  }
  .gast-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 400; line-height: 1; letter-spacing: -0.03em; margin-bottom: 16px;
  }
  .gast-hero__sub {
    font-size: 16px; color: var(--ink-soft); line-height: 1.5; max-width: 560px;
  }

  .gast-layout {
    max-width: 1400px; margin: 0 auto;
    padding: 0 32px 80px;
    display: grid; grid-template-columns: 5fr 7fr;
    gap: 48px; align-items: start;
  }
  @media (max-width: 1000px) {
    .gast-layout { grid-template-columns: 1fr; gap: 32px; padding: 0 20px 64px; }
  }
  .gast-sidebar { display: flex; flex-direction: column; gap: 16px; }

  .gast-preview-btn {
    margin-top: 20px;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 18px; background: var(--bg-deep);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    color: var(--ink); cursor: pointer;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; transition: all 200ms;
  }
  .gast-preview-btn:hover:not(:disabled) { background: var(--te-yellow-soft); }
  .gast-preview-btn:disabled { opacity: 0.5; cursor: wait; }
</style>
