---
import HotelierLayout from '../layouts/HotelierLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getUserRole } from '@retaha/auth';
import { hasPermission } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) {
  return Astro.redirect(`${import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de'}/admin/login`);
}
const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) {
  return Astro.redirect(`${import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de'}/admin/login?error=no_hotel`);
}

const myRole = await getUserRole(Astro.cookies, Astro.request, hotel.id);
if (!myRole || !hasPermission(myRole, 'settings.read')) return new Response('Forbidden', { status: 403 });
const canWrite = hasPermission(myRole, 'settings.write');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: sessions } = await client
  .from('showcase_sessions')
  .select('id, token, demo_data, expires_at, is_active, reset_count, last_reset_at, created_at')
  .eq('hotel_id', hotel.id)
  .order('created_at', { ascending: false });

const rows = (sessions ?? []) as any[];
// Gäste-URLs laufen über Hotel-Subdomain: https://{slug}.retaha.de/g/{token}
const guestRootDomain = (import.meta.env.PUBLIC_GUEST_ROOT_DOMAIN as string | undefined) || 'retaha.de';

function fmtDate(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('de-DE', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function statusOf(s: any): { label: string; class: string } {
  if (!s.is_active) return { label: 'inaktiv', class: 'sc-pill--off' };
  if (Date.parse(s.expires_at) < Date.now()) return { label: 'abgelaufen', class: 'sc-pill--off' };
  return { label: 'aktiv', class: 'sc-pill--on' };
}

function presetLabel(p: string | undefined): string {
  if (p === 'pre_arrival')  return 'Anreise';
  if (p === 'in_house')     return 'Im Hotel';
  if (p === 'checkout_day') return 'Abreise';
  if (p === 'checked_out')  return 'Abgereist';
  return '—';
}
---

<HotelierLayout title="Test-Gast" activeTab="gast" hotelName={hotel.name}>
  <div class="sc-page" x-data="showcasePage()" x-cloak>

    <!-- ── Form Modal (Anlegen + Bearbeiten) ─────────────────── -->
    <div x-show="showForm" class="sc-modal-backdrop" @click.self="showForm = false" x-cloak>
      <div class="settings-section sc-form-panel">
        <div class="sc-form-head">
          <h2 class="settings-section__title" x-text="editId ? 'Demo-Konto bearbeiten' : 'Neues Demo-Konto'"></h2>
          <button type="button" class="sc-form-close" @click="showForm = false" aria-label="Schließen">✕</button>
        </div>

        <form @submit.prevent="submitForm()">
          <!-- Gast -->
          <p class="sc-form-section">Gast</p>
          <div class="sc-form-row-2">
            <label class="sc-form-field">
              <span class="sc-form-label">Vorname</span>
              <input class="sc-form-input" type="text" x-model="form.guest_first_name" required>
            </label>
            <label class="sc-form-field">
              <span class="sc-form-label">Nachname</span>
              <input class="sc-form-input" type="text" x-model="form.guest_last_name">
            </label>
          </div>
          <label class="sc-form-field">
            <span class="sc-form-label">E-Mail <small>für Wallet-Button</small></span>
            <input class="sc-form-input" type="email" x-model="form.guest_email" placeholder="gast@beispiel.de">
          </label>
          <div class="sc-form-row-2">
            <label class="sc-form-field">
              <span class="sc-form-label">Zimmer-Nr.</span>
              <input class="sc-form-input" type="text" x-model="form.room_number">
            </label>
            <label class="sc-form-field">
              <span class="sc-form-label">Zimmer-Name</span>
              <input class="sc-form-input" type="text" x-model="form.room_name">
            </label>
          </div>

          <!-- Zustand -->
          <p class="sc-form-section">Zustand</p>
          <div class="sc-preset-row">
            <button type="button" class="sc-preset-btn" :class="{ 'sc-preset-btn--on': form.preset === 'pre_arrival' }"   @click="applyPreset('pre_arrival')">Anreise</button>
            <button type="button" class="sc-preset-btn" :class="{ 'sc-preset-btn--on': form.preset === 'in_house' }"      @click="applyPreset('in_house')">Im Hotel</button>
            <button type="button" class="sc-preset-btn" :class="{ 'sc-preset-btn--on': form.preset === 'checkout_day' }"  @click="applyPreset('checkout_day')">Abreise</button>
            <button type="button" class="sc-preset-btn" :class="{ 'sc-preset-btn--on': form.preset === 'checked_out' }"   @click="applyPreset('checked_out')">Abgereist</button>
          </div>
          <p class="sc-form-hint">
            <span x-show="form.preset === 'pre_arrival'">Gast noch nicht angereist. Link gültig — zeigt Anreise-Ansicht.</span>
            <span x-show="form.preset === 'in_house'">Gast eingecheckt. Alle Module aktiv.</span>
            <span x-show="form.preset === 'checkout_day'">Abreisetag — Checkout-Kachel + Billing testbar.</span>
            <span x-show="form.preset === 'checked_out'">Zeigt „Einladung ungültig" — zum Testen dieses Pfads.</span>
          </p>

          <!-- Termine -->
          <p class="sc-form-section">Termine</p>
          <div class="sc-form-row-2">
            <label class="sc-form-field">
              <span class="sc-form-label">Anreise</span>
              <input class="sc-form-input" type="datetime-local" x-model="form.check_in">
            </label>
            <label class="sc-form-field">
              <span class="sc-form-label">Abreise</span>
              <input class="sc-form-input" type="datetime-local" x-model="form.check_out">
            </label>
          </div>

          <!-- Billing -->
          <p class="sc-form-section">Abrechnung</p>
          <label class="sc-form-field">
            <span class="sc-form-label">Offener Betrag (€) — 0&nbsp;=&nbsp;Zustand B (bezahlt) · &gt;0&nbsp;=&nbsp;Zustand C (offen)</span>
            <input class="sc-form-input sc-form-input--w200" type="number" min="0" step="0.01" x-model="form.balance_euros">
          </label>

          <!-- Rechnungsposten -->
          <p class="sc-form-section">Rechnungsposten <small>(optional · nur sichtbar in Zustand C)</small></p>
          <div class="sc-items-list">
            <template x-for="(item, i) in form.items" :key="i">
              <div class="sc-item-row">
                <input class="sc-form-input sc-item-label-input" type="text" placeholder="Bezeichnung" x-model="item.label">
                <div class="sc-item-money">
                  <span class="sc-item-eur">€</span>
                  <input class="sc-form-input sc-item-amount-input" type="number" min="0" step="0.01" x-model="item.euros">
                </div>
                <button type="button" class="sc-item-remove" @click="removeItem(i)" title="Posten entfernen">✕</button>
              </div>
            </template>
          </div>
          <div class="sc-items-footer">
            <button type="button" class="sc-mini-btn" @click="addItem()">+ Posten</button>
            <span class="sc-items-total" x-show="form.items.length > 0">Summe: <strong>€ <span x-text="totalEuros"></span></strong></span>
          </div>

          <!-- Error + Actions -->
          <p x-show="error" x-text="error" class="sc-error" style="margin-top:12px"></p>
          <div class="sc-form-actions">
            <button type="button" class="v9-btn v9-btn--ghost" @click="showForm = false" :disabled="busy">Abbrechen</button>
            <button type="submit" class="v9-btn" :disabled="busy" :data-loading="busy ? 'true' : null"
              x-text="editId ? 'Speichern' : 'Demo-Konto anlegen'"></button>
          </div>
        </form>
      </div>
    </div>
    <!-- ── End Form Modal ──────────────────────────────────── -->

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/gast-vorschau" class="breadcrumb__crumb">Gäste-Vorschau</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Test-Gast</span>
    </nav>

    <section class="settings-hero">
      <span class="settings-hero__eyebrow">Test-Gast · Demo-Konten</span>
      <h1 class="settings-hero__title">Zeig retaha vor — ohne echte Buchungen<span class="dot-pink">.</span></h1>
      <p class="settings-hero__sub">
        Ein Demo-Konto verhält sich wie ein echter Stay (Eve, Frühstück, Service-Anfragen),
        bleibt aber isoliert: nichts geht an Mews, keine E-Mails, keine Push-Nachrichten.
        Reset wischt die Demo-Daten, Löschen entfernt das Konto samt allem.
      </p>
    </section>

    {canWrite && (
      <div class="sc-actions-top">
        <button class="v9-btn" type="button" @click="openCreate()">+ Neues Demo-Konto</button>
      </div>
    )}

    {rows.length === 0 ? (
      <div class="sc-empty">
        <p>Noch keine Demo-Konten. Lege eines an, um retaha als Test-Gast vorzuführen.</p>
      </div>
    ) : (
      <div class="sc-list">
        {rows.map((s: any) => {
          const status = statusOf(s);
          const demoUrl = `https://${hotel.slug}.${guestRootDomain}/g/${s.token}`;
          const ddJson = JSON.stringify(s.demo_data ?? {});
          const live = s.is_active && Date.parse(s.expires_at) >= Date.now();
          return (
            <article class={`settings-section sc-card${!s.is_active ? ' sc-card--off' : ''}`} x-data="{ busy: false }">
              <div class="sc-card-head">
                <span class={`sc-pill ${status.class}`}>{status.label}</span>
                <span class="sc-card-meta">
                  {s.demo_data?.preset && <span class="sc-card-preset">{presetLabel(s.demo_data.preset)}</span>}
                  erstellt {fmtDate(s.created_at)}
                </span>
              </div>
              <h3 class="sc-card-title">
                {s.demo_data?.guest_first_name ?? 'Anna'} {s.demo_data?.guest_last_name ?? 'Demo'}
                <span class="sc-card-sep"> · </span>
                Zimmer {s.demo_data?.room_number ?? '101'}
                {s.demo_data?.guest_email && (
                  <span class="sc-card-sep"> · </span>
                )}
                {s.demo_data?.guest_email && (
                  <span class="sc-card-email">{s.demo_data.guest_email}</span>
                )}
              </h3>
              <div class="sc-token-row">
                <code class="sc-token">{s.token}</code>
              </div>
              <div class="sc-meta-grid">
                <div><span class="sc-mlabel">Gültig bis</span><span class="sc-mval">{fmtDate(s.expires_at)}</span></div>
                <div><span class="sc-mlabel">Resets</span><span class="sc-mval">{s.reset_count}</span></div>
                <div><span class="sc-mlabel">Letzter Reset</span><span class="sc-mval">{s.last_reset_at ? fmtDate(s.last_reset_at) : '—'}</span></div>
              </div>
              <div class="sc-card-actions">
                {live && (
                  <a href={demoUrl} target="_blank" rel="noopener" class="v9-btn v9-btn--ghost">Demo öffnen →</a>
                )}
                {live && (
                  <button class="v9-btn v9-btn--ghost" type="button"
                    @click={`navigator.clipboard.writeText('${demoUrl}').then(() => window.retahaToast && window.retahaToast('URL kopiert'))`}
                  >URL kopieren</button>
                )}
                {canWrite && s.is_active && (
                  <button
                    class="v9-btn v9-btn--ghost"
                    type="button"
                    data-demo={ddJson}
                    data-id={s.id}
                    @click="$dispatch('open-edit', { demo: JSON.parse($el.dataset.demo), id: $el.dataset.id })"
                  >Bearbeiten</button>
                )}
                {canWrite && s.is_active && (
                  <button
                    class="v9-btn v9-btn--ghost"
                    type="button"
                    :disabled="busy"
                    :data-loading="busy ? 'true' : null"
                    @click={`if (!confirm('Alle Demo-Daten dieses Kontos zurücksetzen?')) return; busy = true; fetch('/api/showcase/${s.id}/reset', { method: 'POST', credentials: 'include' }).then(r => r.json()).then(d => { if (d.ok) { sessionStorage.setItem('sc_flash', 'Zurückgesetzt'); location.reload(); } else { busy = false; window.retahaToast && window.retahaToast('Fehler: ' + (d.error || 'unbekannt'), 'error'); } }).catch(() => { busy = false; window.retahaToast && window.retahaToast('Netzwerkfehler', 'error'); })`}
                  >Reset</button>
                )}
                {canWrite && (
                  <button
                    class="v9-btn v9-btn--ghost sc-danger"
                    type="button"
                    :disabled="busy"
                    :data-loading="busy ? 'true' : null"
                    @click={`if (!confirm('Dieses Demo-Konto dauerhaft löschen? Alle zugehörigen Demo-Daten (Buchungen, Chat, Wallet-Pässe) werden mitentfernt.')) return; busy = true; fetch('/api/showcase/${s.id}', { method: 'DELETE', credentials: 'include' }).then(r => r.json()).then(d => { if (d.ok) { sessionStorage.setItem('sc_flash', 'Demo-Konto gelöscht'); location.reload(); } else { busy = false; window.retahaToast && window.retahaToast('Fehler: ' + (d.error || 'unbekannt'), 'error'); } }).catch(() => { busy = false; window.retahaToast && window.retahaToast('Netzwerkfehler', 'error'); })`}
                  >Löschen</button>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>

  <script is:inline>
    function showcasePage() {
      function pad(n) { return String(n).padStart(2, '0'); }
      function dtLocal(d) {
        return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
      }
      function addDays(d, n) { const r = new Date(d); r.setDate(r.getDate() + n); return r; }

      function defaultForm() {
        return {
          guest_first_name: 'Anna',
          guest_last_name: 'Demo',
          guest_email: '',
          room_number: '101',
          room_name: 'Demo-Suite',
          preset: 'in_house',
          check_in: '',
          check_out: '',
          balance_euros: '0.00',
          items: [],
        };
      }

      return {
        showForm: false,
        editId: null,
        form: defaultForm(),
        busy: false,
        error: '',

        init() {
          this.$el.addEventListener('open-edit', (e) => {
            this.openEdit(e.detail.demo, e.detail.id);
          });
          // Flash-Toast nach Reload (location.reload würde eine sofortige Toast verschlucken).
          const flash = sessionStorage.getItem('sc_flash');
          if (flash) { sessionStorage.removeItem('sc_flash'); if (window.retahaToast) window.retahaToast(flash); }
        },

        openCreate() {
          this.editId = null;
          this.form = defaultForm();
          this.applyPresetDates('in_house');
          this.showForm = true;
          this.error = '';
        },

        openEdit(dd, id) {
          this.editId = id;
          this.form = {
            guest_first_name: dd.guest_first_name ?? 'Anna',
            guest_last_name:  dd.guest_last_name  ?? 'Demo',
            guest_email:      dd.guest_email      ?? '',
            room_number:      dd.room_number      ?? '101',
            room_name:        dd.room_name        ?? 'Demo-Suite',
            preset:           dd.preset           ?? 'in_house',
            check_in:  dd.check_in  ? dtLocal(new Date(dd.check_in))  : '',
            check_out: dd.check_out ? dtLocal(new Date(dd.check_out)) : '',
            balance_euros: ((dd.balance_cents ?? 0) / 100).toFixed(2),
            items: (dd.items ?? []).map(function(i) {
              return { label: i.label, euros: (i.amount_cents / 100).toFixed(2) };
            }),
          };
          if (!this.form.check_in) this.applyPresetDates(this.form.preset);
          this.showForm = true;
          this.error = '';
        },

        applyPresetDates(preset) {
          const now = new Date();
          let ci, co;
          if (preset === 'pre_arrival') {
            ci = addDays(now, 3);  ci.setHours(14, 0, 0, 0);
            co = addDays(ci, 2);   co.setHours(11, 0, 0, 0);
          } else if (preset === 'in_house') {
            ci = addDays(now, -1); ci.setHours(14, 0, 0, 0);
            co = addDays(now,  1); co.setHours(11, 0, 0, 0);
          } else if (preset === 'checkout_day') {
            ci = addDays(now, -2); ci.setHours(14, 0, 0, 0);
            co = new Date(now);    co.setHours(11, 0, 0, 0);
          } else {
            ci = addDays(now, -3); ci.setHours(14, 0, 0, 0);
            co = addDays(now, -1); co.setHours(11, 0, 0, 0);
          }
          this.form.check_in  = dtLocal(ci);
          this.form.check_out = dtLocal(co);
        },

        applyPreset(preset) {
          this.form.preset = preset;
          this.applyPresetDates(preset);
        },

        addItem() {
          this.form.items = [...this.form.items, { label: '', euros: '0.00' }];
        },

        removeItem(i) {
          this.form.items = this.form.items.filter(function(_, idx) { return idx !== i; });
        },

        get totalEuros() {
          return this.form.items.reduce(function(s, i) {
            return s + (parseFloat(i.euros) || 0);
          }, 0).toFixed(2);
        },

        async submitForm() {
          this.busy = true;
          this.error = '';
          try {
            const demoData = {
              guest_first_name: this.form.guest_first_name,
              guest_last_name:  this.form.guest_last_name,
              guest_email:      this.form.guest_email,
              room_number:      this.form.room_number,
              room_name:        this.form.room_name,
              preset:           this.form.preset,
              check_in:  this.form.check_in  ? new Date(this.form.check_in).toISOString()  : null,
              check_out: this.form.check_out ? new Date(this.form.check_out).toISOString() : null,
              balance_cents: Math.round((parseFloat(this.form.balance_euros) || 0) * 100),
              currency: 'EUR',
              items: this.form.items.map(function(i) {
                return { label: i.label, amount_cents: Math.round((parseFloat(i.euros) || 0) * 100) };
              }),
              // Abgereist-Marker NUR im 'checked_out'-Preset; sonst explizit null,
              // damit ein stale Marker aus dem Demo-Checkout beim Merge geleert wird.
              checked_out_at_sim: this.form.preset === 'checked_out'
                ? (this.form.check_out ? new Date(this.form.check_out).toISOString() : new Date().toISOString())
                : null,
            };
            const url    = this.editId ? `/api/showcase/${this.editId}/update` : '/api/showcase/create';
            const method = this.editId ? 'PATCH' : 'POST';
            const res = await fetch(url, {
              method,
              credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ demo_data: demoData }),
            });
            const data = await res.json();
            if (data.ok) {
              sessionStorage.setItem('sc_flash', this.editId ? 'Gespeichert' : 'Demo-Konto angelegt');
              location.reload();
            } else {
              this.error = data.error || 'Unbekannter Fehler';
              this.busy = false;
            }
          } catch (_) {
            this.error = 'Netzwerkfehler';
            this.busy = false;
          }
        },
      };
    }
  </script>

  <style>
    [x-cloak] { display: none !important; }

    /* Breite + Paddings 1:1 wie die Module-Seite (.features-page). */
    .sc-page { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; }
    @media (max-width: 768px) { .sc-page { padding: 0 20px 64px; } }

    /* Kopfbereich 1:1 wie backoffice.retaha.de/breakfast (admin-page.css repliziert;
       das Guest-HotelierLayout lädt admin-page.css nicht, .dot-pink kommt aus v9-colors). */
    .breadcrumb {
      display: flex; align-items: center; gap: 10px;
      padding: 16px 0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-muted);
    }
    .breadcrumb__sep { color: var(--ink-faint); }
    .breadcrumb__crumb { color: var(--ink-muted); text-decoration: none; transition: color 150ms; }
    .breadcrumb__crumb:hover { color: var(--ink); }
    .breadcrumb__crumb--current { color: var(--ink); font-weight: 500; }

    .settings-hero {
      padding: 40px 0 32px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 28px;
    }
    .settings-hero__eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
      color: #0A0A0A; background: var(--te-yellow);
      padding: 5px 10px; display: inline-block;
      margin-bottom: 20px; border-radius: var(--r-sm);
    }
    .settings-hero__title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(32px, 5vw, 52px); font-weight: 400;
      line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 10px;
      color: var(--ink);
    }
    .settings-hero__sub {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px; color: var(--ink-muted); letter-spacing: 0.04em;
    }

    .sc-actions-top { margin-bottom: 20px; }

    /* ── V9-Karte (settings-section, wie Gast-Vorschau) ── */
    .settings-section {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--r); padding: 22px 24px;
    }
    .sc-card { transition: border-color .15s; }
    .sc-card:hover { border-color: var(--ink-muted); }
    .sc-card--off { opacity: .55; }
    .settings-section__title { font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); margin: 0; }

    /* ── V9-Button: Danger-Variante (Löschen) — extending v9-btn, kein neuer Button ── */
    .sc-danger { color: var(--burgund, #8C2128); border-color: color-mix(in srgb, var(--burgund, #8C2128) 28%, transparent); }
    .sc-danger:hover:not(:disabled):not([data-loading]) { background: var(--burgund-soft, rgba(140,33,40,0.08)); border-color: var(--burgund, #8C2128); color: var(--burgund, #8C2128); }

    .sc-error { color: var(--te-pink, #FF4A82); font-size: 13px; margin: 0; }

    .sc-empty { padding: 48px 24px; background: var(--surface); border: 1px dashed var(--border); border-radius: var(--r); text-align: center; color: var(--ink-muted); font-style: italic; }
    .sc-empty p { margin: 0; }

    .sc-list { display: flex; flex-direction: column; gap: 12px; }
    .sc-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 8px; flex-wrap: wrap; }
