---
import HotelierLayout from '../../layouts/HotelierLayout.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels } from '@retaha/auth';
import { loadBreakfastItems, EU_ALLERGENS } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) {
  const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
  return Astro.redirect(`${b}/admin/login`);
}

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) {
  const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
  return Astro.redirect(`${b}/admin/login?error=no_hotel`);
}

const items = await loadBreakfastItems(hotel.id);

function countAllergens(item: any): number {
  return EU_ALLERGENS.filter(a => item[`contains_${a.key}`]).length;
}

const itemsByCategory: Record<string, typeof items> = {};
items.forEach(item => {
  const cat = item.category || 'Ohne Kategorie';
  if (!itemsByCategory[cat]) itemsByCategory[cat] = [];
  itemsByCategory[cat].push(item);
});
---

<HotelierLayout title="Speisen" activeTab="gast" hotelName={hotel.name}>
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber="06"
      sectionLabel="Speisen"
      headlineLight="Dein"
      headlineBold="Frühstücksmenü"
      subtitle="Allergene, Diät-Flags, Preise."
    />
  </div>

  <div class="bg-amber-50 border-l-4 border-amber-400 p-4 mb-8">
    <div class="flex gap-3">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" class="text-amber-700 flex-shrink-0 mt-0.5">
        <path d="M12 9v4m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.74-3l-6.93-12a2 2 0 0 0-3.48 0L3.34 16a2 2 0 0 0 1.73 3z"/>
      </svg>
      <div>
        <p class="text-sm font-medium text-amber-900">Wichtiger Hinweis zu Allergen-Angaben</p>
        <p class="text-xs text-amber-800 mt-1 leading-relaxed max-w-2xl">
          Du als Hotelbetreiber bist gesetzlich (LMIV Art. 9) für die Richtigkeit der
          Allergen-Angaben verantwortlich. retaha bietet nur das Werkzeug zur Pflege und Anzeige —
          die Allergen-Auswahl pro Speise musst du selbst sorgfältig vornehmen und bei Rezeptur-Änderungen
          aktualisieren.
        </p>
      </div>
    </div>
  </div>

  <div class="flex justify-between items-center mb-6">
    <p class="text-sm text-anthrazit/55">
      {items.length} Speise{items.length === 1 ? '' : 'n'} insgesamt
    </p>
    <a href="/menu/new" class="bauhaus-button bauhaus-button--primary bauhaus-button--small">
      + Neue Speise hinzufügen
    </a>
  </div>

  {items.length === 0 ? (
    <div class="bg-white border border-anthrazit/[0.12] p-12 text-center">
      <p class="text-anthrazit/55 italic mb-4">Noch keine Speisen angelegt.</p>
      <a href="/menu/new" class="bauhaus-button bauhaus-button--primary">
        Erste Speise anlegen
      </a>
    </div>
  ) : (
    <div class="space-y-6">
      {Object.entries(itemsByCategory).map(([cat, catItems]) => (
        <section>
          <h2 class="eyebrow text-anthrazit/55 mb-3">{cat}</h2>
          <div class="bg-white border border-anthrazit/[0.12] divide-y divide-anthrazit/[0.12]">
            {catItems.map(item => {
              const allergenCount = countAllergens(item);
              return (
                <a href={`/menu/${item.id}`} class="block p-4 hover:bg-white transition">
                  <div class="flex justify-between items-start gap-4">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="font-medium text-anthrazit">{item.name_de}</span>
                        {!item.is_active && (
                          <span class="text-xs px-2 py-0.5 bg-anthrazit/[0.04] text-anthrazit/55 border border-anthrazit/[0.12]">inaktiv</span>
                        )}
                        {item.is_vegan && (
                          <span class="text-xs px-2 py-0.5 bg-green-50 text-green-700 border border-green-200">vegan</span>
                        )}
                        {!item.is_vegan && item.is_vegetarian && (
                          <span class="text-xs px-2 py-0.5 bg-green-50 text-green-700 border border-green-200">vegetarisch</span>
                        )}
                        {item.is_organic && (
                          <span class="text-xs px-2 py-0.5 bg-amber-50 text-amber-700 border border-amber-200">bio</span>
                        )}
                      </div>
                      {item.description_de && (
                        <p class="text-sm text-anthrazit/55 truncate italic">{item.description_de}</p>
                      )}
                    </div>
                    <div class="text-right flex-shrink-0">
                      <span class="meta-mono text-anthrazit/40">
                        {allergenCount === 0
                          ? 'Keine Allergene angegeben'
                          : `${allergenCount} Allergen${allergenCount === 1 ? '' : 'e'}`
                        }
                      </span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  )}
</HotelierLayout>
