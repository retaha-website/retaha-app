---
import HotelierLayout from '../layouts/HotelierLayout.astro';
import { getUser, getUserHotels } from '@retaha/auth';
import { MODULE_REGISTRY, TIER_LABELS, CATEGORY_ORDER, CATEGORY_LABELS, MODULE_CATEGORY, type ModuleDefinition, type ModuleTier } from '../lib/modules-registry';
import { isModuleAvailable } from '../lib/plan-modules';
import ModuleRow from '../components/features/ModuleRow.astro';

const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
const d = import.meta.env.DASHBOARD_URL ?? 'https://dashboard.retaha.de';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect(`${b}/admin/login`);

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect(`${b}/admin/login?error=no_hotel`);

const hotelPlan = (hotel as any).plan ?? 'lite';
const hotelAddons: string[] = (hotel as any).addons ?? [];

const avail = (mod: ModuleDefinition) => isModuleAvailable({ plan: hotelPlan, addons: hotelAddons }, mod.key);

const includedCount = MODULE_REGISTRY.filter(m => !m.comingSoon && !m.required && avail(m)).length;
const upgradeCount  = MODULE_REGISTRY.filter(m => !m.comingSoon && !m.required && !avail(m)).length;
const soonCount     = MODULE_REGISTRY.filter(m => m.comingSoon).length;

const PLAN_LABEL: Record<string, string> = {
  lite: 'Lite', pro: 'Pro', premium: 'Premium', enterprise: 'Enterprise',
};

function configHref(mod: ModuleDefinition): string | null {
  if (mod.linkedRoute) return mod.linkedRoute;
  if (mod.backofficeRoute) return `${b}${mod.backofficeRoute}`;
  if (mod.dashboardRoute) return `${d}${mod.dashboardRoute}`;
  return null;
}

const upgradeHref = `${b}/admin/subscription`;
const decorated = MODULE_REGISTRY.map(mod => ({
  mod,
  included: avail(mod),
  status: mod.comingSoon ? 'coming-soon' : 'normal',
  href: configHref(mod),
}));

// Zwei Gruppierungs-Achsen aus bestehenden Metadaten: Paket (tier) + Kategorie.
const TIER_ORDER: ModuleTier[] = ['lite', 'pro', 'premium', 'enterprise'];
const tierSections = TIER_ORDER
  .map(t => ({ label: TIER_LABELS[t], mods: decorated.filter(x => x.mod.tier === t) }))
  .filter(s => s.mods.length > 0);
const catSections = CATEGORY_ORDER
  .map(c => ({ label: CATEGORY_LABELS[c], mods: decorated.filter(x => (MODULE_CATEGORY[x.mod.key] ?? 'betrieb') === c) }))
  .filter(s => s.mods.length > 0);

// Status-Flags je Sektion → Alpine blendet leere Sektionen (alle Zeilen vom
// Status-Tab gefiltert) aus, damit kein leerer Sektions-Header stehen bleibt.
function sectionFlags(mods: typeof decorated): string {
  return JSON.stringify(mods.map(x => ({ s: x.status, i: x.included })));
}
---

<HotelierLayout title="Module" activeTab="gast" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

  <div class="features-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/gast-vorschau" class="breadcrumb__crumb">Gäste-Vorschau</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Module</span>
    </nav>

    <section class="features-hero">
      <span class="features-hero__eyebrow">Module · {PLAN_LABEL[hotelPlan] ?? hotelPlan}-Paket</span>
      <h1 class="features-hero__title">Deine Module<span class="dot-pink">.</span></h1>
      <p class="features-hero__sub">{includedCount} Module in deinem Paket enthalten. Aktivierung in der <a href="/gast-vorschau" class="features-hero__link">Gäste-Vorschau</a>.</p>
    </section>

    <div
      x-data={`{
        filter: 'alle',
        groupBy: 'paket',
        isVisible(status, included) {
          if (this.filter === 'alle') return true;
          if (this.filter === 'enthalten') return included && status !== 'coming-soon';
          if (this.filter === 'upgrade') return !included && status !== 'coming-soon';
          if (this.filter === 'bald') return status === 'coming-soon';
          return true;
        },
        sectionVisible(mods) { return mods.some(m => this.isVisible(m.s, m.i)); }
      }`}
    >
      <div class="features-controls">
        <div class="features-groupby" role="group" aria-label="Gruppieren nach">
          <span class="features-groupby__label">Gruppieren</span>
          <button type="button" class="features-seg" :class="groupBy === 'paket' ? 'features-seg--on' : ''" @click="groupBy = 'paket'">Paket</button>
          <button type="button" class="features-seg" :class="groupBy === 'kategorie' ? 'features-seg--on' : ''" @click="groupBy = 'kategorie'">Kategorie</button>
        </div>

        <div class="features-tabs" role="tablist">
          {[
            { key: 'alle',      label: 'Alle' },
            { key: 'enthalten', label: `Enthalten (${includedCount})` },
            { key: 'upgrade',   label: `Upgrade (${upgradeCount})` },
            { key: 'bald',      label: 'Bald verfügbar' },
          ].map(tab => (
            <button
              type="button"
              role="tab"
              class="features-tab"
              :class={`filter === '${tab.key}' ? 'features-tab--active' : ''`}
              @click={`filter = '${tab.key}'`}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      <!-- PAKET-Gruppierung (Default) — Sektion = Paket, daher kein Tier-Badge pro Zeile -->
      <div x-show="groupBy === 'paket'" x-cloak>
        {tierSections.map(sec => (
          <section class="mod-group" x-show={`sectionVisible(${sectionFlags(sec.mods)})`} x-cloak>
            <div class="mod-group__label">{sec.label}</div>
            <div class="mod-list">
              {sec.mods.map(x => (
                <ModuleRow mod={x.mod} included={x.included} status={x.status} href={x.href} upgradeHref={upgradeHref} showTier={false} />
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- KATEGORIE-Gruppierung — Tier-Badge pro Zeile (Paket ist dann Nebeninfo) -->
      <div x-show="groupBy === 'kategorie'" x-cloak>
        {catSections.map(sec => (
          <section class="mod-group" x-show={`sectionVisible(${sectionFlags(sec.mods)})`} x-cloak>
            <div class="mod-group__label">{sec.label}</div>
            <div class="mod-list">
              {sec.mods.map(x => (
                <ModuleRow mod={x.mod} included={x.included} status={x.status} href={x.href} upgradeHref={upgradeHref} showTier={true} />
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>

    <div class="features-footer">
      <div class="features-footer__left">
        <div class="features-footer__stat">
          <span class="features-footer__num">{includedCount}</span>
          <span class="features-footer__label">enthalten</span>
        </div>
        <div class="features-footer__sep"></div>
        <div class="features-footer__stat">
          <span class="features-footer__num">{upgradeCount}</span>
          <span class="features-footer__label">per Upgrade</span>
        </div>
        <div class="features-footer__sep"></div>
        <div class="features-footer__stat">
          <span class="features-footer__num">{soonCount}</span>
          <span class="features-footer__label">bald verfügbar</span>
        </div>
      </div>
      <div class="features-footer__right">
        <a href={`${b}/admin/subscription`} class="features-footer__link">Plan verwalten →</a>
      </div>
    </div>

    <p class="features-hint">
      Module aktivieren/deaktivieren: <a href="/gast-vorschau" class="features-hint__link">Gäste-Vorschau → Module</a>
    </p>

  </div>

</HotelierLayout>

<style>
  .features-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }
  @media (max-width: 768px) { .features-page { padding: 0 20px 64px; } }

  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-muted);
  }
  .breadcrumb__sep { color: var(--ink-faint); }
  .breadcrumb__crumb { color: var(--ink-muted); text-decoration: none; transition: color 150ms; }
  .breadcrumb__crumb:hover { color: var(--ink); }
  .breadcrumb__crumb--current { color: var(--ink); font-weight: 500; }

  .features-hero {
    padding: 40px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .features-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
    color: #0A0A0A; background: var(--petrol, #14616E);
    padding: 5px 10px; display: inline-block;
    margin-bottom: 20px; border-radius: var(--r-sm);
  }
  .features-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 4.5vw, 52px); font-weight: 400;
    line-height: 1.05; letter-spacing: -0.025em;
    margin-bottom: 12px; color: var(--ink);
  }
  .features-hero__sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.04em;
  }
  .features-hero__link {
    color: var(--ink); font-weight: 500; text-decoration: underline;
    text-underline-offset: 2px;
  }

  .features-controls {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 12px 24px; flex-wrap: wrap;
    border-bottom: 1px solid var(--border); margin-bottom: 20px;
  }
  .features-groupby { display: flex; align-items: center; gap: 6px; padding-bottom: 11px; }
  .features-groupby__label {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-muted); margin-right: 4px;
  }
  /* V9-Farbrolle: aktives Segment = Gelb (gewählt), inaktiv = Ghost. */
  .features-seg {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 6px 14px; border: 1px solid var(--border); border-radius: var(--r-sm);
    background: transparent; color: var(--ink-soft); cursor: pointer; transition: all 150ms ease;
  }
  .features-seg:not(.features-seg--on):hover { background: var(--petrol-soft, rgba(20,97,110,0.08)); color: var(--ink); border-color: var(--petrol-soft, rgba(20,97,110,0.08)); }
  .features-seg--on { background: var(--petrol, #14616E); color: var(--ink); border-color: var(--petrol, #14616E); }

  .features-tabs { display: flex; gap: 6px; flex-wrap: wrap; }
  .features-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 8px 14px;
    border: none; background: none; cursor: pointer;
    color: var(--ink-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 150ms ease;
  }
  .features-tab:hover { color: var(--ink); }
  .features-tab--active { color: var(--ink); border-bottom-color: var(--ink); }
  [x-cloak] { display: none !important; }

  /* ── Gruppierte kompakte Liste (statt 3-Spalten-Karten) ── */
  .mod-group { margin-bottom: 22px; }
  .mod-group:last-child { margin-bottom: 4px; }
  .mod-group__label {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft);
    margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid var(--border);
  }
  .mod-list {
    border: 1px solid var(--border); border-radius: var(--r);
    background: var(--surface); overflow: hidden;
  }

  .features-footer {
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    padding: 18px 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-deep);
    margin-bottom: 20px;
  }
  @media (max-width: 600px) { .features-footer { flex-direction: column; align-items: flex-start; } }
  .features-footer__left { display: flex; align-items: center; gap: 16px; }
  .features-footer__stat { display: flex; flex-direction: column; gap: 1px; }
  .features-footer__num { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 300; color: var(--ink); line-height: 1; }
  .features-footer__label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); }
  .features-footer__sep { width: 1px; height: 32px; background: var(--border); }
  .features-footer__right { display: flex; gap: 10px; align-items: center; flex-shrink: 0; }
  .features-footer__link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; color: var(--ink-muted);
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    transition: all 150ms;
  }
  .features-footer__link:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .features-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-faint); letter-spacing: 0.04em; margin-top: 8px;
  }
  .features-hint__link { color: var(--ink-muted); text-decoration: underline; text-underline-offset: 2px; }
</style>
