---
import HotelierLayout from '../layouts/HotelierLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { MODULE_REGISTRY, TIER_LABELS, type ModuleDefinition } from '../lib/modules-registry';

const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect(`${b}/admin/login`);

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect(`${b}/admin/login?error=no_hotel`);

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

let flashMsg: { ok: boolean; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const { data: current } = await client
    .from('hotel_settings')
    .select('features')
    .eq('hotel_id', hotel.id)
    .maybeSingle();

  const existing = (current?.features as Record<string, boolean>) ?? {};
  const updated: Record<string, boolean> = { ...existing };

  for (const mod of MODULE_REGISTRY) {
    if (mod.required || mod.comingSoon) continue;
    const val = form.get(`feature_${mod.key}`) === 'on';
    updated[mod.key] = val;
    if (mod.legacyKey) updated[mod.legacyKey] = val;
  }
  updated['welcome'] = true;
  updated['wifi'] = true;

  const { error } = await client
    .from('hotel_settings')
    .update({ features: updated })
    .eq('hotel_id', hotel.id);

  flashMsg = error
    ? { ok: false, text: `Fehler: ${error.message}` }
    : { ok: true, text: '✓ Module gespeichert.' };
}

const { data: settings } = await client
  .from('hotel_settings')
  .select('features')
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const features = (settings?.features as Record<string, boolean>) ?? {};

function isActive(mod: ModuleDefinition): boolean {
  if (mod.required) return true;
  if (mod.comingSoon) return false;
  if (typeof features[mod.key] === 'boolean') return features[mod.key];
  if (mod.legacyKey && typeof features[mod.legacyKey] === 'boolean') return features[mod.legacyKey];
  return false;
}

const activeCount    = MODULE_REGISTRY.filter(m => !m.comingSoon && isActive(m)).length;
const availableCount = MODULE_REGISTRY.filter(m => !m.comingSoon && !m.required && !isActive(m)).length;
const soonCount      = MODULE_REGISTRY.filter(m => m.comingSoon).length;
const totalActive    = MODULE_REGISTRY.filter(m => !m.comingSoon).length;

const TIER_CSS: Record<string, string> = {
  lite:       'background:transparent; color:var(--ink); border-color:var(--ink)',
  pro:        'background:var(--sage); color:#fff; border-color:var(--sage)',
  premium:    'background:var(--burgund); color:#fff; border-color:var(--burgund)',
  enterprise: 'background:var(--ink); color:var(--bg); border-color:var(--ink)',
};

function configHref(mod: ModuleDefinition): string | null {
  if (mod.linkedRoute) return mod.linkedRoute;
  if (mod.backofficeRoute) return `${b}${mod.backofficeRoute}`;
  return null;
}
---

<HotelierLayout title="Module" activeTab="gast" hotelName={hotel.name} hotelLogoUrl={(hotel as any).logo_primary ?? (hotel as any).logo_dark}>

  <div class="features-page">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/uebersicht" class="breadcrumb__crumb">Übersicht</a>
      <span class="breadcrumb__sep">/</span>
      <span class="breadcrumb__crumb breadcrumb__crumb--current">Module</span>
    </nav>

    <section class="features-hero">
      <span class="features-hero__eyebrow">Module · Verwaltung</span>
      <h1 class="features-hero__title">Deine Module<span class="dot-pink">.</span></h1>
      <p class="features-hero__sub">Was du nutzt — was du noch aktivieren kannst. {activeCount} von {totalActive} Modulen aktiv.</p>
    </section>

    {flashMsg && (
      <div class={`page-flash ${flashMsg.ok ? 'page-flash--ok' : 'page-flash--err'}`}>
        {flashMsg.text}
      </div>
    )}

    <div
      x-data={`{
        filter: 'alle',
        isVisible(status, active) {
          if (this.filter === 'alle') return true;
          if (this.filter === 'aktiv') return active;
          if (this.filter === 'verfügbar') return !active && status !== 'coming-soon';
          if (this.filter === 'bald') return status === 'coming-soon';
          return true;
        }
      }`}
    >
      <div class="features-tabs" role="tablist">
        {[
          { key: 'alle',      label: 'Alle' },
          { key: 'aktiv',     label: 'Aktiv' },
          { key: 'verfügbar', label: 'Verfügbar' },
          { key: 'bald',      label: 'Bald verfügbar' },
        ].map(tab => (
          <button
            type="button"
            role="tab"
            class="features-tab"
            :class={`filter === '${tab.key}' ? 'features-tab--active' : ''`}
            @click={`filter = '${tab.key}'`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <form method="POST" id="featuresForm">
        <div class="features-grid">
          {MODULE_REGISTRY.map(mod => {
            const active  = isActive(mod);
            const tierCss = TIER_CSS[mod.tier] ?? TIER_CSS.lite;
            const inputId = `toggle-${mod.key}`;
            const href    = configHref(mod);

            return (
              <div
                class={[
                  'fcard',
                  active         ? 'fcard--active'  : '',
                  mod.comingSoon ? 'fcard--soon'     : '',
                  mod.required   ? 'fcard--required' : '',
                ].filter(Boolean).join(' ')}
                x-show={`isVisible('${mod.comingSoon ? 'coming-soon' : 'toggleable'}', ${active})`}
                x-cloak
              >
                <div class="fcard__head">
                  <span class="fcard__tier" style={tierCss}>
                    {TIER_LABELS[mod.tier]}
                  </span>
                  {mod.required ? (
                    <span class="fcard__status fcard__status--required">Pflicht</span>
                  ) : mod.comingSoon ? (
                    <span class="fcard__status fcard__status--soon">Bald</span>
                  ) : mod.beta ? (
                    <span class="fcard__status fcard__status--beta">Beta</span>
                  ) : (
                    <label class="fcard__toggle" for={inputId} title={active ? 'Deaktivieren' : 'Aktivieren'}>
                      <input
                        type="checkbox"
                        id={inputId}
                        name={`feature_${mod.key}`}
                        checked={active}
                        class="fcard__toggle-input"
                        onchange="this.form.requestSubmit()"
                      />
                      <span class="fcard__toggle-track">
                        <span class="fcard__toggle-thumb"></span>
                      </span>
                    </label>
                  )}
                </div>

                <div class="fcard__identity">
                  <span class="fcard__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                         stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                      <Fragment set:html={mod.icon} />
                    </svg>
                  </span>
                  <span class="fcard__name">{mod.label}</span>
                </div>

                <p class="fcard__desc">{mod.desc}</p>

                <div class="fcard__meta">
                  {mod.requiresHardware && (
                    <span class="fcard__meta-badge fcard__meta-badge--hw">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="11" height="11">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                      </svg>
                      Hardware nötig
                    </span>
                  )}
                  {mod.addonPrice && (
                    <span class="fcard__meta-badge fcard__meta-badge--addon">
                      + {mod.addonPrice} Add-On
                    </span>
                  )}
                  {href && !mod.comingSoon && (
                    <a href={href} class="fcard__meta-badge fcard__meta-badge--config">
                      Konfigurieren →
                    </a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </form>
    </div>

    <div class="features-footer">
      <div class="features-footer__left">
        <div class="features-footer__stat">
          <span class="features-footer__num">{activeCount}</span>
          <span class="features-footer__label">aktiv</span>
        </div>
        <div class="features-footer__sep"></div>
        <div class="features-footer__stat">
          <span class="features-footer__num">{availableCount}</span>
          <span class="features-footer__label">verfügbar</span>
        </div>
        <div class="features-footer__sep"></div>
        <div class="features-footer__stat">
          <span class="features-footer__num">{soonCount}</span>
          <span class="features-footer__label">bald verfügbar</span>
        </div>
      </div>
      <div class="features-footer__right">
        <a href={`${b}/admin/subscription`} class="features-footer__link">
          Plan verwalten →
        </a>
      </div>
    </div>

    <p class="features-hint">
      Deaktivierte Module verschwinden sofort aus der Gäste-App. Aktive Buchungen bleiben bestehen.
    </p>

  </div>

</HotelierLayout>

<style>
  .features-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }
  @media (max-width: 768px) { .features-page { padding: 0 20px 64px; } }

  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-muted);
  }
  .breadcrumb__sep { color: var(--ink-faint); }
  .breadcrumb__crumb { color: var(--ink-muted); text-decoration: none; transition: color 150ms; }
  .breadcrumb__crumb:hover { color: var(--ink); }
  .breadcrumb__crumb--current { color: var(--ink); font-weight: 500; }

  .features-hero {
    padding: 40px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .features-hero__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.18em; font-weight: 500;
    color: #0A0A0A; background: var(--te-yellow);
    padding: 5px 10px; display: inline-block;
    margin-bottom: 20px; border-radius: var(--r-sm);
  }
  .features-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 4.5vw, 52px); font-weight: 400;
    line-height: 1.05; letter-spacing: -0.025em;
    margin-bottom: 12px; color: var(--ink);
  }
  .features-hero__sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted); letter-spacing: 0.04em;
  }

  .page-flash {
    margin-bottom: 20px; padding: 12px 16px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.06em; border-radius: var(--r-sm);
  }
  .page-flash--ok  { background: var(--sage-soft); color: var(--sage-strong); border: 1px solid var(--sage); }
  .page-flash--err { background: var(--burgund-soft); color: var(--burgund); border: 1px solid var(--burgund); }

  .features-tabs {
    display: flex; gap: 6px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }
  .features-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 8px 14px;
    border: none; background: none; cursor: pointer;
    color: var(--ink-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 150ms ease;
  }
  .features-tab:hover { color: var(--ink); }
  .features-tab--active { color: var(--ink); border-bottom-color: var(--ink); }
  [x-cloak] { display: none !important; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  @media (max-width: 900px)  { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .features-grid { grid-template-columns: 1fr; } }

  .fcard {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    padding: 18px;
    display: flex; flex-direction: column; gap: 10px;
    transition: border-color 150ms, box-shadow 150ms;
  }
  .fcard:hover:not(.fcard--soon) { border-color: var(--te-pink); box-shadow: 0 2px 12px rgba(0,0,0,.06); }
  .fcard--active { border-color: var(--sage); }
  .fcard--active:hover { border-color: var(--te-pink); background: var(--te-yellow-soft); }
  .fcard--soon { opacity: 0.55; cursor: default; }
  .fcard--required { background: var(--bg-deep); }

  .fcard__head { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .fcard__tier {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 2px 7px; border-radius: 99px; border: 1px solid;
  }
  .fcard__status {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 99px;
  }
  .fcard__status--required { background: var(--sage-soft); color: var(--sage-strong); border: 1px solid var(--sage); }
  .fcard__status--soon { background: var(--te-yellow-soft); color: var(--ink); border: 1px solid var(--te-yellow); }
  .fcard__status--beta { background: #FFF8E6; color: #8C6700; border: 1px solid #F7D97A; }

  .fcard__toggle { display: flex; align-items: center; cursor: pointer; }
  .fcard__toggle-input { position: absolute; opacity: 0; width: 0; height: 0; }
  .fcard__toggle-track {
    width: 36px; height: 20px; border-radius: 10px;
    background: var(--border);
    display: flex; align-items: center;
    padding: 2px; transition: background 200ms ease; cursor: pointer;
  }
  .fcard__toggle-input:checked + .fcard__toggle-track { background: var(--sage); }
  .fcard__toggle-thumb {
    width: 16px; height: 16px; border-radius: 50%;
    background: white; box-shadow: 0 1px 3px rgba(0,0,0,.25);
    transition: transform 200ms ease;
  }
  .fcard__toggle-input:checked + .fcard__toggle-track .fcard__toggle-thumb { transform: translateX(16px); }

  .fcard__identity { display: flex; align-items: center; gap: 10px; }
  .fcard__icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: var(--bg-deep);
    display: flex; align-items: center; justify-content: center;
    color: var(--ink-soft); flex-shrink: 0;
  }
  .fcard--active .fcard__icon { background: var(--te-yellow-soft); color: var(--ink); }
  .fcard__name { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.2; }
  .fcard--soon .fcard__name { color: var(--ink-muted); }

  .fcard__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; line-height: 1.5;
    color: var(--ink-muted); letter-spacing: 0.01em; margin: 0; flex: 1;
  }

  .fcard__meta { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 2px; }
  .fcard__meta-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px; font-weight: 500; letter-spacing: 0.08em;
    padding: 3px 8px; border-radius: 99px;
    text-decoration: none; display: inline-flex; align-items: center; gap: 4px;
    transition: all 120ms;
  }
  .fcard__meta-badge--hw { background: #FFF3E0; color: #8C5000; border: 1px solid #F5CFA0; }
  .fcard__meta-badge--addon { background: var(--te-yellow); color: var(--ink); border: 1px solid var(--te-yellow); }
  .fcard__meta-badge--config { background: var(--bg-deep); color: var(--ink-muted); border: 1px solid var(--border); }
  .fcard__meta-badge--config:hover { background: var(--ink); color: var(--bg); }

  .features-footer {
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
    padding: 18px 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-deep);
    margin-bottom: 20px;
  }
  @media (max-width: 600px) { .features-footer { flex-direction: column; align-items: flex-start; } }
  .features-footer__left { display: flex; align-items: center; gap: 16px; }
  .features-footer__stat { display: flex; flex-direction: column; gap: 1px; }
  .features-footer__num { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 300; color: var(--ink); line-height: 1; }
  .features-footer__label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-muted); }
  .features-footer__sep { width: 1px; height: 32px; background: var(--border); }
  .features-footer__right { display: flex; gap: 10px; align-items: center; flex-shrink: 0; }
  .features-footer__link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; color: var(--ink-muted);
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    transition: all 150ms;
  }
  .features-footer__link:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .features-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--ink-faint); letter-spacing: 0.04em; margin-top: 8px;
  }
</style>
