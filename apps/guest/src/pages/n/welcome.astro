---
// /n/welcome?hotel=<uuid>[&room=<nr>]
// Empty-State wenn kein aktiver Stay für den NFC-Tag gefunden wurde.
// Zeigt Hotel-Logo + ausgewähltes Hotel-Theme — identisch zur /g/[token]-Logik.

import { createSupabaseServiceRoleInstance } from '@retaha/auth';
import { computeBrandPalette } from '@retaha/auth';
import { resolveTheme } from '@retaha/ui/theme';
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/retaha.css';
import '@retaha/ui-guest/themes/bauhaus';
import '@retaha/ui-guest/themes/editorial';
import '@retaha/ui-guest/themes/maison';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/inter-tight/500.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/bodoni-moda/400.css';
import '@fontsource/bodoni-moda/400-italic.css';
import '@fontsource/bodoni-moda/500.css';
import '@fontsource/dm-sans/300.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';

const url = new URL(Astro.request.url);
const hotelId = url.searchParams.get('hotel');
const roomNumber = url.searchParams.get('room');

let hotel: {
  name: string;
  logo_primary: string | null;
  logo_dark: string | null;
  theme: string | null;
  design_identity: string | null;
  brand_primary: string | null;
} | null = null;

if (hotelId && /^[0-9a-f-]{36}$/i.test(hotelId)) {
  const sb = createSupabaseServiceRoleInstance();
  const { data } = await sb
    .from('hotels')
    .select('name, logo_primary, logo_dark, theme, design_identity, brand_primary')
    .eq('id', hotelId)
    .maybeSingle();
  if (data) hotel = data;
}

// Theme-Auflösung identisch zu /g/[token].astro
const IDENTITY_REMAP: Record<string, string> = {
  classic:             'bauhaus',
  bauhaus_manufaktur:  'bauhaus',
  premium_anthrazit:   'maison',
  warmes_burgund:      'editorial',
};
const VALID_IDENTITIES = new Set(['bauhaus', 'editorial', 'maison']);
const rawIdentity = hotel?.design_identity ?? null;
const remappedIdentity = rawIdentity ? (IDENTITY_REMAP[rawIdentity] ?? rawIdentity) : null;
const hotelDesignIdentity = remappedIdentity && VALID_IDENTITIES.has(remappedIdentity) ? remappedIdentity : null;
const legacyTheme = resolveTheme({ hotelTheme: hotel?.theme });
const activeTheme = hotelDesignIdentity ?? (IDENTITY_REMAP[legacyTheme] ?? 'bauhaus');

const brandPrimary: string | null = hotel?.brand_primary ?? null;
const brandStyle = (() => {
  if (!brandPrimary) return undefined;
  const p = computeBrandPalette(brandPrimary);
  return `--user-brand-primary:${brandPrimary};--accent:${brandPrimary};--user-brand-hover:${p.hover};--user-brand-soft:${p.soft};--user-brand-on-accent:${p.onAccent}`;
})();

const hotelName = hotel?.name ?? 'das Hotel';
const heading = roomNumber
  ? `Willkommen in Zimmer ${roomNumber}`
  : `Willkommen im ${hotelName}`;
const subtitle = roomNumber
  ? `Es ist gerade kein aktiver Aufenthalt für dieses Zimmer hinterlegt. Frag an der Rezeption nach deinem Zugang.`
  : `Frag an der Rezeption nach deinem persönlichen Zugang oder scanne den QR-Code auf deinem Schlüsselanhänger.`;
---

<!DOCTYPE html>
<html lang="de" data-theme={activeTheme} style={brandStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{hotelName} · retaha</title>
  </head>
  <body class={`gate-guest gate-theme-${activeTheme}`}>
    <main class="nw-shell">
      {(hotel?.logo_primary ?? hotel?.logo_dark) && (
        <img class="nw-logo" src={hotel.logo_primary ?? hotel.logo_dark!} alt={hotelName} />
      )}
      <h1 class="nw-heading">{heading}<span class="h-dot">.</span></h1>
      <p class="nw-sub">{subtitle}</p>
      <div class="nw-hint">
        <p class="nw-hint-line">📱 Karte am Empfang scannen lassen.</p>
      </div>
    </main>

    <style>
      .nw-shell {
        max-width: 520px;
        width: 100%;
        margin: 0 auto;
        padding: 64px 24px;
        text-align: center;
      }
      .nw-logo { max-height: 56px; width: auto; margin-bottom: 28px; }
      .nw-eyebrow {
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--theme-accent, var(--accent, #FF4A82));
        margin: 0 0 16px;
        font-weight: 500;
      }
      .nw-heading {
        font-family: var(--theme-font-headline, var(--theme-font-sans));
        font-size: 30px;
        font-weight: 300;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin: 0 0 16px;
        color: var(--theme-text-primary);
      }
      .h-dot { color: var(--theme-accent, var(--accent, #FF4A82)); }
      .nw-sub {
        font-size: 15px;
        line-height: 1.55;
        color: var(--theme-text-secondary, rgba(26,26,26,.65));
        margin: 0 0 32px;
      }
      .nw-hint {
        padding: 16px 20px;
        background: var(--theme-bg-secondary, #FAFAF8);
        border-left: 3px solid var(--theme-accent, var(--accent, #FF4A82));
        text-align: left;
      }
      .nw-hint-line {
        font-size: 14px;
        color: var(--theme-text-primary);
        margin: 0;
      }
    </style>
  </body>
</html>
