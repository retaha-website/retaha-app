---
import HotelierLayout from '../layouts/HotelierLayout.astro';
import BauhausToggle from '@retaha/ui/components/admin/BauhausToggle.astro';
import EditorialPageHeader from '@retaha/ui/components/admin/EditorialPageHeader.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { mergeAndTranslate, asLanguageCode } from '@retaha/i18n';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) {
  const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
  return Astro.redirect(`${b}/admin/login`);
}

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) {
  const b = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
  return Astro.redirect(`${b}/admin/login?error=no_hotel`);
}

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const { data: hotelLangRow } = await client
  .from('hotels').select('default_language, enabled_languages')
  .eq('id', hotel.id).maybeSingle();
const hotelDefaultLang = (hotelLangRow?.default_language as string | undefined) ?? 'de';
const hotelEnabledLangs: string[] = Array.isArray(hotelLangRow?.enabled_languages)
  ? hotelLangRow.enabled_languages : ['de','en','fr','es'];
const LANG_LABELS_LOC: Record<string, string> = {
  de: 'Deutsch', en: 'English', fr: 'Français', es: 'Español',
  it: 'Italiano', pt: 'Português', nl: 'Nederlands',
  ru: 'Русский', ar: 'العربية', zh: '中文',
};
const otherEnabledLabel = hotelEnabledLangs.filter(l => l !== hotelDefaultLang)
  .map(l => LANG_LABELS_LOC[l] || l).join(', ');

function pickI18n(value: any, lang: string, fallback: string = ''): string {
  if (!value || typeof value !== 'object') return fallback;
  return value[lang]?.value || value[hotelDefaultLang]?.value || value['de']?.value || fallback;
}

let message: { type: 'success' | 'error'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();

  const { data: currentSettings } = await client
    .from('hotel_settings')
    .select('features, breakfast_location_i18n, breakfast_included_i18n')
    .eq('hotel_id', hotel.id)
    .maybeSingle();

  const currentFeatures = (currentSettings?.features as Record<string, any>) || {};
  const allReservationValues = form.getAll('breakfast_reservation');
  const reservationOn = allReservationValues.includes('on');
  const newFeatures = { ...currentFeatures, breakfast_reservation: reservationOn };

  const locationDefault = form.get('breakfast_location_default')?.toString().trim() || '';
  const includedDefault = form.get('breakfast_included_default')?.toString().trim() || '';

  const updates: Record<string, any> = {
    features: newFeatures,
    breakfast_start_time: form.get('breakfast_start_time')?.toString() || '07:30',
    breakfast_end_time: form.get('breakfast_end_time')?.toString() || '10:30',
    breakfast_slot_minutes: parseInt(form.get('breakfast_slot_minutes')?.toString() || '30') || 30,
    ...(await Promise.all([
      mergeAndTranslate(currentSettings?.breakfast_location_i18n, locationDefault, asLanguageCode(hotelDefaultLang), { logLabel: 'hotel_settings.breakfast_location' }),
      mergeAndTranslate(currentSettings?.breakfast_included_i18n, includedDefault, asLanguageCode(hotelDefaultLang), { logLabel: 'hotel_settings.breakfast_included' }),
    ]).then(([locR, incR]) => ({
      breakfast_location_i18n: Object.keys(locR.i18n).length > 0 ? locR.i18n : null,
      breakfast_included_i18n: Object.keys(incR.i18n).length > 0 ? incR.i18n : null,
    }))),
    updated_at: new Date().toISOString(),
  };
  if (hotelDefaultLang === 'de') {
    updates.breakfast_location_de = locationDefault || null;
    updates.breakfast_included_de = includedDefault || null;
  }

  const { data: updatedRows, error } = await client
    .from('hotel_settings')
    .update(updates)
    .eq('hotel_id', hotel.id)
    .select('hotel_id');

  if (error) {
    message = { type: 'error', text: `Speichern fehlgeschlagen: ${error.message}` };
  } else if (!updatedRows || updatedRows.length === 0) {
    message = { type: 'error', text: 'Speichern fehlgeschlagen: keine Berechtigung (RLS) oder Eintrag nicht gefunden' };
  } else {
    message = { type: 'success', text: 'Frühstücks-Einstellungen gespeichert.' };
  }
}

const { data: settings } = await client
  .from('hotel_settings')
  .select(`
    features,
    breakfast_start_time, breakfast_end_time, breakfast_slot_minutes,
    breakfast_location_de, breakfast_location_i18n,
    breakfast_included_de, breakfast_included_i18n
  `)
  .eq('hotel_id', hotel.id)
  .maybeSingle();

const s = settings || {};
const features = ((settings?.features as Record<string, any>) || {});
const reservationOn = features.breakfast_reservation !== false;
const startTime = ((s as any).breakfast_start_time || '07:30').substring(0, 5);
const endTime = ((s as any).breakfast_end_time || '10:30').substring(0, 5);
---

<HotelierLayout title="Frühstück" activeTab="gast" hotelName={hotel.name}>
  <div class="-mt-10">
    <EditorialPageHeader
      sectionNumber="03"
      sectionLabel="Frühstück"
      headlineLight="Was deine Gäste"
      headlineBold="erwartet"
      subtitle="Reservierungen, Zeiten, Ort, Angebot."
    />
  </div>

  {message && (
    <div class={`mb-6 px-4 py-3 text-sm ${
      message.type === 'success'
        ? 'bg-green-50 border-l-4 border-green-700 text-green-800'
        : 'bg-red-50 border-l-4 border-red-700 text-red-800'
    }`}>
      {message.text}
    </div>
  )}

  <form method="POST" class="space-y-8">

    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Reservierung —</p>
        <h2 class="text-xl font-medium">Können Gäste einen Tisch reservieren?</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Wenn aktiviert, sehen Gäste ein Formular zum Reservieren. Wenn deaktiviert, sehen sie nur
          die Frühstückszeiten + Ort als Info ("Komm einfach vorbei").
        </p>
      </div>

      <label for="reservation-toggle" class="flex items-center gap-5 py-[26px] cursor-pointer">
        <span
          data-toggle-accent
          class="w-1.5 h-1.5 rounded-full bg-anthrazit/30 transition-colors duration-200 ease-in-out flex-shrink-0 pointer-events-none"
          aria-hidden="true"
        ></span>
        <div class="flex-1 min-w-0">
          <p class="text-[15px] font-medium text-anthrazit leading-tight tracking-tight mb-1.5">Tisch-Reservierung aktiv</p>
          <p class="text-[13px] italic text-anthrazit/55 leading-[1.55]" id="toggle-status-text">
            {reservationOn ? 'Gäste können Tische reservieren' : 'Gäste sehen nur Infos, kein Reservierungs-Formular'}
          </p>
        </div>
        <BauhausToggle id="reservation-toggle" name="breakfast_reservation" checked={reservationOn} label="Tisch-Reservierung aktiv" />
      </label>

      <script is:inline>
        const toggle = document.getElementById('reservation-toggle');
        const statusText = document.getElementById('toggle-status-text');
        if (toggle && statusText) {
          toggle.addEventListener('change', () => {
            statusText.textContent = toggle.checked
              ? 'Gäste können Tische reservieren'
              : 'Gäste sehen nur Infos, kein Reservierungs-Formular';
          });
        }
      </script>
    </section>

    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Zeiten —</p>
        <h2 class="text-xl font-medium">Wann gibt es Frühstück?</h2>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Beginn</span>
          <input type="time" name="breakfast_start_time" value={startTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit" />
        </label>
        <label class="block">
          <span class="eyebrow text-anthrazit/55 block mb-1">Ende</span>
          <input type="time" name="breakfast_end_time" value={endTime}
            class="w-full px-3 py-2 border border-anthrazit/20 text-sm focus:outline-none focus:border-anthrazit" />
        </label>
        <label class="bauhaus-field">
          <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">Slot-Länge (Min)</span>
          <input type="number" name="breakfast_slot_minutes" value={(s as any).breakfast_slot_minutes || 30}
            min="5" max="120" step="5" class="bauhaus-input" />
        </label>
      </div>
      <p class="text-[10px] text-anthrazit/40 mt-3 italic">
        Slot-Länge bestimmt die Abstände der Reservierungs-Zeiten (z.B. 30 = 07:30, 08:00, 08:30, ...).
      </p>
    </section>

    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Ort —</p>
        <h2 class="text-xl font-medium">Wo wird gefrühstückt?</h2>
        <p class="text-xs text-anthrazit/55 mt-1">Z.B. „im Wintergarten" — wird zusammen mit der Begrüßung gezeigt.</p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">{LANG_LABELS_LOC[hotelDefaultLang]}</span>
        <input
          type="text"
          name="breakfast_location_default"
          value={pickI18n((s as any).breakfast_location_i18n, hotelDefaultLang, (s as any).breakfast_location_de ?? '')}
          class="bauhaus-input"
        />
        <p class="text-xs text-anthrazit/55 mt-1 italic">
          {otherEnabledLabel
            ? `Wird automatisch in ${otherEnabledLabel} übersetzt.`
            : 'Aktuell nur Standardsprache aktiviert.'}
        </p>
      </label>
    </section>

    <section class="bg-white border border-anthrazit/[0.12] p-8">
      <div class="mb-6">
        <p class="eyebrow text-pink-shock mb-1">— Was inkludiert ist —</p>
        <h2 class="text-xl font-medium">Was bekommen deine Gäste?</h2>
        <p class="text-xs text-anthrazit/55 mt-1 max-w-lg">
          Z.B. „Frische Backwaren, regionaler Honig, Bio-Eier, …" — wird im Info-Mode prominent gezeigt.
        </p>
      </div>
      <label class="bauhaus-field">
        <span class="bauhaus-field-eyebrow bauhaus-field-eyebrow--sub">{LANG_LABELS_LOC[hotelDefaultLang]}</span>
        <textarea name="breakfast_included_default" rows="3" class="bauhaus-textarea"
        >{pickI18n((s as any).breakfast_included_i18n, hotelDefaultLang, (s as any).breakfast_included_de ?? '')}</textarea>
        <p class="text-xs text-anthrazit/55 mt-1 italic">
          {otherEnabledLabel
            ? `Wird automatisch in ${otherEnabledLabel} übersetzt.`
            : 'Aktuell nur Standardsprache aktiviert.'}
        </p>
      </label>
    </section>

    <div class="flex justify-end pt-4">
      <button type="submit" class="bauhaus-button bauhaus-button--primary">
        Änderungen speichern
      </button>
    </div>

  </form>
</HotelierLayout>
