---
// Eine kompakte Modul-Zeile für die Module-Seite. In beiden Gruppierungen
// (Paket + Kategorie) wiederverwendet — showTier blendet das Tier-Badge ein
// (nur bei Kategorie-Gruppierung sinnvoll; bei Paket ist die Sektion das Paket).
// x-show/isVisible referenzieren die Alpine-Scope der Eltern-Seite (Status-Tab).
import { TIER_LABELS, type ModuleDefinition } from '../../lib/modules-registry';

interface Props {
  mod: ModuleDefinition;
  included: boolean;
  status: string;       // 'normal' | 'coming-soon'
  href: string | null;  // Konfigurieren-Ziel
  upgradeHref: string;
  showTier?: boolean;
}
const { mod, included, status, href, upgradeHref, showTier = false } = Astro.props;
const isSoon = status === 'coming-soon';
---

<div class="mod-row" x-show={`isVisible('${status}', ${included})`} x-cloak>
  <span class="mod-row__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
         stroke-linecap="round" stroke-linejoin="round" width="17" height="17">
      <Fragment set:html={mod.icon} />
    </svg>
  </span>

  <div class="mod-row__text">
    <span class="mod-row__name">
      {mod.label}
      {showTier && <span class="mod-row__tier" data-tier={mod.tier}>{TIER_LABELS[mod.tier]}</span>}
    </span>
    <span class="mod-row__sub">{mod.desc}</span>
  </div>

  <div class="mod-row__right">
    {mod.required ? (
      <span class="mod-row__status mod-row__status--req">Pflicht</span>
    ) : isSoon ? (
      <span class="mod-row__status mod-row__status--soon">Bald</span>
    ) : included ? (
      <span class="mod-row__status mod-row__status--inc">✓ Enthalten</span>
    ) : (
      <span class="mod-row__status mod-row__status--up">{mod.addonPrice ? `+ ${mod.addonPrice}` : 'Upgrade'}</span>
    )}

    {(href && included && !isSoon) ? (
      <a href={href} class="mod-row__chev" aria-label={`${mod.label} konfigurieren`}>›</a>
    ) : (!included && !isSoon) ? (
      <a href={upgradeHref} class="mod-row__chev mod-row__chev--up" aria-label="Plan upgraden">›</a>
    ) : (
      <span class="mod-row__chev mod-row__chev--none" aria-hidden="true">·</span>
    )}
  </div>
</div>

<style>
  .mod-row {
    display: flex; align-items: center; gap: 12px;
    padding: 11px 14px; border-bottom: 1px solid var(--border);
  }
  .mod-row:last-child { border-bottom: none; }

  .mod-row__icon {
    width: 30px; height: 30px; border-radius: var(--r-sm);
    background: var(--bg-deep); color: var(--ink-soft);
    display: grid; place-items: center; flex-shrink: 0;
  }

  .mod-row__text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  .mod-row__name {
    font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--ink); display: inline-flex; align-items: center; gap: 8px;
  }
  .mod-row__tier {
    font-family: 'JetBrains Mono', monospace; font-size: 8px; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 1px 6px; border-radius: 99px;
    background: var(--bg-deep); color: var(--ink-muted); border: 1px solid var(--border);
  }
  .mod-row__tier[data-tier="pro"]        { color: #2563EB; border-color: rgba(37,99,235,0.30); }
  .mod-row__tier[data-tier="premium"]    { color: #7C3AED; border-color: rgba(124,58,237,0.30); }
  .mod-row__tier[data-tier="enterprise"] { color: var(--ink); border-color: var(--ink-faint); }
  .mod-row__sub {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; line-height: 1.4;
    color: var(--ink-muted); letter-spacing: 0.01em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .mod-row__right { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .mod-row__status {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase; white-space: nowrap;
  }
  .mod-row__status--inc  { color: #5C9070; }
  .mod-row__status--req  { color: var(--ink-muted); }
  .mod-row__status--soon { color: var(--ink-faint); }
  .mod-row__status--up   { color: var(--ink-muted); }

  .mod-row__chev {
    font-size: 18px; line-height: 1; color: var(--ink-muted); text-decoration: none;
    width: 16px; text-align: center; transition: color 150ms ease; flex-shrink: 0;
  }
  .mod-row__chev:hover { color: var(--ink); }
  .mod-row__chev--none { color: var(--ink-faint); }
</style>
