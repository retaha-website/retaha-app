---
import { t } from '@retaha/i18n';
import type { Lang } from '@retaha/i18n';

interface Props {
  hotel: any;
  hotelLogoDark: string | null;
  guest: any;
  room: any;
  settings: any;
  token: string;
  lang: string;
  hotelEnabledLangs: string[];
  greetingName: string;
  checkInLabel: string;
  checkOutLabel: string;
  nightsCount: number;
  recs: any[];
  f: any;
  walletAvailable: boolean;
}

const {
  hotel, hotelLogoDark, guest, room, settings, token, lang,
  hotelEnabledLangs, greetingName, checkInLabel, checkOutLabel,
  nightsCount, recs, f, walletAvailable,
} = Astro.props;

const switchUrl = (l: string) => `/g/${token}?lang=${l}`;
const eveName = settings.eve_name || 'Eve';
const welcomeSub = settings.welcome_message_de || 'Schön, dass du da bist.';
const hasService = f.service !== false && settings.service_items?.length > 0;
const hasConference = f.conference !== false && settings.conference_rooms?.length > 0;
---

<!-- ─── HOTEL HEADER ─────────────────────────────────────────────────── -->
<header class="bh-head">
  <div class="bh-mark">
    {hotelLogoDark ? (
      <img class="bh-mark__img" src={hotelLogoDark} alt={hotel.name} />
    ) : hotel.logo_url ? (
      <img class="bh-mark__img bh-mark__img--invert" src={hotel.logo_url} alt={hotel.name} />
    ) : (
      <div class="bh-mark__initial">{hotel.name.charAt(0)}</div>
    )}
    <div>
      <div class="bh-mark__name">{hotel.name}</div>
      {room && <div class="bh-mark__sub">{hotel.city ? `${hotel.city} · ` : ''}{t('hero.stay.room', lang as Lang)} {room.room_number}</div>}
    </div>
  </div>
  <div class="bh-lang">
    {hotelEnabledLangs.map(l => (
      <a href={switchUrl(l)} class={`bh-lang__btn ${lang === l ? 'is-active' : ''}`}>{l.toUpperCase()}</a>
    ))}
  </div>
</header>

<!-- ─── HERO ─────────────────────────────────────────────────────────── -->
<section class="bh-hero">
  <span class="bh-hero__eyebrow">Willkommen</span>
  <h1 class="bh-hero__title">
    {greetingName}<span class="bh-dot"></span>
  </h1>
  <p class="bh-hero__sub">{welcomeSub}</p>
</section>

<!-- ─── STAY CARD ─────────────────────────────────────────────────────── -->
<div class="bh-stay">
  <div class="bh-stay__col">
    <div class="bh-stay__label">Anreise</div>
    <div class="bh-stay__value">{checkInLabel}</div>
  </div>
  <div class="bh-stay__div"></div>
  <div class="bh-stay__col">
    <div class="bh-stay__label">Abreise</div>
    <div class="bh-stay__value">{checkOutLabel}</div>
  </div>
  <div class="bh-stay__div"></div>
  <div class="bh-stay__col">
    <div class="bh-stay__label">Nächte</div>
    <div class="bh-stay__value">{nightsCount}</div>
  </div>
</div>

<!-- ─── ACTION GRID ───────────────────────────────────────────────────── -->
<section class="bh-actions">
  <div class="bh-actions__head">
    <h2 class="bh-actions__title">Was du brauchst</h2>
  </div>
  <div class="bh-grid">

    <button class="bh-tile" type="button" @click="openSheet('wifi')">
      <div class="bh-tile__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/>
        </svg>
      </div>
      <div class="bh-tile__title">WLAN</div>
      <div class="bh-tile__sub">Sofort verbinden</div>
    </button>

    <button class="bh-tile" type="button" @click="openSheet('breakfast')">
      <div class="bh-tile__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
        </svg>
      </div>
      <div class="bh-tile__title">Frühstück</div>
      <div class="bh-tile__sub">Slot buchen</div>
    </button>

    {f.eve !== false && (
      <button class="bh-tile bh-tile--featured" type="button"
        @click="eveOpen = true; eveSeenBefore = true; try { localStorage.setItem('retaha_eve_seen', '1') } catch(_) {}; eveMaybeWelcome()">
        <div class="bh-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        </div>
        <div class="bh-tile__title">{eveName}</div>
        <div class="bh-tile__sub">24/7 Concierge</div>
      </button>
    )}

    {hasService && (
      <button class="bh-tile" type="button" @click="openSheet('service')">
        <div class="bh-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
        </div>
        <div class="bh-tile__title">Service</div>
        <div class="bh-tile__sub">Anfrage senden</div>
      </button>
    )}

    {hasConference && (
      <button class="bh-tile" type="button" @click="openSheet('conference')">
        <div class="bh-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="7" width="18" height="13"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
        </div>
        <div class="bh-tile__title">Konferenz</div>
        <div class="bh-tile__sub">Raum buchen</div>
      </button>
    )}

    {f.recommendations !== false && (
      <button class="bh-tile" type="button" @click="openSheet('places')">
        <div class="bh-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>
          </svg>
        </div>
        <div class="bh-tile__title">Tipps</div>
        <div class="bh-tile__sub">{hotel.city || 'Entdecken'}</div>
      </button>
    )}

    {f.self_checkout !== false && (
      <button class="bh-tile" type="button" onclick={`window.location='/g/${token}/checkout'`}>
        <div class="bh-tile__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12L10 17L19 7"/>
          </svg>
        </div>
        <div class="bh-tile__title">Checkout</div>
        <div class="bh-tile__sub">Abreise vorbereiten</div>
      </button>
    )}

  </div>
</section>

<!-- ─── EMPFEHLUNG ────────────────────────────────────────────────────── -->
{recs.length > 0 && (
  <div class="bh-rec"
    role="button" tabindex="0"
    data-card-id={recs[0].id}
    data-card-type={recs[0].cardType}
    data-action-target={recs[0].actionTarget ?? ''}
    @click="handleRecClick($el)">
    <div>
      <div class="bh-rec__eyebrow">Empfehlung</div>
      <div class="bh-rec__title">{recs[0].title}</div>
      {recs[0].sub && <div class="bh-rec__sub">{recs[0].sub}</div>}
    </div>
    <div class="bh-rec__arrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 17l9.2-9.2M17 17V7H7"/>
      </svg>
    </div>
  </div>
)}

<!-- ─── BOTTOM TABS ───────────────────────────────────────────────────── -->
<nav class="bh-tabs">
  <button class="bh-tab bh-tab--active" type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M3 12l9-9 9 9M5 10v10h14V10"/>
    </svg>
    <span>Start</span>
  </button>
  <button class="bh-tab" type="button"
    @click="eveOpen = true; eveSeenBefore = true; try { localStorage.setItem('retaha_eve_seen', '1') } catch(_) {}; eveMaybeWelcome()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <span>Eve</span>
  </button>
  <button class="bh-tab" type="button" @click="openSheet('places')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="10"/><polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>
    </svg>
    <span>Tipps</span>
  </button>
  <button class="bh-tab" type="button" @click="openSheet('service')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span>Service</span>
  </button>
</nav>

<style>
  /* ── Bauhaus — Space Grotesk · Pink-Punkt · Yellow-Hover ── */

  .bh-head {
    padding: 16px 24px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--guest-border, #E5E4DF);
    background: var(--guest-bg-card, #fff);
  }
  .bh-mark { display: flex; align-items: center; gap: 10px; }
  .bh-mark__img { height: 32px; width: auto; }
  .bh-mark__img--invert { filter: brightness(0) saturate(0); }
  .bh-mark__initial {
    width: 32px; height: 32px;
    background: var(--guest-ink, #0A0A0A);
    color: var(--guest-bg, #FAFAF7);
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--guest-radius-sm, 8px);
    font-family: var(--guest-font-mono, 'JetBrains Mono', monospace);
    font-size: 14px; font-weight: 600;
  }
  .bh-mark__name { font-size: 13px; font-weight: 500; letter-spacing: -0.01em; }
  .bh-mark__sub {
    font-family: var(--guest-font-mono, 'JetBrains Mono', monospace);
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--guest-ink-faint, #A3A3A3); margin-top: 1px;
  }
  .bh-lang { display: flex; gap: 4px; }
  .bh-lang__btn {
    width: 30px; height: 30px; border-radius: 50%;
    border: 1px solid var(--guest-border, #E5E4DF);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--guest-font-mono, monospace); font-size: 10px; font-weight: 500;
    color: var(--guest-ink-muted, #5C5C5C); text-decoration: none;
    transition: all 180ms;
  }
  .bh-lang__btn.is-active, .bh-lang__btn:hover {
    background: var(--guest-ink, #0A0A0A); color: var(--guest-bg, #fff);
    border-color: var(--guest-ink, #0A0A0A);
  }

  .bh-hero {
    padding: 36px 24px 24px;
  }
  .bh-hero__eyebrow {
    display: inline-block;
    background: var(--guest-hover, #FFE600); color: var(--guest-ink, #0A0A0A);
    padding: 4px 10px;
    font-family: var(--guest-font-mono, monospace); font-size: 10px; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
    border-radius: 4px; margin-bottom: 14px;
  }
  .bh-hero__title {
    font-family: var(--guest-font-display, 'Space Grotesk', sans-serif);
    font-size: clamp(36px, 10vw, 46px); line-height: 1.05;
    font-weight: 500; letter-spacing: -0.025em;
    color: var(--guest-ink, #0A0A0A); margin-bottom: 10px;
  }
  .bh-dot {
    display: inline-block; width: 11px; height: 11px;
    background: var(--guest-accent, #FF4A82); border-radius: 50%;
    vertical-align: baseline; margin-left: 3px;
  }
  .bh-hero__sub {
    font-size: 14px; color: var(--guest-ink-muted, #5C5C5C); line-height: 1.5;
  }

  .bh-stay {
    margin: 0 24px 24px;
    border: 1px solid var(--guest-border, #E5E4DF);
    border-radius: var(--guest-radius, 12px);
    padding: 18px 20px;
    display: flex; align-items: center; gap: 0;
    background: var(--guest-bg-card, #fff);
  }
  .bh-stay__col { flex: 1; padding: 0 4px; }
  .bh-stay__label {
    font-family: var(--guest-font-mono, monospace); font-size: 9px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--guest-ink-faint, #A3A3A3); margin-bottom: 4px;
  }
  .bh-stay__value { font-size: 14px; font-weight: 500; letter-spacing: -0.01em; }
  .bh-stay__div { width: 1px; height: 36px; background: var(--guest-border, #E5E4DF); }

  .bh-actions { padding: 0 24px 16px; }
  .bh-actions__head { margin-bottom: 14px; }
  .bh-actions__title { font-size: 14px; font-weight: 500; letter-spacing: -0.01em; }

  .bh-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  }
  .bh-tile {
    background: var(--guest-bg-card, #fff);
    border: 1px solid var(--guest-border, #E5E4DF);
    border-radius: var(--guest-radius, 12px);
    padding: 16px; cursor: pointer;
    transition: all 200ms ease;
    position: relative; min-height: 110px;
    display: flex; flex-direction: column; justify-content: space-between;
    text-align: left;
  }
  .bh-tile:hover, .bh-tile:active {
    background: var(--guest-hover-soft, #FFFAB8);
    border-color: var(--guest-hover, #FFE600);
    transform: translateY(-2px);
  }
  .bh-tile--featured {
    background: var(--guest-ink, #0A0A0A) !important;
    border-color: var(--guest-ink, #0A0A0A) !important;
  }
  .bh-tile--featured .bh-tile__icon,
  .bh-tile--featured .bh-tile__title { color: var(--guest-bg, #FAFAF7) !important; }
  .bh-tile--featured .bh-tile__sub { color: rgba(250,250,247,0.5) !important; }
  .bh-tile__icon { color: var(--guest-ink, #0A0A0A); }
  .bh-tile__icon svg { width: 20px; height: 20px; }
  .bh-tile__title { font-size: 14px; font-weight: 500; letter-spacing: -0.01em; margin-top: 12px; }
  .bh-tile__sub {
    font-family: var(--guest-font-mono, monospace); font-size: 9px;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--guest-ink-faint, #A3A3A3); margin-top: 4px;
  }

  .bh-rec {
    margin: 4px 24px 24px;
    padding: 20px;
    background: var(--guest-accent, #FF4A82); color: #fff;
    border-radius: var(--guest-radius, 12px);
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; cursor: pointer; position: relative; overflow: hidden;
  }
  .bh-rec__eyebrow {
    font-family: var(--guest-font-mono, monospace); font-size: 9px;
    letter-spacing: 0.14em; text-transform: uppercase;
    opacity: 0.7; margin-bottom: 6px;
  }
  .bh-rec__title { font-size: 18px; font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; }
  .bh-rec__sub { font-size: 12px; opacity: 0.85; margin-top: 2px; }
  .bh-rec__arrow {
    width: 28px; height: 28px;
    border: 1px solid rgba(255,255,255,0.5); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .bh-rec__arrow svg { width: 14px; height: 14px; }

  .bh-tabs {
    margin-top: auto;
    padding: 12px 8px env(safe-area-inset-bottom, 16px);
    border-top: 1px solid var(--guest-border, #E5E4DF);
    background: var(--guest-bg-card, #fff);
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px;
    position: sticky; bottom: 0;
  }
  .bh-tab {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 8px 4px; cursor: pointer; border: none; background: transparent;
    color: var(--guest-ink-faint, #A3A3A3); transition: color 180ms;
    font-family: inherit;
  }
  .bh-tab svg { width: 20px; height: 20px; stroke: currentColor; }
  .bh-tab span {
    font-family: var(--guest-font-mono, monospace); font-size: 9px;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .bh-tab--active { color: var(--guest-ink, #0A0A0A); }
  .bh-tab--active span { font-weight: 600; }
</style>
