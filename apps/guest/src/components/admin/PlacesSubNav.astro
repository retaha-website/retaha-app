---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const tabs = [
  { href: '/places', label: 'Picks', slug: 'picks' },
];
---

<nav class="places-subnav" aria-label="Places Sub-Navigation">
  <div class="places-subnav-inner">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class={`places-subnav-tab${currentPath === tab.href ? ' is-active' : ''}`}
        aria-current={currentPath === tab.href ? 'page' : undefined}
      >
        {tab.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .places-subnav {
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .places-subnav-inner {
    display: flex;
    gap: 0;
    max-width: 72rem;
    margin: 0 auto;
  }
  .places-subnav-tab {
    padding: 12px 20px;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    margin-bottom: -1px;
  }
  .places-subnav-tab:hover { color: var(--ink); }
  .places-subnav-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--petrol, #14616E);
    font-weight: 500;
  }
</style>
