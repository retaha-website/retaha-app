---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const tabs = [
  { href: '/eve/knowledge',   label: 'Wissen',        slug: 'knowledge' },
  { href: '/eve/settings',    label: 'Persönlichkeit', slug: 'settings'  },
  { href: '/eve/feedback',    label: 'Feedback',       slug: 'feedback'  },
];
---

<nav class="eve-subnav" aria-label="Eve Sub-Navigation">
  <div class="eve-subnav-inner">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class={`eve-subnav-tab${currentPath === tab.href ? ' is-active' : ''}`}
        aria-current={currentPath === tab.href ? 'page' : undefined}
      >
        {tab.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .eve-subnav {
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .eve-subnav-inner {
    display: flex;
    gap: 0;
    max-width: 72rem;
    margin: 0 auto;
  }
  .eve-subnav-tab {
    padding: 12px 20px;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
    margin-bottom: -1px;
  }
  .eve-subnav-tab:hover { color: var(--ink); }
  .eve-subnav-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--te-pink, #FF4A82);
    font-weight: 500;
  }
</style>
