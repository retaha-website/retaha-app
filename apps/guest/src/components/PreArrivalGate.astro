    justify-content: center;
    animation: wc-check-pop .5s .25s ease-out both;
  }
  .wc-hotel-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
