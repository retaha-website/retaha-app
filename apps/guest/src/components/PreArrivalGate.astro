  }
  .wc-skip:hover, .wc-skip:active { color: rgba(255,255,255,.64); }

  /* ── Bis-bald-State ──────────────────────────────────────────────── */
  .wc-done-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
