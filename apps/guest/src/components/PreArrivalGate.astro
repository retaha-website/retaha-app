---
interface Props {
  token: string;
  guestName: string | null;
  hotelName: string;
  heroImageUrl: string | null;
  logoUrl: string | null;
  brandPrimary: string;
  gateState: 'default' | 'skipped' | 'completed';
  checkInLabel: string;
  lang: string;
}

const { token, guestName, hotelName, heroImageUrl, logoUrl, brandPrimary, gateState, checkInLabel, lang } = Astro.props;

const firstName = guestName ?? '';

type LS = { title: string; sub: string };
type LG = { default: LS; skipped: LS; completed: LS };
const allLabels: Record<string, LG> = {
  de: {
    default:   { title: firstName ? `Willkommen, ${firstName}.` : 'Willkommen.',    sub: 'Schön, dass du kommst. Wir freuen uns auf dich.' },
    skipped:   { title: firstName ? `Bis bald, ${firstName}.`   : 'Bis bald.',      sub: `Wir freuen uns auf deinen Besuch am ${checkInLabel}.` },
    completed: { title: firstName ? `Bis bald, ${firstName}!`   : 'Bis bald!',      sub: 'Wir sehen uns beim Check-in.' },
  },
  en: {
    default:   { title: firstName ? `Welcome, ${firstName}.`    : 'Welcome.',       sub: 'Great to have you coming. We look forward to your visit.' },
    skipped:   { title: firstName ? `See you soon, ${firstName}.` : 'See you soon.', sub: `We look forward to seeing you on ${checkInLabel}.` },
    completed: { title: firstName ? `See you soon, ${firstName}!` : 'See you soon!', sub: "We'll see you at check-in." },
  },
  fr: {
    default:   { title: firstName ? `Bienvenue, ${firstName}.`  : 'Bienvenue.',     sub: 'Nous sommes ravis de votre venue.' },
    skipped:   { title: firstName ? `À bientôt, ${firstName}.`  : 'À bientôt.',     sub: `Nous attendons votre arrivée le ${checkInLabel}.` },
    completed: { title: firstName ? `À bientôt, ${firstName} !` : 'À bientôt !',    sub: 'Nous vous accueillerons au check-in.' },
  },
  es: {
    default:   { title: firstName ? `Bienvenido, ${firstName}.` : 'Bienvenido.',    sub: 'Nos alegra que vengas. Te esperamos con entusiasmo.' },
    skipped:   { title: firstName ? `Hasta pronto, ${firstName}.` : 'Hasta pronto.', sub: `Esperamos tu visita el ${checkInLabel}.` },
    completed: { title: firstName ? `¡Hasta pronto, ${firstName}!` : '¡Hasta pronto!', sub: 'Te vemos en el check-in.' },
  },
};
const lg = allLabels[lang] ?? allLabels.de;
const L = lg[gateState];

const heroStyle = heroImageUrl
  ? `url('${heroImageUrl.replace(/'/g, "\\'")}')`
  : 'none';
---

{/* Update theme-color so status bar blends into the dark photo */}
<script is:inline>
  (function() {
    var m = document.querySelector('meta[name="theme-color"]');
    if (m) m.setAttribute('content', '#16181c');
  })();
</script>

<div
  class="screen"
  style={`--accent:${brandPrimary};--hero:${heroStyle};`}
>
  <!-- Inner layout: flex-col, fills full viewport height -->
  <div class="inner">

    <!-- Logo -->
    <div class="logo">
      {logoUrl ? (
        <img src={logoUrl} alt={hotelName} />
      ) : (
        <span class="logo-name">{hotelName}</span>
      )}
    </div>

    <!-- Greeting -->
    <div class="ptitle">{L.title}</div>
    <div class="psub">{L.sub}</div>

    <!-- Cards pushed to bottom via margin-top:auto on .cards -->
    <div class="cards">

      {/* ── Default: Voranmeldung dominant ── */}
      {gateState === 'default' && (
        <a class="glasscard primary" href={`/g/${token}/pre-checkin`} data-astro-reload>
          <span class="gi" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2.5"/>
              <circle cx="8.5" cy="11" r="2"/>
              <path d="M13.5 9.5h4.5M13.5 12.5h4.5M6.5 15.5h6"/>
            </svg>
          </span>
          <span class="gtxt">
            <div class="geyebrow">Vor der Anreise</div>
            <div class="gt">Online voranmelden</div>
            <div class="gs">Spart Zeit beim Check-in</div>
          </span>
          <span class="gchev" aria-hidden="true">›</span>
        </a>
      )}

      {/* ── Skipped: Reminder als Primärkarte, column-layout ── */}
      {gateState === 'skipped' && (
        <a class="glasscard primary col" href={`/g/${token}/pre-checkin`} data-astro-reload>
          <div class="geyebrow">Anmeldung noch offen</div>
          <div class="gt">Jetzt online voranmelden</div>
          <div class="gs">2 Minuten — schnellerer Check-in, kein Papierkram an der Rezeption.</div>
        </a>
      )}

      {/* ── Completed: Kompakte Erledigtkarte ── */}
      {gateState === 'completed' && (
        <div class="glasscard done">
          <span class="done-check" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          <span class="gtxt">
            <div class="gt">Anmeldung erledigt</div>
            <div class="gs">Check-in am {checkInLabel}</div>
          </span>
        </div>
      )}

      <!-- Anfahrt & Check-in -->
      <a class="glasscard" href={`/g/${token}/anfahrt`} data-astro-reload>
        <span class="gi" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 21s7-6.5 7-12a7 7 0 1 0-14 0c0 5.5 7 12 7 12Z"/>
            <circle cx="12" cy="9" r="2.3"/>
          </svg>
        </span>
        <span class="gtxt">
          <div class="gt">Anfahrt &amp; Check-in</div>
          <div class="gs">Route &amp; Zeiten</div>
        </span>
        <span class="gchev" aria-hidden="true">›</span>
      </a>

      <!-- Frühstück -->
      <a class="glasscard" href={`/g/${token}/fruehstueck`} data-astro-reload>
        <span class="gi" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 8h12v5a5 5 0 0 1-5 5H9a5 5 0 0 1-5-5V8Z"/>
            <path d="M16 9h2.4a2 2 0 0 1 0 5H16"/>
            <path d="M7.5 3v2M11 3v2"/>
          </svg>
        </span>
        <span class="gtxt">
          <div class="gt">Frühstück</div>
          <div class="gs">Zeiten &amp; Infos</div>
        </span>
        <span class="gchev" aria-hidden="true">›</span>
      </a>

      <!-- Wünsche vorab -->
      <a class="glasscard" href={`/g/${token}/requests`} data-astro-reload>
        <span class="gi" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </span>
        <span class="gtxt">
          <div class="gt">Wünsche vorab</div>
          <div class="gs">Präferenzen mitteilen</div>
        </span>
        <span class="gchev" aria-hidden="true">›</span>
      </a>

      {/* Soft-skip: Liquid-Glass Pill */}
      {gateState === 'default' && (
        <button
          class="glassbtn"
          type="button"
          onclick="fetch('/api/g/gate-skip',{method:'POST',credentials:'same-origin'}).then(()=>location.reload())"
        >
          Später erledigen &rarr;
        </button>
      )}
    </div>
  </div>
</div>

<style>
  /* ── Full-bleed photo screen ── */
  .screen {
    position: fixed;
    inset: 0;
    z-index: 50;
    overflow-y: auto;
    overscroll-behavior: none;
    -webkit-overflow-scrolling: touch;
    background: #16181c;
    color: #fff;
  }

  /* Photo layer */
  .screen::before {
    content: '';
    position: fixed;
    inset: 0;
    background-color: #16181c;
    background-image: var(--hero);
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  /* Gradient overlay — bright middle so the photo shows, dark top+bottom for text */
  .screen::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(8, 10, 14, 0.46) 0%,
      rgba(8, 10, 14, 0.10) 22%,
      rgba(8, 10, 14, 0.00) 42%,
      rgba(8, 10, 14, 0.52) 72%,
      rgba(8, 10, 14, 0.78) 100%
    );
  }

  /* Content container */
  .inner {
    position: relative;
    z-index: 2;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding:
      max(54px, calc(env(safe-area-inset-top, 0px) + 16px))
      22px
      calc(env(safe-area-inset-bottom, 0px) + 28px);
    max-width: 430px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  /* ── Logo ── */
  .logo {
    margin-bottom: 16px;
  }
  .logo img {
    height: 30px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }
  .logo-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Greeting ── */
  .ptitle {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(28px, 7.5vw, 32px);
    letter-spacing: -0.02em;
    line-height: 1.07;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.32);
  }
  .psub {
    font-size: 15.5px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.9);
    margin-top: 10px;
    max-width: 300px;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.3);
  }

  /* ── Card cluster: pushed to bottom ── */
  .cards {
    margin-top: auto;
    padding-top: 26px;
  }

  /* ── Base glass card ── */
  .glasscard {
    display: flex;
    align-items: center;
    gap: 13px;
    background: rgba(26, 28, 34, 0.42);
    -webkit-backdrop-filter: blur(22px) saturate(135%);
    backdrop-filter: blur(22px) saturate(135%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 17px;
    padding: 12px 15px;
    text-decoration: none;
    margin-top: 9px;
    color: #fff;
    cursor: pointer;
    transition: opacity 0.13s ease;
    box-sizing: border-box;
  }
  .glasscard:active { opacity: 0.76; }

  /* Icon container */
  .gi {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.11);
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    color: #fff;
  }

  /* Text block */
  .gtxt { flex: 1; min-width: 0; }

  .geyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 68%, rgba(255, 255, 255, 0.65));
    margin-bottom: 4px;
  }

  .gt {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 16px;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .gs {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.66);
    margin-top: 3px;
    line-height: 1.35;
  }

  .gchev {
    color: rgba(255, 255, 255, 0.52);
    font-size: 23px;
    flex: 0 0 auto;
    line-height: 1;
  }

  /* ── Primary card (Voranmeldung / Reminder) ── */
  .glasscard.primary {
    border-color: color-mix(in srgb, var(--accent) 60%, rgba(255, 255, 255, 0.15));
    background: color-mix(in srgb, var(--accent) 17%, rgba(26, 28, 34, 0.52));
    box-shadow: 0 0 26px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .glasscard.primary .gi {
    background: color-mix(in srgb, var(--accent) 30%, rgba(255, 255, 255, 0.11));
    color: color-mix(in srgb, var(--accent) 30%, #fff);
  }

  /* Column variant for skipped reminder card */
  .glasscard.col {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 14px 15px;
  }

  /* ── Completed card ── */
  .glasscard.done {
    border-color: rgba(52, 199, 89, 0.35);
    background: rgba(52, 199, 89, 0.10);
    cursor: default;
  }
  .done-check {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(52, 199, 89, 0.22);
    border: 1px solid rgba(52, 199, 89, 0.38);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #34c759;
  }

  /* ── Liquid-Glass Pill (Skip button) ── */
  .glassbtn {
    display: block;
    width: fit-content;
    margin: 16px auto 0;
    background: rgba(26, 28, 34, 0.42);
    -webkit-backdrop-filter: blur(20px) saturate(130%);
    backdrop-filter: blur(20px) saturate(130%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 30px;
    padding: 12px 24px;
    color: rgba(255, 255, 255, 0.92);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .glassbtn:hover {
    background: rgba(40, 44, 52, 0.55);
    border-color: rgba(255, 255, 255, 0.26);
  }
</style>
