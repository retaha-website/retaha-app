    margin-bottom: 18px;
  }
  .wc-completed .wc-headline {
    font-size: clamp(28px, 7.5vw, 34px);
    margin-bottom: 12px;
  }
  .wc-completed .wc-sub {
    color: rgba(255,255,255,.55);
  }
  .wc-checkin-badge {
    margin-top: 24px;
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 20px;
    padding: 8px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: .06em;
    color: rgba(255,255,255,.68);
  }

  /* ── Animations ──────────────────────────────────────────────────── */
  @keyframes wc-logo-in   { from { opacity:0; transform:translateY(-10px) } to { opacity:1; transform:none } }
  @keyframes wc-dev-in    { from { opacity:0; transform:translateY(28px) scale(.96) } to { opacity:1; transform:none } }
  @keyframes wc-copy-up   { from { opacity:0; transform:translateY(18px) } to { opacity:1; transform:none } }
  @keyframes wc-cta-fade  { from { opacity:0; } to { opacity:1 } }
  @keyframes wc-float     { 0%,100% { transform:translateY(0) } 50% { transform:translateY(-9px) } }
  @keyframes wc-check-pop { from { opacity:0; transform:scale(.65) } to { opacity:1; transform:scale(1) } }
  @keyframes wc-glow-pulse { 0%,100% { transform:scale(1); opacity:.8 } 50% { transform:scale(1.14); opacity:.46 } }

  @media (prefers-reduced-motion: reduce) {
    .wc-brand   { animation: none; opacity: 1; }
    .wc-device  { animation: none; opacity: 1; transform: none; }
    .wc-copy    { animation: none; opacity: 1; transform: none; }
    .wc-cta     { animation: none; opacity: 1; }
    .wc-check-circle { animation: none; opacity: 1; transform: none; }
    .wc-check-glow   { animation: none; opacity: .5; }
    .wc-if      { transition: none; }
    .wc-stars2, .wc-stars3, .wc-spark, .wc-es, .wc-chevs { animation: none; opacity: .55; }
  }
</style>

{/* Iframe-Scale + Fade-in: responsive scale auf Geräte-Breite */}
<script>
  (function () {
    var scr = document.getElementById('wc-scr');
    var iframeEl = document.getElementById('wc-if');
    if (!scr || !iframeEl) return;

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function setScale() {
      iframeEl.style.transform = 'scale(' + (scr.offsetWidth / 390) + ')';
    }
    setScale();
    window.addEventListener('resize', setScale, { passive: true });

    function showIframe() { iframeEl.style.opacity = '1'; }
    if (reduced) {
      showIframe();
    } else {
      iframeEl.addEventListener('load', showIframe);
      // Fallback: nach 2.5s anzeigen auch wenn load-Event nicht feuert
      setTimeout(showIframe, 2500);
    }
  })();
</script>

{/* Slide + Skip JS — nur für Default-State */}
{!isCompleted && (
  <script>
    (function () {
      var slide = document.getElementById('wc-slide');
      var track = document.getElementById('wc-track');
      var knob  = document.getElementById('wc-knob');
      var fill  = document.getElementById('wc-fill');
      var lbl   = document.getElementById('wc-lbl');
      if (!slide || !track || !knob || !fill || !lbl) return;

      var url        = track.dataset.url || '';
      var completing = track.dataset.completing || '…';
      var dragging   = false, dragged = false;
      var startX = 0, x = 0, max = 0, done = false;
      var KNOB_W = knob.offsetWidth;

      var CHECK_SVG =
        '<svg width="20" height="20" viewBox="0 0 40 40" fill="none" aria-hidden="true">' +
        '<polyline points="10 20 17 27 30 13" stroke="#fff" stroke-width="3"' +
        ' stroke-linecap="square" stroke-linejoin="miter"/></svg>';

      function setMax() { max = slide.clientWidth - KNOB_W - 8; }
      setMax();
      window.addEventListener('resize', setMax, { passive: true });

      function move(px) {
        x = Math.max(0, Math.min(max, px));
        knob.style.transition = 'none';
        knob.style.left = (4 + x) + 'px';
        var p = x / max;
        fill.style.width = (KNOB_W + x) + 'px';
        fill.style.opacity = p > 0.02 ? '1' : '0';
        lbl.style.opacity = String(1 - Math.min(1, p * 1.4));
      }

      function complete() {
        if (done) return;
        done = true;
        x = max;
        knob.style.transition = 'left .4s cubic-bezier(.2,.7,.2,1)';
        knob.style.left = (4 + max) + 'px';
        knob.classList.add('wc-done');
        var arr = knob.querySelector('.wc-arr');
        if (arr) arr.innerHTML = CHECK_SVG;
        lbl.textContent = completing;
        lbl.style.opacity = '1';
        lbl.style.paddingLeft = '0';
        fill.style.width = '100%';
        fill.style.opacity = '1';
        setTimeout(function () { window.location.href = url; }, 500);
      }

      function snapBack() {
        x = 0;
        knob.style.transition = 'left .35s cubic-bezier(.5,0,.2,1)';
        knob.style.left = '4px';
        fill.style.opacity = '0';
        fill.style.width = KNOB_W + 'px';
        lbl.style.opacity = '1';
      }

      function down(e) {
        if (done) return;
        dragging = true; dragged = false;
        startX = (e.touches ? e.touches[0].clientX : e.clientX) - x;
      }
      function mv(e) {
        if (!dragging) return;
        e.preventDefault();
        var cx = e.touches ? e.touches[0].clientX : e.clientX;
        var nx = cx - startX;
        if (nx > 4) dragged = true;
        move(nx);
      }
      function up() {
        if (!dragging) return;
        dragging = false;
        knob.style.transition = 'left .25s cubic-bezier(.2,.7,.2,1)';
        if (x > max * 0.85) { complete(); }
        else { snapBack(); }
      }

      function tapComplete() {
        if (done) return;
        knob.style.transition = 'left .5s cubic-bezier(.2,.7,.2,1)';
        x = max; knob.style.left = (4 + max) + 'px';
        fill.style.width = '100%'; fill.style.opacity = '1';
        lbl.style.opacity = '0';
        setTimeout(complete, 320);
      }

      knob.addEventListener('mousedown', down);
      window.addEventListener('mousemove', mv);
      window.addEventListener('mouseup', up);
      knob.addEventListener('touchstart', down, { passive: false });
      window.addEventListener('touchmove', mv, { passive: false });
      window.addEventListener('touchend', up);

      track.addEventListener('click', function () { if (done || dragged) return; tapComplete(); });
      track.addEventListener('keydown', function (e) {
        if (done) return;
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tapComplete(); }
      });

      var skip = document.getElementById('wc-skip');
      if (skip) {
        skip.addEventListener('click', function () {
          fetch('/api/g/gate-skip', { method: 'POST', credentials: 'same-origin' })
            .then(function () { location.reload(); });
        });
      }
    })();
  </script>
)}
