---
interface Props {
  token: string;
  guestName: string | null;
  hotelName: string;
  heroImageUrl: string | null;
  logoUrl: string | null;
  brandPrimary: string;
  gateState: 'default' | 'skipped' | 'completed';
  checkInLabel: string;
  lang: string;
}

const { token, guestName, hotelName, heroImageUrl, logoUrl, brandPrimary, gateState, checkInLabel, lang } = Astro.props;

const firstName = guestName ?? '';

type LS = { title: string; sub: string };
type LG = { default: LS; skipped: LS; completed: LS };
const allLabels: Record<string, LG> = {
  de: {
    default:   { title: firstName ? `Willkommen, ${firstName}.` : 'Willkommen.',    sub: 'Schön, dass du kommst. Wir freuen uns auf dich.' },
    skipped:   { title: firstName ? `Bis bald, ${firstName}.`   : 'Bis bald.',      sub: 'Wir freuen uns auf deinen Besuch.' },
    completed: { title: firstName ? `Bis bald, ${firstName}!`   : 'Bis bald!',      sub: 'Wir sehen uns beim Check-in.' },
  },
  en: {
    default:   { title: firstName ? `Welcome, ${firstName}.`    : 'Welcome.',       sub: 'Great to have you coming. We look forward to your visit.' },
    skipped:   { title: firstName ? `See you soon, ${firstName}.` : 'See you soon.',sub: 'We look forward to your visit.' },
    completed: { title: firstName ? `See you soon, ${firstName}!` : 'See you soon!',sub: "We'll see you at check-in." },
  },
  fr: {
    default:   { title: firstName ? `Bienvenue, ${firstName}.`  : 'Bienvenue.',     sub: 'Nous sommes ravis de votre venue.' },
    skipped:   { title: firstName ? `À bientôt, ${firstName}.`  : 'À bientôt.',     sub: 'Nous attendons votre visite avec impatience.' },
    completed: { title: firstName ? `À bientôt, ${firstName} !` : 'À bientôt !',    sub: 'Nous vous accueillerons au check-in.' },
  },
  es: {
    default:   { title: firstName ? `Bienvenido, ${firstName}.` : 'Bienvenido.',    sub: 'Nos alegra que vengas. Te esperamos con entusiasmo.' },
    skipped:   { title: firstName ? `Hasta pronto, ${firstName}.` : 'Hasta pronto.',sub: 'Esperamos tu visita con entusiasmo.' },
    completed: { title: firstName ? `¡Hasta pronto, ${firstName}!` : '¡Hasta pronto!', sub: 'Te vemos en el check-in.' },
  },
};
const lg = allLabels[lang] ?? allLabels.de;
const L = lg[gateState];
---

<div
  class="pag-root"
  style={`--pag-accent:${brandPrimary};--pag-hero:${heroImageUrl ? `url('${heroImageUrl.replace(/'/g, "\\'")}')` : 'none'};`}
>
  <div class="pag-bg" aria-hidden="true"></div>

  <div class="pag-inner">
    <!-- Hotel logo -->
    {logoUrl ? (
      <img class="pag-logo" src={logoUrl} alt={hotelName} />
    ) : (
      <div class="pag-logo-text">{hotelName}</div>
    )}

    <!-- Greeting -->
    <div class="pag-title">{L.title}</div>
    <div class="pag-sub">{L.sub}</div>

    <!-- Cards -->
    <div class="pag-cards">

      {/* ── Primary: Voranmeldung (default) ── */}
      {gateState === 'default' && (
        <a class="pag-card pag-card--primary" href={`/g/${token}/pre-checkin`} data-astro-reload>
          <div class="pag-card-eyebrow">Vor der Anreise</div>
          <div class="pag-card-title">Online voranmelden</div>
          <div class="pag-card-hint">Spart Zeit beim Check-in</div>
          <div class="pag-card-cta">Jetzt ausfüllen →</div>
        </a>
      )}

      {/* ── Reminder: noch offen (skipped) ── */}
      {gateState === 'skipped' && (
        <a class="pag-card pag-card--reminder" href={`/g/${token}/pre-checkin`} data-astro-reload>
          <div class="pag-card-eyebrow">Noch offen</div>
          <div class="pag-card-title">Jetzt online voranmelden</div>
          <div class="pag-card-hint">Check-in am {checkInLabel}</div>
          <div class="pag-card-cta">Ausfüllen →</div>
        </a>
      )}

      {/* ── Done: abgeschlossen ── */}
      {gateState === 'completed' && (
        <div class="pag-card pag-card--done">
          <div class="pag-done-row">
            <div class="pag-done-check" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div>
              <div class="pag-done-label">Anmeldung erledigt</div>
              <div class="pag-done-sub">Check-in am {checkInLabel}</div>
            </div>
          </div>
        </div>
      )}

      <!-- Anfahrt & Check-in -->
      <a class="pag-card pag-card--info" href={`/g/${token}/anfahrt`} data-astro-reload>
        <div class="pag-info-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
            <polygon points="3 11 22 2 13 21 11 13 3 11"/>
          </svg>
        </div>
        <div class="pag-info-text">
          <div class="pag-info-label">Anfahrt & Check-in</div>
          <div class="pag-info-sub">Route & Zeiten</div>
        </div>
        <div class="pag-info-arrow" aria-hidden="true">›</div>
      </a>

      <!-- Frühstück -->
      <a class="pag-card pag-card--info" href={`/g/${token}/fruehstueck`} data-astro-reload>
        <div class="pag-info-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
            <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
          </svg>
        </div>
        <div class="pag-info-text">
          <div class="pag-info-label">Frühstück</div>
          <div class="pag-info-sub">Zeiten & Infos</div>
        </div>
        <div class="pag-info-arrow" aria-hidden="true">›</div>
      </a>

      <!-- Wünsche vorab -->
      <a class="pag-card pag-card--info" href={`/g/${token}/requests`} data-astro-reload>
        <div class="pag-info-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
            <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <div class="pag-info-text">
          <div class="pag-info-label">Wünsche vorab</div>
          <div class="pag-info-sub">Präferenzen mitteilen</div>
        </div>
        <div class="pag-info-arrow" aria-hidden="true">›</div>
      </a>

    </div>

    <!-- Soft-skip (only in default state) -->
    {gateState === 'default' && (
      <button
        class="pag-skip"
        type="button"
        onclick="fetch('/api/g/gate-skip',{method:'POST',credentials:'same-origin'}).then(()=>location.reload())"
      >
        Später erledigen →
      </button>
    )}

    <div class="pag-footer">{hotelName}</div>
  </div>
</div>

<style>
  .pag-root {
    position: fixed;
    inset: 0;
    z-index: 50;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  /* Photo background with parallax-safe approach */
  .pag-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-color: #16181c;
    background-image: var(--pag-hero);
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
    transform-origin: center;
  }
  .pag-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(22, 24, 28, 0.25) 0%,
      rgba(22, 24, 28, 0.52) 52%,
      rgba(22, 24, 28, 0.83) 100%
    );
  }

  /* Content container */
  .pag-inner {
    position: relative;
    z-index: 2;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding: calc(env(safe-area-inset-top, 0px) + 52px) 22px calc(env(safe-area-inset-bottom, 0px) + 36px);
    max-width: 430px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  /* Logo */
  .pag-logo {
    display: block;
    width: auto;
    height: 28px;
    object-fit: contain;
    object-position: left center;
    margin-bottom: 44px;
    filter: brightness(0) invert(1);
    opacity: 0.88;
  }
  .pag-logo-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.60);
    margin-bottom: 44px;
  }

  /* Title + Sub */
  .pag-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 7.5vw, 34px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.12;
    margin-bottom: 10px;
  }
  .pag-sub {
    font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
    font-size: 15.5px;
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.5;
    margin-bottom: 30px;
  }

  /* ── Glass cards base ── */
  .pag-cards {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .pag-card {
    display: block;
    border-radius: 18px;
    padding: 18px 20px;
    background: rgba(26, 28, 34, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(22px) saturate(135%);
    -webkit-backdrop-filter: blur(22px) saturate(135%);
    color: #fff;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.14s ease;
    box-sizing: border-box;
  }
  .pag-card:active { opacity: 0.75; }

  /* ── Primary: Voranmeldung mit Akzent-Glow ── */
  .pag-card--primary {
    background: color-mix(in srgb, var(--pag-accent) 14%, rgba(26, 28, 34, 0.52));
    border-color: color-mix(in srgb, var(--pag-accent) 40%, rgba(255, 255, 255, 0.14));
    box-shadow: 0 0 28px color-mix(in srgb, var(--pag-accent) 30%, transparent);
    padding: 22px 22px 20px;
  }
  .pag-card-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--pag-accent) 68%, rgba(255, 255, 255, 0.70));
    margin-bottom: 8px;
  }
  .pag-card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    line-height: 1.25;
    margin-bottom: 4px;
  }
  .pag-card-hint {
    font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.50);
    margin-bottom: 14px;
  }
  .pag-card-cta {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ── Reminder: skipped state ── */
  .pag-card--reminder {
    padding: 22px 22px 20px;
    border-color: rgba(255, 255, 255, 0.20);
  }
  .pag-card--reminder .pag-card-eyebrow {
    color: rgba(255, 200, 120, 0.85);
  }

  /* ── Done: completed state ── */
  .pag-card--done {
    border-color: rgba(52, 199, 89, 0.32);
    background: rgba(52, 199, 89, 0.10);
    cursor: default;
  }
  .pag-done-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .pag-done-check {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(52, 199, 89, 0.22);
    border: 1px solid rgba(52, 199, 89, 0.38);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #34c759;
  }
  .pag-done-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }
  .pag-done-sub {
    font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.50);
    margin-top: 2px;
  }

  /* ── Info cards: Anfahrt / Frühstück / Wünsche ── */
  .pag-card--info {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
  }
  .pag-info-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.78);
  }
  .pag-info-text { flex: 1; min-width: 0; }
  .pag-info-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }
  .pag-info-sub {
    font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.50);
    margin-top: 2px;
  }
  .pag-info-arrow {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
    line-height: 1;
  }

  /* Skip link */
  .pag-skip {
    background: none;
    border: none;
    padding: 0;
    margin-top: 22px;
    font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.48);
    cursor: pointer;
    text-align: center;
    width: 100%;
    letter-spacing: 0.01em;
    transition: color 0.15s;
  }
  .pag-skip:hover { color: rgba(255, 255, 255, 0.70); }

  /* Footer hotel name */
  .pag-footer {
    margin-top: 36px;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.22);
  }
</style>
