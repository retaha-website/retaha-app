---
// Pre-Arrival Welcome — "Check-in vorbereiten"
// Design: welcome-checkin.html (1:1 rebuild), ersetzt altes Gate-Landing.
// gateState 'skipped' wird auf [token].astro-Ebene abgefangen (App rendern).
interface Props {
  token: string;
  guestName: string | null;
  hotelName: string;
  heroImageUrl: string | null;
  logoUrl: string | null;
  brandPrimary: string;
  gateState: 'default' | 'completed';
  checkInLabel: string;
  lang: string;
  previewUrl: string | null;
  eyebrowTagline: string | null;
}

const {
  token, guestName, hotelName, heroImageUrl, logoUrl,
  brandPrimary, gateState, checkInLabel, lang, previewUrl, eyebrowTagline,
} = Astro.props;

const fn = guestName ?? '';

function hexToRgb(hex: string) {
  const h = (hex || '#6982cf').replace('#', '');
  const r = parseInt(h.slice(0, 2), 16) || 105;
  const g = parseInt(h.slice(2, 4), 16) || 130;
  const b = parseInt(h.slice(4, 6), 16) || 207;
  return `${r},${g},${b}`;
}
const accentRgb = hexToRgb(brandPrimary);

type Lang = 'de'|'en'|'fr'|'es'|'it'|'pt'|'nl'|'ru'|'ar'|'zh';
const l = (['de','en','fr','es','it','pt','nl','ru','ar','zh'].includes(lang) ? lang : 'de') as Lang;

type Txt = {
  headline: string; sub: string;
  slider: string; skip: string; completing: string;
  tagline: string;
  eyebrow: string; mockGreet: string;
  eveMsg: string; chip1: string; chip2: string; eveInput: string;
  headlineDone: string; subDone: string;
};

const LABELS: Record<Lang, Txt> = {
  de: {
    headline:     fn ? `Willkommen, ${fn}.` : 'Willkommen.',
    sub:          'Bereite deinen Check-in vor – dann geht\'s bei der Ankunft ganz schnell.',
    slider:       'Check-in vorbereiten',
    skip:         'Später erledigen',
    completing:   'Check-in wird geöffnet …',
    tagline:      'Für eine sternenvolle Nacht',
    eyebrow:      'Dein Aufenthalt',
    mockGreet:    fn ? `Hallo, ${fn}` : 'Hallo',
    eveMsg:       'Ich hab Tipps & Empfehlungen für deinen Aufenthalt zusammengestellt.',
    chip1:        '☕ Frühstück',
    chip2:        '📍 Anfahrt',
    eveInput:     'Frag mich alles …',
    headlineDone: fn ? `Bis bald, ${fn}!` : 'Bis bald!',
    subDone:      'Deine Anmeldung ist erledigt. Beim Check-in geht\'s direkt los.',
  },
  en: {
    headline:     fn ? `Welcome, ${fn}.` : 'Welcome.',
    sub:          'Prepare your check-in now – for a smooth and quick arrival.',
    slider:       'Prepare Check-in',
    skip:         'Maybe later',
    completing:   'Opening check-in …',
    tagline:      'For a stellar night',
    eyebrow:      'Your Stay',
    mockGreet:    fn ? `Hello, ${fn}` : 'Hello',
    eveMsg:       'I\'ve put together tips and recommendations for your stay.',
    chip1:        '☕ Breakfast',
    chip2:        '📍 Directions',
    eveInput:     'Ask me anything …',
    headlineDone: fn ? `See you soon, ${fn}!` : 'See you soon!',
    subDone:      'All set. Check-in will be quick and easy.',
  },
  fr: {
    headline:     fn ? `Bienvenue, ${fn}.` : 'Bienvenue.',
    sub:          'Préparez votre enregistrement – pour une arrivée rapide et sans attente.',
    slider:       'Préparer le check-in',
    skip:         'Plus tard',
    completing:   'Ouverture du check-in …',
    tagline:      'Pour une nuit étoilée',
    eyebrow:      'Votre séjour',
    mockGreet:    fn ? `Bonjour, ${fn}` : 'Bonjour',
    eveMsg:       'J\'ai préparé des conseils et recommandations pour votre séjour.',
    chip1:        '☕ Petit-déj.',
    chip2:        '📍 Itinéraire',
    eveInput:     'Posez-moi une question …',
    headlineDone: fn ? `À bientôt, ${fn} !` : 'À bientôt !',
    subDone:      'Votre enregistrement est terminé. L\'arrivée sera rapide.',
  },
  es: {
    headline:     fn ? `Bienvenido, ${fn}.` : 'Bienvenido.',
    sub:          'Prepara tu check-in – para una llegada rápida y sin esperas.',
    slider:       'Preparar el check-in',
    skip:         'Más tarde',
    completing:   'Abriendo check-in …',
    tagline:      'Para una noche estelar',
    eyebrow:      'Tu estancia',
    mockGreet:    fn ? `Hola, ${fn}` : 'Hola',
    eveMsg:       'He preparado consejos y recomendaciones para tu estancia.',
    chip1:        '☕ Desayuno',
    chip2:        '📍 Cómo llegar',
    eveInput:     'Pregúntame …',
    headlineDone: fn ? `¡Hasta pronto, ${fn}!` : '¡Hasta pronto!',
    subDone:      'Tu registro está listo. El check-in será rápido.',
  },
  it: {
    headline:     fn ? `Benvenuto, ${fn}.` : 'Benvenuto.',
    sub:          'Prepara il tuo check-in – per un arrivo rapido e senza attese.',
    slider:       'Prepara il check-in',
    skip:         'Più tardi',
    completing:   'Apertura del check-in …',
    tagline:      'Per una notte stellare',
    eyebrow:      'Il tuo soggiorno',
    mockGreet:    fn ? `Ciao, ${fn}` : 'Ciao',
    eveMsg:       'Ho preparato consigli e suggerimenti per il tuo soggiorno.',
    chip1:        '☕ Colazione',
    chip2:        '📍 Come arrivare',
    eveInput:     'Chiedimi tutto …',
    headlineDone: fn ? `A presto, ${fn}!` : 'A presto!',
    subDone:      'La tua registrazione è completata. Il check-in sarà veloce.',
  },
  pt: {
    headline:     fn ? `Bem-vindo, ${fn}.` : 'Bem-vindo.',
    sub:          'Prepare o seu check-in – para uma chegada rápida e sem esperas.',
    slider:       'Preparar check-in',
    skip:         'Mais tarde',
    completing:   'A abrir o check-in …',
    tagline:      'Para uma noite estrelada',
    eyebrow:      'A sua estadia',
    mockGreet:    fn ? `Olá, ${fn}` : 'Olá',
    eveMsg:       'Preparei dicas e recomendações para a sua estadia.',
    chip1:        '☕ Pequeno-almoço',
    chip2:        '📍 Como chegar',
    eveInput:     'Pergunte-me …',
    headlineDone: fn ? `Até breve, ${fn}!` : 'Até breve!',
    subDone:      'O seu registo está concluído. O check-in será rápido.',
  },
  nl: {
    headline:     fn ? `Welkom, ${fn}.` : 'Welkom.',
    sub:          'Bereid je check-in voor – voor een vlotte aankomst zonder wachten.',
    slider:       'Check-in voorbereiden',
    skip:         'Later',
    completing:   'Check-in wordt geopend …',
    tagline:      'Voor een sterrenrijke nacht',
    eyebrow:      'Jouw verblijf',
    mockGreet:    fn ? `Hallo, ${fn}` : 'Hallo',
    eveMsg:       'Ik heb tips en aanbevelingen voor jouw verblijf samengesteld.',
    chip1:        '☕ Ontbijt',
    chip2:        '📍 Route',
    eveInput:     'Stel me een vraag …',
    headlineDone: fn ? `Tot snel, ${fn}!` : 'Tot snel!',
    subDone:      'Je aanmelding is klaar. De check-in gaat snel.',
  },
  ru: {
    headline:     fn ? `Добро пожаловать, ${fn}.` : 'Добро пожаловать.',
    sub:          'Подготовьтесь к заезду – чтобы прибытие прошло быстро.',
    slider:       'Подготовить заезд',
    skip:         'Позже',
    completing:   'Открываем заезд …',
    tagline:      'Для звёздной ночи',
    eyebrow:      'Ваше пребывание',
    mockGreet:    fn ? `Привет, ${fn}` : 'Привет',
    eveMsg:       'Я подготовила советы и рекомендации для вашего пребывания.',
    chip1:        '☕ Завтрак',
    chip2:        '📍 Маршрут',
    eveInput:     'Спросите меня …',
    headlineDone: fn ? `До встречи, ${fn}!` : 'До встречи!',
    subDone:      'Ваша регистрация завершена. Заезд пройдёт быстро.',
  },
  ar: {
    headline:     fn ? `مرحباً، ${fn}.` : 'مرحباً.',
    sub:          'جهّز تسجيل وصولك – للوصول بسرعة دون انتظار.',
    slider:       'التحضير للوصول',
    skip:         'لاحقاً',
    completing:   'جارٍ فتح تسجيل الوصول …',
    tagline:      'لليلة مضيئة بالنجوم',
    eyebrow:      'إقامتك',
    mockGreet:    fn ? `مرحباً، ${fn}` : 'مرحباً',
    eveMsg:       'لقد أعددت نصائح وتوصيات لإقامتك.',
    chip1:        '☕ الإفطار',
    chip2:        '📍 الاتجاهات',
    eveInput:     'اسألني …',
    headlineDone: fn ? `إلى اللقاء، ${fn}!` : 'إلى اللقاء!',
    subDone:      'تم التسجيل. سيكون الوصول سريعاً.',
  },
  zh: {
    headline:     fn ? `欢迎，${fn}。` : '欢迎。',
    sub:          '提前完成入住登记 – 到达时无需排队，快速入住。',
    slider:       '准备入住登记',
    skip:         '稍后',
    completing:   '正在打开入住登记 …',
    tagline:      '为一个繁星之夜',
    eyebrow:      '您的住宿',
    mockGreet:    fn ? `你好，${fn}` : '你好',
    eveMsg:       '我为您的住宿准备了提示和建议。',
    chip1:        '☕ 早餐',
    chip2:        '📍 路线',
    eveInput:     '有什么问题请问我 …',
    headlineDone: fn ? `再见，${fn}！` : '再见！',
    subDone:      '登记完成。入住将会很顺畅。',
  },
};

const txt = LABELS[l];
const isCompleted = gateState === 'completed';
const heroSafe = (heroImageUrl ?? '').replace(/'/g, "\\'");
const preCheckinUrl = `/g/${token}/pre-checkin`;
---

<div
  class={`wc-screen${isCompleted ? ' wc-completed' : ''}`}
  style={`--accent:${brandPrimary};--accent-rgb:${accentRgb};`}
>

  {/* ── Star field ── */}
  <div class="wc-bgfx" aria-hidden="true">
    <div class="wc-stars"></div>
    <div class="wc-stars2"></div>
    <div class="wc-stars3"></div>
    <div class="wc-spark" style="top:72px;left:48px;font-size:11px;animation-delay:.6s">✦</div>
    <div class="wc-spark" style="top:138px;right:52px;font-size:8px;animation-delay:1.2s">✦</div>
    <div class="wc-spark" style="top:218px;left:34px;font-size:7px;animation-delay:2s">✦</div>
    <div class="wc-spark" style="top:88px;right:78px;font-size:9px;animation-delay:.3s">✦</div>
  </div>

  {/* ── Logo ── */}
  <div class="wc-brand">
    {logoUrl ? (
      <img src={logoUrl} alt={hotelName} class="wc-logo" />
    ) : (
      <span class="wc-logo-text">{hotelName}</span>
    )}
  </div>

  {isCompleted ? (
    // ── Bis-bald-State ─────────────────────────────────────────────
    <div class="wc-done-body">
      <div class="wc-check-wrap">
        <div class="wc-check-glow"></div>
        <div class="wc-check-circle">
          {/* Eckiger Haus-Haken (nicht Unicode-✓) */}
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <polyline
              points="10 20 17 27 30 13"
              stroke="#fff"
              stroke-width="3"
              stroke-linecap="square"
              stroke-linejoin="miter"
            />
          </svg>
        </div>
      </div>
      <p class="wc-hotel-tag">{hotelName}</p>
      <h1 class="wc-headline">{txt.headlineDone}</h1>
      <p class="wc-sub">{txt.subDone}</p>
      <div class="wc-checkin-badge">Check-in · {checkInLabel}</div>
    </div>
  ) : (
    // ── Welcome-State ──────────────────────────────────────────────
    <>
      {/* Stage: Glows + Device */}
      <div class="wc-stage">
        <div class="wc-glow wc-glow-a"></div>
        <div class="wc-glow wc-glow-b"></div>

        <div class="wc-device">
          <div class="wc-scr" id="wc-scr">
            {/* Dynamic Island always on top */}
            <div class="wc-island"></div>

            {previewUrl ? (
              <div class="wc-if-wrap" aria-hidden="true">
                <iframe
                  id="wc-if"
                  src={previewUrl}
                  class="wc-if"
                  title=""
                  tabindex="-1"
                  loading="lazy"
                ></iframe>
              </div>
            ) : (
              <div class="wc-static">
                <div
                  class="wc-ph"
                  style={heroSafe ? `--hero:url('${heroSafe}')` : undefined}
                >
                  <div class="wc-ph-over"></div>
                  <div class="wc-ph-hi">
                    <span class="wc-ph-eyebrow">{txt.eyebrow}</span>
                    <span class="wc-ph-name">{txt.mockGreet}</span>
                  </div>
                </div>
                <div class="wc-in">
                  <div class="wc-eve-row">
                    <div class="wc-ev-av">E</div>
                    <div class="wc-ev-bubble">{txt.eveMsg}</div>
                  </div>
                  <div class="wc-chips">
                    <span class="wc-chip">{txt.chip1}</span>
                    <span class="wc-chip">{txt.chip2}</span>
                  </div>
                  <div class="wc-input-bar">
                    <span class="wc-input-txt">{txt.eveInput}</span>
                    <span class="wc-input-send" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Copy */}
      <div class="wc-copy">
        <div class="wc-eyebrow">
          <span class="wc-es" aria-hidden="true">✦</span>
          {eyebrowTagline ?? txt.tagline}
        </div>
        <h1 class="wc-headline">{txt.headline}</h1>
        <p class="wc-sub">{txt.sub}</p>
      </div>

      {/* CTA: Slider + Skip */}
      <div class="wc-cta">
        <div class="wc-slide" id="wc-slide">
          <div
            id="wc-track"
            class="wc-track"
            role="button"
            tabindex="0"
            aria-label={txt.slider}
            data-url={preCheckinUrl}
            data-completing={txt.completing}
          >
            <div id="wc-fill" class="wc-fill"></div>
            <span id="wc-lbl" class="wc-lbl">{txt.slider}</span>
            <span class="wc-chevs" aria-hidden="true">›&#8203;›&#8203;›</span>
          </div>
          <div id="wc-knob" class="wc-knob">
            <span class="wc-arr" aria-hidden="true">→</span>
          </div>
        </div>
        <button id="wc-skip" class="wc-skip" type="button">
          {txt.skip}
        </button>
      </div>
    </>
  )}
</div>

<style>
  /* ── Root screen ─────────────────────────────────────────────────── */
  .wc-screen {
    background: #0a0b0d;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  /* ── Star field ─────────────────────────────────────────────────── */
  .wc-bgfx {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .wc-stars, .wc-stars2, .wc-stars3 {
    position: absolute;
    top: 0; left: 0;
    width: 1px; height: 1px;
    border-radius: 50%;
    background: transparent;
  }
  .wc-stars {
    box-shadow:
      43px 58px 0 rgba(255,255,255,.58), 182px 23px 0 rgba(255,255,255,.46),
      321px 41px 0 rgba(255,255,255,.52), 76px 112px 0 rgba(255,255,255,.42),
      259px 87px 0 rgba(255,255,255,.50), 134px 167px 0 rgba(255,255,255,.44),
      378px 134px 0 rgba(255,255,255,.48), 19px 234px 0 rgba(255,255,255,.40),
      203px 198px 0 rgba(255,255,255,.54), 342px 256px 0 rgba(255,255,255,.46),
      89px 312px 0 rgba(255,255,255,.40), 167px 378px 0 rgba(255,255,255,.44),
      278px 334px 0 rgba(255,255,255,.48), 57px 456px 0 rgba(255,255,255,.38),
      231px 423px 0 rgba(255,255,255,.44), 356px 478px 0 rgba(255,255,255,.50),
      112px 534px 0 rgba(255,255,255,.40), 287px 512px 0 rgba(255,255,255,.44),
      145px 612px 0 rgba(255,255,255,.36), 378px 589px 0 rgba(255,255,255,.42),
      34px 667px 0 rgba(255,255,255,.38), 201px 645px 0 rgba(255,255,255,.44),
      312px 712px 0 rgba(255,255,255,.40), 78px 723px 0 rgba(255,255,255,.36),
      256px 756px 0 rgba(255,255,255,.42), 389px 634px 0 rgba(255,255,255,.38),
      156px 801px 0 rgba(255,255,255,.34), 45px 178px 0 rgba(255,255,255,.48),
      278px 145px 0 rgba(255,255,255,.46), 123px 289px 0 rgba(255,255,255,.42),
      334px 367px 0 rgba(255,255,255,.44), 189px 489px 0 rgba(255,255,255,.40),
      67px 556px 0 rgba(255,255,255,.38), 345px 567px 0 rgba(255,255,255,.42),
      23px 601px 0 rgba(255,255,255,.36), 267px 689px 0 rgba(255,255,255,.40),
      123px 734px 0 rgba(255,255,255,.38), 298px 289px 0 rgba(255,255,255,.44);
  }
  .wc-stars2 {
    box-shadow:
      156px 45px 0 rgba(255,255,255,.80), 312px 112px 0 rgba(255,255,255,.76),
      56px 189px 0 rgba(255,255,255,.72), 234px 267px 0 rgba(255,255,255,.78),
      345px 312px 0 rgba(255,255,255,.74), 89px 423px 0 rgba(255,255,255,.80),
      178px 534px 0 rgba(255,255,255,.76), 267px 601px 0 rgba(255,255,255,.72),
      123px 667px 0 rgba(255,255,255,.78), 345px 689px 0 rgba(255,255,255,.74),
      56px 756px 0 rgba(255,255,255,.80), 234px 801px 0 rgba(255,255,255,.76),
      312px 756px 0 rgba(255,255,255,.72), 178px 145px 0 rgba(255,255,255,.78);
    animation: wc-tw 5s ease-in-out infinite;
  }
  .wc-stars3 {
    width: 2px; height: 2px;
    box-shadow:
      78px 78px 1px rgba(255,255,255,.90), 298px 198px 1px rgba(255,255,255,.88),
      167px 389px 1px rgba(255,255,255,.92), 312px 534px 1px rgba(255,255,255,.86),
      89px 623px 1px rgba(255,255,255,.90), 234px 712px 1px rgba(255,255,255,.88);
    animation: wc-tw 7.5s ease-in-out infinite 1.8s;
  }
  .wc-spark {
    position: absolute;
    color: rgba(170,183,234,.70);
    pointer-events: none;
    animation: wc-tw 3.5s ease-in-out infinite;
    line-height: 1;
  }
  @keyframes wc-tw {
    0%,100% { opacity: .30; }
    50%      { opacity: .95; }
  }

  /* ── Logo / Brand ────────────────────────────────────────────────── */
  .wc-brand {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: max(env(safe-area-inset-top, 0px), 20px) 24px 12px;
    animation: wc-logo-in .7s .15s ease-out both;
  }
  .wc-logo {
    height: 28px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.88;
  }
  .wc-logo-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,.6);
  }

  /* ── Stage ───────────────────────────────────────────────────────── */
  .wc-stage {
    flex: 1;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    padding: 8px 0 12px;
  }

  /* Radial glows */
  .wc-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .wc-glow-a {
    width: 340px;
    height: 340px;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -48%);
    background: radial-gradient(
      circle,
      rgba(var(--accent-rgb), .32) 0%,
      rgba(var(--accent-rgb), .14) 36%,
      rgba(var(--accent-rgb), .04) 62%,
      transparent 76%
    );
  }
  .wc-glow-b {
    width: 200px;
    height: 180px;
    left: 62%;
    top: 32%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle,
      rgba(var(--accent-rgb), .18) 0%,
      transparent 70%
    );
  }

  /* ── Device mockup ───────────────────────────────────────────────── */
  .wc-device {
    position: relative;
    z-index: 2;
    width: min(198px, 52vw);
    aspect-ratio: 9 / 17;
    border-radius: min(36px, 9.4vw);
    background: #0f1014;
    border: 1.5px solid rgba(255,255,255,.18);
    box-shadow:
      0 0 0 3px rgba(0,0,0,.5),
      0 0 40px rgba(0,0,0,.55),
      inset 0 1px 0 rgba(255,255,255,.10);
    overflow: hidden;
    animation: wc-dev-in .95s .32s cubic-bezier(.2,0,.2,1.1) both, wc-float 6s 1.5s ease-in-out infinite;
  }

  .wc-scr {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
    background: #0f1014;
  }

  /* Live-iframe (PhoneFrame-Muster) */
  .wc-if-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
  }
  .wc-if {
    position: absolute;
    top: 0;
    left: 0;
    width: 390px;
    height: 844px;
    border: none;
    pointer-events: none;
    transform-origin: top left;
    transform: scale(0.508);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Statischer Fallback-Teaser */
  .wc-static {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Dynamic Island */
  .wc-island {
    position: absolute;
    top: 6%;
    left: 50%;
