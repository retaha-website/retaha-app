  /* Slide wrapper */
  .wc-slide {
    position: relative;
    width: 100%;
    height: 62px;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* Glass track */
  .wc-track {
    position: absolute;
    inset: 0;
    border-radius: 31px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.04));
    -webkit-backdrop-filter: blur(20px) saturate(170%);
    backdrop-filter: blur(20px) saturate(170%);
    border: 1px solid rgba(255,255,255,.16);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.28), inset 0 -8px 16px rgba(0,0,0,.22);
    cursor: pointer;
    touch-action: none;
  }

  /* Accent fill (grows as knob slides) */
  .wc-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 54px;
    background: linear-gradient(90deg, rgba(var(--accent-rgb),.0), rgba(var(--accent-rgb),.30));
    opacity: 0;
