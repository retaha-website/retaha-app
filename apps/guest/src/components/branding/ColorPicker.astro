---
/**
 * Custom in-page color picker.
 * Renders a styled swatch button that opens a spectrum+hue popover.
 * On change, updates the input element identified by `targetId` and
 * dispatches an `input` event so existing sync logic continues to work.
 */
interface Props {
  targetId: string;   // ID of the <input type="text"> to keep in sync
  value?: string;     // Initial hex value e.g. "#FF4A82"
  ariaLabel?: string;
}
const { targetId, value = '#FF4A82', ariaLabel = 'Farbwähler' } = Astro.props;
---

<div class="cp" data-cp data-target={targetId}>
  <button type="button" class="cp__trigger" aria-label={ariaLabel} aria-expanded="false">
    <span class="cp__swatch" style={`background:${value}`}></span>
  </button>

  <div class="cp__pop" hidden>
    <!-- Spectrum (saturation × brightness) -->
    <div class="cp__spec-bg">
      <div class="cp__spec">
        <span class="cp__spec-handle"></span>
      </div>
    </div>

    <!-- Hue slider -->
    <div class="cp__hue">
      <span class="cp__hue-thumb"></span>
    </div>

    <!-- Hex input + OK -->
    <div class="cp__foot">
      <div class="cp__hex-wrap">
        <span class="cp__hash">#</span>
        <input type="text" class="cp__hex" maxlength="6" spellcheck="false" autocomplete="off" />
      </div>
      <button type="button" class="cp__ok">OK</button>
    </div>
  </div>
</div>

<style>
  .cp { position: relative; display: inline-block; }

  /* Trigger swatch button */
  .cp__trigger {
    width: 40px; height: 40px;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    cursor: pointer; flex-shrink: 0;
    padding: 3px; background: var(--surface);
    transition: border-color 150ms;
  }
  .cp__trigger:hover, .cp__trigger[aria-expanded="true"] { border-color: var(--ink); }
  .cp__swatch {
    display: block; width: 100%; height: 100%;
    border-radius: calc(var(--r-sm) - 2px);
  }

  /* Popover */
  .cp__pop {
    position: absolute;
    top: calc(100% + 8px); right: 0;
    z-index: 300;
    background: var(--surface);
    border: 1px solid var(--border-medium);
    border-radius: var(--r);
    box-shadow: 0 12px 40px rgba(0,0,0,.14), 0 2px 8px rgba(0,0,0,.07);
    padding: 14px;
    width: 224px;
  }
  .cp__pop[hidden] { display: none !important; }

  /* Spectrum */
  .cp__spec-bg {
    border-radius: var(--r-sm);
    overflow: hidden;
    margin-bottom: 10px;
  }
  .cp__spec {
    width: 100%; height: 136px;
    background:
      linear-gradient(to bottom, transparent, #000),
      linear-gradient(to right, #fff, transparent);
    position: relative; cursor: crosshair;
    user-select: none; -webkit-user-select: none;
  }
  .cp__spec-handle {
    position: absolute;
    width: 14px; height: 14px; border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px rgba(0,0,0,.35);
    transform: translate(-50%, -50%);
    pointer-events: none;
    top: 0; left: 0;
  }

  /* Hue slider */
  .cp__hue {
    height: 12px; border-radius: 99px;
    background: linear-gradient(to right,
      #f00, #ff0, #0f0, #0ff, #00f, #f0f, #f00);
    position: relative; cursor: pointer; margin-bottom: 14px;
    user-select: none; -webkit-user-select: none;
  }
  .cp__hue-thumb {
    position: absolute;
    width: 18px; height: 18px; border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 1px rgba(0,0,0,.25), 0 1px 4px rgba(0,0,0,.18);
    transform: translate(-50%, -3px);
    pointer-events: none; top: 0; left: 0;
  }

  /* Footer */
  .cp__foot { display: flex; gap: 8px; align-items: center; }
  .cp__hex-wrap {
    display: flex; align-items: center; flex: 1;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); padding: 7px 10px;
    transition: border-color 150ms;
  }
  .cp__hex-wrap:focus-within { border-color: var(--ink); }
  .cp__hash {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--ink-muted); margin-right: 2px;
  }
  .cp__hex {
    background: none; border: none; outline: none;
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    color: var(--ink); width: 62px; text-transform: uppercase;
  }
  .cp__ok {
    background: var(--ink); color: var(--bg); border: none;
    border-radius: var(--r-sm); padding: 8px 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em;
    cursor: pointer; transition: all 150ms; white-space: nowrap;
  }
  .cp__ok:hover { background: var(--te-yellow); color: #0A0A0A; }
</style>

<script>
  function hexToHsv(hex: string): { h: number; s: number; v: number } {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b), d = max - min;
    let h = 0;
    const s = max === 0 ? 0 : d / max;
    const v = max;
    if (d !== 0) {
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
      else if (max === g) h = ((b - r) / d + 2) / 6;
      else h = ((r - g) / d + 4) / 6;
    }
    return { h: h * 360, s, v };
  }

  function hsvToHex(h: number, s: number, v: number): string {
    const c = v * s, x = c * (1 - Math.abs(((h / 60) % 2) - 1)), m = v - c;
    let r = 0, g = 0, b = 0;
    if (h < 60)       { r = c; g = x; b = 0; }
    else if (h < 120) { r = x; g = c; b = 0; }
    else if (h < 180) { r = 0; g = c; b = x; }
    else if (h < 240) { r = 0; g = x; b = c; }
    else if (h < 300) { r = x; g = 0; b = c; }
    else              { r = c; g = 0; b = x; }
    const toHex = (n: number) => Math.round((n + m) * 255).toString(16).padStart(2, '0');
    return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
  }

  document.querySelectorAll<HTMLElement>('[data-cp]').forEach(cp => {
    const trigger    = cp.querySelector<HTMLButtonElement>('.cp__trigger')!;
    const swatch     = cp.querySelector<HTMLElement>('.cp__swatch')!;
    const pop        = cp.querySelector<HTMLElement>('.cp__pop')!;
    const specBg     = cp.querySelector<HTMLElement>('.cp__spec-bg')!;
    const spec       = cp.querySelector<HTMLElement>('.cp__spec')!;
    const specHandle = cp.querySelector<HTMLElement>('.cp__spec-handle')!;
    const hueEl      = cp.querySelector<HTMLElement>('.cp__hue')!;
    const hueThumb   = cp.querySelector<HTMLElement>('.cp__hue-thumb')!;
    const hexInput   = cp.querySelector<HTMLInputElement>('.cp__hex')!;
    const okBtn      = cp.querySelector<HTMLButtonElement>('.cp__ok')!;

    const targetId = cp.dataset.target!;
    const targetInput = document.getElementById(targetId) as HTMLInputElement | null;

    // Read initial value from target input
    const initHex = targetInput?.value || '#FF4A82';
    let hsv = hexToHsv(/^#[0-9a-fA-F]{6}$/.test(initHex) ? initHex : '#FF4A82');

    function renderUI() {
      specBg.style.background = `hsl(${hsv.h}, 100%, 50%)`;
      specHandle.style.left = `${hsv.s * 100}%`;
      specHandle.style.top = `${(1 - hsv.v) * 100}%`;
      hueThumb.style.left = `${(hsv.h / 360) * 100}%`;
      const hex = hsvToHex(hsv.h, hsv.s, hsv.v);
      hexInput.value = hex.slice(1).toUpperCase();
      swatch.style.background = hex;
    }

    function applyColor() {
      const hex = hsvToHex(hsv.h, hsv.s, hsv.v);
      swatch.style.background = hex;
      if (targetInput) {
        targetInput.value = hex;
        targetInput.dispatchEvent(new Event('input', { bubbles: true }));
      }
    }

    // Open / close
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const opening = pop.hidden;
      pop.hidden = !opening;
      trigger.setAttribute('aria-expanded', String(opening));
      if (opening) {
        // Re-sync from target on open
        const cur = targetInput?.value || '#FF4A82';
        if (/^#[0-9a-fA-F]{6}$/.test(cur)) hsv = hexToHsv(cur);
        renderUI();
      }
    });

    document.addEventListener('click', (e) => {
      if (!cp.contains(e.target as Node)) {
        pop.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Spectrum drag
    function applySpecPos(clientX: number, clientY: number) {
      const r = spec.getBoundingClientRect();
      hsv.s = Math.max(0, Math.min(1, (clientX - r.left) / r.width));
      hsv.v = 1 - Math.max(0, Math.min(1, (clientY - r.top) / r.height));
      renderUI();
    }
    let dragSpec = false;
    spec.addEventListener('mousedown', (e) => { dragSpec = true; applySpecPos(e.clientX, e.clientY); e.preventDefault(); });
    document.addEventListener('mousemove', (e) => { if (dragSpec) applySpecPos(e.clientX, e.clientY); });
    document.addEventListener('mouseup', () => { dragSpec = false; });
    spec.addEventListener('touchstart', (e) => { applySpecPos(e.touches[0].clientX, e.touches[0].clientY); e.preventDefault(); }, { passive: false });
    spec.addEventListener('touchmove', (e) => { applySpecPos(e.touches[0].clientX, e.touches[0].clientY); e.preventDefault(); }, { passive: false });

    // Hue drag
    function applyHuePos(clientX: number) {
      const r = hueEl.getBoundingClientRect();
      hsv.h = Math.max(0, Math.min(360, ((clientX - r.left) / r.width) * 360));
      renderUI();
    }
    let dragHue = false;
    hueEl.addEventListener('mousedown', (e) => { dragHue = true; applyHuePos(e.clientX); e.preventDefault(); });
    document.addEventListener('mousemove', (e) => { if (dragHue) applyHuePos(e.clientX); });
    document.addEventListener('mouseup', () => { dragHue = false; });
    hueEl.addEventListener('touchstart', (e) => { applyHuePos(e.touches[0].clientX); e.preventDefault(); }, { passive: false });
    hueEl.addEventListener('touchmove', (e) => { applyHuePos(e.touches[0].clientX); e.preventDefault(); }, { passive: false });

    // Hex input in popover
    hexInput.addEventListener('input', () => {
      const clean = hexInput.value.replace(/[^0-9a-fA-F]/g, '');
      if (clean.length === 6) { hsv = hexToHsv('#' + clean); renderUI(); }
    });
    hexInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { applyColor(); pop.hidden = true; } });

    // OK
    okBtn.addEventListener('click', () => { applyColor(); pop.hidden = true; trigger.setAttribute('aria-expanded', 'false'); });

    renderUI();
  });
</script>
