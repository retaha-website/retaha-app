---
import Sheet from '../Sheet.astro';

interface ConferenceRoom {
  id: string;
  name_de: string;
  name_en?: string;
  name_fr?: string;
  name_es?: string;
  capacity: number;
  description_de?: string;
  description_en?: string;
  description_fr?: string;
  description_es?: string;
}

interface Props {
  lang: 'de' | 'en' | 'fr' | 'es';
  rooms: ConferenceRoom[];
  startTime: string;
  endTime: string;
  slotMinutes: number;
  accessToken: string;
  existingBooking: any | null;
  conciergeName: string;
  checkIn: string;
  checkOut: string;
}

const { lang, rooms, startTime, endTime, slotMinutes, accessToken, existingBooking, conciergeName, checkIn, checkOut } = Astro.props;

// Build slots for time selection
const [startH, startM] = startTime.substring(0, 5).split(':').map(Number);
const [endH, endM] = endTime.substring(0, 5).split(':').map(Number);
const startMin = startH * 60 + startM;
const endMin = endH * 60 + endM;

const allSlots: { value: string; label: string }[] = [];
for (let m = startMin; m < endMin; m += slotMinutes) {
  const h = Math.floor(m / 60);
  const mm = m % 60;
  const time = `${String(h).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
  allSlots.push({ value: time, label: time });
}

// Stay date range
const checkInDate = new Date(checkIn);
const checkOutDate = new Date(checkOut);
const today = new Date();
today.setHours(0, 0, 0, 0);

const toLocalIso = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

const stayRangeDates: { iso: string; label: string }[] = [];
const cursor = new Date(Math.max(today.getTime(), checkInDate.getTime()));
while (cursor < checkOutDate) {
  stayRangeDates.push({
    iso: toLocalIso(cursor),
    label: cursor.toLocaleDateString(lang === 'de' ? 'de-DE' : lang === 'fr' ? 'fr-FR' : lang === 'es' ? 'es-ES' : 'en-US', {
      weekday: 'short', day: '2-digit', month: 'short',
    }),
  });
  cursor.setDate(cursor.getDate() + 1);
}

// Duration options
const durationOptions = [
  { value: 1, label: '1 h' },
  { value: 2, label: '2 h' },
  { value: 3, label: '3 h' },
  { value: 4, label: '4 h' },
  { value: 6, label: '6 h' },
  { value: 8, label: '8 h' },
];

// Localize rooms
const localizedRooms = rooms.map(r => ({
  id: r.id,
  name: (r as any)[`name_${lang}`] || r.name_de,
  description: (r as any)[`description_${lang}`] || r.description_de || '',
  capacity: r.capacity,
}));

// Labels per language
const labelMap = {
  de: {
    eyebrow: 'Konferenz',
    title: 'Salon ',
    titleAccent: 'reservieren',
    subtitle: 'Für Meetings, Besprechungen und Anlässe.',
    chooseRoom: 'Welchen Salon?',
    capacity: 'Plätze',
    dateLabel: 'Wann?',
    timeLabel: 'Ab welcher Uhrzeit?',
    durationLabel: 'Wie lange?',
    peopleLabel: 'Wie viele Personen?',
    occasionLabel: 'Anlass',
    occasionPlaceholder: 'z.B. Team-Meeting, Vorstellungsgespräch, Workshop',
    notesLabel: 'Notiz (optional)',
    notesPlaceholder: 'Catering-Wünsche, Technik, Sonderausstattung...',
    submitBtn: 'Salon anfragen',
    rebookBtn: 'Andere Reservierung',
    statusPendingTitle: 'Wir haben deine Anfrage.',
    statusPendingSub: 'Du hörst gleich von uns.',
    statusConfirmedTitle: 'Reservierung bestätigt.',
    statusConfirmedSub: 'Wir freuen uns auf dich.',
    statusCancelledTitle: 'Reservierung abgelehnt.',
    statusCancelledSub: 'Bitte sprich mit dem Empfang.',
    yourSelection: 'Deine Auswahl',
    summaryRoom: 'Salon',
    summaryDate: 'Datum',
    summaryTime: 'Uhrzeit',
    summaryDuration: 'Dauer',
    summaryPeople: 'Personen',
    summaryOccasion: 'Anlass',
  },
  en: {
    eyebrow: 'Conference',
    title: 'Book ',
    titleAccent: 'a salon',
    subtitle: 'For meetings, workshops and gatherings.',
    chooseRoom: 'Which salon?',
    capacity: 'Seats',
    dateLabel: 'When?',
    timeLabel: 'What time?',
    durationLabel: 'How long?',
    peopleLabel: 'How many people?',
    occasionLabel: 'Occasion',
    occasionPlaceholder: 'e.g. team meeting, interview, workshop',
    notesLabel: 'Note (optional)',
    notesPlaceholder: 'Catering wishes, tech setup, special needs...',
    submitBtn: 'Request salon',
    rebookBtn: 'Different reservation',
    statusPendingTitle: 'We got your request.',
    statusPendingSub: 'We\'ll be in touch shortly.',
    statusConfirmedTitle: 'Reservation confirmed.',
    statusConfirmedSub: 'See you soon.',
    statusCancelledTitle: 'Reservation declined.',
    statusCancelledSub: 'Please speak with reception.',
    yourSelection: 'Your selection',
    summaryRoom: 'Salon',
    summaryDate: 'Date',
    summaryTime: 'Time',
    summaryDuration: 'Duration',
    summaryPeople: 'People',
    summaryOccasion: 'Occasion',
  },
  fr: {
    eyebrow: 'Conférence',
    title: 'Réserver ',
    titleAccent: 'un salon',
    subtitle: 'Pour réunions, ateliers et rencontres.',
    chooseRoom: 'Quel salon ?',
    capacity: 'Places',
    dateLabel: 'Quand ?',
    timeLabel: 'À quelle heure ?',
    durationLabel: 'Combien de temps ?',
    peopleLabel: 'Combien de personnes ?',
    occasionLabel: 'Occasion',
    occasionPlaceholder: 'ex. réunion d\'équipe, entretien, atelier',
    notesLabel: 'Note (optionnel)',
    notesPlaceholder: 'Restauration, équipement technique, besoins spéciaux...',
    submitBtn: 'Demander le salon',
    rebookBtn: 'Autre réservation',
    statusPendingTitle: 'Demande reçue.',
    statusPendingSub: 'Nous revenons vers vous rapidement.',
    statusConfirmedTitle: 'Réservation confirmée.',
    statusConfirmedSub: 'À très bientôt.',
    statusCancelledTitle: 'Réservation refusée.',
    statusCancelledSub: 'Veuillez parler à la réception.',
    yourSelection: 'Votre sélection',
    summaryRoom: 'Salon',
    summaryDate: 'Date',
    summaryTime: 'Heure',
    summaryDuration: 'Durée',
    summaryPeople: 'Personnes',
    summaryOccasion: 'Occasion',
  },
  es: {
    eyebrow: 'Conferencia',
    title: 'Reservar ',
    titleAccent: 'un salón',
    subtitle: 'Para reuniones, talleres y encuentros.',
    chooseRoom: '¿Qué salón?',
    capacity: 'Plazas',
    dateLabel: '¿Cuándo?',
    timeLabel: '¿A qué hora?',
    durationLabel: '¿Cuánto tiempo?',
    peopleLabel: '¿Cuántas personas?',
    occasionLabel: 'Ocasión',
    occasionPlaceholder: 'ej. reunión, entrevista, taller',
    notesLabel: 'Nota (opcional)',
    notesPlaceholder: 'Catering, equipamiento técnico, necesidades especiales...',
    submitBtn: 'Solicitar salón',
    rebookBtn: 'Otra reserva',
    statusPendingTitle: 'Solicitud recibida.',
    statusPendingSub: 'Te contactaremos pronto.',
    statusConfirmedTitle: 'Reserva confirmada.',
    statusConfirmedSub: 'Nos vemos pronto.',
    statusCancelledTitle: 'Reserva rechazada.',
    statusCancelledSub: 'Por favor habla con recepción.',
    yourSelection: 'Tu selección',
    summaryRoom: 'Salón',
    summaryDate: 'Fecha',
    summaryTime: 'Hora',
    summaryDuration: 'Duración',
    summaryPeople: 'Personas',
    summaryOccasion: 'Ocasión',
  },
};

const l = labelMap[lang];

const sheetData = {
  rooms: localizedRooms,
  stayRangeDates,
  allSlots,
  durationOptions,
  labels: l,
  accessToken,
  existingBooking,
  lang,
};
---

<Sheet
  id="conference"
  eyebrow={l.eyebrow}
  title={l.title}
  titleAccent={l.titleAccent}
  subtitle={l.subtitle}
>
  <div x-data={`conferenceForm(${JSON.stringify(sheetData)})`}>

    <!-- View 1: Existing booking status -->
    <template x-if="view === 'status'">
      <div class="booking-status">
        <div :class="`status-circle status-${existingBooking.status}`">
          <template x-if="existingBooking.status === 'pending'">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </template>
          <template x-if="existingBooking.status === 'confirmed'">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </template>
          <template x-if="existingBooking.status === 'cancelled'">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </template>
        </div>

        <h3 class="booking-status-title">
          <span x-text="statusInfo.title"></span>
        </h3>
        <p class="booking-status-sub" x-text="statusInfo.sub"></p>

        <div class="booking-summary">
          <p class="booking-summary-eyebrow" x-text="labels.yourSelection"></p>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryRoom"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.room_name || '—'"></span>
          </div>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryDate"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.date || '—'"></span>
          </div>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryTime"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.time || '—'"></span>
          </div>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryDuration"></span>
            <span class="booking-summary-value" x-text="(existingBooking.details?.duration_hours || '—') + ' h'"></span>
          </div>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryPeople"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.people || '—'"></span>
          </div>
          <div class="booking-summary-row" x-show="existingBooking.details?.occasion">
            <span class="booking-summary-label" x-text="labels.summaryOccasion"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.occasion"></span>
          </div>
        </div>

        <button
          type="button"
          class="bauhaus-button bauhaus-button--secondary"
          @click="startRebook()"
          x-show="existingBooking.status === 'cancelled' || existingBooking.status === 'confirmed'"
          x-text="labels.rebookBtn"
        ></button>
      </div>
    </template>

    <!-- View 2: Form -->
    <template x-if="view === 'form'">
      <form class="booking-form" @submit.prevent="submit()">

        <!-- Salon selection -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.chooseRoom"></div>
          <div class="conf-rooms">
            <template x-for="room in rooms" :key="room.id">
              <button type="button" class="conf-room"
                :class="{ active: form.room_id === room.id }"
                @click="form.room_id = room.id; if (form.people > room.capacity) form.people = room.capacity;">
                <div class="conf-room-name" x-text="room.name"></div>
                <div class="conf-room-cap" x-text="`${room.capacity} ${labels.capacity}`"></div>
                <div class="conf-room-desc" x-text="room.description" x-show="room.description"></div>
              </button>
            </template>
          </div>
        </div>

        <!-- Date -->
        <div class="booking-section" x-show="form.room_id">
          <div class="booking-section-label" x-text="labels.dateLabel"></div>
          <div class="booking-chip-row">
            <template x-for="d in stayRangeDates" :key="d.iso">
              <button type="button" class="bauhaus-pill"
                :data-active="form.date === d.iso"
                @click="form.date = d.iso"
                x-text="d.label"></button>
            </template>
          </div>
        </div>

        <!-- Time -->
        <div class="booking-section" x-show="form.date">
          <div class="booking-section-label" x-text="labels.timeLabel"></div>
          <div class="booking-chip-row">
            <template x-for="slot in allSlots" :key="slot.value">
              <button type="button" class="bauhaus-pill"
                :data-active="form.time === slot.value"
                @click="form.time = slot.value"
                x-text="slot.label"></button>
            </template>
          </div>
        </div>

        <!-- Duration -->
        <div class="booking-section" x-show="form.time">
          <div class="booking-section-label" x-text="labels.durationLabel"></div>
          <div class="booking-chip-row">
            <template x-for="d in durationOptions" :key="d.value">
              <button type="button" class="bauhaus-pill"
                :data-active="form.duration_hours === d.value"
                @click="form.duration_hours = d.value"
                x-text="d.label"></button>
            </template>
          </div>
        </div>

        <!-- People -->
        <div class="booking-section" x-show="form.duration_hours">
          <div class="booking-section-label">
            <span x-text="labels.peopleLabel"></span>
            <span class="form-label-max" x-text="`(max ${currentRoomCapacity})`"></span>
          </div>
          <div class="booking-chip-row">
            <template x-for="n in peopleOptions" :key="n">
              <button type="button" class="bauhaus-pill"
                :data-active="form.people === n"
                @click="form.people = n"
                x-text="n"></button>
            </template>
          </div>
        </div>

        <!-- Occasion -->
        <div class="booking-section" x-show="form.people">
          <div class="booking-section-label" x-text="labels.occasionLabel"></div>
          <input type="text" class="bauhaus-input"
            :placeholder="labels.occasionPlaceholder"
            x-model="form.occasion" />
        </div>

        <!-- Notes -->
        <div class="booking-section" x-show="form.people">
          <div class="booking-section-label" x-text="labels.notesLabel"></div>
          <textarea class="bauhaus-textarea" rows="3"
            :placeholder="labels.notesPlaceholder"
            x-model="form.notes"></textarea>
        </div>

        <!-- Submit -->
        <button type="submit" class="bauhaus-button bauhaus-button--primary bauhaus-button--block"
          :disabled="!canSubmit || submitting">
          <span x-show="!submitting" x-text="labels.submitBtn"></span>
          <span x-show="submitting">...</span>
        </button>

      </form>
    </template>

  </div>
</Sheet>

<style>
  /* ── BAUHAUS ─────────────────────────────────────────────────────────── */
  :global([data-theme="bauhaus"] #conference .conf-rooms) {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  }
  :global([data-theme="bauhaus"] #conference .conf-room) {
    display: block; width: 100%; padding: 14px 12px;
    background: var(--guest-bg-card); border: 1.5px solid var(--guest-border);
    border-radius: var(--guest-radius-sm); text-align: left; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  :global([data-theme="bauhaus"] #conference .conf-room.active) {
    border-color: var(--guest-accent); background: var(--guest-hover-soft);
  }
  :global([data-theme="bauhaus"] #conference .conf-room-name) {
    font-family: var(--guest-font-display); font-size: 14px; font-weight: 500;
    color: var(--guest-ink);
  }
  :global([data-theme="bauhaus"] #conference .conf-room-cap) {
    font-family: var(--guest-font-mono); font-size: 10px;
    letter-spacing: 0.10em; text-transform: uppercase;
    color: var(--guest-ink-muted); margin-top: 4px;
  }
  :global([data-theme="bauhaus"] #conference .conf-room-desc) {
    font-size: 11px; color: var(--guest-ink-muted); margin-top: 4px;
  }
  :global([data-theme="bauhaus"] #conference .bauhaus-textarea:focus),
  :global([data-theme="bauhaus"] #conference .bauhaus-input:focus) {
    outline: none; box-shadow: 0 0 0 2px var(--guest-accent);
  }
  :global([data-theme="bauhaus"] #conference .sheet-title) {
    font-family: var(--guest-font-display); font-weight: 500; letter-spacing: -0.02em;
  }

  /* ── EDITORIAL ───────────────────────────────────────────────────────── */
  :global([data-theme="editorial"] #conference .conf-rooms) {
    counter-reset: conf;
    display: flex; flex-direction: column;
  }
  :global([data-theme="editorial"] #conference .conf-room) {
    counter-increment: conf;
    display: flex; align-items: baseline; gap: 14px;
    padding: 16px 0; border: none; border-radius: 0;
    border-bottom: 1px solid var(--guest-border);
    background: transparent; text-align: left; cursor: pointer;
  }
  :global([data-theme="editorial"] #conference .conf-rooms .conf-room:first-child) {
    border-top: 1px solid var(--guest-border);
  }
  :global([data-theme="editorial"] #conference .conf-room::before) {
    content: "0" counter(conf);
    font-family: var(--guest-font-display); font-style: italic;
    font-size: 20px; font-weight: 300; color: var(--guest-ink-faint);
    flex-shrink: 0; width: 28px; transition: color 0.15s;
  }
  :global([data-theme="editorial"] #conference .conf-room.active::before) {
    color: var(--guest-accent);
  }
  :global([data-theme="editorial"] #conference .conf-room-name) {
    font-family: var(--guest-font-display); font-style: italic; font-size: 17px;
    color: var(--guest-ink); transition: color 0.15s;
  }
  :global([data-theme="editorial"] #conference .conf-room.active .conf-room-name) {
    color: var(--guest-accent);
  }
  :global([data-theme="editorial"] #conference .conf-room-cap) {
    font-size: 11px; color: var(--guest-ink-muted); margin-top: 3px;
  }
  :global([data-theme="editorial"] #conference .bauhaus-pill) {
    border: none; border-bottom: 1px solid var(--guest-border); border-radius: 0;
    background: transparent; font-family: var(--guest-font-body);
    font-size: 13px; letter-spacing: 0; padding: 10px 4px; color: var(--guest-ink-muted);
  }
  :global([data-theme="editorial"] #conference .bauhaus-pill[data-active="true"]) {
    border-bottom-color: var(--guest-accent); color: var(--guest-ink); background: transparent;
  }
  :global([data-theme="editorial"] #conference .bauhaus-textarea),
  :global([data-theme="editorial"] #conference .bauhaus-input) {
    border: none; border-bottom: 1px solid var(--guest-border);
    border-radius: 0; background: transparent; padding: 10px 0;
    font-family: var(--guest-font-display); font-style: italic; font-size: 15px;
    color: var(--guest-ink);
  }
  :global([data-theme="editorial"] #conference .bauhaus-textarea:focus),
  :global([data-theme="editorial"] #conference .bauhaus-input:focus) {
    outline: none; border-bottom-color: var(--guest-accent);
  }
  :global([data-theme="editorial"] #conference .bauhaus-button--primary) {
    background: transparent; color: var(--guest-ink);
    border: 1px solid var(--guest-ink); border-radius: 0;
    font-family: var(--guest-font-display); font-style: italic;
  }
  :global([data-theme="editorial"] #conference .bauhaus-button--primary:hover:not(:disabled)) {
    background: var(--guest-ink); color: var(--guest-bg-card);
  }
  :global([data-theme="editorial"] #conference .booking-section-label) {
    font-family: var(--guest-font-mono); font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--guest-ink-muted);
  }
  :global([data-theme="editorial"] #conference .sheet-title) {
    font-family: var(--guest-font-display); font-style: italic; font-weight: 400;
  }

  /* ── MAISON ──────────────────────────────────────────────────────────── */
  :global([data-theme="maison"] #conference .conf-rooms) {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }
  :global([data-theme="maison"] #conference .conf-room) {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 18px 12px;
    background: transparent; border: 1px solid var(--guest-border);
    border-radius: 0; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  :global([data-theme="maison"] #conference .conf-room::before) {
    content: ''; display: block; width: 5px; height: 5px;
    background: var(--guest-accent); transform: rotate(45deg);
    margin-bottom: 8px; opacity: 0.4; transition: opacity 0.2s;
  }
  :global([data-theme="maison"] #conference .conf-room.active) {
    border-color: var(--guest-accent); background: var(--guest-accent-soft);
  }
  :global([data-theme="maison"] #conference .conf-room.active::before) { opacity: 1; }
  :global([data-theme="maison"] #conference .conf-room-name) {
    font-family: var(--guest-font-display); font-size: 12px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--guest-ink);
  }
  :global([data-theme="maison"] #conference .conf-room-cap) {
    font-family: var(--guest-font-mono); font-size: 9px;
    letter-spacing: 0.20em; text-transform: uppercase;
    color: var(--guest-accent); margin-top: 5px;
  }
  :global([data-theme="maison"] #conference .bauhaus-pill) {
    border: 1px solid var(--guest-border); border-radius: 0;
    font-family: var(--guest-font-display); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 10px 16px; background: transparent; color: var(--guest-ink-muted);
  }
  :global([data-theme="maison"] #conference .bauhaus-pill[data-active="true"]) {
    border-color: var(--guest-accent); background: var(--guest-accent);
    color: var(--guest-bg-deep);
  }
  :global([data-theme="maison"] #conference .bauhaus-textarea),
  :global([data-theme="maison"] #conference .bauhaus-input) {
    border: 1px solid var(--guest-accent); border-radius: 0;
    background: transparent; padding: 12px 16px;
    font-family: var(--guest-font-body); font-style: italic;
    font-size: 14px; color: var(--guest-ink);
  }
  :global([data-theme="maison"] #conference .bauhaus-textarea:focus),
  :global([data-theme="maison"] #conference .bauhaus-input:focus) {
    outline: none; box-shadow: 0 0 0 1px var(--guest-accent);
  }
  :global([data-theme="maison"] #conference .bauhaus-button--primary) {
    background: var(--guest-accent); color: var(--guest-bg-deep);
    border: none; border-radius: 0; font-family: var(--guest-font-display);
    letter-spacing: 0.22em; text-transform: uppercase; font-size: 10px;
  }
  :global([data-theme="maison"] #conference .bauhaus-button--primary:hover:not(:disabled)) {
    background: var(--guest-accent-bright);
  }
