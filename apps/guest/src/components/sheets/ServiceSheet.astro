---
import Sheet from '../Sheet.astro';

interface ServiceItem {
  id: string;
  name_de: string;
  name_en?: string;
  name_fr?: string;
  name_es?: string;
  description_de?: string;
  description_en?: string;
  description_fr?: string;
  description_es?: string;
  icon?: string;
}

interface Props {
  lang: 'de' | 'en' | 'fr' | 'es';
  items: ServiceItem[];
  startTime: string;
  endTime: string;
  accessToken: string;
  existingBooking: any | null;
  conciergeName: string;
  checkIn: string;
  checkOut: string;
  formality?: 'informal' | 'formal';
}

const { lang, items, startTime, endTime, accessToken, existingBooking, conciergeName, checkIn, checkOut, formality = 'informal' } = Astro.props;
const isFormal = formality === 'formal';

// Time slots — every 30 min between start and end
const [startH, startM] = startTime.substring(0, 5).split(':').map(Number);
const [endH, endM] = endTime.substring(0, 5).split(':').map(Number);
const startMin = startH * 60 + startM;
const endMin = endH * 60 + endM;

const allSlots: { value: string; label: string }[] = [];
for (let m = startMin; m < endMin; m += 30) {
  const h = Math.floor(m / 60);
  const mm = m % 60;
  const time = `${String(h).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
  allSlots.push({ value: time, label: time });
}

// Localize items
const localizedItems = items.map(item => ({
  id: item.id,
  name: (item as any)[`name_${lang}`] || item.name_de,
  description: (item as any)[`description_${lang}`] || item.description_de || '',
  icon: item.icon || 'default',
}));

const labelMap = {
  de: {
    eyebrow: 'Service',
    title: isFormal ? 'Was brauchen ' : 'Was brauchst ',
    titleAccent: isFormal ? 'Sie?' : 'du?',
    subtitle: isFormal ? 'Wir bringen es Ihnen aufs Zimmer.' : 'Wir bringen es dir aufs Zimmer.',
    chooseItem: isFormal ? 'Was möchten Sie?' : 'Was möchtest du?',
    timingLabel: 'Wann?',
    timingNow: 'So schnell wie möglich',
    timingScheduled: 'Zu einer bestimmten Zeit',
    timeLabel: 'Uhrzeit',
    notesLabel: 'Notiz (optional)',
    notesPlaceholder: 'z.B. extra-saugfähige Handtücher, kohlensäurefreies Wasser ...',
    submitBtn: 'Service anfragen',
    rebookBtn: 'Neue Anfrage',
    statusPendingTitle: isFormal ? 'Wir haben Ihre Anfrage.' : 'Wir haben deine Anfrage.',
    statusPendingSub: isFormal ? 'Kommt zu Ihnen aufs Zimmer.' : 'Kommt zu dir aufs Zimmer.',
    statusConfirmedTitle: 'Bestätigt.',
    statusConfirmedSub: isFormal ? 'Wir bringen es Ihnen gleich.' : 'Wir bringen es dir gleich.',
    statusCancelledTitle: 'Anfrage abgelehnt.',
    statusCancelledSub: isFormal ? 'Bitte sprechen Sie mit dem Empfang.' : 'Bitte sprich mit dem Empfang.',
    yourSelection: isFormal ? 'Ihre Auswahl' : 'Deine Auswahl',
    summaryItem: 'Service',
    summaryTime: 'Wann',
    summaryNote: 'Notiz',
  },
  en: {
    eyebrow: 'Service',
    title: 'What do ',
    titleAccent: 'you need?',
    subtitle: 'We bring it to your room.',
    chooseItem: 'What would you like?',
    timingLabel: 'When?',
    timingNow: 'As soon as possible',
    timingScheduled: 'At a specific time',
    timeLabel: 'Time',
    notesLabel: 'Note (optional)',
    notesPlaceholder: 'e.g. extra-absorbent towels, still water ...',
    submitBtn: 'Request service',
    rebookBtn: 'New request',
    statusPendingTitle: 'We got your request.',
    statusPendingSub: 'Coming to your room.',
    statusConfirmedTitle: 'Confirmed.',
    statusConfirmedSub: 'We bring it shortly.',
    statusCancelledTitle: 'Request declined.',
    statusCancelledSub: 'Please speak with reception.',
    yourSelection: 'Your selection',
    summaryItem: 'Service',
    summaryTime: 'When',
    summaryNote: 'Note',
  },
  fr: {
    eyebrow: 'Service',
    title: 'De quoi ',
    titleAccent: 'avez-vous besoin ?',
    subtitle: 'Nous l\'apportons dans votre chambre.',
    chooseItem: 'Que souhaitez-vous ?',
    timingLabel: 'Quand ?',
    timingNow: 'Dès que possible',
    timingScheduled: 'À une heure précise',
    timeLabel: 'Heure',
    notesLabel: 'Note (optionnel)',
    notesPlaceholder: 'ex. serviettes très absorbantes, eau plate ...',
    submitBtn: 'Demander le service',
    rebookBtn: 'Nouvelle demande',
    statusPendingTitle: 'Demande reçue.',
    statusPendingSub: 'Arrive dans votre chambre.',
    statusConfirmedTitle: 'Confirmé.',
    statusConfirmedSub: 'Nous arrivons.',
    statusCancelledTitle: 'Demande refusée.',
    statusCancelledSub: 'Veuillez parler à la réception.',
    yourSelection: 'Votre sélection',
    summaryItem: 'Service',
    summaryTime: 'Quand',
    summaryNote: 'Note',
  },
  es: {
    eyebrow: 'Servicio',
    title: '¿Qué ',
    titleAccent: 'necesitas?',
    subtitle: 'Te lo llevamos a la habitación.',
    chooseItem: '¿Qué te gustaría?',
    timingLabel: '¿Cuándo?',
    timingNow: 'Lo antes posible',
    timingScheduled: 'A una hora concreta',
    timeLabel: 'Hora',
    notesLabel: 'Nota (opcional)',
    notesPlaceholder: 'ej. toallas extra absorbentes, agua sin gas ...',
    submitBtn: 'Solicitar servicio',
    rebookBtn: 'Nueva solicitud',
    statusPendingTitle: 'Solicitud recibida.',
    statusPendingSub: 'Va a tu habitación.',
    statusConfirmedTitle: 'Confirmado.',
    statusConfirmedSub: 'Lo traemos enseguida.',
    statusCancelledTitle: 'Solicitud rechazada.',
    statusCancelledSub: 'Por favor habla con recepción.',
    yourSelection: 'Tu selección',
    summaryItem: 'Servicio',
    summaryTime: 'Cuándo',
    summaryNote: 'Nota',
  },
};

const l = labelMap[lang];

const sheetData = {
  items: localizedItems,
  allSlots,
  labels: l,
  accessToken,
  existingBooking,
  lang,
};
---

<Sheet
  id="service"
  eyebrow={l.eyebrow}
  title={l.title}
  titleAccent={l.titleAccent}
  subtitle={l.subtitle}
>
  <div x-data={`serviceForm(${JSON.stringify(sheetData)})`}>

    <!-- View 1: Status -->
    <template x-if="view === 'status'">
      <div class="booking-status">
        <div :class="`status-circle status-${existingBooking.status}`">
          <template x-if="existingBooking.status === 'pending'">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </template>
          <template x-if="existingBooking.status === 'confirmed'">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </template>
          <template x-if="existingBooking.status === 'cancelled'">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </template>
        </div>

        <h3 class="booking-status-title">
          <span x-text="statusInfo.title"></span>
        </h3>
        <p class="booking-status-sub" x-text="statusInfo.sub"></p>

        <div class="booking-summary">
          <p class="booking-summary-eyebrow" x-text="labels.yourSelection"></p>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryItem"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.item_name || '—'"></span>
          </div>
          <div class="booking-summary-row">
            <span class="booking-summary-label" x-text="labels.summaryTime"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.time || labels.timingNow"></span>
          </div>
          <div class="booking-summary-row" x-show="existingBooking.details?.notes">
            <span class="booking-summary-label" x-text="labels.summaryNote"></span>
            <span class="booking-summary-value" x-text="existingBooking.details?.notes"></span>
          </div>
        </div>

        <button
          type="button"
          class="bauhaus-button bauhaus-button--secondary"
          @click="startRebook()"
          x-show="existingBooking.status === 'cancelled' || existingBooking.status === 'confirmed'"
          x-text="labels.rebookBtn"
        ></button>
      </div>
    </template>

    <!-- View 2: Form -->
    <template x-if="view === 'form'">
      <form class="booking-form" @submit.prevent="submit()">

        <!-- Item selection -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.chooseItem"></div>
          <div class="service-items">
            <template x-for="item in items" :key="item.id">
              <button type="button" class="service-item"
                :class="{ active: form.item_id === item.id }"
                @click="form.item_id = item.id">
                <div class="service-item-name" x-text="item.name"></div>
                <div class="service-item-desc" x-text="item.description" x-show="item.description"></div>
              </button>
            </template>
          </div>
        </div>

        <!-- Timing choice -->
        <div class="booking-section" x-show="form.item_id">
          <div class="booking-section-label" x-text="labels.timingLabel"></div>
          <div class="timing-pills">
            <button type="button" class="bauhaus-pill"
              :data-active="form.timing === 'now'"
              @click="form.timing = 'now'; form.time = ''"
              x-text="labels.timingNow"></button>
            <button type="button" class="bauhaus-pill"
              :data-active="form.timing === 'scheduled'"
              @click="form.timing = 'scheduled'"
              x-text="labels.timingScheduled"></button>
          </div>
        </div>

        <!-- Time slots (only if scheduled) -->
        <div class="booking-section" x-show="form.timing === 'scheduled'">
          <div class="booking-section-label" x-text="labels.timeLabel"></div>
          <div class="booking-chip-row">
            <template x-for="slot in allSlots" :key="slot.value">
              <button type="button" class="bauhaus-pill"
                :data-active="form.time === slot.value"
                @click="form.time = slot.value"
                x-text="slot.label"></button>
            </template>
          </div>
        </div>

        <!-- Notes -->
        <div class="booking-section" x-show="form.item_id && form.timing">
          <div class="booking-section-label" x-text="labels.notesLabel"></div>
          <textarea class="bauhaus-textarea" rows="3"
            :placeholder="labels.notesPlaceholder"
            x-model="form.notes"></textarea>
        </div>

        <button type="submit" class="bauhaus-button bauhaus-button--primary bauhaus-button--block"
          :disabled="!canSubmit || submitting">
          <span x-show="!submitting" x-text="labels.submitBtn"></span>
          <span x-show="submitting">...</span>
        </button>

      </form>
    </template>

  </div>
</Sheet>

<style>
  /* ── BAUHAUS ─────────────────────────────────────────────────────────── */
  :global([data-theme="bauhaus"] #service .service-items) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  :global([data-theme="bauhaus"] #service .service-item) {
    display: block; width: 100%;
    padding: 14px 12px;
    background: var(--guest-bg-card);
    border: 1.5px solid var(--guest-border);
    border-radius: var(--guest-radius-sm);
    text-align: left; cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  :global([data-theme="bauhaus"] #service .service-item.active) {
    border-color: var(--guest-accent);
    background: var(--guest-hover-soft);
  }
  :global([data-theme="bauhaus"] #service .service-item-name) {
    font-family: var(--guest-font-display);
    font-size: 14px; font-weight: 500; color: var(--guest-ink);
  }
  :global([data-theme="bauhaus"] #service .service-item-desc) {
    font-size: 11px; margin-top: 4px; color: var(--guest-ink-muted);
  }
  :global([data-theme="bauhaus"] #service .bauhaus-textarea:focus) {
    outline: none;
    box-shadow: 0 0 0 2px var(--guest-accent);
  }
  :global([data-theme="bauhaus"] #service .sheet-title) {
    font-family: var(--guest-font-display);
    font-weight: 500; letter-spacing: -0.02em;
  }

  /* ── EDITORIAL ───────────────────────────────────────────────────────── */
  :global([data-theme="editorial"] #service .service-items) {
    counter-reset: svc;
    display: flex; flex-direction: column;
  }
  :global([data-theme="editorial"] #service .service-item) {
    counter-increment: svc;
    display: flex; align-items: baseline; gap: 14px;
    padding: 16px 0;
    border: none; border-radius: 0;
    border-bottom: 1px solid var(--guest-border);
    background: transparent; text-align: left; cursor: pointer;
  }
  :global([data-theme="editorial"] #service .service-items .service-item:first-child) {
    border-top: 1px solid var(--guest-border);
  }
  :global([data-theme="editorial"] #service .service-item::before) {
    content: "0" counter(svc);
    font-family: var(--guest-font-display);
    font-style: italic; font-size: 20px; font-weight: 300;
    color: var(--guest-ink-faint); flex-shrink: 0; width: 28px;
    transition: color 0.15s;
  }
  :global([data-theme="editorial"] #service .service-item.active::before) {
    color: var(--guest-accent);
  }
  :global([data-theme="editorial"] #service .service-item-name) {
    font-family: var(--guest-font-display);
    font-style: italic; font-size: 17px;
    color: var(--guest-ink); transition: color 0.15s;
  }
  :global([data-theme="editorial"] #service .service-item.active .service-item-name) {
    color: var(--guest-accent);
  }
  :global([data-theme="editorial"] #service .service-item-desc) {
    font-size: 12px; color: var(--guest-ink-muted); margin-top: 3px;
  }
  :global([data-theme="editorial"] #service .bauhaus-pill) {
    border: none; border-bottom: 1px solid var(--guest-border); border-radius: 0;
    background: transparent; font-family: var(--guest-font-body);
    font-size: 13px; letter-spacing: 0; padding: 10px 4px;
    color: var(--guest-ink-muted);
  }
  :global([data-theme="editorial"] #service .bauhaus-pill[data-active="true"]) {
    border-bottom-color: var(--guest-accent); color: var(--guest-ink); background: transparent;
  }
  :global([data-theme="editorial"] #service .booking-chip-row) { flex-wrap: wrap; gap: 0 8px; }
  :global([data-theme="editorial"] #service .bauhaus-textarea) {
    border: none; border-bottom: 1px solid var(--guest-border);
    border-radius: 0; background: transparent; padding: 10px 0;
    font-family: var(--guest-font-display); font-style: italic; font-size: 15px;
    color: var(--guest-ink); resize: none; width: 100%;
  }
  :global([data-theme="editorial"] #service .bauhaus-textarea:focus) {
    outline: none; border-bottom-color: var(--guest-accent);
  }
  :global([data-theme="editorial"] #service .bauhaus-button--primary) {
    background: transparent; color: var(--guest-ink);
    border: 1px solid var(--guest-ink); border-radius: 0;
    font-family: var(--guest-font-display); font-style: italic; letter-spacing: 0.02em;
  }
  :global([data-theme="editorial"] #service .bauhaus-button--primary:hover:not(:disabled)) {
    background: var(--guest-ink); color: var(--guest-bg-card);
  }
  :global([data-theme="editorial"] #service .booking-section-label) {
    font-family: var(--guest-font-mono);
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--guest-ink-muted);
  }
  :global([data-theme="editorial"] #service .sheet-title) {
    font-family: var(--guest-font-display); font-style: italic; font-weight: 400;
  }

  /* ── MAISON ──────────────────────────────────────────────────────────── */
  :global([data-theme="maison"] #service .service-items) {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }
  :global([data-theme="maison"] #service .service-item) {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; padding: 18px 12px;
    background: transparent; border: 1px solid var(--guest-border);
    border-radius: 0; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  :global([data-theme="maison"] #service .service-item::before) {
    content: ''; display: block; width: 5px; height: 5px;
    background: var(--guest-accent); transform: rotate(45deg);
    margin-bottom: 8px; opacity: 0.4; transition: opacity 0.2s;
  }
  :global([data-theme="maison"] #service .service-item.active) {
    border-color: var(--guest-accent); background: var(--guest-accent-soft);
  }
  :global([data-theme="maison"] #service .service-item.active::before) { opacity: 1; }
  :global([data-theme="maison"] #service .service-item-name) {
    font-family: var(--guest-font-display); font-size: 12px;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--guest-ink);
  }
  :global([data-theme="maison"] #service .service-item-desc) {
    font-family: var(--guest-font-body); font-style: italic;
    font-size: 11px; color: var(--guest-ink-muted); margin-top: 5px;
  }
  :global([data-theme="maison"] #service .bauhaus-pill) {
    border: 1px solid var(--guest-border); border-radius: 0;
    font-family: var(--guest-font-display); font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 10px 16px; background: transparent; color: var(--guest-ink-muted);
  }
  :global([data-theme="maison"] #service .bauhaus-pill[data-active="true"]) {
    border-color: var(--guest-accent); background: var(--guest-accent);
    color: var(--guest-bg-deep);
  }
  :global([data-theme="maison"] #service .bauhaus-textarea) {
    border: 1px solid var(--guest-accent); border-radius: 0;
    background: transparent; padding: 12px 16px;
    font-family: var(--guest-font-body); font-style: italic;
    font-size: 14px; color: var(--guest-ink); resize: none; width: 100%;
  }
  :global([data-theme="maison"] #service .bauhaus-textarea:focus) {
    outline: none; box-shadow: 0 0 0 1px var(--guest-accent);
  }
  :global([data-theme="maison"] #service .bauhaus-button--primary) {
    background: var(--guest-accent); color: var(--guest-bg-deep);
    border: none; border-radius: 0;
    font-family: var(--guest-font-display);
    letter-spacing: 0.22em; text-transform: uppercase; font-size: 10px;
  }
  :global([data-theme="maison"] #service .bauhaus-button--primary:hover:not(:disabled)) {
    background: var(--guest-accent-bright);
  }
  :global([data-theme="maison"] #service .booking-section-label) {
    font-family: var(--guest-font-mono); font-size: 9px;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--guest-accent);
  }
  :global([data-theme="maison"] #service .sheet-title) {
    font-family: var(--guest-font-display); letter-spacing: 0.12em; font-weight: 400;
  }
  :global([data-theme="maison"] #service .sheet-eyebrow) { letter-spacing: 0.20em; }
</style>
