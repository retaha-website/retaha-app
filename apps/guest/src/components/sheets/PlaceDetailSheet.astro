---
// Sprint E2 · Phase 8 — Detail-Sheet pro Place
//
// Layered ÜBER PlacesSheet (höherer z-index, eigener Backdrop). Beim
// Close: PlacesSheet bleibt sichtbar, Detail verschwindet.
//
// Datenquelle pro Click:
//   1. Pick → Daten kommen aus pre-loaded window.__PLACE_DETAILS__ Map
//   2. Auto → fetch /api/places/details?placeId=...
//
// Alpine-State sitzt in guestPage:
//   activeDetailPlaceId, activeDetailData, detailLoading, detailError

import { t, type Lang } from '@retaha/i18n';
---

<!-- Backdrop (höherer z als regulärer Sheet) -->
<div
  class="place-detail-backdrop"
  x-show="activeDetailPlaceId"
  x-cloak
  @click="closePlaceDetail()"
  x-transition.opacity
></div>

<!-- Sheet -->
<aside
  class="place-detail-sheet"
  x-show="activeDetailPlaceId"
  x-cloak
  x-transition:enter="place-detail-enter"
  x-transition:enter-start="place-detail-enter-start"
  x-transition:enter-end="place-detail-enter-end"
  x-transition:leave="place-detail-leave"
  x-transition:leave-start="place-detail-leave-start"
  x-transition:leave-end="place-detail-leave-end"
  role="dialog"
  aria-modal="true"
>
  <!-- Header mit Close -->
  <header class="place-detail-header">
    <h2 class="place-detail-title" x-text="activeDetailData?.name || '…'"></h2>
    <button type="button" class="place-detail-close" @click="closePlaceDetail()" aria-label="Schließen">×</button>
  </header>

  <!-- Loading-State -->
  <div x-show="detailLoading && !activeDetailData" class="place-detail-loading" x-cloak>
    <p class="place-detail-loading-text">…</p>
  </div>

  <!-- Error-State -->
  <div x-show="detailError" class="place-detail-error" x-cloak>
    <p x-text="detailError"></p>
  </div>

  <!-- Content -->
  <div x-show="activeDetailData" x-cloak class="place-detail-body">

    <!-- Photo-Carousel -->
    <div class="photo-carousel" x-data="{ idx: 0 }" x-show="(activeDetailData?.photoUrls?.length || 0) > 0">
      <div class="photo-carousel-frame">
        <template x-for="(url, i) in (activeDetailData?.photoUrls || [])" :key="url">
          <img
            :src="url"
            :alt="activeDetailData?.name"
            class="photo-carousel-img"
            x-show="i === idx || i === idx + 1"
            :class="{ 'is-active': i === idx }"
            loading="lazy"
          />
        </template>
      </div>
      <button
        type="button"
        class="photo-carousel-btn photo-carousel-btn--prev"
        @click="idx = idx > 0 ? idx - 1 : 0"
        :disabled="idx === 0"
        x-show="(activeDetailData?.photoUrls?.length || 0) > 1"
        aria-label="Vorheriges Foto"
      >‹</button>
      <button
        type="button"
        class="photo-carousel-btn photo-carousel-btn--next"
        @click="idx = idx < (activeDetailData.photoUrls.length - 1) ? idx + 1 : idx"
        :disabled="idx >= (activeDetailData?.photoUrls?.length || 1) - 1"
        x-show="(activeDetailData?.photoUrls?.length || 0) > 1"
        aria-label="Nächstes Foto"
      >›</button>
      <div class="photo-carousel-counter" x-show="(activeDetailData?.photoUrls?.length || 0) > 1">
        <span x-text="idx + 1"></span>/<span x-text="activeDetailData?.photoUrls?.length || 0"></span>
      </div>
    </div>

    <!-- Rating + Price + Type -->
    <div class="place-detail-meta">
      <span class="rating" x-show="activeDetailData?.rating != null">
        ⭐ <span x-text="activeDetailData?.rating"></span>
        <span class="rating-count" x-text="`(${activeDetailData?.userRatingCount ?? 0})`"></span>
      </span>
      <span class="price" x-show="activeDetailData?.priceSymbol" x-text="activeDetailData?.priceSymbol"></span>
    </div>

    <!-- Hotel-Notiz (nur bei Picks) -->
    <div class="place-detail-note" x-show="activeDetailData?.hotelNote" x-cloak>
      <p class="place-detail-note-eyebrow themed-eyebrow-flank">Hotel-Notiz</p>
      <p class="place-detail-note-text" x-text="activeDetailData?.hotelNote"></p>
    </div>

    <!-- Öffnungszeiten -->
    <section class="place-detail-section" x-show="activeDetailData?.openingHours || activeDetailData?.openNow != null">
      <h3 class="place-detail-section-title">Öffnungszeiten</h3>
      <div class="place-detail-hours">
        <template x-if="activeDetailData?.openNow === true">
          <p class="hours-status hours-status--open">☑ Geöffnet</p>
        </template>
        <template x-if="activeDetailData?.openNow === false">
          <p class="hours-status hours-status--closed">☒ Geschlossen</p>
        </template>
        <template x-if="activeDetailData?.openNow == null">
          <p class="hours-status hours-status--unknown">☐ Öffnungszeiten nicht verfügbar</p>
        </template>
        <ul class="hours-list" x-show="(activeDetailData?.weekdayDescriptions?.length || 0) > 0">
          <template x-for="line in (activeDetailData?.weekdayDescriptions || [])" :key="line">
            <li x-text="line"></li>
          </template>
        </ul>
      </div>
    </section>

    <!-- Kontakt -->
    <section class="place-detail-section" x-show="activeDetailData?.formattedAddress || activeDetailData?.phone || activeDetailData?.website">
      <h3 class="place-detail-section-title">Kontakt</h3>
      <p class="contact-line" x-show="activeDetailData?.formattedAddress">
        <span class="contact-icon" aria-hidden="true">📍</span>
        <span x-text="activeDetailData?.formattedAddress"></span>
      </p>
      <p class="contact-line" x-show="activeDetailData?.phone">
        <span class="contact-icon" aria-hidden="true">📞</span>
        <a :href="`tel:${activeDetailData?.phone}`" x-text="activeDetailData?.phone"></a>
      </p>
      <p class="contact-line" x-show="activeDetailData?.website">
        <span class="contact-icon" aria-hidden="true">🌐</span>
        <a :href="activeDetailData?.website" target="_blank" rel="noopener noreferrer" x-text="activeDetailData?.website"></a>
      </p>
    </section>

    <!-- Reviews -->
    <section class="place-detail-section" x-show="(activeDetailData?.reviews?.length || 0) > 0">
      <h3 class="place-detail-section-title">Top-Bewertungen</h3>
      <template x-for="(r, i) in (activeDetailData?.reviews || [])" :key="i">
        <article class="review">
          <p class="review-meta">
            <span class="review-author" x-text="r.authorName"></span>
            <span class="review-rating">⭐ <span x-text="r.rating"></span></span>
          </p>
          <p class="review-text" x-text="r.text"></p>
        </article>
      </template>
    </section>

    <!-- Action-Buttons -->
    <div class="place-detail-actions" x-show="activeDetailData?.googleMapsUri || activeDetailData?.phone || activeDetailData?.website">
      <a
        x-show="activeDetailData?.googleMapsUri"
        :href="activeDetailData?.googleMapsUri"
        target="_blank"
        rel="noopener noreferrer"
        class="place-detail-action place-detail-action--primary"
      >
        📍 Google Maps
      </a>
      <a
        x-show="activeDetailData?.phone"
        :href="`tel:${activeDetailData?.phone}`"
        class="place-detail-action place-detail-action--secondary"
      >
        📞 Anrufen
      </a>
      <a
        x-show="activeDetailData?.website"
        :href="activeDetailData?.website"
        target="_blank"
        rel="noopener noreferrer"
        class="place-detail-action place-detail-action--secondary"
      >
        🌐 Website
      </a>
    </div>
  </div>
</aside>

<style is:global>
  /* Backdrop + Sheet — höher als regulärer sheet-overlay (z-index 90/100) */
  .place-detail-backdrop {
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    z-index: 150;
  }
  .place-detail-sheet {
    position: fixed;
    inset: 0;
    background: var(--theme-bg-secondary);
    z-index: 160;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  @media (min-width: 768px) {
    .place-detail-sheet {
      inset: 40px 40px 40px auto;
      width: 480px;
      border-radius: 16px;
      box-shadow: 0 16px 64px rgba(0, 0, 0, 0.25);
    }
  }

  .place-detail-enter { transition: transform 0.3s ease-out, opacity 0.3s; }
  .place-detail-enter-start { transform: translateY(100%); opacity: 0; }
  .place-detail-enter-end { transform: translateY(0); opacity: 1; }
  .place-detail-leave { transition: transform 0.25s ease-in, opacity 0.25s; }
  .place-detail-leave-start { transform: translateY(0); opacity: 1; }
  .place-detail-leave-end { transform: translateY(100%); opacity: 0; }

  /* Header */
  .place-detail-header {
    position: sticky; top: 0;
    background: var(--theme-bg-primary);
    border-bottom: 1px solid var(--theme-border);
    padding: 16px 20px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px;
    z-index: 2;
  }
  .place-detail-title {
    margin: 0;
    font-size: 18px; font-weight: 500;
    color: var(--theme-text-primary);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .place-detail-close {
    width: 36px; height: 36px; flex-shrink: 0;
    border: none; background: transparent;
    font-size: 28px; line-height: 1; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent);
    cursor: pointer; border-radius: 50%;
    transition: background 0.15s;
  }
  .place-detail-close:hover { background: color-mix(in srgb, var(--theme-text-primary) .05, transparent); }

  .place-detail-body { padding: 0 0 32px; }
  .place-detail-loading, .place-detail-error { padding: 40px 20px; text-align: center; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }
  .place-detail-error { color: #900; background: #fee; margin: 20px; padding: 12px 16px; border-left: 3px solid #c00; text-align: left; }

  /* Photo-Carousel */
  .photo-carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--theme-border);
    overflow: hidden;
  }
  .photo-carousel-frame { width: 100%; height: 100%; position: relative; }
  .photo-carousel-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .photo-carousel-img.is-active { opacity: 1; }
  .photo-carousel-btn {
    position: absolute; top: 50%;
    transform: translateY(-50%);
    width: 40px; height: 40px;
    border: none; border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    color: var(--theme-text-primary);
    font-size: 22px; line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.15);
  }
  .photo-carousel-btn--prev { left: 12px; }
  .photo-carousel-btn--next { right: 12px; }
  .photo-carousel-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .photo-carousel-counter {
    position: absolute; bottom: 12px; right: 12px;
    background: rgba(0,0,0,.55);
    color: var(--theme-bg-primary);
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-variant-numeric: tabular-nums;
  }

  /* Meta-Row */
  .place-detail-meta {
    padding: 16px 20px 8px;
    display: flex; gap: 12px;
    font-size: 14px; color: var(--theme-text-primary);
  }
  .place-detail-meta .rating-count { color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); font-size: 12px; margin-left: 2px; }
  .place-detail-meta .price { color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); }

  /* Hotel-Notiz */
  .place-detail-note {
    margin: 16px 20px;
    padding: 14px 16px;
    background: rgba(var(--theme-accent-rgb), 0.06);
    border-left: 3px solid var(--theme-accent);
  }
  .place-detail-note-eyebrow {
    font-size: 10px; letter-spacing: 0.18em;
    color: var(--theme-accent); margin: 0 0 6px;
  }
  .place-detail-note-text {
    margin: 0;
    font-style: italic; font-size: 14px; color: color-mix(in srgb, var(--theme-text-primary) .85, transparent);
  }

  /* Sections */
  .place-detail-section {
    padding: 20px;
    border-top: 1px solid var(--theme-border);
  }
  .place-detail-section-title {
    margin: 0 0 12px;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: color-mix(in srgb, var(--theme-text-primary) .55, transparent);
    font-weight: 500;
  }

  /* Hours */
  .hours-status { margin: 0 0 8px; font-size: 14px; font-weight: 500; }
  /* Marken-DNA: open = sage, closed = pink */
  .hours-status--open { color: var(--theme-success); }
  .hours-status--closed { color: var(--theme-accent); }
  .hours-status--unknown { color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); font-weight: 400; }
  .hours-list {
    list-style: none; padding: 0; margin: 8px 0 0;
    font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .7, transparent);
    font-variant-numeric: tabular-nums;
  }
  .hours-list li { padding: 2px 0; }

  /* Kontakt */
  .contact-line { margin: 4px 0; font-size: 14px; color: var(--theme-text-primary); display: flex; gap: 8px; }
  .contact-icon { flex-shrink: 0; }
  .contact-line a { color: var(--theme-accent); text-decoration: none; word-break: break-all; }
  .contact-line a:hover { text-decoration: underline; }

  /* Reviews */
  .review {
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--theme-border);
  }
  .review:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .review-meta {
    margin: 0 0 6px;
    display: flex; gap: 12px;
    font-size: 13px;
  }
  .review-author { font-weight: 500; color: var(--theme-text-primary); }
  .review-rating { color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); }
  .review-text {
    margin: 0;
    font-size: 14px;
    color: color-mix(in srgb, var(--theme-text-primary) .75, transparent);
    line-height: 1.5;
  }

  /* Action-Buttons */
  .place-detail-actions {
    padding: 20px;
    display: flex; flex-wrap: wrap; gap: 8px;
    border-top: 1px solid var(--theme-border);
  }
  .place-detail-action {
    flex: 1 1 auto; min-width: 120px;
    padding: 12px 16px;
    text-align: center;
    font-size: 14px; font-weight: 500;
    text-decoration: none;
    border-radius: 4px;
    transition: opacity 0.15s, background 0.15s;
  }
  .place-detail-action--primary {
    background: var(--theme-accent); color: var(--theme-bg-primary);
  }
  .place-detail-action--primary:hover { background: var(--theme-accent-hover); }
  .place-detail-action--secondary {
    background: transparent;
    color: var(--theme-text-primary);
    border: 1px solid var(--theme-border);
  }
  .place-detail-action--secondary:hover { background: var(--theme-bg-tertiary); }

  /* Fix hardcoded error colors */
  .place-detail-error {
    color: var(--guest-danger, #8C2128);
    background: var(--guest-danger-soft, rgba(140,33,40,0.10));
    border-left-color: var(--guest-danger, #8C2128);
  }

  /* ── BAUHAUS ─────────────────────────────────────────────────────────── */
  [data-theme="bauhaus"] .place-detail-title {
    font-family: var(--guest-font-display);
    font-weight: 500; letter-spacing: -0.02em;
  }
  [data-theme="bauhaus"] .place-detail-action { border-radius: 0; }

  /* ── EDITORIAL ───────────────────────────────────────────────────────── */
  [data-theme="editorial"] .place-detail-title {
    font-family: var(--guest-font-display);
    font-style: italic; font-weight: 400;
  }
  [data-theme="editorial"] .place-detail-action {
    border-radius: 0;
    font-family: var(--guest-font-display); font-style: italic;
  }
  [data-theme="editorial"] .place-detail-action--primary {
    background: transparent; color: var(--guest-ink);
    border: 1px solid var(--guest-ink);
  }
  [data-theme="editorial"] .place-detail-action--primary:hover {
    background: var(--guest-ink); color: var(--guest-bg-card);
  }
  [data-theme="editorial"] .place-detail-note-text {
    font-family: var(--guest-font-display); font-style: italic;
  }
  [data-theme="editorial"] .place-detail-section-title {
    font-family: var(--guest-font-mono); letter-spacing: 0.18em;
  }

  /* ── MAISON ──────────────────────────────────────────────────────────── */
  [data-theme="maison"] .place-detail-title {
    font-family: var(--guest-font-display);
    letter-spacing: 0.08em; font-weight: 400;
  }
  [data-theme="maison"] .place-detail-header {
    border-bottom-color: var(--guest-accent);
  }
  [data-theme="maison"] .place-detail-note {
    border-left-color: var(--guest-accent);
    background: var(--guest-accent-soft);
  }
  [data-theme="maison"] .place-detail-action {
    border-radius: 0;
    letter-spacing: 0.12em; text-transform: uppercase; font-size: 11px;
    font-family: var(--guest-font-display);
  }
  [data-theme="maison"] .place-detail-action--primary {
    background: var(--guest-accent); color: var(--guest-bg-deep);
  }
  [data-theme="maison"] .place-detail-action--primary:hover {
    background: var(--guest-accent-bright); color: var(--guest-bg-deep);
  }
  [data-theme="maison"] .place-detail-section-title {
    font-family: var(--guest-font-mono);
    color: var(--guest-accent); letter-spacing: 0.22em;
  }
</style>
