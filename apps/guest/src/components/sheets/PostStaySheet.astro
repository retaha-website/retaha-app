---
// Sprint Functional Modul C Phase 8 — Post-Stay-Rating-Sheet
//
// Trigger (Option A): check_out liegt in der Vergangenheit + 24h Cooldown
// via localStorage. Server entscheidet, ob das Sheet überhaupt gerendert
// wird (stayEnded && !hasFeedback). Client entscheidet, wann es aufpoppt
// (Cooldown-Check) und kann zwischen Form ↔ Thanks wechseln.

import type { Lang } from '@retaha/i18n';

interface Props {
  lang: Lang;
  stayId: string;
  hotelName: string;
}

const { lang, stayId, hotelName } = Astro.props;

const STRINGS: Record<string, Record<string, string>> = {
  de: {
    title: 'Wie war dein Aufenthalt?',
    sub: `Dein Feedback hilft ${hotelName}, besser zu werden.`,
    commentLabel: 'Etwas, das wir wissen sollten? (optional)',
    commentPlaceholder: 'Was hat besonders gefallen oder gefehlt …',
    submit: 'Bewertung senden',
    later: 'Später',
    sending: 'Wird gesendet …',
    thanksTitle: 'Danke!',
    thanksSub: 'Wir leiten dein Feedback ans Hotel weiter.',
    close: 'Schließen',
    starHint: 'Sterne tippen',
    errorPrefix: 'Senden fehlgeschlagen',
  },
  en: {
    title: 'How was your stay?',
    sub: `Your feedback helps ${hotelName} get better.`,
    commentLabel: 'Anything we should know? (optional)',
    commentPlaceholder: 'What stood out — for better or worse …',
    submit: 'Send rating',
    later: 'Later',
    sending: 'Sending …',
    thanksTitle: 'Thank you!',
    thanksSub: 'We\'re passing your feedback to the hotel.',
    close: 'Close',
    starHint: 'Tap a star',
    errorPrefix: 'Failed to send',
  },
  fr: {
    title: 'Comment était votre séjour ?',
    sub: `Votre avis aide ${hotelName} à s'améliorer.`,
    commentLabel: 'Un mot pour nous ? (facultatif)',
    commentPlaceholder: 'Ce qui vous a plu — ou pas …',
    submit: 'Envoyer',
    later: 'Plus tard',
    sending: 'Envoi …',
    thanksTitle: 'Merci !',
    thanksSub: 'Nous transmettons votre retour à l\'hôtel.',
    close: 'Fermer',
    starHint: 'Touchez une étoile',
    errorPrefix: 'Échec de l\'envoi',
  },
  es: {
    title: '¿Cómo fue tu estancia?',
    sub: `Tu opinión ayuda a ${hotelName} a mejorar.`,
    commentLabel: '¿Algo que debamos saber? (opcional)',
    commentPlaceholder: 'Lo que más te gustó o faltó …',
    submit: 'Enviar valoración',
    later: 'Más tarde',
    sending: 'Enviando …',
    thanksTitle: '¡Gracias!',
    thanksSub: 'Estamos enviando tu opinión al hotel.',
    close: 'Cerrar',
    starHint: 'Toca una estrella',
    errorPrefix: 'Fallo al enviar',
  },
};

const L = STRINGS[lang] ?? STRINGS.en;
---

<div
  class="poststay-overlay"
  x-show="postStayOpen"
  x-cloak
  x-transition.opacity
  @click.self="postStayDismiss()"
  role="dialog"
  aria-modal="true"
  aria-labelledby="poststay-title"
>
  <div class="poststay-sheet" x-transition>
    <button
      type="button"
      class="poststay-close"
      @click="postStayDismiss()"
      aria-label={L.close}
    >×</button>

    <template x-if="!postStayDone">
      <div class="poststay-form">
        <div class="poststay-eyebrow">
          <span class="poststay-eyebrow-shapes">
            <span class="circle"></span>
            <span class="square"></span>
            <span class="triangle"></span>
          </span>
          <span>retaha</span>
        </div>

        <h2 id="poststay-title" class="poststay-title">{L.title}</h2>
        <p class="poststay-sub">{L.sub}</p>

        <div
          class="poststay-stars"
          role="radiogroup"
          aria-label={L.starHint}
        >
          <template x-for="n in [1,2,3,4,5]" :key="n">
            <button
              type="button"
              class="poststay-star"
              :class="{ 'is-on': postStayRating >= n, 'is-hover': postStayHover >= n }"
              :aria-checked="postStayRating === n"
              role="radio"
              @click="postStayRating = n"
              @mouseenter="postStayHover = n"
              @mouseleave="postStayHover = 0"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <polygon points="12,2 15,9.5 23,9.5 16.5,14.5 19,22 12,17 5,22 7.5,14.5 1,9.5 9,9.5"/>
              </svg>
            </button>
          </template>
        </div>

        <label class="poststay-field">
          <span class="poststay-field-label">{L.commentLabel}</span>
          <textarea
            class="poststay-textarea"
            x-model="postStayComment"
            rows="3"
            maxlength="2000"
            placeholder={L.commentPlaceholder}
          ></textarea>
        </label>

        <template x-if="postStayError">
          <div class="poststay-error" x-text="postStayError"></div>
        </template>

        <div class="poststay-actions">
          <button
            type="button"
            class="poststay-btn-later"
            @click="postStayDismiss()"
            :disabled="postStaySubmitting"
          >{L.later}</button>
          <button
            type="button"
            class="poststay-btn-submit"
            :disabled="!postStayRating || postStaySubmitting"
            @click="postStaySubmit()"
            x-text={`postStaySubmitting ? ${JSON.stringify(L.sending)} : ${JSON.stringify(L.submit)}`}
          ></button>
        </div>
      </div>
    </template>

    <template x-if="postStayDone">
      <div class="poststay-thanks">
        <div class="poststay-thanks-icon">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 24 L20 34 L38 14"/>
          </svg>
        </div>
        <h2 class="poststay-title">{L.thanksTitle}</h2>
        <p class="poststay-sub">{L.thanksSub}</p>
        <button
          type="button"
          class="poststay-btn-submit"
          style="margin-top:24px"
          @click="postStayOpen = false"
        >{L.close}</button>
      </div>
    </template>
  </div>
</div>

<style>
  .poststay-overlay {
    position: fixed; inset: 0; z-index: 1100;
    background: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    display: flex; align-items: flex-end; justify-content: center;
    padding: 0;
    backdrop-filter: blur(4px);
  }
  @media (min-width: 640px) {
    .poststay-overlay { align-items: center; padding: 24px; }
  }
  .poststay-sheet {
    position: relative;
    width: 100%; max-width: 480px;
    background: var(--theme-bg-primary);
    padding: 28px 24px 32px;
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.18);
  }
  @media (min-width: 640px) {
    .poststay-sheet { padding: 32px 32px 36px; }
  }
  .poststay-close {
    position: absolute; top: 12px; right: 12px;
    width: 40px; height: 40px;
    background: transparent; border: none;
    font-size: 28px; line-height: 1; color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    cursor: pointer;
  }
  .poststay-close:hover { color: var(--theme-text-primary); }
  .poststay-eyebrow {
    display: flex; align-items: center; gap: 8px;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--theme-accent); font-weight: 500;
    margin-bottom: 16px;
  }
  .poststay-eyebrow-shapes { display: inline-flex; gap: 4px; align-items: center; }
  .poststay-eyebrow-shapes .circle  { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .poststay-eyebrow-shapes .square  { width: 6px; height: 6px; background: currentColor; }
  .poststay-eyebrow-shapes .triangle{ width: 0; height: 0; border-left: 3px solid transparent; border-right: 3px solid transparent; border-bottom: 6px solid currentColor; }
  .poststay-title {
    font-size: 24px; font-weight: 300; letter-spacing: -0.02em;
    line-height: 1.2; margin: 0 0 8px 0; color: var(--theme-text-primary);
  }
  .poststay-sub {
    font-size: 14px; line-height: 1.5; color: color-mix(in srgb, var(--theme-text-primary) 0.6, transparent);
    margin: 0 0 24px 0;
  }
  .poststay-stars {
    display: flex; gap: 8px; justify-content: center;
    margin: 8px 0 24px 0;
  }
  .poststay-star {
    width: 48px; height: 48px;       /* ≥40px tap target (mobile-first) */
    background: transparent; border: none; padding: 4px;
    color: color-mix(in srgb, var(--theme-text-primary) 0.18, transparent);
    cursor: pointer;
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .poststay-star svg { width: 100%; height: 100%; display: block; }
  .poststay-star.is-on    { color: #FFB400; }
  .poststay-star.is-hover { color: #FFB400; transform: scale(1.08); }
  .poststay-star:focus-visible { outline: 2px solid var(--theme-accent); outline-offset: 2px; }
  .poststay-field { display: block; margin-bottom: 20px; }
  .poststay-field-label {
    display: block; font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    margin-bottom: 8px; letter-spacing: 0.02em;
  }
  .poststay-textarea {
    width: 100%; box-sizing: border-box;
    padding: 12px; font-family: inherit; font-size: 14px; line-height: 1.5;
    border: 1px solid var(--theme-border); background: var(--theme-bg-secondary); color: var(--theme-text-primary);
    resize: vertical; min-height: 80px;
  }
  .poststay-textarea:focus { outline: none; border-color: var(--theme-text-primary); background: var(--theme-bg-primary); }
  .poststay-error {
    padding: 10px 12px; background: rgba(220, 53, 69, 0.08);
    color: #B00020; font-size: 13px; margin-bottom: 16px;
  }
  .poststay-actions { display: flex; gap: 12px; align-items: stretch; }
  .poststay-btn-later, .poststay-btn-submit {
    flex: 1; padding: 14px 16px;
    font-family: inherit; font-size: 14px; font-weight: 500;
    letter-spacing: 0.02em; cursor: pointer;
    border: none; transition: opacity 0.15s ease, background 0.15s ease;
    min-height: 48px;
  }
  .poststay-btn-later {
    background: transparent; color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    border: 1px solid var(--theme-border);
  }
  .poststay-btn-later:hover:not(:disabled) { color: var(--theme-text-primary); border-color: var(--theme-text-primary); }
  .poststay-btn-submit {
    background: var(--theme-bg-anthrazit); color: var(--theme-bg-primary);
  }
  .poststay-btn-submit:hover:not(:disabled) { background: var(--theme-accent); }
  .poststay-btn-submit:disabled, .poststay-btn-later:disabled { opacity: 0.4; cursor: not-allowed; }
  .poststay-thanks { text-align: center; padding: 16px 0 8px; }
  .poststay-thanks-icon {
    width: 64px; height: 64px; margin: 0 auto 16px;
    color: #00A86B;
  }
  .poststay-thanks-icon svg { width: 100%; height: 100%; }
</style>

<script is:inline define:vars={{ stayId, hasFeedback: false }}>
  // Cooldown-Check via localStorage. Wenn Gast "Später" gewählt hat, 24h warten.
  // Schreibt nicht direkt in Alpine — setzt window-Global, das guestPage liest.
  (function() {
    try {
      const key = 'retaha_poststay_dismissed_' + stayId;
      const raw = localStorage.getItem(key);
      const last = raw ? parseInt(raw, 10) : 0;
      const now = Date.now();
      const COOLDOWN_MS = 24 * 60 * 60 * 1000;
      window.__RETAHA_POSTSTAY__ = {
        stayId,
        shouldAutoOpen: !raw || (now - last) > COOLDOWN_MS,
      };
    } catch (_) {
      window.__RETAHA_POSTSTAY__ = { stayId, shouldAutoOpen: true };
    }
  })();
</script>
