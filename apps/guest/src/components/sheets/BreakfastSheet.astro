  mustard: { de: 'Senf', en: 'Mustard', fr: 'Moutarde', es: 'Mostaza' }[lang],
  sesame: { de: 'Sesam', en: 'Sesame', fr: 'Sésame', es: 'Sésamo' }[lang],
  sulfites: { de: 'Sulfite', en: 'Sulphites', fr: 'Sulfites', es: 'Sulfitos' }[lang],
  lupins: { de: 'Lupinen', en: 'Lupin', fr: 'Lupin', es: 'Altramuces' }[lang],
  molluscs: { de: 'Weichtiere', en: 'Molluscs', fr: 'Mollusques', es: 'Moluscos' }[lang],
