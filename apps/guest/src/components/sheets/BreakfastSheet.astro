// Localize menu items
const localizedItems = menuItems.map(item => ({
  id: item.id,
  category: item.category || 'Allgemein',
  name: item[`name_${lang}`] || item.name_de,
  description: item[`description_${lang}`] || item.description_de || '',
  allergens: ALLERGEN_KEYS.filter(key => item[`contains_${key}`]),
  isVegetarian: item.is_vegetarian,
  isVegan: item.is_vegan,
  isOrganic: item.is_organic,
}));

const sheetData = {
  stayRangeDates,        // alle ISO-Datums im Aufenthalt
  allSlots,              // alle möglichen Slots (Server-Zeitfenster)
  startTime,             // für Anzeige
  endTime,
  peopleOptions,
  tableOptions,
  labels: l,
  accessToken,
  existingBooking,
  lang,                  // für Locale-Formatting client-side
  reservationEnabled,
  includedText,
  location,
  menuItems: localizedItems,
  allergenLabels,
  allergenKeys: ALLERGEN_KEYS,
};
---

<Sheet
  id="breakfast"
  eyebrow={l.eyebrow}
  title={reservationEnabled ? l.title : l.infoTitle}
  titleAccent={reservationEnabled ? l.titleAccent : l.infoTitleAccent}
  subtitle={reservationEnabled ? l.subtitle : l.infoSubtitle}
>
  <div x-data={`breakfastForm(${JSON.stringify(sheetData)})`}>

    <!-- Tab Navigation: nur sichtbar wenn Menu vorhanden -->
    <div class="sheet-tabs" x-show="menuItems.length > 0">
      <button type="button" class="sheet-tab"
        :class="{ active: activeTab === 'main' }"
        @click="activeTab = 'main'">
        <span x-text="reservationEnabled ? labels.menuTabReservation : labels.menuTabInfo"></span>
      </button>
      <button type="button" class="sheet-tab"
        :class="{ active: activeTab === 'menu' }"
        @click="activeTab = 'menu'">
        <span x-text="labels.menuTabMenu"></span>
      </button>
    </div>

    <!-- Main tab: existing views -->
    <div x-show="activeTab === 'main'">

    <!-- View 1: Existing booking status -->
    <template x-if="view === 'status'">
      <div class="booking-status">
        <div class="booking-status-icon" :class="statusInfo.iconClass">
          <template x-if="statusInfo.icon === 'check'">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </template>
          <template x-if="statusInfo.icon === 'clock'">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="9"/>
              <polyline points="12 7 12 12 16 14"/>
            </svg>
          </template>
          <template x-if="statusInfo.icon === 'cross'">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </template>
        </div>

        <h3 class="booking-status-title" x-text="statusInfo.title"></h3>
        <p class="booking-status-sub" x-text="statusInfo.sub"></p>

        <div class="booking-summary">
          <div class="booking-summary-row">
            <span class="label" x-text="labels.bookingDate"></span>
            <span class="value" x-text="formatDate(existingBooking.details.date)"></span>
          </div>
          <div class="booking-summary-row">
            <span class="label" x-text="labels.bookingTime"></span>
            <span class="value" x-text="existingBooking.details.time"></span>
          </div>
          <div class="booking-summary-row">
            <span class="label" x-text="labels.bookingPeople"></span>
            <span class="value" x-text="existingBooking.details.people"></span>
          </div>
          <div class="booking-summary-row" x-show="existingBooking.details.table_preference && existingBooking.details.table_preference !== 'any'">
            <span class="label" x-text="labels.bookingTable"></span>
            <span class="value" x-text="tableLabelFor(existingBooking.details.table_preference)"></span>
          </div>
        </div>

        <button
          type="button"
          class="bauhaus-button bauhaus-button--secondary"
          @click="startRebook()"
          x-show="existingBooking.status === 'cancelled' || existingBooking.status === 'confirmed'"
          x-text="labels.rebookBtn"
        ></button>
      </div>
    </template>

    <!-- View 2: Form -->
    <template x-if="view === 'form'">
      <div>
        <template x-if="availableDates.length === 0">
          <div class="sheet-disabled-message">
            <p x-text="labels.noSlotsAvailable"></p>
          </div>
        </template>

        <form class="booking-form" @submit.prevent="submitBooking()" x-show="availableDates.length > 0">

        <!-- When -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.whenLabel"></div>
          <div class="booking-chip-row">
            <template x-for="(date, i) in availableDates" :key="date.iso">
              <button type="button" class="bauhaus-pill"
                :data-active="form.date === date.iso"
                @click="setDate(date.iso)">
                <span x-text="dateLabels[i]"></span>
                <span class="bauhaus-pill-sub" x-text="formatDateShort(date.iso)"></span>
              </button>
            </template>
          </div>
        </div>

        <!-- People -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.peopleLabel"></div>
          <div class="booking-chip-row">
            <template x-for="n in peopleOptions" :key="n">
              <button type="button" class="bauhaus-pill"
                :data-active="form.people === n"
                @click="form.people = n"
                x-text="n"></button>
            </template>
            <button type="button" class="bauhaus-pill"
              :data-active="form.people > 4"
              @click="form.people = 5">
              5+
            </button>
          </div>
        </div>

        <!-- Time -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.timeLabel"></div>
          <div class="booking-chip-row">
            <template x-for="slot in slots" :key="slot">
              <button type="button" class="bauhaus-pill"
                :data-active="form.time === slot"
                @click="form.time = slot"
                x-text="slot"></button>
            </template>
          </div>
        </div>

        <!-- Table -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.tableLabel"></div>
          <div class="booking-chip-row">
            <template x-for="opt in tableOptions" :key="opt.value">
              <button type="button" class="bauhaus-pill"
                :data-active="form.table_preference === opt.value"
                @click="form.table_preference = opt.value"
                x-text="opt.label"></button>
            </template>
          </div>
        </div>

        <!-- Notes -->
        <div class="booking-section">
          <div class="booking-section-label" x-text="labels.notesLabel"></div>
          <textarea class="bauhaus-textarea"
            :placeholder="labels.notesPlaceholder"
            x-model="form.notes"></textarea>
        </div>

        <div x-show="errorMsg" class="booking-error" x-text="errorMsg"></div>

        <button type="submit" class="bauhaus-button bauhaus-button--primary bauhaus-button--block"
          :disabled="!canSubmit || submitting"
          x-text="submitting ? labels.submitting : labels.submit"></button>
        </form>
      </div>
    </template>

    <!-- View 3: Info-Mode (Reservation disabled) -->
    <template x-if="view === 'info'">
      <div class="booking-info">
        <div class="info-row">
          <div class="info-label" x-text="labels.infoTimeLabel"></div>
          <div class="info-value" x-text="labels.infoTimeValue"></div>
        </div>
        <div class="info-row">
          <div class="info-label" x-text="labels.infoLocationLabel"></div>
          <div class="info-value" x-text="location"></div>
        </div>
        <div class="info-row info-row-full" x-show="includedText">
          <div class="info-label" x-text="labels.infoIncludedLabel"></div>
          <div class="info-value info-value-multiline" x-text="includedText"></div>
        </div>
      </div>
    </template>

    </div>

    <!-- Menu tab: Speisekarte -->
    <div x-show="activeTab === 'menu'">

      <!-- Allergen-Filter -->
      <div class="menu-filter-section" x-show="!filterCollapsed">
        <div class="menu-filter-title" x-text="labels.menuFilterTitle"></div>
        <p class="menu-filter-hint" x-text="labels.menuFilterHint"></p>
        <div class="menu-filter-chips">
          <template x-for="key in allergenKeys" :key="key">
            <button type="button" class="menu-filter-chip"
              :class="{ active: selectedAllergens.includes(key) }"
              @click="toggleAllergen(key)"
              x-text="allergenLabels[key]"></button>
          </template>
        </div>
        <button type="button" class="menu-filter-toggle"
          @click="clearAllergenFilter()"
          x-show="selectedAllergens.length > 0"
          x-text="labels.menuFilterHideShow"></button>
      </div>

      <!-- Menu items grouped by category -->
      <template x-if="menuItems.length === 0">
        <div class="menu-empty" x-text="labels.menuEmpty"></div>
      </template>

      <template x-for="(items, category) in groupedMenuItems" :key="category">
        <div class="menu-category">
          <div class="menu-category-title" x-text="category"></div>
          <div class="menu-items">
            <template x-for="item in items" :key="item.id">
              <div class="menu-item">
                <div class="menu-item-header">
                  <div class="menu-item-name" x-text="item.name"></div>
                  <div class="menu-item-flags">
                    <template x-if="item.isVegan">
                      <span class="menu-flag" x-text="labels.menuFlagVegan"></span>
                    </template>
                    <template x-if="!item.isVegan && item.isVegetarian">
                      <span class="menu-flag" x-text="labels.menuFlagVegetarian"></span>
                    </template>
                    <template x-if="item.isOrganic">
                      <span class="menu-flag organic" x-text="labels.menuFlagOrganic"></span>
                    </template>
                  </div>
                </div>
                <div class="menu-item-description" x-text="item.description" x-show="item.description"></div>

                <!-- Warnung nur wenn Allergen-Match -->
                <template x-if="getMatchingAllergens(item).length > 0">
                  <div class="menu-item-warning">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 9v4m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.74-3l-6.93-12a2 2 0 0 0-3.48 0L3.34 16a2 2 0 0 0 1.73 3z"/>
                    </svg>
                    <span>
                      <span x-text="labels.menuWarningPrefix"></span>
                      <span x-text="getMatchingAllergens(item).map(k => allergenLabels[k]).join(', ')"></span>
                    </span>
                  </div>
                </template>

                <!-- Generelle Allergen-Liste (nur wenn keine speziellen Allergene markiert) -->
                <template x-if="item.allergens.length > 0 && selectedAllergens.length === 0">
                  <div class="menu-item-allergens">
                    <span x-text="labels.menuAllergensPrefix"></span>
                    <span x-text="item.allergens.map(k => allergenLabels[k]).join(', ')"></span>
                  </div>
                </template>
              </div>
            </template>
          </div>
        </div>
      </template>

      <!-- Disclaimer -->
      <div class="menu-disclaimer" x-text="labels.menuDisclaimer"></div>
    </div>

  </div>
</Sheet>

