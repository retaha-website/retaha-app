---
import Sheet from '../Sheet.astro';

interface Props {
  lang: 'de' | 'en' | 'fr' | 'es';
  startTime: string;       // "07:30:00"
  endTime: string;         // "10:30:00"
  slotMinutes: number;     // 30
  location: string;        // "im Wintergarten"
  accessToken: string;
  existingBooking: any | null;  // null if none, else booking object
  conciergeName: string;
  checkIn: string;   // ISO date "2026-05-21"
  checkOut: string;  // ISO date "2026-05-24"
  reservationEnabled: boolean;
  includedText: string;
  menuItems: any[];
}
const { lang, startTime, endTime, slotMinutes, location, accessToken, existingBooking, conciergeName, checkIn, checkOut, reservationEnabled, includedText, menuItems } = Astro.props;

// Local-date ISO string (YYYY-MM-DD) — avoids UTC drift from .toISOString()
const toLocalIso = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

console.log('Today ISO:', toLocalIso(new Date()));

// Generate time slots
function generateSlots(start: string, end: string, step: number): string[] {
  const slots: string[] = [];
  const [sH, sM] = start.substring(0, 5).split(':').map(Number);
  const [eH, eM] = end.substring(0, 5).split(':').map(Number);
  const startMin = sH * 60 + sM;
  const endMin = eH * 60 + eM;
  for (let t = startMin; t <= endMin - step; t += step) {
    const h = Math.floor(t / 60);
    const m = t % 60;
    slots.push(`${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`);
  }
  return slots;
}
// Send raw stay range to client — filtering happens live in Alpine
const stayRangeDates: { iso: string }[] = [];
{
  const cursor = new Date(checkIn);
  const stayEnd = new Date(checkOut);
  while (cursor <= stayEnd) {
    stayRangeDates.push({ iso: toLocalIso(cursor) });
    cursor.setDate(cursor.getDate() + 1);
  }
}

// Generate ALL possible time slots (no time filtering server-side)
const allSlots = generateSlots(startTime, endTime, slotMinutes);

