const l = labels[lang];

// Date formatting helper
const localeMap: Record<string, string> = { de: 'de-DE', en: 'en-GB', fr: 'fr-FR', es: 'es-ES' };
const dateFmt = (iso: string) => new Date(iso).toLocaleDateString(localeMap[lang], { weekday: 'long', day: 'numeric', month: 'short' });

const peopleOptions = [1, 2, 3, 4];
const tableOptions = [
  { value: 'inside', label: l.tableInside },
  { value: 'outside', label: l.tableOutside },
  { value: 'garden', label: l.tableGarden },
  { value: 'any', label: l.tableAny },
];

// Serialize for client-side use
// Allergen labels for current language
const allergenLabels: Record<string, string> = {
  gluten: { de: 'Gluten', en: 'Gluten', fr: 'Gluten', es: 'Gluten' }[lang],
  crustaceans: { de: 'Krebstiere', en: 'Crustaceans', fr: 'Crustacés', es: 'Crustáceos' }[lang],
  eggs: { de: 'Eier', en: 'Eggs', fr: 'Œufs', es: 'Huevos' }[lang],
  fish: { de: 'Fisch', en: 'Fish', fr: 'Poisson', es: 'Pescado' }[lang],
