---
import Sheet from '../Sheet.astro';
import QRCode from 'qrcode';

interface Props {
  hotelId: string;
  ssid: string;
  password: string;
  speedMbits: number;
  lang: 'de' | 'en' | 'fr' | 'es';
}
const { hotelId, ssid, password, speedMbits, lang } = Astro.props;

// Generate QR inline — no separate API call needed
const escapeWifi = (s: string) => s.replace(/([\\;,":])/g, '\\$1');
const qrDataUrl: string | null = ssid ? await QRCode.toDataURL(
  `WIFI:T:WPA;S:${escapeWifi(ssid)};P:${escapeWifi(password ?? '')};;`,
  { errorCorrectionLevel: 'M', margin: 2, width: 200,
    color: { dark: '#1A1A1A', light: '#FFFFFF' } }
).catch(() => null) : null;

const labels = {
  de: {
    eyebrow: 'Verbindung',
    title: 'WLAN ist',
    titleAccent: ' bereit',
    subtitle: 'Schnell verbunden — direkt loslegen.',
    networkLabel: 'Netzwerk',
    passwordLabel: 'Passwort',
    speedLabel: 'Geschwindigkeit',
    copy: 'Kopieren',
    qrHint: 'Mit Handy-Kamera scannen für automatische Verbindung.',
  },
  en: {
    eyebrow: 'Connection',
    title: 'Wi-Fi is',
    titleAccent: ' ready',
    subtitle: 'Connect fast — get started.',
    networkLabel: 'Network',
    passwordLabel: 'Password',
    speedLabel: 'Speed',
    copy: 'Copy',
    qrHint: 'Scan with phone camera to auto-connect.',
  },
  fr: {
    eyebrow: 'Connexion',
    title: 'Wi-Fi est',
    titleAccent: ' prêt',
    subtitle: 'Connexion rapide — c\'est parti.',
    networkLabel: 'Réseau',
    passwordLabel: 'Mot de passe',
    speedLabel: 'Vitesse',
    copy: 'Copier',
    qrHint: 'Scannez avec la caméra pour vous connecter automatiquement.',
  },
  es: {
    eyebrow: 'Conexión',
    title: 'Wi-Fi está',
    titleAccent: ' listo',
    subtitle: 'Conéctate rápido — empieza ya.',
    networkLabel: 'Red',
    passwordLabel: 'Contraseña',
    speedLabel: 'Velocidad',
    copy: 'Copiar',
    qrHint: 'Escanea con la cámara para conectar automáticamente.',
  },
};
const l = labels[lang];
---

<Sheet id="wifi" eyebrow={l.eyebrow} title={l.title} titleAccent={l.titleAccent} subtitle={l.subtitle}>
  <div class="ws-wifi">

    <div class="ws-wifi__rows">

      <!-- Row: Network -->
      <div class="ws-wifi__row">
        <span class="ws-wifi__num" aria-hidden="true">01</span>
        <div class="ws-wifi__col">
          <div class="ws-wifi__label">{l.networkLabel}</div>
          <div class="ws-wifi__value">{ssid}</div>
        </div>
        <button class="wifi-copy ws-wifi__copy" type="button" @click={`copyText('${ssid}', $event)`} aria-label={l.copy}>
          <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>

      <!-- Rhombus divider (maison only) -->
      <div class="ws-wifi__rhombus" aria-hidden="true"></div>

      <!-- Row: Password -->
      <div class="ws-wifi__row">
        <span class="ws-wifi__num" aria-hidden="true">02</span>
        <div class="ws-wifi__col">
          <div class="ws-wifi__label">{l.passwordLabel}</div>
          <div class="ws-wifi__value ws-wifi__value--pw">{password}</div>
        </div>
        <button class="wifi-copy ws-wifi__copy" type="button" @click={`copyText('${password}', $event)`} aria-label={l.copy}>
          <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>

      <!-- Row: Speed (no copy) -->
      <div class="ws-wifi__row ws-wifi__row--speed">
        <span class="ws-wifi__num" aria-hidden="true">03</span>
        <div class="ws-wifi__col">
          <div class="ws-wifi__label">{l.speedLabel}</div>
          <div class="ws-wifi__value">{speedMbits} Mbit/s</div>
        </div>
      </div>

    </div>

    <!-- QR section -->
    {qrDataUrl && (
      <div class="ws-wifi__qr">
        <p class="ws-wifi__qr-hint">{l.qrHint}</p>
        <div class="ws-wifi__qr-frame">
          <img src={qrDataUrl} alt="WiFi QR Code" width="160" height="160" />
        </div>
      </div>
    )}

  </div>
</Sheet>

<style>
  /* ── Shared base ────────────────────────────────────────────────── */
  .ws-wifi { padding: 0 2px; }

  .ws-wifi__rows { margin-bottom: 20px; }

  .ws-wifi__row {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--guest-border);
  }
  .ws-wifi__row:last-child { border-bottom: none; }

  .ws-wifi__num { display: none; }
  .ws-wifi__rhombus { display: none; }

  .ws-wifi__col { flex: 1; min-width: 0; }
  .ws-wifi__label {
    font-family: var(--guest-font-mono);
    font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--guest-ink-faint); margin-bottom: 3px;
  }
  .ws-wifi__value {
    font-family: var(--guest-font-mono);
    font-size: 15px; font-weight: 500; color: var(--guest-ink);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  /* Fix 1: accent-tinted copy buttons (light accent fill ~10% + accent icon) */
  :global(.ws-wifi .wifi-copy) {
    background: color-mix(in srgb, var(--guest-accent) 10%, transparent);
    border: 1px solid var(--guest-border);
    color: var(--guest-accent);
  }
  :global(.ws-wifi .wifi-copy:hover) {
    background: var(--guest-hover-soft, var(--guest-accent-soft));
    color: var(--guest-ink);
    border-color: var(--guest-border-strong);
  }
  :global(.ws-wifi .wifi-copy.copied) {
    background: var(--guest-accent);
    border-color: var(--guest-accent);
    color: #fff;
  }

  .ws-wifi__qr { text-align: center; }
  .ws-wifi__qr-hint {
    font-family: var(--guest-font-mono);
    font-size: 10px; letter-spacing: 0.06em;
    color: var(--guest-ink-muted); margin: 0 0 14px;
  }
  .ws-wifi__qr-frame {
    display: inline-block; padding: 12px;
    background: #fff; border: 1px solid var(--guest-border);
  }
  .ws-wifi__qr-frame img { display: block; width: 160px; height: 160px; }

  /* ─────────────────────────────────────────────────────────────── */
  /* BAUHAUS                                                         */
  /* ─────────────────────────────────────────────────────────────── */
  :global([data-theme="bauhaus"]) .ws-wifi__rows {
    background: var(--guest-bg-card);
    border: 1px solid var(--guest-border);
    border-radius: var(--guest-radius);
    overflow: hidden; padding: 0 16px;
  }
  :global([data-theme="bauhaus"]) .ws-wifi__row { padding: 14px 0; }
  :global([data-theme="bauhaus"]) .ws-wifi__value--pw {
    font-family: var(--guest-font-mono);
    letter-spacing: 0.04em;
  }
  :global([data-theme="bauhaus"]) .ws-wifi .wifi-copy:hover {
    background: var(--guest-hover); color: var(--guest-ink);
    border-color: var(--guest-hover);
  }
  :global([data-theme="bauhaus"]) .ws-wifi__qr-frame {
    border-radius: var(--guest-radius-sm);
  }
  /* Bauhaus sheet header tweaks */
  :global([data-theme="bauhaus"] #wifi .sheet-title) {
    font-family: var(--guest-font-display);
    font-weight: 500; letter-spacing: -0.02em;
  }

  /* ─────────────────────────────────────────────────────────────── */
  /* EDITORIAL                                                       */
  /* ─────────────────────────────────────────────────────────────── */
  :global([data-theme="editorial"]) .ws-wifi__num {
    display: block;
    font-family: var(--guest-font-display);
    font-style: italic; font-size: 22px; font-weight: 300;
    color: var(--guest-accent); flex-shrink: 0; width: 28px; line-height: 1;
  }
  :global([data-theme="editorial"]) .ws-wifi__row {
    padding: 20px 0; gap: 16px;
  }
  :global([data-theme="editorial"]) .ws-wifi__label {
    font-family: var(--guest-font-mono);
    font-size: 9px; text-transform: uppercase; letter-spacing: 0.10em;
    color: var(--guest-ink-muted); margin-bottom: 5px;
  }
  :global([data-theme="editorial"]) .ws-wifi__value {
    font-family: var(--guest-font-display);
    font-style: italic; font-size: 20px; font-weight: 400;
    color: var(--guest-ink); white-space: normal;
    border-bottom: 1px solid var(--guest-accent);
    display: inline-block; padding-bottom: 2px;
  }
  :global([data-theme="editorial"]) .ws-wifi .wifi-copy {
    background: color-mix(in srgb, var(--guest-accent) 10%, transparent); border-color: var(--guest-border);
    color: var(--guest-accent);
  }
  :global([data-theme="editorial"]) .ws-wifi .wifi-copy:hover {
    background: var(--guest-accent-soft);
  }
  :global([data-theme="editorial"]) .ws-wifi__qr {
    border-top: 1px solid var(--guest-border);
    padding-top: 24px; margin-top: 8px;
  }
  :global([data-theme="editorial"]) .ws-wifi__qr-hint {
    font-family: var(--guest-font-display);
    font-style: italic; font-size: 13px; letter-spacing: 0;
  }
  :global([data-theme="editorial"]) .ws-wifi__qr-frame {
    border: none; background: transparent; padding: 0;
  }
  :global([data-theme="editorial"]) .ws-wifi__qr-frame img {
    border: 1px solid var(--guest-border);
  }
  /* Editorial sheet header */
  :global([data-theme="editorial"] #wifi .sheet-title) {
    font-family: var(--guest-font-display);
    font-style: italic; font-weight: 400;
    letter-spacing: -0.01em;
  }
  :global([data-theme="editorial"] #wifi .sheet-subtitle) {
    font-family: var(--guest-font-display);
    font-style: italic;
  }

  /* ─────────────────────────────────────────────────────────────── */
  /* MAISON                                                          */
  /* ─────────────────────────────────────────────────────────────── */
  :global([data-theme="maison"]) .ws-wifi { text-align: center; }
  :global([data-theme="maison"]) .ws-wifi__rows {
    border: 1px solid var(--guest-accent);
    margin: 0 4px 20px; padding: 4px 0;
  }
  :global([data-theme="maison"]) .ws-wifi__row {
    justify-content: center; padding: 16px 20px; border-bottom: none;
  }
  :global([data-theme="maison"]) .ws-wifi__row--speed { display: none; }
  :global([data-theme="maison"]) .ws-wifi__col { text-align: center; flex: none; }
  :global([data-theme="maison"]) .ws-wifi__label {
    font-family: var(--guest-font-mono);
    font-size: 9px; letter-spacing: 0.30em; text-transform: uppercase;
    color: var(--guest-accent); margin-bottom: 6px;
  }
  :global([data-theme="maison"]) .ws-wifi__value {
    font-family: var(--guest-font-display);
    font-size: 18px; letter-spacing: 0.05em; font-weight: normal;
    color: var(--guest-ink); white-space: normal;
  }
  :global([data-theme="maison"]) .ws-wifi__rhombus {
    display: block; width: 6px; height: 6px;
    background: var(--guest-accent);
    transform: rotate(45deg); margin: 0 auto;
  }
  :global([data-theme="maison"]) .ws-wifi .wifi-copy {
    background: color-mix(in srgb, var(--guest-accent) 10%, transparent); border: 1px solid var(--guest-accent);
    border-radius: 0; color: var(--guest-accent);
  }
  :global([data-theme="maison"]) .ws-wifi .wifi-copy:hover {
    background: var(--guest-accent); color: var(--guest-bg-card);
    border-color: var(--guest-accent);
  }
  :global([data-theme="maison"]) .ws-wifi__qr { margin: 0 4px; }
  :global([data-theme="maison"]) .ws-wifi__qr-frame {
    border: 1px solid var(--guest-accent);
    padding: 12px;
  }
  /* Maison sheet header */
  :global([data-theme="maison"] #wifi .sheet-title) {
    font-family: var(--guest-font-display);
    letter-spacing: 0.15em; font-weight: 400;
  }
  :global([data-theme="maison"] #wifi .sheet-eyebrow) {
    letter-spacing: 0.20em;
  }
  :global([data-theme="maison"] #wifi .sheet-subtitle) {
    font-family: var(--guest-font-display);
    font-style: italic;
  }
</style>
