---
interface Props {
  id: string;
  eyebrow?: string;
  title: string;
  titleAccent?: string;
  subtitle?: string;
}
const { id, eyebrow, title, titleAccent, subtitle } = Astro.props;
---

<div
  class="sheet-overlay"
  :class={`{ open: activeSheet === '${id}' }`}
  @click.self={`closeSheet()`}
  x-show={`activeSheet === '${id}'`}
  x-transition.opacity
  style="display: none;"
>
  <div
    class="sheet"
    :class={`{ dragging: sheetIsDragging }`}
    :style={`activeSheet === '${id}' && sheetDragOffset > 0 ? \`transform: translateY(\${sheetDragOffset}px)\` : ''`}
  >
    <div
      class="sheet-handle-area"
      @pointerdown="startSheetDrag($event)"
      @touchstart.passive="startSheetDragTouch($event)"
    >
      <div class="sheet-handle"></div>
    </div>

    <button class="sheet-close" @click="closeSheet()" type="button" aria-label="Schließen">×</button>

    <div class="sheet-header">
      {eyebrow && <div class="sheet-eyebrow">{eyebrow}</div>}
      <h2 class="sheet-title">
        {title}{titleAccent && <span class="accent">{titleAccent}</span>}<span class="accent">.</span>
      </h2>
      {subtitle && <p class="sheet-subtitle">{subtitle}</p>}
    </div>

    <div class="sheet-body">
      <slot />
    </div>
  </div>
</div>
