---
import PhoneScreen from './PhoneScreen.astro';
---

<div class="phone-frame" aria-label="Telefon-Vorschau">
  <div class="phone-frame__notch" aria-hidden="true"></div>
  <div class="phone-frame__screen-area">
    <div class="phone-frame__content" id="phoneContent">
      <PhoneScreen />
    </div>
  </div>
  <div class="phone-frame__home-bar" aria-hidden="true"></div>
</div>

<style>
  .phone-frame {
    width: 300px;
    height: 616px;
    background: #0A0A0A;
    border-radius: 37px;
    padding: 12px;
    position: relative;
    box-shadow:
      0 24px 64px rgba(10,10,10,0.22),
      0 6px 18px rgba(10,10,10,0.1),
      inset 0 0 0 1.5px rgba(255,255,255,0.06);
  }
  :global([data-theme="dark"]) .phone-frame {
    background: #1C1C1E;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6), inset 0 0 0 1.5px rgba(255,255,255,0.08);
  }
  .phone-frame__notch {
    position: absolute; top: 15px; left: 50%;
    transform: translateX(-50%);
    width: 100px; height: 28px;
    background: #0A0A0A;
    border-radius: 14px; z-index: 10;
  }
  :global([data-theme="dark"]) .phone-frame__notch { background: #1C1C1E; }
  .phone-frame__screen-area {
    width: 100%; height: 100%;
    background: white; border-radius: 27px; overflow: hidden; position: relative;
  }
  .phone-frame__content {
    width: 100%; height: 100%;
    transform-origin: center center;
    transition: transform 400ms ease-out;
  }
  .phone-frame__content.is-zoomed {
    /* transform set inline by JS */
  }
  .phone-frame__home-bar {
    position: absolute; bottom: 6px; left: 50%;
    transform: translateX(-50%);
    width: 100px; height: 4px;
    background: rgba(255,255,255,0.3); border-radius: 3px; z-index: 10;
  }
  @media (max-width: 480px) {
    .phone-frame { width: 260px; height: 533px; border-radius: 32px; }
  }
</style>
