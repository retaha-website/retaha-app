---
interface Props {
  showcaseUrl: string;
}
const { showcaseUrl } = Astro.props;
---

<div class="phone-frame" aria-label="Telefon-Vorschau">
  <div class="phone-frame__screen-area">
    <iframe
      id="guestPreview"
      src={showcaseUrl}
      data-base-url={showcaseUrl}
      title="Gäste-Vorschau"
      class="phone-frame__iframe"
    ></iframe>
  </div>
</div>

<style>
  .phone-frame {
    width: 300px;
    height: 616px;
    background: #0A0A0A;
    border-radius: 37px;
    padding: 12px;
    position: relative;
    box-shadow:
      0 24px 64px rgba(10,10,10,0.22),
      0 6px 18px rgba(10,10,10,0.1),
      inset 0 0 0 1.5px rgba(255,255,255,0.06);
  }
  :global([data-theme="dark"]) .phone-frame {
    background: #1C1C1E;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6), inset 0 0 0 1.5px rgba(255,255,255,0.08);
  }
  .phone-frame__screen-area {
    width: 100%; height: 100%;
    background: white; border-radius: 27px; overflow: hidden; position: relative;
  }
  .phone-frame__iframe {
    position: absolute;
    top: 0;
    left: 0;
    /* 390px Content + ~20px Headroom: die native iframe-Scrollbar faellt in den
       overflow:hidden-Bereich der screen-area und ist damit unsichtbar. */
    width: 410px;
    height: 836px;
    border: none;
    display: block;
    transform: scale(0.7077);
    transform-origin: top left;
  }
  @media (max-width: 480px) {
    .phone-frame { width: 260px; height: 533px; border-radius: 32px; }
    .phone-frame__iframe { transform: scale(0.6051); height: 841px; }
  }
</style>
