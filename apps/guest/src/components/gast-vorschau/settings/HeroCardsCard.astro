---
// Hero-Karten-Box (Gast-Vorschau) — Liste der gast-sichtbaren Hero-Karten +
// Quick-Link zum Editor. Design 1:1 wie BrandLinkCard (Branding-Box): gleiche
// .settings-section / .brand-summary-Struktur. Read-only, hotel-skopiert.
import { createSupabaseServerInstance } from '@retaha/auth';

interface Props {
  hotelId: string;
  defaultLanguage?: string;
}
const { hotelId, defaultLanguage = 'de' } = Astro.props;
const BACKOFFICE_URL = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);
const { data: cards } = await client
  .from('hotel_action_cards')
  .select('id, card_type, eyebrow_de, eyebrow_i18n, title_de, title_i18n, is_published, sort_order')
  .eq('hotel_id', hotelId)
  .eq('is_published', true)
  .order('sort_order', { ascending: true });

// i18n-Resolver wie im Action-Card-Editor: title_i18n->'<lang>'->>'value'
// (verschachteltes { value, source, updated_at }). Fallback DE, dann Legacy-Spalte.
function pickI18n(value: any, lang: string): string {
  if (!value || typeof value !== 'object') return '';
  return value[lang]?.value || value['de']?.value || '';
}

const CARD_TYPE_LABELS: Record<string, string> = {
  external_link:   'Link',
  internal_action: 'Aktion',
  info:            'Info',
};

const list = ((cards ?? []) as any[]).map((c) => {
  const title   = pickI18n(c.title_i18n, defaultLanguage)   || c.title_de   || '(ohne Titel)';
  const eyebrow = pickI18n(c.eyebrow_i18n, defaultLanguage) || c.eyebrow_de || '';
  return {
    id: c.id,
    title,
    label: eyebrow || CARD_TYPE_LABELS[c.card_type] || c.card_type || '',
  };
});
---

<section class="settings-section">
  <div class="settings-section__head">
    <span class="settings-section__title">Hero-Karten</span>
    <span class="settings-section__num">04</span>
  </div>

  {list.length > 0 ? (
    <div class="brand-summary">
      {list.map((c) => (
        <div class="brand-summary__row">
          <span class="brand-summary__label">{c.label}</span>
          <span class="brand-summary__value">{c.title}</span>
        </div>
      ))}
    </div>
  ) : (
    <p class="hero-empty">Noch keine Hero-Karten.</p>
  )}

  <a href={`${BACKOFFICE_URL}/admin/action-cards`} class="brand-summary__link">→ Hero Karten bearbeiten</a>
</section>

<style>
  /* 1:1 aus BrandLinkCard (Branding-Box) übernommen — kein neues Visual-Vokabular. */
  .settings-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 24px 28px;
  }
  .settings-section__head {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;
  }
  .settings-section__title {
    font-family: 'Space Grotesk', sans-serif; font-size: 20px;
    letter-spacing: -0.01em; color: var(--ink); font-weight: 500;
  }
  .settings-section__num {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--ink-muted); letter-spacing: 0.14em;
  }
  .brand-summary { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .brand-summary__row {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 8px 12px; background: var(--bg-deep); border-radius: var(--r-sm);
  }
  .brand-summary__label {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.1em; color: var(--ink-muted); text-transform: uppercase;
    flex-shrink: 0;
  }
  .brand-summary__value {
    font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500;
    color: var(--ink); display: inline-flex; align-items: center; gap: 6px;
    text-align: right; min-width: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .hero-empty {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--ink-muted); line-height: 1.6; letter-spacing: 0.03em;
    margin: 0 0 20px;
  }
  .brand-summary__link {
    display: flex; align-items: center; justify-content: center;
    padding: 11px 16px; background: var(--ink); color: var(--bg);
    border-radius: var(--r-sm); text-decoration: none;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    font-weight: 500; letter-spacing: 0.12em; transition: all 200ms;
  }
  .brand-summary__link:hover { background: var(--te-yellow); color: #0A0A0A; }
</style>
