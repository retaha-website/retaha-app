---
interface Props {
  hotelId: string;
  enabledLanguages: string[];
  defaultLanguage: string;
}
const { hotelId, enabledLanguages, defaultLanguage } = Astro.props;

const LANGUAGES = [
  { code: 'de', label: 'deutsch',    flag: '🇩🇪' },
  { code: 'en', label: 'english',    flag: '🇬🇧' },
  { code: 'fr', label: 'français',   flag: '🇫🇷' },
  { code: 'es', label: 'español',    flag: '🇪🇸' },
  { code: 'it', label: 'italiano',   flag: '🇮🇹' },
  { code: 'pt', label: 'português',  flag: '🇵🇹' },
  { code: 'nl', label: 'nederlands', flag: '🇳🇱' },
  { code: 'ru', label: 'русский',    flag: '🇷🇺' },
  { code: 'ar', label: 'العربية',     flag: '🇸🇦' },
  { code: 'zh', label: '中文',        flag: '🇨🇳' },
];
---

<section class="settings-section">
  <div class="settings-section__head">
    <span class="settings-section__title">— sprachen für gäste —</span>
  </div>

  <div class="lang-grid" id="langGrid">
    {LANGUAGES.map(lang => {
      const isActive  = enabledLanguages.includes(lang.code);
      const isDefault = lang.code === defaultLanguage;
      return (
        <label
          class={`lang-pill ${isActive ? 'is-active' : ''} ${isDefault ? 'is-default' : ''}`}
          title={isDefault ? 'Standardsprache — nicht abwählbar' : undefined}
        >
          <input
            type="checkbox"
            value={lang.code}
            checked={isActive}
            disabled={isDefault}
            aria-label={lang.label}
            data-is-default={isDefault ? 'true' : undefined}
          />
          <span class="lang-pill__flag">{lang.flag}</span>
          <span class="lang-pill__label">{lang.label}</span>
          {isDefault && <span class="lang-pill__badge">std</span>}
        </label>
      );
    })}
  </div>
  <p class="lang-hint">gäste können in der app zwischen diesen sprachen wechseln.</p>
  <p id="langLimitMsg" class="lang-limit-msg" hidden>Maximal 6 Sprachen – bitte wähle eine ab, um eine weitere hinzuzufügen.</p>

  <div class="default-lang-row">
    <label class="default-lang-label" for="defaultLang">standard</label>
    <select id="defaultLang" class="default-lang-select">
      {LANGUAGES.map(lang => (
        <option
          value={lang.code}
          selected={lang.code === defaultLanguage}
          disabled={!enabledLanguages.includes(lang.code)}
        >
          {lang.flag} {lang.label}
        </option>
      ))}
    </select>
  </div>

  <!-- Speichern-Zeile -->
  <div class="lang-save-row">
    <button
      id="langSaveBtn"
      class="lang-save-btn"
      type="button"
      disabled
      data-hotel-id={hotelId}
      data-initial-langs={JSON.stringify(enabledLanguages)}
      data-initial-default={defaultLanguage}
    >
      SPEICHERN
    </button>
    <span id="langSaveStatus" class="lang-save-status" aria-live="polite"></span>
  </div>
</section>

<style>
  .settings-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 24px 28px;
  }
  .settings-section__head { margin-bottom: 16px; }
  .settings-section__title {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.2em; color: var(--ink); font-weight: 500; text-transform: uppercase;
  }

  .lang-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 8px;
  }
  .lang-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 12px; cursor: pointer;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-sm); transition: all 150ms ease;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.04em; text-transform: lowercase; color: var(--ink-muted);
    user-select: none;
  }
  .lang-pill input { display: none; }
  .lang-pill:not(.is-default):hover { background: var(--te-yellow-soft); color: var(--ink); }
  .lang-pill.is-active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  /* Default-Sprache: nicht anklickbar, aber trotzdem aktiv dargestellt */
  .lang-pill.is-default { cursor: default; opacity: 0.9; }
  .lang-pill__flag { font-size: 14px; }
  .lang-pill__badge {
    margin-left: auto;
    font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase;
    background: var(--bg); color: var(--ink); border-radius: 4px;
    padding: 1px 5px; line-height: 1.4;
    border: 1px solid var(--border);
  }
  .lang-pill.is-active .lang-pill__badge {
    background: var(--surface); color: var(--ink);
  }

  .lang-hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--ink-muted); margin-top: 10px; letter-spacing: 0.04em;
  }

  .default-lang-row {
    margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border);
    display: flex; align-items: center; gap: 16px;
  }
  .default-lang-label {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
    white-space: nowrap;
  }
  .default-lang-select {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-sm); padding: 8px 12px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--ink); outline: none; cursor: pointer;
    transition: border-color 150ms;
  }
  .default-lang-select:focus { border-color: var(--ink); }

  /* Speichern-Zeile */
  .lang-save-row {
    margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
  }
  .lang-save-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 10px 20px;
    background: var(--ink); color: var(--bg);
    border: none; border-radius: var(--r-sm);
    cursor: pointer; transition: opacity 160ms ease;
  }
  .lang-save-btn:hover:not(:disabled) { opacity: 0.8; }
  .lang-save-btn:disabled { opacity: 0.28; cursor: default; }
  .lang-save-btn[data-loading] { opacity: 0.6; cursor: wait; }

  .lang-save-status {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.08em;
  }
  .lang-save-status[data-state="saved"]  { color: #5C9070; } /* Sage */
  .lang-save-status[data-state="error"]  { color: #C0392B; }

  .lang-limit-msg {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.06em;
    color: #8C2128;
    margin-top: 8px;
    padding: 6px 10px;
    border-left: 2px solid #8C2128;
    background: rgba(140, 33, 40, 0.05);
  }
</style>

<script>
  import { updateState } from '../../../lib/gast-vorschau/state';

  const grid        = document.getElementById('langGrid');
  const pills       = grid?.querySelectorAll<HTMLLabelElement>('.lang-pill');
  const defaultSel  = document.getElementById('defaultLang') as HTMLSelectElement;
  const saveBtn     = document.getElementById('langSaveBtn') as HTMLButtonElement;
  const statusEl    = document.getElementById('langSaveStatus') as HTMLElement;
  const limitMsg    = document.getElementById('langLimitMsg') as HTMLElement;

  function showLimit(show: boolean) {
    limitMsg.hidden = !show;
  }

  const HOTEL_ID = saveBtn?.dataset.hotelId ?? '';

  // Mutable baseline — wird nach erfolgreichem Speichern aktualisiert
  let baseline = {
    langs:       JSON.parse(saveBtn?.dataset.initialLangs ?? '[]') as string[],
    defaultLang: saveBtn?.dataset.initialDefault ?? 'de',
  };

  let currentLangs   = [...baseline.langs];
  let currentDefault = baseline.defaultLang;

  function isDirty(): boolean {
    if (currentDefault !== baseline.defaultLang) return true;
    if (currentLangs.length !== baseline.langs.length) return true;
    const sorted     = [...currentLangs].sort();
    const initSorted = [...baseline.langs].sort();
    return sorted.some((l, i) => l !== initSorted[i]);
  }

  function setStatus(state: 'saved' | 'error' | '', msg: string) {
    statusEl.dataset.state = state;
    statusEl.textContent = msg;
  }

  function updateSaveBtn() {
    saveBtn.disabled = !isDirty();
  }

  function getActive(): string[] {
    return Array.from(pills ?? [])
      .filter(p => p.querySelector('input')?.checked)
      .map(p => p.querySelector('input')!.value);
  }

  function syncDefaultOptions(active: string[]) {
    const current = defaultSel.value;
    Array.from(defaultSel.options).forEach(opt => {
      opt.disabled = !active.includes(opt.value);
    });
    if (!active.includes(current) && active.length > 0) {
      defaultSel.value = active[0];
      currentDefault = active[0];
      updateState({ defaultLanguage: active[0] });
    }
  }

  // Pill toggle — default-Sprache nicht anklickbar
  pills?.forEach(pill => {
    const input = pill.querySelector('input') as HTMLInputElement;
    if (input?.dataset.isDefault) return; // nicht abwählbar

    pill.addEventListener('click', () => {
      const active = getActive();
      // Mindestens 1 Sprache muss aktiv bleiben
      if (input.checked && active.length <= 1) return;
      // Maximal 6 Sprachen
      if (!input.checked && active.length >= 6) {
        showLimit(true);
        return;
      }
      showLimit(false);

      input.checked = !input.checked;
      pill.classList.toggle('is-active', input.checked);
      const newActive = getActive();
      currentLangs = newActive;
      updateState({ activeLanguages: newActive });
      syncDefaultOptions(newActive);
      setStatus('', '');
      updateSaveBtn();
    });
  });

  defaultSel?.addEventListener('change', () => {
    currentDefault = defaultSel.value;
    updateState({ defaultLanguage: defaultSel.value });
    setStatus('', '');
    updateSaveBtn();
  });

  saveBtn?.addEventListener('click', async () => {
    if (!isDirty() || saveBtn.disabled) return;
    saveBtn.dataset.loading = 'true';
    saveBtn.disabled = true;
    setStatus('', '');

    try {
      const res = await fetch('/api/hotel/update-languages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          enabledLanguages: currentLangs,
          defaultLanguage:  currentDefault,
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        throw new Error(data.error ?? `HTTP ${res.status}`);
      }
      // Erfolg: Baseline auf gespeicherten Zustand setzen
      baseline = { langs: [...currentLangs], defaultLang: currentDefault };
      setStatus('saved', 'Gespeichert');
      setTimeout(() => setStatus('', ''), 3000);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      console.error('[lang-section] save error', msg);
      const isLimit = msg.includes('check_enabled_languages_count') || msg.includes('violates check constraint') || msg.includes('Maximal 6');
      if (isLimit) {
        showLimit(true);
      } else {
        setStatus('error', `Fehler: ${msg}`);
      }
      saveBtn.disabled = false;
    } finally {
      delete saveBtn.dataset.loading;
      updateSaveBtn();
    }
  });
</script>
