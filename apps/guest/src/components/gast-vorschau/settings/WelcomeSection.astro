---
interface Props {
  hotelName?: string;
  welcomeText?: string;
  eyebrowText?: string;
  formality?: 'du' | 'sie';
}
const {
  hotelName  = 'Ihrem Hotel',
  welcomeText = '',
  eyebrowText = '',
  formality   = 'du',
} = Astro.props;

const initWelcome = welcomeText || `Willkommen im ${hotelName}`;
const initEyebrow = eyebrowText || '';
---

<section
  class="settings-section"
  id="welcomeSection"
  data-baseline={JSON.stringify({ welcomeText: initWelcome, eyebrowText: initEyebrow, formality })}
>
  <div class="settings-section__head">
    <span class="settings-section__title">Willkommen & Ansprache</span>
  </div>

  <!-- Willkommenstext -->
  <div class="ws-field">
    <label class="ws-label" for="welcomeTextarea">
      willkommenstext
      <span id="welcomeCount" class="ws-counter">{initWelcome.length} / 120</span>
    </label>
    <textarea
      class="ws-textarea"
      id="welcomeTextarea"
      maxlength="120"
      placeholder={`z.B. Willkommen im ${hotelName}`}
      aria-label="Willkommenstext für Gäste"
    >{initWelcome}</textarea>
    <p class="ws-hint">wird ganz oben im gast-app angezeigt.</p>
  </div>

  <!-- Du/Sie Toggle -->
  <div class="ansprache-row">
    <span class="ansprache-label">ansprache</span>
    <div class="ansprache-cards" role="radiogroup" aria-label="Ansprache wählen">
      <button
        class={`ansprache-card${formality === 'du' ? ' is-active' : ''}`}
        data-value="du"
        role="radio"
        aria-checked={formality === 'du' ? 'true' : 'false'}
        type="button"
      >du-form</button>
      <button
        class={`ansprache-card${formality === 'sie' ? ' is-active' : ''}`}
        data-value="sie"
        role="radio"
        aria-checked={formality === 'sie' ? 'true' : 'false'}
        type="button"
      >sie-form</button>
    </div>
    <span class="ansprache-hint">gilt in gäste-app, emails und allen texten</span>
  </div>

  <!-- Save row -->
  <div class="ws-save-row">
    <button id="welcomeSaveBtn" class="v9-btn" type="button">
      Speichern
    </button>
  </div>
</section>

<style>
  .settings-section {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r); padding: 24px 28px;
  }
  .settings-section__head {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;
  }
  .settings-section__title {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.2em; color: var(--ink); font-weight: 500; text-transform: uppercase;
  }

  /* ── Field layout ───────────────────────────────────────────── */
  .ws-field { margin-bottom: 18px; }
  .ws-label {
    display: flex; justify-content: space-between; align-items: baseline;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted);
    margin-bottom: 8px;
  }
  .ws-counter {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted);
  }
  .ws-input {
    width: 100%; padding: 10px 14px;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); outline: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    color: var(--ink); transition: border-color 200ms ease;
  }
  .ws-input:focus { border-color: var(--ink); }
  .ws-textarea {
    width: 100%; min-height: 70px; padding: 12px 14px;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r-sm); resize: vertical; outline: none;
    font-family: 'Space Grotesk', sans-serif; font-size: 14px;
    color: var(--ink); line-height: 1.5; transition: border-color 200ms ease;
  }
  .ws-textarea:focus { border-color: var(--ink); }
  .ws-hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--ink-muted); margin-top: 6px; letter-spacing: 0.04em;
  }

  /* ── Ansprache ──────────────────────────────────────────────── */
  .ansprache-row {
    margin-top: 4px; padding-top: 18px; border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 10px;
  }
  .ansprache-label {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-muted);
  }
  .ansprache-cards { display: flex; gap: 8px; }
  .ansprache-card {
    padding: 8px 18px; cursor: pointer;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-sm); transition: all 150ms ease;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.08em; text-transform: lowercase; color: var(--ink-soft);
  }
  .ansprache-card:hover { background: var(--te-yellow-soft); color: var(--ink); }
  .ansprache-card.is-active { background: var(--ink); color: var(--bg); border-color: var(--ink); }
  .ansprache-hint {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--ink-muted); letter-spacing: 0.04em;
  }

  /* ── Save row ───────────────────────────────────────────────── */
  .ws-save-row {
    margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border);
    display: flex; align-items: center; gap: 12px;
  }
</style>

<script>
  import { updateState } from '../../../lib/gast-vorschau/state';

  const section    = document.getElementById('welcomeSection');
  const textarea   = document.getElementById('welcomeTextarea')  as HTMLTextAreaElement;
  const counter    = document.getElementById('welcomeCount')     as HTMLElement;
  const cards      = document.querySelectorAll<HTMLButtonElement>('.ansprache-card');
  const saveBtn    = document.getElementById('welcomeSaveBtn')   as HTMLButtonElement;

  type Baseline = { welcomeText: string; eyebrowText: string; formality: 'du' | 'sie' };
  let baseline: Baseline = JSON.parse(section?.dataset.baseline ?? '{}') as Baseline;
  let currentFormality = baseline.formality ?? 'du';

  updateState({ welcomeText: textarea.value, formality: currentFormality });

  textarea?.addEventListener('input', () => {
    if (counter) counter.textContent = `${textarea.value.length} / 120`;
    updateState({ welcomeText: textarea.value });
  });

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const value = card.dataset.value as 'du' | 'sie';
      cards.forEach(c => {
        c.classList.remove('is-active');
        c.setAttribute('aria-checked', 'false');
      });
      card.classList.add('is-active');
      card.setAttribute('aria-checked', 'true');
      currentFormality = value;
      updateState({ formality: value });
    });
  });

  saveBtn?.addEventListener('click', async () => {
    if (saveBtn.dataset.loading) return;
    saveBtn.dataset.loading = 'true';
    saveBtn.disabled = true;
    const saveBtnLabel = saveBtn.textContent;
    saveBtn.textContent = 'Übersetze in alle Sprachen …';

    try {
      const res = await fetch('/api/hotel/save-welcome', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          welcomeText:  textarea.value,
          eyebrowText:  baseline.eyebrowText, // preserve existing value (field removed from UI)
          formality:    currentFormality,
        }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error ?? `HTTP ${res.status}`);

      baseline = { ...baseline, welcomeText: textarea.value, formality: currentFormality };
      (window as any).retahaToast?.('Gespeichert');
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      console.error('[welcome-section] save error', msg);
      (window as any).retahaToast?.(`Fehler: ${msg}`, 'error');
    } finally {
      delete saveBtn.dataset.loading;
      saveBtn.disabled = false;
      saveBtn.textContent = saveBtnLabel;
    }
  });
</script>
