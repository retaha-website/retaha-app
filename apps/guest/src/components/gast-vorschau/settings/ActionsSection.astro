---
import type { NfcTag } from '../../../lib/gast-vorschau/demo-data';
interface Props { tags: NfcTag[] }
const { tags } = Astro.props;
---

<section class="settings-section">
  <div class="settings-section__head">
    <span class="settings-section__title">Aktionen pro Tag</span>
    <a href="/action-cards" class="settings-section__link" title="Action-Card-Editor öffnen">
      → alle bearbeiten
    </a>
  </div>
  <div class="actions-list">
    {tags.map(tag => (
      <div class="action-row">
        <div class="action-row__tag">
          <span class="action-row__tag-dot" aria-hidden="true"></span>
          <span class="action-row__tag-label">{tag.label}</span>
        </div>
        <span class="action-row__arrow" aria-hidden="true">→</span>
        <div class="action-row__card">
          <span class="action-row__card-label">{tag.actionCard.title}</span>
          <span class="action-row__card-cta">{tag.actionCard.cta}</span>
        </div>
      </div>
    ))}
  </div>
  <p class="actions-hint">Echte Zuweisungen aus den NFC-Tag-Einstellungen – hier nur Demo.</p>
</section>

<style>
  .settings-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 24px 28px; }
  .settings-section__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .settings-section__title { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; color: var(--ink); font-weight: 500; text-transform: uppercase; }
  .settings-section__link { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted); text-decoration: none; transition: color 150ms ease; }
  .settings-section__link:hover { color: var(--ink); }
  .actions-list { display: flex; flex-direction: column; gap: 0; }
  .action-row {
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center; gap: 12px;
    padding: 12px 0; border-bottom: 1px solid var(--border);
  }
  .action-row:last-child { border-bottom: none; }
  .action-row__tag { display: flex; align-items: center; gap: 8px; }
  .action-row__tag-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-faint); flex-shrink: 0; }
  .action-row__tag-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink); letter-spacing: 0.08em; text-transform: uppercase; }
  .action-row__arrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-faint); }
  .action-row__card { display: flex; flex-direction: column; gap: 2px; }
  .action-row__card-label { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 500; color: var(--ink); }
  .action-row__card-cta { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted); letter-spacing: 0.04em; }
  .actions-hint { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-faint); margin-top: 16px; letter-spacing: 0.04em; }
</style>
