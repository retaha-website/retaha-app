---
import WelcomeSection from './WelcomeSection.astro';
import LanguageSection from './LanguageSection.astro';
import BrandLinkCard from './BrandLinkCard.astro';
import ModulesSection from './ModulesSection.astro';
import ActionsSection from './ActionsSection.astro';
import HeroCardsCard from './HeroCardsCard.astro';
import type { NfcTag } from '../../../lib/gast-vorschau/demo-data';
interface Props {
  tags: NfcTag[];
  hotelName?: string;
  hotelId: string;
  enabledLanguages: string[];
  defaultLanguage: string;
  welcomeText?: string;
  eyebrowText?: string;
  formality?: 'du' | 'sie';
  modulesFeatures?: Record<string, unknown>;
  modulesHotelPlan?: string;
  modulesHotelAddons?: string[];
}
const {
  tags, hotelName = 'Ihr Hotel', hotelId,
  enabledLanguages, defaultLanguage,
  welcomeText = '', eyebrowText = '', formality = 'du',
  modulesFeatures = {},
  modulesHotelPlan = 'lite',
  modulesHotelAddons = [],
} = Astro.props;

const tabDefs = [
  { key: 'module',     label: 'Module' },
  { key: 'sprachen',   label: 'Sprachen' },
  { key: 'branding',   label: 'Branding' },
  { key: 'hero',       label: 'Hero-Karten' },
  { key: 'aktionen',   label: 'Aktionen' },
] as const;
---

<aside
  class="settings-panel"
  x-data="{ tab: 'module' }"
>
  <!-- Settings-Bar -->
  <nav class="sp-tabs" aria-label="Einstellungs-Bereiche">
    {tabDefs.map(t => (
      <button
        class="sp-tab"
        :class={`{ 'sp-tab--active': tab === '${t.key}' }`}
        @click={`tab = '${t.key}'`}
        type="button"
        aria-pressed={t.key === 'module' ? 'true' : 'false'}
        :aria-pressed={`tab === '${t.key}' ? 'true' : 'false'`}
      >
        {t.label}
      </button>
    ))}
  </nav>

  <!-- MODULE -->
  <div x-show="tab === 'module'" x-cloak>
    <ModulesSection features={modulesFeatures} hotelPlan={modulesHotelPlan} hotelAddons={modulesHotelAddons} />
  </div>

  <!-- SPRACHEN -->
  <div x-show="tab === 'sprachen'" x-cloak>
    <WelcomeSection
      hotelName={hotelName}
      welcomeText={welcomeText}
      eyebrowText={eyebrowText}
      formality={formality}
    />
    <div style="margin-top:16px">
      <LanguageSection
        hotelId={hotelId}
        enabledLanguages={enabledLanguages}
        defaultLanguage={defaultLanguage}
      />
    </div>
  </div>

  <!-- BRANDING -->
  <div x-show="tab === 'branding'" x-cloak>
    <BrandLinkCard />
  </div>

  <!-- HERO-KARTEN -->
  <div x-show="tab === 'hero'" x-cloak>
    <HeroCardsCard hotelId={hotelId} defaultLanguage={defaultLanguage} />
  </div>

  <!-- AKTIONEN -->
  <div x-show="tab === 'aktionen'" x-cloak>
    <ActionsSection tags={tags} />
  </div>
</aside>

<style>
  .settings-panel { display: flex; flex-direction: column; gap: 16px; }

  /* Settings-Bar */
  .sp-tabs {
    display: flex; gap: 4px; flex-wrap: wrap;
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: var(--r); padding: 6px;
  }
  .sp-tab {
    flex: 1; min-width: 0;
    padding: 8px 10px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-muted); background: transparent;
    border: 1px solid transparent; border-radius: var(--r-sm);
    cursor: pointer; white-space: nowrap;
    transition: all 180ms ease;
  }
  .sp-tab:hover { color: var(--ink); background: var(--surface); }
  .sp-tab--active {
    color: var(--ink); background: var(--surface);
    border-color: var(--border-medium);
    font-weight: 500;
  }

  [x-cloak] { display: none !important; }
</style>
