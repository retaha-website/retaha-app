---
interface Props {
  features?: Record<string, unknown>;
}
const { features = {} } = Astro.props;

// Same logic as guest Startseite: key !== false → on (undefined/null/true → on)
function isOn(key: string): boolean {
  return features[key] !== false;
}

const groups = [
  {
    label: 'Gäste-Services',
    modules: [
      { key: 'eve',          label: 'Eve Concierge',   sub: 'KI-Chat für Gäste' },
      { key: 'empfehlungen', label: 'Empfehlungen',     sub: 'Google Places, Tipps' },
      { key: 'service',      label: 'Service-Anfragen', sub: 'Zimmerwünsche, Buchungen' },
    ],
  },
  {
    label: 'Kulinarik & Buchung',
    modules: [
      { key: 'breakfast',   label: 'Frühstück',   sub: 'Slot-Buchung, Zeiten' },
    ],
  },
  {
    label: 'Abreise & Wallet',
    modules: [
      { key: 'self_checkout', label: 'Self-Checkout', sub: 'Digitale Abreise' },
      { key: 'wallet',        label: 'Wallet-Pass',   sub: 'Apple & Google Wallet' },
    ],
  },
  {
    label: 'Inhalte',
    modules: [
      { key: 'action_cards', label: 'Hero-Slider', sub: 'Swipeable Karten-Feed' },
    ],
  },
];
---

<section class="settings-section">
  <div class="settings-section__head">
    <span class="settings-section__title">— Module —</span>
    <span class="settings-section__hint">live toggle</span>
  </div>

  {groups.map(group => (
    <div class="module-group">
      <div class="module-group__label">{group.label}</div>
      <div class="modules-list">
        {group.modules.map(mod => (
          <div class="module-row">
            <div class="module-row__info">
              <span class="module-row__label">{mod.label}</span>
              <span class="module-row__sub">{mod.sub}</span>
            </div>
            <button
              class:list={['module-toggle', { 'is-on': isOn(mod.key) }]}
              data-module-key={mod.key}
              aria-pressed={isOn(mod.key) ? 'true' : 'false'}
              aria-label={`${mod.label} ein/aus`}
              type="button"
            >
              <span class="module-toggle__led"></span>
            </button>
          </div>
        ))}
      </div>
    </div>
  ))}

  <div class="mod-save-row">
    <span id="modSaveStatus" class="mod-save-status" aria-live="polite"></span>
  </div>
</section>

<style>
  .settings-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 24px 28px; }
  .settings-section__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .settings-section__title { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.2em; color: var(--ink); font-weight: 500; text-transform: uppercase; }
  .settings-section__hint { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted); }

  .module-group { margin-bottom: 16px; }
  .module-group:last-child { margin-bottom: 0; }
  .module-group__label {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-faint); margin-bottom: 6px; padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .modules-list { display: flex; flex-direction: column; gap: 2px; }
  .module-row {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 10px 0; border-bottom: 1px solid var(--border);
  }
  .module-row:last-child { border-bottom: none; }
  .module-row__info { display: flex; flex-direction: column; gap: 2px; }
  .module-row__label { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 500; color: var(--ink); }
  .module-row__sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-muted); letter-spacing: 0.04em; }
  .module-toggle {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 6px 12px; border: 1px solid var(--border);
    border-radius: 99px; cursor: pointer; background: transparent;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-muted);
    transition: all 200ms ease; white-space: nowrap;
  }
  .module-toggle.is-on { border-color: var(--sage); color: var(--sage); background: var(--sage-soft); }
  .module-toggle__led {
    width: 6px; height: 6px; border-radius: 50%; background: var(--ink-faint);
    transition: all 200ms ease;
  }
  .module-toggle.is-on .module-toggle__led {
    background: var(--sage); box-shadow: 0 0 0 3px rgba(92,144,112,0.25);
    animation: led-pulse 2s ease-in-out infinite;
  }

  .mod-save-row {
    margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border);
    min-height: 20px;
  }
  .mod-save-status {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.08em;
  }
  .mod-save-status[data-state="saved"] { color: #5C9070; }
  .mod-save-status[data-state="error"] { color: #C0392B; }
</style>

<script>
  import { updateState, getState } from '../../../lib/gast-vorschau/state';
  type ModuleKey = keyof ReturnType<typeof getState>['modules'];

  const statusEl = document.getElementById('modSaveStatus') as HTMLElement | null;
  let statusTimer: ReturnType<typeof setTimeout> | null = null;

  function setStatus(state: 'saved' | 'error' | '', msg: string) {
    if (!statusEl) return;
    statusEl.dataset.state = state;
    statusEl.textContent = msg;
    if (statusTimer) clearTimeout(statusTimer);
    if (state === 'saved') statusTimer = setTimeout(() => setStatus('', ''), 2500);
  }

  // Sync preview state from SSR-rendered DOM — initialState has all-true hardcoded,
  // reading DOM gives us the real DB values the server rendered.
  const domModules: Partial<ReturnType<typeof getState>['modules']> = {};
  document.querySelectorAll<HTMLButtonElement>('.module-toggle').forEach(btn => {
    const k = btn.dataset.moduleKey as ModuleKey | undefined;
    if (k) domModules[k] = btn.classList.contains('is-on');
  });
  updateState({ modules: { ...getState().modules, ...domModules } });

  document.querySelectorAll<HTMLButtonElement>('.module-toggle').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.moduleKey as ModuleKey | undefined;
      if (!key || btn.dataset.loading) return;

      // Read current state from DOM (not from initialState which hardcodes all-true)
      const wasOn = btn.classList.contains('is-on');
      const newVal = !wasOn;

      // Optimistic update
      btn.classList.toggle('is-on', newVal);
      btn.setAttribute('aria-pressed', newVal ? 'true' : 'false');
      updateState({ modules: { ...getState().modules, [key]: newVal } });
      btn.dataset.loading = 'true';
      setStatus('', '');

      try {
        const res = await fetch('/api/hotel/save-modules', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key, value: newVal }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error ?? `HTTP ${res.status}`);
        setStatus('saved', '✓ Gespeichert');
      } catch {
        // Rollback visual + state on failure
        btn.classList.toggle('is-on', wasOn);
        btn.setAttribute('aria-pressed', wasOn ? 'true' : 'false');
        updateState({ modules: { ...getState().modules, [key]: wasOn } });
        setStatus('error', 'Fehler — bitte neu laden');
      } finally {
        delete btn.dataset.loading;
      }
    });
  });
</script>
