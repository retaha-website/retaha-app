---
const personas = [
  { key: 'arrival'   as const, label: 'Anreise' },
  { key: 'in_house'  as const, label: 'Im Hotel' },
  { key: 'departure' as const, label: 'Abreise' },
];
---

<div class="persona-picker">
  <div class="persona-picker__tabs">
    {personas.map(p => (
      <button
        class:list={['persona-tab', { 'is-active': p.key === 'in_house' }]}
        data-persona={p.key}
        type="button"
        aria-pressed={p.key === 'in_house' ? 'true' : 'false'}
      >
        {p.label}
      </button>
    ))}
  </div>
</div>

<style>
  .persona-picker {
    width: 100%;
  }
  .persona-picker__tabs {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 4px;
    background: var(--bg-deep);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 4px;
  }
  .persona-tab {
    padding: 8px 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-muted);
    background: transparent; border: 1px solid transparent;
    border-radius: 6px; cursor: pointer;
    transition: all 180ms ease;
    white-space: nowrap; text-align: center;
  }
  .persona-tab:hover { color: var(--ink); background: var(--surface); }
  .persona-tab.is-active {
    color: var(--ink); background: var(--surface);
    border-color: var(--border-medium);
  }
</style>

<script>
  import { updateState } from '../../lib/gast-vorschau/state';
  document.querySelectorAll<HTMLButtonElement>('.persona-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const persona = tab.dataset.persona as 'arrival' | 'in_house' | 'departure';
      if (!persona) return;
      document.querySelectorAll('.persona-tab').forEach(t => {
        t.classList.remove('is-active');
        t.setAttribute('aria-pressed', 'false');
      });
      tab.classList.add('is-active');
      tab.setAttribute('aria-pressed', 'true');
      updateState({ persona });
    });
  });
</script>
