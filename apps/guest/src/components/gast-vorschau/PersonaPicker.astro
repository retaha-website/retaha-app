---
const personas = [
  { key: 'arrival'   as const, label: 'Anreise',  default: false },
  { key: 'in_house'  as const, label: 'Im Hotel',  default: true  },
  { key: 'departure' as const, label: 'Abreise',  default: false },
];
---

<div class="persona-dots" role="tablist" aria-label="Gast-Situation">
  {personas.map(p => (
    <button
      class="persona-dot"
      data-active={p.default ? 'true' : 'false'}
      data-persona={p.key}
      type="button"
      role="tab"
      aria-label={p.label}
      aria-selected={p.default ? 'true' : 'false'}
    >
      <span class="persona-dot__label">{p.label}</span>
    </button>
  ))}
</div>

<style>
  .persona-dots {
    display: flex;
    gap: 10px;
    justify-content: center;
    align-items: center;
    margin: 8px 0 20px;
    padding-bottom: 18px;
    position: relative;
  }

  .persona-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: transparent;
    cursor: pointer;
    transition: width 200ms ease, border-radius 200ms ease, background 200ms ease, border-color 200ms ease;
    position: relative;
    padding: 0;
    flex-shrink: 0;
  }

  .persona-dot[data-active="true"] {
    width: 24px;
    border-radius: 6px;
    background: var(--petrol, #14616E);
    border-color: var(--petrol, #14616E);
  }

  .persona-dot:hover:not([data-active="true"]) {
    border-color: var(--petrol, #14616E);
    background: rgba(255, 230, 0, 0.15);
  }

  .persona-dot__label {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    color: var(--ink-muted);
    opacity: 0;
    transition: opacity 150ms ease;
    pointer-events: none;
  }

  .persona-dot[data-active="true"] .persona-dot__label {
    color: var(--ink);
    opacity: 1;
  }

  .persona-dot:hover .persona-dot__label {
    opacity: 1;
  }
</style>

<script>
  import { updateState } from '../../lib/gast-vorschau/state';
  document.querySelectorAll<HTMLButtonElement>('.persona-dot').forEach(dot => {
    dot.addEventListener('click', () => {
      const persona = dot.dataset.persona as 'arrival' | 'in_house' | 'departure';
      if (!persona) return;
      document.querySelectorAll<HTMLButtonElement>('.persona-dot').forEach(d => {
        d.dataset.active = 'false';
        d.setAttribute('aria-selected', 'false');
      });
      dot.dataset.active = 'true';
      dot.setAttribute('aria-selected', 'true');
      updateState({ persona });
    });
  });
</script>
