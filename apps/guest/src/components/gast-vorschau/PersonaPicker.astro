---
const personas = [
  { key: 'arrival'   as const, label: 'Anreise' },
  { key: 'in_house'  as const, label: 'Im Hotel' },
  { key: 'departure' as const, label: 'Abreise' },
];
---

<div class="persona-picker">
  {personas.map((p, i) => (
    <>
      {i > 0 && <span class="persona-arrow" aria-hidden="true">→</span>}
      <button
        class:list={['persona-pill', { 'is-active': p.key === 'in_house' }]}
        data-persona={p.key}
        type="button"
        aria-pressed={p.key === 'in_house' ? 'true' : 'false'}
      >
        {p.label}
      </button>
    </>
  ))}
</div>

<style>
  .persona-picker {
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
  }

  .persona-pill {
    flex: 1;
    padding: 8px 12px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: var(--ink-muted);
    cursor: pointer;
    transition: all 200ms ease;
    white-space: nowrap;
  }

  .persona-pill:hover:not(.is-active) {
    border-color: var(--te-yellow);
    color: var(--ink);
  }

  .persona-pill.is-active {
    background: var(--te-yellow);
    border-color: var(--te-yellow);
    color: #0A0A0A;
    font-weight: 500;
  }

  .persona-arrow {
    color: var(--ink-faint, var(--border));
    font-size: 13px;
    flex-shrink: 0;
    user-select: none;
    line-height: 1;
  }
</style>

<script>
  import { updateState } from '../../lib/gast-vorschau/state';
  document.querySelectorAll<HTMLButtonElement>('.persona-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      const persona = pill.dataset.persona as 'arrival' | 'in_house' | 'departure';
      if (!persona) return;
      document.querySelectorAll('.persona-pill').forEach(p => {
        p.classList.remove('is-active');
        p.setAttribute('aria-pressed', 'false');
      });
      pill.classList.add('is-active');
      pill.setAttribute('aria-pressed', 'true');
      updateState({ persona });
    });
  });
</script>
