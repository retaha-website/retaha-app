---
// Sprint E4 · Phase 9 — Floating-Bubble unten rechts
//
// Versteckt sich automatisch wenn:
//   - Eve-Sheet bereits offen (eveOpen)
//   - andere Bottom-Sheets offen (activeSheet !== null)
//
// First-Stay-Pulse: einmaliger Pink-Ring-Pulse für Discoverability.
// Kontrolle via localStorage-Flag `retaha_eve_seen`.

interface Props {
  accentColor?: string;
}

const { accentColor = 'var(--theme-accent)' } = Astro.props;
---

<button
  type="button"
  class="eve-fab"
  @click="eveOpen = true; eveMaybeWelcome()"
  x-show="!eveOpen && !activeSheet"
  :class="{ 'eve-fab--pulse': !eveSeenBefore }"
  aria-label="Eve öffnen"
>
  <svg class="eve-fab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12c0 4.97-4.03 9-9 9-1.4 0-2.74-.32-3.94-.9L3 21l1.1-4.06A8.95 8.95 0 0 1 3 12c0-4.97 4.03-9 9-9s9 4.03 9 9z"/>
  </svg>
</button>

<style is:global define:vars={{ fabAccent: accentColor }}>
  .eve-fab {
    position: fixed;
    bottom: calc(24px + env(safe-area-inset-bottom));
    right: 20px;
    z-index: 80;
    width: 56px;
    height: 56px;
    border: none;
    border-radius: 50%;
    background: var(--fabAccent);
    color: var(--theme-bg-primary);
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18), 0 2px 4px rgba(0, 0, 0, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .eve-fab:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.22), 0 3px 6px rgba(0, 0, 0, 0.1);
  }
  .eve-fab:active { transform: scale(0.95); }

  .eve-fab-icon {
    width: 26px;
    height: 26px;
  }

  /* First-Stay-Pulse — Pink-Ring 3× */
  .eve-fab--pulse::before {
    content: '';
    position: absolute;
    inset: -4px;
    border: 2px solid var(--fabAccent);
    border-radius: 50%;
    opacity: 0;
    animation: eve-fab-pulse 2.5s ease-out 3;
  }
  @keyframes eve-fab-pulse {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(1.6); opacity: 0; }
  }
</style>
