---
// Sprint E4 · Phase 9 — 3-Dots-Animation für "Eve schreibt …"
interface Props {
  typingLabel?: string;
}
const { typingLabel = 'Eve schreibt …' } = Astro.props;
---

<div class="eve-typing" data-typing-label={typingLabel} aria-label={typingLabel} role="status">
  <span></span><span></span><span></span>
</div>

<style>
  .eve-typing {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 12px 16px;
    background: var(--theme-bg-primary);
    border: 1px solid var(--theme-border);
    border-radius: 18px 18px 18px 4px;
    width: fit-content;
  }
  .eve-typing span {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--theme-text-primary) 45%, transparent);
    animation: eve-typing-bounce 1.2s infinite ease-in-out;
  }
  .eve-typing span:nth-child(1) { animation-delay: 0s; }
  .eve-typing span:nth-child(2) { animation-delay: 0.15s; }
  .eve-typing span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes eve-typing-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .eve-typing span { display: none; }
    .eve-typing::after {
      content: attr(data-typing-label);
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.04em;
      color: color-mix(in srgb, var(--theme-text-primary) 60%, transparent);
    }
  }
</style>
