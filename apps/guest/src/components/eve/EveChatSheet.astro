---
// Sprint E4 · Phase 9 — Voll-Screen Chat-Sheet für Eve
//
// Verbraucht parent x-data="guestPage" mit erweitertem Eve-State (siehe
// /g/[token].astro). State-Felder:
//   eveOpen: boolean
//   eveMessages: Array<{role, content, streaming?}>
//   eveTyping: boolean
//   evePendingAction: {action_type, action_params, summary} | null
//   eveError: string | null
//   eveConfirming: boolean  — während POST /api/eve/confirm-action
// Methods:
//   eveSend(text), eveConfirm(), eveCancel(), eveClose()
//
// Sub-Components werden via Import-only-for-Styles geladen — die eigentlichen
// Templates sind hier inline weil Alpine bindings nur in einem File schlicht
// rendern.

import EveTypingIndicator from './EveTypingIndicator.astro';
import EveMessage from './EveMessage.astro';
import EveActionConfirmCard from './EveActionConfirmCard.astro';
import EveSuggestionChips from './EveSuggestionChips.astro';
import { t, type Lang } from '@retaha/i18n';

interface Props {
  lang: Lang;
  eveName: string;
  /** Pink-Shock Default — Hotelier kann via hotel_settings.accent_color überschreiben. */
  accentColor?: string;
  /** Default-Chip-Set. Phase 10 macht das tageszeit-dynamisch. */
  chips?: Array<{ key: string; text: string }>;
}

const { lang, eveName, accentColor = 'var(--theme-accent)', chips } = Astro.props;

// Default-Fallback wenn Caller keine Chips übergibt (z.B. Tageszeit unklar).
// Phase 10: /g/[token].astro übergibt tageszeit-dynamische Chips via getEveSuggestions().
const defaultChips = chips ?? [
  { key: 'breakfast_when',  text: t('eve.chip_breakfast_when', lang) },
  { key: 'wifi',            text: t('eve.chip_wifi', lang) },
  { key: 'recommendations', text: t('eve.chip_recommendations', lang) },
  { key: 'checkout',        text: t('eve.chip_checkout', lang) },
];

const placeholder = t('eve.placeholder', lang).replace('{name}', eveName);
const typingLabel = t('eve.typing', lang).replace('{name}', eveName);
const sendLabel = t('eve.send', lang);
const closeLabel = t('eve.close', lang);
const confirmLabel = t('eve.confirm_booking', lang);
const cancelLabel = t('eve.cancel_booking', lang);
const suggestionsLabel = t('eve.suggestions_label', lang);
---

<!-- Backdrop -->
<div
  class="eve-sheet-backdrop"
  x-show="eveOpen"
  x-transition.opacity
  @click="eveClose()"
  style="display: none;"
></div>

<!-- Sheet -->
<aside
  class="eve-sheet"
  x-show="eveOpen"
  x-transition:enter="eve-sheet-enter"
  x-transition:enter-start="eve-sheet-enter-start"
  x-transition:enter-end="eve-sheet-enter-end"
  x-transition:leave="eve-sheet-leave"
  x-transition:leave-start="eve-sheet-leave-start"
  x-transition:leave-end="eve-sheet-leave-end"
  role="dialog"
  aria-modal="true"
  aria-label={`Chat mit ${eveName}`}
  style="display: none;"
>
  <!-- Header -->
  <header class="eve-sheet-header">
    <div class="eve-sheet-avatar" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
    </div>
    <div class="eve-sheet-header-info">
      <span class="eve-sheet-header-eyebrow themed-eyebrow-flank">concierge</span>
      <h2 class="eve-sheet-header-name">{eveName}<span class="eve-name-dot">.</span></h2>
    </div>
    <button type="button" class="eve-sheet-close" @click="eveClose()" aria-label={closeLabel}>×</button>
  </header>

  <!-- Messages -->
  <div class="eve-sheet-messages" x-ref="eveMessagesEl">
    <!-- Messages -->
    <template x-for="(msg, idx) in eveMessages" :key="idx">
      <div
        :class="`eve-message eve-message--${msg.role}${msg.streaming ? ' eve-message--streaming' : ''}`"
      >
        <div class="eve-message-bubble" x-text="msg.content"></div>
        <!-- Sprint Functional Modul C Phase 7 — Feedback-Daumen für assistant-Messages -->
        <div
          class="eve-message-feedback"
          x-show="msg.role === 'assistant' && msg.id && !msg.streaming"
          x-cloak
        >
          <button
            type="button"
            class="eve-fb-btn"
            :class="{ 'is-active': msg.feedback === 1 }"
            @click="sendEveFeedback(msg.id, 1)"
            aria-label="Hilfreich"
            title="Hilfreich"
          >👍</button>
          <button
            type="button"
            class="eve-fb-btn"
            :class="{ 'is-active': msg.feedback === -1 }"
            @click="sendEveFeedback(msg.id, -1)"
            aria-label="Nicht hilfreich"
            title="Nicht hilfreich"
          >👎</button>
        </div>
      </div>
    </template>

    <!-- Typing-Indicator -->
    <div class="eve-message eve-message--assistant" x-show="eveTyping" style="display: none;">
      <EveTypingIndicator />
    </div>

    <!-- Confirmation-Card (pending_action) -->
    <template x-if="evePendingAction">
      <div class="eve-confirm-card">
        <h3 class="eve-confirm-title" x-text="evePendingAction.summary?.title || 'Bestätigen?'"></h3>

        <ul class="eve-confirm-list" x-show="evePendingAction.summary?.items?.length > 0">
          <template x-for="(item, i) in (evePendingAction.summary?.items || [])" :key="i">
            <li>
              <span class="item-name" x-text="`${item.quantity > 1 ? item.quantity + '× ' : ''}${item.label}`"></span>
              <span class="item-price" x-show="item.price_cents != null && item.price_cents > 0" x-text="`€${(item.price_cents / 100).toFixed(2)}`"></span>
              <span class="item-price" x-show="item.price_cents === 0">inklusive</span>
            </li>
          </template>
        </ul>

        <p class="eve-confirm-when" x-show="evePendingAction.summary?.when" x-text="evePendingAction.summary?.when"></p>

        <p class="eve-confirm-total" x-show="evePendingAction.summary?.total_cents > 0"
           x-text="`Summe: €${(evePendingAction.summary.total_cents / 100).toFixed(2)}`"></p>

        <p class="eve-confirm-note" x-show="evePendingAction.summary?.note" x-text="evePendingAction.summary?.note"></p>

        <div class="eve-confirm-actions">
          <button type="button" class="eve-confirm-btn eve-confirm-btn--primary" @click="eveConfirm()" :disabled="eveConfirming">
            <span x-show="!eveConfirming">{confirmLabel}</span>
            <span x-show="eveConfirming" style="display:none">…</span>
          </button>
          <button type="button" class="eve-confirm-btn eve-confirm-btn--secondary" @click="eveCancel()" :disabled="eveConfirming">
            {cancelLabel}
          </button>
        </div>
      </div>
    </template>

    <!-- Error -->
    <div class="eve-error" x-show="eveError" style="display: none;">
      <p x-text="eveError"></p>
    </div>
  </div>

  <!-- Suggestion-Chips (wenn noch kein User-Message, zwischen Messages und Input) -->
  <div
    class="eve-chips-bar"
    x-show="!eveMessages.some(m => m.role === 'user')"
    style="display: none;"
  >
    {defaultChips.map(chip => (
      <button
        type="button"
        class="eve-chip"
        data-chip-text={chip.text}
        @click={`eveSend('${chip.text.replace(/'/g, "\\'")}')`}
      >
        {chip.text}
      </button>
    ))}
  </div>

  <!-- Input -->
  <form class="eve-sheet-input-row" @submit.prevent="eveSend($refs.eveInput.value); $refs.eveInput.value = ''">
    <input
      type="text"
      class="eve-sheet-input"
      x-ref="eveInput"
      placeholder={placeholder}
      :disabled="eveTyping || eveConfirming"
      autocomplete="off"
    />
    <button
      type="submit"
      class="eve-sheet-send"
      :disabled="eveTyping || eveConfirming"
      aria-label={sendLabel}
    >
      ↑
    </button>
  </form>
</aside>

<style is:global define:vars={{ accent: accentColor }}>
  .eve-sheet-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    z-index: 90;
  }
  .eve-sheet {
    position: fixed;
    inset: 0;
    background: var(--theme-bg-secondary);
    z-index: 100;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .eve-sheet {
      inset: auto 24px 24px auto;
      width: 420px;
      height: min(80vh, 720px);
      border-radius: 16px;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18);
    }
  }

  /* Transitions */
  .eve-sheet-enter { transition: transform 0.3s ease-out, opacity 0.3s ease-out; }
  .eve-sheet-enter-start { transform: translateY(100%); opacity: 0; }
  .eve-sheet-enter-end { transform: translateY(0); opacity: 1; }
  .eve-sheet-leave { transition: transform 0.25s ease-in, opacity 0.25s ease-in; }
  .eve-sheet-leave-start { transform: translateY(0); opacity: 1; }
  .eve-sheet-leave-end { transform: translateY(100%); opacity: 0; }

  /* Header */
  .eve-sheet-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--theme-border);
    background: var(--theme-bg-primary);
  }
  .eve-sheet-header-info { display: flex; flex-direction: column; gap: 2px; }
  .eve-sheet-header-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
  }
  .eve-sheet-header-name {
    margin: 0;
    font-size: 18px;
    font-weight: 400;
    color: var(--theme-text-primary);
    letter-spacing: -0.01em;
  }
  .eve-sheet-close {
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    font-size: 28px;
    line-height: 1;
    color: color-mix(in srgb, var(--theme-text-primary) 0.55, transparent);
    cursor: pointer;
    border-radius: 50%;
    transition: background 0.15s ease;
  }
  .eve-sheet-close:hover { background: color-mix(in srgb, var(--theme-text-primary) 0.05, transparent); }

  /* Messages-Scroll-Area */
  .eve-sheet-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
    scroll-behavior: smooth;
  }

  /* Error-Box */
  .eve-error {
    margin: 12px 0;
    padding: 12px 16px;
    background: var(--guest-danger-soft, rgba(140,33,40,0.10));
    border-left: 3px solid var(--guest-danger, #8C2128);
    color: var(--guest-danger, #8C2128);
    font-size: 13px;
    border-radius: 4px;
  }

  /* Chips bar (between messages and input) */
  .eve-chips-bar {
    flex-shrink: 0;
    display: flex; flex-wrap: wrap; gap: 7px;
    padding: 10px 16px 8px;
    border-top: 1px solid var(--theme-border);
    background: var(--theme-bg-primary);
  }
  .eve-chip {
    display: inline-flex; align-items: center;
    padding: 7px 13px;
    border: 1px solid var(--theme-border);
    border-radius: 20px;
    background: var(--theme-bg-secondary);
    color: var(--theme-text-secondary);
    font-size: 13px; cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .eve-chip:hover {
    background: var(--theme-bg-primary);
    border-color: var(--accent);
    color: var(--theme-text-primary);
  }

  /* Input */
  .eve-sheet-input-row {
    flex-shrink: 0;
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--theme-border);
    background: var(--theme-bg-primary);
  }
  .eve-sheet-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--theme-border);
    border-radius: 22px;
    font-size: 15px;
    color: var(--theme-text-primary);
    background: var(--theme-bg-tertiary);
    outline: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .eve-sheet-input:focus {
    border-color: var(--accent);
    background: var(--theme-bg-primary);
  }
  .eve-sheet-input:disabled { opacity: 0.5; }
  .eve-sheet-send {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background: var(--accent);
    color: var(--theme-bg-primary);
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    transition: opacity 0.15s ease, transform 0.1s ease;
  }
  .eve-sheet-send:hover:not(:disabled) { transform: scale(1.05); }
  .eve-sheet-send:disabled { opacity: 0.4; cursor: wait; }
</style>

<style is:global>
  /* ── BAUHAUS ─────────────────────────────────────────────────────────── */
  [data-theme="bauhaus"] .eve-sheet-header {
    background: #FAFAF6;
    border-bottom-color: #E3E1DA;
    gap: 12px;
  }
  [data-theme="bauhaus"] .eve-sheet-avatar {
    width: 38px; height: 38px;
    border-radius: 13px; background: #0A0A0A; color: #fff;
    display: grid; place-items: center; position: relative; flex-shrink: 0;
  }
  [data-theme="bauhaus"] .eve-sheet-avatar::after {
    content: ''; position: absolute; top: 5px; right: 5px;
    width: 6px; height: 6px; background: #FF4A82; border-radius: 50%;
  }
  [data-theme="bauhaus"] .eve-sheet-avatar svg { width: 18px; height: 18px; }
  [data-theme="bauhaus"] .eve-sheet-header-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px; font-weight: 700; letter-spacing: -0.01em;
  }
  [data-theme="bauhaus"] .eve-name-dot { color: #FF4A82; font-style: normal; }
  [data-theme="bauhaus"] .eve-sheet-header-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: #5C9070;
  }
  [data-theme="bauhaus"] .eve-sheet-header-eyebrow::before {
    content: '● '; font-size: 6px; vertical-align: middle;
  }
  [data-theme="bauhaus"] .eve-sheet-close {
    width: 32px; height: 32px;
    border: 1px solid #E3E1DA; background: #FFFFFF;
    border-radius: 10px; font-size: 15px; color: #6B6B66;
    cursor: pointer; transition: all 0.2s; display: grid; place-items: center;
  }
  [data-theme="bauhaus"] .eve-sheet-close:hover {
    background: #FFE600; border-color: #FFE600; color: #0A0A0A;
  }
  /* Pink-pulsing live-dot on eyebrow (remove old ::after, replaced with ::before above) */
  [data-theme="bauhaus"] .eve-sheet-header-eyebrow::after { display: none; }
  @keyframes eve-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }
  [data-theme="bauhaus"] .eve-message--user .eve-message-bubble {
    background: #0A0A0A; color: #FAFAF6;
    border-radius: 12px 12px 0 12px;
  }
  [data-theme="bauhaus"] .eve-message--assistant .eve-message-bubble {
    background: #FFFFFF; color: #0A0A0A;
    border: 1px solid #E3E1DA;
    border-radius: 12px 12px 12px 4px;
  }
  [data-theme="bauhaus"] .eve-sheet-input {
    border-radius: 12px; font-family: 'Space Grotesk', sans-serif;
  }
  [data-theme="bauhaus"] .eve-sheet-input:focus {
    outline: none; border-color: var(--accent, #FF4A82); background: #FFFFFF;
  }
  [data-theme="bauhaus"] .eve-sheet-send {
    border-radius: 12px; background: #0A0A0A;
  }
  [data-theme="bauhaus"] .eve-sheet-send:hover:not(:disabled) {
    background: var(--accent, #FF4A82); transform: none;
  }
  [data-theme="bauhaus"] .eve-chip {
    background: #FFFFFF; border: 1.5px solid #E3E1DA;
    border-radius: 18px; padding: 8px 13px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.05em; color: #0A0A0A;
    transition: background 0.15s, border-color 0.15s;
  }
  [data-theme="bauhaus"] .eve-chip:hover { background: var(--hover, #FFE600); border-color: var(--hover, #FFE600); }

  /* ── EDITORIAL ───────────────────────────────────────────────────────── */
  [data-theme="editorial"] .eve-sheet-header-name {
    font-family: var(--guest-font-display);
    font-style: italic; font-weight: 400;
    text-decoration: underline; text-underline-offset: 4px;
    text-decoration-color: var(--guest-accent);
  }
  [data-theme="editorial"] .eve-message--user .eve-message-bubble {
    background: var(--guest-accent); color: var(--guest-bg-card);
    border-radius: 0; font-family: var(--guest-font-body);
  }
  [data-theme="editorial"] .eve-message--assistant .eve-message-bubble {
    background: transparent; color: var(--guest-ink);
    border: 1px solid var(--guest-border);
    border-radius: 0; font-family: var(--guest-font-body);
  }
  [data-theme="editorial"] .eve-sheet-input {
    border: none; border-bottom: 1px solid var(--guest-border);
    border-radius: 0; background: transparent;
    font-family: var(--guest-font-display); font-style: italic;
  }
  [data-theme="editorial"] .eve-sheet-input:focus {
    outline: none; border-bottom-color: var(--guest-accent); box-shadow: none;
    background: transparent;
  }
  [data-theme="editorial"] .eve-sheet-input-row { border-top: none; }
  [data-theme="editorial"] .eve-sheet-send {
    border-radius: 0; background: var(--guest-accent);
  }
  [data-theme="editorial"] .eve-chips {
    display: flex; flex-direction: column; gap: 12px; align-items: flex-start;
  }
  [data-theme="editorial"] .eve-chip {
    background: transparent; border: none;
    border-bottom: 1px solid var(--guest-accent);
    border-radius: 0; color: var(--guest-accent);
    font-family: var(--guest-font-display); font-style: italic;
    font-size: 14px; padding: 4px 0;
  }
  [data-theme="editorial"] .eve-chip:hover {
    color: var(--guest-ink); border-bottom-color: var(--guest-ink);
  }
  [data-theme="editorial"] .eve-chips-label {
    font-family: var(--guest-font-display); font-style: italic;
    font-size: 12px; letter-spacing: 0;
  }

  /* ── MAISON ──────────────────────────────────────────────────────────── */
  [data-theme="maison"] .eve-sheet-header-eyebrow { letter-spacing: 0.20em; }
  [data-theme="maison"] .eve-sheet-header-name {
    font-family: var(--guest-font-display);
    letter-spacing: 0.15em; text-transform: uppercase; font-weight: 400;
  }
  [data-theme="maison"] .eve-sheet-header-name::before {
    content: '◆ '; color: var(--guest-accent); font-size: 9px;
  }
  [data-theme="maison"] .eve-sheet-header-name::after {
    content: ' ◆'; color: var(--guest-accent); font-size: 9px;
  }
  [data-theme="maison"] .eve-message--user .eve-message-bubble {
    background: var(--guest-bg-card); color: var(--guest-ink);
    border: none; border-right: 2px solid var(--guest-accent);
    border-radius: 0; padding-right: 14px;
    font-family: var(--guest-font-body);
  }
  [data-theme="maison"] .eve-message--assistant .eve-message-bubble {
    background: var(--guest-bg-deep); color: var(--guest-ink);
    border: none; border-left: 2px solid var(--guest-accent);
    border-radius: 0; padding-left: 14px;
    font-family: var(--guest-font-body);
  }
  [data-theme="maison"] .eve-sheet-input {
    border: 1px solid var(--guest-accent); border-radius: 0;
    background: var(--guest-bg-card);
    font-family: var(--guest-font-body); font-style: italic;
  }
  [data-theme="maison"] .eve-sheet-input:focus {
    outline: none; box-shadow: 0 0 0 1px var(--guest-accent);
    border-color: var(--guest-accent);
  }
  [data-theme="maison"] .eve-sheet-send {
    border-radius: 0; background: var(--guest-accent); color: var(--guest-bg-deep);
  }
  [data-theme="maison"] .eve-chips {
    display: flex; flex-direction: column; align-items: center;
    gap: 8px; text-align: center;
  }
  [data-theme="maison"] .eve-chips-label {
    letter-spacing: 0.15em; text-transform: uppercase; font-size: 9px;
    color: var(--guest-accent); font-family: var(--guest-font-mono);
  }
  [data-theme="maison"] .eve-chip {
    background: transparent; border: 1px solid var(--guest-border);
    border-radius: 0; color: var(--guest-ink-muted);
    font-family: var(--guest-font-display); font-size: 12px;
    letter-spacing: 0.08em; padding: 8px 20px;
  }
  [data-theme="maison"] .eve-chip:hover {
    border-color: var(--guest-accent); color: var(--guest-ink);
  }
</style>
