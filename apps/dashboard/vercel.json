{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "cd ../.. && pnpm --filter @retaha/dashboard-app build",
  "outputDirectory": ".vercel/output",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/mews-sync-all",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/stay-push-scheduler",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/pre-arrival-invites",
      "schedule": "0 8 * * *"
    }
  ]
}
