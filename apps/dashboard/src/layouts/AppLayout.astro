---
// Sprint E3 Phase 1 — AppLayout für Operations-Dashboard (/app/*)
//
// KAPSELUNGS-DISZIPLIN: dieses Layout importiert KEINE AdminLayout-Internals
// (NotificationBell, AdminFooter, etc.). Sprint F zieht /app sauber raus
// nach dashboard.retaha.de — je weniger Cross-Dependencies, desto einfacher.
//
// Mobile-first: Top-Bar mit Hotel-Name + Settings-Icon-Link (→ /admin),
// darunter horizontal scrollbare Tab-Bar. Auf Desktop: Tab-Bar zentriert
// neben Hotel-Name.

// Geteilte Header-Vars (Petrol/Tokens) + Theme-Mapping, damit die geteilte Navbar
// identisch zu Backoffice/Gast aussieht.
import '@retaha/ui/styles/themes.css';
import '@retaha/ui/styles/v9-colors.css';
import '@retaha/ui/styles/tokens.css';
import '@retaha/ui/styles/global.css';
import Header from '@retaha/ui/components/header/Header.astro';
import Toast from '@retaha/ui/components/shared/Toast.astro';
import { getHeaderUser } from '@retaha/auth';
import { normalizeLanguage } from '@retaha/i18n';

interface Props {
  title: string;
  hotel: { name: string; slug: string; logo_primary?: string | null; logo_dark?: string | null };
  user: { email: string };
}

const { title, hotel, user } = Astro.props;
const currentPath = Astro.url.pathname;

const BACKOFFICE = import.meta.env.BACKOFFICE_URL ?? 'https://backoffice.retaha.de';
const GUEST_APP  = import.meta.env.GUEST_APP_URL  ?? 'https://app.retaha.de';

// Sprache identisch zur Backoffice-Kette auflösen: ?lang → Cookie retaha_lang →
// Accept-Language → 'de'.
function resolveLang(): string {
  try {
    const urlLang = new URL(Astro.request.url).searchParams.get('lang');
    if (urlLang) return normalizeLanguage(urlLang);
  } catch { /* relative URL */ }
  const cookieLang = Astro.cookies.get('retaha_lang')?.value;
  if (cookieLang) return normalizeLanguage(cookieLang);
  const accept = Astro.request.headers.get('accept-language') ?? '';
  return normalizeLanguage(accept.split(',')[0]?.trim());
}

// Volles Header-Profil — dieselben Hotel-/User-Daten wie Backoffice + Gast-App.
const headerUser = await getHeaderUser(Astro.cookies, Astro.request, resolveLang());

interface NavItem { href: string; label: string; matchPrefix?: boolean }
const NAV: NavItem[] = [
  { href: '/app',           label: 'Übersicht' },
  { href: '/app/arrivals',  label: 'Anreisen' },
  { href: '/app/bookings',  label: 'Buchungen', matchPrefix: true },
  { href: '/app/service',   label: 'Service' },
  { href: '/app/qr',        label: 'QR-Codes' },
  { href: '/app/feedback',  label: 'Feedback' },
  { href: '/app/loyalty',   label: 'Loyalty' },
];

function isActive(item: NavItem): boolean {
  if (item.matchPrefix) return currentPath === item.href || currentPath.startsWith(item.href + '/');
  return currentPath === item.href;
}
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/apple-touch-icon-167x167.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon-precomposed.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title} · retaha operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="app-body">
    <!-- Geteilte App-Navbar (1:1 wie Backoffice/Gast) — Admin-Tab aktiv. -->
    {headerUser && (
      <Header
        activeTab="admin"
        user={headerUser}
        hotelName={hotel.name}
        hotelLogoUrl={hotel.logo_primary ?? hotel.logo_dark ?? null}
        bo={BACKOFFICE}
        guestBase={GUEST_APP}
        dashboardBase="/app"
      />
    )}

    <!-- Operations-Sub-Navigation (Dashboard-spezifisch, horizontal scrollbar auf mobile) -->
    <nav class="app-nav" aria-label="Operations-Navigation">
      <div class="app-nav-inner">
        {NAV.map(item => (
          <a
            href={item.href}
            class={`app-nav-tab${isActive(item) ? ' is-active' : ''}`}
            aria-current={isActive(item) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Page-Content -->
    <main class="app-main">
      <slot />
    </main>

    <!-- Footer (minimal, kapselt nicht AdminFooter) -->
    <footer class="app-footer">
      <span class="app-footer-email">{user.email}</span>
      <span class="app-footer-sep">·</span>
      <span class="app-footer-slug">/{hotel.slug}</span>
    </footer>

    <Toast />

    <script>
      import Alpine from 'alpinejs';
      // @ts-expect-error - Alpine types
      window.Alpine = Alpine;
      Alpine.start();
    </script>

    <style is:global>
      :root {
        /* Operations-Dashboard auf das neue Petrol-Design (statt Pink-Default aus themes.css). */
        --theme-accent: #14616E;
        --theme-accent-hover: #0F4D58;
        --theme-accent-rgb: 20, 97, 110;
      }
      .app-body {
        min-height: 100vh;
        background: var(--bg-deep, #fafafa);
        font-family: 'Space Grotesk', system-ui, sans-serif;
        color: var(--ink, #1A1A1A);
        margin: 0;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
      }
      [x-cloak] { display: none !important; }

      /* Operations-Sub-Nav — eigenständige Leiste unter der geteilten Navbar */
      .app-nav {
        background: var(--surface, #fff);
        border-bottom: 1px solid var(--border, #e8e8e8);
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }
      .app-nav::-webkit-scrollbar { display: none; }
      .app-nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        gap: 4px;
      }
      .app-nav-tab {
        flex-shrink: 0;
        padding: 12px 16px;
        font-size: 13px;
        color: var(--ink-muted, rgba(26, 26, 26, 0.55));
        text-decoration: none;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
        margin-bottom: -1px;
        white-space: nowrap;
      }
      .app-nav-tab:hover { color: var(--ink, #1A1A1A); }
      .app-nav-tab.is-active {
        color: var(--ink, #1A1A1A);
        border-bottom-color: var(--petrol, var(--theme-accent));
        font-weight: 500;
      }

      /* Main */
      .app-main {
        flex: 1;
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px 20px 48px;
        width: 100%;
        box-sizing: border-box;
      }
      @media (min-width: 768px) {
        .app-main { padding: 32px 20px 64px; }
      }

      /* Footer */
      .app-footer {
        padding: 16px 20px;
        text-align: center;
        font-size: 11px;
        color: rgba(26, 26, 26, 0.35);
        border-top: 1px solid #f0f0f0;
        font-family: 'JetBrains Mono', monospace;
        display: flex;
        justify-content: center;
        gap: 8px;
      }
      .app-footer-sep { color: rgba(26, 26, 26, 0.2); }
    </style>
  </body>
</html>
