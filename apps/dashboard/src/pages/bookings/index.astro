---
// Sprint E3 Phase 3 — Bookings-Verwaltung (migriert aus /admin/bookings)
//
// 1:1-Migration der 433-Zeilen-UI mit Kapselung (AppLayout statt
// AdminLayout, inline-Styles, keine i18n-Imports).
//
// Tag-12-Findings-Fix: Detail-Expansion. Click auf Booking-Row klappt
// auf — voll-aufgeklapptes details JSONB lesbar formatiert plus
// Eve-Audit-Context wenn die Buchung via Eve kam.

import AppLayout from '../../layouts/AppLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { loadBookingsForHotel } from '@retaha/db';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const url = new URL(Astro.request.url);
const filter = url.searchParams.get('filter') || 'today';
const typeFilter = url.searchParams.get('type') || 'breakfast';

const allBookings = await loadBookingsForHotel(hotel.id, typeFilter);

// ─── Eve-Audit-Lookup für alle Bookings dieser Liste ──────────
const bookingIds = allBookings.map((b: any) => b.id);
let auditByBookingId: Record<string, any> = {};
if (bookingIds.length > 0) {
  const { data: audits } = await client
    .from('eve_action_log')
    .select('id, action_type, action_params, conversation_context, result, result_data, created_at')
    .eq('hotel_id', hotel.id)
    .filter('result_data->>booking_id', 'in', `(${bookingIds.map(id => `"${id}"`).join(',')})`);
  for (const a of (audits ?? []) as any[]) {
    const bId = a.result_data?.booking_id;
    if (bId) auditByBookingId[bId] = a;
  }
}

// Date filtering helpers
const today = new Date();
today.setHours(0, 0, 0, 0);
const weekFromToday = new Date(today);
weekFromToday.setDate(weekFromToday.getDate() + 7);

const toLocalIso = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
const todayIso = toLocalIso(today);
const weekIso = toLocalIso(weekFromToday);

let filteredBookings = allBookings;
if (filter === 'today') {
  filteredBookings = allBookings.filter((b: any) => b.details?.date === todayIso);
} else if (filter === 'week') {
  filteredBookings = allBookings.filter((b: any) => {
    const d = b.details?.date;
    return d && d >= todayIso && d <= weekIso;
  });
}

const counts = {
  today: allBookings.filter((b: any) => b.details?.date === todayIso).length,
  week: allBookings.filter((b: any) => {
    const d = b.details?.date;
    return d && d >= todayIso && d <= weekIso;
  }).length,
  all: allBookings.length,
  pending: allBookings.filter((b: any) => (b.status || '').toLowerCase() === 'pending').length,
};

const fmtDate = (iso: string) => {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('de-DE', { weekday: 'short', day: '2-digit', month: 'short' });
};
const fmtTimeAgo = (iso: string) => {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'gerade eben';
  if (mins < 60) return `vor ${mins} Min`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `vor ${hours} Std`;
  const days = Math.floor(hours / 24);
  return `vor ${days} Tag${days > 1 ? 'en' : ''}`;
};

const tableLabels: Record<string, string> = { inside: 'Drinnen', outside: 'Draußen', garden: 'Garten', any: 'egal' };

const statusLabels: Record<string, { label: string; cls: string }> = {
  pending:   { label: 'Wartet auf Bestätigung', cls: 'status-pending' },
  confirmed: { label: 'Bestätigt',              cls: 'status-confirmed' },
  cancelled: { label: 'Abgelehnt',              cls: 'status-cancelled' },
};

// Helper: Items-Array lesbar formatieren ("Granola × 1 — inklusive")
function formatItems(items: any[]): string[] {
  if (!Array.isArray(items)) return [];
  return items.map((it: any) => {
    const qty = it.quantity ?? 1;
    const name = it.name ?? `Item ${it.breakfast_item_id?.slice(0, 8) ?? '?'}`;
    const priceCents = it.price_cents;
    const priceLabel = priceCents == null ? '' :
      priceCents === 0 ? ' — inklusive' :
      ` — €${(priceCents / 100).toFixed(2)}`;
    return `${qty > 1 ? `${qty}× ` : ''}${name}${priceLabel}`;
  });
}
---

<AppLayout title="Buchungen" hotel={hotel} user={{ email: user.email ?? '' }}>
  <header class="app-page-header">
    <p class="app-page-eyebrow themed-eyebrow-flank">Operations</p>
    <h1 class="app-page-title">Buchungen<span class="h-dot">.</span></h1>
  </header>

  <!-- Stats -->
  <div class="bk-stats">
    <div class="bk-stat-card">
      <div class="bk-stat-label">— Heute —</div>
      <div class="bk-stat-value">{counts.today}</div>
    </div>
    <div class="bk-stat-card">
      <div class="bk-stat-label">— Diese Woche —</div>
      <div class="bk-stat-value">{counts.week}</div>
    </div>
    <div class="bk-stat-card">
      <div class="bk-stat-label">— Gesamt —</div>
      <div class="bk-stat-value">{counts.all}</div>
    </div>
    <div class={`bk-stat-card${counts.pending > 0 ? ' bk-stat-card--warning' : ''}`}>
      <div class="bk-stat-label">— Wartet auf dich —</div>
      <div class="bk-stat-value">{counts.pending}</div>
    </div>
  </div>

  <!-- Type-Filter -->
  <div class="bk-tabs">
    {['breakfast', 'conference', 'service'].map(t => (
      <a
        href={`?filter=${filter}&type=${t}`}
        class={`bk-tab${typeFilter === t ? ' is-active' : ''}`}
      >
        {t === 'breakfast' ? 'Frühstück' : t === 'conference' ? 'Konferenz' : 'Service'}
      </a>
    ))}
  </div>

  <!-- Time-Filter -->
  <div class="bk-tabs bk-tabs--sub">
    {['today', 'week', 'all'].map(f => (
      <a
        href={`?filter=${f}&type=${typeFilter}`}
        class={`bk-tab${filter === f ? ' is-active' : ''}`}
      >
        {f === 'today' ? 'Heute' : f === 'week' ? 'Diese Woche' : 'Alle'}
      </a>
    ))}
  </div>

  <!-- Liste -->
  {filteredBookings.length === 0 ? (
    <div class="bk-empty">
      <p>Keine Buchungen in diesem Zeitraum.</p>
    </div>
  ) : (
    <div class="bk-list">
      {filteredBookings.map((b: any) => {
        const guest = b.stay?.guest;
        const room = b.stay?.room;
        const guestName = [guest?.first_name, guest?.last_name].filter(Boolean).join(' ') || 'Unbekannter Gast';
        const roomLabel = room ? [room.room_number, room.room_name].filter(Boolean).join(' · ') || '—' : '—';
        const normalizedStatus = (b.status || 'pending').toLowerCase();
        const status = statusLabels[normalizedStatus] || statusLabels.pending;
        const details = b.details || {};
        const tablePref = details.table_preference && details.table_preference !== 'any' ? tableLabels[details.table_preference] || details.table_preference : null;
        const audit = auditByBookingId[b.id];
        const isEveBooked = !!audit;
        const items = b.type === 'breakfast' ? formatItems(details.items ?? []) : [];

        return (
          <article class="bk-row" data-booking-id={b.id} x-data="{ open: false }">
            <!-- Click-row (compact summary) -->
            <button type="button" class="bk-row-head" @click="open = !open" :class="{ 'is-open': open }">
              <div class="bk-row-head-left">
                <div class="bk-row-badges">
                  <span class={`bk-status-badge ${status.cls}`}>{status.label}</span>
                  {isEveBooked && <span class="bk-eve-badge">🤖 Via Eve</span>}
                  <span class="bk-time-ago">{fmtTimeAgo(b.created_at)}</span>
                </div>
                <p class="bk-row-name">{guestName}</p>
                <p class="bk-row-room">Zimmer {roomLabel}</p>
              </div>
              <div class="bk-row-head-right">
                <span class="bk-row-summary">
                  {b.type === 'breakfast' && details.date && `${fmtDate(details.date)} · ${details.time ?? ''}`}
                  {b.type === 'service' && (details.item_name ?? '—')}
                  {b.type === 'conference' && details.date && `${fmtDate(details.date)} · ${details.room_name ?? ''}`}
                </span>
                <span class="bk-row-chevron" :class="{ 'is-open': open }">▾</span>
              </div>
            </button>

            <!-- Expanded details (Tag-12-Fix) -->
            <div x-show="open" x-cloak class="bk-row-expanded">
              <!-- Standard-Felder per type -->
              {b.type === 'breakfast' && (
                <div class="bk-detail-grid">
                  <div><div class="bk-detail-label">Datum</div><div class="bk-detail-value">{fmtDate(details.date)}</div></div>
                  <div><div class="bk-detail-label">Zeit</div><div class="bk-detail-value">{details.time || details.time_slot || '—'}</div></div>
                  <div><div class="bk-detail-label">Personen</div><div class="bk-detail-value">{details.people || '—'}</div></div>
                  <div><div class="bk-detail-label">Tisch</div><div class="bk-detail-value">{tablePref || '—'}</div></div>
                  {details.delivery && (
                    <div>
                      <div class="bk-detail-label">Lieferart</div>
                      <div class="bk-detail-value">
                        {details.delivery === 'room'
                          ? `Zimmer${details.room_number ? ` ${details.room_number}` : ''}`
                          : 'Tisch'}
                      </div>
                    </div>
                  )}
                </div>
              )}
              {b.type === 'conference' && (
                <div class="bk-detail-grid">
                  <div><div class="bk-detail-label">Datum</div><div class="bk-detail-value">{fmtDate(details.date)}</div></div>
                  <div><div class="bk-detail-label">Zeit</div><div class="bk-detail-value">{details.time || '—'}</div></div>
                  <div><div class="bk-detail-label">Dauer</div><div class="bk-detail-value">{details.duration_hours ? `${details.duration_hours} h` : '—'}</div></div>
                  <div><div class="bk-detail-label">Personen</div><div class="bk-detail-value">{details.people || '—'}</div></div>
                  <div><div class="bk-detail-label">Salon</div><div class="bk-detail-value">{details.room_name || '—'}</div></div>
                </div>
              )}
              {b.type === 'service' && (
                <div class="bk-detail-grid">
                  <div><div class="bk-detail-label">Item</div><div class="bk-detail-value">{details.item_name || '—'}</div></div>
                  <div><div class="bk-detail-label">Wann</div><div class="bk-detail-value">{details.timing === 'now' ? 'Sofort' : (details.time || '—')}</div></div>
                  <div><div class="bk-detail-label">Eingang</div><div class="bk-detail-value">{new Date(b.created_at).toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' })}</div></div>
                </div>
              )}

              <!-- Items-Liste (breakfast / service mit items-array) -->
              {items.length > 0 && (
                <div class="bk-detail-block">
                  <div class="bk-detail-label">Items</div>
                  <ul class="bk-items">
                    {items.map(line => <li>{line}</li>)}
                  </ul>
                </div>
              )}

              {b.type === 'conference' && details.occasion && (
                <div class="bk-detail-block">
                  <div class="bk-detail-label">Anlass</div>
                  <p class="bk-detail-text">{details.occasion}</p>
                </div>
              )}

              {details.notes && (
                <div class="bk-detail-block">
                  <div class="bk-detail-label">Notiz vom Gast</div>
                  <p class="bk-detail-quote">„{details.notes}"</p>
                </div>
              )}

              <!-- Eve-Audit-Context (Tag-12-Findings) -->
              {isEveBooked && (
                <div class="bk-detail-block bk-eve-context">
                  <div class="bk-detail-label">🤖 Via Eve gebucht</div>
                  {audit.conversation_context ? (
                    <pre class="bk-eve-conversation">{audit.conversation_context}</pre>
                  ) : (
                    <p class="bk-detail-text">Conversation-Context nicht gespeichert.</p>
                  )}
                </div>
              )}

              <!-- UX-017 P2 — Mews-Charge-Fehler-Banner + Retry-Button -->
              {b.mews_push_error && !b.mews_cancelled_at && (
                <div class="mews-error-banner">
                  <p class="mews-error-eyebrow themed-eyebrow-flank">mews-charge fehlgeschlagen</p>
                  <p class="mews-error-meta">
                    Letzter Versuch:&nbsp;
                    {b.mews_push_attempted_at
                      ? new Date(b.mews_push_attempted_at).toLocaleString('de-DE', {
                          dateStyle: 'short', timeStyle: 'short',
                        })
                      : '—'}
                  </p>
                  <pre class="mews-error-reason">{b.mews_push_error}</pre>
                  <button
                    type="button"
                    class="bk-btn bk-btn--primary mews-retry-btn"
                    data-action="retry-mews"
                    data-booking-id={b.id}
                  >erneut versuchen</button>
                </div>
              )}

              <!-- Action-Buttons -->
              <div class="bk-actions">
                {b.status !== 'confirmed' && (
                  <button type="button" data-action="confirm" data-booking-id={b.id} class="bk-btn bk-btn--primary">Bestätigen</button>
                )}
                {b.status !== 'cancelled' && (
                  <button type="button" data-action="cancel" data-booking-id={b.id} class="bk-btn bk-btn--secondary">Ablehnen</button>
                )}
                {b.status !== 'pending' && (
                  <button type="button" data-action="reset" data-booking-id={b.id} class="bk-btn bk-btn--ghost" title="Zurück auf Wartend">↺ Zurück</button>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  )}

  <!-- Toast -->
  <div id="toast-container" class="bk-toast-container"></div>

  <script is:inline>
    function showToast(message, type) {
      const c = document.getElementById('toast-container');
      if (!c) return;
      const t = document.createElement('div');
      t.className = 'bk-toast bk-toast--' + (type === 'error' ? 'error' : 'success');
      t.textContent = message;
      c.appendChild(t);
      setTimeout(() => t.remove(), 3500);
    }

    async function handleRetryMewsClick(e) {
      const btn = e.currentTarget;
      const bookingId = btn.dataset.bookingId;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'wird gesendet…';
      try {
        const res = await fetch(`/api/bookings/${bookingId}/retry-mews-push`, {
          method: 'POST',
        });
        const data = await res.json();
        if (data.success) {
          showToast('charge erfolgreich gesendet', 'success');
          setTimeout(() => window.location.reload(), 800);
        } else {
          showToast('fehler: ' + (data.error || 'unbekannt'), 'error');
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch (err) {
        showToast('netzwerk-fehler: ' + (err.message || ''), 'error');
        btn.disabled = false;
        btn.textContent = original;
      }
    }

    async function handleActionClick(e) {
      const btn = e.currentTarget;
      const action = btn.dataset.action;
      if (action === 'retry-mews') return handleRetryMewsClick(e);
      const bookingId = btn.dataset.bookingId;
      const map = { confirm: 'confirmed', cancel: 'cancelled', reset: 'pending' };
      const newStatus = map[action];
      if (!newStatus) return;
      if (action === 'cancel' && !confirm('Wirklich ablehnen? Der Gast sieht das sofort.')) return;

      const row = btn.closest('[data-booking-id]');
      const buttons = row ? row.querySelectorAll('button[data-action]') : [];
      buttons.forEach(b => b.disabled = true);

      try {
        const res = await fetch('/api/bookings/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ booking_id: bookingId, status: newStatus }),
        });
        const data = await res.json();
        if (!data.ok) {
          showToast('Fehler: ' + (data.error || 'unbekannt'), 'error');
          buttons.forEach(b => b.disabled = false);
          return;
        }
        showToast({
          confirmed: 'Bestätigt — Gast sieht das beim nächsten Reload.',
          cancelled: 'Abgelehnt — Gast sieht das beim nächsten Reload.',
          pending: 'Zurück auf Wartend.',
        }[newStatus] || 'Status geändert.', 'success');
        // Soft reload nach 1s damit Status-Badge aktuell ist
        setTimeout(() => window.location.reload(), 1000);
      } catch (err) {
        showToast('Netzwerk-Fehler: ' + (err.message || ''), 'error');
        buttons.forEach(b => b.disabled = false);
      }
    }

    document.querySelectorAll('button[data-action]').forEach(b => b.addEventListener('click', handleActionClick));
  </script>

  <style>
    .app-page-header { margin-bottom: 24px; }
    .app-page-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); margin: 0 0 8px; }
    .app-page-title { font-size: 26px; font-weight: 300; letter-spacing: -0.01em; margin: 0; color: var(--theme-text-primary); }
    @media (min-width: 768px) { .app-page-title { font-size: 32px; } }

    /* Stats */
    .bk-stats {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;
      margin-bottom: 20px;
    }
    @media (min-width: 640px) { .bk-stats { grid-template-columns: repeat(4, 1fr); gap: 12px; } }
    .bk-stat-card { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 14px; }
    .bk-stat-card--warning { background: rgba(var(--theme-accent-rgb), .04); border-color: var(--theme-accent); }
    .bk-stat-label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin-bottom: 6px; }
    .bk-stat-value { font-size: 24px; font-weight: 300; color: var(--theme-text-primary); font-variant-numeric: tabular-nums; }
    .bk-stat-card--warning .bk-stat-value { font-weight: 500; color: var(--theme-accent); }

    /* Tabs */
    .bk-tabs { display: flex; gap: 2px; border-bottom: 1px solid var(--theme-border); margin-bottom: 8px; overflow-x: auto; }
    .bk-tabs--sub { margin-bottom: 20px; }
    .bk-tabs::-webkit-scrollbar { display: none; }
    .bk-tab {
      padding: 10px 16px;
      font-size: 13px;
      color: color-mix(in srgb, var(--theme-text-primary) .55, transparent);
      text-decoration: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      white-space: nowrap;
      transition: color .15s, border-color .15s;
    }
    .bk-tab:hover { color: var(--theme-text-primary); }
    .bk-tab.is-active { color: var(--theme-text-primary); border-bottom-color: var(--theme-accent); font-weight: 500; }

    .bk-empty { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 48px 24px; text-align: center; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); font-style: italic; }
    .bk-list { display: flex; flex-direction: column; gap: 8px; }

    /* Row */
    .bk-row { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); }
    .bk-row-head {
      width: 100%; padding: 16px;
      background: transparent; border: none; cursor: pointer; text-align: left;
      display: flex; align-items: flex-start; gap: 16px; justify-content: space-between;
      transition: background .12s;
    }
    .bk-row-head:hover { background: rgba(0,0,0,.02); }
    .bk-row-head.is-open { background: rgba(0,0,0,.02); border-bottom: 1px solid var(--theme-border); }
    .bk-row-head-left { flex: 1; min-width: 0; }
    .bk-row-badges { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; align-items: center; }
    .bk-status-badge { font-size: 10px; padding: 3px 8px; border: 1px solid; letter-spacing: 0.04em; }
    /* Marken-DNA: pending=stein, confirmed=sage, cancelled=pink */
    .status-pending {
      background: color-mix(in srgb, var(--theme-text-primary) 6%, transparent);
      color: color-mix(in srgb, var(--theme-text-primary) 70%, transparent);
      border-color: color-mix(in srgb, var(--theme-text-primary) 20%, transparent);
    }
    .status-confirmed {
      background: color-mix(in srgb, var(--theme-success) 10%, transparent);
      color: var(--theme-success);
      border-color: color-mix(in srgb, var(--theme-success) 35%, transparent);
    }
    .status-cancelled {
      background: rgba(var(--theme-accent-rgb), 0.08);
      color: var(--theme-accent);
      border-color: rgba(var(--theme-accent-rgb), 0.35);
    }
    .bk-eve-badge { font-size: 10px; padding: 3px 8px; background: rgba(var(--theme-accent-rgb), .08); color: var(--theme-accent); border: 1px solid rgba(var(--theme-accent-rgb), .3); }
    .bk-time-ago { font-size: 11px; color: color-mix(in srgb, var(--theme-text-primary) .4, transparent); font-family: var(--theme-font-mono); }
    .bk-row-name { margin: 0 0 2px; font-size: 16px; font-weight: 500; color: var(--theme-text-primary); }
    .bk-row-room { margin: 0; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }
    .bk-row-head-right { display: flex; align-items: center; gap: 12px; flex-shrink: 0; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); font-size: 13px; }
    .bk-row-summary { display: none; }
    @media (min-width: 768px) { .bk-row-summary { display: inline; } }
    .bk-row-chevron { transition: transform .2s; font-size: 12px; }
    .bk-row-chevron.is-open { transform: rotate(180deg); }

    /* Expanded */
    .bk-row-expanded { padding: 20px; background: var(--theme-bg-secondary); }
    .bk-detail-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
      margin-bottom: 16px;
    }
    @media (min-width: 640px) { .bk-detail-grid { grid-template-columns: repeat(4, 1fr); } }
    .bk-detail-label {
      font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
      color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin-bottom: 4px;
    }
    .bk-detail-value { font-size: 14px; font-weight: 500; color: var(--theme-text-primary); }
    .bk-detail-block { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--theme-border); }
    .bk-detail-text { margin: 4px 0 0; font-size: 14px; color: var(--theme-text-primary); }
    .bk-detail-quote {
      margin: 6px 0 0;
      padding: 10px 12px;
      background: var(--theme-bg-primary);
      border-left: 3px solid color-mix(in srgb, var(--theme-text-primary) .2, transparent);
      font-size: 14px; font-style: italic; color: color-mix(in srgb, var(--theme-text-primary) .85, transparent);
    }
