---
// Dashboard 404 — v9 Control-Surface, interner Ton. Standalone (keine Auth/DB),
// rendert immer; auto-serviert für unbekannte Routen.
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/inter-tight/400.css';
import '@fontsource/jetbrains-mono/400.css';

Astro.response.status = 404;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FAFAF8" />
    <title>Seite nicht gefunden · retaha Dashboard</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0; min-height: 100dvh; background: #FAFAF8; color: #0A0A0A;
        font-family: 'Inter Tight', system-ui, sans-serif;
        display: flex; align-items: center; justify-content: center;
        padding: 24px; -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: 460px; width: 100%; text-align: center; }
      .code {
        font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.18em;
        text-transform: uppercase; color: #0A0A0A; background: #FFE600;
        display: inline-block; padding: 5px 11px; border-radius: 8px; margin: 0 0 22px; font-weight: 500;
      }
      .title {
        font-family: 'Space Grotesk', sans-serif; font-weight: 500;
        font-size: clamp(26px, 6vw, 34px); letter-spacing: -0.02em; line-height: 1.12;
        margin: 0 0 12px; color: #0A0A0A;
      }
      .title .dot { color: #FF4A82; }
      .body { font-size: 14px; line-height: 1.55; color: rgba(10,10,10,0.6); margin: 0 auto 28px; max-width: 360px; }
      .cta {
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
        font-family: 'Space Grotesk', sans-serif; font-weight: 500; font-size: 14px;
        color: #FAFAF8; background: #0A0A0A; border-radius: 10px; padding: 12px 22px;
        transition: background 0.14s ease;
      }
      .cta:hover { background: #2A2A2A; }
      .cta svg { width: 15px; height: 15px; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <span class="code">404</span>
      <h1 class="title">Seite nicht gefunden<span class="dot">.</span></h1>
      <p class="body">Diese Seite gibt es nicht (mehr). Vielleicht wurde sie verschoben oder die Adresse ist nicht korrekt.</p>
      <a class="cta" href="/">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
        </svg>
        Zum Dashboard
      </a>
    </main>
  </body>
</html>
