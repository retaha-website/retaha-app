---
// Dashboard · Anreisen — heutige Ankünfte mit manuellem "Zimmer bereit"-Push
//
// Listet Stays mit check_in-Datum = heute. Jede Zeile hat einen "Zimmer bereit"-
// Button, der POST /app/api/stays/room-ready aufruft und einen Stay-Push sendet.
// Konzept: operative Rezeptionsansicht (nicht Backoffice-Konfiguration).

import AppLayout from '../layouts/AppLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance, buildLoginRedirect } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect(buildLoginRedirect(Astro.url));

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect(buildLoginRedirect(Astro.url));

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const todayIso = new Date().toISOString().slice(0, 10);
const todayStart = `${todayIso}T00:00:00.000Z`;
const todayEnd   = `${todayIso}T23:59:59.999Z`;

const { data: arrivalsRaw } = await client
  .from('stays')
  .select('id, check_in, check_out, state, guests(first_name, last_name), rooms(room_number, room_name)')
  .eq('hotel_id', hotel.id)
  .gte('check_in', todayStart)
  .lte('check_in', todayEnd)
  .order('check_in', { ascending: true });

const arrivals = (arrivalsRaw ?? []) as Array<{
  id: string;
  check_in: string;
  check_out: string;
  state: string;
  guests: { first_name: string | null; last_name: string | null } | null;
  rooms: { room_number: string | null; room_name: string | null } | null;
}>;

function fmtTime(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '—';
  return d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
}
---

<AppLayout title="Anreisen" hotel={hotel} user={{ email: user.email ?? '' }}>
  <header class="app-page-header">
    <p class="app-page-eyebrow themed-eyebrow-flank">{todayIso}</p>
    <h1 class="app-page-title">Anreisen heute<span class="h-dot">.</span></h1>
  </header>

  {arrivals.length === 0 ? (
    <div class="arr-empty">Keine Anreisen für heute erfasst.</div>
  ) : (
    <div class="arr-list" id="arr-list">
      {arrivals.map((stay) => {
        const guest = stay.guests as any;
        const room  = stay.rooms as any;
        const name = [guest?.first_name, guest?.last_name].filter(Boolean).join(' ') || 'Gast';
        const roomLabel = room?.room_number
          ? `Zimmer ${room.room_number}${room.room_name ? ` (${room.room_name})` : ''}`
          : room?.room_name ?? '—';
        return (
          <div class="arr-row" data-stay-id={stay.id}>
            <div class="arr-info">
              <p class="arr-name">{name}</p>
              <p class="arr-meta">{roomLabel} · Check-in {fmtTime(stay.check_in)}</p>
            </div>
            <div class="arr-actions">
              <button
                class="arr-btn-ready"
                data-stay-id={stay.id}
                data-guest={name}
                type="button"
              >
                Zimmer bereit
              </button>
              <span class="arr-status" aria-live="polite"></span>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <script>
    document.querySelectorAll<HTMLButtonElement>('.arr-btn-ready').forEach(btn => {
      btn.addEventListener('click', async () => {
        const stayId = btn.dataset.stayId!;
        const guestName = btn.dataset.guest ?? 'Gast';
        const statusEl = btn.nextElementSibling as HTMLElement | null;

        btn.disabled = true;
        btn.textContent = '…';
        if (statusEl) statusEl.textContent = '';

        try {
          const res = await fetch('/app/api/stays/room-ready', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ stay_id: stayId }),
          });
          const data = await res.json();
          if (data.ok || data.status === 'skipped_already_sent') {
            btn.textContent = '✓ Gesendet';
            btn.classList.add('arr-btn-sent');
            if (statusEl) statusEl.textContent = data.status === 'skipped_already_sent' ? '(bereits gesendet)' : '';
          } else {
            btn.disabled = false;
            btn.textContent = 'Zimmer bereit';
            if (statusEl) {
              statusEl.textContent = data.status === 'skipped_template_inactive'
                ? 'Template inaktiv'
                : data.status === 'skipped_template_missing'
                ? 'Kein Template'
                : data.status === 'skipped_no_pass'
                ? 'Kein Wallet-Pass'
                : 'Fehler';
              statusEl.classList.add('arr-status-err');
            }
          }
        } catch {
          btn.disabled = false;
          btn.textContent = 'Zimmer bereit';
          if (statusEl) { statusEl.textContent = 'Netzwerkfehler'; statusEl.classList.add('arr-status-err'); }
        }
      });
    });
  </script>

  <style>
    .arr-empty {
      padding: 48px 24px;
      text-align: center;
      color: var(--ink-muted);
      font-size: 14px;
    }

    .arr-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--border);
    }

    .arr-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
    }
    .arr-row:last-child { border-bottom: none; }

    .arr-info { flex: 1; min-width: 0; }
    .arr-name { margin: 0 0 2px; font-size: 15px; font-weight: 500; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .arr-meta { margin: 0; font-size: 12px; color: var(--ink-muted); }

    .arr-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

    .arr-btn-ready {
      padding: 8px 14px;
      background: var(--ink);
      color: var(--surface);
      border: none;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
      font-family: inherit;
      white-space: nowrap;
      transition: background 0.15s;
    }
    .arr-btn-ready:hover:not(:disabled) { background: #14616e; }
    .arr-btn-ready:disabled { opacity: 0.6; cursor: not-allowed; }
    .arr-btn-ready.arr-btn-sent { background: #14616e; }

    .arr-status { font-size: 11px; color: var(--ink-muted); }
    .arr-status-err { color: #c0392b; }
  </style>
</AppLayout>
