---
// Dashboard · Anreisen — heutige Ankünfte mit manuellem "Zimmer bereit"-Push
//
// Listet Stays mit check_in-Datum = heute. Jede Zeile hat einen "Zimmer bereit"-
// Button, der POST /app/api/stays/room-ready aufruft und einen Stay-Push sendet.
// Konzept: operative Rezeptionsansicht (nicht Backoffice-Konfiguration).

import AppLayout from '../layouts/AppLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance, buildLoginRedirect } from '@retaha/auth';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect(buildLoginRedirect(Astro.url));

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect(buildLoginRedirect(Astro.url));

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

const todayIso = new Date().toISOString().slice(0, 10);
const todayStart = `${todayIso}T00:00:00.000Z`;
const todayEnd   = `${todayIso}T23:59:59.999Z`;

const { data: arrivalsRaw } = await client
  .from('stays')
  .select('id, check_in, check_out, state, guests(first_name, last_name), rooms(room_number, room_name)')
  .eq('hotel_id', hotel.id)
  .gte('check_in', todayStart)
  .lte('check_in', todayEnd)
  .order('check_in', { ascending: true });

const arrivals = (arrivalsRaw ?? []) as Array<{
  id: string;
  check_in: string;
  check_out: string;
  state: string;
  guests: { first_name: string | null; last_name: string | null } | null;
  rooms: { room_number: string | null; room_name: string | null } | null;
}>;

const todayLabel = new Date().toLocaleDateString('de-DE', { weekday: 'long', day: 'numeric', month: 'long' });

function fmtTime(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '—';
  return d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
}
---

<AppLayout title="Anreisen" hotel={hotel} user={{ email: user.email ?? '' }}>
  <header class="app-page-header">
    <p class="app-page-eyebrow themed-eyebrow-flank">{todayLabel}</p>
    <h1 class="app-page-title">Anreisen heute<span class="h-dot">.</span></h1>
  </header>

  <div class="arr-count-bar">
    <span class="arr-count-num">{arrivals.length}</span>
    <span class="arr-count-label">{arrivals.length === 1 ? 'Anreise' : 'Anreisen'} für heute</span>
  </div>

  {arrivals.length === 0 ? (
    <div class="arr-empty">
      <p class="arr-empty-icon">✓</p>
      <p class="arr-empty-text">Keine Anreisen für heute erfasst.</p>
    </div>
  ) : (
    <div class="arr-list">
      {arrivals.map((stay) => {
        const guest = stay.guests as any;
        const room  = stay.rooms as any;
        const name = [guest?.first_name, guest?.last_name].filter(Boolean).join(' ') || 'Gast';
        const roomNumber = room?.room_number ?? null;
        const roomName   = room?.room_name ?? null;
        const roomLabel  = roomNumber
          ? `Zimmer ${roomNumber}${roomName ? ` · ${roomName}` : ''}`
          : roomName ?? '—';
        const checkInTime  = fmtTime(stay.check_in);
        const checkOutTime = fmtTime(stay.check_out);
        return (
          <article class="arr-row" data-stay-id={stay.id}>
            <div class="arr-row-inner">
              <div class="arr-guest">
                <div class="arr-avatar">{name.slice(0,1).toUpperCase()}</div>
                <div class="arr-info">
                  <p class="arr-name">{name}</p>
                  <p class="arr-meta">
                    {roomLabel}
                    {checkInTime !== '—' && <span class="arr-meta-sep">·</span>}
                    {checkInTime !== '—' && <span>Check-in {checkInTime}</span>}
                    {checkOutTime !== '—' && <span class="arr-meta-sep">·</span>}
                    {checkOutTime !== '—' && <span>Check-out {checkOutTime}</span>}
                  </p>
                </div>
              </div>
              <div class="arr-action-col">
                <button
                  class="arr-btn"
                  data-stay-id={stay.id}
                  type="button"
                >
                  Zimmer bereit
                </button>
                <span class="arr-status-msg" aria-live="polite"></span>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  )}

  <script>
    document.querySelectorAll<HTMLButtonElement>('.arr-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const stayId = btn.dataset.stayId!;
        const statusEl = btn.nextElementSibling as HTMLElement | null;

        btn.disabled = true;
        btn.textContent = '…';
        if (statusEl) { statusEl.textContent = ''; statusEl.className = 'arr-status-msg'; }

        try {
          const res = await fetch('/app/api/stays/room-ready', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ stay_id: stayId }),
          });
          const data = await res.json();
          if (data.ok || data.status === 'skipped_already_sent') {
            btn.textContent = '✓ Gesendet';
            btn.classList.add('arr-btn--sent');
            if (statusEl && data.status === 'skipped_already_sent') {
              statusEl.textContent = 'bereits gesendet';
            }
          } else {
            btn.disabled = false;
            btn.textContent = 'Zimmer bereit';
            if (statusEl) {
              const msgMap: Record<string, string> = {
                skipped_template_inactive: 'Template inaktiv',
                skipped_template_missing:  'Kein Template konfiguriert',
                skipped_no_pass:           'Kein Wallet-Pass',
                skipped_guard:             'Push blockiert',
              };
              statusEl.textContent = msgMap[data.status] ?? 'Fehler';
              statusEl.classList.add('arr-status-msg--err');
            }
          }
        } catch {
          btn.disabled = false;
          btn.textContent = 'Zimmer bereit';
          if (statusEl) {
            statusEl.textContent = 'Netzwerkfehler';
            statusEl.classList.add('arr-status-msg--err');
          }
        }
      });
    });
  </script>

  <style>
    .app-page-header { margin-bottom: 24px; }

    /* Count bar */
    .arr-count-bar {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 20px;
    }
    .arr-count-num {
      font-size: 32px;
      font-weight: 500;
      color: var(--theme-text-primary);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .arr-count-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: color-mix(in srgb, var(--theme-text-primary) .45, transparent);
    }

    /* Empty state */
    .arr-empty {
      background: var(--theme-bg-primary);
      border: 1px solid var(--theme-border);
      border-radius: 16px;
      padding: 56px 24px;
      text-align: center;
    }
    .arr-empty-icon {
      font-size: 24px;
      margin: 0 0 12px;
      color: var(--theme-success);
      line-height: 1;
    }
    .arr-empty-text {
      margin: 0;
      font-size: 14px;
      color: color-mix(in srgb, var(--theme-text-primary) .5, transparent);
      font-style: italic;
    }

    /* List */
    .arr-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    /* Row */
    .arr-row {
      background: var(--theme-bg-primary);
      border: 1px solid var(--theme-border);
      border-radius: 16px;
      overflow: hidden;
      transition: box-shadow .16s ease, transform .16s ease;
    }
    .arr-row:hover {
      box-shadow: 0 10px 28px rgba(40, 30, 20, .08);
      transform: translateY(-2px);
    }
    .arr-row-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 22px;
    }

    /* Guest info */
    .arr-guest {
      display: flex;
      align-items: center;
      gap: 14px;
      flex: 1;
      min-width: 0;
    }
    .arr-avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: color-mix(in srgb, var(--theme-accent) 12%, transparent);
      color: var(--theme-accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      font-weight: 600;
      flex-shrink: 0;
    }
    .arr-info { flex: 1; min-width: 0; }
    .arr-name {
      margin: 0 0 3px;
      font-size: 16px;
      font-weight: 500;
      color: var(--theme-text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .arr-meta {
      margin: 0;
      font-size: 13px;
      color: color-mix(in srgb, var(--theme-text-primary) .55, transparent);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 4px;
    }
    .arr-meta-sep { opacity: .4; }

    /* Action */
    .arr-action-col {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
      flex-shrink: 0;
    }
    .arr-btn {
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 500;
      font-family: inherit;
      border: 1px solid var(--theme-accent);
      border-radius: 8px;
      background: var(--theme-accent);
      color: var(--theme-bg-primary);
      cursor: pointer;
      white-space: nowrap;
      transition: background .15s, border-color .15s, opacity .15s;
    }
    .arr-btn:hover:not(:disabled) {
      background: var(--theme-accent-hover, var(--theme-accent));
      border-color: var(--theme-accent-hover, var(--theme-accent));
    }
    .arr-btn:disabled { opacity: .6; cursor: not-allowed; }
    .arr-btn--sent {
      background: var(--theme-success);
      border-color: var(--theme-success);
    }

    .arr-status-msg {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.05em;
      color: color-mix(in srgb, var(--theme-text-primary) .45, transparent);
      text-align: right;
    }
    .arr-status-msg--err {
      color: var(--theme-accent);
    }
  </style>
</AppLayout>
