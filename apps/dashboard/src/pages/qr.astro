---
// Sprint E3 Phase 5 — QR-Codes UI
//
// Hotel-weiter QR (Download PNG/SVG) + Pro-Zimmer-Sektion mit Hinweis bei
// 0 rooms. Hotel-weit nutzt first-active-stay-token-Workaround → braucht
// mindestens 1 aktiven Stay damit der QR funktioniert. Pro-Zimmer nutzt
// room_code-Pairing (Sprint D Phase 3).
//
// Demo-Hotel-Realität: 0 rooms → Empty-State + Hinweis auf Mews-Room-Bug.
// PDF-Export kommt in Phase 6.

import AppLayout from '../layouts/AppLayout.astro';
import { getUser, getUserHotels, createSupabaseServerInstance } from '@retaha/auth';
import { getGuestBaseUrl, buildGuestStayUrl, buildGuestRoomUrl } from '../lib/qr/base-url';

const user = await getUser(Astro.cookies, Astro.request);
if (!user) return Astro.redirect('/admin/login');

const hotels = await getUserHotels(Astro.cookies, Astro.request);
const hotel = hotels?.[0]?.hotel;
if (!hotel) return Astro.redirect('/admin/login?error=no_hotel');

const client = createSupabaseServerInstance(Astro.cookies, Astro.request);

// First-active-stay-token Workaround Vorschau
const { data: firstStay } = await client
  .from('stays')
  .select('access_token, state, check_in, guest:guests(first_name, last_name), room:rooms(room_number, room_name)')
  .eq('hotel_id', hotel.id)
  .in('state', ['Confirmed', 'Started'])
  .not('access_token', 'is', null)
  .order('check_in', { ascending: true })
  .limit(1)
  .maybeSingle();

// Rooms-Liste (mit room_code) — falls Mews-Sync funktionierte
const { data: rooms } = await client
  .from('rooms')
  .select('id, room_code, room_number, room_name, is_active')
  .eq('hotel_id', hotel.id)
  .eq('is_active', true)
  .order('room_number', { ascending: true });

const roomsList = rooms ?? [];
const roomsWithCode = roomsList.filter((r: any) => r.room_code);
const baseUrl = getGuestBaseUrl(Astro.request.url);
const hotelTargetUrl = firstStay?.access_token ? buildGuestStayUrl(firstStay.access_token, Astro.request.url) : null;
---

<AppLayout title="QR-Codes" hotel={hotel} user={{ email: user.email ?? '' }}>
  <header class="app-page-header">
    <p class="app-page-eyebrow">— Operations —</p>
    <h1 class="app-page-title">QR-Codes.</h1>
    <p class="app-page-sub">
      Gast-Frontend-Basis: <code class="env-code">{baseUrl}</code>
      {import.meta.env.PUBLIC_GUEST_BASE_URL ? <span class="env-note">aus PUBLIC_GUEST_BASE_URL</span> : <span class="env-note env-note--dev">Default — setze PUBLIC_GUEST_BASE_URL in Production</span>}
    </p>
  </header>

  <!-- Hotel-weiter QR -->
  <section class="qr-section">
    <h2 class="qr-section-title">Hotel-weiter QR-Code</h2>
    <p class="qr-section-desc">Aushang an Rezeption, Lobby, im Fahrstuhl. Gast scannt → Holzkarten-Flow startet automatisch.</p>

    {hotelTargetUrl ? (
      <div class="qr-card">
        <div class="qr-preview">
          <img src={`/api/qr/hotel/${hotel.id}?format=svg`} alt="Hotel-QR" class="qr-image" />
        </div>
        <div class="qr-meta">
          <div class="qr-meta-label">Ziel-URL</div>
          <code class="qr-meta-url">{hotelTargetUrl}</code>

          <div class="qr-meta-label" style="margin-top: 16px;">Workaround</div>
          <p class="qr-meta-note">
            Aktuell auf den access_token des ersten aktiven Stays gemappt
            (<strong>{firstStay?.guest?.first_name} {firstStay?.guest?.last_name}</strong>
            {firstStay?.room?.room_number && <span>, Zimmer {firstStay.room.room_number}</span>}).
            Später wird ein dedizierter Hotel-Token vergeben — bis dahin reicht das für die Pilot-Demo.
          </p>

          <div class="qr-downloads">
            <a href={`/api/qr/hotel/${hotel.id}?format=svg&download=1`} class="qr-btn qr-btn--primary">↓ SVG</a>
            <a href={`/api/qr/hotel/${hotel.id}?format=png&download=1`} class="qr-btn qr-btn--secondary">↓ PNG</a>
            <a href={hotelTargetUrl} target="_blank" rel="noopener" class="qr-btn qr-btn--ghost">URL öffnen ↗</a>
          </div>
        </div>
      </div>
    ) : (
      <div class="qr-empty">
        <p class="qr-empty-icon">⚠</p>
        <p class="qr-empty-text">
          Kein aktiver Stay mit access_token gefunden — Hotel-QR kann erst generiert werden, wenn mindestens
          ein Stay den Status <code>Confirmed</code> oder <code>Started</code> hat. Sobald das Pre-Arrival-Pairing
          läuft oder via Mews-Sync ein Stay aktiviert wurde, erscheint hier der QR.
        </p>
      </div>
    )}
  </section>

  <!-- Pro-Zimmer-QRs -->
  <section class="qr-section">
    <h2 class="qr-section-title">Pro-Zimmer QR-Codes</h2>
    <p class="qr-section-desc">Aushang im Zimmer (z.B. Holzkarte am Bett). Gast scannt → automatisches Pairing mit aktivem Stay im Zimmer.</p>

    {roomsWithCode.length === 0 ? (
      <div class="qr-empty">
        <p class="qr-empty-icon">⚠</p>
        <p class="qr-empty-text">
          {roomsList.length === 0 ? (
            <>
              Aktuell sind keine Räume mit gültigem <code>room_code</code> verknüpft.
              Räume werden nach dem Mews-Room-Sync verfügbar — der Sync läuft aktuell auf einen Bug (Backlog),
              sodass die Räume zwar in der Mews-DB existieren, aber nicht korrekt auf dieses Hotel gemappt werden.
              Sobald gefixt, erscheinen hier alle Zimmer-QRs.
            </>
          ) : (
            <>
              Es gibt <strong>{roomsList.length}</strong> Räume, aber keiner hat einen <code>room_code</code>.
              Der Code wird beim Pairing-Setup vergeben — bitte zuerst den Sprint-D-Phase-3-Pairing-Flow durchlaufen.
            </>
          )}
        </p>
      </div>
    ) : (
      <div class="qr-grid">
        {roomsWithCode.map((r: any) => {
          const roomUrl = buildGuestRoomUrl(r.room_code, Astro.request.url);
          const label = [r.room_number, r.room_name].filter(Boolean).join(' · ');
          return (
            <article class="qr-room-card">
              <div class="qr-room-head">
                <p class="qr-room-number">{r.room_number || '—'}</p>
                {r.room_name && <p class="qr-room-name">{r.room_name}</p>}
              </div>
              <img src={`/api/qr/room/${r.room_code}?format=svg`} alt={`QR ${label}`} class="qr-image qr-image--sm" />
              <code class="qr-room-code">{r.room_code}</code>
              <div class="qr-downloads qr-downloads--sm">
                <a href={`/api/qr/room/${r.room_code}?format=svg&download=1`} class="qr-btn qr-btn--secondary qr-btn--sm">SVG</a>
                <a href={`/api/qr/room/${r.room_code}?format=png&download=1`} class="qr-btn qr-btn--secondary qr-btn--sm">PNG</a>
              </div>
              <a href={roomUrl} target="_blank" rel="noopener" class="qr-room-url">{roomUrl}</a>
            </article>
          );
        })}
      </div>
    )}
  </section>

  <!-- Druck-Export (Phase 6) -->
  <section class="qr-section">
    <h2 class="qr-section-title">Drucken / PDF-Export</h2>
    <p class="qr-section-desc">
      Print-CSS-optimierte Druckansicht. Browser-Druck-Dialog → „Als PDF speichern" funktioniert plattformübergreifend
      ohne zusätzliche Software.
    </p>

    <div class="print-grid">
      <a href="/app/qr/print?mode=rooms" target="_blank" rel="noopener" class="print-card">
        <p class="print-card-eyebrow">— Zimmer-Bogen —</p>
        <p class="print-card-title">A4 Grid · 3×4 = 12 QRs pro Seite</p>
        <p class="print-card-desc">
          Alle Zimmer-QRs zum Ausdrucken und Ausschneiden. Pro Zelle: Hotel-Name, Zimmer-Nummer, QR-Code, room_code.
          {roomsWithCode.length === 0
            ? ' (Aktuell 0 rooms → zeigt Hotel-weiten QR als Fallback.)'
            : ` Aktuell ${roomsWithCode.length} Zimmer.`}
        </p>
        <span class="print-card-cta">Öffnen ↗</span>
      </a>

      <a href="/app/qr/print?mode=tisch" target="_blank" rel="noopener" class="print-card">
        <p class="print-card-eyebrow">— Tischaufsteller —</p>
        <p class="print-card-title">A4 Hochformat · Hotel-weit</p>
        <p class="print-card-desc">
          Großer Hotel-QR mit Hotel-Name und „Scannen für WLAN, Frühstück, Empfehlungen & mehr".
          Für Rezeption, Lobby, Frühstücksraum.
        </p>
        <span class="print-card-cta">Öffnen ↗</span>
      </a>
    </div>
  </section>

  <style>
    .app-page-header { margin-bottom: 32px; }
    .app-page-eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .45, transparent); margin: 0 0 8px; }
    .app-page-title { font-size: 26px; font-weight: 300; letter-spacing: -0.01em; margin: 0 0 10px; color: var(--theme-text-primary); }
    @media (min-width: 768px) { .app-page-title { font-size: 32px; } }
    .app-page-sub { margin: 0; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }
    .env-code { background: color-mix(in srgb, var(--theme-text-primary) .06, transparent); padding: 2px 8px; font-family: var(--theme-font-mono); font-size: 12px; color: var(--theme-text-primary); }
    .env-note { margin-left: 8px; font-size: 11px; padding: 2px 8px; background: #e8f5ec; color: #145c2a; border: 1px solid #a8d9b6; }
    .env-note--dev { background: #fff8e1; color: #8a5800; border-color: #f5d77a; }

    .qr-section { margin-bottom: 40px; }
    .qr-section-title { margin: 0 0 8px; font-size: 16px; font-weight: 500; color: var(--theme-text-primary); }
    .qr-section-desc { margin: 0 0 20px; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }

    .qr-card { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 24px; display: grid; grid-template-columns: 1fr; gap: 24px; }
    @media (min-width: 768px) { .qr-card { grid-template-columns: auto 1fr; align-items: start; } }
    .qr-preview { display: flex; justify-content: center; }
    .qr-image { display: block; width: 240px; height: 240px; }
    .qr-image--sm { width: 160px; height: 160px; margin: 8px 0; }
    .qr-meta { display: flex; flex-direction: column; }
    .qr-meta-label { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin-bottom: 4px; }
    .qr-meta-url { display: inline-block; background: color-mix(in srgb, var(--theme-text-primary) .06, transparent); padding: 6px 10px; font-family: var(--theme-font-mono); font-size: 12px; word-break: break-all; color: var(--theme-text-primary); }
    .qr-meta-note { margin: 6px 0 0; font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); line-height: 1.5; }

    .qr-downloads { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; }
    .qr-downloads--sm { margin-top: 8px; }
    .qr-btn { padding: 8px 14px; font-size: 13px; font-weight: 500; border: 1px solid; cursor: pointer; text-decoration: none; transition: background .15s; }
    .qr-btn--sm { padding: 4px 10px; font-size: 11px; }
    .qr-btn--primary { background: var(--theme-accent); color: var(--theme-bg-primary); border-color: var(--theme-accent); }
    .qr-btn--primary:hover { background: var(--theme-accent-hover); }
    .qr-btn--secondary { background: transparent; color: color-mix(in srgb, var(--theme-text-primary) .85, transparent); border-color: var(--theme-border); }
    .qr-btn--secondary:hover { background: var(--theme-bg-tertiary); }
    .qr-btn--ghost { background: transparent; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); border-color: transparent; }
    .qr-btn--ghost:hover { color: var(--theme-text-primary); }

    .qr-empty { padding: 32px 24px; background: var(--theme-bg-primary); border: 1px dashed var(--theme-border); text-align: center; }
    .qr-empty-icon { font-size: 32px; color: #b45309; margin: 0 0 12px; line-height: 1; }
    .qr-empty-text { font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); margin: 0; line-height: 1.6; max-width: 560px; margin-left: auto; margin-right: auto; }
    .qr-empty-text code { background: color-mix(in srgb, var(--theme-text-primary) .06, transparent); padding: 1px 6px; font-family: var(--theme-font-mono); font-size: 12px; }

    .qr-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
    .qr-room-card { background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 16px; display: flex; flex-direction: column; align-items: center; text-align: center; }
    .qr-room-head { margin-bottom: 4px; }
    .qr-room-number { margin: 0; font-size: 18px; font-weight: 500; color: var(--theme-text-primary); }
    .qr-room-name { margin: 2px 0 0; font-size: 12px; color: color-mix(in srgb, var(--theme-text-primary) .55, transparent); }
    .qr-room-code { background: color-mix(in srgb, var(--theme-text-primary) .06, transparent); padding: 2px 8px; font-family: var(--theme-font-mono); font-size: 11px; color: color-mix(in srgb, var(--theme-text-primary) .7, transparent); }
    .qr-room-url { margin-top: 6px; font-size: 10px; color: color-mix(in srgb, var(--theme-text-primary) .4, transparent); word-break: break-all; text-decoration: none; }
    .qr-room-url:hover { color: var(--theme-accent); }

    .print-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
    @media (min-width: 768px) { .print-grid { grid-template-columns: 1fr 1fr; } }
    .print-card { display: block; background: var(--theme-bg-primary); border: 1px solid var(--theme-border); padding: 20px; text-decoration: none; color: inherit; transition: border-color .15s; }
    .print-card:hover { border-color: var(--theme-accent); }
    .print-card-eyebrow { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: color-mix(in srgb, var(--theme-text-primary) .5, transparent); margin: 0 0 8px; }
    .print-card-title { font-size: 16px; font-weight: 500; color: var(--theme-text-primary); margin: 0 0 8px; }
    .print-card-desc { font-size: 13px; color: color-mix(in srgb, var(--theme-text-primary) .6, transparent); margin: 0 0 12px; line-height: 1.5; }
    .print-card-cta { font-size: 13px; font-weight: 500; color: var(--theme-accent); }
  </style>
</AppLayout>
